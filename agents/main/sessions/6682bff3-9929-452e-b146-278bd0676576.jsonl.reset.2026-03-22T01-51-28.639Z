fault\n\n\ndef normalize_side(value: Any) -> str:\n    text = str(value or \"\").strip().upper()\n    if text in {\"BUY\", \"SELL\"}:\n        return text\n    if any(k in text for k in [\"买\", \"BUY\", \"B\", \"LONG\"]):\n        return \"BUY\"\n    if any(k in text for k in [\"卖\", \"SELL\", \"S\", \"SHORT\"]):\n        return \"SELL\"\n    return \"\"\n\n\ndef normalize_joinquant_code(value: Any) -> str:\n    raw = str(value or \"\").strip().upper()\n    if not raw or raw == \"NAN\":\n        return \"\"\n    if raw.endswith(\".XSHG\") or raw.endswith(\".XSHE\"):\n        return raw\n    if raw.endswith(\".SH\"):\n        return raw[:-3] + \".XSHG\"\n    if raw.endswith(\".SZ\"):\n        return raw[:-3] + \".XSHE\"\n    if raw.startswith(\"SH\") and len(raw) >= 8:\n        return f\"{raw[2:8]}.XSHG\"\n    if raw.startswith(\"SZ\") and len(raw) >= 8:\n        return f\"{raw[2:8]}.XSHE\"\n    if raw.isdigit() and len(raw) == 6:\n        market = \"XSHG\" if raw.startswith((\"5\", \"6\", \"9\")) else \"XSHE\"\n        return f\"{raw}.{market}\"\n    return raw\n\n\ndef to_tushare_code(joinquant_code: str) -> str:\n    code = normalize_joinquant_code(joinquant_code)\n    if \".\" not in code:\n        return \"\"\n    symbol, market = code.split(\".\", 1)\n    if market == \"XSHG\":\n        return f\"{symbol}.SH\"\n    if market == \"XSHE\":\n        return f\"{symbol}.SZ\"\n    return \"\"\n\n\ndef count_csv_rows(path: Path) -> int:\n    if not path.exists():\n        return 0\n    try:\n        with path.open(\"r\", encoding=\"utf-8\", newline=\"\") as handle:\n            return max(0, sum(1 for _ in handle) - 1)\n    except Exception:\n        return 0\n\n\ndef ensure_parent(path: Path) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n\n\ndef live_ticket_path(date_tag: str) -> Path:\n    return REPORT_DIR / f\"stock_signal_tickets_live_{date_tag}.csv\"\n\n\ndef legacy_ticket_path(date_tag: str) -> Path:\n    return REPORT_DIR / f\"stock_signal_tickets_{date_tag}.csv\"\n\n\ndef ticket_path(date_tag: str) -> Path:\n    return live_ticket_path(date_tag)\n\n\ndef summary_path(date_tag: str) -> Path:\n    return REPORT_DIR / f\"signal_ticket_bridge_summary_{date_tag}.json\"\n\n\ndef write_ticket_rows(path: Path, rows: list[dict[str, Any]]) -> None:\n    ensure_parent(path)\n    frame = pd.DataFrame(rows, columns=DEFAULT_HEADER) if rows else pd.DataFrame(columns=DEFAULT_HEADER)\n    frame.to_csv(path, index=False, encoding=\"utf-8\")\n\n\ndef write_summary(path: Path, payload: dict[str, Any]) -> None:\n    ensure_parent(path)\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef load_live_candidate_settings() -> dict[str, Any]:\n    settings = dict(DEFAULT_LIVE_CANDIDATE_SETTINGS)\n    if not LIVE_TRADING_CONFIG_PATH.exists():\n        return settings\n    try:\n        payload = json.loads(LIVE_TRADING_CONFIG_PATH.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return settings\n\n    live_settings = payload.get(\"smallcap_live_candidates\", {}) or {}\n    if isinstance(live_settings, dict):\n        settings.update({k: v for k, v in live_settings.items() if v not in (None, \"\")})\n\n    config_value = str(settings.get(\"config\", \"\")).strip()\n    if config_value:\n        config_path = Path(config_value)\n        if not config_path.is_absolute():\n            config_path = (PROJECT_ROOT / config_path).resolve()\n        settings[\"config\"] = str(config_path)\n    return settings\n\n\ndef run_cmd(cmd: list[str], *, cwd: Path) -> dict[str, Any]:\n    proc = subprocess.run(cmd, cwd=str(cwd), capture_output=True, text=True)\n    return {\n        \"cmd\": cmd,\n        \"returncode\": proc.returncode,\n        \"stdout\": (proc.stdout or \"\").strip(),\n        \"stderr\": (proc.stderr or \"\").strip(),\n    }\n\n\ndef materialize_signal_chain(date_tag: str, available_cash: float, account_nav: float, *, force_rebuild: bool = False) -> list[dict[str, An