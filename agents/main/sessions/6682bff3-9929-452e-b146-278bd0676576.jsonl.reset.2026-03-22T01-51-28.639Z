{"type":"message","id":"c65d25ca","parentId":"36322653","timestamp":"2026-03-21T09:00:35.350Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Latest date is 20260319. Let me rewrite the script to use chunked reading and process only recent data. Also need to fix the market gate logic - the current one has bugs.","thinkingSignature":"7753ed69f028d6b80b97760ef684193442fa160fda2daa7b963725f46433857d"},{"type":"toolCall","id":"call_function_2uxtrcdnf54f_1","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_day1_3_mean_reversion_signals.py","content":"#!/usr/bin/env python3\n\"\"\"Generate day1-3 style mean reversion signals.\n\nOptimized version: reads only recent data to avoid memory issues.\n\"\"\"\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nDEFAULT_CONFIG = PROJECT_ROOT / \"config\" / \"day1_3_mean_reversion.yaml\"\n\n\ndef load_yaml(path: Path) -> dict[str, Any]:\n    data = yaml.safe_load(path.read_text(encoding=\"utf-8\"))\n    return data or {}\n\n\ndef normalize_ts_code(raw: str) -> str:\n    s = raw.strip().upper()\n    if not s or s == \"NAN\":\n        return \"\"\n    if s.endswith((\".SH\", \".SZ\", \".BJ\")):\n        return s\n    if s.startswith((\"60\", \"68\", \"90\")):\n        return f\"{s}.SH\"\n    if s.startswith((\"00\", \"30\")):\n        return f\"{s}.SZ\"\n    if s.startswith((\"4\", \"8\")):\n        return f\"{s}.BJ\"\n    return s\n\n\ndef load_recent_history(path: Path, target_date: str, lookback_days: int = 120) -> pd.DataFrame:\n    \"\"\"Load only recent history to save memory.\"\"\"\n    # Read in chunks and filter by date\n    dates = pd.read_csv(path, usecols=[\"trade_date\"], dtype={\"trade_date\": str})\n    dates = dates[\"trade_date\"].drop_duplicates().sort_values()\n    cutoff_date = str(int(target_date.replace(\"-\", \"\")) - lookback_days * 100)  # rough estimate\n    \n    chunks = []\n    for chunk in pd.read_csv(path, chunksize=500000, dtype={\"trade_date\": str}):\n        chunk = chunk[chunk[\"trade_date\"] >= cutoff_date]\n        if not chunk.empty:\n            chunks.append(chunk)\n    \n    if not chunks:\n        raise ValueError(f\"No data after cutoff {cutoff_date}\")\n    \n    df = pd.concat(chunks, ignore_index=True)\n    df[\"ts_code\"] = df[\"ts_code\"].map(normalize_ts_code)\n    df[\"trade_date\"] = pd.to_datetime(df[\"trade_date\"], format=\"%Y%m%d\", errors=\"coerce\")\n    return df.dropna(subset=[\"trade_date\", \"ts_code\", \"close\"]).sort_values([\"ts_code\", \"trade_date\"])\n\n\ndef load_fundamentals_recent(path: Path, target_date: str) -> pd.DataFrame:\n    \"\"\"Load fundamentals for target date.\"\"\"\n    cutoff = str(int(target_date.replace(\"-\", \"\")) - 500)\n    chunks = []\n    for chunk in pd.read_csv(path, chunksize=500000, dtype={\"trade_date\": str}):\n        chunk = chunk[chunk[\"trade_date\"] >= cutoff]\n        if not chunk.empty:\n            chunks.append(chunk)\n    \n    if not chunks:\n        return pd.DataFrame()\n    \n    df = pd.concat(chunks, ignore_index=True)\n    df[\"ts_code\"] = df[\"ts_code\"].map(normalize_ts_code)\n    df[\"trade_date\"] = pd.to_datetime(df[\"trade_date\"], format=\"%Y%m%d\", errors=\"coerce\")\n    return df.dropna(subset=[\"trade_date\", \"ts_code\"])\n\n\ndef compute_features(history: pd.DataFrame) -> pd.DataFrame:\n    \"\"\"Compute technical features.\"\"\"\n    g = history.groupby(\"ts_code\", group_keys=False)\n    work = history.copy()\n    \n    # Rolling features\n    work[\"ma10\"] = g[\"close\"].transform(lambda s: s.rolling(10, min_periods=5).mean())\n    work[\"ret5\"] = g[\"close\"].transform(lambda s: s.pct_change(5))\n    work[\"ret1\"] = g[\"close\"].transform(lambda s: s.pct_change(1))\n    work[\"hh20\"] = g[\"high\"].transform(lambda s: s.rolling(20, min_periods=10).max())\n    work[\"ll20\"] = g[\"low\"].transform(lambda s: s.rolling(20, min_periods=10).min())\n    \n    # Derived features\n    work[\"dist_ma10\"] = (work[\"close\"] / work[\"ma10\"] - 1.0).fillna(0)\n    rng = (work[\"hh20\"] - work[\"ll20\"]).replace(0, np.nan)\n    work[\"range_pos20\"] = ((work[\"close\"] - work[\"ll20\"]) / rng).clip(0, 1).fillna(0.5)\n    work[\"reversal_bar\"] = ((work[\"close\"] - work[\"open\"]) / work[\"open\"].replace(0, np.nan)).fillna(0)\n    \n    # Filter stocks with enough history\n    counts = g[\"close\"].transform(\"count\")\n    work = work[counts >= 40].copy()\n    \n    return work\n\n\ndef compute_market_gate(index_df: pd.DataFrame, history: pd.DataFrame, trade_date: pd.Timestamp, cfg: dict) -> dict:\n    \"\"\"Compute market regime (strong/neutral/weak).\"\"\"\n    # Get index data up to trade_date\n    idx = index_df[index_df[\"date\"] <= trade_date].copy()\n    if len(idx) < 20:\n        return {\"regime\": \"neutral\", \"breadth\": 0.5, \"trend\": 0.0, \"scale\": 0.6}\n    \n    idx[\"ma20\"] = idx[\"close\"].rolling(20, min_periods=10).mean()\n    latest_idx = idx.iloc[-1]\n    trend = float(latest_idx[\"close\"] / latest_idx[\"ma20\"] - 1.0) if pd.notna(latest_idx[\"ma20\"]) else 0.0\n    \n    # Compute breadth: % of stocks above their MA20\n    latest_hist = history[history[\"trade_date\"] == trade_date].copy()\n    if len(latest_hist) < 50:\n        return {\"regime\": \"neutral\", \"breadth\": 0.5, \"trend\": trend, \"scale\": 0.6}\n    \n    # Need MA20 for each stock\n    latest_hist[\"ma20\"] = latest_hist.groupby(\"ts_code\")[\"close\"].transform(lambda s: s.rolling(20, min_periods=10).mean())\n    latest_hist = latest_hist.dropna(subset=[\"ma20\"])\n    breadth = float((latest_hist[\"close\"] > latest_hist[\"ma20\"]).mean()) if len(latest_hist) else 0.5\n    \n    strong_breadth = cfg.get(\"strong_breadth\", 0.58)\n    neutral_breadth = cfg.get(\"neutral_breadth\", 0.48)\n    weak_floor = cfg.get(\"weak_index_trend_floor\", -0.03)\n    \n    if breadth >= strong_breadth and trend >= 0:\n        regime, scale = \"strong\", cfg.get(\"strong_scale\", 1.0)\n    elif breadth >= neutral_breadth and trend >= weak_floor:\n        regime, scale = \"neutral\", cfg.get(\"neutral_scale\", 0.6)\n    else:\n        regime, scale = \"weak\", cfg.get(\"weak_scale\", 0.3)\n    \n    return {\"regime\": regime, \"breadth\": round(breadth, 4), \"trend\": round(trend, 4), \"scale\": scale}\n\n\ndef compute_excess_return(history: pd.DataFrame, index_df: pd.DataFrame, trade_date: pd.Timestamp) -> pd.DataFrame:\n    \"\"\"Compute excess return vs HS300.\"\"\"\n    # Get index ret5\n    idx = index_df[index_df[\"date\"] <= trade_date].copy()\n    idx[\"ret5_idx\"] = idx[\"close\"].pct_change(5)\n    idx_today = idx[idx[\"date\"] == trade_date][[\"ret5_idx\"]].iloc[-1] if len(idx) else 0\n    \n    # Get stock ret5\n    latest = history[history[\"trade_date\"] == trade_date][[\"ts_code\", \"ret5\"]].copy()\n    latest[\"excess_ret5\"] = latest[\"ret5\"] - idx_today[\"ret5_idx\"]\n    return latest\n\n\ndef score_and_select(candidates: pd.DataFrame, weights: dict, gate: dict, cfg: dict) -> pd.DataFrame:\n    \"\"\"Score candidates and select top K.\"\"\"\n    if len(candidates) == 0:\n        return candidates\n    \n    df = candidates.copy()\n    \n    # Rank features (lower/negative = better for mean reversion)\n    df[\"rank_dist\"] = df[\"dist_ma10\"].rank(pct=True, ascending=True)\n    df[\"rank_ret5\"] = df[\"ret5\"].rank(pct=True, ascending=True)\n    df[\"rank_excess\"] = df[\"excess_ret5\"].rank(pct=True, ascending=True)\n    df[\"rank_range\"] = df[\"range_pos20\"].rank(pct=True, ascending=True)\n    df[\"rank_reversal\"] = df[\"reversal_bar\"].rank(pct=False)  # higher reversal = better\n    \n    # Weighted score\n    df[\"score\"] = (\n        weights.get(\"dist_ma10\", 0.30) * df[\"rank_dist\"] +\n        weights.get(\"ret5\", 0.25) * df[\"rank_ret5\"] +\n        weights.get(\"excess_ret5\", 0.20) * df[\"rank_excess\"] +\n        weights.get(\"range_pos20\", 0.15) * df[\"rank_range\"] +\n        weights.get(\"reversal\", 0.10) * df[\"rank_reversal\"]\n    )\n    \n    # Select top K\n    top_k = cfg.get(\"top_k\", 12)\n    df = df.nlargest(top_k, \"score\")\n    \n    # Allocate weights\n    total_exp = cfg.get(\"total_exposure\", 0.72) * gate[\"scale\"]\n    max_single = cfg.get(\"max_single_weight\", 0.08)\n    \n    raw_weights = df[\"score\"].clip(lower=0.001)\n    weights = (raw_weights / raw_weights.sum() * total_exp).clip(upper=max_single)\n    df[\"target_weight\"] = weights.round(4)\n    \n    return df\n\n\ndef main():\n    ap = argparse.ArgumentParser(description=\"Generate day1-3 mean reversion signals\")\n    ap.add_argument(\"--config\", default=str(DEFAULT_CONFIG))\n    ap.add_argument(\"--trade-date\", default=\"\", help=\"YYYY-MM-DD\")\n    args = ap.parse_args()\n    \n    cfg = load_yaml(Path(args.config).expanduser().resolve())\n    \n    # Determine target date\n    if args.trade_date:\n        target_date = args.trade_date\n    else:\n        # Find latest available date\n        hist_path = Path(cfg[\"history\"][\"csv\"]).expanduser()\n        dates = pd.read_csv(hist_path, usecols=[\"trade_date\"], dtype={\"trade_date\": str})\n        target_date = str(dates[\"trade_date\"].max())\n        # Format as YYYY-MM-DD\n        target_date = f\"{target_date[:4]}-{target_date[4:6]}-{target_date[6:]}\"\n    \n    trade_date = pd.to_datetime(target_date)\n    print(f\"Processing trade date: {target_date}\")\n    \n    # Load data\n    hist_cfg = cfg[\"history\"]\n    lookback = hist_cfg.get(\"lookback_calendar_days\", 120)\n    history = load_recent_history(Path(hist_cfg[\"csv\"]), target_date, lookback)\n    print(f\"Loaded history: {len(history)} rows, {history['ts_code'].nunique()} stocks\")\n    \n    fundamentals = load_fundamentals_recent(Path(cfg[\"fundamentals\"][\"csv\"]), target_date)\n    print(f\"Loaded fundamentals: {len(fundamentals)} rows\")\n    \n    # Compute features\n    features = compute_features(history)\n    latest = features[features[\"trade_date\"] == trade_date].copy()\n    print(f\"Latest date features: {len(latest)} stocks\")\n    \n    # Compute market gate\n    market_cfg = cfg[\"market\"]\n    index_df = pd.read_csv(Path(market_cfg[\"index_csv\"]).expanduser())\n    index_df[\"date\"] = pd.to_datetime(index_df[\"date\"], errors=\"coerce\")\n    gate = compute_market_gate(index_df, history, trade_date, market_cfg)\n    print(f\"Market regime: {gate['regime']}, breadth={gate['breadth']}, trend={gate['trend']}, scale={gate['scale']}\")\n    \n    # Merge fundamentals\n    f_latest = fundamentals[fundamentals[\"trade_date\"] == trade_date][[\"ts_code\", \"total_mv\", \"turnover_rate\"]].copy()\n    latest = latest.merge(f_latest, on=\"ts_code\", how=\"left\")\n    \n    # Compute excess return\n    excess = compute_excess_return(history, index_df, trade_date)\n    latest = latest.merge(excess[[\"ts_code\", \"excess_ret5\"]], on=\"ts_code\", how=\"left\")\n    \n    # Apply filters\n    sf = cfg.get(\"signal\", {})\n    fc = cfg.get(\"fundamentals\", {})\n    \n    filtered = latest.copy()\n    if \"close\" in filtered.columns:\n        filtered = filtered[filtered[\"close\"] >= fc.get(\"min_price\", 3.0)]\n    if \"total_mv\" in filtered.columns:\n        filtered = filtered[filtered[\"total_mv\"].fillna(0) >= fc.get(\"min_total_mv\", 0)]\n    filtered = filtered[filtered[\"amount\"].fillna(0) >= sf.get(\"min_amount\", 100_000_000)]\n    filtered = filtered[filtered[\"ret5\"] <= sf.get(\"max_ret5\", -0.02)]\n    filtered = filtered[filtered[\"dist_ma10\"] <= sf.get(\"max_dist_ma10\", -0.015)]\n    filtered = filtered[filtered[\"range_pos20\"] <= sf.get(\"max_range_pos20\", 0.45)]\n    \n    print(f\"After filters: {len(filtered)} candidates\")\n    \n    # Score and select\n    selected = score_and_select(filtered, sf.get(\"weights\", {}), gate, sf)\n    print(f\"Selected: {len(selected)} stocks\")\n    \n    # Generate outputs\n    tag = target_date.replace(\"-\", \"\")\n    out_cfg = cfg[\"outputs\"]\n    \n    # Candidate CSV\n    cand_path = Path(out_cfg[\"candidate_dir\"]) / f\"day1_3_candidates_{tag}.csv\"\n    cand_path.parent.mkdir(parents=True, exist_ok=True)\n    selected[[\"trade_date\", \"ts_code\", \"close\", \"ret5\", \"excess_ret5\", \"dist_ma10\", \"range_pos20\", \"score\", \"target_weight\"]].to_csv(cand_path, index=False)\n    \n    # RD Factor CSV (for overlay backtest)\n    factor_path = Path(out_cfg[\"rd_factor_dir\"]) / f\"day1_3_mean_reversion_factor_{tag}.csv\"\n    factor_path.parent.mkdir(parents=True, exist_ok=True)\n    selected[[\"trade_date\", \"ts_code\", \"score\"]].rename(columns={\"trade_date\": \"date\", \"ts_code\": \"instrument\"}).to_csv(factor_path, index=False)\n    \n    # Raw signal CSV\n    raw_path = Path(out_cfg[\"raw_signal_dir\"]) / f\"day1_3_mean_reversion_{tag}.csv\"\n    raw_path.parent.mkdir(parents=True, exist_ok=True)\n    raw = pd.DataFrame({\n        \"trade_date\": selected[\"trade_date\"].astype(str),\n        \"ts_code\": selected[\"ts_code\"],\n        \"signal_type\": \"BUY\",\n        \"score\": selected[\"score\"].round(6),\n        \"target_weight\": selected[\"target_weight\"],\n        \"strategy_id\": \"day1_3_mean_reversion\",\n        \"risk_flag\": gate[\"regime\"],\n        \"comment\": f\"day1_3|regime={gate['regime']}|breadth={gate['breadth']}\",\n        \"source_run_id\": f\"day1_3_{tag}\",\n        \"generated_at\": pd.Timestamp.now(tz=\"Asia/Shanghai\").isoformat(),\n    })\n    raw.to_csv(raw_path, index=False)\n    \n    # Summary JSON\n    summary = {\n        \"trade_date\": target_date,\n        \"market_regime\": gate[\"regime\"],\n        \"breadth\": gate[\"breadth\"],\n        \"index_trend\": gate[\"trend\"],\n        \"exposure_scale\": gate[\"scale\"],\n        \"candidates\": len(selected),\n        \"total_weight\": float(selected[\"target_weight\"].sum()) if len(selected) else 0,\n        \"files\": {\n            \"candidates\": str(cand_path),\n            \"factor\": str(factor_path),\n            \"raw\": str(raw_path),\n        }\n    }\n    sum_path = Path(out_cfg[\"summary_dir\"]) / f\"day1_3_summary_{tag}.json\"\n    sum_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2))\n    \n    print(json.dumps(summary, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":43893,"output":3747,"cacheRead":24928,"cacheWrite":0,"totalTokens":72568,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774083563401}}
