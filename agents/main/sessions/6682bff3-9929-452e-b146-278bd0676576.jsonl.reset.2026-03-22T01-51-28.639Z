{"type":"message","id":"3bcaaa88","parentId":"0951e0bf","timestamp":"2026-03-21T08:46:29.944Z","message":{"role":"toolResult","toolCallId":"call_8wUzvxEmHSkfUaipEWEQjAtu","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"Export normalized signal file for smallcap_chip_v4_2_alpha_recover.\n\n当前为主系统接入的第一版适配器：\n- 输入：人工/研究侧整理好的候选列表 CSV\n- 输出：标准化 signal CSV 到 signals/raw/\n\n输入 CSV 最低要求字段：\n- ts_code（或 code / symbol）\n可选字段：\n- score\n- target_weight\n- comment\n\n示例：\npython3 scripts/export_smallcap_v4_2_signal.py \\\n  --input research/reports/manual_smallcap_candidates_20260310.csv \\\n  --trade-date 2026-03-10\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nfrom pathlib import Path\nfrom datetime import datetime\nimport pandas as pd\n\n\nSTRATEGY_ID = \"smallcap_chip_v4_2\"\n\n\ndef normalize_code(value: str) -> str:\n    v = str(value).strip()\n    if v.endswith((\".SZ\", \".SH\", \".BJ\")):\n        return v\n    if v.startswith((\"60\", \"68\")):\n        return f\"{v}.SH\"\n    if v.startswith((\"00\", \"30\")):\n        return f\"{v}.SZ\"\n    if v.startswith((\"8\", \"4\")):\n        return f\"{v}.BJ\"\n    return v\n\n\ndef resolve_code_column(df: pd.DataFrame) -> str:\n    for col in [\"ts_code\", \"code\", \"symbol\"]:\n        if col in df.columns:\n            return col\n    raise ValueError(\"Input CSV must contain one of: ts_code, code, symbol\")\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser()\n    ap.add_argument(\"--input\", required=True, help=\"candidate csv path\")\n    ap.add_argument(\"--trade-date\", required=True, help=\"trade date, e.g. 2026-03-10\")\n    ap.add_argument(\"--output\", default=None, help=\"output path; default signals/raw/{strategy_id}_{trade_date}.csv\")\n    args = ap.parse_args()\n\n    input_path = Path(args.input)\n    if not input_path.exists():\n        raise FileNotFoundError(f\"input file not found: {input_path}\")\n\n    df = pd.read_csv(input_path)\n    code_col = resolve_code_column(df)\n\n    out = pd.DataFrame()\n    out[\"trade_date\"] = [args.trade_date] * len(df)\n    out[\"ts_code\"] = df[code_col].map(normalize_code)\n    out[\"signal_type\"] = \"BUY\"\n    out[\"score\"] = df[\"score\"] if \"score\" in df.columns else 1.0\n    out[\"target_weight\"] = df[\"target_weight\"] if \"target_weight\" in df.columns else None\n    out[\"strategy_id\"] = STRATEGY_ID\n    out[\"risk_flag\"] = \"normal\"\n    out[\"comment\"] = df[\"comment\"] if \"comment\" in df.columns else \"exported_from_candidate_list\"\n    out[\"source_run_id\"] = f\"{STRATEGY_ID}_{args.trade_date.replace('-', '')}\"\n    out[\"generated_at\"] = datetime.now().astimezone().isoformat()\n\n    out = out.drop_duplicates(subset=[\"trade_date\", \"ts_code\", \"strategy_id\"], keep=\"last\")\n\n    if args.output:\n        output_path = Path(args.output)\n    else:\n        base = Path(__file__).resolve().parents[1]\n        output_path = base / \"signals\" / \"raw\" / f\"{STRATEGY_ID}_{args.trade_date.replace('-', '')}.csv\"\n\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n    out.to_csv(output_path, index=False)\n    print(f\"wrote {len(out)} rows -> {output_path}\")\n\n\nif __name__ == \"__main__\":\n    main()"}],"details":{"status":"completed","exitCode":0,"durationMs":5,"aggregated":"#!/usr/bin/env python3\n\"\"\"Export normalized signal file for smallcap_chip_v4_2_alpha_recover.\n\n当前为主系统接入的第一版适配器：\n- 输入：人工/研究侧整理好的候选列表 CSV\n- 输出：标准化 signal CSV 到 signals/raw/\n\n输入 CSV 最低要求字段：\n- ts_code（或 code / symbol）\n可选字段：\n- score\n- target_weight\n- comment\n\n示例：\npython3 scripts/export_smallcap_v4_2_signal.py \\\n  --input research/reports/manual_smallcap_candidates_20260310.csv \\\n  --trade-date 2026-03-10\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nfrom pathlib import Path\nfrom datetime import datetime\nimport pandas as pd\n\n\nSTRATEGY_ID = \"smallcap_chip_v4_2\"\n\n\ndef normalize_code(value: str) -> str:\n    v = str(value).strip()\n    if v.endswith((\".SZ\", \".SH\", \".BJ\")):\n        return v\n    if v.startswith((\"60\", \"68\")):\n        return f\"{v}.SH\"\n    if v.startswith((\"00\", \"30\")):\n        return f\"{v}.SZ\"\n    if v.startswith((\"8\", \"4\")):\n        return f\"{v}.BJ\"\n    return v\n\n\ndef resolve_code_column(df: pd.DataFrame) -> str:\n    for col in [\"ts_code\", \"code\", \"symbol\"]:\n        if col in df.columns:\n            return col\n    raise ValueError(\"Input CSV must contain one of: ts_code, code, symbol\")\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser()\n    ap.add_argument(\"--input\", required=True, help=\"candidate csv path\")\n    ap.add_argument(\"--trade-date\", required=True, help=\"trade date, e.g. 2026-03-10\")\n    ap.add_argument(\"--output\", default=None, help=\"output path; default signals/raw/{strategy_id}_{trade_date}.csv\")\n    args = ap.parse_args()\n\n    input_path = Path(args.input)\n    if not input_path.exists():\n        raise FileNotFoundError(f\"input file not found: {input_path}\")\n\n    df = pd.read_csv(input_path)\n    code_col = resolve_code_column(df)\n\n    out = pd.DataFrame()\n    out[\"trade_date\"] = [args.trade_date] * len(df)\n    out[\"ts_code\"] = df[code_col].map(normalize_code)\n    out[\"signal_type\"] = \"BUY\"\n    out[\"score\"] = df[\"score\"] if \"score\" in df.columns else 1.0\n    out[\"target_weight\"] = df[\"target_weight\"] if \"target_weight\" in df.columns else None\n    out[\"strategy_id\"] = STRATEGY_ID\n    out[\"risk_flag\"] = \"normal\"\n    out[\"comment\"] = df[\"comment\"] if \"comment\" in df.columns else \"exported_from_candidate_list\"\n    out[\"source_run_id\"] = f\"{STRATEGY_ID}_{args.trade_date.replace('-', '')}\"\n    out[\"generated_at\"] = datetime.now().astimezone().isoformat()\n\n    out = out.drop_duplicates(subset=[\"trade_date\", \"ts_code\", \"strategy_id\"], keep=\"last\")\n\n    if args.output:\n        output_path = Path(args.output)\n    else:\n        base = Path(__file__).resolve().parents[1]\n        output_path = base / \"signals\" / \"raw\" / f\"{STRATEGY_ID}_{args.trade_date.replace('-', '')}.csv\"\n\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n    out.to_csv(output_path, index=False)\n    print(f\"wrote {len(out)} rows -> {output_path}\")\n\n\nif __name__ == \"__main__\":\n    main()","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774082789937}}
{"type":"message","id":"6c5abc77","parentId":"3bcaaa88","timestamp":"2026-03-21T08:46:29.950Z","message":{"role":"toolResult","toolCallId":"call_2BZYkA1jUPNPT2I6O9BMGjji","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"Export normalized signal file for smallcap_chip_v4_2b_fundamental_guard.\n\n第一版与 v4.2 接口保持一致，便于后续 merged signal 统一处理。\n输入 CSV 最低要求字段：\n- ts_code（或 code / symbol）\n可选字段：\n- score\n- target_weight\n- comment\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nfrom pathlib import Path\nfrom datetime import datetime\nimport pandas as pd\n\nSTRATEGY_ID = \"smallcap_chip_v4_2b\"\n\n\ndef normalize_code(value: str) -> str:\n    v = str(value).strip()\n    if v.endswith((\".SZ\", \".SH\", \".BJ\")):\n        return v\n    if v.startswith((\"60\", \"68\")):\n        return f\"{v}.SH\"\n    if v.startswith((\"00\", \"30\")):\n        return f\"{v}.SZ\"\n    if v.startswith((\"8\", \"4\")):\n        return f\"{v}.BJ\"\n    return v\n\n\ndef resolve_code_column(df: pd.DataFrame) -> str:\n    for col in [\"ts_code\", \"code\", \"symbol\"]:\n        if col in df.columns:\n            return col\n    raise ValueError(\"Input CSV must contain one of: ts_code, code, symbol\")\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser()\n    ap.add_argument(\"--input\", required=True)\n    ap.add_argument(\"--trade-date\", required=True)\n    ap.add_argument(\"--output\", default=None)\n    args = ap.parse_args()\n\n    input_path = Path(args.input)\n    if not input_path.exists():\n        raise FileNotFoundError(f\"input file not found: {input_path}\")\n\n    df = pd.read_csv(input_path)\n    code_col = resolve_code_column(df)\n\n    out = pd.DataFrame()\n    out[\"trade_date\"] = [args.trade_date] * len(df)\n    out[\"ts_code\"] = df[code_col].map(normalize_code)\n    out[\"signal_type\"] = \"BUY\"\n    out[\"score\"] = df[\"score\"] if \"score\" in df.columns else 1.0\n    out[\"target_weight\"] = df[\"target_weight\"] if \"target_weight\" in df.columns else None\n    out[\"strategy_id\"] = STRATEGY_ID\n    out[\"risk_flag\"] = \"normal\"\n    out[\"comment\"] = df[\"comment\"] if \"comment\" in df.columns else \"fundamental_guard_candidate\"\n    out[\"source_run_id\"] = f\"{STRATEGY_ID}_{args.trade_date.replace('-', '')}\"\n    out[\"generated_at\"] = datetime.now().astimezone().isoformat()\n\n    out = out.drop_duplicates(subset=[\"trade_date\", \"ts_code\", \"strategy_id\"], keep=\"last\")\n\n    if args.output:\n        output_path = Path(args.output)\n    else:\n        base = Path(__file__).resolve().parents[1]\n        output_path = base / \"signals\" / \"raw\" / f\"{STRATEGY_ID}_{args.trade_date.replace('-', '')}.csv\"\n\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n    out.to_csv(output_path, index=False)\n    print(f\"wrote {len(out)} rows -> {output_path}\")\n\n\nif __name__ == \"__main__\":\n    main()"}],"details":{"status":"completed","exitCode":0,"durationMs":11,"aggregated":"#!/usr/bin/env python3\n\"\"\"Export normalized signal file for smallcap_chip_v4_2b_fundamental_guard.\n\n第一版与 v4.2 接口保持一致，便于后续 merged signal 统一处理。\n输入 CSV 最低要求字段：\n- ts_code（或 code / symbol）\n可选字段：\n- score\n- target_weight\n- comment\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nfrom pathlib import Path\nfrom datetime import datetime\nimport pandas as pd\n\nSTRATEGY_ID = \"smallcap_chip_v4_2b\"\n\n\ndef normalize_code(value: str) -> str:\n    v = str(value).strip()\n    if v.endswith((\".SZ\", \".SH\", \".BJ\")):\n        return v\n    if v.startswith((\"60\", \"68\")):\n        return f\"{v}.SH\"\n    if v.startswith((\"00\", \"30\")):\n        return f\"{v}.SZ\"\n    if v.startswith((\"8\", \"4\")):\n        return f\"{v}.BJ\"\n    return v\n\n\ndef resolve_code_column(df: pd.DataFrame) -> str:\n    for col in [\"ts_code\", \"code\", \"symbol\"]:\n        if col in df.columns:\n            return col\n    raise ValueError(\"Input CSV must contain one of: ts_code, code, symbol\")\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser()\n    ap.add_argument(\"--input\", required=True)\n    ap.add_argument(\"--trade-date\", required=True)\n    ap.add_argument(\"--output\", default=None)\n    args = ap.parse_args()\n\n    input_path = Path(args.input)\n    if not input_path.exists():\n        raise FileNotFoundError(f\"input file not found: {input_path}\")\n\n    df = pd.read_csv(input_path)\n    code_col = resolve_code_column(df)\n\n    out = pd.DataFrame()\n    out[\"trade_date\"] = [args.trade_date] * len(df)\n    out[\"ts_code\"] = df[code_col].map(normalize_code)\n    out[\"signal_type\"] = \"BUY\"\n    out[\"score\"] = df[\"score\"] if \"score\" in df.columns else 1.0\n    out[\"target_weight\"] = df[\"target_weight\"] if \"target_weight\" in df.columns else None\n    out[\"strategy_id\"] = STRATEGY_ID\n    out[\"risk_flag\"] = \"normal\"\n    out[\"comment\"] = df[\"comment\"] if \"comment\" in df.columns else \"fundamental_guard_candidate\"\n    out[\"source_run_id\"] = f\"{STRATEGY_ID}_{args.trade_date.replace('-', '')}\"\n    out[\"generated_at\"] = datetime.now().astimezone().isoformat()\n\n    out = out.drop_duplicates(subset=[\"trade_date\", \"ts_code\", \"strategy_id\"], keep=\"last\")\n\n    if args.output:\n        output_path = Path(args.output)\n    else:\n        base = Path(__file__).resolve().parents[1]\n        output_path = base / \"signals\" / \"raw\" / f\"{STRATEGY_ID}_{args.trade_date.replace('-', '')}.csv\"\n\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n    out.to_csv(output_path, index=False)\n    print(f\"wrote {len(out)} rows -> {output_path}\")\n\n\nif __name__ == \"__main__\":\n    main()","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774082789944}}
