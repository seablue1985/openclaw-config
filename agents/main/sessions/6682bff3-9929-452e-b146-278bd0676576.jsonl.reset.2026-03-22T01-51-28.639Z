esearch/reports/investment_research_role_brief_soros_avatar_morning_20260319.json\n?? research/reports/investment_research_role_brief_soros_avatar_morning_20260319.md\n?? research/reports/investment_research_role_brief_soros_avatar_morning_20260320.json\n?? research/reports/investment_research_role_brief_soros_avatar_morning_20260320.md\n?? research/reports/investment_research_role_brief_soros_avatar_night_20260314.json\n?? research/reports/investment_research_role_brief_soros_avatar_night_20260314.md\n?? research/reports/investment_research_role_brief_soros_avatar_night_20260315.json\n?? research/reports/investment_research_role_brief_soros_avatar_night_20260315.md\n?? research/reports/investment_research_role_brief_soros_avatar_night_20260317.json\n?? research/reports/investment_research_role_brief_soros_avatar_night_20260317.md\n?? research/reports/investment_research_role_brief_soros_avatar_night_20260318.json\n?? research/reports/investment_research_role_brief_soros_avatar_night_20260318.md\n?? research/reports/investment_research_role_brief_soros_avatar_night_20260319.json\n?? research/reports/investment_research_role_brief_soros_avatar_night_20260319.md\n?? research/reports/investment_research_role_brief_trader_close_20260314.json\n?? research/reports/investment_research_role_brief_trader_close_20260314.md\n?? research/reports/investment_research_role_brief_trader_close_20260317.json\n?? research/reports/investment_research_role_brief_trader_close_20260317.md\n?? research/reports/investment_research_role_brief_trader_close_20260318.json\n?? research/reports/investment_research_role_brief_trader_close_20260318.md\n?? research/reports/investment_research_role_brief_trader_close_20260319.json\n?? research/reports/investment_research_role_brief_trader_close_20260319.md\n?? research/reports/investment_research_role_brief_trader_close_20260320.json\n?? research/reports/investment_research_role_brief_trader_close_20260320.md\n?? research/reports/investment_research_role_brief_trader_midday_20260314.json\n?? research/reports/investment_research_role_brief_trader_midday_20260314.md\n?? research/reports/investment_research_role_brief_trader_midday_20260316.json\n?? research/reports/investment_research_role_brief_trader_midday_20260316.md\n?? research/reports/investment_research_role_brief_trader_midday_20260317.json\n?? research/reports/investment_research_role_brief_trader_midday_20260317.md\n?? research/reports/investment_research_role_brief_trader_midday_20260318.json\n?? research/reports/investment_research_role_brief_trader_midday_20260318.md\n?? research/reports/investment_research_role_brief_trader_midday_20260319.json\n?? research/reports/investment_research_role_brief_trader_midday_20260319.md\n?? research/reports/investment_research_role_brief_trader_midday_20260320.json\n?? research/reports/investment_research_role_brief_trader_midday_20260320.md\n?? research/reports/investment_research_role_brief_trader_morning_20260315.json\n?? research/reports/investment_research_role_brief_trader_morning_20260316.json\n?? research/reports/investment_research_role_brief_trader_morning_20260316.md\n?? research/reports/investment_research_role_brief_trader_morning_20260317.json\n?? research/reports/investment_research_role_brief_trader_morning_20260317.md\n?? research/reports/investment_research_role_brief_trader_morning_20260318.json\n?? research/reports/investment_research_role_brief_trader_morning_20260318.md\n?? research/reports/investment_research_role_brief_trader_morning_20260319.json\n?? research/reports/investment_research_role_brief_trader_morning_20260319.md\n?? research/reports/investment_research_role_brief_trader_morning_20260320.json\n?? research/reports/investment_research_role_brief_trader_morning_20260320.md\n?? research/reports/investment_research_role_brief_trader_night_20260314.json\n?? research/reports/investment_research_role_brief_trader_night_20260314.md\n?? research/reports/investment_research_role_brief_trad