{"type":"message","id":"43896bfc","parentId":"04eaa7f5","timestamp":"2026-03-21T08:53:42.671Z","message":{"role":"toolResult","toolCallId":"call_BbczD4eCHsQ32zNwLRkpA65f","toolName":"exec","content":[{"type":"text","text":"parser.add_argument(\"--rd-file\", default=\"\", help=\"显式指定RD因子文件（CSV）\")\n    parser.add_argument(\"--tag\", default=datetime.now().strftime(\"%Y%m%d\"), help=\"输出标签\")\n    parser.add_argument(\"--check-only\", action=\"store_true\", help=\"只校验接入与覆盖率，不跑Qlib回测\")\n    args = parser.parse_args()\n\n    config_path = (PROJECT_ROOT / args.config).resolve() if not Path(args.config).is_absolute() else Path(args.config)\n    cfg = load_yaml(config_path)\n\n    if not bool(cfg.get(\"enabled\", True)):\n        print(json.dumps({\"status\": \"DISABLED\", \"config\": str(config_path)}, ensure_ascii=False, indent=2))\n        return\n\n    source_cfg = cfg.get(\"source\", {})\n    blend_cfg = cfg.get(\"blend\", {})\n    bt_cfg = cfg.get(\"backtest\", {})\n\n    source_dir = Path(source_cfg.get(\"root_dir\", \"\")).expanduser()\n    pattern = str(source_cfg.get(\"glob_pattern\", \"*.csv\"))\n\n    rd_file = Path(args.rd_file).expanduser() if args.rd_file else discover_latest_factor_file(source_dir, pattern)\n\n    if rd_file is None or not rd_file.exists():\n        payload = write_waiting_report(tag=args.tag, config_path=config_path, source_dir=source_dir)\n        print(json.dumps(payload, ensure_ascii=False, indent=2))\n        return\n\n    rd_signal, rd_meta = load_rd_factor_series(\n        file_path=rd_file,\n        date_col=str(source_cfg.get(\"date_col\", \"date\")),\n        symbol_col=str(source_cfg.get(\"symbol_col\", \"instrument\")),\n        score_col=str(source_cfg.get(\"score_col\", \"score\")),\n        encoding=str(source_cfg.get(\"encoding\", \"utf-8\")),\n    )\n\n    REPORT_DIR.mkdir(parents=True, exist_ok=True)\n    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n    if args.check_only:\n        preview = rd_signal.reset_index().rename(columns={\"datetime\": \"date\", \"instrument\": \"symbol\"}).head(50)\n        preview_path = REPORT_DIR / f\"rd_agent_factor_preview_{args.tag}.csv\"\n        preview.to_csv(preview_path, index=False)\n\n        payload = {\n            \"generated_at\": timestamp,\n            \"status\": \"CHECK_OK\",\n            \"config\": str(config_path),\n            \"rd_factor_file\": str(rd_file),\n            \"rd_meta\": rd_meta,\n            \"files\": {\"preview\": str(preview_path)},\n        }\n        out = REPORT_DIR / f\"rd_agent_integration_check_{args.tag}.json\"\n        out.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n        print(json.dumps(payload, ensure_ascii=False, indent=2))\n        return\n\n    # 1) 基线信号\n    breadth = sanity.load_market_breadth()\n    pred, start_date, end_date = sanity.train_prediction()\n    base_signal = sanity.shift_signal_one_day(pred)\n\n    # 2) 融合信号\n    base_weight = float(blend_cfg.get(\"base_weight\", 0.75))\n    rd_weight = float(blend_cfg.get(\"rd_weight\", 0.25))\n    fill_missing = float(blend_cfg.get(\"fill_missing_rd_score\", 0.0))\n\n    blended_signal, merged_df, coverage_stats = build_blended_signal(\n        base_signal=base_signal,\n        rd_signal=rd_signal,\n        base_weight=base_weight,\n        rd_weight=rd_weight,\n        fill_missing_rd_score=fill_missing,\n    )\n\n    # 3) 同参数回测对比\n    profile = bt_cfg.get(\"breadth_profile\", {})\n    base_result = sanity.run_backtest_once(\n        pred_shifted=base_signal,\n        start_date=start_date,\n        end_date=end_date,\n        breadth=breadth,\n        topk=int(bt_cfg.get(\"topk\", 10)),\n        n_drop=int(bt_cfg.get(\"n_drop\", 1)),\n        hold_thresh=int(bt_cfg.get(\"hold_thresh\", 4)),\n        risk_degree=float(bt_cfg.get(\"risk_degree\", 0.5)),\n        profile={\n            \"low_th\": float(profile.get(\"low_th\", 0.48)),\n            \"mid_th\": float(profile.get(\"mid_th\", 0.55)),\n            \"low_scale\": float(profile.get(\"low_scale\", 0.30)),\n            \"mid_scale\": float(profile.get(\"mid_scale\", 0.60)),\n            \"high_scale\": float(profile.get(\"high_scale\", 0.95)),\n        },\n    )\n\n    blended_result = sanity.run_backtest_once(\n        pred_shifted=blended_signal,\n        start_date=start_date,\n        end_date=end_date,\n        breadth=breadth,\n        topk=int(bt_cfg.get(\"topk\", 10)),\n        n_drop=int(bt_cfg.get(\"n_drop\", 1)),\n        hold_thresh=int(bt_cfg.get(\"hold_thresh\", 4)),\n        risk_degree=float(bt_cfg.get(\"risk_degree\", 0.5)),\n        profile={\n            \"low_th\": float(profile.get(\"low_th\", 0.48)),\n            \"mid_th\": float(profile.get(\"mid_th\", 0.55)),\n            \"low_scale\": float(profile.get(\"low_scale\", 0.30)),\n            \"mid_scale\": float(profile.get(\"mid_scale\", 0.60)),\n            \"high_scale\": float(profile.get(\"high_scale\", 0.95)),\n        },\n    )\n\n    # 4) 输出\n    signal_out = REPORT_DIR / f\"rd_agent_overlay_signal_{args.tag}.csv\"\n    out_df = merged_df.reset_index().rename(columns={\"datetime\": \"date\", \"instrument\": \"symbol\"})\n    out_df.to_csv(signal_out, index=False)\n\n    base_result = to_serializable(base_result)\n    blended_result = to_serializable(blended_result)\n\n    compare = {\n        \"annual_return_pct_delta\": round(\n            float(blended_result.get(\"annual_return_pct\", 0.0) - base_result.get(\"annual_return_pct\", 0.0)), 2\n        ),\n        \"max_drawdown_pct_delta\": round(\n            float(blended_result.get(\"max_drawdown_pct\", 0.0) - base_result.get(\"max_drawdown_pct\", 0.0)), 2\n        ),\n        \"sharpe_delta\": round(float(blended_result.get(\"sharpe\", 0.0) - base_result.get(\"sharpe\", 0.0)), 3),\n        \"recent_annual_return_pct_delta\": round(\n            float(\n                blended_result.get(\"recent_annual_return_pct\", 0.0)\n                - base_result.get(\"recent_annual_return_pct\", 0.0)\n            ),\n            2,\n        ),\n        \"recent_max_drawdown_pct_delta\": round(\n            float(\n                blended_result.get(\"recent_max_drawdown_pct\", 0.0)\n                - base_result.get(\"recent_max_drawdown_pct\", 0.0)\n            ),\n            2,\n        ),"}],"details":{"status":"completed","exitCode":0,"durationMs":8,"aggregated":"parser.add_argument(\"--rd-file\", default=\"\", help=\"显式指定RD因子文件（CSV）\")\n    parser.add_argument(\"--tag\", default=datetime.now().strftime(\"%Y%m%d\"), help=\"输出标签\")\n    parser.add_argument(\"--check-only\", action=\"store_true\", help=\"只校验接入与覆盖率，不跑Qlib回测\")\n    args = parser.parse_args()\n\n    config_path = (PROJECT_ROOT / args.config).resolve() if not Path(args.config).is_absolute() else Path(args.config)\n    cfg = load_yaml(config_path)\n\n    if not bool(cfg.get(\"enabled\", True)):\n        print(json.dumps({\"status\": \"DISABLED\", \"config\": str(config_path)}, ensure_ascii=False, indent=2))\n        return\n\n    source_cfg = cfg.get(\"source\", {})\n    blend_cfg = cfg.get(\"blend\", {})\n    bt_cfg = cfg.get(\"backtest\", {})\n\n    source_dir = Path(source_cfg.get(\"root_dir\", \"\")).expanduser()\n    pattern = str(source_cfg.get(\"glob_pattern\", \"*.csv\"))\n\n    rd_file = Path(args.rd_file).expanduser() if args.rd_file else discover_latest_factor_file(source_dir, pattern)\n\n    if rd_file is None or not rd_file.exists():\n        payload = write_waiting_report(tag=args.tag, config_path=config_path, source_dir=source_dir)\n        print(json.dumps(payload, ensure_ascii=False, indent=2))\n        return\n\n    rd_signal, rd_meta = load_rd_factor_series(\n        file_path=rd_file,\n        date_col=str(source_cfg.get(\"date_col\", \"date\")),\n        symbol_col=str(source_cfg.get(\"symbol_col\", \"instrument\")),\n        score_col=str(source_cfg.get(\"score_col\", \"score\")),\n        encoding=str(source_cfg.get(\"encoding\", \"utf-8\")),\n    )\n\n    REPORT_DIR.mkdir(parents=True, exist_ok=True)\n    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n    if args.check_only:\n        preview = rd_signal.reset_index().rename(columns={\"datetime\": \"date\", \"instrument\": \"symbol\"}).head(50)\n        preview_path = REPORT_DIR / f\"rd_agent_factor_preview_{args.tag}.csv\"\n        preview.to_csv(preview_path, index=False)\n\n        payload = {\n            \"generated_at\": timestamp,\n            \"status\": \"CHECK_OK\",\n            \"config\": str(config_path),\n            \"rd_factor_file\": str(rd_file),\n            \"rd_meta\": rd_meta,\n            \"files\": {\"preview\": str(preview_path)},\n        }\n        out = REPORT_DIR / f\"rd_agent_integration_check_{args.tag}.json\"\n        out.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n        print(json.dumps(payload, ensure_ascii=False, indent=2))\n        return\n\n    # 1) 基线信号\n    breadth = sanity.load_market_breadth()\n    pred, start_date, end_date = sanity.train_prediction()\n    base_signal = sanity.shift_signal_one_day(pred)\n\n    # 2) 融合信号\n    base_weight = float(blend_cfg.get(\"base_weight\", 0.75))\n    rd_weight = float(blend_cfg.get(\"rd_weight\", 0.25))\n    fill_missing = float(blend_cfg.get(\"fill_missing_rd_score\", 0.0))\n\n    blended_signal, merged_df, coverage_stats = build_blended_signal(\n        base_signal=base_signal,\n        rd_signal=rd_signal,\n        base_weight=base_weight,\n        rd_weight=rd_weight,\n        fill_missing_rd_score=fill_missing,\n    )\n\n    # 3) 同参数回测对比\n    profile = bt_cfg.get(\"breadth_profile\", {})\n    base_result = sanity.run_backtest_once(\n        pred_shifted=base_signal,\n        start_date=start_date,\n        end_date=end_date,\n        breadth=breadth,\n        topk=int(bt_cfg.get(\"topk\", 10)),\n        n_drop=int(bt_cfg.get(\"n_drop\", 1)),\n        hold_thresh=int(bt_cfg.get(\"hold_thresh\", 4)),\n        risk_degree=float(bt_cfg.get(\"risk_degree\", 0.5)),\n        profile={\n            \"low_th\": float(profile.get(\"low_th\", 0.48)),\n            \"mid_th\": float(profile.get(\"mid_th\", 0.55)),\n            \"low_scale\": float(profile.get(\"low_scale\", 0.30)),\n            \"mid_scale\": float(profile.get(\"mid_scale\", 0.60)),\n            \"high_scale\": float(profile.get(\"high_scale\", 0.95)),\n        },\n    )\n\n    blended_result = sanity.run_backtest_once(\n        pred_shifted=blended_signal,\n        start_date=start_date,\n        end_date=end_date,\n        breadth=breadth,\n        topk=int(bt_cfg.get(\"topk\", 10)),\n        n_drop=int(bt_cfg.get(\"n_drop\", 1)),\n        hold_thresh=int(bt_cfg.get(\"hold_thresh\", 4)),\n        risk_degree=float(bt_cfg.get(\"risk_degree\", 0.5)),\n        profile={\n            \"low_th\": float(profile.get(\"low_th\", 0.48)),\n            \"mid_th\": float(profile.get(\"mid_th\", 0.55)),\n            \"low_scale\": float(profile.get(\"low_scale\", 0.30)),\n            \"mid_scale\": float(profile.get(\"mid_scale\", 0.60)),\n            \"high_scale\": float(profile.get(\"high_scale\", 0.95)),\n        },\n    )\n\n    # 4) 输出\n    signal_out = REPORT_DIR / f\"rd_agent_overlay_signal_{args.tag}.csv\"\n    out_df = merged_df.reset_index().rename(columns={\"datetime\": \"date\", \"instrument\": \"symbol\"})\n    out_df.to_csv(signal_out, index=False)\n\n    base_result = to_serializable(base_result)\n    blended_result = to_serializable(blended_result)\n\n    compare = {\n        \"annual_return_pct_delta\": round(\n            float(blended_result.get(\"annual_return_pct\", 0.0) - base_result.get(\"annual_return_pct\", 0.0)), 2\n        ),\n        \"max_drawdown_pct_delta\": round(\n            float(blended_result.get(\"max_drawdown_pct\", 0.0) - base_result.get(\"max_drawdown_pct\", 0.0)), 2\n        ),\n        \"sharpe_delta\": round(float(blended_result.get(\"sharpe\", 0.0) - base_result.get(\"sharpe\", 0.0)), 3),\n        \"recent_annual_return_pct_delta\": round(\n            float(\n                blended_result.get(\"recent_annual_return_pct\", 0.0)\n                - base_result.get(\"recent_annual_return_pct\", 0.0)\n            ),\n            2,\n        ),\n        \"recent_max_drawdown_pct_delta\": round(\n            float(\n                blended_result.get(\"recent_max_drawdown_pct\", 0.0)\n                - base_result.get(\"recent_max_drawdown_pct\", 0.0)\n            ),\n            2,\n        ),","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774083222661}}
{"type":"message","id":"13867100","parentId":"43896bfc","timestamp":"2026-03-21T08:54:07.505Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Implementing stock data scripts**\n\nI’m focusing on creating a single script to output various CSV formats, including candidate CSV and summary JSON. I’ll need to reuse data from a_stock_history.csv for this. Since the user wants to start from scratch, I should ensure this first version includes standard data like date, instrument, score, and raw signals. \n\nI’ll load the price data, calculate returns, and compute various metrics like moving averages and deviations based on specified conditions.**Developing heuristic matching for XHS**\n\nI need to create a simple heuristic for matching XHS posts. First, I’ll calculate the relative strength by comparing the returns, specifically ret_5 with hs300_ret_5. I’m also considering a low5 rebound metric that looks at the closing price relative to the 10-day rolling minimum.\n\nFor scoring, I want more negative deviation or returns to contribute positively, along with a positive rebound today. I’ll assess the market state based on index close versus moving averages and output a scaled state as strong, neutral, or weak.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_9EVZ7XM4YBnEL9YPkf8jLdcj","name":"exec","arguments":{"command":"sed -n '1,160p' /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_rd_agent_factor_overlay_backtest.py","workdir":"/Users/ling/.openclaw/workspace","timeout":30}}],"api":"openai-completions","provider":"gmn","model":"gpt-5.4","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774083222676}}
{"type":"message","id":"b8d03f8f","parentId":"13867100","timestamp":"2026-03-21T08:54:07.574Z","message":{"role":"toolResult","toolCallId":"call_9EVZ7XM4YBnEL9YPkf8jLdcj","toolName":"exec","content":[{"type":"text","text":"from __future__ import annotations\n\nimport argparse\nimport json\nimport re\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\n\nimport sys\n\nsys.path.append(str(PROJECT_ROOT / \"scripts\"))\nimport run_qlib_breadth_sanity_check as sanity  # noqa: E402\n\n\ndef load_yaml(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        raise FileNotFoundError(f\"配置文件不存在: {path}\")\n    data = yaml.safe_load(path.read_text(encoding=\"utf-8\"))\n    return data or {}\n\n\ndef normalize_symbol(raw: Any) -> str | None:\n    \"\"\"\n    统一成 Qlib 预测信号里常见的代码格式：SH600000 / SZ000001 / BJ430001。\n    兼容输入：600000.SH、SH600000、600000。\n    \"\"\"\n    if raw is None:\n        return None\n\n    s = str(raw).strip().upper()\n    if not s:\n        return None\n\n    # 600000.SH -> SH600000\n    if \".\" in s:\n        code, suffix = s.split(\".\", 1)\n        code = re.sub(r\"[^0-9A-Z]\", \"\", code)\n        suffix = re.sub(r\"[^0-9A-Z]\", \"\", suffix)\n        if code and suffix:\n            if suffix in {\"SH\", \"SZ\", \"BJ\", \"HK\"}:\n                return f\"{suffix}{code}\"\n            return f\"{suffix}{code}\"\n\n    token = re.sub(r\"[^0-9A-Z]\", \"\", s)\n\n    # 已经是 SH600000 这种\n    if re.match(r\"^(SH|SZ|BJ|HK)\\d+$\", token):\n        return token\n\n    # 纯数字自动补市场前缀\n    if token.isdigit():\n        if len(token) == 6:\n            if token.startswith((\"4\", \"8\")):\n                return f\"BJ{token}\"\n            if token.startswith((\"5\", \"6\", \"9\")):\n                return f\"SH{token}\"\n            return f\"SZ{token}\"\n        if len(token) == 5:\n            return f\"HK{token}\"\n\n    return token or None\n\n\ndef discover_latest_factor_file(root_dir: Path, pattern: str) -> Path | None:\n    if not root_dir.exists():\n        return None\n    files = [p for p in root_dir.glob(pattern) if p.is_file()]\n    if not files:\n        return None\n    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)\n    return files[0]\n\n\ndef load_rd_factor_series(\n    file_path: Path,\n    date_col: str,\n    symbol_col: str,\n    score_col: str,\n    encoding: str = \"utf-8\",\n) -> tuple[pd.Series, dict[str, Any]]:\n    df = pd.read_csv(file_path, encoding=encoding)\n\n    missing = [c for c in [date_col, symbol_col, score_col] if c not in df.columns]\n    if missing:\n        raise ValueError(f\"因子文件缺少字段: {missing}, file={file_path}\")\n\n    work = df[[date_col, symbol_col, score_col]].copy()\n    work.columns = [\"date\", \"symbol\", \"rd_score\"]\n\n    work[\"date\"] = pd.to_datetime(work[\"date\"], errors=\"coerce\")\n    work[\"symbol\"] = work[\"symbol\"].map(normalize_symbol)\n    work[\"rd_score\"] = pd.to_numeric(work[\"rd_score\"], errors=\"coerce\")\n\n    work = work.dropna(subset=[\"date\", \"symbol\", \"rd_score\"])\n    work[\"date\"] = work[\"date\"].dt.normalize()\n\n    if work.empty:\n        raise ValueError(f\"因子文件清洗后为空: {file_path}\")\n\n    agg = work.groupby([\"date\", \"symbol\"], as_index=True)[\"rd_score\"].mean().sort_index()\n    agg.index = pd.MultiIndex.from_tuples(agg.index, names=[\"datetime\", \"instrument\"])\n\n    meta = {\n        \"rows_raw\": int(len(df)),\n        \"rows_clean\": int(len(work)),\n        \"rows_grouped\": int(len(agg)),\n        \"date_min\": str(work[\"date\"].min().date()),\n        \"date_max\": str(work[\"date\"].max().date()),\n        \"symbols\": int(work[\"symbol\"].nunique()),\n    }\n    return agg, meta\n\n\ndef cs_zscore(series: pd.Series) -> pd.Series:\n    def _z(x: pd.Series) -> pd.Series:\n        std = float(x.std(ddof=0))\n        if std < 1e-12 or np.isnan(std):\n            return pd.Series(0.0, index=x.index)\n        return (x - x.mean()) / std\n\n    return series.groupby(level=0).transform(_z)\n\n\ndef build_blended_signal(\n    base_signal: pd.Series,\n    rd_signal: pd.Series,\n    base_weight: float,\n    rd_weight: float,\n    fill_missing_rd_score: float,\n) -> tuple[pd.Series, pd.DataFrame, dict[str, Any]]:\n    merged = base_signal.rename(\"base_score\").to_frame().join(rd_signal.rename(\"rd_score\"), how=\"left\")\n    merged = merged.sort_index()\n\n    merged[\"rd_score_filled\"] = merged[\"rd_score\"].fillna(fill_missing_rd_score)\n    merged[\"base_z\"] = cs_zscore(merged[\"base_score\"])\n    merged[\"rd_z\"] = cs_zscore(merged[\"rd_score_filled\"])\n    merged[\"blended_score\"] = base_weight * merged[\"base_z\"] + rd_weight * merged[\"rd_z\"]\n\n    covered = int(merged[\"rd_score\"].notna().sum())\n    total = int(len(merged))\n    coverage_ratio = covered / total if total > 0 else 0.0\n\n    coverage_by_day = merged[\"rd_score\"].notna().groupby(level=0).mean()\n\n    stats = {\n        \"base_rows\": total,\n        \"rd_covered_rows\": covered,\n        \"coverage_ratio\": round(float(coverage_ratio), 4),\n        \"coverage_daily_mean\": round(float(coverage_by_day.mean()), 4) if not coverage_by_day.empty else 0.0,\n        \"coverage_daily_p25\": round(float(coverage_by_day.quantile(0.25)), 4) if not coverage_by_day.empty else 0.0,\n        \"coverage_daily_p50\": round(float(coverage_by_day.quantile(0.50)), 4) if not coverage_by_day.empty else 0.0,\n        \"coverage_daily_p75\": round(float(coverage_by_day.quantile(0.75)), 4) if not coverage_by_day.empty else 0.0,"}],"details":{"status":"completed","exitCode":0,"durationMs":5,"aggregated":"from __future__ import annotations\n\nimport argparse\nimport json\nimport re\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\n\nimport sys\n\nsys.path.append(str(PROJECT_ROOT / \"scripts\"))\nimport run_qlib_breadth_sanity_check as sanity  # noqa: E402\n\n\ndef load_yaml(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        raise FileNotFoundError(f\"配置文件不存在: {path}\")\n    data = yaml.safe_load(path.read_text(encoding=\"utf-8\"))\n    return data or {}\n\n\ndef normalize_symbol(raw: Any) -> str | None:\n    \"\"\"\n    统一成 Qlib 预测信号里常见的代码格式：SH600000 / SZ000001 / BJ430001。\n    兼容输入：600000.SH、SH600000、600000。\n    \"\"\"\n    if raw is None:\n        return None\n\n    s = str(raw).strip().upper()\n    if not s:\n        return None\n\n    # 600000.SH -> SH600000\n    if \".\" in s:\n        code, suffix = s.split(\".\", 1)\n        code = re.sub(r\"[^0-9A-Z]\", \"\", code)\n        suffix = re.sub(r\"[^0-9A-Z]\", \"\", suffix)\n        if code and suffix:\n            if suffix in {\"SH\", \"SZ\", \"BJ\", \"HK\"}:\n                return f\"{suffix}{code}\"\n            return f\"{suffix}{code}\"\n\n    token = re.sub(r\"[^0-9A-Z]\", \"\", s)\n\n    # 已经是 SH600000 这种\n    if re.match(r\"^(SH|SZ|BJ|HK)\\d+$\", token):\n        return token\n\n    # 纯数字自动补市场前缀\n    if token.isdigit():\n        if len(token) == 6:\n            if token.startswith((\"4\", \"8\")):\n                return f\"BJ{token}\"\n            if token.startswith((\"5\", \"6\", \"9\")):\n                return f\"SH{token}\"\n            return f\"SZ{token}\"\n        if len(token) == 5:\n            return f\"HK{token}\"\n\n    return token or None\n\n\ndef discover_latest_factor_file(root_dir: Path, pattern: str) -> Path | None:\n    if not root_dir.exists():\n        return None\n    files = [p for p in root_dir.glob(pattern) if p.is_file()]\n    if not files:\n        return None\n    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)\n    return files[0]\n\n\ndef load_rd_factor_series(