{"type":"message","id":"7efeab57","parentId":"cbf20093","timestamp":"2026-03-21T14:10:40.222Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建一个飞书命令处理器，当收到股票代码时自动调用分析。","thinkingSignature":"37472c6548ec66a28ff1367623224146a5741d600bcebd357a3407e4c200ae8e"},{"type":"toolCall","id":"call_function_3412chrq2412_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n飞书命令处理器 - Agent 问股\n\n当用户在飞书发送股票代码时，自动调用分析并返回结果。\n\n使用方式：\n1. 独立运行: python3 scripts/feishu_stock_handler.py 600519\n2. 作为模块导入: from scripts.feishu_stock_handler import handle_feishu_message\n\"\"\"\n\nimport sys\nimport re\nimport json\nfrom pathlib import Path\n\n# 添加项目路径\nPROJECT_ROOT = Path(__file__).parent.parent\nsys.path.insert(0, str(PROJECT_ROOT))\n\nfrom scripts.dsa_wrapper import analyze_stock, format_dashboard\n\n\ndef parse_stock_code(text: str) -> str | None:\n    \"\"\"从文本中提取股票代码\"\"\"\n    # 6位数字\n    match = re.search(r'\\b(\\d{6})\\b', text)\n    if match:\n        code = match.group(1)\n        # 简单验证：排除明显不是股票代码的数字\n        if code and not code.startswith('00') and not code.startswith('30') and \\\n           not code.startswith('60') and not code.startswith('68') and \\\n           not code.startswith('00') and not code.startswith('00'):\n            # 尝试补全\n            if code.startswith('1') or code.startswith('2'):\n                code = '00' + code\n            elif code.startswith('3') or code.startswith('0'):\n                code = '30' + code\n            elif code.startswith('6') or code.startswith('8'):\n                code = '60' + code\n        return code\n    \n    # 常见格式\n    patterns = [\n        r'(?:600|601|603|605|688|000|001|002|003|300|301|330)\\d{3}',  # A股\n    ]\n    \n    for pattern in patterns:\n        match = re.search(pattern, text.upper())\n        if match:\n            return match.group(0)\n    \n    return None\n\n\ndef is_stock_code_message(text: str) -> bool:\n    \"\"\"判断是否是股票代码消息\"\"\"\n    code = parse_stock_code(text)\n    return code is not None\n\n\ndef handle_stock_query(stock_code: str, format_output: bool = True) -> str:\n    \"\"\"\n    处理股票查询请求\n    \n    Args:\n        stock_code: 6位股票代码\n        format_output: 是否格式化输出\n    \n    Returns:\n        格式化的分析结果\n    \"\"\"\n    print(f\"🔍 分析股票: {stock_code}\")\n    \n    # 调用分析\n    result = analyze_stock(stock_code, timeout=90)\n    \n    if format_output:\n        return format_dashboard(result)\n    else:\n        # 返回原始JSON\n        import json\n        return json.dumps(result, ensure_ascii=False, indent=2)\n\n\ndef handle_feishu_message(message: str, user_id: str = None) -> str:\n    \"\"\"\n    处理飞书消息\n    \n    Args:\n        message: 用户发送的消息\n        user_id: 用户ID（可选）\n    \n    Returns:\n        回复消息\n    \"\"\"\n    message = message.strip()\n    \n    # 跳过命令\n    if message.startswith('/') or message.startswith('!') or message.startswith('！'):\n        return None\n    \n    # 提取股票代码\n    stock_code = parse_stock_code(message)\n    \n    if not stock_code:\n        # 尝试其他模式\n        # \"分析 XXX\"\n        # \"看看 XXX\"\n        # \"XXX 怎么样\"\n        if any(kw in message for kw in ['分析', '看看', '查询', '股票']):\n            stock_code = parse_stock_code(message)\n    \n    if not stock_code:\n        return None  # 不是股票查询\n    \n    # 执行分析\n    try:\n        return handle_stock_query(stock_code)\n    except Exception as e:\n        return f\"❌ 分析出错: {str(e)}\"\n\n\n# CLI 入口\nif __name__ == \"__main__\":\n    import argparse\n    \n    parser = argparse.ArgumentParser(description=\"飞书股票命令处理器\")\n    parser.add_argument(\"stock_code\", nargs=\"?\", help=\"股票代码\")\n    parser.add_argument(\"--raw\", \"-r\", action=\"store_true\", help=\"输出原始JSON\")\n    parser.add_argument(\"--test\", \"-t\", action=\"store_true\", help=\"测试模式\")\n    \n    args = parser.parse_args()\n    \n    if args.test:\n        # 测试各种消息格式\n        test_messages = [\n            \"600519\",\n            \"600519 怎么样\",\n            \"分析 600519\",\n            \"帮我看看 300750\",\n            \"000001\",\n            \"688111\",\n        ]\n        print(\"🧪 测试消息解析\\n\" + \"=\" * 40)\n        for msg in test_messages:\n            code = parse_stock_code(msg)\n            print(f\"'{msg}' -> {code}\")\n    \n    elif args.stock_code:\n        print(handle_stock_query(args.stock_code, format_output=not args.raw))\n    \n    else:\n        print(\"Usage:\")\n        print(\"  python3 feishu_stock_handler.py 600519\")\n        print(\"  python3 feishu_stock_handler.py --test\")\n","path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/feishu_stock_handler.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":70130,"output":1145,"cacheRead":41408,"cacheWrite":0,"totalTokens":112683,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774102220813}}
