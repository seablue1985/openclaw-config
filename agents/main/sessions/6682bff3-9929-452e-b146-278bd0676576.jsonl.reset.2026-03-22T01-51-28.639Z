{"type":"message","id":"6032891c","parentId":"92419ced","timestamp":"2026-03-21T08:46:13.323Z","message":{"role":"toolResult","toolCallId":"call_a3FokKJFv28300W2SYgppdLn","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nDEFAULT_PRICE_CSV = Path(\"/Users/ling/.openclaw/workspace/data/a_stock_history.csv\")\nDEFAULT_BASIC_CSV = PROJECT_ROOT / \"data\" / \"daily_basic_all_2019_2026.csv\"\nDEFAULT_CONFIG = PROJECT_ROOT / \"config\" / \"strategy_smallcap_chip_candidate_top50.yaml\"\n\n\ndef count_csv_rows(path: Path) -> int:\n    if not path.exists():\n        return 0\n    try:\n        with path.open(\"r\", encoding=\"utf-8\", newline=\"\") as handle:\n            return max(0, sum(1 for _ in handle) - 1)\n    except Exception:\n        return 0\n\n\ndef ensure_parent(path: Path) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n\n\ndef load_smallcap_config(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    payload = yaml.safe_load(path.read_text(encoding=\"utf-8\")) or {}\n    return payload.get(\"smallcap_chip\", payload)\n\n\ndef pick_liquid_symbols(frame: pd.DataFrame, max_symbols: int) -> list[str]:\n    latest_dates = sorted(frame[\"date\"].dropna().unique())\n    if not latest_dates:\n        return []\n    cutoff = latest_dates[max(0, len(latest_dates) - 60)]\n    recent = frame[frame[\"date\"] >= cutoff]\n    ranked = (\n        recent.groupby(\"ts_code\", as_index=False)[\"amount\"]\n        .mean()\n        .sort_values(\"amount\", ascending=False)\n        .head(max_symbols)\n    )\n    return sorted(ranked[\"ts_code\"].astype(str).tolist())\n\n\ndef safe_percentile(series: pd.Series, *, ascending: bool = True, fill_value: float = 0.0) -> pd.Series:\n    numeric = pd.to_numeric(series, errors=\"coerce\")\n    ranked = numeric.rank(pct=True, ascending=ascending)\n    return ranked.fillna(fill_value)\n\n\ndef load_price_history(path: Path, target_date: int) -> pd.DataFrame:\n    if not path.exists():\n        raise FileNotFoundError(path)\n\n    frame = pd.read_csv(\n        path,\n        usecols=[\"ts_code\", \"trade_date\", \"close\", \"vol\", \"amount\"],\n    )\n    frame[\"trade_date\"] = pd.to_numeric(frame[\"trade_date\"], errors=\"coerce\").fillna(0).astype(int)\n    frame = frame[frame[\"trade_date\"] <= target_date].copy()\n    if frame.empty:\n        raise ValueError(f\"no_price_history_le_{target_date}\")\n\n    frame[\"date\"] = pd.to_datetime(frame[\"trade_date\"].astype(str), format=\"%Y%m%d\", errors=\"coerce\")\n    frame = frame.dropna(subset=[\"date\"]).copy()\n    if frame.empty:\n        raise ValueError(\"no_valid_price_dates\")\n\n    frame[\"ts_code\"] = frame[\"ts_code\"].astype(str).str.upper().str.strip()\n    frame[\"close\"] = pd.to_numeric(frame[\"close\"], errors=\"coerce\")\n    frame[\"amount\"] = pd.to_numeric(frame[\"amount\"], errors=\"coerce\").fillna(0.0) * 1000.0\n    frame[\"volume\"] = pd.to_numeric(frame[\"vol\"], errors=\"coerce\").fillna(0.0) * 100.0\n    frame = frame.dropna(subset=[\"ts_code\", \"close\"]).copy()\n    if frame.empty:\n        raise ValueError(\"no_valid_price_rows\")\n    return frame\n\n\ndef build_market_snapshot(frame: pd.DataFrame, cfg: dict[str, Any]) -> tuple[pd.DataFrame, str]:\n    max_symbols = int(cfg.get(\"max_symbols\", 300))\n    smallcap_pct = float(cfg.get(\"smallcap_pct\", 0.35))\n    min_turnover_20d = float(cfg.get(\"min_turnover_20d\", 30_000_000))\n    w_m20 = float(cfg.get(\"w_m20\", 0.55))\n    w_m60 = float(cfg.get(\"w_m60\", 0.45))\n    w_break = float(cfg.get(\"w_break\", 0.25))\n    w_near = float(cfg.get(\"w_near\", 0.05))\n    chip_near_threshold = float(cfg.get(\"chip_near_threshold\", 0.07))\n    volume_break_ratio = float(cfg.get(\"volume_break_ratio\", 1.3))\n\n    selected = pick_liquid_symbols(frame, max_symbols=max_symbols)\n    scoped = frame[frame[\"ts_code\"].isin(selected)].copy()\n    if scoped.empty:\n        raise ValueError(\"liquid_universe_empty\")\n\n    close = scoped.pivot(index=\"date\", columns=\"ts_code\", values=\"close\").sort_index()\n    amount = scoped.pivot(index=\"date\", columns=\"ts_code\", values=\"amount\").sort_index()\n    volume = scoped.pivot(index=\"date\", columns=\"ts_code\", values=\"volume\").sort_index()\n    if close.empty:\n        raise ValueError(\"pivot_close_empty\")\n\n    latest_date = close.index[-1]\n    latest_close = close.loc[latest_date]\n    prev_close = close.shift(1).loc[latest_date]\n    mom20 = close.pct_change(20, fill_method=None).loc[latest_date]\n    mom60 = close.pct_change(60, fill_method=None).loc[latest_date]\n    liq20 = amount.rolling(20).mean().loc[latest_date]\n\n    vwap60_full = (close * volume).rolling(60).sum() / volume.rolling(60).sum().replace(0, np.nan)\n    vwap60 = vwap60_full.loc[latest_date]\n    prev_vwap60 = vwap60_full.shift(1).loc[latest_date]\n    vol_ma20 = volume.rolling(20).mean().loc[latest_date]\n    latest_volume = volume.loc[latest_date]\n\n    chip_break = (\n        (latest_close > vwap60)\n        & (prev_close <= prev_vwap60)\n        & (latest_volume > volume_break_ratio * vol_ma20)\n    ).fillna(False)\n    chip_near = (((latest_close - vwap60).abs() / vwap60.replace(0, np.nan)) <= chip_near_threshold).fillna(False)\n\n    eligible = mom20.notna() & mom60.notna() & liq20.notna() & (liq20 >= min_turnover_20d)\n    eligible_codes = eligible[eligible].index.tolist()\n    if not eligible_codes:\n        raise ValueError(\"eligible_universe_empty\")\n\n    m20_rank = safe_percentile(mom20[eligible_codes], ascending=True)\n    m60_rank = safe_percentile(mom60[eligible_codes], ascending=True)\n    liq_rank = safe_percentile(liq20[eligible_codes], ascending=True)\n    smallcap_mask = liq_rank <= smallcap_pct\n\n    tech_score = (\n        w_m20 * m20_rank\n        + w_m60 * m60_rank\n        + w_break * chip_break[eligible_codes].astype(float)\n        + w_near * chip_near[eligible_codes].astype(float)\n    )\n    tech_score = tech_score[smallcap_mask].sort_values(ascending=False)\n    if tech_score.empty:\n        raise ValueError(\"tech_score_empty_after_smallcap_filter\")\n\n    universe = pd.DataFrame({\"ts_code\": tech_score.index, \"tech_score\": tech_score.values})\n    universe[\"close\"] = pd.to_numeric(latest_close.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"mom20\"] = pd.to_numeric(mom20.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"mom60\"] = pd.to_numeric(mom60.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"liq20\"] = pd.to_numeric(liq20.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"vwap60\"] = pd.to_numeric(vwap60.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"volume_break\"] = chip_break.reindex(universe[\"ts_code\"]).fillna(False).astype(bool).values\n    universe[\"chip_near\"] = chip_near.reindex(universe[\"ts_code\"]).fillna(False).astype(bool).values\n    universe[\"tech_rank\"] = safe_percentile(universe[\"tech_score\"], ascending=True)\n    universe[\"source_trade_date\"] = latest_date.strftime(\"%Y%m%d\")\n    universe = universe.sort_values([\"tech_score\", \"ts_code\"], ascending=[False, True]).reset_index(drop=True)\n    return universe, latest_date.strftime(\"%Y%m%d\")\n\n\ndef load_latest_daily_basic(path: Path, target_date: int) -> tuple[str, pd.DataFrame]:\n    if not path.exists():\n        return \"\", pd.DataFrame()\n\n    frame = pd.read_csv(\n        path,\n        usecols=[\"ts_code\", \"trade_date\", \"total_mv\", \"circ_mv\", \"turnover_rate\", \"pe\", \"pb\", \"ps\"],\n    )\n    frame[\"trade_date\"] = pd.to_numeric(frame[\"trade_date\"], errors=\"coerce\").fillna(0).astype(int)\n    frame = frame[frame[\"trade_date\"] <= target_date].copy()\n    if frame.empty:\n        return \"\", pd.DataFrame()\n\n    latest_trade_date = int(frame[\"trade_date\"].max())\n    frame = frame[frame[\"trade_date\"] == latest_trade_date].copy()\n    frame[\"ts_code\"] = frame[\"ts_code\"].astype(str).str.upper().str.strip()\n    for col in [\"total_mv\", \"circ_mv\", \"turnover_rate\", \"pe\", \"pb\", \"ps\"]:\n        frame[col] = pd.to_numeric(frame[col], errors=\"coerce\")\n    return str(latest_trade_date), frame\n\n\ndef select_main_candidates(\n    universe: pd.DataFrame,\n    *,\n    limit: int,\n    target_weight: float,\n) -> pd.DataFrame:\n    picked = universe.head(limit).copy()\n    picked[\"score\"] = picked[\"tech_score\"].round(6)\n    picked[\"target_weight\"] = round(float(target_weight), 4)\n    picked[\"comment\"] = \"auto_live_v4_2\"\n    return picked[\n        [\n            \"ts_code\",\n            \"score\",\n            \"target_weight\",\n            \"comment\",\n            \"source_trade_date\",\n            \"close\",\n            \"mom20\",\n            \"mom60\",\n            \"liq20\",\n            \"vwap60\",\n            \"volume_break\",\n            \"chip_near\",\n            \"tech_score\",\n        ]\n    ].copy()\n\n\ndef build_guard_candidates(\n    universe: pd.DataFrame,\n    daily_basic: pd.DataFrame,\n    *,"}],"details":{"status":"completed","exitCode":0,"durationMs":5,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nDEFAULT_PRICE_CSV = Path(\"/Users/ling/.openclaw/workspace/data/a_stock_history.csv\")\nDEFAULT_BASIC_CSV = PROJECT_ROOT 