{"type":"message","id":"68dd0d5b","parentId":"6221827e","timestamp":"2026-03-21T08:52:04.870Z","message":{"role":"toolResult","toolCallId":"call_oemYKFI5yCCKgHmzC4CM3RRv","toolName":"exec","content":[{"type":"text","text":"]\n        ].copy()\n\n    valid[\"turnover_score\"] = safe_percentile(valid[\"turnover_rate\"], ascending=True)\n    valid[\"size_score\"] = safe_percentile(valid[\"total_mv\"], ascending=False, fill_value=0.0)\n    valid[\"pb_score\"] = safe_percentile(valid[\"pb\"], ascending=False, fill_value=0.0)\n    valid[\"ps_score\"] = safe_percentile(valid[\"ps\"], ascending=False, fill_value=0.0)\n    valid[\"pe_score\"] = safe_percentile(valid[\"pe\"].where(valid[\"pe\"] > 0), ascending=False, fill_value=0.5)\n    valid[\"guard_score\"] = (\n        0.55 * valid[\"tech_rank\"]\n        + 0.15 * valid[\"turnover_score\"]\n        + 0.15 * valid[\"size_score\"]\n        + 0.075 * valid[\"pb_score\"]\n        + 0.05 * valid[\"ps_score\"]\n        + 0.025 * valid[\"pe_score\"]\n    )\n    valid = valid.sort_values([\"guard_score\", \"tech_score\", \"ts_code\"], ascending=[False, False, True]).copy()\n\n    if len(valid) < limit:\n        existing_codes = set(valid[\"ts_code\"].astype(str))\n        supplement = merged[~merged[\"ts_code\"].isin(existing_codes)].head(limit - len(valid)).copy()\n        if not supplement.empty:\n            supplement[\"guard_score\"] = supplement[\"tech_rank\"] * 0.9\n            supplement[\"guard_mode\"] = \"tech_fallback_partial\"\n            valid = pd.concat([valid, supplement], ignore_index=True)\n\n    picked = valid.head(limit).copy()\n    picked[\"score\"] = picked[\"guard_score\"].round(6)\n    picked[\"target_weight\"] = round(float(target_weight), 4)\n    picked[\"comment\"] = picked[\"guard_mode\"].map(\n        lambda x: \"auto_live_v4_2b_fundamental_guard\" if x == \"fundamental_guard\" else \"auto_live_v4_2b_tech_fallback\"\n    )\n    return picked[\n        [\n            \"ts_code\",\n            \"score\",\n            \"target_weight\",\n            \"comment\",\n            \"guard_mode\",\n            \"source_trade_date\",\n            \"tech_score\",\n            \"guard_score\",\n            \"turnover_rate\",\n            \"pe\",\n            \"pb\",\n            \"ps\",\n            \"total_mv\",\n            \"circ_mv\",\n        ]\n    ].copy()\n\n\ndef write_candidates(path: Path, frame: pd.DataFrame, *, overwrite: bool) -> dict[str, Any]:\n    existing_rows = count_csv_rows(path)\n    if existing_rows > 0 and not overwrite:\n        return {\n            \"path\": str(path),\n            \"status\": \"skipped_existing_non_empty\",\n            \"rows\": existing_rows,\n        }\n\n    ensure_parent(path)\n    frame.to_csv(path, index=False, encoding=\"utf-8\")\n    return {\n        \"path\": str(path),\n        \"status\": \"written\",\n        \"rows\": int(len(frame)),\n    }\n\n\ndef summary_output_path(date_tag: str, override: str) -> Path:\n    if override:\n        return Path(override)\n    return REPORT_DIR / f\"live_smallcap_candidate_generation_{date_tag}.json\"\n\n\ndef main_output_path(date_tag: str, override: str) -> Path:\n    if override:\n        return Path(override)\n    return REPORT_DIR / f\"manual_smallcap_candidates_{date_tag}.csv\"\n\n\ndef guard_output_path(date_tag: str, override: str) -> Path:\n    if override:\n        return Path(override)\n    return REPORT_DIR / f\"manual_smallcap_candidates_v4_2b_{date_tag}.csv\"\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"Generate same-day live smallcap candidates\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD, default today\")\n    parser.add_argument(\"--price-src\", default=str(DEFAULT_PRICE_CSV))\n    parser.add_argument(\"--basic-src\", default=str(DEFAULT_BASIC_CSV))\n    parser.add_argument(\"--config\", default=str(DEFAULT_CONFIG))\n    parser.add_argument(\"--main-output\", default=\"\")\n    parser.add_argument(\"--guard-output\", default=\"\")\n    parser.add_argument(\"--summary-output\", default=\"\")\n    parser.add_argument(\"--main-count\", type=int, default=10)\n    parser.add_argument(\"--guard-count\", type=int, default=8)\n    parser.add_argument(\"--main-target-weight\", type=float, default=0.10)\n    parser.add_argument(\"--guard-target-weight\", type=float, default=0.08)\n    parser.add_argument(\"--overwrite\", action=\"store_true\")\n    args = parser.parse_args()\n\n    date_tag = args.date.strip() or datetime.now().strftime(\"%Y%m%d\")\n    target_date = int(date_tag)\n    main_path = main_output_path(date_tag, args.main_output)\n    guard_path = guard_output_path(date_tag, args.guard_output)\n    summary_path = summary_output_path(date_tag, args.summary_output)\n\n    summary: dict[str, Any] = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"date_tag\": date_tag,\n        \"target_trade_date\": date_tag,\n        \"price_src\": str(Path(args.price_src)),\n        \"basic_src\": str(Path(args.basic_src)),\n        \"config\": str(Path(args.config)),\n        \"market_trade_date\": \"\",\n        \"daily_basic_trade_date\": \"\",\n        \"outputs\": {},\n        \"top_preview\": {},\n        \"status\": \"PASS\",\n        \"reason\": \"\",\n    }\n\n    try:\n        cfg = load_smallcap_config(Path(args.config))\n        price_frame = load_price_history(Path(args.price_src), target_date)\n        universe, market_trade_date = build_market_snapshot(price_frame, cfg)\n        summary[\"market_trade_date\"] = market_trade_date\n\n        basic_trade_date, daily_basic = load_latest_daily_basic(Path(args.basic_src), target_date)\n        summary[\"daily_basic_trade_date\"] = basic_trade_date\n\n        main_candidates = select_main_candidates(\n            universe,\n            limit=max(1, int(args.main_count)),\n            target_weight=max(0.0, float(args.main_target_weight)),\n        )\n        guard_candidates = build_guard_candidates(\n            universe,\n            daily_basic,\n            limit=max(1, int(args.guard_count)),\n            target_weight=max(0.0, float(args.guard_target_weight)),\n        )\n\n        summary[\"outputs\"][\"v4_2\"] = write_candidates(main_path, main_candidates, overwrite=bool(args.overwrite))\n        summary[\"outputs\"][\"v4_2b\"] = write_candidates(guard_path, guard_candidates, overwrite=bool(args.overwrite))\n        summary[\"top_preview\"][\"v4_2\"] = (\n            main_candidates[[\"ts_code\", \"score\"]].head(5).to_dict(orient=\"records\")\n            if not main_candidates.empty else []\n        )\n        summary[\"top_preview\"][\"v4_2b\"] = (\n            guard_candidates[[\"ts_code\", \"score\", \"guard_mode\"]].head(5).to_dict(orient=\"records\")\n            if not guard_candidates.empty else []\n        )\n        if not basic_trade_date:\n            summary[\"reason\"] = \"daily_basic_missing_guard_used_tech_fallback\"\n    except Exception as exc:\n        summary[\"status\"] = \"FAIL\"\n        summary[\"reason\"] = str(exc)\n        summary[\"outputs\"][\"v4_2\"] = {\"path\": str(main_path), \"status\": \"not_written\", \"rows\": count_csv_rows(main_path)}\n        summary[\"outputs\"][\"v4_2b\"] = {\"path\": str(guard_path), \"status\": \"not_written\", \"rows\": count_csv_rows(guard_path)}\n\n    ensure_parent(summary_path)\n    summary_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    print(json.dumps(summary, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()"}],"details":{"status":"completed","exitCode":0,"durationMs":7,"aggregated":"]\n        ].copy()\n\n    valid[\"turnover_score\"] = safe_percentile(valid[\"turnover_rate\"], ascending=True)\n    valid[\"size_score\"] = safe_percentile(valid[\"total_mv\"], ascending=False, fill_value=0.0)\n    valid[\"pb_score\"] = safe_percentile(valid[\"pb\"], ascending=False, fill_value=0.0)\n    valid[\"ps_score