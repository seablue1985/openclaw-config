{"type":"message","id":"21c3eea8","parentId":"7793a182","timestamp":"2026-03-21T08:58:49.766Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_cZkmIY8NCv9WMMn0vTJKRKLA","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_day1_3_mean_reversion_signals.py","content":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nDEFAULT_CONFIG = PROJECT_ROOT / \"config\" / \"day1_3_mean_reversion.yaml\"\n\n\n@dataclass\nclass MarketGate:\n    trade_date: str\n    market_regime: str\n    breadth_ratio: float\n    hs300_trend: float\n    exposure_scale: float\n    candidate_count: int\n\n\ndef load_yaml(path: Path) -> dict[str, Any]:\n    data = yaml.safe_load(path.read_text(encoding=\"utf-8\"))\n    return data or {}\n\n\ndef normalize_ts_code(value: Any) -> str:\n    raw = str(value).strip().upper()\n    if not raw or raw == \"NAN\":\n        return \"\"\n    if raw.endswith((\".SH\", \".SZ\", \".BJ\")):\n        return raw\n    if raw.startswith((\"60\", \"68\", \"90\")):\n        return f\"{raw}.SH\"\n    if raw.startswith((\"00\", \"30\")):\n        return f\"{raw}.SZ\"\n    if raw.startswith((\"4\", \"8\")):\n        return f\"{raw}.BJ\"\n    return raw\n\n\ndef safe_rank_pct(s: pd.Series, ascending: bool = True) -> pd.Series:\n    if len(s) == 0:\n        return s\n    return s.rank(pct=True, ascending=ascending, method=\"average\")\n\n\ndef load_history(path: Path, lookback_calendar_days: int) -> pd.DataFrame:\n    df = pd.read_csv(path)\n    req = {\"ts_code\", \"trade_date\", \"open\", \"high\", \"low\", \"close\", \"amount\"}\n    missing = req.difference(df.columns)\n    if missing:\n        raise ValueError(f\"history csv missing columns: {sorted(missing)}\")\n    df = df.copy()\n    df[\"ts_code\"] = df[\"ts_code\"].map(normalize_ts_code)\n    df[\"trade_date\"] = pd.to_datetime(df[\"trade_date\"].astype(str), format=\"%Y%m%d\", errors=\"coerce\")\n    df = df.dropna(subset=[\"trade_date\", \"ts_code\", \"close\"]) \n    max_date = df[\"trade_date\"].max()\n    cutoff = max_date - pd.Timedelta(days=int(lookback_calendar_days))\n    return df[df[\"trade_date\"] >= cutoff].sort_values([\"ts_code\", \"trade_date\"]).reset_index(drop=True)\n\n\ndef load_fundamentals(path: Path) -> pd.DataFrame:\n    df = pd.read_csv(path)\n    req = {\"ts_code\", \"trade_date\", \"total_mv\"}\n    missing = req.difference(df.columns)\n    if missing:\n        raise ValueError(f\"fundamental csv missing columns: {sorted(missing)}\")\n    df = df.copy()\n    df[\"ts_code\"] = df[\"ts_code\"].map(normalize_ts_code)\n    df[\"trade_date\"] = pd.to_datetime(df[\"trade_date\"].astype(str), format=\"%Y%m%d\", errors=\"coerce\")\n    return df.dropna(subset=[\"trade_date\", \"ts_code\"]).sort_values([\"trade_date\", \"ts_code\"])\n\n\ndef compute_features(history: pd.DataFrame, min_history_bars: int) -> pd.DataFrame:\n    g = history.groupby(\"ts_code\", group_keys=False)\n    work = history.copy()\n    work[\"ma10\"] = g[\"close\"].transform(lambda s: s.rolling(10).mean())\n    work[\"ret5\"] = g[\"close\"].transform(lambda s: s.pct_change(5))\n    work[\"ret1\"] = g[\"close\"].transform(lambda s: s.pct_change(1))\n    work[\"hh20\"] = g[\"high\"].transform(lambda s: s.rolling(20).max())\n    work[\"ll20\"] = g[\"low\"].transform(lambda s: s.rolling(20).min())\n    work[\"dist_ma10\"] = work[\"close\"] / work[\"ma10\"] - 1.0\n    rng = (work[\"hh20\"] - work[\"ll20\"]).replace(0, np.nan)\n    work[\"range_pos20\"] = ((work[\"close\"] - work[\"ll20\"]) / rng).clip(0, 1)\n    work[\"reversal_bar\"] = ((work[\"close\"] - work[\"open\"]) / work[\"open\"].replace(0, np.nan)).fillna(0.0)\n    counts = g[\"close\"].transform(\"count\")\n    work = work[counts >= int(min_history_bars)].copy()\n    return work\n\n\ndef build_market_gate(index_path: Path, history: pd.DataFrame, cfg: dict[str, Any], trade_date: pd.Timestamp) -> MarketGate:\n    index_df = pd.read_csv(index_path)\n    req = {\"date\", \"close\"}\n    missing = req.difference(index_df.columns)\n    if missing:\n        raise ValueError(f\"index csv missing columns: {sorted(missing)}\")\n    index_df[\"date\"] = pd.to_datetime(index_df[\"date\"], errors=\"coerce\")\n    index_df = index_df.dropna(subset=[\"date\"]).sort_values(\"date\")\n    index_df = index_df[index_df[\"date\"] <= trade_date].copy()\n    ma_window = int(cfg.get(\"ma_window\", 20))\n    index_df[\"ma\"] = index_df[\"close\"].rolling(ma_window).mean()\n    latest_idx = index_df.iloc[-1]\n    hs300_trend = float(latest_idx[\"close\"] / latest_idx[\"ma\"] - 1.0) if pd.notna(latest_idx[\"ma\"]) else 0.0\n\n    latest_hist = history[history[\"trade_date\"] == trade_date].copy()\n    breadth_ma_window = int(cfg.get(\"breadth_ma_window\", 20))\n    latest_hist[\"ma_breadth\"] = latest_hist.groupby(\"ts_code\")[\"close\"].transform(lambda s: s)\n    hist2 = history[history[\"trade_date\"] <= trade_date].copy()\n    hist2[\"ma_breadth\"] = hist2.groupby(\"ts_code\")[\"close\"].transform(lambda s: s.rolling(breadth_ma_window).mean())\n    latest_hist = hist2[hist2[\"trade_date\"] == trade_date].copy()\n    latest_hist = latest_hist.dropna(subset=[\"ma_breadth\"])\n    breadth_ratio = float((latest_hist[\"close\"] > latest_hist[\"ma_breadth\"]).mean()) if len(latest_hist) else 0.0\n\n    strong_breadth = float(cfg.get(\"strong_breadth\", 0.58))\n    neutral_breadth = float(cfg.get(\"neutral_breadth\", 0.48))\n    weak_index_trend_floor = float(cfg.get(\"weak_index_trend_floor\", -0.03))\n    if breadth_ratio >= strong_breadth and hs300_trend >= 0:\n        regime = \"strong\"\n        scale = float(cfg.get(\"strong_scale\", 1.0))\n    elif breadth_ratio >= neutral_breadth and hs300_trend >= weak_index_trend_floor:\n        regime = \"neutral\"\n        scale = float(cfg.get(\"neutral_scale\", 0.6))\n    else:\n        regime = \"weak\"\n        scale = float(cfg.get(\"weak_scale\", 0.3))\n\n    return MarketGate(\n        trade_date=str(trade_date.date()),\n        market_regime=regime,\n        breadth_ratio=round(breadth_ratio, 4),\n        hs300_trend=round(hs300_trend, 4),\n        exposure_scale=scale,\n        candidate_count=int(len(latest_hist)),\n    )\n\n\ndef latest_snapshot(features: pd.DataFrame, fundamentals: pd.DataFrame, signal_cfg: dict[str, Any], trade_date: pd.Timestamp) -> pd.DataFrame:\n    latest = features[features[\"trade_date\"] == trade_date].copy()\n    f_latest = fundamentals[fundamentals[\"trade_date\"] == trade_date].copy()\n    latest = latest.merge(\n        f_latest[[c for c in [\"ts_code\", \"trade_date\", \"total_mv\", \"turnover_rate\"] if c in f_latest.columns]],\n        on=[\"ts_code\", \"trade_date\"],\n        how=\"left\",\n    )\n    latest = latest.dropna(subset=[\"dist_ma10\", \"ret5\", \"range_pos20\"])\n    latest = latest[latest[\"amount\"].fillna(0) >= float(signal_cfg.get(\"min_amount\", 0))]\n    latest = latest[latest[\"ret5\"] <= float(signal_cfg.get(\"max_ret5\", -0.02))]\n    latest = latest[latest[\"dist_ma10\"] <= float(signal_cfg.get(\"max_dist_ma10\", -0.015))]\n    latest = latest[latest[\"range_pos20\"] <= float(signal_cfg.get(\"max_range_pos20\", 0.45))]\n    if bool(signal_cfg.get(\"require_positive_reversal\", False)):\n        latest = latest[latest[\"reversal_bar\"] > 0]\n    return latest\n\n\ndef attach_excess_ret5(snapshot: pd.DataFrame, history: pd.DataFrame, index_path: Path, trade_date: pd.Timestamp, signal_cfg: dict[str, Any]) -> pd.DataFrame:\n    idx = pd.read_csv(index_path)\n    idx[\"date\"] = pd.to_datetime(idx[\"date\"], errors=\"coerce\")\n    idx = idx.dropna(subset=[\"date\"]).sort_values(\"date\")\n    idx[\"ret5_idx\"] = idx[\"close\"].pct_change(5)\n    idx_today = idx[idx[\"date\"] == trade_date][[\"date\", \"ret5_idx\"]].rename(columns={\"date\": \"trade_date\"})\n    out = snapshot.merge(idx_today, on=\"trade_date\", how=\"left\")\n    out[\"excess_ret5\"] = out[\"ret5\"] - out[\"ret5_idx\"].fillna(0.0)\n    out = out[out[\"excess_ret5\"] <= float(signal_cfg.get(\"max_excess_ret5\", -0.015))]\n    return out\n\n\ndef apply_fundamental_filters(snapshot: pd.DataFrame, funda_cfg: dict[str, Any]) -> pd.DataFrame:\n    df = snapshot.copy()\n    if \"close\" in df.columns:\n        df = df[df[\"close\"] >= float(funda_cfg.get(\"min_price\", 0))]\n    if \"total_mv\" in df.columns:\n        df = df[df[\"total_mv\"].fillna(np.inf) >= float(funda_cfg.get(\"min_total_mv\", 0))]\n        df = df[df[\"total_mv\"].fillna(-np.inf) <= float(funda_cfg.get(\"max_total_mv\", np.inf))]\n    if \"turnover_rate\" in df.columns:\n        df = df[df[\"turnover_rate\"].fillna(0) >= float(funda_cfg.get(\"min_turnover_rate\", 0))]\n        df = df[df[\"turnover_rate\"].fillna(0) <= float(funda_cfg.get(\"max_turnover_rate\", np.inf))]\n    return df\n\n\ndef score_snapshot(snapshot: pd.DataFrame, weights: dict[str, Any]) -> pd.DataFrame:\n    df = snapshot.copy()\n    df[\"rank_dist_ma10\"] = safe_rank_pct(df[\"dist_ma10\"], ascending=True)\n    df[\"rank_ret5\"] = safe_rank_pct(df[\"ret5\"], ascending=True)\n    df[\"rank_excess_ret5\"] = safe_rank_pct(df[\"excess_ret5\"], ascending=True)\n    df[\"rank_range_pos20\"] = safe_rank_pct(df[\"range_pos20\"], ascending=True)\n    df[\"rank_reversal\"] = safe_rank_pct(df[\"reversal_bar\"], ascending=False)\n    df[\"score\"] = (\n        float(weights.get(\"dist_ma10\", 0.30)) * df[\"rank_dist_ma10\"]\n        + float(weights.get(\"ret5\", 0.25)) * df[\"rank_ret5\"]\n        + float(weights.get(\"excess_ret5\", 0.20)) * df[\"rank_excess_ret5\"]\n        + float(weights.get(\"range_pos20\", 0.15)) * df[\"rank_range_pos20\"]\n        + float(weights.get(\"reversal\", 0.10)) * df[\"rank_reversal\"]\n    )\n    return df.sort_values([\"score\", \"amount\"], ascending=[False, False]).reset_index(drop=True)\n\n\ndef allocate_weights(candidates: pd.DataFrame, signal_cfg: dict[str, Any], gate: MarketGate) -> pd.DataFrame:\n    top_k = int(signal_cfg.get(\"top_k\", 12))\n    total_exposure = float(signal_cfg.get(\"total_exposure\", 0.72)) * float(gate.exposure_scale)\n    max_single_weight = float(signal_cfg.get(\"max_single_weight\", 0.08))\n    out = candidates.head(top_k).copy()\n    if len(out) == 0:\n        out[\"target_weight\"] = []\n        return out\n    raw = out[\"score\"].clip(lower=0.0001)\n    weight = raw / raw.sum() * total_exposure\n    weight = weight.clip(upper=max_single_weight)\n    if weight.sum() > 0:\n        weight = weight / weight.sum() * min(total_exposure, max_single_weight * len(weight))\n    out[\"target_weight\"] = weight.round(4)\n    return out\n\n\ndef render_comment(row: pd.Series, gate: MarketGate) -> str:\n    return (\n        f\"day1_3_mean_reversion|regime={gate.market_regime}|breadth={gate.breadth_ratio:.3f}|\"\n        f\"hs300_trend={gate.hs300_trend:.3f}|ret5={row['ret5']:.3f}|\"\n        f\"excess_ret5={row['excess_ret5']:.3f}|dist_ma10={row['dist_ma10']:.3f}|range_pos20={row['range_pos20']:.3f}\"\n    )\n\n\ndef write_outputs(candidates: pd.DataFrame, gate: MarketGate, cfg: dict[str, Any], tag: str) -> dict[str, str]:\n    out_cfg = cfg[\"outputs\"]\n    trade_date = gate.trade_date\n    candidate_path = Path(out_cfg[\"candidate_dir\"]) / f\"day1_3_mean_reversion_candidates_{tag}.csv\"\n    factor_path = Path(out_cfg[\"rd_factor_dir\"]) / f\"day1_3_mean_reversion_factor_{tag}.csv\"\n    raw_signal_path = Path(out_cfg[\"raw_signal_dir\"]) / f\"day1_3_mean_reversion_{tag}.csv\"\n    summary_path = Path(out_cfg[\"summary_dir\"]) / f\"day1_3_mean_reversion_summary_{tag}.json\"\n    for p in [candidate_path, factor_path, raw_signal_path, summary_path]:\n        p.parent.mkdir(parents=True, exist_ok=True)\n\n    export_cols = [\n        \"trade_date\", \"ts_code\", \"close\", \"amount\", \"ret5\", \"excess_ret5\", \"dist_ma10\",\n        \"range_pos20\", \"reversal_bar\", \"score\", \"target_weight\", \"market_regime\",\n        \"breadth_ratio\", \"hs300_trend\", \"comment\",\n    ]\n    candidates[export_cols].to_csv(candidate_path, index=False)\n\n    factor_df = candidates[[\"trade_date\", \"ts_code\", \"score\"]].rename(\n        columns={\"trade_date\": \"date\", \"ts_code\": \"instrument\"}\n    )\n    factor_df.to_csv(factor_path, index=False)\n\n    raw = pd.DataFrame({\n        \"trade_date\": candidates[\"trade_date\"].astype(str),\n        \"ts_code\": candidates[\"ts_code\"],\n        \"signal_type\": \"BUY\",\n        \"score\": candidates[\"score\"].round(6),\n        \"target_weight\": candidates[\"target_weight\"],\n        \"strategy_id\": \"day1_3_mean_reversion\",\n        \"risk_flag\": gate.market_regime,\n        \"comment\": candidates[\"comment\"],\n        \"source_run_id\": f\"day1_3_mean_reversion_{tag}\",\n        \"generated_at\": pd.Timestamp.now(tz=\"Asia/Shanghai\").isoformat(),\n    })\n    raw.to_csv(raw_signal_path, index=False)\n\n    payload = {\n        \"trade_date\": trade_date,\n        \"market_regime\": gate.market_regime,\n        \"breadth_ratio\": gate.breadth_ratio,\n        \"hs300_trend\": gate.hs300_trend,\n        \"exposure_scale\": gate.exposure_scale,\n        \"candidate_count\": int(len(candidates)),\n        \"total_target_weight\": round(float(candidates[\"target_weight\"].sum()), 4) if len(candidates) else 0.0,\n        \"files\": {\n            \"candidates\": str(candidate_path),\n            \"factor\": str(factor_path),\n            \"raw_signal\": str(raw_signal_path),\n        },\n    }\n    summary_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    return {\n        \"candidate_path\": str(candidate_path),\n        \"factor_path\": str(factor_path),\n        \"raw_signal_path\": str(raw_signal_path),\n        \"summary_path\": str(summary_path),\n    }\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser(description=\"Generate day1-3 style mean reversion signals.\")\n    ap.add_argument(\"--config\", default=str(DEFAULT_CONFIG))\n    ap.add_argument(\"--trade-date\", default=\"\", help=\"YYYY-MM-DD; default latest available date\")\n    args = ap.parse_args()\n\n    cfg = load_yaml(Path(args.config).expanduser().resolve())\n    hist_cfg = cfg[\"history\"]\n    funda_cfg = cfg[\"fundamentals\"]\n    market_cfg = cfg[\"market\"]\n    signal_cfg = cfg[\"signal\"]\n\n    history = load_history(Path(hist_cfg[\"csv\"]).expanduser(), int(hist_cfg.get(\"lookback_calendar_days\", 220)))\n    fundamentals = load_fundamentals(Path(funda_cfg[\"csv\"]).expanduser())\n    features = compute_features(history, int(hist_cfg.get(\"min_history_bars\", 40)))\n\n    trade_date = pd.to_datetime(args.trade_date) if args.trade_date else pd.to_datetime(features[\"trade_date\"].max())\n    gate = build_market_gate(Path(market_cfg[\"index_csv\"]).expanduser(), history, market_cfg, trade_date)\n    snapshot = latest_snapshot(features, fundamentals, signal_cfg, trade_date)\n    snapshot = attach_excess_ret5(snapshot, history, Path(market_cfg[\"index_csv\"]).expanduser(), trade_date, signal_cfg)\n    snapshot = apply_fundamental_filters(snapshot, funda_cfg)\n    ranked = score_snapshot(snapshot, signal_cfg.get(\"weights\", {}))\n    ranked[\"market_regime\"] = gate.market_regime\n    ranked[\"breadth_ratio\"] = gate.breadth_ratio\n    ranked[\"hs300_trend\"] = gate.hs300_trend\n    selected = allocate_weights(ranked, signal_cfg, gate)\n    if len(selected):\n        selected[\"comment\"] = selected.apply(lambda row: render_comment(row, gate), axis=1)\n    else:\n        selected[\"comment\"] = []\n    tag = trade_date.strftime(\"%Y%m%d\")\n    files = write_outputs(selected, gate, cfg, tag)\n    payload = {\n        \"status\": \"ok\",\n        \"trade_date\": gate.trade_date,\n        \"market_regime\": gate.market_regime,\n        \"breadth_ratio\": gate.breadth_ratio,\n        \"hs300_trend\": gate.hs300_trend,\n        \"candidate_count\": int(len(selected)),\n        \"files\": files,\n    }\n    print(json.dumps(payload, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"gmn","model":"gpt-5.4","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774083439219}}
