{"type":"message","id":"90bbc352","parentId":"8cc92a33","timestamp":"2026-03-21T08:48:55.288Z","message":{"role":"toolResult","toolCallId":"call_kLboIyWHaoeH4aom3aq6eEwE","toolName":"exec","content":[{"type":"text","text":"from __future__ import annotations\n\nimport argparse\nimport json\nimport re\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\n\nimport sys\n\nsys.path.append(str(PROJECT_ROOT / \"scripts\"))\nimport run_qlib_breadth_sanity_check as sanity  # noqa: E402\n\n\ndef load_yaml(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        raise FileNotFoundError(f\"配置文件不存在: {path}\")\n    data = yaml.safe_load(path.read_text(encoding=\"utf-8\"))\n    return data or {}\n\n\ndef normalize_symbol(raw: Any) -> str | None:\n    \"\"\"\n    统一成 Qlib 预测信号里常见的代码格式：SH600000 / SZ000001 / BJ430001。\n    兼容输入：600000.SH、SH600000、600000。\n    \"\"\"\n    if raw is None:\n        return None\n\n    s = str(raw).strip().upper()\n    if not s:\n        return None\n\n    # 600000.SH -> SH600000\n    if \".\" in s:\n        code, suffix = s.split(\".\", 1)\n        code = re.sub(r\"[^0-9A-Z]\", \"\", code)\n        suffix = re.sub(r\"[^0-9A-Z]\", \"\", suffix)\n        if code and suffix:\n            if suffix in {\"SH\", \"SZ\", \"BJ\", \"HK\"}:\n                return f\"{suffix}{code}\"\n            return f\"{suffix}{code}\"\n\n    token = re.sub(r\"[^0-9A-Z]\", \"\", s)\n\n    # 已经是 SH600000 这种\n    if re.match(r\"^(SH|SZ|BJ|HK)\\d+$\", token):\n        return token\n\n    # 纯数字自动补市场前缀\n    if token.isdigit():\n        if len(token) == 6:\n            if token.startswith((\"4\", \"8\")):\n                return f\"BJ{token}\"\n            if token.startswith((\"5\", \"6\", \"9\")):\n                return f\"SH{token}\"\n            return f\"SZ{token}\"\n        if len(token) == 5:\n            return f\"HK{token}\"\n\n    return token or None\n\n\ndef discover_latest_factor_file(root_dir: Path, pattern: str) -> Path | None:\n    if not root_dir.exists():\n        return None\n    files = [p for p in root_dir.glob(pattern) if p.is_file()]\n    if not files:\n        return None\n    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)\n    return files[0]\n\n\ndef load_rd_factor_series(\n    file_path: Path,\n    date_col: str,\n    symbol_col: str,\n    score_col: str,\n    encoding: str = \"utf-8\",\n) -> tuple[pd.Series, dict[str, Any]]:\n    df = pd.read_csv(file_path, encoding=encoding)\n\n    missing = [c for c in [date_col, symbol_col, score_col] if c not in df.columns]\n    if missing:\n        raise ValueError(f\"因子文件缺少字段: {missing}, file={file_path}\")\n\n    work = df[[date_col, symbol_col, score_col]].copy()\n    work.columns = [\"date\", \"symbol\", \"rd_score\"]\n\n    work[\"date\"] = pd.to_datetime(work[\"date\"], errors=\"coerce\")\n    work[\"symbol\"] = work[\"symbol\"].map(normalize_symbol)\n    work[\"rd_score\"] = pd.to_numeric(work[\"rd_score\"], errors=\"coerce\")\n\n    work = work.dropna(subset=[\"date\", \"symbol\", \"rd_score\"])\n    work[\"date\"] = work[\"date\"].dt.normalize()\n\n    if work.empty:\n        raise ValueError(f\"因子文件清洗后为空: {file_path}\")\n\n    agg = work.groupby([\"date\", \"symbol\"], as_index=True)[\"rd_score\"].mean().sort_index()\n    agg.index = pd.MultiIndex.from_tuples(agg.index, names=[\"datetime\", \"instrument\"])\n\n    meta = {\n        \"rows_raw\": int(len(df)),\n        \"rows_clean\": int(len(work)),\n        \"rows_grouped\": int(len(agg)),\n        \"date_min\": str(work[\"date\"].min().date()),\n        \"date_max\": str(work[\"date\"].max().date()),\n        \"symbols\": int(work[\"symbol\"].nunique()),\n    }\n    return agg, meta\n\n\ndef cs_zscore(series: pd.Series) -> pd.Series:\n    def _z(x: pd.Series) -> pd.Series:\n        std = float(x.std(ddof=0))\n        if std < 1e-12 or np.isnan(std):\n            return pd.Series(0.0, index=x.index)\n        return (x - x.mean()) / std\n\n    return series.groupby(level=0).transform(_z)\n\n\ndef build_blended_signal(\n    base_signal: pd.Series,\n    rd_signal: pd.Series,\n    base_weight: float,\n    rd_weight: float,\n    fill_missing_rd_score: float,\n) -> tuple[pd.Series, pd.DataFrame, dict[str, Any]]:\n    merged = base_signal.rename(\"base_score\").to_frame().join(rd_signal.rename(\"rd_score\"), how=\"left\")\n    merged = merged.sort_index()\n\n    merged[\"rd_score_filled\"] = merged[\"rd_score\"].fillna(fill_missing_rd_score)\n    merged[\"base_z\"] = cs_zscore(merged[\"base_score\"])\n    merged[\"rd_z\"] = cs_zscore(merged[\"rd_score_filled\"])\n    merged[\"blended_score\"] = base_weight * merged[\"base_z\"] + rd_weight * merged[\"rd_z\"]\n\n    covered = int(merged[\"rd_score\"].notna().sum())\n    total = int(len(merged))\n    coverage_ratio = covered / total if total > 0 else 0.0\n\n    coverage_by_day = merged[\"rd_score\"].notna().groupby(level=0).mean()\n\n    stats = {\n        \"base_rows\": total,\n        \"rd_covered_rows\": covered,\n        \"coverage_ratio\": round(float(coverage_ratio), 4),\n        \"coverage_daily_mean\": round(float(coverage_by_day.mean()), 4) if not coverage_by_day.empty else 0.0,\n        \"coverage_daily_p25\": round(float(coverage_by_day.quantile(0.25)), 4) if not coverage_by_day.empty else 0.0,\n        \"coverage_daily_p50\": round(float(coverage_by_day.quantile(0.50)), 4) if not coverage_by_day.empty else 0.0,\n        \"coverage_daily_p75\": round(float(coverage_by_day.quantile(0.75)), 4) if not coverage_by_day.empty else 0.0,\n    }\n\n    blended = merged[\"blended_score\"].copy()\n    blended.index = pd.MultiIndex.from_tuples(blended.index, names=base_signal.index.names)\n    return blended, merged, stats\n\n\ndef to_serializable(result: dict[str, Any]) -> dict[str, Any]:\n    out = {}\n    for k, v in result.items():\n        if isinstance(v, (np.integer,)):\n            out[k] = int(v)\n        elif isinstance(v, (np.floating,)):\n            out[k] = float(v)\n        else:\n            out[k] = v\n    return out\n\n\ndef write_waiting_report(tag: str, config_path: Path, source_dir: Path) -> dict[str, Any]:\n    REPORT_DIR.mkdir(parents=True, exist_ok=True)\n    now = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n    payload = {\n        \"generated_at\": now,\n        \"status\": \"WAITING_FOR_RD_AGENT_OUTPUT\",\n        \"config\": str(config_path),\n        \"expected_source_dir\": str(source_dir),\n        \"hint\": \"请先在 RD-Agent 导出因子CSV（至少包含 date/instrument/score 三列）后再执行回测融合。\",\n    }\n\n    json_path = REPORT_DIR / f\"rd_agent_integration_status_{tag}.json\"\n    md_path = REPORT_DIR / f\"rd_agent_integration_status_{tag}.md\"\n\n    json_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n    lines = [\n        f\"# RD-Agent 接入状态（{tag}）\",\n        \"\",\n        f\"- 生成时间：{now}\",\n        \"- 状态：**WAITING_FOR_RD_AGENT_OUTPUT**\",\n        f\"- 配置文件：`{config_path}`\",\n        f\"- 预期因子目录：`{source_dir}`\",\n        \"\",\n        \"## 下一步\",\n        \"\",\n        \"1. 在 RD-Agent 产出因子文件（CSV）\",\n        \"2. 至少包含三列：`date`, `instrument`, `score`\",\n        \"3. 再执行：`python3 scripts/run_rd_agent_factor_overlay_backtest.py`\",\n    ]\n    md_path.write_text(\"\\n\".join(lines), encoding=\"utf-8\")\n\n    payload[\"files\"] = {\"json\": str(json_path), \"md\": str(md_path)}\n    return payload\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"RD-Agent 因子接入并与Qlib基线信号融合回测\")\n    parser.add_argument(\"--config\", default=\"config/rd_agent_integration.yaml\", help=\"接入配置路径\")\n    parser.add_argument(\"--rd-file\", default=\"\", help=\"显式指定RD因子文件（CSV）\")"}],"details":{"status":"completed","exitCode":0,"durationMs":5,"aggregated":"from __future__ import annotations\n\nimport argparse\nimport json\nimport re\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\n\nimport sys\n\nsys.path.append(str(PROJECT_ROOT / \"scripts\"))\nimport run_qlib_breadth_sanity_check as sanity  # noqa: E402\n\n\ndef load_yaml(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        raise FileNotFoundError(f\"配置文件不存在: {path}\")\n    data = yaml.safe_load(path.read_text(encoding=\"utf-8\"))\n    return data or {}\n\n\ndef normalize_symbol(raw: Any) -> str | None:\n    \"\"\"\n    统一成 Qlib 预测信号里常见的代码格式：SH600000 / SZ000001 / BJ430001。\n    兼容输入：600000.SH、SH600000、600000。\n    \"\"\"\n    if raw is None:\n        return None\n\n    s = str(raw).strip().upper()\n    if not s:\n        return None\n\n    # 600000.SH -> SH600000\n    if \".\" in s:\n        code, suffix = s.split(\".\", 1)\n        code = re.sub(r\"[^0-9A-Z]\", \"\", code)\n        suffix = re.sub(r\"[^0-9A-Z]\", \"\", suffix)\n        if code and suffix:\n            if suffix in {\"SH\", \"SZ\", \"BJ\", \"HK\"}:\n                return f\"{suffix}{code}\"\n            return f\"{suffix}{code}\"\n\n    token = re.sub(r\"[^0-9A-Z]\", \"\", s)\n\n    # 已经是 SH600000 这种\n    if re.match(r\"^(SH|SZ|BJ|HK)\\d+$\", token):\n        return token\n\n    # 纯数字自动补市场前缀\n    if token.isdigit():\n        if len(token) == 6:\n            if token.startswith((\"4\", \"8\")):\n                return f\"BJ{token}\"\n            if token.startswith((\"5\", \"6\", \"9\")):\n                return f\"SH{token}\"\n            return f\"SZ{token}\"\n        if len(token) == 5:\n            return f\"HK{token}\"\n\n    return token or None\n\n\ndef discover_latest_factor_file(root_dir: Path, pattern: str) -> Path | None:\n    if not root_dir.exists():\n        return None\n    files = [p for p in root_dir.glob(pattern) if p.is_file()]\n    if not files:\n        return None\n    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)\n    return files[0]\n\n\ndef load_rd_factor_series(\n    file_path: Path,\n    date_col: str,\n    symbol_col: str,\n    score_col: str,\n    encoding: str = \"utf-8\",\n) -> tuple[pd.Series, dict[str, Any]]:\n    df = pd.read_csv(file_path, encoding=encoding)\n\n    missing = [c for c in [date_col, symbol_col, score_col] if c not in df.columns]\n    if missing:\n        raise ValueError(f\"因子文件缺少字段: {missing}, file={file_path}\")\n\n    work = df[[date_col, symbol_col, score_col]].copy()\n    work.columns = [\"date\", \"symbol\", \"rd_score\"]\n\n    work[\"date\"] = pd.to_datetime(work[\"date\"], errors=\"coerce\")\n    work[\"symbol\"] = work[\"symbol\"].map(normalize_symbol)\n    work[\"rd_score\"] = pd.to_numeric(work[\"rd_score\"], errors=\"coerce\")\n\n    work = work.dropna(subset=[\"date\", \"symbol\", \"rd_score\"])\n    work[\"date\"] = work[\"date\"].dt.normalize()\n\n    if work.empty:\n        raise ValueError(f\"因子文件清洗后为空: {file_path}\")\n\n    agg = work.groupby([\"date\", \"symbol\"], as_index=True)[\"rd_score\"].mean().sort_index()\n    agg.index = pd.MultiIndex.from_tuples(agg.index, names=[\"datetime\", \"instrument\"])\n\n    meta = {\n        \"rows_raw\": int(len(df)),\n        \"rows_clean\": int(len(work)),\n        \"rows_grouped\": int(len(agg)),\n        \"date_min\": str(work[\"date\"].min().date()),\n        \"date_max\": str(work[\"date\"].max().date()),\n        \"symbols\": int(work[\"symbol\"].nunique()),\n    }\n    return agg, meta\n\n\ndef cs_zscore(series: pd.Series) -> pd.Series:\n    def _z(x: pd.Series) -> pd.Series:\n        std = float(x.std(ddof=0))\n        if std < 1e-12 or np.isnan(std):\n            return pd.Series(0.0, index=x.index)\n        return (x - x.mean()) / std\n\n    return series.groupby(level=0).transform(_z)\n\n\ndef build_blended_signal(\n    base_signal: pd.Series,\n    rd_signal: pd.Series,\n    base_weight: float,\n    rd_weight: float,\n    fill_missing_rd_score: float,\n) -> tuple[pd.Series, pd.DataFrame, dict[str, Any]]:\n    merged = base_signal.rename(\"base_score\").to_frame().join(rd_signal.rename(\"rd_score\"), how=\"left\")\n    merged = merged.sort_index()\n\n    merged[\"rd_score_filled\"] = merged[\"rd_score\"].fillna(fill_missing_rd_score)\n    merged[\"base_z\"] = cs_zscore(merged[\"base_score\"])\n    merged[\"rd_z\"] = cs_zscore(merged[\"rd_score_filled\"])\n    merged[\"blended_score\"] = base_weight * merged[\"base_z\"] + rd_weight * merged[\"rd_z\"]\n\n    covered = int(merged[\"rd_score\"].notna().sum())\n    total = int(len(merged))\n    coverage_ratio = covered / total if total > 0 else 0.0\n\n    coverage_by_day = merged[\"rd_score\"].notna().groupby(level=0).mean()\n\n    stats = {\n        \"base_rows\": total,\n        \"rd_covered_rows\": covered,\n        \"coverage_ratio\": round(float(coverage_ratio), 4),\n        \"coverage_daily_mean\": round(float(coverage_by_day.mean()), 4) if not coverage_by_day.empty else 0.0,\n        \"coverage_daily_p25\": round(float(coverage_by_day.quantile(0.25)), 4) if not coverage_by_day.empty else 0.0,\n        \"coverage_daily_p50\": round(float(coverage_by_day.quantile(0.50)), 4) if not coverage_by_day.empty else 0.0,\n        \"coverage_daily_p75\": round(float(coverage_by_day.quantile(0.75)), 4) if not coverage_by_day.empty else 0.0,\n    }\n\n    blended = merged[\"blended_score\"].copy()\n    blended.index = pd.MultiIndex.from_tuples(blended.index, names=base_signal.index.names)\n    return blended, merged, stats\n\n\ndef to_serializable(result: dict[str, Any]) -> dict[str, Any]:\n    out = {}\n    for k, v in result.items():\n        if isinstance(v, (np.integer,)):\n            out[k] = int(v)\n        elif isinstance(v, (np.floating,)):\n            out[k] = float(v)\n        else:\n            out[k] = v\n    return out\n\n\ndef write_waiting_report(tag: str, config_path: Path, source_dir: Path) -> dict[str, Any]:\n    REPORT_DIR.mkdir(parents=True, exist_ok=True)\n    now = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n    payload = {\n        \"generated_at\": now,\n        \"status\": \"WAITING_FOR_RD_AGENT_OUTPUT\",\n        \"config\": str(config_path),\n        \"expected_source_dir\": str(source_dir),\n        \"hint\": \"请先在 RD-Agent 导出因子CSV（至少包含 date/instrument/score 三列）后再执行回测融合。\",\n    }\n\n    json_path = REPORT_DIR / f\"rd_agent_integration_status_{tag}.json\"\n    md_path = REPORT_DIR / f\"rd_agent_integration_status_{tag}.md\"\n\n    json_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n    lines = [\n        f\"# RD-Agent 接入状态（{tag}）\",\n        \"\",\n        f\"- 生成时间：{now}\",\n        \"- 状态：**WAITING_FOR_RD_AGENT_OUTPUT**\",\n        f\"- 配置文件：`{config_path}`\",\n        f\"- 预期因子目录：`{source_dir}`\",\n        \"\",\n        \"## 下一步\",\n        \"\",\n        \"1. 在 RD-Agent 产出因子文件（CSV）\",\n        \"2. 至少包含三列：`date`, `instrument`, `score`\",\n        \"3. 再执行：`python3 scripts/run_rd_agent_factor_overlay_backtest.py`\",\n    ]\n    md_path.write_text(\"\\n\".join(lines), encoding=\"utf-8\")\n\n    payload[\"files\"] = {\"json\": str(json_path), \"md\": str(md_path)}\n    return payload\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"RD-Agent 因子接入并与Qlib基线信号融合回测\")\n    parser.add_argument(\"--config\", default=\"config/rd_agent_integration.yaml\", help=\"接入配置路径\")\n    parser.add_argument(\"--rd-file\", default=\"\", help=\"显式指定RD因子文件（CSV）\")","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774082935281}}
