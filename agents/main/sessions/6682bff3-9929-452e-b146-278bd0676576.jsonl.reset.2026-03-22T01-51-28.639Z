p60_full.shift(1).loc[latest_date]\n    vol_ma20 = volume.rolling(20).mean().loc[latest_date]\n    latest_volume = volume.loc[latest_date]\n\n    chip_break = (\n        (latest_close > vwap60)\n        & (prev_close <= prev_vwap60)\n        & (latest_volume > volume_break_ratio * vol_ma20)\n    ).fillna(False)\n    chip_near = (((latest_close - vwap60).abs() / vwap60.replace(0, np.nan)) <= chip_near_threshold).fillna(False)\n\n    eligible = mom20.notna() & mom60.notna() & liq20.notna() & (liq20 >= min_turnover_20d)\n    eligible_codes = eligible[eligible].index.tolist()\n    if not eligible_codes:\n        raise ValueError(\"eligible_universe_empty\")\n\n    m20_rank = safe_percentile(mom20[eligible_codes], ascending=True)\n    m60_rank = safe_percentile(mom60[eligible_codes], ascending=True)\n    liq_rank = safe_percentile(liq20[eligible_codes], ascending=True)\n    smallcap_mask = liq_rank <= smallcap_pct\n\n    tech_score = (\n        w_m20 * m20_rank\n        + w_m60 * m60_rank\n        + w_break * chip_break[eligible_codes].astype(float)\n        + w_near * chip_near[eligible_codes].astype(float)\n    )\n    tech_score = tech_score[smallcap_mask].sort_values(ascending=False)\n    if tech_score.empty:\n        raise ValueError(\"tech_score_empty_after_smallcap_filter\")\n\n    universe = pd.DataFrame({\"ts_code\": tech_score.index, \"tech_score\": tech_score.values})\n    universe[\"close\"] = pd.to_numeric(latest_close.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"mom20\"] = pd.to_numeric(mom20.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"mom60\"] = pd.to_numeric(mom60.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"liq20\"] = pd.to_numeric(liq20.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"vwap60\"] = pd.to_numeric(vwap60.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"volume_break\"] = chip_break.reindex(universe[\"ts_code\"]).fillna(False).astype(bool).values\n    universe[\"chip_near\"] = chip_near.reindex(universe[\"ts_code\"]).fillna(False).astype(bool).values\n    universe[\"tech_rank\"] = safe_percentile(universe[\"tech_score\"], ascending=True)\n    universe[\"source_trade_date\"] = latest_date.strftime(\"%Y%m%d\")\n    universe = universe.sort_values([\"tech_score\", \"ts_code\"], ascending=[False, True]).reset_index(drop=True)\n    return universe, latest_date.strftime(\"%Y%m%d\")\n\n\ndef load_latest_daily_basic(path: Path, target_date: int) -> tuple[str, pd.DataFrame]:\n    if not path.exists():\n        return \"\", pd.DataFrame()\n\n    frame = pd.read_csv(\n        path,\n        usecols=[\"ts_code\", \"trade_date\", \"total_mv\", \"circ_mv\", \"turnover_rate\", \"pe\", \"pb\", \"ps\"],\n    )\n    frame[\"trade_date\"] = pd.to_numeric(frame[\"trade_date\"], errors=\"coerce\").fillna(0).astype(int)\n    frame = frame[frame[\"trade_date\"] <= target_date].copy()\n    if frame.empty:\n        return \"\", pd.DataFrame()\n\n    latest_trade_date = int(frame[\"trade_date\"].max())\n    frame = frame[frame[\"trade_date\"] == latest_trade_date].copy()\n    frame[\"ts_code\"] = frame[\"ts_code\"].astype(str).str.upper().str.strip()\n    for col in [\"total_mv\", \"circ_mv\", \"turnover_rate\", \"pe\", \"pb\", \"ps\"]:\n        frame[col] = pd.to_numeric(frame[col], errors=\"coerce\")\n    return str(latest_trade_date), frame\n\n\ndef select_main_candidates(\n    universe: pd.DataFrame,\n    *,\n    limit: int,\n    target_weight: float,\n) -> pd.DataFrame:\n    picked = universe.head(limit).copy()\n    picked[\"score\"] = picked[\"tech_score\"].round(6)\n    picked[\"target_weight\"] = round(float(target_weight), 4)\n    picked[\"comment\"] = \"auto_live_v4_2\"\n    return picked[\n        [\n            \"ts_code\",\n            \"score\",\n            \"target_weight\",\n            \"comment\",\n            \"source_trade_date\",\n            \"close\",\n            \"mom20\",\n            \"mom60\",\n            \"liq20\",\n            \"vwap60\",\n            \"volume_break\",\n            \"chip_near\",\n            \"tech_score\",\n        ]\n    ].copy()\n\n\ndef build_guard_candidates(\n    universe: pd.DataFrame,\n    daily_basic: pd.DataFrame,\n    *,\n    limit: int,\n    target_weight: float,\n) -> pd.DataFrame:\n    merged = universe.merge(\n        daily_basic[[\"ts_code\", \"turnover_rate\", \"pe\", \"pb\", \"ps\", \"total_mv\", \"circ_mv\"]],\n        on=\"ts_code\",\n        how=\"left\",\n    )\n    merged[\"guard_mode\"] = \"fundamental_guard\"\n\n    valid = merged[\n        (pd.to_numeric(merged[\"turnover_rate\"], errors=\"coerce\") >= 0.8)\n        & (pd.to_numeric(merged[\"pb\"], errors=\"coerce\") > 0)\n        & (pd.to_numeric(merged[\"ps\"], errors=\"coerce\") > 0)\n    ].copy()\n\n    if valid.empty:\n        fallback = universe.head(limit).copy()\n        fallback[\"score\"] = fallback[\"tech_score\"].round(6)\n        fallback[\"target_weight\"] = round(float(target_weight), 4)\n        fallback[\"comment\"] = \"auto_live_v4_2b_tech_fallback\"\n        fallback[\"guard_mode\"] = \"tech_fallback_no_basic\"\n        for col in [\"turnover_rate\", \"pe\", \"pb\", \"ps\", \"total_mv\", \"circ_mv\", \"guard_score\"]:\n            fallback[col] = np.nan\n        return fallback[\n            [\n                \"ts_code\",\n                \"score\",\n                \"target_weight\",\n                \"comment\",\n                \"guard_mode\",\n                \"source_trade_date\",\n                \"tech_score\",\n                \"guard_score\",\n                \"turnover_rate\",\n                \"pe\",\n                \"pb\",\n                \"ps\",\n                \"total_mv\",\n                \"circ_mv\",","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774082973921}}
{"type":"message","id":"c12c60b7","parentId":"79d7c8ed","timestamp":"2026-03-21T08:49:33.935Z","message":{"role":"toolResult","toolCallId":"call_o39Gtqddocm9GdmumS1ykw5Y","toolName":"exec","content":[{"type":"text","text":"# 小市值筹码策略候选配置落地说明\n\n生成时间：2026-03-14\n\n## 结论\n- 日常回测入口默认切换到 `strategy_smallcap_chip_candidate_top50.yaml`\n- 输出目录继续固定为 `backtest/results/active_strategy`，避免影响现有日报读取\n- 日常入口仍默认使用全量 `a_stock_history.csv`；如需复现研究窗结果，可覆盖第三个参数传入 `2020+` 截断数据\n- 主 live 候选生成默认也已切到 `candidate_top50`，覆盖 `generate_live_smallcap_candidates.py`、`prepare_live_signal_tickets.py` fallback 和 `config/live_trading_v1.json`\n- 备用 exit candidate live 配置暂未调整，继续保留原实验口径\n\n## 推荐依据\n### 全量样本口径（日常入口实际使用）\n| 策略 | 年化收益 | 夏普 | 最大回撤 | 总成本 |\n| --- | ---: | ---: | ---: | ---: |\n| current | 15.21% | 1.148 | 37.85% | 8.59% |\n| candidate_top50 | 15.60% | 1.161 | 36.31% | 9.92% |\n| aggressive | 18.49% | 0.970 | 41.11% | 22.83% |\n\n`candidate_top50` 在日常入口使用的全量样本上，较 `current` 仅是小幅优化，但方向一致：收益、Sharpe、回撤都略优；`aggressive` 虽然收益更高，但回撤和交易成本明显更差。\n\n### 研究窗口径（`2020-01-02` 之后截断样本）\n此前 `*_20260314` 版本化结果目录采用的是 `2020+` 截断数据，因此数值显著高于日常入口：\n\n| 策略 | 年化收益 | 夏普 | 最大回撤 | 总成本 |\n| --- | ---: | ---: | ---: | ---: |\n| current | 29.19% | 1.806 | 15.52% | 6.52% |\n| candidate_top50 | 33.25% | 1.890 | 18.10% | 6.73% |\n| aggressive | 33.33% | 1.650 | 27.50% | 14.18% |\n\n### Walk-forward（2020-01-02 至 2026-03-13，24m train / 6m test）\n| 策略 | 测试年化均值 | 测试夏普均值 | 测试最大回撤均值 | 测试总收益均值 |\n| --- | ---: | ---: | ---: | ---: |\n| current | 20.99% | 1.617 | 6.48% | 8.74% |\n| candidate_top50 | 22.00% | 1.687 | 6.37% | 9.17% |\n| aggressive | 25.60% | 1.625 | 8.13% | 10.64% |\n\n综合来看，`candidate_top50` 在全量样本上是温和升级，在 `2020+` 研究窗和样本外 walk-forward 上则更明确优于 `current`；因此它仍然是更合适的下一阶段标准候选。\n\n## 运行侧落地范围\n- 主 daily live 链路 `run_live_daily_v1.sh -> prepare_live_signal_tickets.py -> generate_live_smallcap_candidates.py` 默认已切到 `candidate_top50`\n- `config/live_trading_v1.json` 中 `smallcap_live_candidates.profile` 已改为 `candidate_top50`\n- `config/live_trading_exit_candidate_dual_v1.json` 与 `config/live_trading_exit_candidate_tight_v1.json` 暂未改动，避免影响其他纸面配置实验\n\n## 分阶段观察\n| 区间 | current | candidate_top50 | aggressive |\n| --- | --- | --- | --- |\n| 2020-2021 | 23.63% / 1.460 / 12.16% | 28.21% / 1.574 / 15.93% | 29.21% / 1.530 / 16.61% |\n| 2022-2023 | 5.82% / 0.497 / 14.05% | 5.86% / 0.478 / 18.72% | 14.29% / 0.809 / 18.34% |\n| 2024-2026YTD | 75.73% / 3.598 / 14.39% | 93.81% / 3.974 / 16.05% | 99.93% / 3.828 / 17.20% |\n\n表内数值格式为 `年化收益 / 夏普 / 最大回撤`。`candidate_top50` 不是每个市场阶段都最强，但整体更均衡；`aggressive` 主要靠更高风险和更高换手换取收益。\n\n## 已知限制\n- `strategy_smallcap_chip_aggressive.yaml` 中以下键当前不会被回测引擎读取：`enable_breadth_timing`、`breadth_lookback`、`breadth_threshold`、`enable_stop_loss`、`stop_loss_pct`、`take_profit_pct`\n- 因此 `aggressive` 结果不应被解释为“已启用宽度择时和止盈止损后的表现”\n\n## 新入口用法\n默认运行：\n\n```bash\nbash scripts/run_active_strategy.sh\n```\n\n临时覆盖配置：\n\n```bash\nbash scripts/run_active_strategy.sh config/strategy_smallcap_chip.yaml\n```\n\n临时覆盖配置、输出目录和数据源：\n\n```bash\nbash scripts/run_active_strategy.sh \\\n  config/strategy_smallcap_chip_aggressive.yaml \\\n  backtest/results/active_strategy_aggressive_preview \\\n  /tmp/a_stock_history_from_20200102.csv\n```"}],"details":{"status":"completed","exitCode":0,"durationMs":14,"aggregated":"# 小市值筹码策略候选配置落地说明\n\n生成时间：2026-03-14\n\n## 结论\n- 日常回测入口默认切换到 `strategy_smallcap_chip_candidate_top50.yaml`\n- 输出目录继续固定为 `backtest/results/active_strategy`，避免影响现有日报读取\n- 日常入口仍默认使用全量 `a_stock_history.csv`；如需复现研究窗结果，可覆盖第三个参数传入 `2020+` 截断数据\n- 主 live 候选生成默认也已切到 `candidate_top50`，覆盖 `generate_live_smallcap_candidates.py`、`prepare_live_signal_tickets.py` fallback 和 `config/live_trading_v1.json`\n- 备用 exit candidate live 配置暂未调整，继续保留原实验口径\n\n## 推荐依据\n### 全量样本口径（日常入口实际使用）\n| 策略 | 年化收益 | 夏普 | 最大回撤 | 总成本 |\n| --- | ---: | ---: | ---: | ---: |\n| current | 15.21% | 1.148 | 37.85% | 8.59% |\n| candidate_top50 | 15.60% | 1.161 | 36.31% | 9.92% |\n| aggressive | 18.49% | 0.970 | 41.11% | 22.83% |\n\n`candidate_top50` 在日常入口使用的全量样本上，较 `current` 仅是小幅优化，但方向一致：收益、Sharpe、回撤都略优；`aggressive` 虽然收益更高，但回撤和交易成本明显更差。\n\n### 研究窗口径（`2020-01-02` 之后截断样本）\n此前 `*_20260314` 版本化结果目录采用的是 `2020+` 截断数据，因此数值显著高于日常入口：\n\n| 策略 | 年化收益 | 夏普 | 最大回撤 | 总成本 |\n| --- | ---: | ---: | ---: | ---: |\n| current | 29.19% | 1.806 | 15.52% | 6.52% |\n| candidate_top50 | 33.25% | 1.890 | 18.10% | 6.73% |\n| aggressive | 33.33% | 1.650 | 27.50% | 14.18% |\n\n### Walk-forward（2020-01-02 至 2026-03-13，24m train / 6m test）\n| 策略 | 测试年化均值 | 测试夏普均值 | 测试最大回撤均值 | 测试总收益均值 |\n| --- | ---: | ---: | ---: | ---: |\n| current | 20.99% | 1.617 | 6.48% | 8.74% |\n| candidate_top50 | 22.00% | 1.687 | 6.37% | 9.17% |\n| aggressive | 25.60% | 1.625 | 8.13% | 10.64% |\n\n综合来看，`candidate_top50` 在全量样本上是温和升级，在 `2020+` 研究窗和样本外 walk-forward 上则更明确优于 `current`；因此它仍然是更合适的下一阶段标准候选。\n\n## 运行侧落地范围\n- 主 daily live 链路 `run_live_daily_v1.sh -> prepare_live_signal_tickets.py -> generate_live_smallcap_candidates.py` 默认已切到 `candidate_top50`\n- `config/live_trading_v1.json` 中 `smallcap_live_candidates.profile` 已改为 `candidate_top50`\n- `config/live_trading_exit_candidate_dual_v1.json` 与 `config/live_trading_exit_candidate_tight_v1.json` 暂未改动，避免影响其他纸面配置实验\n\n## 分阶段观察\n| 区间 | current | candidate_top50 | aggressive |\n| --- | --- | --- | --- |\n| 2020-2021 | 23.63% / 1.460 / 12.16% | 28.21% / 1.574 / 15.93% | 29.21% / 1.530 / 16.61% |\n| 2022-2023 | 5.82% / 0.497 / 14.05% | 5.86% / 0.478 / 18.72% | 14.29% / 0.809 / 18.34% |\n| 2024-2026YTD | 75.73% / 3.598 / 14.39% | 93.81% / 3.974 / 16.05% | 99.93% / 3.828 / 17.20% |\n\n表内数值格式为 `年化收益 / 夏普 / 最大回撤`。`candidate_top50` 不是每个市场阶段都最强，但整体更均衡；`aggressive` 主要靠更高风险和更高换手换取收益。\n\n## 已知限制\n- `strategy_smallcap_chip_aggressive.yaml` 中以下键当前不会被回测引擎读取：`enable_breadth_timing`、`breadth_lookback`、`breadth_threshold`、`enable_stop_loss`、`stop_loss_pct`、`take_profit_pct`\n- 因此 `aggressive` 结果不应被解释为“已启用宽度择时和止盈止损后的表现”\n\n## 新入口用法\n默认运行：\n\n```bash\nbash scripts/run_active_strategy.sh\n```\n\n临时覆盖配置：\n\n```bash\nbash scripts/run_active_strategy.sh config/strategy_smallcap_chip.yaml\n```\n\n临时覆盖配置、输出目录和数据源：\n\n```bash\nbash scripts/run_active_strategy.sh \\\n  config/strategy_smallcap_chip_aggressive.yaml \\\n  backtest/results/active_strategy_aggressive_preview \\\n  /tmp/a_stock_history_from_20200102.csv\n```","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774082973929}}
