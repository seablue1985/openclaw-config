universe[\"mom20\"] = pd.to_numeric(mom20.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"mom60\"] = pd.to_numeric(mom60.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"liq20\"] = pd.to_numeric(liq20.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"vwap60\"] = pd.to_numeric(vwap60.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"volume_break\"] = chip_break.reindex(universe[\"ts_code\"]).fillna(False).astype(bool).values\n    universe[\"chip_near\"] = chip_near.reindex(universe[\"ts_code\"]).fillna(False).astype(bool).values\n    universe[\"tech_rank\"] = safe_percentile(universe[\"tech_score\"], ascending=True)\n    universe[\"source_trade_date\"] = latest_date.strftime(\"%Y%m%d\")\n    universe = universe.sort_values([\"tech_score\", \"ts_code\"], ascending=[False, True]).reset_index(drop=True)\n    return universe, latest_date.strftime(\"%Y%m%d\")\n\n\ndef load_latest_daily_basic(path: Path, target_date: int) -> tuple[str, pd.DataFrame]:\n    if not path.exists():\n        return \"\", pd.DataFrame()\n\n    frame = pd.read_csv(\n        path,\n        usecols=[\"ts_code\", \"trade_date\", \"total_mv\", \"circ_mv\", \"turnover_rate\", \"pe\", \"pb\", \"ps\"],\n    )\n    frame[\"trade_date\"] = pd.to_numeric(frame[\"trade_date\"], errors=\"coerce\").fillna(0).astype(int)\n    frame = frame[frame[\"trade_date\"] <= target_date].copy()\n    if frame.empty:\n        return \"\", pd.DataFrame()\n\n    latest_trade_date = int(frame[\"trade_date\"].max())\n    frame = frame[frame[\"trade_date\"] == latest_trade_date].copy()\n    frame[\"ts_code\"] = frame[\"ts_code\"].astype(str).str.upper().str.strip()\n    for col in [\"total_mv\", \"circ_mv\", \"turnover_rate\", \"pe\", \"pb\", \"ps\"]:\n        frame[col] = pd.to_numeric(frame[col], errors=\"coerce\")\n    return str(latest_trade_date), frame\n\n\ndef select_main_candidates(\n    universe: pd.DataFrame,\n    *,\n    limit: int,\n    target_weight: float,\n) -> pd.DataFrame:\n    picked = universe.head(limit).copy()\n    picked[\"score\"] = picked[\"tech_score\"].round(6)\n    picked[\"target_weight\"] = round(float(target_weight), 4)\n    picked[\"comment\"] = \"auto_live_v4_2\"\n    return picked[\n        [\n            \"ts_code\",\n            \"score\",\n            \"target_weight\",\n            \"comment\",\n            \"source_trade_date\",\n            \"close\",\n            \"mom20\",\n            \"mom60\",\n            \"liq20\",\n            \"vwap60\",\n            \"volume_break\",\n            \"chip_near\",\n            \"tech_score\",\n        ]\n    ].copy()\n\n\ndef build_guard_candidates(\n    universe: pd.DataFrame,\n    daily_basic: pd.DataFrame,\n    *,","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774082773317}}
{"type":"message","id":"84a8a3de","parentId":"6032891c","timestamp":"2026-03-21T08:46:13.328Z","message":{"role":"toolResult","toolCallId":"call_rTAKMaRmmRucsJkWxaqE19DC","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport math\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nfrom stock_analysis_decision_bridge import (  # type: ignore\n    EXECUTION_OVERLAY_PROFILE,\n    apply_stock_analysis_overlay,\n)\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nORDERS_DIR = PROJECT_ROOT / \"orders\" / \"proposed\"\nSIGNALS_RAW_DIR = PROJECT_ROOT / \"signals\" / \"raw\"\nSIGNALS_MERGED_DIR = PROJECT_ROOT / \"signals\" / \"merged\"\nSIGNALS_APPROVED_DIR = PROJECT_ROOT / \"signals\" / \"approved\"\nRISK_CONFIG_PATH = PROJECT_ROOT / \"risk\" / \"configs\" / \"default_risk_config.json\"\nLIVE_TRADING_CONFIG_PATH = PROJECT_ROOT / \"config\" / \"live_trading_v1.json\"\nA_STOCK_CSV = Path(\"/Users/ling/.openclaw/workspace/data/a_stock_history.csv\")\n\nDEFAULT_ACCOUNT_NAV = 1000000.0\nDEFAULT_AVAILABLE_CASH = 1000000.0\nDEFAULT_LOT_SIZE = 100\nDEFAULT_LIVE_CANDIDATE_SETTINGS: dict[str, Any] = {\n    \"profile\": \"candidate_top50\",\n    \"config\": str(PROJECT_ROOT / \"config\" / \"strategy_smallcap_chip_candidate_top50.yaml\"),\n    \"main_count\": 10,\n    \"guard_count\": 8,\n    \"main_target_weight\": 0.10,\n    \"guard_target_weight\": 0.08,\n}\nDEFAULT_HEADER = [\n    \"ticket_time\",\n    \"ts_code\",\n    \"side\",\n    \"source_time\",\n    \"source_qty\",\n    \"source_price\",\n    \"source_amount\",\n    \"reason\",\n    \"confirm_status\",\n    \"execute_status\",\n    \"notes\",\n]\n\n\ndef parse_float(value: Any, default: float = 0.0) -> float:\n    try:\n        parsed = float(str(value).replace(\",\", \"\").strip())\n        return parsed if math.isfinite(parsed) else default\n    except Exception:\n        return default\n\n\ndef parse_int(value: Any, default: int = 0) -> int:\n    try:\n        return int(float(str(value).replace(\",\", \"\").strip()))\n    except Exception:\n        return default\n\n\ndef parse_bool(value: Any, default: bool = False) -> bool:\n    if value is None:\n        return default\n    text = str(value).strip().lower()\n    if text in {\"1\", \"true\", \"yes\", \"y\", \"ok\"}:\n        return True\n    if text in {\"0\", \"false\", \"no\", \"n\"}:\n        return False\n    return default\n\n\ndef normalize_side(value: Any) -> str:\n    text = str(value or \"\").strip().upper()\n    if text in {\"BUY\", \"SELL\"}:\n        return text\n    if any(k in text for k in [\"买\", \"BUY\", \"B\", \"LONG\"]):\n        return \"BUY\"\n    if any(k in text for k in [\"卖\", \"SELL\", \"S\", \"SHORT\"]):\n        return \"SELL\"\n    return \"\"\n\n\ndef normalize_joinquant_code(value: Any) -> str:\n    raw = str(value or \"\").strip().upper()\n    if not raw or raw == \"NAN\":\n        return \"\"\n    if raw.endswith(\".XSHG\") or raw.endswith(\".XSHE\"):\n        return raw\n    if raw.endswith(\".SH\"):\n        return raw[:-3] + \".XSHG\"\n    if raw.endswith(\".SZ\"):\n        return raw[:-3] + \".XSHE\"\n    if raw.startswith(\"SH\") and len(raw) >= 8:\n        return f\"{raw[2:8]}.XSHG\"\n    if raw.startswith(\"SZ\") and len(raw) >= 8:\n        return f\"{raw[2:8]}.XSHE\"\n    if raw.isdigit() and len(raw) == 6:\n        market = \"XSHG\" if raw.startswith((\"5\", \"6\", \"9\")) else \"XSHE\"\n        return f\"{raw}.{market}\"\n    return raw\n\n\ndef to_tushare_code(joinquant_code: str) -> str:\n    code = normalize_joinquant_code(joinquant_code)\n    if \".\" not in code:\n        return \"\"\n    symbol, market = code.split(\".\", 1)\n    if market == \"XSHG\":\n        return f\"{symbol}.SH\"\n    if market == \"XSHE\":\n        return f\"{symbol}.SZ\"\n    return \"\"\n\n\ndef count_csv_rows(path: Path) -> int:\n    if not path.exists():\n        return 0\n    try:\n        with path.open(\"r\", encoding=\"utf-8\", newline=\"\") as handle:\n            return max(0, sum(1 for _ in handle) - 1)\n    except Exception:\n        return 0\n\n\ndef ensure_parent(path: Path) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n\n\ndef live_ticket_path(date_tag: str) -> Path:\n    return REPORT_DIR / f\"stock_signal_tickets_live_{date_tag}.csv\"\n\n\ndef legacy_ticket_path(date_tag: str) -> Path:\n    return REPORT_DIR / f\"stock_signal_tickets_{date_tag}.csv\"\n\n\ndef ticket_path(date_tag: str) -> Path:\n    return live_ticket_path(date_tag)\n\n\ndef summary_path(date_tag: str) -> Path:\n    return REPORT_DIR / f\"signal_ticket_bridge_summary_{date_tag}.json\"\n\n\ndef write_ticket_rows(path: Path, rows: list[dict[str, Any]]) -> None:\n    ensure_parent(path)\n    frame = pd.DataFrame(rows, columns=DEFAULT_HEADER) if rows else pd.DataFrame(columns=DEFAULT_HEADER)\n    frame.to_csv(path, index=False, encoding=\"utf-8\")\n\n\ndef write_summary(path: Path, payload: dict[str, Any]) -> None:\n    ensure_parent(path)\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef load_live_candidate_settings() -> dict[str, Any]:\n    settings = dict(DEFAULT_LIVE_CANDIDATE_SETTINGS)\n    if not LIVE_TRADING_CONFIG_PATH.exists():\n        return settings\n    try:\n        payload = json.loads(LIVE_TRADING_CONFIG_PATH.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return settings\n\n    live_settings = payload.get(\"smallcap_live_candidates\", {}) or {}\n    if isinstance(live_settings, dict):\n        settings.update({k: v for k, v in live_settings.items() if v not in (None, \"\")})\n\n    config_value = str(settings.get(\"config\", \"\")).strip()\n    if config_value:\n        config_path = Path(config_value)\n        if not config_path.is_absolute():\n            config_path = (PROJECT_ROOT / config_path).resolve()\n        settings[\"config\"] = str(config_path)\n    return settings\n\n\ndef run_cmd(cmd: list[str], *, cwd: Path) -> dict[str, Any]:\n    proc = subprocess.run(cmd, cwd=str(cwd), capture_output=True, text=True)\n    return {\n        \"cmd\": cmd,\n        \"returncode\": proc.returncode,\n        \"stdout\": (proc.stdout or \"\").strip(),\n        \"stderr\": (proc.stderr or \"\").strip(),\n    }\n\n\ndef materialize_signal_chain(date_tag: str, available_cash: float, account_nav: float, *, force_rebuild: bool = False) -> list[dict[str, Any]]:\n    trade_date = f\"{date_tag[:4]}-{date_tag[4:6]}-{date_tag[6:8]}\"\n    ops: list[dict[str, Any]] = []\n\n    candidate_specs = [\n        (\n            REPORT_DIR / f\"manual_smallcap_candidates_{date_tag}.csv\",\n            PROJECT_ROOT / \"scripts\" / \"export_smallcap_v4_2_signal.py\",\n            SIGNALS_RAW_DIR / f\"smallcap_chip_v4_2_{date_tag}.csv\",\n        ),\n        (\n            REPORT_DIR / f\"manual_smallcap_candidates_v4_2b_{date_tag}.csv\",\n            PROJECT_ROOT / \"scripts\" / \"export_smallcap_v4_2b_signal.py\",\n            SIGNALS_RAW_DIR / f\"smallcap_chip_v4_2b_{date_tag}.csv\",\n        ),\n    ]\n\n    missing_candidates = [\n        str(candidate_path)\n        for candidate_path, _, _ in candidate_specs\n        if force_rebuild or count_csv_rows(candidate_path) <= 0\n    ]\n    if missing_candidates:\n        auto_candidate_summary = REPORT_DIR / f\"live_smallcap_candidate_generation_{date_tag}.json\""}],"details":{"status":"completed","exitCode":0,"durationMs":4,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport math\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nfrom stock_analysis_decision_bridge import (  # type: ignore\n    EXECUTION_OVERLAY_PROFILE,\n    apply_stock_analysis_overlay,\n)\n\nPROJEC