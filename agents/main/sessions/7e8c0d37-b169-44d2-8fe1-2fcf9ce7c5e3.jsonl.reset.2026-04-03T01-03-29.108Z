 the full script carefully, making sure we don't have any unused imports or redundancies in the existing code. I'll make sure everything is clean and organized. I'll focus on replacing the whole file with the modified version, ensuring it's exactly what we need and nothing extra. Let's get started on this!\"}]}"},{"type":"toolCall","id":"call_yF2c6g8j5i6BSZRWkKunbj2H|fc_0faca0e75e9e48550169cda14d4290819a839caf5c06cff56c","name":"write","arguments":{"file":"/Users/ling/.openclaw/skills/github-repo-monitor/scripts/check_updates.py","content":"#!/usr/bin/env python3\n\"\"\"\nGitHub 仓库更新检查脚本\n- 检查所有配置的仓库是否有上游更新\n- 分析 CHANGELOG / Release Notes 判断是否建议更新\n- 有重要更新时推送飞书通知\n- 记录状态到 JSON 文件\n\"\"\"\n\nimport json\nimport subprocess\nimport sys\nimport re\nfrom datetime import datetime, date\nfrom pathlib import Path\nfrom typing import Optional\n\n# ── 路径配置 ──────────────────────────────────────────────\nSKILL_DIR = Path(__file__).resolve().parents[1]\nCONFIG_FILE = SKILL_DIR / \"config\" / \"repos.json\"\nSTATE_FILE = SKILL_DIR / \"state\" / \"last_check.json\"\nSTATE_FILE.parent.mkdir(parents=True, exist_ok=True)\nFEISHU_WEBHOOK = \"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\"\n\n# ── 判断规则：commit message 关键词 → 优先级 ───────────────\nCOMMIT_PRIORITY_KEYWORDS = {\n    \"breaking\": \"🔴 Breaking\",\n    \"feat:\": \"🟢 新功能\",\n    \"fix:\": \"🟡 Bug修复\",\n    \"refactor:\": \"🔵 重构\",\n    \"docs:\": \"📝 文档\",\n    \"perf:\": \"⚡ 性能\",\n    \"test:\": \"🧪 测试\",\n    \"chore:\": \"🔧 维护\",\n    \"security\": \"🔴 安全\",\n    \"hotfix\": \"🔴 热修复\",\n}\n\n# 低优先级关键字（自动跳过）\nSKIP_KEYWORDS = [\"chore(deps)\", \"ci\", \"build:\", \"style:\", \"lint:\"]\n\n\ndef load_config() -> list[dict]:\n    \"\"\"加载仓库配置\"\"\"\n    if CONFIG_FILE.exists():\n        return json.loads(CONFIG_FILE.read_text(encoding=\"utf-8\"))\n    # 默认配置：如果有 upstream remote 的 git 仓库\n    default_repos = discover_git_repos()\n    return [{\"path\": str(r)} for r in default_repos]\n\n\ndef discover_git_repos() -> list[Path]:\n    \"\"\"自动发现 workspace 下有 upstream 的 git 仓库\"\"\"\n    workspace = Path.home() / \".openclaw\" / \"workspace\"\n    found = []\n    for git_dir in workspace.rglob(\".git\"):\n        repo_dir = git_dir.parent\n        try:\n            # 检查是否有 upstream remote\n            r = run_git(repo_dir, [\"remote\", \"get-url\", \"upstream\"])\n            upstream = r.strip() if r else \"\"\n            r2 = run_git(repo_dir, [\"remote\", \"get-url\", \"origin\"])\n            origin = r2.strip() if r2 else \"\"\n            if upstream or \"ZhuLinsen\" in origin or \"seablue1985\" in origin:\n                found.append(repo_dir)\n        except Exception:\n            pass\n    return found\n\n\ndef run_git(repo_dir: Path, args: list[str], timeout: int = 15) -> str:\n    \"\"\"运行 git 命令\"\"\"\n    full_cmd = [\"git\", \"-C\", str(repo_dir)] + args\n    r = subprocess.run(full_cmd, capture_output=True, text=True, timeout=timeout)\n    if r.returncode != 0:\n        raise RuntimeError(f\"git failed: {r.stderr.strip()}\")\n    return r.stdout.strip()\n\n\ndef fetch_repo(repo_dir: Path) -> Optional[str]:\n    \"\"\"刷新远端引用；失败时返回错误文本，不中断整体检查。\"\"\"\n    try:\n        run_git(repo_dir, [\"fetch\", \"--all\", \"--tags\", \"--prune\"], timeout=60)\n        return None\n    except Exception as e:\n        return str(e)\n\n\ndef compare_branch(repo: Path, branch: str) -> Optional[dict]:\n    \"\"\"对比本地 HEAD 与指定远端分支。\"\"\"\n    try:\n        run_git(repo, [\"rev-parse\", \"--short\", branch])\n    except Exception:\n        return None\n\n    try:\n        branch_tag = run_git(repo, [\"describe\", \"--tags\", \"--always\", branch])\n    except Exception:\n        branch_tag = None\n\n    try:\n        behind = int(run_git(repo, [\"rev-list\", \"--count\", f\"HEAD..{branch}\"]))\n        ahead = int(run_git(repo, [\"rev-list\", \"--count\", f\"{branch}..HEAD\"]))\n    except Exception:\n        behind = 0\n        ahead = 0\n\n    return {\n        \"tag\": branch_tag,\n        \"behind\": behind,\n        \"ahead\": ahead,\n    }\n\n\ndef get_repo_status(repo_path: str) -> dict:\n    \"\"\"检查单个仓库的更新状态\"\"\"\n    repo = Path(repo_path)\n    if not repo.exists() or not (repo / \".git\").exists():\n        return {\"error\": \"Not a git repository\", \"path\": repo_path}\n\n    result = {\n        \"path\": repo_path,\n        \"name\": repo.name,\n        \"local_tag\": None,\n        \"upstream_tag\": None,\n        \"commits_behind\": 0,\n        \"commits_ahead\": 0,\n        \"status\": \"unknown\",\n        \"new_commits\": [],\n        \"new_tags\": [],\n        \"breaking_changes\": False,\n        \"remote_statuses\": {},\n        \"local_updates\": False,\n        \"diverged\": False,\n        \"fetch_ok\": True,\n        \"fetch_error\": None,\n    }\n\n    try:\n        fetch_error = fetch_repo(repo)\n        if fetch_error:\n            result[\"fetch_ok\"] = False\n            result[\"fetch_error\"] = fetch_error\n\n        # 获取当前 HEAD / tag\n        run_git(repo, [\"rev-parse\", \"--short\", \"HEAD\"])\n        try:\n            result[\"local_tag\"] = run_git(repo, [\"describe\", \"--tags\", \"--always\"])\n        except Exception:\n            pass\n\n        # 记录所有候选远端分支状态：优先 upstream，但 origin 也纳入报告\n        candidate_branches = [\n            \"upstream/main\", \"upstream/master\",\n            \"origin/main\", \"origin/master\",\n        ]\n        primary_branch = None\n        for branch in candidate_branches:\n            meta = compare_branch(repo, branch)\n            if not meta:\n                continue\n            result[\"remote_statuses\"][branch] = meta\n            if primary_branch is None:\n                primary_branch = branch\n\n        if primary_branch is None:\n            result[\"status\"] = \"no_upstream\"\n            return result\n\n        result[\"upstream_branch\"] = primary_branch\n        result[\"upstream_tag\"] = result[\"remote_statuses\"][primary_branch].get(\"tag\")\n        result[\"commits_behind\"] = max(v.get(\"behind\", 0) for v in result[\"remote_statuses\"].values())\n        result[\"commits_ahead\"] = max(v.get(\"ahead\", 0) for v in result[\"remote_statuses\"].values())\n        result[\"local_updates\"] = result[\"commits_behind\"] == 0 and result[\"commits_ahead\"] > 0\n        result[\"diverged\"] = any(v.get(\"behind\", 0) > 0 and v.get(\"ahead\", 0) > 0 for v in result[\"remote_statuses\"].values())\n\n        # 仅对主比较分支抓取上游新增 commit，避免重复\n        if result[\"remote_statuses\"][primary_branch].get(\"behind\", 0) > 0:\n            commits_raw = run_git(\n                repo,\n                [\"log\", f\"HEAD..{primary_branch}\", \"--format=%s|||%h\", \"-20\"]\n            )\n            for line in commits_raw.splitlines():\n                if not line.strip():\n                    continue\n                parts = line.split(\"|||\")\n                msg = parts[0].strip()\n                short = parts[1].strip() if len(parts) > 1 else \"\"\n                priority = classify_commit(msg)\n                is_break = \"breaking\" in priority.lower() or \"🔴\" in priority\n                result[\"new_commits\"].append({\n                    \"message\": msg,\n                    \"short\": short,\n                    \"priority\": priority,\n                    \"breaking\": is_break,\n                })\n                if is_break:\n                    result[\"breaking_changes\"] = True\n\n        # 状态判断\n        if result[\"diverged\"]:\n            result[\"status\"] = \"diverged\"\n        elif result[\"commits_behind\"] == 0 and result[\"commits_ahead\"] > 0:\n            result[\"status\"] = \"local_ahead\"\n        elif result[\"commits_behind\"] == 0:\n            result[\"status\"] = \"up_to_date\"\n        elif result[\"breaking_changes\"]:\n            result[\"status\"] = \"breaking_update\"\n        elif result[\"commits_behind\"] <= 3:\n            result[\"status\"] = \"minor_update\"\n        elif result[\"commits_behind\"] <= 10:\n            result[\"status\"] = \"major_update\"\n        else:\n            result[\"status\"] = \"far_behind\"\n\n    except Exception as e:\n        result[\"error\"] = str(e)\n\n    return result\n\n\ndef classify_commit(message: str) -> str:\n    \"\"\"根据 commit message 分类优先级\"\"\"\n    msg_lower = message.lower()\n    for kw, label in COMMIT_PRIORITY_KEYWORDS.items():\n        if kw in msg_lower:\n            # 跳过低优先级\n            for skip in SKIP_KEYWORDS:\n                if skip in msg_lower:\n                    return \"⚪ 维护\"\n            return label\n    return \"⚪ 其他\"\n\n\ndef should_update(status: dict) -> tuple[bool, str, int]:\n    \"\"\"\n    判断是否建议更新\n    返回：(建议更新, 理由, 优先级 1-5)\n    \"\"\"\n    s = status.get(\"status\", \"\")\n    commits = status.get(\"commits_behind\", 0)\n    breaking = status.get(\"breaking_changes\", False)\n\n    if s == \"up_to_date\":\n        return False, \"已是最新版本\", 0\n    if s == \"local_ahead\":\n        return False, f\"本地有新增提交（ahead {status.get('commits_ahead', 0)}）\", 1\n    if s == \"no_upstream\":\n        return False, \"无 upstream remote，跳过\", 0\n    if s == \"diverged\":\n        return True, f\"本地与远端已分叉（behind {status.get('commits_behind', 0)} / ahead {status.get('commits_ahead', 0)}）\", 5\n\n    if breaking:\n        return True, f\"包含 Breaking Changes，强烈建议更新（{commits} commits）\", 5\n    if commits >= 10:\n        return True, f\"落后 {commits} 个 commits，建议一次性合并\", 4\n    if commits >= 5:\n        return True, f\"落后 {commits} 个 commits，可择机更新\", 3\n    if commits >= 1:\n        return True, f\"落后 {commits} 个 commits，可按需更新\", 2\n    return False, f\"落后 {commits} 个 commits，影响不大\", 1\n\n\ndef build_report(all_results: list[dict]) -> str:\n    \"\"\"生成更新报告\"\"\"\n    today = date.today().strftime(\"%Y-%m-%d\")\n    lines = [f\"# GitHub 仓库更新报告 — {today}\", \"\"]\n\n    recommend_updates = [r for r in all_results if should_update(r)[0]]\n    local_changes = [r for r in all_results if r.get(\"status\") == \"local_ahead\"]\n    up_to_date = [r for r in all_results if r.get(\"status\") == \"up_to_date\"]\n    no_update = [r for r in all_results if not should_update(r)[0] and r.get(\"status\") not in {\"up_to_date\", \"local_ahead\"}]\n\n    lines.append(f\"**检查仓库数：{len(all_results)}** | 建议更新：{len(recommend_updates)} | 本地有新增：{len(local_changes)} | 已同步：{len(up_to_date)}\")\n    lines.append(\"\")\n\n    if recommend_updates:\n        lines.append(\"## 🔔 需要关注的更新\\n\")\n        for r in sorted(recommend_updates, key=lambda x: should_update(x)[2], reverse=True):\n            _, reason, priority = should_update(r)\n            stars = \"⭐\" * priority\n            lines.append(f\"### {r['name']} {stars}（{r.get('upstream_tag', '?')}）\")\n            lines.append(f\"- 当前版本：{r.get('local_tag', '?')}\")\n            lines.append(f\"- 主比较分支：{r.get('upstream_branch', '?')}\")\n            lines.append(f\"- 上游版本：{r.get('upstream_tag', '?')}\")\n            lines.append(f\"- 落后：{r['commits_behind']} commits | Ahead：{r['commits_ahead']}\")\n            lines.append(f\"- **建议：{reason}**\")\n            if r.get(\"breaking_changes\"):\n                lines.append(\"- ⚠️ **包含 Breaking Changes**\")\n            if r.get(\"remote_statuses\"):\n                remote_desc = \"；\".join(\n                    f\"{branch}: behind {meta.get('behind', 0)} / ahead {meta.get('ahead', 0)}\"\n                    for branch, meta in r[\"remote_statuses\"].items()\n                )\n                lines.append(f\"- 远端对比：{remote_desc}\")\n            if r.get(\"new_commits\"):\n                lines.append(\"\")\n                lines.append(\"**主要变更：**\")\n                shown = 0\n                for c in r[\"new_commits\"][:8]:\n                    if shown >= 5:\n                        break\n                    lines.append(f\"- {c['priority']} `{c['short']}` {c['message']}\")\n                    shown += 1\n            lines.append(\"\")\n    elif not local_changes:\n        lines.append(\"## ✅ 所有仓库已同步，无需处理\\n\")\n\n    if local_changes:\n        lines.append(\"## 🛠 本地有新增提交\\n\")\n        for r in local_changes:\n            lines.append(f\"### {r['name']}\")\n            lines.append(f\"- 当前版本：{r.get('local_tag', '?')}\")\n            lines.append(f\"- 主比较分支：{r.get('upstream_branch', '?')}\")\n            lines.append(f\"- 本地领先：{r.get('commits_ahead', 0)} commits\")\n            if r.get(\"remote_statuses\"):\n                remote_desc = \"；\".join(\n                    f\"{branch}: behind {meta.get('behind', 0)} / ahead {meta.get('ahead', 0)}\"\n                    for branch, meta in r[\"remote_statuses\"].items()\n                )\n                lines.append(f\"- 远端对比：{remote_desc}\")\n            if not r.get(\"fetch_ok\", True) and r.get(\"fetch_error\"):\n                lines.append(f\"- ⚠️ fetch 失败：{r['fetch_error']}\")\n            lines.append(\"\")\n\n    if up_to_date:\n        lines.append(f\"**已同步（{len(up_to_date)}）：** \" + \"、\".join(r[\"name\"] for r in up_to_date))\n        lines.append(\"\")\n\n    if no_update:\n        lines.append(f\"**无需操作（{len(no_update)}）：** \" + \"、\".join(r[\"name\"] for r in no_update))\n        lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(f\"*由 github-repo-monitor 自动生成 | {datetime.now().strftime('%H:%M')}*\")\n    return \"\\n\".join(lines)\n\n\ndef build_summary(results: list[dict]) -> str:\n    \"\"\"生成飞书摘要\"\"\"\n    recommend = [r for r in results if should_update(r)[0]]\n    breaking = [r for r in results if r.get(\"breaking_changes\")]\n    up_to_date = [r for r in results if r.get(\"status\") == \"up_to_date\"]\n    local_changes = [r for r in results if r.get(\"status\") == \"local_ahead\"]\n\n    if recommend:\n        top = recommend[0]\n        msg = f\"🔔 GitHub 仓库检查 | 上游 {len(recommend)} 个待处理 | 本地 {len(local_changes)} 个有新增 | 最高优先：{top['name']}（behind {top['commits_behind']}）\"\n        if breaking:\n            msg += f\"\\n⚠️ 含 Breaking Changes：{'、'.join(r['name'] for r in breaking)}\"\n        return msg\n\n    if local_changes:\n        return f\"🛠 GitHub 仓库检查 | 本地 {len(local_changes)} 个有新增 | 上游 0 个待处理 | {local_changes[0]['name']} 等\"\n\n    return f\"✅ GitHub 仓库检查 | {len(up_to_date)} 个已同步 | 无需处理\"\n\n\ndef save_report(report: str, results: list[dict]):\n    \"\"\"保存报告\"\"\"\n    today = date.today().strftime(\"%Y%m%d\")\n    out_dir = Path.home() / \".openclaw\" / \"workspace\" / \"research\" / \"reports\"\n    out_dir.mkdir(parents=True, exist_ok=True)\n\n    f1 = out_dir / f\"github_repo_update_report_{today}.md\"\n    f2 = out_dir / \"github_repo_update_latest.md\"\n    f1.write_text(report, encoding=\"utf-8\")\n    f2.write_text(report, encoding=\"utf-8\")\n\n    # 保存 JSON\n    state = {\n        \"checked_at\": datetime.now().isoformat(),\n        \"results\": results,\n    }\n    state_file = out_dir / f\"github_repo_update_state_{today}.json\"\n    state_file.write_text(json.dumps(state, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n    print(f\"报告已保存: {f1.name}\")\n    return str(f1)\n\n\ndef send_feishu(summary: str) -> bool:\n    \"\"\"推送飞书摘要\"\"\"\n    try:\n        import requests\n        resp = requests.post(\n            FEISHU_WEBHOOK,\n            json={\"msg_type\": \"text\", \"content\": {\"text\": summary}},\n            timeout=10\n        )\n        return resp.status_code == 200\n    except Exception as e:\n        print(f\"[飞书推送失败] {e}\", file=sys.stderr)\n        return False\n\n\ndef main():\n    print(f\"[{datetime.now():%Y-%m-%d %H:%M:%S}] 检查 GitHub 仓库更新...\")\n\n    repos = load_config()\n    print(f\"监控仓库数：{len(repos)}\")\n\n    results = []\n    for repo_cfg in repos:\n        path = repo_cfg.get(\"path\") or repo_cfg.get(\"repo_path\")\n        if not path:\n            continue\n        print(f\"  检查: {path}...\", end=\" \", flush=True)\n        status = get_repo_status(path)\n        results.append(status)\n        commits = status.get(\"commits_behind\", \"?\")\n        ahead = status.get(\"commits_ahead\", \"?\")\n        local = status.get(\"local_tag\", \"?\")\n        upstream = status.get(\"upstream_tag\", \"?\")\n        print(f\"本地={local} 上游={upstream} 落后={commits} commits 超前={ahead} commits [{status.get('status','?')}]\")\n\n    report = build_report(results)\n    report_path = save_report(report, results)\n    summary = build_summary(results)\n\n    # 保存状态\n    STATE_FILE.write_text(json.dumps({\n        \"checked_at\": datetime.now().isoformat(),\n        \"results\": results,\n    }, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n    # 飞书推送\n    ok = send_feishu(summary)\n    print(f\"飞书推送: {'成功' if ok else '失败'}\")\n    print(f\"\\n报告路径: {report_path}\")\n\n    return results\n\n\nif __name__ == \"__main__\":\n    main()\n"},"partialJson":"{\"file\":\"/Users/ling/.openclaw/skills/github-repo-monitor/scripts/check_updates.py\",\"content\":\"#!/usr/bin/env python3\\n\\\"\\\"\\\"\\nGitHub 仓库更新检查脚本\\n- 检查所有配置的仓库是否有上游更新\\n- 分析 CHANGELOG / Release Notes 判断是否建议更新\\n- 有重要更新时推送飞书通知\\n- 记录状态到 JSON 文件\\n\\\"\\\"\\\"\\n\\nimport json\\nimport subprocess\\nimport sys\\nimport re\\nfrom datetime import datetime, date\\nfrom pathlib import Path\\nfrom typing import Optional\\n\\n# ── 路径配置 ──────────────────────────────────────────────\\nSKILL_DIR = Path(__file__).resolve().parents[1]\\nCONFIG_FILE = SKILL_DIR / \\\"config\\\" / \\\"repos.json\\\"\\nSTATE_FILE = SKILL_DIR / \\\"state\\\" / \\\"last_check.json\\\"\\nSTATE_FILE.parent.mkdir(parents=True, exist_ok=True)\\nFEISHU_WEBHOOK = \\\"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\\\"\\n\\n# ── 判断规则：commit message 关键词 → 优先级 ───────────────\\nCOMMIT_PRIORITY_KEYWORDS = {\\n    \\\"breaking\\\": \\\"🔴 Breaking\\\",\\n    \\\"feat:\\\": \\\"🟢 新功能\\\",\\n    \\\"fix:\\\": \\\"🟡 Bug修复\\\",\\n    \\\"refactor:\\\": \\\"🔵 重构\\\",\\n    \\\"docs:\\\": \\\"📝 文档\\\",\\n    \\\"perf:\\\": \\\"⚡ 性能\\\",\\n    \\\"test:\\\": \\\"🧪 测试\\\",\\n    \\\"chore:\\\": \\\"🔧 维护\\\",\\n    \\\"security\\\": \\\"🔴 安全\\\",\\n    \\\"hotfix\\\": \\\"🔴 热修复\\\",\\n}\\n\\n# 低优先级关键字（自动跳过）\\nSKIP_KEYWORDS = [\\\"chore(deps)\\\", \\\"ci\\\", \\\"build:\\\", \\\"style:\\\", \\\"lint:\\\"]\\n\\n\\ndef load_config() -> list[dict]:\\n    \\\"\\\"\\\"加载仓库配置\\\"\\\"\\\"\\n    if CONFIG_FILE.exists():\\n        return json.loads(CONFIG_FILE.read_text(encoding=\\\"utf-8\\\"))\\n    # 默认配置：如果有 upstream remote 的 git 仓库\\n    default_repos = discover_git_repos()\\n    return [{\\\"path\\\": str(r)} for r in default_repos]\\n\\n\\ndef discover_git_repos() -> list[Path]:\\n    \\\"\\\"\\\"自动发现 workspace 下有 upstream 的 git 仓库\\\"\\\"\\\"\\n    workspace = Path.home() / \\\".openclaw\\\" / \\\"workspace\\\"\\n    found = []\\n    for git_dir in workspace.rglob(\\\".git\\\"):\\n        repo_dir = git_dir.parent\\n        try:\\n            # 检查是否有 upstream remote\\n            r = run_git(repo_dir, [\\\"remote\\\", \\\"get-url\\\", \\\"upstream\\\"])\\n            upstream = r.strip() if r else \\\"\\\"\\n            r2 = run_git(repo_dir, [\\\"remote\\\", \\\"get-url\\\", \\\"origin\\\"])\\n            origin = r2.strip() if r2 else \\\"\\\"\\n            if upstream or \\\"ZhuLinsen\\\" in origin or \\\"seablue1985\\\" in origin:\\n                found.append(repo_dir)\\n        except Exception:\\n            pass\\n    return found\\n\\n\\ndef run_git(repo_dir: Path, args: list[str], timeout: int = 15) -> str:\\n    \\\"\\\"\\\"运行 git 命令\\\"\\\"\\\"\\n    full_cmd = [\\\"git\\\", \\\"-C\\\", str(repo_dir)] + args\\n    r = subprocess.run(full_cmd, capture_output=True, text=True, timeout=timeout)\\n    if r.returncode != 0:\\n        raise RuntimeError(f\\\"git failed: {r.stderr.strip()}\\\")\\n    return r.stdout.strip()\\n\\n\\ndef fetch_repo(repo_dir: Path) -> Optional[str]:\\n    \\\"\\\"\\\"刷新远端引用；失败时返回错误文本，不中断整体检查。\\\"\\\"\\\"\\n    try:\\n        run_git(repo_dir, [\\\"fetch\\\", \\\"--all\\\", \\\"--tags\\\", \\\"--prune\\\"], timeout=60)\\n        return None\\n    except Exception as e:\\n        return str(e)\\n\\n\\ndef compare_branch(repo: Path, branch: str) -> Optional[dict]:\\n    \\\"\\\"\\\"对比本地 HEAD 与指定远端分支。\\\"\\\"\\\"\\n    try:\\n        run_git(repo, [\\\"rev-parse\\\", \\\"--short\\\", branch])\\n    except Exception:\\n        return None\\n\\n    try:\\n        branch_tag = run_git(repo, [\\\"describe\\\", \\\"--tags\\\", \\\"--always\\\", branch])\\n    except Exception:\\n        branch_tag = None\\n\\n    try:\\n        behind = int(run_git(repo, [\\\"rev-list\\\", \\\"--count\\\", f\\\"HEAD..{branch}\\\"]))\\n        ahead = int(run_git(repo, [\\\"rev-list\\\", \\\"--count\\\", f\\\"{branch}..HEAD\\\"]))\\n    except Exception:\\n        behind = 0\\n        ahead = 0\\n\\n    return {\\n        \\\"tag\\\": branch_tag,\\n        \\\"behind\\\": behind,\\n        \\\"ahead\\\": ahead,\\n    }\\n\\n\\ndef get_repo_status(repo_path: str) -> dict:\\n    \\\"\\\"\\\"检查单个仓库的更新状态\\\"\\\"\\\"\\n    repo = Path(repo_path)\\n    if not repo.exists() or not (repo / \\\".git\\\").exists():\\n        return {\\\"error\\\": \\\"Not a git repository\\\", \\\"path\\\": repo_path}\\n\\n    result = {\\n        \\\"path\\\": repo_path,\\n        \\\"name\\\": repo.name,\\n        \\\"local_tag\\\": None,\\n        \\\"upstream_tag\\\": None,\\n        \\\"commits_behind\\\": 0,\\n        \\\"commits_ahead\\\": 0,\\n        \\\"status\\\": \\\"unknown\\\",\\n        \\\"new_commits\\\": [],\\n        \\\"new_tags\\\": [],\\n        \\\"breaking_changes\\\": False,\\n        \\\"remote_statuses\\\": {},\\n        \\\"local_updates\\\": False,\\n        \\\"diverged\\\": False,\\n        \\\"fetch_ok\\\": True,\\n        \\\"fetch_error\\\": None,\\n    }\\n\\n    try:\\n        fetch_error = fetch_repo(repo)\\n        if fetch_error:\\n            result[\\\"fetch_ok\\\"] = False\\n            result[\\\"fetch_error\\\"] = fetch_error\\n\\n        # 获取当前 HEAD / tag\\n        run_git(repo, [\\\"rev-parse\\\", \\\"--short\\\", \\\"HEAD\\\"])\\n        try:\\n            result[\\\"local_tag\\\"] = run_git(repo, [\\\"describe\\\", \\\"--tags\\\", \\\"--always\\\"])\\n        except Exception:\\n            pass\\n\\n        # 记录所有候选远端分支状态：优先 upstream，但 origin 也纳入报告\\n        candidate_branches = [\\n            \\\"upstream/main\\\", \\\"upstream/master\\\",\\n            \\\"origin/main\\\", \\\"origin/master\\\",\\n        ]\\n        primary_branch = None\\n        for branch in candidate_branches:\\n            meta = compare_branch(repo, branch)\\n            if not meta:\\n                continue\\n            result[\\\"remote_statuses\\\"][branch] = meta\\n            if primary_branch is None:\\n                primary_branch = branch\\n\\n        if primary_branch is None:\\n            result[\\\"status\\\"] = \\\"no_upstream\\\"\\n            return result\\n\\n        result[\\\"upstream_branch\\\"] = primary_branch\\n        result[\\\"upstream_tag\\\"] = result[\\\"remote_statuses\\\"][primary_branch].get(\\\"tag\\\")\\n        result[\\\"commits_behind\\\"] = max(v.get(\\\"behind\\\", 0) for v in result[\\\"remote_statuses\\\"].values())\\n        result[\\\"commits_ahead\\\"] = max(v.get(\\\"ahead\\\", 0) for v in result[\\\"remote_statuses\\\"].values())\\n        result[\\\"local_updates\\\"] = result[\\\"commits_behind\\\"] == 0 and result[\\\"commits_ahead\\\"] > 0\\n        result[\\\"diverged\\\"] = any(v.get(\\\"behind\\\", 0) > 0 and v.get(\\\"ahead\\\", 0) > 0 for v in result[\\\"remote_statuses\\\"].values())\\n\\n        # 仅对主比较分支抓取上游新增 commit，避免重复\\n        if result[\\\"remote_statuses\\\"][primary_branch].get(\\\"behind\\\", 0) > 0:\\n            commits_raw = run_git(\\n                repo,\\n                [\\\"log\\\", f\\\"HEAD..{primary_branch}\\\", \\\"--format=%s|||%h\\\", \\\"-20\\\"]\\n            )\\n            for line in commits_raw.splitlines():\\n                if not line.strip():\\n                    continue\\n                parts = line.split(\\\"|||\\\")\\n                msg = parts[0].strip()\\n                short = parts[1].strip() if len(parts) > 1 else \\\"\\\"\\n                priority = classify_commit(msg)\\n                is_break = \\\"breaking\\\" in priority.lower() or \\\"🔴\\\" in priority\\n                result[\\\"new_commits\\\"].append({\\n                    \\\"message\\\": msg,\\n                    \\\"short\\\": short,\\n                    \\\"priority\\\": priority,\\n                    \\\"breaking\\\": is_break,\\n                })\\n                if is_break:\\n                    result[\\\"breaking_changes\\\"] = True\\n\\n        # 状态判断\\n        if result[\\\"diverged\\\"]:\\n            result[\\\"status\\\"] = \\\"diverged\\\"\\n        elif result[\\\"commits_behind\\\"] == 0 and result[\\\"commits_ahead\\\"] > 0:\\n            result[\\\"status\\\"] = \\\"local_ahead\\\"\\n        elif result[\\\"commits_behind\\\"] == 0:\\n            result[\\\"status\\\"] = \\\"up_to_date\\\"\\n        elif result[\\\"breaking_changes\\\"]:\\n            result[\\\"status\\\"] = \\\"breaking_update\\\"\\n        elif result[\\\"commits_behind\\\"] <= 3:\\n            result[\\\"status\\\"] = \\\"minor_update\\\"\\n        elif result[\\\"commits_behind\\\"] <= 10:\\n            result[\\\"status\\\"] = \\\"major_update\\\"\\n        else:\\n            result[\\\"status\\\"] = \\\"far_behind\\\"\\n\\n    except Exception as e:\\n        result[\\\"error\\\"] = str(e)\\n\\n    return result\\n\\n\\ndef classify_commit(message: str) -> str:\\n    \\\"\\\"\\\"根据 commit message 分类优先级\\\"\\\"\\\"\\n    msg_lower = message.lower()\\n    for kw, label in COMMIT_PRIORITY_KEYWORDS.items():\\n        if kw in msg_lower:\\n            # 跳过低优先级\\n            for skip in SKIP_KEYWORDS:\\n                if skip in msg_lower:\\n                    return \\\"⚪ 维护\\\"\\n            return label\\n    return \\\"⚪ 其他\\\"\\n\\n\\ndef should_update(status: dict) -> tuple[bool, str, int]:\\n    \\\"\\\"\\\"\\n    判断是否建议更新\\n    返回：(建议更新, 理由, 优先级 1-5)\\n    \\\"\\\"\\\"\\n    s = status.get(\\\"status\\\", \\\"\\\")\\n    commits = status.get(\\\"commits_behind\\\", 0)\\n    breaking = status.get(\\\"breaking_changes\\\", False)\\n\\n    if s == \\\"up_to_date\\\":\\n        return False, \\\"已是最新版本\\\", 0\\n    if s == \\\"local_ahead\\\":\\n        return False, f\\\"本地有新增提交（ahead {status.get('commits_ahead', 0)}）\\\", 1\\n    if s == \\\"no_upstream\\\":\\n        return False, \\\"无 upstream remote，跳过\\\", 0\\n    if s == \\\"diverged\\\":\\n        return True, f\\\"本地与远端已分叉（behind {status.get('commits_behind', 0)} / ahead {status.get('commits_ahead', 0)}）\\\", 5\\n\\n    if breaking:\\n        return True, f\\\"包含 Breaking Changes，强烈建议更新（{commits} commits）\\\", 5\\n    if commits >= 10:\\n        return True, f\\\"落后 {commits} 个 commits，建议一次性合并\\\", 4\\n    if commits >= 5:\\n        return True, f\\\"落后 {commits} 个 commits，可择机更新\\\", 3\\n    if commits >= 1:\\n        return True, f\\\"落后 {commits} 个 commits，可按需更新\\\", 2\\n    return False, f\\\"落后 {commits} 个 commits，影响不大\\\", 1\\n\\n\\ndef build_report(all_results: list[dict]) -> str:\\n    \\\"\\\"\\\"生成更新报告\\\"\\\"\\\"\\n    today = date.today().strftime(\\\"%Y-%m-%d\\\")\\n    lines = [f\\\"# GitHub 仓库更新报告 — {today}\\\", \\\"\\\"]\\n\\n    recommend_updates = [r for r in all_results if should_update(r)[0]]\\n    local_changes = [r for r in all_results if r.get(\\\"status\\\") == \\\"local_ahead\\\"]\\n    up_to_date = [r for r in all_results if r.get(\\\"status\\\") == \\\"up_to_date\\\"]\\n    no_update = [r for r in all_results if not should_update(r)[0] and r.get(\\\"status\\\") not in {\\\"up_to_date\\\", \\\"local_ahead\\\"}]\\n\\n    lines.append(f\\\"**检查仓库数：{len(all_results)}** | 建议更新：{len(recommend_updates)} | 本地有新增：{len(local_changes)} | 已同步：{len(up_to_date)}\\\")\\n    lines.append(\\\"\\\")\\n\\n    if recommend_updates:\\n        lines.append(\\\"## 🔔 需要关注的更新\\\\n\\\")\\n        for r in sorted(recommend_updates, key=lambda x: should_update(x)[2], reverse=True):\\n            _, reason, priority = should_update(r)\\n            stars = \\\"⭐\\\" * priority\\n            lines.append(f\\\"### {r['name']} {stars}（{r.get('upstream_tag', '?')}）\\\")\\n            lines.append(f\\\"- 当前版本：{r.get('local_tag', '?')}\\\")\\n            lines.append(f\\\"- 主比较分支：{r.get('upstream_branch', '?')}\\\")\\n            lines.append(f\\\"- 上游版本：{r.get('upstream_tag', '?')}\\\")\\n            lines.append(f\\\"- 落后：{r['commits_behind']} commits | Ahead：{r['commits_ahead']}\\\")\\n            lines.append(f\\\"- **建议：{reason}**\\\")\\n            if r.get(\\\"breaking_changes\\\"):\\n                lines.append(\\\"- ⚠️ **包含 Breaking Changes**\\\")\\n            if r.get(\\\"remote_statuses\\\"):\\n                remote_desc = \\\"；\\\".join(\\n                    f\\\"{branch}: behind {meta.get('behind', 0)} / ahead {meta.get('ahead', 0)}\\\"\\n                    for branch, meta in r[\\\"remote_statuses\\\"].items()\\n                )\\n                lines.append(f\\\"- 远端对比：{remote_desc}\\\")\\n            if r.get(\\\"new_commits\\\"):\\n                lines.append(\\\"\\\")\\n                lines.append(\\\"**主要变更：**\\\")\\n                shown = 0\\n                for c in r[\\\"new_commits\\\"][:8]:\\n                    if shown >= 5:\\n                        break\\n                    lines.append(f\\\"- {c['priority']} `{c['short']}` {c['message']}\\\")\\n                    shown += 1\\n            lines.append(\\\"\\\")\\n    elif not local_changes:\\n        lines.append(\\\"## ✅ 所有仓库已同步，无需处理\\\\n\\\")\\n\\n    if local_changes:\\n        lines.append(\\\"## 🛠 本地有新增提交\\\\n\\\")\\n        for r in local_changes:\\n            lines.append(f\\\"### {r['name']}\\\")\\n            lines.append(f\\\"- 当前版本：{r.get('local_tag', '?')}\\\")\\n            lines.append(f\\\"- 主比较分支：{r.get('upstream_branch', '?')}\\\")\\n            lines.append(f\\\"- 本地领先：{r.get('commits_ahead', 0)} commits\\\")\\n            if r.get(\\\"remote_statuses\\\"):\\n                remote_desc = \\\"；\\\".join(\\n                    f\\\"{branch}: behind {meta.get('behind', 0)} / ahead {meta.get('ahead', 0)}\\\"\\n                    for branch, meta in r[\\\"remote_statuses\\\"].items()\\n                )\\n                lines.append(f\\\"- 远端对比：{remote_desc}\\\")\\n            if not r.get(\\\"fetch_ok\\\", True) and r.get(\\\"fetch_error\\\"):\\n                lines.append(f\\\"- ⚠️ fetch 失败：{r['fetch_error']}\\\")\\n            lines.append(\\\"\\\")\\n\\n    if up_to_date:\\n        lines.append(f\\\"**已同步（{len(up_to_date)}）：** \\\" + \\\"、\\\".join(r[\\\"name\\\"] for r in up_to_date))\\n        lines.append(\\\"\\\")\\n\\n    if no_update:\\n        lines.append(f\\\"**无需操作（{len(no_update)}）：** \\\" + \\\"、\\\".join(r[\\\"name\\\"] for r in no_update))\\n        lines.append(\\\"\\\")\\n\\n    lines.append(\\\"---\\\")\\n    lines.append(f\\\"*由 github-repo-monitor 自动生成 | {datetime.now().strftime('%H:%M')}*\\\")\\n    return \\\"\\\\n\\\".join(lines)\\n\\n\\ndef build_summary(results: list[dict]) -> str:\\n    \\\"\\\"\\\"生成飞书摘要\\\"\\\"\\\"\\n    recommend = [r for r in results if should_update(r)[0]]\\n    breaking = [r for r in results if r.get(\\\"breaking_changes\\\")]\\n    up_to_date = [r for r in results if r.get(\\\"status\\\") == \\\"up_to_date\\\"]\\n    local_changes = [r for r in results if r.get(\\\"status\\\") == \\\"local_ahead\\\"]\\n\\n    if recommend:\\n        top = recommend[0]\\n        msg = f\\\"🔔 GitHub 仓库检查 | 上游 {len(recommend)} 个待处理 | 本地 {len(local_changes)} 个有新增 | 最高优先：{top['name']}（behind {top['commits_behind']}）\\\"\\n        if breaking:\\n            msg += f\\\"\\\\n⚠️ 含 Breaking Changes：{'、'.join(r['name'] for r in breaking)}\\\"\\n        return msg\\n\\n    if local_changes:\\n        return f\\\"🛠 GitHub 仓库检查 | 本地 {len(local_changes)} 个有新增 | 上游 0 个待处理 | {local_changes[0]['name']} 等\\\"\\n\\n    return f\\\"✅ GitHub 仓库检查 | {len(up_to_date)} 个已同步 | 无需处理\\\"\\n\\n\\ndef save_report(report: str, results: list[dict]):\\n    \\\"\\\"\\\"保存报告\\\"\\\"\\\"\\n    today = date.today().strftime(\\\"%Y%m%d\\\")\\n    out_dir = Path.home() / \\\".openclaw\\\" / \\\"workspace\\\" / \\\"research\\\" / \\\"reports\\\"\\n    out_dir.mkdir(parents=True, exist_ok=True)\\n\\n    f1 = out_dir / f\\\"github_repo_update_report_{today}.md\\\"\\n    f2 = out_dir / \\\"github_repo_update_latest.md\\\"\\n    f1.write_text(report, encoding=\\\"utf-8\\\")\\n    f2.write_text(report, encoding=\\\"utf-8\\\")\\n\\n    # 保存 JSON\\n    state = {\\n        \\\"checked_at\\\": datetime.now().isoformat(),\\n        \\\"results\\\": results,\\n    }\\n    state_file = out_dir / f\\\"github_repo_update_state_{today}.json\\\"\\n    state_file.write_text(json.dumps(state, ensure_ascii=False, indent=2), encoding=\\\"utf-8\\\")\\n\\n    print(f\\\"报告已保存: {f1.name}\\\")\\n    return str(f1)\\n\\n\\ndef send_feishu(summary: str) -> bool:\\n    \\\"\\\"\\\"推送飞书摘要\\\"\\\"\\\"\\n    try:\\n        import requests\\n        resp = requests.post(\\n            FEISHU_WEBHOOK,\\n            json={\\\"msg_type\\\": \\\"text\\\", \\\"content\\\": {\\\"text\\\": summary}},\\n            timeout=10\\n        )\\n        return resp.status_code == 200\\n    except Exception as e:\\n        print(f\\\"[飞书推送失败] {e}\\\", file=sys.stderr)\\n        return False\\n\\n\\ndef main():\\n    print(f\\\"[{datetime.now():%Y-%m-%d %H:%M:%S}] 检查 GitHub 仓库更新...\\\")\\n\\n    repos = load_config()\\n    print(f\\\"监控仓库数：{len(repos)}\\\")\\n\\n    results = []\\n    for repo_cfg in repos:\\n        path = repo_cfg.get(\\\"path\\\") or repo_cfg.get(\\\"repo_path\\\")\\n        if not path:\\n            continue\\n        print(f\\\"  检查: {path}...\\\", end=\\\" \\\", flush=True)\\n        status = get_repo_status(path)\\n        results.append(status)\\n        commits = status.get(\\\"commits_behind\\\", \\\"?\\\")\\n        ahead = status.get(\\\"commits_ahead\\\", \\\"?\\\")\\n        local = status.get(\\\"local_tag\\\", \\\"?\\\")\\n        upstream = status.get(\\\"upstream_tag\\\", \\\"?\\\")\\n        print(f\\\"本地={local} 上游={upstream} 落后={commits} commits 超前={ahead} commits [{status.get('status','?')}]\\\")\\n\\n    report = build_report(results)\\n    report_path = save_report(report, results)\\n    summary = build_summary(results)\\n\\n    # 保存状态\\n    STATE_FILE.write_text(json.dumps({\\n        \\\"checked_at\\\": datetime.now().isoformat(),\\n        \\\"results\\\": results,\\n    }, ensure_ascii=False, indent=2), encoding=\\\"utf-8\\\")\\n\\n    # 飞书推送\\n    ok = send_feishu(summary)\\n    print(f\\\"飞书推送: {'成功' if ok else '失败'}\\\")\\n    print(f\\\"\\\\n报告路径: {report_path}\\\")\\n\\n    return results\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n\"}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":12386,"output":5046,"cacheRead":66304,"cacheWrite":0,"totalTokens":83736,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775083846519,"responseId":"resp_0faca0e75e9e48550169cda148da54819a858362272092775c"}}
