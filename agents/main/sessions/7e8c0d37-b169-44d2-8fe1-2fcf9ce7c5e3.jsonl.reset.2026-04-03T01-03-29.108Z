ppYRPkNvmnHZtg8z49iJZjTuBuicgRTn3mHminQExBjVdlyf9_MEIMtdlntv0vsLPD-e-jMoW6f0_v8LusV5w_oulGajRjhwkViIhUtqTasIMS8qJikIyem2ROZcrnyDtzAevv3KOI6mTFcgy333vjTMKhkNHrxlCxUX-9aKGNzs7TsEWP_-hdodjyAT2FnRR1aN5HJ3gKRDpM_T0UknaSlPlgX5EiHd5VwcqEPtEKg\",\"summary\":[]}"},{"type":"toolCall","id":"call_Q7hkxeuze3K5IwXNHAKlWfR0|fc_0faca0e75e9e48550169cda027c434819a80107180e0266871","name":"read","arguments":{"file":"/Users/ling/.openclaw/skills/github-repo-monitor/scripts/check_updates.py","offset":120,"limit":160},"partialJson":"{\"file\":\"/Users/ling/.openclaw/skills/github-repo-monitor/scripts/check_updates.py\",\"offset\":120,\"limit\":160}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":54322,"output":218,"cacheRead":8704,"cacheWrite":0,"totalTokens":63244,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775083553268,"responseId":"resp_0faca0e75e9e48550169cda0227b9c819aaaa5f5261522754a"}}
{"type":"message","id":"04f478e5","parentId":"d7f5f013","timestamp":"2026-04-01T22:46:00.730Z","message":{"role":"toolResult","toolCallId":"call_Q7hkxeuze3K5IwXNHAKlWfR0|fc_0faca0e75e9e48550169cda027c434819a80107180e0266871","toolName":"read","content":[{"type":"text","text":"        try:\n            result[\"local_tag\"] = run_git(repo, [\"describe\", \"--tags\", \"--always\"])\n        except Exception:\n            pass\n\n        # 获取 upstream 最新 tag\n        try:\n            upstream_tag = run_git(repo, [\"describe\", \"--tags\", \"--always\", result[\"upstream_branch\"]])\n            result[\"upstream_tag\"] = upstream_tag\n        except Exception:\n            pass\n\n        # 计算落后多少 commits\n        try:\n            behind = run_git(repo, [\"rev-list\", \"--count\", f\"HEAD..{result['upstream_branch']}\"])\n            ahead = run_git(repo, [\"rev-list\", \"--count\", f\"{result['upstream_branch']}..HEAD\"])\n            result[\"commits_behind\"] = int(behind)\n            result[\"commits_ahead\"] = int(ahead)\n        except Exception:\n            pass\n\n        # 获取具体的新 commit\n        if result[\"commits_behind\"] > 0:\n            commits_raw = run_git(\n                repo,\n                [\"log\", f\"HEAD..{result['upstream_branch']}\", \"--format=%s|||%h\", \"-20\"]\n            )\n            for line in commits_raw.splitlines():\n                if not line.strip():\n                    continue\n                parts = line.split(\"|||\")\n                msg = parts[0].strip()\n                short = parts[1].strip() if len(parts) > 1 else \"\"\n                priority = classify_commit(msg)\n                is_break = \"breaking\" in priority.lower() or \"🔴\" in priority\n                result[\"new_commits\"].append({\n                    \"message\": msg,\n                    \"short\": short,\n                    \"priority\": priority,\n                    \"breaking\": is_break,\n                })\n                if is_break:\n                    result[\"breaking_changes\"] = True\n\n        # 状态判断\n        if result[\"commits_behind\"] == 0:\n            result[\"status\"] = \"up_to_date\"\n        elif result[\"breaking_changes\"]:\n            result[\"status\"] = \"breaking_update\"\n        elif result[\"commits_behind\"] <= 3:\n            result[\"status\"] = \"minor_update\"\n        elif result[\"commits_behind\"] <= 10:\n            result[\"status\"] = \"major_update\"\n        else:\n            result[\"status\"] = \"far_behind\"\n\n    except Exception as e:\n        result[\"error\"] = str(e)\n\n    return result\n\n\ndef classify_commit(message: str) -> str:\n    \"\"\"根据 commit message 分类优先级\"\"\"\n    msg_lower = message.lower()\n    for kw, label in COMMIT_PRIORITY_KEYWORDS.items():\n        if kw in msg_lower:\n            # 跳过低优先级\n            for skip in SKIP_KEYWORDS:\n                if skip in msg_lower:\n                    return \"⚪ 维护\"\n            return label\n    return \"⚪ 其他\"\n\n\ndef should_update(status: dict) -> tuple[bool, str, int]:\n    \"\"\"\n    判断是否建议更新\n    返回：(建议更新, 理由, 优先级 1-5)\n    \"\"\"\n    s = status.get(\"status\", \"\")\n    commits = status.get(\"commits_behind\", 0)\n    breaking = status.get(\"breaking_changes\", False)\n\n    if s == \"up_to_date\":\n        return False, \"已是最新版本\", 0\n    if s == \"no_upstream\":\n        return False, \"无 upstream remote，跳过\", 0\n\n    if breaking:\n        return True, f\"包含 Breaking Changes，强烈建议更新（{commits} commits）\", 5\n    if commits >= 10:\n        return True, f\"落后 {commits} 个 commits，建议一次性合并\", 4\n    if commits >= 5:\n        return True, f\"落后 {commits} 个 commits，可择机更新\", 3\n    if commits >= 1:\n        return True, f\"落后 {commits} 个 commits，可按需更新\", 2\n    return False, f\"落后 {commits} 个 commits，影响不大\", 1\n\n\ndef build_report(all_results: list[dict]) -> str:\n    \"\"\"生成更新报告\"\"\"\n    today = date.today().strftime(\"%Y-%m-%d\")\n    lines = [f\"# GitHub 仓库更新报告 — {today}\", \"\"]\n\n    recommend_updates = [r for r in all_results if should_update(r)[0]]\n    up_to_date = [r for r in all_results if r.get(\"status\") == \"up_to_date\"]\n    no_update = [r for r in all_results if not should_update(r)[0] and r.get(\"status\") != \"up_to_date\"]\n\n    lines.append(f\"**检查仓库数：{len(all_results)}** | 建议更新：{len(recommend_updates)} | 已最新：{len(up_to_date)}\")\n    lines.append(\"\")\n\n    if recommend_updates:\n        lines.append(\"## 🔔 需要关注的更新\\n\")\n        for r in sorted(recommend_updates, key=lambda x: should_update(x)[2], reverse=True):\n            should, reason, priority = should_update(r)\n            stars = \"⭐\" * priority\n            lines.append(f\"### {r['name']} {stars}（{r.get('upstream_tag', '?')}）\")\n            lines.append(f\"- 当前版本：{r.get('local_tag', '?')}\")\n            lines.append(f\"- 上游版本：{r.get('upstream_tag', '?')}\")\n            lines.append(f\"- 落后：{r['commits_behind']} commits | Ahead：{r['commits_ahead']}\")\n            lines.append(f\"- **建议：{reason}**\")\n            if r.get(\"breaking_changes\"):\n                lines.append(f\"- ⚠️ **包含 Breaking Changes**\")\n            if r.get(\"new_commits\"):\n                lines.append(\"\")\n                lines.append(\"**主要变更：**\")\n                shown = 0\n                for c in r[\"new_commits\"][:8]:\n                    if shown >= 5:\n                        break\n                    lines.append(f\"- {c['priority']} `{c['short']}` {c['message']}\")\n                    shown += 1\n            lines.append(\"\")\n    else:\n        lines.append(\"## ✅ 所有仓库已最新，无需更新\\n\")\n\n    if up_to_date:\n        lines.append(f\"**已最新（{len(up_to_date)}）：** \" + \"、\".join(r[\"name\"] for r in up_to_date))\n        lines.append(\"\")\n\n    if no_update:\n        lines.append(f\"**无需操作（{len(no_update)}）：** \" + \"、\".join(r[\"name\"] for r in no_update))\n        lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(f\"*由 github-repo-monitor 自动生成 | {datetime.now().strftime('%H:%M')}*\")\n    return \"\\n\".join(lines)\n\n\ndef build_summary(results: list[dict]) -> str:\n    \"\"\"生成飞书摘要\"\"\"\n    recommend = [r for r in results if should_update(r)[0]]\n    breaking = [r for r in results if r.get(\"breaking_changes\")]\n    up_to_date = [r for r in results if r.get(\"status\") == \"up_to_date\"]\n\n    if not recommend:\n        msg = f\"✅ GitHub 仓库检查 | {len(up_to_date)} 个已最新 | 无需更新\"\n    else:\n        top = recommend[0]\n\n[84 more lines in file. Use offset=280 to continue.]"}],"isError":false,"timestamp":1775083560722}}
