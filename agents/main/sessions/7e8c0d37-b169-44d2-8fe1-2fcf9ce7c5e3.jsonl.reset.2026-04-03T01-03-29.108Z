{"type":"message","id":"f98ed715","parentId":"49e4739d","timestamp":"2026-04-02T07:59:10.629Z","message":{"role":"toolResult","toolCallId":"call_function_zei7szp8o6rt_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n持仓日报生成器\n仅允许使用已明确选定的真实持仓源；若缺失则中止发送，避免误发旧口径。\n\"\"\"\n\nimport csv\nimport html as html_mod\nimport re\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom real_holdings_source import resolve_real_holdings\n\nWORKSPACE = Path.home() / \".openclaw/workspace\"\nREPORTS = WORKSPACE / \"research/reports\"\nQUANT = WORKSPACE / \"quant_projects\" / \"personal-a-share-research-system\" / \"research\" / \"reports\"\nFEISHU_WEBHOOK = \"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\"\n\n\ndef is_trading_day() -> bool:\n    return datetime.now().weekday() < 5\n\n\ndef clean(text):\n    text = re.sub(r\"<[^>]+>\", \"\", str(text or \"\"))\n    return html_mod.unescape(text).strip()\n\n\ndef get_latest_file(pattern, base):\n    files = sorted(Path(base).glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)\n    return files[0] if files else None\n\n\ndef get_holdings():\n    holdings, meta = resolve_real_holdings(include_auto=False)\n    if not holdings:\n        raise RuntimeError(meta.get(\"fallback_reason\") or \"missing_trusted_real_holdings_source\")\n    return holdings, meta.get(\"date_tag\") or datetime.now().strftime(\"%Y%m%d\")\n\n\ndef get_strategy_summary():\n    f = get_latest_file(\"today_stock_strategy_report_????????.md\", QUANT)\n    if not f:\n        return {}\n    content = f.read_text(encoding=\"utf-8\") if f.exists() else \"\"\n\n    result = {}\n    m = re.search(r\"形成 `(\\d+)` 个去重 BUY 候选\", content)\n    if m:\n        result[\"buy_count\"] = int(m.group(1))\n    m = re.search(r\"形成 `(\\d+)` 个去重 SELL 候选\", content)\n    if m:\n        result[\"sell_count\"] = int(m.group(1))\n    m = re.search(r\"宽度门禁：当前 `([\\d.]+)%`\", content)\n    if m:\n        result[\"market_breadth\"] = float(m.group(1))\n    m = re.search(r\"风险模式：`(\\w+)`\", content)\n    if m:\n        result[\"risk_mode\"] = m.group(1)\n\n    f2 = QUANT / \"today_market_snapshot_latest.json\"\n    if f2.exists():\n        import json\n        try:\n            snap = json.loads(f2.read_text())\n            result[\"index_close\"] = snap.get(\"index_close\", {})\n        except Exception:\n            pass\n    return result\n\n\ndef get_audit():\n    f = get_latest_file(\"daily_strategy_audit_*.json\", QUANT)\n    if not f:\n        return {}\n    import json\n    try:\n        return json.loads(f.read_text())\n    except Exception:\n        return {}\n\n\ndef send_feishu(msg):\n    import requests\n    payload = {\"msg_type\": \"text\", \"content\": {\"text\": msg}}\n    resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\n    return resp.json()\n\n\ndef build_report(holdings, date, strategy, audit):\n    now = datetime.now()\n\n    a_stocks = []\n    hk_stocks = []\n    etf_funds = []\n    for h in holdings:\n        ts = h.get(\"ts_code\", \"\")\n        cur = h.get(\"currency\", \"CNY\")\n        name = h.get(\"name\", \"\") or ts\n        qty = int(float(h.get(\"qty\", 0) or 0))\n        cost = float(h.get(\"cost_price\", 0) or 0)\n        asset_type = h.get(\"asset_type\", \"stock\")\n\n        item = {\"code\": ts, \"name\": name, \"qty\": qty, \"cost_price\": cost, \"currency\": cur}\n        if cur == \"HKD\":\n            hk_stocks.append(item)\n        elif asset_type == \"etf\" or ts.startswith((\"5\", \"1\", \"15\")) or \"ETF\" in name.upper():\n            etf_funds.append(item)\n        else:\n            a_stocks.append(item)\n\n    total_cost = sum(float(h.get(\"cost_price\", 0) or 0) * int(float(h.get(\"qty\", 0) or 0)) for h in holdings)\n\n    lines = []\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(\"📊 持仓日报\")\n    lines.append(f\"日期：{date} | 生成：{now.strftime('%m-%d %H:%M')}\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    if a_stocks:\n        lines.append(f\"\\n【A 股持仓】共 {len(a_stocks)} 只\")\n        lines.append(f\"成本总额：{total_cost:,.0f} 元\")\n        lines.append(\"\")\n        for h in a_stocks:\n            name = h['name'] if h['name'] and h['name'] != h['code'] else h['code']\n            lines.append(f\"  {h['code']} {name[:6]}\")\n            lines.append(f\"    {h['qty']:,} 股 | 成本 {h['cost_price']:.3f} 元\")\n\n    if hk_stocks:\n        lines.append(f\"\\n【港股持仓】共 {len(hk_stocks)} 只\")\n        for h in hk_stocks:\n            lines.append(f\"  {h['code']} {h['name']}\")\n            lines.append(f\"    {h['qty']:,} 股 | 成本 {h['cost_price']:.3f} 港币\")\n\n    if etf_funds:\n        lines.append(f\"\\n【ETF/基金】共 {len(etf_funds)} 只\")\n        for h in etf_funds:\n            lines.append(f\"  {h['code']} {h['name']}\")\n            lines.append(f\"    {h['qty']:,} 份 | 成本 {h['cost_price']:.3f} 元\")\n\n    lines.append(\"\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"【汇总】A股 {len(a_stocks)} 只 | 港股 {len(hk_stocks)} | ETF {len(etf_funds)} 只\")\n    lines.append(f\"持仓总数：{len(holdings)} 只 | 成本总额：{total_cost:,.0f} 元\")\n\n    if strategy:\n        bw = strategy.get(\"market_breadth\")\n        buy = strategy.get(\"buy_count\", 0)\n        sell = strategy.get(\"sell_count\", 0)\n        if bw:\n            icon = \"🟢\" if bw >= 28 else \"🟡\" if bw >= 14 else \"🔴\"\n            lines.append(f\"\\n【市场宽度】{bw:.2f}% {icon}\")\n        if buy or sell:\n            lines.append(f\"【策略信号】BUY {buy} 个 | SELL {sell} 个\")\n        risk_mode = strategy.get(\"risk_mode\", \"\")\n        if risk_mode:\n            lines.append(f\"【风险模式】{risk_mode}\")\n\n    if audit:\n        ar = audit.get(\"annual_return_pct\", 0)\n        mdd = audit.get(\"max_drawdown_pct\", 0)\n        sharpe = audit.get(\"sharpe\", 0)\n        if ar:\n            lines.append(f\"\\n【模拟盘审计】年化 {ar:.1f}% | 回撤 {mdd:.1f}% | 夏普 {sharpe:.2f}\")\n\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"📊 生成时间：{now.strftime('%H:%M:%S')}\")\n    return \"\\n\".join(lines)\n\n\ndef main():\n    if not is_trading_day():\n        print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] 非 A 股交易日，跳过持仓日报\")\n        return\n\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] 生成持仓日报...\")\n    try:\n        holdings, date = get_holdings()\n    except Exception as e:\n        print(f\"[{datetime.now().strftime('%H:%M:%S')}] 中止发送：{e}\")\n        return\n\n    strategy = get_strategy_summary()\n    audit = get_audit()\n    report = build_report(holdings, date, strategy, audit)\n\n    out_file = REPORTS / \"daily_position_report_latest.md\"\n    out_file.write_text(report, encoding=\"utf-8\")\n    print(f\"已保存: {out_file.name}\")\n\n    print(\"\\n发送飞书...\")\n    result = send_feishu(report)\n    print(f\"发送结果: {result}\")\n    print(\"\\n\" + report)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1775116750618}}
{"type":"message","id":"9415ad1a","parentId":"f98ed715","timestamp":"2026-04-02T08:00:05.345Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the full file. The fix is:\n1. Add `get_live_market_breadth()` function that uses akshare to calculate real-time market breadth\n2. Modify `get_strategy_summary()` to call `get_live_market_breadth()` first, and use the result as `market_breadth` if available\n\nLet me write the complete updated file.","thinkingSignature":"8010364a31a8d06673f8fcb2bccb0f75f56e6f6d11147beb5afcc507c5676063"},{"type":"text","text":"文件全貌清晰了。我直接写进去，加 `get_live_market_breadth()` 并优先用实时值。\n"},{"type":"toolCall","id":"call_function_70ha0yuihhn5_1","name":"write","arguments":{"file":"/Users/ling/.openclaw/workspace/scripts/generate_daily_position_report.py","content":"#!/usr/bin/env python3\n\"\"\"\n持仓日报生成器\n仅允许使用已明确选定的真实持仓源；若缺失则中止发送，避免误发旧口径。\n\"\"\"\n\nimport csv\nimport html as html_mod\nimport re\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom real_holdings_source import resolve_real_holdings\n\nWORKSPACE = Path.home() / \".openclaw/workspace\"\nREPORTS = WORKSPACE / \"research/reports\"\nQUANT = WORKSPACE / \"quant_projects\" / \"personal-a-share-research-system\" / \"research\" / \"reports\"\nFEISHU_WEBHOOK = \"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\"\n\n\ndef is_trading_day() -> bool:\n    return datetime.now().weekday() < 5\n\n\ndef clean(text):\n    text = re.sub(r\"<[^>]+>\", \"\", str(text or \"\"))\n    return html_mod.unescape(text).strip()\n\n\ndef get_latest_file(pattern, base):\n    files = sorted(Path(base).glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)\n    return files[0] if files else None\n\n\ndef get_live_market_breadth():\n    \"\"\"实时计算今日盘中市场宽度：上涨股数/总交易股数\n    \n    优先从 AkShare 实时行情接口获取；\n    若接口不可用则返回 None，由调用方 fallback 到报告文件解析值。\n    \"\"\"\n    import warnings\n    warnings.filterwarnings('ignore')\n    try:\n        import akshare as ak\n        df = ak.stock_zh_a_spot_em()\n        total = len(df)\n        if total == 0:\n            return None\n        up = len(df[df['涨跌幅'] > 0])\n        breadth = round(up / total * 100, 2)\n        print(f\"[市场宽度] 实时盘中宽度={breadth}% (上涨 {up}/{total})\")\n        return breadth\n    except Exception as e:\n        print(f\"[市场宽度] 实时接口失败: {e}，fallback 到报告解析值\")\n        return None\n\n\ndef get_holdings():\n    holdings, meta = resolve_real_holdings(include_auto=False)\n    if not holdings:\n        raise RuntimeError(meta.get(\"fallback_reason\") or \"missing_trusted_real_holdings_source\")\n    return holdings, meta.get(\"date_tag\") or datetime.now().strftime(\"%Y%m%d\")\n\n\ndef get_strategy_summary():\n    # 优先尝试实时市场宽度\n    live_bw = get_live_market_breadth()\n\n    f = get_latest_file(\"today_stock_strategy_report_????????.md\", QUANT)\n    if not f:\n        result = {}\n        if live_bw is not None:\n            result[\"market_breadth\"] = live_bw\n        return result\n\n    content = f.read_text(encoding=\"utf-8\") if f.exists() else \"\"\n\n    result = {}\n    # 市场宽度：实时接口优先；正则解析值作为 fallback\n    if live_bw is not None:\n        result[\"market_breadth\"] = live_bw\n    else:\n        m = re.search(r\"宽度门禁：当前 `([\\d.]+)%`\", content)\n        if m:\n            result[\"market_breadth\"] = float(m.group(1))\n\n    m = re.search(r\"形成 `(\\d+)` 个去重 BUY 候选\", content)\n    if m:\n        result[\"buy_count\"] = int(m.group(1))\n    m = re.search(r\"形成 `(\\d+)` 个去重 SELL 候选\", content)\n    if m:\n        result[\"sell_count\"] = int(m.group(1))\n    m = re.search(r\"风险模式：`(\\w+)`\", content)\n    if m:\n        result[\"risk_mode\"] = m.group(1)\n\n    f2 = QUANT / \"today_market_snapshot_latest.json\"\n    if f2.exists():\n        import json\n        try:\n            snap = json.loads(f2.read_text())\n            result[\"index_close\"] = snap.get(\"index_close\", {})\n        except Exception:\n            pass\n    return result\n\n\ndef get_audit():\n    f = get_latest_file(\"daily_strategy_audit_*.json\", QUANT)\n    if not f:\n        return {}\n    import json\n    try:\n        return json.loads(f.read_text())\n    except Exception:\n        return {}\n\n\ndef send_feishu(msg):\n    import requests\n    payload = {\"msg_type\": \"text\", \"content\": {\"text\": msg}}\n    resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\n    return resp.json()\n\n\ndef build_report(holdings, date, strategy, audit):\n    now = datetime.now()\n\n    a_stocks = []\n    hk_stocks = []\n    etf_funds = []\n    for h in holdings:\n        ts = h.get(\"ts_code\", \"\")\n        cur = h.get(\"currency\", \"CNY\")\n        name = h.get(\"name\", \"\") or ts\n        qty = int(float(h.get(\"qty\", 0) or 0))\n        cost = float(h.get(\"cost_price\", 0) or 0)\n        asset_type = h.get(\"asset_type\", \"stock\")\n\n        item = {\"code\": ts, \"name\": name, \"qty\": qty, \"cost_price\": cost, \"currency\": cur}\n        if cur == \"HKD\":\n            hk_stocks.append(item)\n        elif asset_type == \"etf\" or ts.startswith((\"5\", \"1\", \"15\")) or \"ETF\" in name.upper():\n            etf_funds.append(item)\n        else:\n            a_stocks.append(item)\n\n    total_cost = sum(float(h.get(\"cost_price\", 0) or 0) * int(float(h.get(\"qty\", 0) or 0)) for h in holdings)\n\n    lines = []\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(\"📊 持仓日报\")\n    lines.append(f\"日期：{date} | 生成：{now.strftime('%m-%d %H:%M')}\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    if a_stocks:\n        lines.append(f\"\\n【A 股持仓】共 {len(a_stocks)} 只\")\n        lines.append(f\"成本总额：{total_cost:,.0f} 元\")\n        lines.append(\"\")\n        for h in a_stocks:\n            name = h['name'] if h['name'] and h['name'] != h['code'] else h['code']\n            lines.append(f\"  {h['code']} {name[:6]}\")\n            lines.append(f\"    {h['qty']:,} 股 | 成本 {h['cost_price']:.3f} 元\")\n\n    if hk_stocks:\n        lines.append(f\"\\n【港股持仓】共 {len(hk_stocks)} 只\")\n        for h in hk_stocks:\n            lines.append(f\"  {h['code']} {h['name']})\")\n            lines.append(f\"    {h['qty']:,} 股 | 成本 {h['cost_price']:.3f} 港币\")\n\n    if etf_funds:\n        lines.append(f\"\\n【ETF/基金】共 {len(etf_funds)} 只\")\n        for h in etf_funds:\n            lines.append(f\"  {h['code']} {h['name']})\")\n            lines.append(f\"    {h['qty']:,} 份 | 成本 {h['cost_price']:.3f} 元\")\n\n    lines.append(\"\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"【汇总】A股 {len(a_stocks)} 只 | 港股 {len(hk_stocks)} | ETF {len(etf_funds)} 只\")\n    lines.append(f\"持仓总数：{len(holdings)} 只 | 成本总额：{total_cost:,.0f} 元\")\n\n    if strategy:\n        bw = strategy.get(\"market_breadth\")\n        buy = strategy.get(\"buy_count\", 0)\n        sell = strategy.get(\"sell_count\", 0)\n        if bw:\n            icon = \"🟢\" if bw >= 28 else \"🟡\" if bw >= 14 else \"🔴\"\n            lines.append(f\"\\n【市场宽度】{bw:.2f}% {icon}\")\n        if buy or sell:\n            lines.append(f\"【策略信号】BUY {buy} 个 | SELL {sell} 个\")\n        risk_mode = strategy.get(\"risk_mode\", \"\")\n        if risk_mode:\n            lines.append(f\"【风险模式】{risk_mode}\")\n\n    if audit:\n        ar = audit.get(\"annual_return_pct\", 0)\n        mdd = audit.get(\"max_drawdown_pct\", 0)\n        sharpe = audit.get(\"sharpe\", 0)\n        if ar:\n            lines.append(f\"\\n【模拟盘审计】年化 {ar:.1f}% | 回撤 {mdd:.1f}% | 夏普 {sharpe:.2f}\")\n\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"📊 生成时间：{now.strftime('%H:%M:%S')}\")\n    return \"\\n\".join(lines)\n\n\ndef main():\n    if not is_trading_day():\n        print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] 非 A 股交易日，跳过持仓日报\")\n        return\n\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] 生成持仓日报...\")\n    try:\n        holdings, date = get_holdings()\n    except Exception as e:\n        print(f\"[{datetime.now().strftime('%H:%M:%S')}] 中止发送：{e}\")\n        return\n\n    strategy = get_strategy_summary()\n    audit = get_audit()\n    report = build_report(holdings, date, strategy, audit)\n\n    out_file = REPORTS / \"daily_position_report_latest.md\"\n    out_file.write_text(report, encoding=\"utf-8\")\n    print(f\"已保存: {out_file.name}\")\n\n    print(\"\\n发送飞书...\")\n    result = send_feishu(report)\n    print(f\"发送结果: {result}\")\n    print(\"\\n\" + report)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":37602,"output":2377,"cacheRead":25866,"cacheWrite":0,"totalTokens":65845,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775116750629,"responseId":"061d54ceddaa291d2abac0ee9fef076e"}}
