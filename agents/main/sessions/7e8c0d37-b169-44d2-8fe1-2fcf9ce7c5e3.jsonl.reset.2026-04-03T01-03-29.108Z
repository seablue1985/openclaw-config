\n        \"板块\", \"概念\", \"龙头\", \"庄家\", \"主力\", \"资金\", \"量能\", \"缩量\", \"放量\",\n        \"研报\", \"业绩\", \"财报\", \"PE\", \"PB\", \"估值\", \"股息\", \"分红\",\n        \"期权\", \"期货\", \"融资\", \"融券\", \"杠杆\", \"做空\", \"做多\",\n        \"美联储\", \"加息\", \"降息\", \"美股\", \"港股\", \"汇率\", \"人民币\", \"美元\",\n        \"央行\", \"货币政策\", \"经济数据\", \"CPI\", \"PPI\", \"GDP\",\n        \"宁德\", \"茅台\", \"比亚迪\", \"腾讯\", \"阿里\", \"美团\", \"京东\",\n        \"新能源\", \"半导体\", \"芯片\", \"AI\", \"人工智能\", \"医药\", \"白酒\",\n        \"证券\", \"基金\", \"私募\", \"公募\", \"量化\", \"对冲\",\n    ]\n    text_lower = text.lower()\n    return sum(1 for kw in keywords if kw in text) >= 2\n\n\ndef has_meaningful_content(text):\n    \"\"\"判断微博是否有实质内容（非纯标签/链接/空白）\n    \n    过滤掉以下类型：\n    - 纯标签微博（#话题# 连续出现但无语义文字）\n    - 仅包含链接/图片描述\n    - 太短（<10个非标签字符）\n    \"\"\"\n    if not text or len(text.strip()) == 0:\n        return False\n    # 去除标签（#...#）后检查剩余字符\n    text_no_tags = re.sub(r'#[^#]+#', '', text).strip()\n    # 去除URL\n    text_no_tags = re.sub(r'https?://\\S+', '', text_no_tags).strip()\n    # 去除空白字符后的长度\n    meaningful_chars = len(re.sub(r'\\s', '', text_no_tags))\n    return meaningful_chars >= 10"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":40608,"output":997,"cacheRead":25866,"cacheWrite":0,"totalTokens":67471,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775127505383,"responseId":"061d7ed134a407fa873682974e9e6c03"}}
