ation, especially if these details impact how I interact with the user's request. So, I’ll take some time to read through those portions carefully to ensure I understand everything correctly!\"}]}"},{"type":"toolCall","id":"call_wBxQUKANO7BtVNGqZyYxrSj6|fc_0faca0e75e9e48550169cd9d91a040819a844c656a7632350b","name":"read","arguments":{"file":"/Library/Frameworks/Python.framework/Versions/3.14/lib/python3.14/site-packages/mcp_server_weibo/weibo.py","limit":220},"partialJson":"{\"file\":\"/Library/Frameworks/Python.framework/Versions/3.14/lib/python3.14/site-packages/mcp_server_weibo/weibo.py\",\"limit\":220}"},{"type":"toolCall","id":"call_nwZ7CnvoZCRgxjUY5beO2gAH|fc_0faca0e75e9e48550169cd9d91a054819a914b045d4165f8cf","name":"read","arguments":{"file":"/Library/Frameworks/Python.framework/Versions/3.14/lib/python3.14/site-packages/mcp_server_weibo/README.md","limit":220},"partialJson":"{\"file\":\"/Library/Frameworks/Python.framework/Versions/3.14/lib/python3.14/site-packages/mcp_server_weibo/README.md\",\"limit\":220}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":5359,"output":132,"cacheRead":76800,"cacheWrite":0,"totalTokens":82291,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775082893274,"responseId":"resp_0faca0e75e9e48550169cd9d8e3394819a8fa6c379e929bf4e"}}
{"type":"message","id":"17f665ad","parentId":"277cd151","timestamp":"2026-04-01T22:34:58.122Z","message":{"role":"toolResult","toolCallId":"call_wBxQUKANO7BtVNGqZyYxrSj6|fc_0faca0e75e9e48550169cd9d91a040819a844c656a7632350b","toolName":"read","content":[{"type":"text","text":"import json\nimport os\nimport httpx\nimport re\nimport logging\nfrom urllib.parse import urlencode\nfrom .consts import DEFAULT_HEADERS, PROFILE_URL, FEEDS_URL, SEARCH_URL, COMMENTS_URL\nfrom .schemas import PagedFeeds, TrendingItem, FeedItem, UserProfile, CommentItem\n\n\nclass WeiboCrawler:\n    \"\"\"\n    A crawler class for extracting data from Weibo (Chinese social media platform).\n    Provides functionality to fetch user profiles, feeds, and search for users.\n    \"\"\"\n\n    def __init__(self):\n        self.logger = logging.getLogger(__name__)\n        self._cookies = None\n\n    async def _cookies_are_valid(self, cookies: dict) -> bool:\n        try:\n            async with httpx.AsyncClient(cookies=cookies, follow_redirects=False) as client:\n                response = await client.get(\"https://m.weibo.cn/\", headers=DEFAULT_HEADERS)\n                location = response.headers.get(\"location\", \"\")\n                if response.status_code in (301, 302, 303, 307, 308) and \"visitor.passport.weibo.cn\" in location:\n                    return False\n                return True\n        except httpx.HTTPError:\n            return False\n\n    async def _ensure_cookies(self, retry: bool = False) -> dict:\n        if self._cookies:\n            if await self._cookies_are_valid(self._cookies):\n                return self._cookies\n            self._cookies = None\n\n        env_cookie = os.getenv(\"WEIBO_COOKIE\", \"\").strip()\n        if env_cookie:\n            parsed = {}\n            for cookie_pair in env_cookie.split(\";\"):\n                cookie_pair = cookie_pair.strip()\n                if \"=\" not in cookie_pair:\n                    continue\n                key, value = cookie_pair.split(\"=\", 1)\n                key = key.strip()\n                value = value.strip()\n                if key and value:\n                    parsed[key] = value\n            if parsed:\n                if await self._cookies_are_valid(parsed):\n                    self._cookies = parsed\n                    return self._cookies\n\n        try:\n            async with httpx.AsyncClient() as client:\n                response = await client.post(\n                    \"https://visitor.passport.weibo.cn/visitor/genvisitor2\",\n                    data={\n                        \"cb\": \"visitor_callback\",\n                        \"from\": \"weibo\",\n                        \"tid\": \"\",\n                        \"return_url\": \"https://m.weibo.cn/\",\n                    },\n                    headers={\"User-Agent\": DEFAULT_HEADERS.get(\"User-Agent\", \"\")},\n                )\n                response.raise_for_status()\n                match = re.search(r\"visitor_callback\\((.*)\\)\", response.text)\n                if not match:\n                    raise ValueError(\"Invalid visitor passport response\")\n                payload = json.loads(match.group(1))\n                data = payload.get(\"data\", {})\n                sub = data.get(\"sub\")\n                subp = data.get(\"subp\")\n                if not sub or not subp:\n                    raise ValueError(\"Missing SUB/SUBP in visitor passport response\")\n\n                generated = {\"SUB\": sub, \"SUBP\": subp}\n                if not await self._cookies_are_valid(generated):\n                    raise ValueError(\"Generated visitor cookies are invalid\")\n                self._cookies = generated\n                return self._cookies\n        except (httpx.HTTPError, json.JSONDecodeError, ValueError):\n            self.logger.error(\"Unable to initialize Weibo visitor cookies\", exc_info=True)\n            self._cookies = None\n            if not retry:\n                return await self._ensure_cookies(retry=True)\n            raise\n\n    async def get_profile(self, uid: int) -> UserProfile:\n        \"\"\"\n        Extract user profile information from Weibo.\n\n        Args:\n            uid (int): The unique identifier of the Weibo user\n\n        Returns:\n            UserProfile: User profile information or empty dict if extraction fails\n        \"\"\"\n        cookies = await self._ensure_cookies()\n        async with httpx.AsyncClient(cookies=cookies) as client:\n            try:\n                response = await client.get(PROFILE_URL.format(userId=uid), headers=DEFAULT_HEADERS)\n                result = response.json()\n                return self._to_user_profile(result[\"data\"][\"userInfo\"])\n            except httpx.HTTPError:\n                self.logger.error(\n                    f\"Unable to eextract profile for uid '{str(uid)}'\", exc_info=True)\n                return {}\n\n    async def get_feeds(self, uid: int, limit: int = 15) -> list[FeedItem]:\n        \"\"\"\n        Extract user's Weibo feeds (posts) with pagination support.\n\n        Args:\n            uid (int): The unique identifier of the Weibo user\n            limit (int): Maximum number of feeds to extract, defaults to 15\n\n        Returns:\n            list[FeedItem]: List of user's Weibo feeds\n        \"\"\"\n        feeds = []\n        sinceId = ''\n        cookies = await self._ensure_cookies()\n        async with httpx.AsyncClient(cookies=cookies) as client:\n            containerId = await self._get_container_id(client, uid)\n\n            while len(feeds) < limit:\n                pagedFeeds = await self._extract_feeds(client, uid, containerId, sinceId)\n                if not pagedFeeds.Feeds:\n                    break\n\n                feeds.extend(pagedFeeds.Feeds)\n                sinceId = pagedFeeds.SinceId\n                if not sinceId:\n                    break\n\n        return feeds\n\n    async def get_hot_feeds(self, uid: int, limit: int = 15) -> list[FeedItem]:\n        \"\"\"\n        Extract hot feeds (posts) from a specific user's Weibo profile.\n\n        Args:\n            uid (int): The unique identifier of the Weibo user\n            limit (int): Maximum number of hot feeds to extract, defaults to 15\n\n        Returns:\n            list[FeedItem]: List of hot feeds from the user's profile\n        \"\"\"\n        cookies = await self._ensure_cookies()\n        async with httpx.AsyncClient(cookies=cookies) as client:\n            try:\n                params = {\n                    'containerid': f'231002{str(uid)}_-_HOTMBLOG',\n                    'type': 'uid',\n                    'value': uid,\n                }\n                encoded_params = urlencode(params)\n\n                response = await client.get(f'{SEARCH_URL}?{encoded_params}', headers=DEFAULT_HEADERS)\n                result = response.json()\n                cards = list(filter(lambda x:x['card_type'] == 9, result[\"data\"][\"cards\"]))\n                feeds = [self._to_feed_item(item['mblog']) for item in cards]\n                return feeds[:limit]\n            except httpx.HTTPError:\n                self.logger.error(f\"Unable to extract hot feeds for uid '{str(uid)}'\", exc_info=True)\n                return []\n\n    async def search_users(self, keyword: str, limit: int = 5, page: int = 1) -> list[UserProfile]:\n        \"\"\"\n        Search for Weibo users based on a keyword.\n\n        Args:\n            keyword (str): Search term to find users\n            limit (int): Maximum number of users to return, defaults to 5\n\n        Returns:\n            list[UserProfile]: List of UserProfile objects containing user information\n        \"\"\"\n        cookies = await self._ensure_cookies()\n        async with httpx.AsyncClient(cookies=cookies) as client:\n            try:\n                params = {\n                    'containerid': f'100103type=3&q={keyword}',\n                    'page_type': 'searchall',\n                    'page': page,\n                }\n                encoded_params = urlencode(params)\n\n                response = await client.get(f'{SEARCH_URL}?{encoded_params}', headers=DEFAULT_HEADERS)\n                result = response.json()\n                cards = result[\"data\"][\"cards\"]\n                if len(cards) < 2:\n                    return []\n                else:\n                    cardGroup = cards[1]['card_group']\n                    return [self._to_user_profile(item['user']) for item in cardGroup][:limit]\n            except httpx.HTTPError:\n                self.logger.error(\n                    f\"Unable to search users for keyword '{keyword}'\", exc_info=True)\n                return []\n\n    async def get_trendings(self, limit: int = 15) -> list[TrendingItem]:\n        \"\"\"\n        Get a list of hot search items from Weibo.\n\n        Args:\n            limit (int): Maximum number of hot search items to return, defaults to 15\n\n        Returns:\n            list[HotSearchItem]: List of HotSearchItem objects containing hot search information\n        \"\"\"\n        try:\n            params = {\n                'containerid': f'106003type=25&t=3&disable_hot=1&filter_type=realtimehot',\n            }\n            encoded_params = urlencode(params)\n            \n            cookies = await self._ensure_cookies()\n\n[376 more lines in file. Use offset=221 to continue.]"}],"isError":false,"timestamp":1775082898116}}
{"type":"message","id":"d96ed241","parentId":"17f665ad","timestamp":"2026-04-01T22:34:58.129Z","message":{"role":"toolResult","toolCallId":"call_nwZ7CnvoZCRgxjUY5beO2gAH|fc_0faca0e75e9e48550169cd9d91a054819a914b045d4165f8cf","toolName":"read","content":[{"type":"text","text":"# Weibo MCP Server\n\n这是一个基于 [Model Context Protocol](https://modelcontextprotocol.io) 的服务器，用于抓取微博用户信息、动态和搜索功能。该服务器可以帮助获取微博用户的详细信息、动态内容以及进行用户搜索。\n\n## 安装\n\n从源代码安装：\n\n```json\n{\n    \"mcpServers\": {\n        \"weibo\": {\n            \"command\": \"uvx\",\n            \"args\": [\n                \"--from\",\n                \"git+https://github.com/qinyuanpei/mcp-server-weibo.git\",\n                \"mcp-server-weibo\"\n            ]\n        }\n    }\n}\n```\n从包管理器安装：\n\n```json\n{\n    \"mcpServers\": {\n        \"weibo\": {\n            \"command\": \"uvx\",\n            \"args\": [\"mcp-server-weibo\"],\n        }\n    }\n}\n```\n\n## 组件\n\n### 工具\n\n- `search_weibo_users`: 用于搜索微博用户\n    - **输入:** `keyword`: 搜索关键词\n    - **输出:** `WeiboUsers`: 包含用户基本信息的 Pydantic 模型列表\n\n- `extract_weibo_profile`: 获取用户详细信息\n    - **输入:** `user_id`: 用户ID\n    - **输出:** `WeiboProfile`: 包含用户详细信息的 Pydantic 模型\n\n- `extract_weibo_feeds`: 获取用户动态\n    - **输入:** `user_id`: 用户ID, `limit`: 获取数量限制\n    - **输出:** `WeiboFeeds`: 包含用户动态信息的 Pydantic 模型列表\n\n### 资源   \n\n无\n\n### 提示\n\n无\n\n## 依赖要求\n\n- Python >= 3.8\n- httpx >= 0.24.0\n- pydantic >= 2.0.0\n- fastmcp >= 0.1.0\n\n## 许可证\n\nMIT 许可证 - 详见 [LICENSE](LICENSE) 文件\n\n## 免责声明\n\n本项目与微博官方无关，仅用于学习和研究目的。\n"}],"isError":false,"timestamp":1775082898121}}
{"type":"message","id":"0ae4f764","parentId":"d96ed241","timestamp":"2026-04-01T22:35:38.543Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Testing the underlying crawler**\n\nI’m considering that visitor cookies might be in use if there’s no environment set up. Perhaps the empty results could be due to changes in the API. I think I might need to directly test the underlying crawler with Python to see if it returns feeds or an error. I could use a command like `python3.14 - <<PY` to import and await the `get_feeds` function for the user ID to check what output I get.","thinkingSignature":"{\"id\":\"rs_0faca0e75e9e48550169cd9db2d638819aa35a2f21d2f0d78b\",\"type\":\"reasoning\",\"encrypted_content\":\"gAAAAABpzZ26rBmkECdMWcuEBGobygSnbZAUzndFoa6qQBYGtFag7bOyv_KwdH7EpeNzX94IUTFt4hu2qRZ-tqIAjg9QIq7tPJGM_sYcJdSAhOOT6AdBbcATAzcZsIhSlaZNZLfgmf6etQszzvjA1oS4ghfk3CjM-cISMxoJ40hlNt6IKbj2GSoSRYE9E86ydMR1EZnXsvoIB1bFYsQkDuNB1xTO7xtnwMaDPh3WXaYzmdUd2u0eZxtF2FROamGTfl1N9zuP5UaDnilFJiOywGsicpebCtJI5SUZx1TGumSjcgfPonhoNjnnudVlxbu0iuH0-gGqRxMJ3KXbPlP8eo1YdldoL3uic1PolDEDfAHgiPlXJKMYx9R9K4nQHpdJxeCwt1UIGRQt1Fh2Hbv3eqpGx3POeFuPjazNsUSSf7oH27Fhwr1o-cSr61VEb8jC4ZKD9DEdHqwjbTTv5A_jzEUoJjdyUEXzCdusJooUAe0uUG2OUr6GEE5ZaX8-VLdbu5_izaE1GpABIhMi_WIJMEkoPan3rvLgGRJy12Z_imAqgVNqfg4WqYAP9HvnOxESzLurFwmKsklL0P62rhSWAHQhAttza9iIXjqx-LBq3ycQJORIejR9PCYNEBFnpidkvxyvWMeLmbx6nENbLHS39hgOmmPjumZLHbejtIOOQ-nTCLBypmHtt2qN9mfbEWIdh3jDUjNyvgLy_UYvl-LVTL2ENkDBJPjLIY0rUlvf8J2u2Mi4sK5pO_OrzUPx5jobObRKGwPFaxYqlzGmf2JEB-lKhfPWqTBhKsZpJeRJZV9xxbj_P9v-GGOy-d-hfBMamqtlsjzBZw9a4LoHY-uvBVALDOs_N7LopxlT2b-fEg3JjyyyP7V7x3ku61gYQLzrgAHWOjUDJRXnrMHnyN6tqc293XrgaMgWQ6ObqGpQwPO-MPSFQAF5mL-N9PM5_qXR2ekQE4X1ad5OFC8AXMsdqrHKgp4ntXp48fi0Mfy39ei-phwRu8RgSkwXG_h3Riln_0Gj4iU06wn6ekpcNrg8-uZIDRn2ENS2a35jHxS90RqG3b-yasnzJjeSBN1Y_li2FxLSMmh7QCou8b-mYr0CReq9cGDzNhZIs6qm23jtMFe65qBjC3HRXPYQbv1SBimeg1R0B4sfqJl_W51bGSEh_S1awv3nxiYgiIQwDt5_nfuRlm1KduPEyVxv1BSVzMCiPODnp9MwOPNc\",\"summary\":[{\"type\":\"summary_text\",\"text\":\"**Testing the underlying crawler**\\n\\nI’m considering that visitor cookies might be in use if there’s no environment set up. Perhaps the empty results could be due to changes in the API. I think I might need to directly test the underlying crawler with Python to see if it returns feeds or an error. I could use a command like `python3.14 - <<PY` to import and await the `get_feeds` function for the user ID to check what output I get.\"}]}"},{"type":"toolCall","id":"call_792Dk4dpENjUAmEcMvIRqqli|fc_0faca0e75e9e48550169cd9dba25ac819aa14ffa6b7328eab0","name":"exec","arguments":{"command":"/Library/Frameworks/Python.framework/Versions/3.14/bin/python3.14 - <<'PY'\nimport asyncio, json\nfrom mcp_server_weibo.weibo import WeiboCrawler\n\nasync def main():\n    crawler = WeiboCrawler()\n    feeds = await crawler.get_feeds(2014433131, 3)\n    print('COUNT', len(feeds))\n    for i, item in enumerate(feeds[:2], 1):\n        print('ITEM', i, json.dumps(item, ensure_ascii=False)[:500])\n\nasyncio.run(main())\nPY","workdir":"/Users/ling/.openclaw/workspace","timeout":120},"partialJson":"{\"command\":\"/Library/Frameworks/Python.framework/Versions/3.14/bin/python3.14 - <<'PY'\\nimport asyncio, json\\nfrom mcp_server_weibo.weibo import WeiboCrawler\\n\\nasync def main():\\n    crawler = WeiboCrawler()\\n    feeds = await crawler.get_feeds(2014433131, 3)\\n    print('COUNT', len(feeds))\\n    for i, item in enumerate(feeds[:2], 1):\\n        print('ITEM', i, json.dumps(item, ensure_ascii=False)[:500])\\n\\nasyncio.run(main())\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":120}"},{"type":"toolCall","id":"call_4CMSlc0RXU9wDspWGjfT029j|fc_0faca0e75e9e48550169cd9dba25c4819aa922a846d23e806b","name":"exec","arguments":{"command":"/Library/Frameworks/Python.framework/Versions/3.14/bin/python3.14 - <<'PY'\nimport asyncio\nfrom mcp_server_weibo.weibo import WeiboCrawler\n\nasync def main():\n    crawler = WeiboCrawler()\n    try:\n        users = await crawler.search_users('唐史主任司马迁', 3, 1)\n        print('USERS', users)\n    except Exception as e:\n        print('ERR', repr(e))\n\nasyncio.run(main())\nPY","workdir":"/Users/ling/.openclaw/workspace","timeout":120},"partialJson":"{\"command\":\"/Library/Frameworks/Python.framework/Versions/3.14/bin/python3.14 - <<'PY'\\nimport asyncio\\nfrom mcp_server_weibo.weibo import WeiboCrawler\\n\\nasync def main():\\n    crawler = WeiboCrawler()\\n    try:\\n        users = await crawler.search_users('唐史主任司马迁', 3, 1)\\n        print('USERS', users)\\n    except Exception as e:\\n        print('ERR', repr(e))\\n\\nasyncio.run(main())\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":120}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":31415,"output":399,"cacheRead":53120,"cacheWrite":0,"totalTokens":84934,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775082898129,"responseId":"resp_0faca0e75e9e48550169cd9db16850819ab68c0546586641ee"}}
