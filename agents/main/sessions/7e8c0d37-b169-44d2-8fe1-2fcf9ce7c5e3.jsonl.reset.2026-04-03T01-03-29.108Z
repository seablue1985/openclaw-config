rs='ignore')\n    line = next((x for x in txt.splitlines() if x.startswith('WEIBO_COOKIE=')), '')\n    print('HAS_COOKIE', bool(line))\n    print('COOKIE_LEN', len(line.split('=',1)[1]) if '=' in line else 0)\nPY","workdir":"/Users/ling/.openclaw/workspace","timeout":20},"partialJson":"{\"command\":\"python3 - <<'PY'\\nfrom pathlib import Path\\np = Path('/Users/ling/.openclaw/skills/weibo-monitor/config/cookie.env')\\nprint('EXISTS', p.exists())\\nif p.exists():\\n    txt = p.read_text(encoding='utf-8', errors='ignore')\\n    line = next((x for x in txt.splitlines() if x.startswith('WEIBO_COOKIE=')), '')\\n    print('HAS_COOKIE', bool(line))\\n    print('COOKIE_LEN', len(line.split('=',1)[1]) if '=' in line else 0)\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":20}"},{"type":"toolCall","id":"call_sYVYGDVZjt68PAFGp3RrJxPQ|fc_0faca0e75e9e48550169cd9e00c914819aab5fe6bb7eafcd88","name":"exec","arguments":{"command":"/Library/Frameworks/Python.framework/Versions/3.14/bin/python3.14 - <<'PY'\nfrom pathlib import Path\nimport asyncio, httpx\nfrom mcp_server_weibo.consts import DEFAULT_HEADERS, PROFILE_URL\n\nasync def main():\n    p = Path('/Users/ling/.openclaw/skills/weibo-monitor/config/cookie.env')\n    txt = p.read_text(encoding='utf-8', errors='ignore') if p.exists() else ''\n    raw = ''\n    for line in txt.splitlines():\n        if line.startswith('WEIBO_COOKIE='):\n            raw = line.split('=',1)[1].strip().strip('\"')\n            break\n    if not raw:\n        print('NO_COOKIE')\n        return\n    cookies = {}\n    for pair in raw.split(';'):\n        pair = pair.strip()\n        if '=' not in pair:\n            continue\n        k,v = pair.split('=',1)\n        if k.strip() and v.strip():\n            cookies[k.strip()] = v.strip()\n    async with httpx.AsyncClient(cookies=cookies, follow_redirects=False) as client:\n        r = await client.get(PROFILE_URL.format(userId='2014433131'), headers=DEFAULT_HEADERS)\n        print('STATUS', r.status_code)\n        try:\n            j = r.json()\n            print('OK', j.get('ok'))\n            print('ERRNO', j.get('errno'))\n            print('HAS_DATA', 'data' in j)\n            print('URL', j.get('url','')[:120])\n        except Exception as e:\n            print('JSON_ERR', repr(e))\n            print('TEXT', r.text[:200])\n\nasyncio.run(main())\nPY","workdir":"/Users/ling/.openclaw/workspace","timeout":120},"partialJson":"{\"command\":\"/Library/Frameworks/Python.framework/Versions/3.14/bin/python3.14 - <<'PY'\\nfrom pathlib import Path\\nimport asyncio, httpx\\nfrom mcp_server_weibo.consts import DEFAULT_HEADERS, PROFILE_URL\\n\\nasync def main():\\n    p = Path('/Users/ling/.openclaw/skills/weibo-monitor/config/cookie.env')\\n    txt = p.read_text(encoding='utf-8', errors='ignore') if p.exists() else ''\\n    raw = ''\\n    for line in txt.splitlines():\\n        if line.startswith('WEIBO_COOKIE='):\\n            raw = line.split('=',1)[1].strip().strip('\\\"')\\n            break\\n    if not raw:\\n        print('NO_COOKIE')\\n        return\\n    cookies = {}\\n    for pair in raw.split(';'):\\n        pair = pair.strip()\\n        if '=' not in pair:\\n            continue\\n        k,v = pair.split('=',1)\\n        if k.strip() and v.strip():\\n            cookies[k.strip()] = v.strip()\\n    async with httpx.AsyncClient(cookies=cookies, follow_redirects=False) as client:\\n        r = await client.get(PROFILE_URL.format(userId='2014433131'), headers=DEFAULT_HEADERS)\\n        print('STATUS', r.status_code)\\n        try:\\n            j = r.json()\\n            print('OK', j.get('ok'))\\n            print('ERRNO', j.get('errno'))\\n            print('HAS_DATA', 'data' in j)\\n            print('URL', j.get('url','')[:120])\\n        except Exception as e:\\n            print('JSON_ERR', repr(e))\\n            print('TEXT', r.text[:200])\\n\\nasyncio.run(main())\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":120}"}],"