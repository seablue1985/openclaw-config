*' \\\\) | sed 's#^#FILE #'\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":20}"},{"type":"toolCall","id":"call_Ky4Q4s4jvOxNG1aZjib44Uga|fc_0faca0e75e9e48550169cd9cc2d23c819aa5b613a80f85ff9e","name":"read","arguments":{"file":"/Users/ling/.openclaw/skills/weibo-monitor/scripts/fetch_weibo_v2.py","limit":260},"partialJson":"{\"file\":\"/Users/ling/.openclaw/skills/weibo-monitor/scripts/fetch_weibo_v2.py\",\"limit\":260}"},{"type":"toolCall","id":"call_169sjlNpOXFHk5dddxz0iv6G|fc_0faca0e75e9e48550169cd9cc2d248819aab9c045e93337690","name":"read","arguments":{"file":"/Users/ling/workspace/weibo-monitor/fetch_and_report.py","limit":260},"partialJson":"{\"file\":\"/Users/ling/workspace/weibo-monitor/fetch_and_report.py\",\"limit\":260}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":36116,"output":397,"cacheRead":0,"cacheWrite":0,"totalTokens":36513,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775082641454,"responseId":"resp_0faca0e75e9e48550169cd9cba5c00819aa12b23ffe7926767"}}
{"type":"message","id":"88cf5cac","parentId":"cedf9af1","timestamp":"2026-04-01T22:31:31.304Z","message":{"role":"toolResult","toolCallId":"call_7F1QzJZhMgOXBIe93n4yyLXj|fc_0faca0e75e9e48550169cd9cc2d230819ab12571126a91f9c2","toolName":"exec","content":[{"type":"text","text":"FILE /Users/ling/.openclaw/skills/weibo-monitor\nFILE /Users/ling/.openclaw/skills/weibo-monitor/logs/weibo_monitor.err\nFILE /Users/ling/.openclaw/skills/weibo-monitor/logs/weibo_monitor.log\nFILE /Users/ling/.openclaw/skills/weibo-monitor/scripts/fetch_weibo.py\nFILE /Users/ling/.openclaw/skills/weibo-monitor/scripts/fetch_weibo_v2.py\nFILE /Users/ling/.openclaw/skills/weibo-monitor/scripts/__pycache__/fetch_weibo.cpython-314.pyc\nFILE /Users/ling/.openclaw/skills/weibo-monitor/scripts/__pycache__/fetch_weibo_v2.cpython-314.pyc"}],"details":{"status":"completed","exitCode":0,"durationMs":12,"aggregated":"FILE /Users/ling/.openclaw/skills/weibo-monitor\nFILE /Users/ling/.openclaw/skills/weibo-monitor/logs/weibo_monitor.err\nFILE /Users/ling/.openclaw/skills/weibo-monitor/logs/weibo_monitor.log\nFILE /Users/ling/.openclaw/skills/weibo-monitor/scripts/fetch_weibo.py\nFILE /Users/ling/.openclaw/skills/weibo-monitor/scripts/fetch_weibo_v2.py\nFILE /Users/ling/.openclaw/skills/weibo-monitor/scripts/__pycache__/fetch_weibo.cpython-314.pyc\nFILE /Users/ling/.openclaw/skills/weibo-monitor/scripts/__pycache__/fetch_weibo_v2.cpython-314.pyc","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1775082691299}}
{"type":"message","id":"b0100485","parentId":"88cf5cac","timestamp":"2026-04-01T22:31:31.309Z","message":{"role":"toolResult","toolCallId":"call_Ky4Q4s4jvOxNG1aZjib44Uga|fc_0faca0e75e9e48550169cd9cc2d23c819aa5b613a80f85ff9e","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\"\"\"\nWeibo Monitor V2 - 监测 + 内容分析 + 评论情绪汇总\n功能：\n  1. 监控指定博主新微博\n  2. 抓取评论并做情绪分析\n  3. 生成内容摘要和评论总结\n  4. 推送完整报告到飞书\n\"\"\"\n\nimport json\nimport re\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any, Optional\n\nimport requests\n\n# 加载配置\nBASE_DIR = Path(__file__).parent.parent\nCOOKIE_FILE = BASE_DIR / \"config\" / \"cookie.env\"\nWATCHLIST_FILE = BASE_DIR / \"config\" / \"watchlist.json\"\nSTATE_DIR = BASE_DIR / \"state\"\nSTATE_DIR.mkdir(exist_ok=True)\nLAST_ID_FILE = STATE_DIR / \"last_post_id.json\"\n\nFEISHU_WEBHOOK = \"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\"\n\nDEFAULT_WATCHLIST = [\n    {\"uid\": \"2014433131\", \"name\": \"股票博主\"},\n]\n\nSTOCK_KEYWORDS = [\n    \"股票\", \"A股\", \"大盘\", \"上证\", \"深证\", \"指数\", \"涨跌\", \"涨停\", \"跌停\", \"持仓\",\n    \"建仓\", \"清仓\", \"加仓\", \"减仓\", \"牛市\", \"熊市\", \"回调\", \"反弹\", \"突破\", \"支撑\",\n    \"压力\", \"板块\", \"概念\", \"龙头\", \"主力\", \"资金\", \"量能\", \"缩量\", \"放量\",\n    \"研报\", \"业绩\", \"财报\", \"期权\", \"期货\", \"融资\", \"美股\", \"港股\", \"汇率\", \"油价\",\n    \"新能源\", \"半导体\", \"芯片\", \"AI\", \"医药\", \"证券\", \"基金\", \"量化\", \"央行\", \"美联储\",\n]\n\n\ndef ensure_default_watchlist_file() -> None:\n    WATCHLIST_FILE.parent.mkdir(parents=True, exist_ok=True)\n    if WATCHLIST_FILE.exists():\n        return\n    WATCHLIST_FILE.write_text(\n        json.dumps(DEFAULT_WATCHLIST, ensure_ascii=False, indent=2) + \"\\n\",\n        encoding=\"utf-8\",\n    )\n\n\ndef load_watchlist() -> list[dict[str, str]]:\n    ensure_default_watchlist_file()\n    try:\n        raw = json.loads(WATCHLIST_FILE.read_text(encoding=\"utf-8\"))\n    except Exception as exc:\n        raise RuntimeError(f\"watchlist 配置读取失败: {exc}\") from exc\n\n    if not isinstance(raw, list):\n        raise RuntimeError(\"watchlist.json 格式错误：顶层必须是数组\")\n\n    normalized: list[dict[str, str]] = []\n    seen: set[str] = set()\n    for idx, item in enumerate(raw, start=1):\n        if not isinstance(item, dict):\n            raise RuntimeError(f\"watchlist.json 第 {idx} 项格式错误：必须是对象\")\n        uid = str(item.get(\"uid\", \"\")).strip()\n        name = str(item.get(\"name\", \"\")).strip() or f\"博主{idx}\"\n        if not uid:\n            raise RuntimeError(f\"watchlist.json 第 {idx} 项缺少 uid\")\n        if uid in seen:\n            continue\n        seen.add(uid)\n        normalized.append({\"uid\": uid, \"name\": name})\n\n    if not normalized:\n        raise RuntimeError(\"watchlist.json 为空：请至少配置 1 个博主\")\n    return normalized\n\n\ndef load_cookie() -> Optional[str]:\n    env = COOKIE_FILE.read_text(encoding=\"utf-8\")\n    for line in env.splitlines():\n        if line.startswith(\"WEIBO_COOKIE=\"):\n            return line.split(\"=\", 1)[1].strip().strip('\"')\n    return None\n\n\ndef fetch_posts(uid: str, cookie: str, page: int = 1) -> list[dict[str, Any]]:\n    \"\"\"获取博主最新微博\"\"\"\n    headers = {\n        \"User-Agent\": \"Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.0 Mobile/15E148 Safari/604.1\",\n        \"Cookie\": cookie,\n        \"Accept\": \"application/json\",\n        \"Referer\": f\"https://weibo.com/u/{uid}\",\n    }\n    url = \"https://weibo.com/ajax/statuses/mymblog\"\n    params = {\"uid\": uid, \"page\": page, \"feature\": 0, \"lang\": \"zh-CN\"}\n    resp = requests.get(url, params=params, headers=headers, timeout=10)\n    resp.raise_for_status()\n    data = resp.json()\n    if data.get(\"ok\") == -100:\n        raise RuntimeError(f\"微博 Cookie 已失效，需要重新登录: uid={uid}\")\n    return data.get(\"data\", {}).get(\"list\", []) or []\n\n\ndef fetch_comments(post_id: str, cookie: str, max_pages: int = 3) -> list[dict[str, Any]]:\n    \"\"\"获取微博评论\"\"\"\n    headers = {\n        \"User-Agent\": \"Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X) AppleWebKit/605.1.15\",\n        \"Cookie\": cookie,\n        \"Accept\": \"application/json\",\n        \"Referer\": \"https://weibo.com\",\n    }\n    all_comments: list[dict[str, Any]] = []\n    for page in range(1, max_pages + 1):\n        try:\n            url = \"https://m.weibo.cn/api/comments/show\"\n            params = {\"id\": post_id, \"page\": page}\n            resp = requests.get(url, params=params, headers=headers, timeout=10)\n            if resp.status_code != 200:\n                break\n            data = resp.json()\n            comments = data.get(\"data\", {}).get(\"data\") or []\n            if not comments:\n                break\n            import html as html_module\n\n            for comment in comments:\n                raw = comment.get(\"text\", \"\") or \"\"\n                text = html_module.unescape(re.sub(r\"<[^>]+>\", \"\", str(raw))).strip()\n                if text:\n                    all_comments.append(\n                        {\n                            \"text\": text,\n                            \"like\": comment.get(\"like_counts\", 0),\n                            \"user\": comment.get(\"user\", {}).get(\"screen_name\", \"匿名\"),\n                        }\n                    )\n        except Exception:\n            break\n    return all_comments\n\n\ndef clean_text(html_text: str) -> str:\n    \"\"\"清理HTML，保留纯文本\"\"\"\n    import html as html_module\n\n    text = re.sub(r\"<[^>]+>\", \"\", str(html_text))\n    text = html_module.unescape(text)\n    text = text.replace(\"&nbsp;\", \" \").replace(\"&amp;\", \"&\")\n    text = text.replace(\"&lt;\", \"<\").replace(\"&gt;\", \">\").replace(\"&#10;\", \"\\n\")\n    return text.strip()\n\n\ndef is_stock_related(text: str) -> int:\n    \"\"\"判断是否股票相关内容\"\"\"\n    return sum(1 for kw in STOCK_KEYWORDS if kw in text)\n\n\ndef analyze_sentiment(comments: list[dict[str, Any]]) -> tuple[str, int, int, int]:\n    \"\"\"简单情绪分析（基于关键词）\"\"\"\n    positive = [\"加油\", \"支持\", \"点赞\", \"厉害\", \"牛\", \"强\", \"好\", \"对\", \"稳\", \"涨\"]\n    negative = [\"亏\", \"跌\", \"傻\", \"骗\", \"垃圾\", \"恶心\", \"跌了\", \"完了\", \"危险\", \"割\"]\n\n    pos_count = sum(1 for c in comments for w in positive if w in c[\"text\"])\n    neg_count = sum(1 for c in comments for w in negative if w in c[\"text\"])\n\n    total = len(comments)\n    if total == 0:\n        return \"无评论\", 0, 0, 0\n\n    pos_ratio = pos_count / total\n    neg_ratio = neg_count / total\n\n    if pos_ratio > neg_ratio * 2:\n        sentiment = \"偏正面 👍\"\n    elif neg_ratio > pos_ratio * 2:\n        sentiment = \"偏负面 👎\"\n    elif pos_ratio > 0.3:\n        sentiment = \"中性偏正面\"\n    elif neg_ratio > 0.3:\n        sentiment = \"中性偏负面\"\n    else:\n        sentiment = \"中性\"\n\n    return sentiment, pos_count, neg_count, total\n\n\ndef build_summary(comments: list[dict[str, Any]]) -> str:\n    \"\"\"生成评论摘要\"\"\"\n    if not comments:\n        return \"暂无评论\"\n\n    top_comments = sorted(comments, key=lambda x: x[\"like\"], reverse=True)[:5]\n    lines = []\n    for i, comment in enumerate(top_comments, 1):\n        text = comment[\"text\"][:80] + (\"...\" if len(comment[\"text\"]) > 80 else \"\")\n        lines.append(f\"{i}. {text} (👍{comment['like']})\")\n    return \"\\n\".join(lines)\n\n\ndef send_feishu(msg: str) -> dict[str, Any]:\n    \"\"\"发送飞书消息\"\"\"\n    payload = {\"msg_type\": \"text\", \"content\": {\"text\": msg}}\n    resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\n    return resp.json()\n\n\ndef load_last_ids() -> dict[str, str]:\n    if LAST_ID_FILE.exists():\n        return json.loads(LAST_ID_FILE.read_text(encoding=\"utf-8\"))\n    return {}\n\n\ndef save_last_ids(ids: dict[str, str]) -> None:\n    LAST_ID_FILE.write_text(json.dumps(ids, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n\n\ndef main() -> None:\n    cookie = load_cookie()\n    if not cookie:\n        print(\"错误: 未找到微博 Cookie\")\n        sys.exit(1)\n\n    try:\n        watchlist = load_watchlist()\n    except Exception as exc:\n        print(f\"错误: {exc}\")\n        sys.exit(1)\n\n    print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] 开始检测微博...\")\n    print(f\"监控博主数: {len(watchlist)}\")\n\n    last_ids = load_last_ids()\n    all_new_posts: list[dict[str, Any]] = []\n    had_fetch_error = False\n\n    for blogger in watchlist:\n        uid = blogger[\"uid\"]\n        name = blogger[\"name\"]\n\n        try:\n            posts = fetch_posts(uid, cookie)\n        except Exception as exc:\n            had_fetch_error = True\n            print(f\"获取微博失败 {uid} ({name}): {exc}\")\n            continue\n\n        if not posts:\n            print(f\"未获取到微博 UID={uid} ({name})\")\n            continue\n\n        effective_posts = [post for post in posts if not post.get(\"isTop\")]\n        if not effective_posts:\n            print(f\"未获取到非置顶微博 UID={uid} ({name})\")\n            continue\n\n\n[76 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1775082691304}}
{"type":"message","id":"34e1621a","parentId":"b0100485","timestamp":"2026-04-01T22:31:31.314Z","message":{"role":"toolResult","toolCallId":"call_169sjlNpOXFHk5dddxz0iv6G|fc_0faca0e75e9e48550169cd9cc2d248819aab9c045e93337690","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n微博财经大V每日监控报告\n每天两次自动抓取 → 分析 → 推送飞书\n\"\"\"\nimport json\nimport subprocess\nimport re\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\n\n# ── 配置 ────────────────────────────────────────────────────────────────────\nKOL_FILE = Path(__file__).parent / \"kol_uids.json\"\nSTATE_FILE = Path(__file__).parent / \"last_fetch.json\"\nMAX_PER_KOL = 20   # 每次最多抓取微博条数\nFEISHU_CHAT_ID = \"oc_8a819be3a90d35b8d0a2d5c1f4642b22\"  # 飞书群\n\n# 关键词过滤器：只保留包含这些词的微博（财经相关）\nFINANCE_KEYWORDS = [\n    \"股\", \"A股\", \"上证\", \"深证\", \"指数\", \"大盘\", \"牛市\", \"熊市\",\n    \"投资\", \"基金\", \"ETF\", \"私募\", \"公募\",\n    \"美联储\", \"降息\", \"加息\", \"汇率\", \"美元\", \"人民币\",\n    \"央行\", \"货币政策\", \"财政政策\",\n    \"GDP\", \"CPI\", \"PPI\", \"经济\",\n    \"房地产\", \"房价\", \"楼市\",\n    \"科技\", \"AI\", \"半导体\", \"芯片\",\n    \"新能源\", \"锂\", \"光伏\", \"电动车\",\n    \"黄金\", \"原油\", \"大宗商品\",\n    \"港股\", \"美股\", \"道琼斯\", \"纳斯达克\", \"标普\",\n    \"汇市\", \"债市\", \"银行\", \"保险\",\n    \"监管\", \"政策\", \"会议\", \"讲话\",\n    \"IPO\", \"上市\", \"定增\", \"减持\", \"回购\",\n    \"业绩\", \"财报\", \"年报\", \"季报\",\n]\n\n# ── 工具函数 ────────────────────────────────────────────────────────────────\n\ndef call_weibo(uid: int, limit: int = MAX_PER_KOL) -> list:\n    \"\"\"调用 mcp-server-weibo 获取某用户最新微博\"\"\"\n    mcporter = str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"node-versions\" / \"v22.22.0\" / \"installation\" / \"bin\" / \"mcporter\")\n    cmd = [mcporter, \"call\", \"weibo.get_feeds\", f\"uid={uid}\", f\"limit={limit}\"]\n    try:\n        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)\n        if result.returncode != 0:\n            return []\n        data = json.loads(result.stdout)\n        return data if isinstance(data, list) else []\n    except Exception as e:\n        print(f\"  ⚠️ 获取UID {uid} 失败: {e}\")\n        return []\n\ndef parse_time(time_str: str) -> datetime:\n    \"\"\"解析微博时间字符串\"\"\"\n    # 格式: \"Mon Mar 23 15:28:32 +0800 2026\"\n    try:\n        return datetime.strptime(time_str, \"%a %b %d %H:%M:%S +0800 %Y\")\n    except:\n        try:\n            # 格式: \"2026-03-23 15:28:32\"\n            return datetime.strptime(time_str[:19], \"%Y-%m-%d %H:%M:%S\")\n        except:\n            return None\n\ndef is_today(dt: datetime) -> bool:\n    \"\"\"判断是否今天或昨天的微博\"\"\"\n    if dt is None:\n        return True  # 无法解析的默认保留\n    now = datetime.now()\n    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)\n    yesterday_start = today_start - timedelta(days=1)\n    return dt >= yesterday_start\n\ndef clean_text(html_text: str) -> str:\n    \"\"\"清洗HTML标签，提取纯文本\"\"\"\n    # 移除 <a href=...> 及其内容\n    text = re.sub(r'<a[^>]*>.*?</a>', '', html_text, flags=re.DOTALL)\n    # 移除 HTML 标签\n    text = re.sub(r'<[^>]+>', '', text)\n    # 移除多余空白\n    text = re.sub(r'\\s+', ' ', text).strip()\n    return text\n\ndef is_finance_related(text: str) -> bool:\n    \"\"\"判断微博是否与财经相关\"\"\"\n    text_upper = text.upper()\n    text_cn = text\n    for kw in FINANCE_KEYWORDS:\n        if kw.upper() in text_upper or kw in text_cn:\n            return True\n    return False\n\ndef get_hot_comments(feeds: list, max_items: int = 3) -> list:\n    \"\"\"从微博列表中提取热度最高的条目（按点赞+评论+转发排序）\"\"\"\n    scored = []\n    for feed in feeds:\n        likes = feed.get(\"attitudes_count\", 0) or 0\n        comments = feed.get(\"comments_count\", 0) or 0\n        reposts = feed.get(\"reposts_count\", 0) or 0\n        score = likes + comments * 2 + reposts * 3\n        scored.append((score, feed))\n    scored.sort(key=lambda x: x[0], reverse=True)\n    return [feed for _, feed in scored[:max_items]]\n\n# ── 核心逻辑 ────────────────────────────────────────────────────────────────\n\ndef fetch_all_kols() -> dict:\n    \"\"\"抓取所有KOL的最新微博\"\"\"\n    with open(KOL_FILE) as f:\n        kols = json.load(f)\n\n    results = {}\n    for name, info in kols.items():\n        uid = info[\"uid\"]\n        title = info.get(\"title\", \"\")\n        tags = info.get(\"tags\", [])\n\n        feeds = call_weibo(uid)\n        if not feeds:\n            # 降级：尝试更少条数\n            feeds = call_weibo(uid, limit=5)\n\n        # 过滤：只保留今天/昨天的\n        today_feeds = []\n        for feed in feeds:\n            dt = parse_time(feed.get(\"created_at\", \"\"))\n            if is_today(dt):\n                today_feeds.append(feed)\n\n        # 不再按\"财经内容\"过滤；所有今天/昨天的微博均进入汇总分析\n        # 热度排序\n        hot_feeds = get_hot_comments(today_feeds, max_items=3)\n\n        results[name] = {\n            \"uid\": uid,\n            \"title\": title,\n            \"tags\": tags,\n            \"total_today\": len(today_feeds),\n            \"hot_feeds\": hot_feeds,\n        }\n        print(f\"  {'✅' if today_feeds else '⚪'} {name}: 今天{len(today_feeds)}条\")\n\n    return results\n\ndef build_report(results: dict) -> str:\n    \"\"\"生成飞书消息卡片\"\"\"\n    now = datetime.now().strftime(\"%Y-%m-%d %H:%M\")\n    total_posts = sum(v[\"total_today\"] for v in results.values())\n\n    lines = [\n        f\"📊 **微博财经大V每日简报**\",\n        f\"🕐 {now}  |  共 {len(results)} 位大V  |  抓取 {total_posts} 条微博\",\n        \"\",\n        \"── 重点内容摘录 ──\",\n        \"\"\n    ]\n\n    # 按当日总微博量排序（不再按财经内容量过滤）\n    sorted_kols = sorted(results.items(), key=lambda x: x[1][\"total_today\"], reverse=True)\n\n    for name, info in sorted_kols:\n        if info[\"total_today\"] == 0:\n            continue\n\n        lines.append(f\"**🔹 {name}**（{info['title']}）\")\n\n        for feed in info[\"hot_feeds\"][:2]:\n            text = clean_text(feed.get(\"text\", \"\"))\n            if len(text) > 200:\n                text = text[:200] + \"...\"\n            dt = parse_time(feed.get(\"created_at\", \"\"))\n            time_str = dt.strftime(\"%H:%M\") if dt else \"?\"\n\n            likes = feed.get(\"attitudes_count\", 0) or 0\n            comments = feed.get(\"comments_count\", 0) or 0\n            reposts = feed.get(\"reposts_count\", 0) or 0\n\n            lines.append(f\"   {time_str} {text}\")\n            lines.append(f\"   👍{likes} 💬{comments} 🔁{reposts}\")\n            lines.append(\"\")\n\n        lines.append(\"\")\n\n    # 总结\n    lines.append(\"── 今日要闻 ──\")\n    all_texts = []\n    for name, info in sorted_kols:\n        for feed in info[\"hot_feeds\"][:2]:\n            text = clean_text(feed.get(\"text\", \"\"))\n            if text:\n                all_texts.append(text)\n\n    if all_texts:\n        # 提取出现最多的关键词\n        kw_counts = {}\n        for text in all_texts:\n            for kw in FINANCE_KEYWORDS:\n                if kw in text:\n                    kw_counts[kw] = kw_counts.get(kw, 0) + 1\n        top_kws = sorted(kw_counts.items(), key=lambda x: x[1], reverse=True)[:5]\n        if top_kws:\n            kw_str = \"  \".join([f\"#{k}\" for k, _ in top_kws])\n            lines.append(f\"高频词：{kw_str}\")\n\n    lines.append(\"\")\n    lines.append(\"⚠️ 仅供参考，不构成投资建议。\")\n\n    return \"\\n\".join(lines)\n\ndef save_state(results: dict):\n    \"\"\"保存状态用于去重\"\"\"\n    state = {\n        \"last_fetch\": datetime.now().isoformat(),\n        \"seen_ids\": set()\n    }\n    for info in results.values():\n        for feed in info.get(\"hot_feeds\", []):\n            state[\"seen_ids\"].add(feed.get(\"id\"))\n\n    with open(STATE_FILE, 'w') as f:\n        # 只保存最后100条ID\n        ids = list(state[\"seen_ids\"])[:100]\n        json.dump({\"last_fetch\": state[\"last_fetch\"], \"seen_ids\": ids}, f)\n\ndef main():\n    print(f\"\\n{'='*60}\")\n    print(f\"🚀 微博财经大V监控报告\")\n    print(f\"⏰ {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n    print(f\"{'='*60}\\n\")\n\n    # 抓取\n    print(\"📡 正在抓取各KOL微博...\\n\")\n    results = fetch_all_kols()\n\n    # 生成报告\n    print(f\"\\n📝 生成报告...\")\n    report = build_report(results)\n\n    # 保存状态\n    save_state(results)\n\n    # 打印报告到控制台\n    print(f\"\\n{'='*60}\")\n    print(\"报告预览:\")\n    print(report)\n\n    # 保存报告\n    report_file = Path(__file__).parent / f\"report_{datetime.now().strftime('%Y%m%d_%H%M')}.txt\"\n    with open(report_file, 'w') as f:\n        f.write(report)\n    print(f\"\\n✅ 报告已保存: {report_file}\")\n\n    return report, results\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1775082691309}}
