it(repo_dir: Path, args: list[str], timeout: int = 15) -> str:\n    \"\"\"运行 git 命令\"\"\"\n    full_cmd = [\"git\", \"-C\", str(repo_dir)] + args\n    r = subprocess.run(full_cmd, capture_output=True, text=True, timeout=timeout)\n    if r.returncode != 0:\n        raise RuntimeError(f\"git failed: {r.stderr.strip()}\")\n    return r.stdout.strip()\n\n\ndef get_repo_status(repo_path: str) -> dict:\n","newText":"def run_git(repo_dir: Path, args: list[str], timeout: int = 15) -> str:\n    \"\"\"运行 git 命令\"\"\"\n    full_cmd = [\"git\", \"-C\", str(repo_dir)] + args\n    r = subprocess.run(full_cmd, capture_output=True, text=True, timeout=timeout)\n    if r.returncode != 0:\n        raise RuntimeError(f\"git failed: {r.stderr.strip()}\")\n    return r.stdout.strip()\n\n\ndef fetch_repo(repo_dir: Path) -> Optional[str]:\n    \"\"\"刷新远端引用；失败时返回错误文本，不中断整体检查。\"\"\"\n    try:\n        run_git(repo_dir, [\"fetch\", \"--all\", \"--tags\", \"--prune\"], timeout=60)\n        return None\n    except Exception as e:\n        return str(e)\n\n\ndef get_repo_status(repo_path: str) -> dict:\n"},{"oldText":"    result = {\n        \"path\": repo_path,\n        \"name\": repo.name,\n        \"local_tag\": None,\n        \"upstream_tag\": None,\n        \"commits_behind\": 0,\n        \"commits_ahead\": 0,\n        \"status\": \"unknown\",\n        \"new_commits\": [],\n        \"new_tags\": [],\n        \"breaking_changes\": False,\n    }\n","newText":"    result = {\n        \"path\": repo_path,\n        \"name\": repo.name,\n        \"local_tag\": None,\n        \"upstream_tag\": None,\n        \"commits_behind\": 0,\n        \"commits_ahead\": 0,\n        \"status\": \"unknown\",\n        \"new_commits\": [],\n        \"new_tags\": [],\n        \"breaking_changes\": False,\n        \"remote_statuses\": {},\n        \"local_updates\": False,\n        \"diverged\": False,\n        \"fetch_ok\": True,\n        \"fetch_error\": None,\n    }\n"},{"oldText":"    try:\n        # 获取当前 HEAD\n        local_sha = run_git(repo, [\"rev-parse\", \"--short\", \"HEAD\"])\n\n        # 获取上游分支（优先 upstream，fallback 到 origin）\n        for branch in [\n            \"upstream/main\", \"upstream/master\",\n            \"origin/main\", \"origin/master\",\n        ]:\n            try:\n                upstream_sha = run_git(repo, [\"rev-parse\", \"--short\", branch])\n                result[\"upstream_branch\"] = branch\n                break\n            except Exception:\n                continue\n\n        if \"upstream_branch\" not in result:\n            result[\"status\"] = \"no_upstream\"\n            return result\n\n        # 获取当前 tag（最近的一个）\n        try:\n            result[\"local_tag\"] = run_git(repo, [\"describe\", \"--tags\", \"--always\"])\n        except Exception:\n            pass\n\n        # 获取 upstream 最新 tag\n        try:\n            upstream_tag = run_git(repo, [\"describe\", \"--tags\", \"--always\", result[\"upstream_branch\"]])\n            result[\"upstream_tag\"] = upstream_tag\n        except Exception:\n            pass\n\n        # 计算落后多少 commits\n        try:\n            behind = run_git(repo, [\"rev-list\", \"--count\", f\"HEAD..{result['upstream_branch']}\"])\n            ahead = run_git(repo, [\"rev-list\", \"--count\", f\"{result['upstream_branch']}..HEAD\"])\n            result[\"commits_behind\"] = int(behind)\n            result[\"commits_ahead\"] = int(ahead)\n        except Exception:\n            pass\n\n        # 获取具体的新 commit\n        if result[\"commits_behind\"] > 0:\n            commits_raw = run_git(\n                repo,\n                [\"log\", f\"HEAD..{result['upstream_branch']}\", \"--format=%s|||%h\", \"-20\"]\n            )\n            for line in commits_raw.splitlines():\n                if not line.strip():\n                    continue\n                parts = line.split(\"|||\")\n                msg = parts[0].strip()\n                short = parts[1].strip() if len(parts) > 1 else \"\"\n                priority = classify_commit(msg)\n                is_break = \"breaking\" in priority.lower() or \"🔴\" in priority\n                result[\"new_commits\"].append({\n                    \"message\": msg,\n                    \"short\": short,\n                    \"priority\": priority,\n                    \"breaking\": is_break,\n                })\n                if is_break:\n                    result[\"breaking_changes\"] = True\n\n        # 状态判断\n        if result[\"commits_behind\"] == 0:\n            result[\"status\"] = \"up_to_date\"\n        elif result[\"breaking_changes\"]:\n            result[\"status\"] = \"breaking_update\"\n        elif result[\"commits_behind\"] <= 3:\n            result[\"status\"] = \"minor_update\"\n        elif result[\"commits_behind\"] <= 10:\n            result[\"status\"] = \"major_update\"\n        else:\n            result[\"status\"] = \"far_behind\"\n\n    except Exception as e:\n        result[\"error\"] = str(e)\n\n    return result\n","newText":"    try:\n        fetch_error = fetch_repo(repo)\n        if fetch_error:\n            result[\"fetch_ok\"] = False\n            result[\"fetch_error\"] = fetch_error\n\n        # 获取当前 HEAD\n        run_git(repo, [\"rev-parse\", \"--short\", \"HEAD\"])\n\n        # 获取当前 tag（最近的一个）\n        try:\n            result[\"local_tag\"] = run_git(repo, [\"describe\", \"--tags\", \"--always\"])\n        except Exception:\n            pass\n\n        # 获取远端分支状态（优先 upstream，fallback 到 origin，但会全部记录）\n        candidate_branches = [\n            \"upstream/main\", \"upstream/master\",\n            \"origin/main\", \"origin/master\",\n        ]\n        primary_branch = None\n        for branch in candidate_branches:\n            try:\n                run_git(repo, [\"rev-parse\", \"--short\", branch])\n            except Exception:\n                continue\n\n            try:\n                branch_tag = run_git(repo, [\"describe\", \"--tags\", \"--always\", branch])\n            except Exception:\n                branch_tag = None\n\n            try:\n                behind = int(run_git(repo, [\"rev-list\", \"--count\", f\"HEAD..{branch}\"]))\n                ahead = int(run_git(repo, [\"rev-list\", \"--count\", f\"{branch}..HEAD\"]))\n            except Exception:\n                behind = 0\n                ahead = 0\n\n            result[\"remote_statuses\"][branch] = {\n                \"tag\": branch_tag,\n                \"behind\": behind,\n                \"ahead\": ahead,\n            }\n            if primary_branch is None:\n                primary_branch = branch\n\n        if primary_branch is None:\n            result[\"status\"] = \"no_upstream\"\n            return result\n\n        result[\"upstream_branch\"] = primary_branch\n        result[\"upstream_tag\"] = result[\"remote_statuses\"][primary_branch].get(\"tag\")\n        result[\"commits_behind\"] = max(v.get(\"behind\", 0) for v in result[\"remote_statuses\"].values())\n        result[\"commits_ahead\"] = max(v.get(\"ahead\", 0) for v in result[\"remote_statuses\"].values())\n        result[\"local_updates\"] = result[\"commits_behind\"] == 0 and result[\"commits_ahead\"] > 0\n        result[\"diverged\"] = any(v.get(\"behind\", 0) > 0 and v.get(\"ahead\", 0) > 0 for v in result[\"remote_statuses\"].values())\n\n        # 仅对主比较分支抓取上游新增 commit，避免重复\n        if result[\"remote_statuses\"][primary_branch].get(\"behind\", 0) > 0:\n            commits_raw = run_git(\n                repo,\n                [\"log\", f\"HEAD..{primary_branch}\", \"--format=%s|||%h\", \"-20\"]\n            )\n            for line in commits_raw.splitlines():\n                if not line.strip():\n                    continue\n                parts = line.split(\"|||\")\n                msg = parts[0].strip()\n                short = parts[1].strip() if len(parts) > 1 else \"\"\n                priority = classify_commit(msg)\n                is_break = \"breaking\" in priority.lower() or \"🔴\" in priority\n                result[\"new_commits\"].append({\n                    \"message\": msg,\n                    \"short\": short,\n                    \"priority\": priority,\n                    \"breaking\": is_break,\n                })\n                if is_break:\n                    result[\"breaking_changes\"] = True\n\n        # 状态判断\n        if result[\"diverged\"]:\n            result[\"status\"] = \"diverged\"\n        elif result[\"commits_behind\"] == 0 and result[\"commits_ahead\"] > 0:\n            result[\"status\"] = \"local_ahead\"\n        elif result[\"commits_behind\"] == 0:\n            result[\"status\"] = \"up_to_date\"\n        elif result[\"breaking_changes\"]:\n            result[\"status\"] = \"breaking_update\"\n        elif result[\"commits_behind\"] <= 3:\n            result[\"status\"] = \"minor_update\"\n        elif result[\"commits_behind\"] <= 10:\n            result[\"status\"] = \"major_update\"\n        else:\n            result[\"status\"] = \"far_behind\"\n\n    except Exception as e:\n        result[\"error\"] = str(e)\n\n    return result\n"},{"oldText":"    if s == \"up_to_date\":\n        return False, \"已是最新版本\", 0\n    if s == \"no_upstream\":\n        return False, \"无 upstream remote，跳过\", 0\n\n    if breaking:\n        return True, f\"包含 Breaking Changes，强烈建议更新（{commits} commits）\", 5\n","newText":"    if s == \"up_to_date\":\n        return False, \"已是最新版本\", 0\n    if s == \"local_ahead\":\n        return False, f\"本地有新增提交（ahead {status.get('commits_ahead', 0)}）\", 1\n    if s == \"no_upstream\":\n        return False, \"无 upstream remote，跳过\", 0\n    if s == \"diverged\":\n        return True, f\"本地与远端已分叉（behind {status.get('commits_behind', 0)} / ahead {status.get('commits_ahead', 0)}）\", 5\n\n    if breaking:\n        return True, f\"包含 Breaking Changes，强烈建议更新（{commits} commits）\", 5\n"},{"oldText":"    recommend_updates = [r for r in all_results if should_update(r)[0]]\n    up_to_date = [r for r in all_results if r.get(\"status\") == \"up_to_date\"]\n    no_update = [r for r in all_results if not should_update(r)[0] and r.get(\"status\") != \"up_to_date\"]\n\n    lines.append(f\"**检查仓库数：{len(all_results)}** | 建议更新：{len(recommend_updates)} | 已最新：{len(up_to_date)}\")\n","newText":"    recommend_updates = [r for r in all_results if should_update(r)[0]]\n    local_changes = [r for r in all_results if r.get(\"status\") == \"local_ahead\"]\n    up_to_date = [r for r in all_results if r.get(\"status\") == \"up_to_date\"]\n    no_update = [r for r in all_results if not should_update(r)[0] and r.get(\"status\") not in {\"up_to_date\", \"local_ahead\"}]\n\n    lines.append(f\"**检查仓库数：{len(all_results)}** | 建议更新：{len(recommend_updates)} | 本地有新增：{len(local_changes)} | 已同步：{len(up_to_date)}\")\n"},{"oldText":"    else:\n        lines.append(\"## ✅ 所有仓库已最新，无需更新\\n\")\n\n    if up_to_date:\n        lines.append(f\"**已最新（{len(up_to_date)}）：** \" + \"、\".join(r[\"name\"] for r in up_to_date))\n        lines.append(\"\")\n\n    if no_update:\n        lines.append(f\"**无需操作（{len(no_update)}）：** \" + \"、\".join(r[\"name\"] for r in no_update))\n        lines.append(\"\")\n","newText":"    elif not local_changes:\n        lines.append(\"## ✅ 所有仓库已同步，无需处理\\n\")\n\n    if local_changes:\n        lines.append(\"## 🛠 本地有新增提交\\n\")\n        for r in local_changes:\n            lines.append(f\"### {r['name']}\")\n            lines.append(f\"- 当前版本：{r.get('local_tag', '?')}\")\n            lines.append(f\"- 主比较分支：{r.get('upstream_branch', '?')}\")\n            lines.append(f\"- 本地领先：{r.get('commits_ahead', 0)} commits\")\n            if r.get(\"remote_statuses\"):\n                remote_desc = \"；\".join(\n                    f\"{branch}: behind {meta.get('behind', 0)} / ahead {meta.get('ahead', 0)}\"\n                    for branch, meta in r[\"remote_statuses\"].items()\n                )\n                lines.append(f\"- 远端对比：{remote_desc}\")\n            lines.append(\"\")\n\n    if up_to_date:\n        lines.append(f\"**已同步（{len(up_to_date)}）：** \" + \"、\".join(r[\"name\"] for r in up_to_date))\n        lines.append(\"\")\n\n    if no_update:\n        lines.append(f\"**无需操作（{len(no_update)}）：** \" + \"、\".join(r[\"name\"] for r in no_update))\n        lines.append(\"\")\n"},{"oldText":"    recommend = [r for r in results if should_update(r)[0]]\n    breaking = [r for r in results if r.get(\"breaking_changes\")]\n    up_to_date = [r for r in results if r.get(\"status\") == \"up_to_date\"]\n\n    if not recommend:\n        msg = f\"✅ GitHub 仓库检查 | {len(up_to_date)} 个已最新 | 无需更新\"\n    else:\n        top = recommend[0]\n        msg = f\"🔔 GitHub 仓库更新 | {len(recommend)} 个可更新 | 最高优先：{top['name']}（{top['commits_behind']} commits）\"\n        if breaking:\n            msg += f\"\\n⚠️ 含 Breaking Changes：{'、'.join(r['name'] for r in breaking)}\"\n    return msg\n","newText":"    recommend = [r for r in results if should_update(r)[0]]\n    breaking = [r for r in results if r.get(\"breaking_changes\")]\n    up_to_date = [r for r in results if r.get(\"status\") == \"up_to_date\"]\n    local_changes = [r for r in results if r.get(\"status\") == \"local_ahead\"]\n\n    if recommend:\n        top = recommend[0]\n        msg = f\"🔔 GitHub 仓库检查 | 上游 {len(recommend)} 个待处理 | 本地 {len(local_changes)} 个有新增 | 最高优先：{top['name']}（behind {top['commits_behind']}）\"\n        if breaking:\n            msg += f\"\\n⚠️ 含 Breaking Changes：{'、'.join(r['name'] for r in breaking)}\"\n        return msg\n\n    if local_changes:\n        return f\"🛠 GitHub 仓库检查 | 本地 {len(local_changes)} 个有新增 | 上游 0 个待处理 | {local_changes[0]['name']} 等\"\n\n    return f\"✅ GitHub 仓库检查 | {len(up_to_date)} 个已同步 | 无需处理\"\n"},{"oldText":"        commits = status.get(\"commits_behind\", \"?\")\n        local = status.get(\"local_tag\", \"?\")\n        upstream = status.get(\"upstream_tag\", \"?\")\n        print(f\"本地={local} 上游={upstream} 落后={commits} commits [{status.get('status','?')}]\")\n","newText":"        commits = status.get(\"commits_behind\", \"?\")\n        ahead = status.get(\"commits_ahead\", \"?\")\n        local = status.get(\"local_tag\", \"?\")\n        upstream = status.get(\"upstream_tag\", \"?\")\n        print(f\"本地={local} 上游={upstream} 落后={commits} commits 超前={ahead} commits [{status.get('status','?')}]\")\n"}]},"partialJson":"{\"file\":\"/Users/ling/.openclaw/skills/github-repo-monitor/scripts/check_updates.py\",\"edits\":[{\"oldText\":\"def run_git(repo_dir: Path, args: list[str], timeout: int = 15) -> str:\\n    \\\"\\\"\\\"运行 git 命令\\\"\\\"\\\"\\n    full_cmd = [\\\"git\\\", \\\"-C\\\", str(repo_dir)] + args\\n    r = subprocess.run(full_cmd, capture_output=True, text=True, timeout=timeout)\\n    if r.returncode != 0:\\n        raise RuntimeError(f\\\"git failed: {r.stderr.strip()}\\\")\\n    return r.stdout.strip()\\n\\n\\ndef get_repo_status(repo_path: str) -> dict:\\n\",\"newText\":\"def run_git(repo_dir: Path, args: list[str], timeout: int = 15) -> str:\\n    \\\"\\\"\\\"运行 git 命令\\\"\\\"\\\"\\n    full_cmd = [\\\"git\\\", \\\"-C\\\", str(repo_dir)] + args\\n    r = subprocess.run(full_cmd, capture_output=True, text=True, timeout=timeout)\\n    if r.returncode != 0:\\n        raise RuntimeError(f\\\"git failed: {r.stderr.strip()}\\\")\\n    return r.stdout.strip()\\n\\n\\ndef fetch_repo(repo_dir: Path) -> Optional[str]:\\n    \\\"\\\"\\\"刷新远端引用；失败时返回错误文本，不中断整体检查。\\\"\\\"\\\"\\n    try:\\n        run_git(repo_dir, [\\\"fetch\\\", \\\"--all\\\", \\\"--tags\\\", \\\"--prune\\\"], timeout=60)\\n        return None\\n    except Exception as e:\\n        return str(e)\\n\\n\\ndef get_repo_status(repo_path: str) -> dict:\\n\"},{\"oldText\":\"    result = {\\n        \\\"path\\\": repo_path,\\n        \\\"name\\\": repo.name,\\n        \\\"local_tag\\\": None,\\n        \\\"upstream_tag\\\": None,\\n        \\\"commits_behind\\\": 0,\\n        \\\"commits_ahead\\\": 0,\\n        \\\"status\\\": \\\"unknown\\\",\\n        \\\"new_commits\\\": [],\\n        \\\"new_tags\\\": [],\\n        \\\"breaking_changes\\\": False,\\n    }\\n\",\"newText\":\"    result = {\\n        \\\"path\\\": repo_path,\\n        \\\"name\\\": repo.name,\\n        \\\"local_tag\\\": None,\\n        \\\"upstream_tag\\\": None,\\n        \\\"commits_behind\\\": 0,\\n        \\\"commits_ahead\\\": 0,\\n        \\\"status\\\": \\\"unknown\\\",\\n        \\\"new_commits\\\": [],\\n        \\\"new_tags\\\": [],\\n        \\\"breaking_changes\\\": False,\\n        \\\"remote_statuses\\\": {},\\n        \\\"local_updates\\\": False,\\n        \\\"diverged\\\": False,\\n        \\\"fetch_ok\\\": True,\\n        \\\"fetch_error\\\": None,\\n    }\\n\"},{\"oldText\":\"    try:\\n        # 获取当前 HEAD\\n        local_sha = run_git(repo, [\\\"rev-parse\\\", \\\"--short\\\", \\\"HEAD\\\"])\\n\\n        # 获取上游分支（优先 upstream，fallback 到 origin）\\n        for branch in [\\n            \\\"upstream/main\\\", \\\"upstream/master\\\",\\n            \\\"origin/main\\\", \\\"origin/master\\\",\\n        ]:\\n            try:\\n                upstream_sha = run_git(repo, [\\\"rev-parse\\\", \\\"--short\\\", branch])\\n                result[\\\"upstream_branch\\\"] = branch\\n                break\\n            except Exception:\\n                continue\\n\\n        if \\\"upstream_branch\\\" not in result:\\n            result[\\\"status\\\"] = \\\"no_upstream\\\"\\n            return result\\n\\n        # 获取当前 tag（最近的一个）\\n        try:\\n            result[\\\"local_tag\\\"] = run_git(repo, [\\\"describe\\\", \\\"--tags\\\", \\\"--always\\\"])\\n        except Exception:\\n            pass\\n\\n        # 获取 upstream 最新 tag\\n        try:\\n            upstream_tag = run_git(repo, [\\\"describe\\\", \\\"--tags\\\", \\\"--always\\\", result[\\\"upstream_branch\\\"]])\\n            result[\\\"upstream_tag\\\"] = upstream_tag\\n        except Exception:\\n            pass\\n\\n        # 计算落后多少 commits\\n        try:\\n            behind = run_git(repo, [\\\"rev-list\\\", \\\"--count\\\", f\\\"HEAD..{result['upstream_branch']}\\\"])\\n            ahead = run_git(repo, [\\\"rev-list\\\", \\\"--count\\\", f\\\"{result['upstream_branch']}..HEAD\\\"])\\n            result[\\\"commits_behind\\\"] = int(behind)\\n            result[\\\"commits_ahead\\\"] = int(ahead)\\n        except Exception:\\n            pass\\n\\n        # 获取具体的新 commit\\n        if result[\\\"commits_behind\\\"] > 0:\\n            commits_raw = run_git(\\n                repo,\\n                [\\\"log\\\", f\\\"HEAD..{result['upstream_branch']}\\\", \\\"--format=%s|||%h\\\", \\\"-20\\\"]\\n            )\\n            for line in commits_raw.splitlines():\\n                if not line.strip():\\n                    continue\\n                parts = line.split(\\\"|||\\\")\\n                msg = parts[0].strip()\\n                short = parts[1].strip() if len(parts) > 1 else \\\"\\\"\\n                priority = classify_commit(msg)\\n                is_break = \\\"breaking\\\" in priority.lower() or \\\"🔴\\\" in priority\\n                result[\\\"new_commits\\\"].append({\\n                    \\\"message\\\": msg,\\n                    \\\"short\\\": short,\\n                    \\\"priority\\\": priority,\\n                    \\\"breaking\\\": is_break,\\n                })\\n                if is_break:\\n                    result[\\\"breaking_changes\\\"] = True\\n\\n        # 状态判断\\n        if result[\\\"commits_behind\\\"] == 0:\\n            result[\\\"status\\\"] = \\\"up_to_date\\\"\\n        elif result[\\\"breaking_changes\\\"]:\\n            result[\\\"status\\\"] = \\\"breaking_update\\\"\\n        elif result[\\\"commits_behind\\\"] <= 3:\\n            result[\\\"status\\\"] = \\\"minor_update\\\"\\n        elif result[\\\"commits_behind\\\"] <= 10:\\n            result[\\\"status\\\"] = \\\"major_update\\\"\\n        else:\\n            result[\\\"status\\\"] = \\\"far_behind\\\"\\n\\n    except Exception as e:\\n        result[\\\"error\\\"] = str(e)\\n\\n    return result\\n\",\"newText\":\"    try:\\n        fetch_error = fetch_repo(repo)\\n        if fetch_error:\\n            result[\\\"fetch_ok\\\"] = False\\n            result[\\\"fetch_error\\\"] = fetch_error\\n\\n        # 获取当前 HEAD\\n        run_git(repo, [\\\"rev-parse\\\", \\\"--short\\\", \\\"HEAD\\\"])\\n\\n        # 获取当前 tag（最近的一个）\\n        try:\\n            result[\\\"local_tag\\\"] = run_git(repo, [\\\"describe\\\", \\\"--tags\\\", \\\"--always\\\"])\\n        except Exception:\\n            pass\\n\\n        # 获取远端分支状态（优先 upstream，fallback 到 origin，但会全部记录）\\n        candidate_branches = [\\n            \\\"upstream/main\\\", \\\"upstream/master\\\",\\n            \\\"origin/main\\\", \\\"origin/master\\\",\\n        ]\\n        primary_branch = None\\n        for branch in candidate_branches:\\n            try:\\n                run_git(repo, [\\\"rev-parse\\\", \\\"--short\\\", branch])\\n            except Exception:\\n                continue\\n\\n            try:\\n                branch_tag = run_git(repo, [\\\"describe\\\", \\\"--tags\\\", \\\"--always\\\", branch])\\n            except Exception:\\n                branch_tag = None\\n\\n            try:\\n                behind = int(run_git(repo, [\\\"rev-list\\\", \\\"--count\\\", f\\\"HEAD..{branch}\\\"]))\\n                ahead = int(run_git(repo, [\\\"rev-list\\\", \\\"--count\\\", f\\\"{branch}..HEAD\\\"]))\\n            except Exception:\\n                behind = 0\\n                ahead = 0\\n\\n            result[\\\"remote_statuses\\\"][branch] = {\\n                \\\"tag\\\": branch_tag,\\n                \\\"behind\\\": behind,\\n                \\\"ahead\\\": ahead,\\n            }\\n            if primary_branch is None:\\n                primary_branch = branch\\n\\n        if primary_branch is None:\\n            result[\\\"status\\\"] = \\\"no_upstream\\\"\\n            return result\\n\\n        result[\\\"upstream_branch\\\"] = primary_branch\\n        result[\\\"upstream_tag\\\"] = result[\\\"remote_statuses\\\"][primary_branch].get(\\\"tag\\\")\\n        result[\\\"commits_behind\\\"] = max(v.get(\\\"behind\\\", 0) for v in result[\\\"remote_statuses\\\"].values())\\n        result[\\\"commits_ahead\\\"] = max(v.get(\\\"ahead\\\", 0) for v in result[\\\"remote_statuses\\\"].values())\\n        result[\\\"local_updates\\\"] = result[\\\"commits_behind\\\"] == 0 and result[\\\"commits_ahead\\\"] > 0\\n        result[\\\"diverged\\\"] = any(v.get(\\\"behind\\\", 0) > 0 and v.get(\\\"ahead\\\", 0) > 0 for v in result[\\\"remote_statuses\\\"].values())\\n\\n        # 仅对主比较分支抓取上游新增 commit，避免重复\\n        if result[\\\"remote_statuses\\\"][primary_branch].get(\\\"behind\\\", 0) > 0:\\n            commits_raw = run_git(\\n                repo,\\n                [\\\"log\\\", f\\\"HEAD..{primary_branch}\\\", \\\"--format=%s|||%h\\\", \\\"-20\\\"]\\n            )\\n            for line in commits_raw.splitlines():\\n                if not line.strip():\\n                    continue\\n                parts = line.split(\\\"|||\\\")\\n                msg = parts[0].strip()\\n                short = parts[1].strip() if len(parts) > 1 else \\\"\\\"\\n                priority = classify_commit(msg)\\n                is_break = \\\"breaking\\\" in priority.lower() or \\\"🔴\\\" in priority\\n                result[\\\"new_commits\\\"].append({\\n                    \\\"message\\\": msg,\\n                    \\\"short\\\": short,\\n                    \\\"priority\\\": priority,\\n                    \\\"breaking\\\": is_break,\\n                })\\n                if is_break:\\n                    result[\\\"breaking_changes\\\"] = True\\n\\n        # 状态判断\\n        if result[\\\"diverged\\\"]:\\n            result[\\\"status\\\"] = \\\"diverged\\\"\\n        elif result[\\\"commits_behind\\\"] == 0 and result[\\\"commits_ahead\\\"] > 0:\\n            result[\\\"status\\\"] = \\\"local_ahead\\\"\\n        elif result[\\\"commits_behind\\\"] == 0:\\n            result[\\\"status\\\"] = \\\"up_to_date\\\"\\n        elif result[\\\"breaking_changes\\\"]:\\n            result[\\\"status\\\"] = \\\"breaking_update\\\"\\n        elif result[\\\"commits_behind\\\"] <= 3:\\n            result[\\\"status\\\"] = \\\"minor_update\\\"\\n        elif result[\\\"commits_behind\\\"] <= 10:\\n            result[\\\"status\\\"] = \\\"major_update\\\"\\n        else:\\n            result[\\\"status\\\"] = \\\"far_behind\\\"\\n\\n    except Exception as e:\\n        result[\\\"error\\\"] = str(e)\\n\\n    return result\\n\"},{\"oldText\":\"    if s == \\\"up_to_date\\\":\\n        return False, \\\"已是最新版本\\\", 0\\n    if s == \\\"no_upstream\\\":\\n        return False, \\\"无 upstream remote，跳过\\\", 0\\n\\n    if breaking:\\n        return True, f\\\"包含 Breaking Changes，强烈建议更新（{commits} commits）\\\", 5\\n\",\"newText\":\"    if s == \\\"up_to_date\\\":\\n        return False, \\\"已是最新版本\\\", 0\\n    if s == \\\"local_ahead\\\":\\n        return False, f\\\"本地有新增提交（ahead {status.get('commits_ahead', 0)}）\\\", 1\\n    if s == \\\"no_upstream\\\":\\n        return False, \\\"无 upstream remote，跳过\\\", 0\\n    if s == \\\"diverged\\\":\\n        return True, f\\\"本地与远端已分叉（behind {status.get('commits_behind', 0)} / ahead {status.get('commits_ahead', 0)}）\\\", 5\\n\\n    if breaking:\\n        return True, f\\\"包含 Breaking Changes，强烈建议更新（{commits} commits）\\\", 5\\n\"},{\"oldText\":\"    recommend_updates = [r for r in all_results if should_update(r)[0]]\\n    up_to_date = [r for r in all_results if r.get(\\\"status\\\") == \\\"up_to_date\\\"]\\n    no_update = [r for r in all_results if not should_update(r)[0] and r.get(\\\"status\\\") != \\\"up_to_date\\\"]\\n\\n    lines.append(f\\\"**检查仓库数：{len(all_results)}** | 建议更新：{len(recommend_updates)} | 已最新：{len(up_to_date)}\\\")\\n\",\"newText\":\"    recommend_updates = [r for r in all_results if should_update(r)[0]]\\n    local_changes = [r for r in all_results if r.get(\\\"status\\\") == \\\"local_ahead\\\"]\\n    up_to_date = [r for r in all_results if r.get(\\\"status\\\") == \\\"up_to_date\\\"]\\n    no_update = [r for r in all_results if not should_update(r)[0] and r.get(\\\"status\\\") not in {\\\"up_to_date\\\", \\\"local_ahead\\\"}]\\n\\n    lines.append(f\\\"**检查仓库数：{len(all_results)}** | 建议更新：{len(recommend_updates)} | 本地有新增：{len(local_changes)} | 已同步：{len(up_to_date)}\\\")\\n\"},{\"oldText\":\"    else:\\n        lines.append(\\\"## ✅ 所有仓库已最新，无需更新\\\\n\\\")\\n\\n    if up_to_date:\\n        lines.append(f\\\"**已最新（{len(up_to_date)}）：** \\\" + \\\"、\\\".join(r[\\\"name\\\"] for r in up_to_date))\\n        lines.append(\\\"\\\")\\n\\n    if no_update:\\n        lines.append(f\\\"**无需操作（{len(no_update)}）：** \\\" + \\\"、\\\".join(r[\\\"name\\\"] for r in no_update))\\n        lines.append(\\\"\\\")\\n\",\"newText\":\"    elif not local_changes:\\n        lines.append(\\\"## ✅ 所有仓库已同步，无需处理\\\\n\\\")\\n\\n    if local_changes:\\n        lines.append(\\\"## 🛠 本地有新增提交\\\\n\\\")\\n        for r in local_changes:\\n            lines.append(f\\\"### {r['name']}\\\")\\n            lines.append(f\\\"- 当前版本：{r.get('local_tag', '?')}\\\")\\n            lines.append(f\\\"- 主比较分支：{r.get('upstream_branch', '?')}\\\")\\n            lines.append(f\\\"- 本地领先：{r.get('commits_ahead', 0)} commits\\\")\\n            if r.get(\\\"remote_statuses\\\"):\\n                remote_desc = \\\"；\\\".join(\\n                    f\\\"{branch}: behind {meta.get('behind', 0)} / ahead {meta.get('ahead', 0)}\\\"\\n                    for branch, meta in r[\\\"remote_statuses\\\"].items()\\n                )\\n                lines.append(f\\\"- 远端对比：{remote_desc}\\\")\\n            lines.append(\\\"\\\")\\n\\n    if up_to_date:\\n        lines.append(f\\\"**已同步（{len(up_to_date)}）：** \\\" + \\\"、\\\".join(r[\\\"name\\\"] for r in up_to_date))\\n        lines.append(\\\"\\\")\\n\\n    if no_update:\\n        lines.append(f\\\"**无需操作（{len(no_update)}）：** \\\" + \\\"、\\\".join(r[\\\"name\\\"] for r in no_update))\\n        lines.append(\\\"\\\")\\n\"},{\"oldText\":\"    recommend = [r for r in results if should_update(r)[0]]\\n    breaking = [r for r in results if r.get(\\\"breaking_changes\\\")]\\n    up_to_date = [r for r in results if r.get(\\\"status\\\") == \\\"up_to_date\\\"]\\n\\n    if not recommend:\\n        msg = f\\\"✅ GitHub 仓库检查 | {len(up_to_date)} 个已最新 | 无需更新\\\"\\n    else:\\n        top = recommend[0]\\n        msg = f\\\"🔔 GitHub 仓库更新 | {len(recommend)} 个可更新 | 最高优先：{top['name']}（{top['commits_behind']} commits）\\\"\\n        if breaking:\\n            msg += f\\\"\\\\n⚠️ 含 Breaking Changes：{'、'.join(r['name'] for r in breaking)}\\\"\\n    return msg\\n\",\"newText\":\"    recommend = [r for r in results if should_update(r)[0]]\\n    breaking = [r for r in results if r.get(\\\"breaking_changes\\\")]\\n    up_to_date = [r for r in results if r.get(\\\"status\\\") == \\\"up_to_date\\\"]\\n    local_changes = [r for r in results if r.get(\\\"status\\\") == \\\"local_ahead\\\"]\\n\\n    if recommend:\\n        top = recommend[0]\\n        msg = f\\\"🔔 GitHub 仓库检查 | 上游 {len(recommend)} 个待处理 | 本地 {len(local_changes)} 个有新增 | 最高优先：{top['name']}（behind {top['commits_behind']}）\\\"\\n        if breaking:\\n            msg += f\\\"\\\\n⚠️ 含 Breaking Changes：{'、'.join(r['name'] for r in breaking)}\\\"\\n        return msg\\n\\n    if local_changes:\\n        return f\\\"🛠 GitHub 仓库检查 | 本地 {len(local_changes)} 个有新增 | 上游 0 个待处理 | {local_changes[0]['name']} 等\\\"\\n\\n    return f\\\"✅ GitHub 仓库检查 | {len(up_to_date)} 个已同步 | 无需处理\\\"\\n\"},{\"oldText\":\"        commits = status.get(\\\"commits_behind\\\", \\\"?\\\")\\n        local = status.get(\\\"local_tag\\\", \\\"?\\\")\\n        upstream = status.get(\\\"upstream_tag\\\", \\\"?\\\")\\n        print(f\\\"本地={local} 上游={upstream} 落后={commits} commits [{status.get('status','?')}]\\\")\\n\",\"newText\":\"        commits = status.get(\\\"commits_behind\\\", \\\"?\\\")\\n        ahead = status.get(\\\"commits_ahead\\\", \\\"?\\\")\\n        local = status.get(\\\"local_tag\\\", \\\"?\\\")\\n        upstream = status.get(\\\"upstream_tag\\\", \\\"?\\\")\\n        print(f\\\"本地={local} 上游={upstream} 落后={commits} commits 超前={ahead} commits [{status.get('status','?')}]\\\")\\n\"}]}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":44962,"output":5785,"cacheRead":24320,"cacheWrite":0,"totalTokens":75067,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775083637868,"responseId":"resp_0faca0e75e9e48550169cda0950bc8819abc7b09e132727c2b"}}
