orkspace","timeout":120},"partialJson":"{\"command\":\"python3 - <<'PY'\\nimport akshare as ak\\nfor code,p in [('000938','sz'),('300383','sz')]:\\n    print(f'=== {code} FUND ===')\\n    try:\\n        df=ak.stock_individual_fund_flow(stock=code, market=p)\\n        print(df.tail(10).to_string(index=False))\\n    except Exception as e:\\n        print('ERR fund',repr(e))\\n    print()\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":120}"},{"type":"toolCall","id":"call_MN4swzi76Yfu3qVUj4Tp7WzZ|fc_01c730309d5123030169c5ee1e9698819bb68d7ca3f797357c","name":"exec","arguments":{"command":"python3 - <<'PY'\nimport akshare as ak, pandas as pd\npairs=[('000938','sz',24.77),('300383','sz',17.08)]\nfor code,p,current in pairs:\n    df=ak.stock_zh_a_daily(symbol=p+code, adjust='qfq').reset_index(drop=True)\n    df['date']=pd.to_datetime(df['date'])\n    s=pd.concat([df['close'], pd.Series([current])], ignore_index=True)\n    print(f'=== {code} TECH ===')\n    print('MA5', round(s.tail(5).mean(),2),'MA10',round(s.tail(10).mean(),2),'MA20',round(s.tail(20).mean(),2),'MA60',round(s.tail(60).mean(),2))\n    start=df[df['date']>=pd.Timestamp('2026-01-01')].iloc[0]['close']\n    print('YTD', round((current/start-1)*100,2),'20D',round((current/df.iloc[-20]['close']-1)*100,2),'60D',round((current/df.iloc[-60]['close']-1)*100,2))\n    print('52W_HIGH', round(float(df.tail(250)['high'].max()),2),'52W_LOW',round(float(df.tail(250)['low'].min()),2))\n    print('DIST_HIGH', round((current/df.tail(250)['high'].max()-1)*100,2),'DIST_LOW',round((current/df.tail(250)['low'].min()-1)*100,2))\n    print('AVG_TURNOVER_20', round(df.tail(20)['turnover'].mean()*100,2),'AVG_AMOUNT_20Y', round(df.tail(20)['amount'].mean()/1e8,2))\n    print()\nPY","workdir":"/Users/ling/.openclaw/workspace","timeout":120},"partialJson":"{\"command\":\"python3 - <<'PY'\\nimport akshare as ak, pandas as pd\\npairs=[('000938','sz',24.77),('300383','sz',17.08)]\\nfor code,p,current in pairs:\\n    df=ak.stock_zh_a_daily(symbol=p+code, adjust='qfq').reset_index(drop=True)\\n    df['date']=pd.to_datetime(df['date'])\\n    s=pd.concat([df['close'], pd.Series([current])], ignore_index=True)\\n    print(f'=== {code} TECH ===')\\n    print('MA5', round(s.tail(5).mean(),2),'MA10',round(s.tail(10).mean(),2),'MA20',round(s.tail(20).mean(),2),'MA60',round(s.tail(60).mean(),2))\\n    start=df[df['date']>=pd.Timestamp('2026-01-01')].iloc[0]['close']\\n    print('YTD', round((current/start-1)*100,2),'20D',round((current/df.iloc[-20]['close']-1)*100,2),'60D',round((current/df.iloc[-60]['close']-1)*100,2))\\n    print('52W_HIGH', round(float(df.tail(250)['high'].max()),2),'52W_LOW',round(float(df.tail(250)['low'].min()),2))\\n    print('DIST_HIGH', round((current/df.tail(250)['high'].max()-1)*100,2),'DIST_LOW',round((current/df.tail(250)['low'].min()-1)*100,2))\\n    print('AVG_TURNOVER_20', round(df.tail(20)['turnover'].mean()*100,2),'AVG_AMOUNT_20Y', round(df.tail(20)['amount'].mean()/1e8,2))\\n    print()\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":120}"},{"type":"toolCall","id":"call_WfJf7AHuppSyXNMwrEUWSm6h|fc_01c730309d5123030169c5ee1e96a0819b88b5192d42442f23","name":"exec","arguments":{"command":"python3 - <<'PY'\nimport akshare as ak\nfor d in ['20251231']:\n    print('=== yjyg', d, '===')\n    try:\n        df=ak.stock_yjyg_em(date=d)\n        for code in ['000938','300383']:\n            row=df[df['股票代码'].astype(str).str.zfill(6)==code]\n            print(code)\n            print(row.to_string(index=False) if not row.empty else 'NO_PREANNOUNCE')\n    except Exception as e:\n        print('ERR yjyg',d,repr(e))\n    print()\nPY","workdir":"/Users/ling/.openclaw/workspace","timeout":180},"partialJson":"{\"command\":\"python3 - <<'PY'\\nimport akshare as ak\\nfor d in ['20251231']:\\n    print('=== yjyg', d, '===')\\n    try:\\n        df=ak.stock_yjyg_em(date=d)\\n        for code in ['000938','300383']:\\n            row=df[df['股票代码'].astype(str)