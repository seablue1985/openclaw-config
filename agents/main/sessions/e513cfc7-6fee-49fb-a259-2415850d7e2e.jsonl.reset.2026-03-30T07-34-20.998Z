i', round(amount/1e8,2), 'vol_wan', round(vol/1e4,2))\nprint('YTD', round((current/q[q['date']>=pd.Timestamp('2026-01-01')].iloc[0]['close']-1)*100,2))\nprint('20d_return', round((current/q.iloc[-20]['close']-1)*100,2))\nprint('60d_return', round((current/q.iloc[-60]['close']-1)*100,2))\nprint('52w_high', q.tail(250)['high'].max(), '52w_low', q.tail(250)['low'].min())\nprint('distance_to_52w_high_pct', round((current/q.tail(250)['high'].max()-1)*100,2))\nprint('distance_to_52w_low_pct', round((current/q.tail(250)['low'].min()-1)*100,2))\nprint('avg_turnover_20', round(q.tail(20)['turnover'].mean()*100,2))\nprint('avg_amount_20_yi', round(q.tail(20)['amount'].mean()/1e8,2))\nprint('2026_dates_tail')\nprint(q.tail(10)[['date','open','high','low','close','turnover']].to_string(index=False))\nPY","workdir":"/Users/ling/.openclaw/workspace","timeout":120},"partialJson":"{\"command\":\"python3 - <<'PY'\\nimport akshare as ak\\nimport pandas as pd\\nfrom math import isnan\\n# daily\\nq = ak.stock_zh_a_daily(symbol='sz002229', adjust='qfq').reset_index(drop=True)\\nq['date']=pd.to_datetime(q['date'])\\n# use last close 2026-03-26, and current 2026-03-27 intraday from min data if available\\nmin_df = ak.stock_zh_a_hist_min_em(symbol='002229', period='1', adjust='qfq')\\nmin_df['时间']=pd.to_datetime(min_df['时间'])\\n# today's data\\nlatest_day=min_df['时间'].dt.date.max()\\ntoday=min_df[min_df['时间'].dt.date==latest_day].copy()\\ncurrent=float(today.iloc[-1]['收盘'])\\nopen_=float(today.iloc[0]['收盘'])\\nhigh=float(today['最高'].max())\\nlow=float(today['最低'].min())\\nvol=float(today['成交量'].sum())\\namount=float(today['成交额'].sum())\\nyclose=float(q.iloc[-1]['close'])\\n# append intraday current as pseudo close for MA view\\nseries=q['close'].copy()\\nseries2=pd.concat([series, pd.Series([current])], ignore_index=True)\\nfor n in [5,10,20,60,120,250]:\\n    print(f'MA{n}', round(series2.tail(n).mean(),3))\\nprint('PRICE', current)\\nprint('TODAY', latest_day, 'open', open_, 'high', high, 'low', low, 'chg_pct', round((current/yclose-1)*100,2), 'amt_yi', round(amount/1e8,2), 'vol_wan', round(vol/1e4,2))\\nprint('YTD', round((current/q[q['date']>=pd.Timestamp('2026-01-01')].iloc[0]['close']-1)*100,2))\\nprint('20d_return', round((current/q.iloc[-20]['close']-1)*100,2))\\nprint('60d_return', round((current/q.iloc[-60]['close']-1)*100,2))\\nprint('52w_high', q.tail(250)['high'].max(), '52w_low', q.tail(250)['low'].min())\\nprint('distance_to_52w_high_pct', round((current/q.tail(250)['high'].max()-1)*100,2))\\nprint('distance_to_52w_low_pct', round((current/q.tail(250)['low'].min()-1)*100,2))\\nprint('avg_turnover_20', round(q.tail(20)['turnover'].mean()*100,2))\\nprint('avg_amount_20_yi', round(q.tail(20)['amount'].mean()/1e8,2))\\nprint('2026_dates_tail')\\nprint(q.tail(10)[['date','open','high','low','close','turnover']].to_string(index=False))\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":120}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":1211,"output":815,"cacheRead":78848,"cacheWrite":0,"totalTokens":80874,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774577038262,"responseId":"resp_01c730309d5123030169c5e58f2dc4819ba61d312b8d80047c"}}
