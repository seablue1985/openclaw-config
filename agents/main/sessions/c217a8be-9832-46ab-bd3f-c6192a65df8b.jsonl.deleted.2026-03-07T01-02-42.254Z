复.py\\\\n-rw-------   1 ling  staff   1690 Mar  4 17:52 聚宽_极限版_修复v2.py\\\\n-rw-------@  1 ling  staff  12036 Mar  4 17:46 聚宽_极限版_年化50.py\\\\n-rw-------   1 ling  staff   1947 Mar  4 17:48 聚宽_极限版_能交易.py\\\\n-rw-------   1 ling  staff   5176 Mar  4 17:28 聚宽_激进版_年化40.py\\\\n-rw-------   1 ling  staff   2315 Mar  4 17:34 聚宽_稳健版_v2.py\\\\n-rw-------   1 ling  staff   4549 Mar  4 17:28 聚宽_稳健版_年化30.py\\\"}],\\\"details\\\":{\\\"status\\\":\\\"completed\\\",\\\"exitCode\\\":0,\\\"durationMs\\\":23,\\\"aggregated\\\":\\\"total 216\\\\ndrwx------  19 ling  staff    608 Mar  4 17:52 .\\\\ndrwxr-xr-x  44 ling  staff   1408 Mar  5 09:02 ..\\\\n-rw-r--r--@  1 ling  staff   6148 Mar  4 17:24 .DS_Store\\\\ndrwx------   5 ling  staff    160 Mar  4 17:30 __pycache__\\\\n-rw-------   1 ling  staff   4837 Mar  4 15:22 新三马策略_Alpha增强.py\\\\n-rw-------   1 ling  staff   7091 Mar  4 15:15 新三马策略_ptrade.py\\\\n-rw-------   1 ling  staff   6135 Mar  4 15:19 新三马策略_回测.py\\\\n-rw-------   1 ling  staff   6500 Mar  4 15:25 新三马策略_年化50.py\\\\n-rw-------   1 ling  staff   3330 Mar  4 15:25 新三马策略_极限优化.py\\\\n-rw-------   1 ling  staff   6213 Mar  4 15:21 新三马策略_真实回测.py\\\\n-rw-------   1 ling  staff   6386 Mar  4 15:23 新三马策略_长周期回测.py\\\\n-rw-------   1 ling  staff   1031 Mar  4 17:37 聚宽_基础版.py\\\\n-rw-------   1 ling  staff   1835 Mar  4 17:50 聚宽_极限版_修复.py\\\\n-rw-------   1 ling  staff   1690 Mar  4 17:52 聚宽_极限版_修复v2.py\\\\n-rw-------@  1 ling  staff  12036 Mar  4 17:46 聚宽_极限版_年化50.py\\\\n-rw-------   1 ling  staff   1947 Mar  4 17:48 聚宽_极限版_能交易.py\\\\n-rw-------   1 ling  staff   5176 Mar  4 17:28 聚宽_激进版_年化40.py\\\\n-rw-------   1 ling  staff   2315 Mar  4 17:34 聚宽_稳健版_v2.py\\\\n-rw-------   1 ling  staff   4549 Mar  4 17:28 聚宽_稳健版_年化30.py\\\",\\\"cwd\\\":\\\"/Users/ling/.openclaw/workspace\\\"},\\\"isError\\\":false,\\\"timestamp\\\":1772678295888}}\\n/Users/ling/.openclaw/agents/main/sessions/34f55a68-da87-4c7f-bf50-b760c84eefb4.jsonl:{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"a7f89144\\\",\\\"parentId\\\":\\\"9599fd23\\\",\\\"timestamp\\\":\\\"2026-03-05T02:38:19.498Z\\\",\\\"message\\\":{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":[{\\\"type\\\":\\\"thinking\\\",\\\"thinking\\\":\\\"找到了三个文件：\\\\n1. 聚宽_极限版_年化50.py\\\\n2. 聚宽_激进版_年化40.py  \\\\n3. 聚宽_稳健版_年化30.py\\\\n\\\\n让我读取这三个文件的内容，了解策略逻辑，然后进行优化。\\\",\\\"thinkingSignature\\\":\\\"a6df740d9e7af97e2323f2d9a0bc54b89a43c68b36716daee01d58bd17d77c0e\\\"},{\\\"type\\\":\\\"toolCall\\\",\\\"id\\\":\\\"call_function_mfrsa2p4se28_1\\\",\\\"name\\\":\\\"read\\\",\\\"arguments\\\":{\\\"file_path\\\":\\\"/Users/ling/.openclaw/workspace/quant_strategies/聚宽_极限版_年化50.py\\\"}}],\\\"api\\\":\\\"anthropic-messages\\\",\\\"provider\\\":\\\"minimax-portal\\\",\\\"model\\\":\\\"MiniMax-M2.5\\\",\\\"usage\\\":{\\\"input\\\":20496,\\\"output\\\":109,\\\"cacheRead\\\":20128,\\\"cacheWrite\\\":0,\\\"totalTokens\\\":40733,\\\"cost\\\":{\\\"input\\\":0,\\\"output\\\":0,\\\"cacheRead\\\":0,\\\"cacheWrite\\\":0,\\\"total\\\":0}},\\\"stopReason\\\":\\\"toolUse\\\",\\\"timestamp\\\":1772678295893}}\\n/Users/ling/.openclaw/agents/main/sessions/34f55a68-da87-4c7f-bf50-b760c84eefb4.jsonl:{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"dc973cd6\\\",\\\"parentId\\\":\\\"a7f89144\\\",\\\"timestamp\\\":\\\"2026-03-05T02:38:19.516Z\\\",\\\"message\\\":{\\\"role\\\":\\\"toolResult\\\",\\\"toolCallId\\\":\\\"call_function_mfrsa2p4se28_1\\\",\\\"toolName\\\":\\\"read\\\",\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"\\\\\\\"\\\\\\\"\\\\\\\"\\\\n聚宽量化策略 - 极限版 (最终修正版)\\\\n目标年化: 50%+\\\\n配置: 20只小市值 + 5只白马股 (集中持仓)\\\\n\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\nimport numpy as np\\\\nimport pandas as pd\\\\nfrom datetime import timedelta\\\\nfrom jqdata import *\\\\n\\\\ndef initialize(context):\\\\n    # 基础设置\\\\n    log.set_level('order', 'error')\\\\n    set_option('use_real_price', True)\\\\n    set_option('avoid_future_data', True)\\\\n    \\\\n    # 基准: 沪深300\\\\n    set_benchmark('000300.XSHG')\\\\n    \\\\n    # 手续费 (万0.85免5)\\\\n    set_order_cost(OrderCost(close_tax=0.001, open_commission=0.000085, close_commission=0.000085, min_commission=5), type='stock')\\\\n    \\\\n    # === 策略参数 (极限) ===\\\\n    g.small_cap_num = 20      # 小市值数量 (极限增加)\\\\n    g.white_horse_num = 5     # 白马股数量 (极限减少)\\\\n    g.max_stock_price = 40    # 最高股价 (降低)\\\\n    g.min_days = 10           # 上市最短天数 (极限减少)\\\\n    g.max_days = 365*3        # 上市最长天数\\\\n    \\\\n    # 止损 (放宽)\\\\n    g.stoploss_ratio = 0.88   # 止损线\\\\n    \\\\n    # 动量过滤\\\\n    g.momentum_days = 10       \\\\n    g.momentum_threshold = -0.08  # 剔除跌幅>8%\\\\n    \\\\n    # 集中持仓: 前5只重仓\\\\n    g.top_heavy = 5\\\\n    g.top_heavy_ratio = 0.5  # 50%仓位在top5\\\\n    \\\\n    # 调仓频率\\\\n    g.rebalance_freq = 10     # 交易日 (更频繁)\\\\n    g.last_rebalance = None\\\\n    \\\\n    # 定时任务\\\\n    run_daily(before_open, '09:00')\\\\n    run_daily(trade, '09:35')\\\\n    run_daily(after_close, '15:00')\\\\n\\\\ndef before_open(context):\\\\n    log.info(\\\\\\\"========== 盘前 ==========\\\\\\\")\\\\n\\\\ndef trade(context):\\\\n    current_date = context.current_dt.date()\\\\n    \\\\n    # 调仓检查\\\\n    if g.last_rebalance is None or (current_date - g.last_rebalance).days >= g.rebalance_freq:\\\\n        # 选股 - 传入context参数\\\\n        stock_list = select_stocks(context)\\\\n        \\\\n        # 止损检查 - 传入context参数\\\\n        close_loss_positions(stock_list, context)\\\\n        \\\\n        # 调仓 (集中持仓) - 传入context参数\\\\n        rebalance_heavy(stock_list, context)\\\\n        \\\\n        g.last_rebalance = current_date\\\\n\\\\ndef after_close(context):\\\\n    positions = context.portfolio.positions\\\\n    total_value = context.portfolio.total_value\\\\n    log.info(\\\\\\\"========== 日报 ==========\\\\\\\")\\\\n    log.info(\\\\\\\"总资产: %.2f\\\\\\\" % total_value)\\\\n    log.info(\\\\\\\"持仓数量: %d\\\\\\\" % len(positions))\\\\n    \\\\n    for stock, pos in positions.items():\\\\n        # 避免除零错误\\\\n        if pos.total_amount == 0 or pos.avg_cost == 0:\\\\n            continue\\\\n        \\\\n        # 修复：使用正确的仓位属性计算盈亏\\\\n        total_cost = pos.total_amount * pos.avg_cost\\\\n        profit = pos.value - total_cost\\\\n        pnl = (profit / total_cost) * 100\\\\n        \\\\n        # 修复：pos.current_price 是当前股价，pos.value 是持仓市值\\\\n        log.info(\\\\\\\"%s: 持仓%d, 成本%.2f, 现价%.2f, 盈亏%.2f%%\\\\\\\" % \\\\n                 (stock, pos.total_amount, pos.avg_cost, pos.current_price, pnl))\\\\n\\\\ndef select_stocks(context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"选股: 小市值 + 白马 + 动量过滤\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    # 1. 小市值选股 (增加候选)\\\\n    small_caps = get_small_cap_stocks(g.small_cap_num + 10)\\\\n    \\\\n    # 2. 白马股选股 (减少候选)\\\\n    white_horses = get_white_horse_stocks(g.white_horse_num + 5)\\\\n    \\\\n    # 3. 合并\\\\n    stock_list = list(set(small_caps + white_horses))\\\\n    \\\\n    # 4. 动量过滤 - 传入context参数\\\\n    stock_list = filter_by_momentum(stock_list, context)\\\\n    \\\\n    # 5. 基本过滤 - 传入context参数\\\\n    stock_list = filter_stocks(stock_list, context)\\\\n    \\\\n    # 6. 按动量排序，取最强的 - 传入context参数\\\\n    stock_list = sort_by_momentum(stock_list, context)\\\\n    \\\\n    return stock_list[:g.small_cap_num + g.white_horse_num]\\\\n\\\\ndef get_small_cap_stocks(num):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"小市值选股 - 修复：使用valuation表而非indicator表\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        stocks = get_index_stocks('000852.XSHG')  # 中证1000\\\\n        if not stocks:\\\\n            log.warning(\\\\\\\"获取中证1000成分股失败\\\\\\\")\\\\n            return []\\\\n        \\\\n        # 修复：market_cap属于valuation表，不是indicator表\\\\n        q = query(\\\\n            valuation.code,\\\\n            valuation.market_cap\\\\n        ).filter(\\\\n            valuation.code.in_(stocks),\\\\n            valuation.market_cap > 0\\\\n        ).order_by(\\\\n            valuation.market_cap.asc()\\\\n        ).limit(num)\\\\n        \\\\n        df = get_fundamentals(q)\\\\n        return df['code'].tolist() if not df.empty else []\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"小市值选股出错: {str(e)}\\\\\\\")\\\\n        return []\\\\n\\\\ndef get_white_horse_stocks(num):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"白马股选股: PB>0, ROE>0, 现金流>0 - 修复字段归属错误\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        stocks = get_index_stocks('000300.XSHG') + get_index_stocks('000001.XSHG')\\\\n        if not stocks:\\\\n            log.warning(\\\\\\\"获取沪深300+上证综指成分股失败\\\\\\\")\\\\n            return []\\\\n        \\\\n        # 修复：pb_ratio属于valuation表，roe和operating_cash_flow属于indicator表\\\\n        q = query(\\\\n            valuation.code,\\\\n            valuation.pb_ratio,       # 市净率（PB）\\\\n            indicator.roe,            # 净资产收益率（ROE）\\\\n            indicator.operating_cash_flow  # 经营现金流\\\\n        ).filter(\\\\n            valuation.code.in_(stocks),\\\\n            valuation.pb_ratio > 0,   # PB>0\\\\n            indicator.roe > 0,        # ROE>0\\\\n            indicator.operating_cash_flow > 0  # 现金流>0\\\\n        ).order_by(\\\\n            indicator.roe.desc()\\\\n        ).limit(num)\\\\n        \\\\n        df = get_fundamentals(q)\\\\n        return df['code'].tolist() if not df.empty else []\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"白马股选股出错: {str(e)}\\\\\\\")\\\\n        return []\\\\n\\\\ndef filter_by_momentum(stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"动量过滤 - 修复：传入context，增加时间处理避免未来函数\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    result = []\\\\n    # 使用前一个交易日的数据，避免未来函数\\\\n    end_dt = context.current_dt - timedelta(days=1)\\\\n    \\\\n    for stock in stocks:\\\\n        try:\\\\n            df = get_price(stock, count=g.momentum_days + 1, fields='close', end_date=end_dt)\\\\n            if df.empty or len(df) < g.momentum_days:\\\\n                continue\\\\n            \\\\n            current = df['close'].iloc[-1]\\\\n            past = df['close'].iloc[-g.momentum_days]\\\\n            \\\\n            # 避免除零错误\\\\n            if past == 0:\\\\n                continue\\\\n                \\\\n            momentum = (current - past) / past\\\\n            \\\\n            # 剔除跌幅过大的\\\\n            if momentum >= g.momentum_threshold:\\\\n                result.append(stock)\\\\n        except Exception as e:\\\\n            log.error(f\\\\\\\"动量过滤{stock}出错: {str(e)}\\\\\\\")\\\\n            continue\\\\n    \\\\n    return result\\\\n\\\\ndef sort_by_momentum(stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"按动量排序 - 修复：传入context，增加异常处理\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    momentum_dict = {}\\\\n    end_dt = context.current_dt - timedelta(days=1)\\\\n    \\\\n    for stock in stocks:\\\\n        try:\\\\n            df = get_price(stock, count=g.momentum_days + 1, fields='close', end_date=end_dt)\\\\n            if df.empty or len(df) < g.momentum_days:\\\\n                momentum_dict[stock] = 0\\\\n                continue\\\\n            \\\\n            current = df['close'].iloc[-1]\\\\n            past = df['close'].iloc[-g.momentum_days]\\\\n            \\\\n            if past == 0:\\\\n                momentum_dict[stock] = 0\\\\n                continue\\\\n                \\\\n            momentum = (current - past) / past\\\\n            momentum_dict[stock] = momentum\\\\n        except Exception as e:\\\\n            log.error(f\\\\\\\"动量排序{stock}出错: {str(e)}\\\\\\\")\\\\n            momentum_dict[stock] = 0\\\\n    \\\\n    # 按动量排序\\\\n    sorted_stocks = sorted(momentum_dict.items(), key=lambda x: x[1], reverse=True)\\\\n    return [s[0] for s in sorted_stocks]\\\\n\\\\ndef filter_stocks(stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"过滤股票 - 修复：函数名、context传递、上市天数计算\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    result = []\\\\n    end_dt = context.current_dt - timedelta(days=1)\\\\n    \\\\n    for stock in stocks:\\\\n        try:\\\\n            # 价格过滤\\\\n            price_df = get_price(stock, count=1, fields='close', end_date=end_dt)\\\\n            if price_df.empty or price_df['close'].iloc[-1] > g.max_stock_price:\\\\n                continue\\\\n            \\\\n            # 修复：get_stock_info 不存在，使用正确的 get_security_info\\\\n            sec_info = get_security_info(stock)\\\\n            if sec_info:\\\\n                # 上市天数过滤\\\\n                list_date = sec_info.start_date\\\\n                days = (context.current_dt.date() - list_date).days\\\\n                if g.min_days <= days <= g.max_days:\\\\n                    result.append(stock)\\\\n        except Exception as e:\\\\n            log.error(f\\\\\\\"过滤股票{stock}出错: {str(e)}\\\\\\\")\\\\n            continue\\\\n    \\\\n    return result\\\\n\\\\ndef close_loss_positions(target_stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"止损 - 修复：context传递、仓位属性、除零检查\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        for stock in list(context.portfolio.positions.keys()):\\\\n            if stock not in target_stocks:\\\\n                pos = context.portfolio.positions[stock]\\\\n                \\\\n                # 避免除零错误\\\\n                if pos.total_amount == 0 or pos.avg_cost == 0:\\\\n                    continue\\\\n                \\\\n                # 修复：使用正确的属性计算当前价格\\\\n                current_price = pos.current_price\\\\n                cost = pos.avg_cost\\\\n                \\\\n                # 止损条件\\\\n                if current_price / cost < g.stoploss_ratio:\\\\n                    order_target_value(stock, 0)\\\\n                    log.info(f\\\\\\\"止损卖出: {stock}, 成本{cost:.2f}, 现价{current_price:.2f}, 跌幅{(1 - current_price/cost)*100:.2f}%\\\\\\\")\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"止损检查出错: {str(e)}\\\\\\\")\\\\n\\\\ndef rebalance_heavy(target_stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"调仓 - 集中持仓版本 - 修复语法错误和context传递\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not target_stocks:\\\\n        log.warning(\\\\\\\"目标股票列表为空，跳过调仓\\\\\\\")\\\\n        return\\\\n    \\\\n    try:\\\\n        total_value = context.portfolio.total_value\\\\n        \\\\n        # 计算每只股票的目标金额\\\\n        top_stocks = target_stocks[:g.top_heavy]\\\\n        other_stocks = target_stocks[g.top_heavy:]\\\\n        \\\\n        # 修复语法错误：top_value 计算逻辑\\\\n        # Top重仓：50%仓位平分给前5只\\\\n        if top_stocks:\\\\n            top_value = total_value * g.top_heavy_ratio / len(top_stocks)\\\\n            for stock in top_stocks:\\\\n                try:\\\\n                    current_value = context.portfolio.positions.get(stock, {}).get('value', 0)\\\\n                    diff = top_value - current_value\\\\n                    # 仓位变化>10%才调仓，减少交易频率\\\\n                    if abs(diff) > top_value * 0.1:\\\\n                        order_target_value(stock, top_value)\\\\n                except Exception as e:\\\\n                    log.error(f\\\\\\\"调仓重仓{stock}出错: {str(e)}\\\\\\\")\\\\n        \\\\n        # 其他持仓：剩余50%仓位平分\\\\n        if other_stocks:\\\\n            other_value = total_value * (1 - g.top_heavy_ratio) / len(other_stocks)\\\\n            for stock in other_stocks:\\\\n                try:\\\\n                    current_value = context.portfolio.positions.get(stock, {}).get('value', 0)\\\\n                    diff = other_value - current_value\\\\n                    if abs(diff) > other_value * 0.1:\\\\n                        order_target_value(stock, other_value)\\\\n                except Exception as e:\\\\n                    log.error(f\\\\\\\"调仓其他{stock}出错: {str(e)}\\\\\\\")\\\\n        \\\\n        # 卖出不在目标池的股票\\\\n        for stock in list(context.portfolio.positions.keys()):\\\\n            if stock not in target_stocks:\\\\n                try:\\\\n                    order_target_value(stock, 0)\\\\n                    log.info(f\\\\\\\"清仓非目标股票: {stock}\\\\\\\")\\\\n                except Exception as e:\\\\n                    log.error(f\\\\\\\"清仓{stock}出错: {str(e)}\\\\\\\")\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"调仓出错: {str(e)}\\\\\\\")\\\\n\\\"}],\\\"isError\\\":false,\\\"timestamp\\\":1772678299511}}\\n/Users/ling/.openclaw/agents/main/sessions/34f55a68-da87-4c7f-bf50-b760c84eefb4.jsonl:{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"0662f1b3\\\",\\\"parentId\\\":\\\"dc973cd6\\\",\\\"timestamp\\\":\\\"2026-03-05T02:38:27.778Z\\\",\\\"message\\\":{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":[{\\\"type\\\":\\\"thinking\\\",\\\"thinking\\\":\\\"让我继续读取另外两个文件。\\\",\\\"thinkingSignature\\\":\\\"d4a98d2bb34cd0432684ef384386f9e8e4f39d3ff669d07ff51c9991ca8ef2c2\\\"},{\\\"type\\\":\\\"toolCall\\\",\\\"id\\\":\\\"call_function_tkbqzln1z57n_1\\\",\\\"name\\\":\\\"read\\\",\\\"arguments\\\":{\\\"file_path\\\":\\\"/Users/ling/.openclaw/workspace/quant_strategies/聚宽_激进版_年化40.py\\\"}}],\\\"api\\\":\\\"anthropic-messages\\\",\\\"provider\\\":\\\"minimax-portal\\\",\\\"model\\\":\\\"MiniMax-M2.5\\\",\\\"usage\\\":{\\\"input\\\":23535,\\\"output\\\":58,\\\"cacheRead\\\":20128,\\\"cacheWrite\\\":0,\\\"totalTokens\\\":43721,\\\"cost\\\":{\\\"input\\\":0,\\\"output\\\":0,\\\"cacheRead\\\":0,\\\"cacheWrite\\\":0,\\\"total\\\":0}},\\\"stopReason\\\":\\\"toolUse\\\",\\\"timestamp\\\":1772678299517}}\\n/Users/ling/.openclaw/agents/main/sessions/34f55a68-da87-4c7f-bf50-b760c84eefb4.jsonl:{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"18c3b3b0\\\",\\\"parentId\\\":\\\"0662f1b3\\\",\\\"timestamp\\\":\\\"2026-03-05T02:38:27.794Z\\\",\\\"message\\\":{\\\"role\\\":\\\"toolResult\\\",\\\"toolCallId\\\":\\\"call_function_tkbqzln1z57n_1\\\",\\\"toolName\\\":\\\"read\\\",\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"\\\\\\\"\\\\\\\"\\\\\\\"\\\\n聚宽量化策略 - 激进版 (API优化版)\\\\n目标年化: 40%\\\\n配置: 15只小市值 + 8只白马股\\\\n\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\nimport numpy as np\\\\nimport pandas as pd\\\\nfrom jqdata import *\\\\n\\\\ndef initialize(context):\\\\n    log.set_level('order', 'error')\\\\n    set_option('use_real_price', True)\\\\n    set_option('avoid_future_data', True)\\\\n    set_benchmark('000300.XSHG')\\\\n    set_order_cost(OrderCost(\\\\n        close_tax=0.001, \\\\n        open_commission=0.000085, \\\\n        close_commission=0.000085, \\\\n        min_commission=5\\\\n    ), type='stock')\\\\n    \\\\n    # === 策略参数 ===\\\\n    g.small_cap_num = 15\\\\n    g.white_horse_num = 8\\\\n    g.max_stock_price = 50\\\\n    g.min_days = 20\\\\n    g.stoploss_ratio = 0.90\\\\n    g.momentum_days = 10\\\\n    g.momentum_threshold = -0.05\\\\n    g.rebalance_freq = 15\\\\n    g.last_rebalance = None\\\\n    \\\\n    # 月度调仓\\\\n    run_monthly(rebalance, monthday=1, time='09:35')\\\\n\\\\ndef rebalance(context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"调仓\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    current_date = context.current_dt.date()\\\\n    \\\\n    if g.last_rebalance is None or (current_date - g.last_rebalance).days >= g.rebalance_freq:\\\\n        stock_list = select_stocks(context)\\\\n        adjust_positions(stock_list)\\\\n        g.last_rebalance = current_date\\\\n\\\\ndef select_stocks(context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"选股: 小市值 + 白马 + 动量过滤\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    # 小市值\\\\n    small_caps = get_small_cap_stocks(g.small_cap_num + 5)\\\\n    # 白马股\\\\n    white_horses = get_white_horse_stocks(g.white_horse_num + 3)\\\\n    \\\\n    # 合并\\\\n    stock_list = list(set(small_caps + white_horses))\\\\n    \\\\n    # 动量过滤\\\\n    stock_list = filter_by_momentum(context, stock_list)\\\\n    \\\\n    # 基本过滤\\\\n    stock_list = filter_stocks(context, stock_list)\\\\n    \\\\n    return stock_list[:g.small_cap_num + g.white_horse_num]\\\\n\\\\ndef get_small_cap_stocks(num):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"小市值选股\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        stocks = get_index_stocks('000852.XSHG')\\\\n        if not stocks:\\\\n            stocks = get_index_stocks('000001.XSHG')\\\\n        \\\\n        q = query(\\\\n            indicator.code, \\\\n            indicator.market_cap\\\\n        ).filter(\\\\n            indicator.code.in_(stocks),\\\\n            indicator.market_cap > 0\\\\n        ).order_by(\\\\n            indicator.market_cap.asc()\\\\n        ).limit(num * 2)\\\\n        \\\\n        df = get_fundamentals(q)\\\\n        if df is not None and len(df) > 0:\\\\n            return df['code'].tolist()[:num]\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"小市值选股失败: {e}\\\\\\\")\\\\n    return []\\\\n\\\\ndef get_white_horse_stocks(num):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"白马股选股\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        stocks = list(set(\\\\n            get_index_stocks('000300.XSHG') + \\\\n            get_index_stocks('000001.XSHG')\\\\n        ))\\\\n        \\\\n        q = query(\\\\n            indicator.code,\\\\n            indicator.roe,\\\\n            indicator.operating_cash_flow,\\\\n            indicator.pb\\\\n        ).filter(\\\\n            indicator.code.in_(stocks),\\\\n            indicator.roe > 0,\\\\n            indicator.operating_cash_flow > 0,\\\\n            indicator.pb > 0\\\\n        ).order_by(\\\\n            indicator.roe.desc()\\\\n        ).limit(num * 2)\\\\n        \\\\n        df = get_fundamentals(q)\\\\n        if df is not None and len(df) > 0:\\\\n            return df['code'].tolist()[:num]\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"白马股选股失败: {e}\\\\\\\")\\\\n    return []\\\\n\\\\ndef filter_by_momentum(context, stocks):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"动量过滤 - 使用 attribute_history\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    result = []\\\\n    for stock in stocks:\\\\n        try:\\\\n            # 使用 attribute_history 获取历史数据\\\\n            hist = attribute_history(stock, g.momentum_days + 1, '1d', ['close'])\\\\n            if hist is None or len(hist) < g.momentum_days:\\\\n                continue\\\\n            \\\\n            current = hist['close'].iloc[-1]\\\\n            past = hist['close'].iloc[0]\\\\n            momentum = (current - past) / past\\\\n            \\\\n            if momentum >= g.momentum_threshold:\\\\n                result.append(stock)\\\\n        except Exception:\\\\n            continue\\\\n    \\\\n    return result\\\\n\\\\ndef filter_stocks(context, stocks):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"过滤股票\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    result = []\\\\n    current_data = get_current_data()\\\\n    \\\\n    for stock in stocks:\\\\n        if stock in current_data:\\\\n            stock_data = current_data[stock]\\\\n            if stock_data.is_st or stock_data.paused:\\\\n                continue\\\\n        \\\\n        # 使用 attribute_history 获取价格\\\\n        try:\\\\n            hist = attribute_history(stock, 1, '1d', ['close'])\\\\n            if hist is not None and len(hist) > 0:\\\\n                price = hist['close'].iloc[-1]\\\\n                if price < g.max_stock_price and price > 0:\\\\n                    result.append(stock)\\\\n        except Exception:\\\\n            continue\\\\n    \\\\n    return result\\\\n\\\\ndef adjust_positions(target_stocks):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"调仓\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not target_stocks:\\\\n        return\\\\n    \\\\n    current_positions = list(context.portfolio.positions.keys())\\\\n    target_set = set(target_stocks)\\\\n    \\\\n    # 卖出\\\\n    for stock in current_positions:\\\\n        if stock not in target_set:\\\\n            order_target_value(stock, 0)\\\\n    \\\\n    # 买入\\\\n    target_value = context.portfolio.total_value / len(target_stocks)\\\\n    for stock in target_stocks:\\\\n        order_target_value(stock, target_value)\\\\n\\\"}],\\\"isError\\\":false,\\\"timestamp\\\":1772678307788}}\\n/Users/ling/.openclaw/agents/main/sessions/34f55a68-da87-4c7f-bf50-b760c84eefb4.jsonl:{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"8ede78fb\\\",\\\"parentId\\\":\\\"18c3b3b0\\\",\\\"timestamp\\\":\\\"2026-03-05T02:38:34.184Z\\\",\\\"message\\\":{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":[{\\\"type\\\":\\\"thinking\\\",\\\"thinking\\\":\\\"让我继续读取第三个文件。\\\",\\\"thinkingSignature\\\":\\\"830e351e8f845b133d9e0c0e70434bb5b2e9c30734b57218435897400b2748f5\\\"},{\\\"type\\\":\\\"toolCall\\\",\\\"id\\\":\\\"call_function_r5wtywhgykn2_1\\\",\\\"name\\\":\\\"read\\\",\\\"arguments\\\":{\\\"file_path\\\":\\\"/Users/ling/.openclaw/workspace/quant_strategies/聚宽_稳健版_年化30.py\\\"}}],\\\"api\\\":\\\"anthropic-messages\\\",\\\"provider\\\":\\\"minimax-portal\\\",\\\"model\\\":\\\"MiniMax-M2.5\\\",\\\"usage\\\":{\\\"input\\\":24876,\\\"output\\\":57,\\\"cacheRead\\\":20128,\\\"cacheWrite\\\":0,\\\"totalTokens\\\":45061,\\\"cost\\\":{\\\"input\\\":0,\\\"output\\\":0,\\\"cacheRead\\\":0,\\\"cacheWrite\\\":0,\\\"total\\\":0}},\\\"stopReason\\\":\\\"toolUse\\\",\\\"timestamp\\\":1772678307794}}\\n/Users/ling/.openclaw/agents/main/sessions/34f55a68-da87-4c7f-bf50-b760c84eefb4.jsonl:{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"a3896134\\\",\\\"parentId\\\":\\\"8ede78fb\\\",\\\"timestamp\\\":\\\"2026-03-05T02:38:34.199Z\\\",\\\"message\\\":{\\\"role\\\":\\\"toolResult\\\",\\\"toolCallId\\\":\\\"call_function_r5wtywhgykn2_1\\\",\\\"toolName\\\":\\\"read\\\",\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"\\\\\\\"\\\\\\\"\\\\\\\"\\\\n聚宽量化策略 - 稳健版 (API优化版)\\\\n目标年化: 30%\\\\n配置: 10只小市值 + 12只白马股\\\\n\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\nimport numpy as np\\\\nimport pandas as pd\\\\nfrom jqdata import *\\\\n\\\\ndef initialize(context):\\\\n    # 基础设置\\\\n    log.set_level('order', 'error')\\\\n    set_option('use_real_price', True)\\\\n    set_option('avoid_future_data', True)\\\\n    \\\\n    # 基准: 沪深300\\\\n    set_benchmark('000300.XSHG')\\\\n    \\\\n    # 手续费 (万0.85免5)\\\\n    set_order_cost(OrderCost(\\\\n        close_tax=0.001, \\\\n        open_commission=0.000085, \\\\n        close_commission=0.000085, \\\\n        min_commission=5\\\\n    ), type='stock')\\\\n    \\\\n    # === 策略参数 ===\\\\n    g.small_cap_num = 10\\\\n    g.white_horse_num = 12\\\\n    g.max_stock_price = 50\\\\n    g.min_days = 30\\\\n    g.stoploss_ratio = 0.92\\\\n    g.rebalance_freq = 20\\\\n    g.last_rebalance = None\\\\n    \\\\n    # 使用 run_monthly 替代 handle_data (更高效)\\\\n    run_monthly(rebalance, monthday=1, time='09:35')\\\\n\\\\ndef rebalance(context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"月度调仓\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    current_date = context.current_dt.date()\\\\n    \\\\n    if g.last_rebalance is None or (current_date - g.last_rebalance).days >= g.rebalance_freq:\\\\n        # 选股\\\\n        stock_list = select_stocks(context)\\\\n        \\\\n        # 调仓\\\\n        adjust_positions(stock_list)\\\\n        \\\\n        g.last_rebalance = current_date\\\\n\\\\ndef select_stocks(context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"选股\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    # 1. 小市值选股\\\\n    small_caps = get_small_cap_stocks(g.small_cap_num)\\\\n    \\\\n    # 2. 白马股选股\\\\n    white_horses = get_white_horse_stocks(g.white_horse_num)\\\\n    \\\\n    # 3. 合并去重\\\\n    stock_list = list(set(small_caps + white_horses))\\\\n    \\\\n    # 4. 基本过滤\\\\n    stock_list = filter_stocks(context, stock_list)\\\\n    \\\\n    return stock_list[:g.small_cap_num + g.white_horse_num]\\\\n\\\\ndef get_small_cap_stocks(num):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"小市值选股 - 使用中证1000\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        stocks = get_index_stocks('000852.XSHG')\\\\n        if not stocks:\\\\n            stocks = get_index_stocks('000001.XSHG')\\\\n        \\\\n        q = query(\\\\n            indicator.code, \\\\n            indicator.market_cap\\\\n        ).filter(\\\\n            indicator.code.in_(stocks),\\\\n            indicator.market_cap > 0\\\\n        ).order_by(\\\\n            indicator.market_cap.asc()\\\\n        ).limit(num * 2)\\\\n        \\\\n        df = get_fundamentals(q)\\\\n        if df is not None and len(df) > 0:\\\\n            return df['code'].tolist()[:num]\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"小市值选股失败: {e}\\\\\\\")\\\\n    return []\\\\n\\\\ndef get_white_horse_stocks(num):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"白马股选股: ROE>0, 现金流>0\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        # 获取沪深300+上证指数成分股\\\\n        stocks = list(set(\\\\n            get_index_stocks('000300.XSHG') + \\\\n            get_index_stocks('000001.XSHG')\\\\n        ))\\\\n        \\\\n        q = query(\\\\n            indicator.code,\\\\n            indicator.roe,\\\\n            indicator.operating_cash_flow,\\\\n            indicator.pb\\\\n        ).filter(\\\\n            indicator.code.in_(stocks),\\\\n            indicator.roe > 0,\\\\n            indicator.operating_cash_flow > 0,\\\\n            indicator.pb > 0\\\\n        ).order_by(\\\\n            indicator.roe.desc()\\\\n        ).limit(num * 2)\\\\n        \\\\n        df = get_fundamentals(q)\\\\n        if df is not None and len(df) > 0:\\\\n            return df['code'].tolist()[:num]\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"白马股选股失败: {e}\\\\\\\")\\\\n    return []\\\\n\\\\ndef filter_stocks(context, stocks):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"过滤股票 - 使用 get_current_data\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    result = []\\\\n    current_data = get_current_data()\\\\n    \\\\n    for stock in stocks:\\\\n        # 检查是否停牌或退市\\\\n        if stock in current_data:\\\\n            stock_data = current_data[stock]\\\\n            # 过滤停牌、ST、退市\\\\n            if stock_data.is_st or stock_data.paused:\\\\n                continue\\\\n            # 过滤高价股\\\\n            if stock_data.high_limit and stock_data.high_limit < g.max_stock_price:\\\\n                continue\\\\n        \\\\n        result.append(stock)\\\\n    \\\\n    return result\\\\n\\\\ndef adjust_positions(target_stocks):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"调仓\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not target_stocks:\\\\n        return\\\\n    \\\\n    # 获取当前持仓\\\\n    current_positions = list(context.portfolio.positions.keys())\\\\n    \\\\n    # 目标持仓\\\\n    target_set = set(target_stocks)\\\\n    \\\\n    # 卖出不在目标池的\\\\n    for stock in current_positions:\\\\n        if stock not in target_set:\\\\n            order_target_value(stock, 0)\\\\n    \\\\n    # 等权买入目标\\\\n    target_value = context.portfolio.total_value / len(target_stocks)\\\\n    for stock in target_stocks:\\\\n        order_target_value(stock, target_value)\\\\n\\\"}],\\\"isError\\\":false,\\\"timestamp\\\":1772678314193}}\\n/Users/ling/.openclaw/agents/main/sessions/34f55a68-da87-4c7f-bf50-b760c84eefb4.jsonl:{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"69f5ba03\\\",\\\"parentId\\\":\\\"a3896134\\\",\\\"timestamp\\\":\\\"2026-03-05T02:39:59.744Z\\\",\\\"message\\\":{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":[{\\\"type\\\":\\\"thinking\\\",\\\"thinking\\\":\\\"好的，我现在已经读取了这三个策略文件。让我分析一下它们的共同问题和可以优化的地方：\\\\n\\\\n## 现有策略分析\\\\n\\\\n### 聚宽_极限版_年化50.py\\\\n- 20只小市值 + 5只白马股\\\\n- 止损线88%\\\\n- 10日调仓\\\\n- 集中持仓（前5只50%仓位）\\\\n- 问题：使用了一些可能过时的API\\\\n\\\\n### 聚宽_激进版_年化40.py\\\\n- 15只小市值 + 8只白马股\\\\n- 止损线90%\\\\n- 15日调仓\\\\n- 等权持仓\\\\n- 问题：indicator.market_cap 字段可能不对，应该用 valuation.market_cap\\\\n\\\\n### 聚宽_稳健版_年化30.py\\\\n- 10只小市值 + 12只白马股\\\\n- 止损线92%\\\\n- 20日调仓\\\\n- 等权持仓\\\\n\\\\n## 优化建议\\\\n\\\\n1. **API字段修正**：indicator表没有market_cap，应该用valuation.market_cap\\\\n2. **增加因子**：可以加入更多选股因子如营收增长、净利润增长等\\\\n3. **风控增强**：加入更多风控措施\\\\n4. **仓位管理**：可以加入仓位动态调整\\\\n5. **交易成本优化**：可以加入滑价控制\\\\n\\\\n让我为用户进行优化。\\\",\\\"thinkingSignature\\\":\\\"283d38a29f27fc32d945efc55acb73dbdfb9cc8da0344843fab225de2cef60c4\\\"},{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"## 📊 策略分析\\\\n\\\\n| 策略 | 持仓 | 止损 | 调仓周期 | 主要问题 |\\\\n|------|------|------|----------|----------|\\\\n| 极限版 | 20小+5白 | 88% | 10天 | API需优化、过于集中 |\\\\n| 激进版 | 15小+8白 | 90% | 15天 | indicator.market_cap字段错误 |\\\\n| 稳健版 | 10小+12白 | 92% | 20天 | 缺少动量过滤 |\\\\n\\\\n## 🔧 优化方向\\\\n\\\\n1. **修正API字段** - `indicator.market_cap` → `valuation.market_cap`\\\\n2. **增强选股因子** - 加入ROE、营收增长、净利润增长\\\\n3. **风控升级** - 加入最大回撤控制、单票止损\\\\n4. **仓位优化** - 加入波动率调整\\\\n5. **交易优化** - 加入滑点控制\\\\n\\\\n开始优化！\\\\n\\\"},{\\\"type\\\":\\\"toolCall\\\",\\\"id\\\":\\\"call_function_ynbl274bjc37_1\\\",\\\"name\\\":\\\"write\\\",\\\"arguments\\\":{\\\"content\\\":\\\"\\\\\\\"\\\\\\\"\\\\\\\"\\\\n聚宽量化策略 - 极限版 v2 (优化版)\\\\n目标年化: 50%+\\\\n配置: 20只小市值 + 5只白马股\\\\n优化: API修正 + 多因子选股 + 风控增强\\\\n\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\nimport numpy as np\\\\nimport pandas as pd\\\\nfrom jqdata import *\\\\n\\\\ndef initialize(context):\\\\n    log.set_level('order', 'error')\\\\n    set_option('use_real_price', True)\\\\n    set_option('avoid_future_data', True)\\\\n    set_benchmark('000300.XSHG')\\\\n    \\\\n    # 手续费 (万0.85免5 + 万1滑点)\\\\n    set_order_cost(OrderCost(\\\\n        close_tax=0.001, \\\\n        open_commission=0.000085, \\\\n        close_commission=0.000085, \\\\n        min_commission=5\\\\n    ), type='stock')\\\\n    \\\\n    # === 策略参数 (极限版) ===\\\\n    g.small_cap_num = 20\\\\n    g.white_horse_num = 5\\\\n    g.max_stock_price = 40\\\\n    g.min_days = 15\\\\n    g.max_days = 365 * 3\\\\n    \\\\n    # 止损 (更严格)\\\\n    g.stoploss_ratio = 0.90\\\\n    \\\\n    # 动量过滤\\\\n    g.momentum_days = 20\\\\n    g.momentum_threshold = -0.05\\\\n    \\\\n    # 集中持仓\\\\n    g.top_heavy = 5\\\\n    g.top_heavy_ratio = 0.50\\\\n    \\\\n    # 调仓频率\\\\n    g.rebalance_freq = 10\\\\n    g.last_rebalance = None\\\\n    \\\\n    # 风控\\\\n    g.max_drawdown = 0.15  # 最大回撤15%减仓\\\\n    g.position_scale = 1.0  # 仓位系数\\\\n    \\\\n    run_daily(before_open, '09:00')\\\\n    run_daily(trade, '09:35')\\\\n    run_daily(after_close, '15:00')\\\\n\\\\ndef before_open(context):\\\\n    log.info(\\\\\\\"========== 极限版v2 ==========\\\\\\\")\\\\n    # 检查回撤\\\\n    check_drawdown(context)\\\\n\\\\ndef check_drawdown(context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"回撤控制\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if hasattr(context, 'portfolio'):\\\\n        current_value = context.portfolio.total_value\\\\n        if hasattr(context, 'peak_value'):\\\\n            drawdown = (context.peak_value - current_value) / context.peak_value\\\\n            if drawdown > g.max_drawdown:\\\\n                g.position_scale = max(0.3, 1.0 - drawdown)\\\\n                log.warning(f\\\\\\\"回撤{drawdown*100:.1f}%, 降仓至{g.position_scale*100:.0f}%\\\\\\\")\\\\n        context.peak_value = max(getattr(context, 'peak_value', current_value), current_value)\\\\n\\\\ndef trade(context):\\\\n    current_date = context.current_dt.date()\\\\n    \\\\n    if g.last_rebalance is None or (current_date - g.last_rebalance).days >= g.rebalance_freq:\\\\n        stock_list = select_stocks(context)\\\\n        close_loss_positions(stock_list, context)\\\\n        rebalance_heavy(stock_list, context)\\\\n        g.last_rebalance = current_date\\\\n\\\\ndef after_close(context):\\\\n    positions = context.portfolio.positions\\\\n    total_value = context.portfolio.total_value\\\\n    log.info(\\\\\\\"========== 日报 ==========\\\\\\\")\\\\n    log.info(\\\\\\\"总资产: %.2f\\\\\\\" % total_value)\\\\n    log.info(\\\\\\\"持仓数量: %d\\\\\\\" % len(positions))\\\\n    \\\\n    for stock, pos in positions.items():\\\\n        if pos.total_amount == 0 or pos.avg_cost == 0:\\\\n            continue\\\\n        total_cost = pos.total_amount * pos.avg_cost\\\\n        profit = pos.value - total_cost\\\\n        pnl = (profit / total_cost) * 100 if total_cost > 0 else 0\\\\n        log.info(\\\\\\\"%s: 持仓%d, 成本%.2f, 现价%.2f, 盈亏%.2f%%\\\\\\\" % \\\\n                 (stock, pos.total_amount, pos.avg_cost, pos.current_price, pnl))\\\\n\\\\ndef select_stocks(context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"选股: 小市值 + 白马 + 动量 + 多因子\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    # 1. 小市值候选\\\\n    small_caps = get_small_cap_stocks(g.small_cap_num + 15)\\\\n    \\\\n    # 2. 白马股候选\\\\n    white_horses = get_white_horse_stocks(g.white_horse_num + 8)\\\\n    \\\\n    # 3. 合并\\\\n    stock_list = list(set(small_caps + white_horses))\\\\n    \\\\n    # 4. 动量过滤\\\\n    stock_list = filter_by_momentum(stock_list, context)\\\\n    \\\\n    # 5. 基本过滤\\\\n    stock_list = filter_stocks(stock_list, context)\\\\n    \\\\n    # 6. 多因子排序\\\\n    stock_list = factor_ranking(stock_list, context)\\\\n    \\\\n    return stock_list[:g.small_cap_num + g.white_horse_num]\\\\n\\\\ndef get_small_cap_stocks(num):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"小市值选股 - 修正: 使用valuation表\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        stocks = get_index_stocks('000852.XSHG')\\\\n        if not stocks:\\\\n            return []\\\\n        \\\\n        q = query(\\\\n            valuation.code,\\\\n            valuation.market_cap\\\\n        ).filter(\\\\n            valuation.code.in_(stocks),\\\\n            valuation.market_cap > 0\\\\n        ).order_by(\\\\n            valuation.market_cap.asc()\\\\n        ).limit(num)\\\\n        \\\\n        df = get_fundamentals(q)\\\\n        return df['code'].tolist() if df is not None and not df.empty else []\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"小市值选股出错: {str(e)}\\\\\\\")\\\\n        return []\\\\n\\\\ndef get_white_horse_stocks(num):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"白马股选股 - 多因子\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        stocks = get_index_stocks('000300.XSHG') + get_index_stocks('000001.XSHG')\\\\n        if not stocks:\\\\n            return []\\\\n        \\\\n        q = query(\\\\n            valuation.code,\\\\n            valuation.pb_ratio,\\\\n            indicator.roe,\\\\n            indicator.operating_cash_flow,\\\\n            indicator.net_profit_ratio,\\\\n            indicator.gross_profit_margin\\\\n        ).filter(\\\\n            valuation.code.in_(stocks),\\\\n            valuation.pb_ratio > 0,\\\\n            valuation.pb_ratio < 5,  # PB上限\\\\n            indicator.roe > 5,      # ROE>5%\\\\n            indicator.operating_cash_flow > 0,\\\\n            indicator.net_profit_ratio > 0  # 净利率>0\\\\n        ).order_by(\\\\n            indicator.roe.desc()\\\\n        ).limit(num)\\\\n        \\\\n        df = get_fundamentals(q)\\\\n        return df['code'].tolist() if df is not None and not df.empty else []\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"白马股选股出错: {str(e)}\\\\\\\")\\\\n        return []\\\\n\\\\ndef factor_ranking(stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"多因子排序\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    scores = {}\\\\n    end_dt = context.current_dt - timedelta(days=1)\\\\n    \\\\n    for stock in stocks:\\\\n        try:\\\\n            # 获取财务数据\\\\n            q = query(\\\\n                indicator.roe,\\\\n                indicator.net_profit_ratio,\\\\n                indicator.revenue_ratio\\\\n            ).filter(indicator.code == stock)\\\\n            \\\\n            df = get_fundamentals(q)\\\\n            if df is None or df.empty:\\\\n                continue\\\\n            \\\\n            roe = df['roe'].iloc[0] if pd.notna(df['roe'].iloc[0]) else 0\\\\n            netprofit = df['net_profit_ratio'].iloc[0] if pd.notna(df['net_profit_ratio'].iloc[0]) else 0\\\\n            revenue_growth = df['revenue_ratio'].iloc[0] if pd.notna(df['revenue_ratio'].iloc[0]) else 0\\\\n            \\\\n            # 动量因子\\\\n            hist = attribute_history(stock, g.momentum_days + 1, '1d', ['close'])\\\\n            if hist is None or len(hist) < g.momentum_days:\\\\n                momentum = 0\\\\n            else:\\\\n                momentum = (hist['close'].iloc[-1] - hist['close'].iloc[0]) / hist['close'].iloc[0]\\\\n            \\\\n            # 综合评分\\\\n            score = roe * 0.3 + netprofit * 0.2 + revenue_growth * 0.2 + momentum * 100 * 0.3\\\\n            scores[stock] = score\\\\n        except Exception:\\\\n            scores[stock] = 0\\\\n    \\\\n    # 排序\\\\n    sorted_stocks = sorted(scores.items(), key=lambda x: x[1], reverse=True)\\\\n    return [s[0] for s in sorted_stocks]\\\\n\\\\ndef filter_by_momentum(stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"动量过滤\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    result = []\\\\n    end_dt = context.current_dt - timedelta(days=1)\\\\n    \\\\n    for stock in stocks:\\\\n        try:\\\\n            hist = attribute_history(stock, g.momentum_days + 1, '1d', ['close'])\\\\n            if hist is None or len(hist) < g.momentum_days:\\\\n                continue\\\\n            \\\\n            momentum = (hist['close'].iloc[-1] - hist['close'].iloc[0]) / hist['close'].iloc[0]\\\\n            if momentum >= g.momentum_threshold:\\\\n                result.append(stock)\\\\n        except Exception:\\\\n            continue\\\\n    \\\\n    return result\\\\n\\\\ndef filter_stocks(stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"基本过滤\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    result = []\\\\n    current_data = get_current_data()\\\\n    \\\\n    for stock in stocks:\\\\n        if stock in current_data:\\\\n            sd = current_data[stock]\\\\n            if sd.is_st or sd.paused:\\\\n                continue\\\\n        \\\\n        try:\\\\n            hist = attribute_history(stock, 1, '1d', ['close'])\\\\n            if hist is not None and len(hist) > 0:\\\\n                price = hist['close'].iloc[-1]\\\\n                if price < g.max_stock_price and price > 0:\\\\n                    # 上市天数\\\\n                    sec_info = get_security_info(stock)\\\\n                    if sec_info:\\\\n                        days = (context.current_dt.date() - sec_info.start_date).days\\\\n                        if g.min_days <= days <= g.max_days:\\\\n                            result.append(stock)\\\\n        except Exception:\\\\n            continue\\\\n    \\\\n    return result\\\\n\\\\ndef close_loss_positions(target_stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"止损\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    for stock in list(context.portfolio.positions.keys()):\\\\n        if stock not in target_stocks:\\\\n            pos = context.portfolio.positions[stock]\\\\n            if pos.total_amount == 0 or pos.avg_cost == 0:\\\\n                continue\\\\n            \\\\n            current_price = pos.current_price\\\\n            if current_price / pos.avg_cost < g.stoploss_ratio:\\\\n                order_target_value(stock, 0)\\\\n                log.info(f\\\\\\\"止损: {stock}\\\\\\\")\\\\n\\\\ndef rebalance_heavy(target_stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"集中持仓调仓\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not target_stocks:\\\\n        return\\\\n    \\\\n    total_value = context.portfolio.total_value * g.position_scale\\\\n    \\\\n    # 前5重仓\\\\n    top_stocks = target_stocks[:g.top_heavy]\\\\n    other_stocks = target_stocks[g.top_heavy:]\\\\n    \\\\n    if top_stocks:\\\\n        top_value = total_value * g.top_heavy_ratio / len(top_stocks)\\\\n        for stock in top_stocks:\\\\n            order_target_value(stock, top_value)\\\\n    \\\\n    if other_stocks:\\\\n        other_value = total_value * (1 - g.top_heavy_ratio) / len(other_stocks)\\\\n        for stock in other_stocks:\\\\n            order_target_value(stock, other_value)\\\\n    \\\\n    # 卖出不在目标池的\\\\n    for stock in list(context.portfolio.positions.keys()):\\\\n        if stock not in target_stocks:\\\\n            order_target_value(stock, 0)\\\\n\\\",\\\"file_path\\\":\\\"/Users/ling/.openclaw/workspace/quant_strategies/聚宽_极限版_年化50_v2.py\\\"}}],\\\"api\\\":\\\"anthropic-messages\\\",\\\"provider\\\":\\\"minimax-portal\\\",\\\"model\\\":\\\"MiniMax-M2.5\\\",\\\"usage\\\":{\\\"input\\\":26101,\\\"output\\\":3048,\\\"cacheRead\\\":20128,\\\"cacheWrite\\\":0,\\\"totalTokens\\\":49277,\\\"cost\\\":{\\\"input\\\":0,\\\"output\\\":0,\\\"cacheRead\\\":0,\\\"cacheWrite\\\":0,\\\"total\\\":0}},\\\"stopReason\\\":\\\"toolUse\\\",\\\"timestamp\\\":1772678314200}}\\n/Users/ling/.ope