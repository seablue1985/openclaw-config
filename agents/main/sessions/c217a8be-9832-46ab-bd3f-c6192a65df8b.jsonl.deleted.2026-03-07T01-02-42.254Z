"小市值选股失败: {e}\\\\\\\")\\\\n        return []\\\\n\\\\ndef get_white_horse_stocks(num):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"白马股选股 - 稳健版(更严格筛选)\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        stocks = get_index_stocks('000300.XSHG') + get_index_stocks('000001.XSHG')\\\\n        if not stocks:\\\\n            return []\\\\n        \\\\n        q = query(\\\\n            valuation.code,\\\\n            valuation.pb_ratio,\\\\n            indicator.roe,\\\\n            indicator.operating_cash_flow,\\\\n            indicator.net_profit_ratio,\\\\n            indicator.roe_avg\\\\n        ).filter(\\\\n            valuation.code.in_(stocks),\\\\n            valuation.pb_ratio > 0,\\\\n            valuation.pb_ratio < 4,  # 更严格的PB\\\\n            indicator.roe > 8,       # 更严格的ROE>8%\\\\n            indicator.operating_cash_flow > 0,\\\\n            indicator.net_profit_ratio > 5,  # 净利率>5%\\\\n            indicator.roe_avg > 8     # 滚动ROE>8%\\\\n        ).order_by(\\\\n            indicator.roe.desc()\\\\n        ).limit(num)\\\\n        \\\\n        df = get_fundamentals(q)\\\\n        return df['code'].tolist() if df is not None and not df.empty else []\\\\n    except Exception as e:\\\\n        log.error(f\\\\\\\"白马股选股失败: {e}\\\\\\\")\\\\n        return []\\\\n\\\\ndef factor_ranking(stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"多因子排序\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    scores = {}\\\\n    \\\\n    for stock in stocks:\\\\n        try:\\\\n            # 财务因子\\\\n            q = query(\\\\n                indicator.roe,\\\\n                indicator.net_profit_ratio,\\\\n                indicator.roe_avg\\\\n            ).filter(indicator.code == stock)\\\\n            \\\\n            df = get_fundamentals(q)\\\\n            if df is None or df.empty:\\\\n                continue\\\\n            \\\\n            roe = df['roe'].iloc[0] if pd.notna(df['roe'].iloc[0]) else 0\\\\n            roe_avg = df['roe_avg'].iloc[0] if pd.notna(df['roe_avg'].iloc[0]) else 0\\\\n            netprofit = df['net_profit_ratio'].iloc[0] if pd.notna(df['net_profit_ratio'].iloc[0]) else 0\\\\n            \\\\n            # 动量因子 (更保守)\\\\n            hist = attribute_history(stock, g.momentum_days + 1, '1d', ['close'])\\\\n            if hist is None or len(hist) < g.momentum_days:\\\\n                momentum = 0\\\\n            else:\\\\n                momentum = (hist['close'].iloc[-1] - hist['close'].iloc[0]) / hist['close'].iloc[0]\\\\n            \\\\n            # 综合评分 (更注重基本面)\\\\n            score = roe * 0.25 + roe_avg * 0.25 + netprofit * 0.2 + momentum * 100 * 0.3\\\\n            scores[stock] = score\\\\n        except Exception:\\\\n            scores[stock] = 0\\\\n    \\\\n    sorted_stocks = sorted(scores.items(), key=lambda x: x[1], reverse=True)\\\\n    return [s[0] for s in sorted_stocks]\\\\n\\\\ndef filter_by_momentum(stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"动量过滤 (更严格)\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    result = []\\\\n    for stock in stocks:\\\\n        try:\\\\n            hist = attribute_history(stock, g.momentum_days + 1, '1d', ['close'])\\\\n            if hist is None or len(hist) < g.momentum_days:\\\\n                continue\\\\n            \\\\n            momentum = (hist['close'].iloc[-1] - hist['close'].iloc[0]) / hist['close'].iloc[0]\\\\n            # 稳健版更严格\\\\n            if momentum >= g.momentum_threshold:\\\\n                result.append(stock)\\\\n        except Exception:\\\\n            continue\\\\n    \\\\n    return result\\\\n\\\\ndef filter_stocks(stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"基本过滤\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not stocks:\\\\n        return []\\\\n    \\\\n    result = []\\\\n    current_data = get_current_data()\\\\n    \\\\n    for stock in stocks:\\\\n        if stock in current_data:\\\\n            sd = current_data[stock]\\\\n            if sd.is_st or sd.paused:\\\\n                continue\\\\n        \\\\n        try:\\\\n            hist = attribute_history(stock, 1, '1d', ['close'])\\\\n            if hist is not None and len(hist) > 0:\\\\n                price = hist['close'].iloc[-1]\\\\n                if price < g.max_stock_price and price > 0:\\\\n                    sec_info = get_security_info(stock)\\\\n                    if sec_info:\\\\n                        days = (context.current_dt.date() - sec_info.start_date).days\\\\n                        if g.min_days <= days <= g.max_days:\\\\n                            result.append(stock)\\\\n        except Exception:\\\\n            continue\\\\n    \\\\n    return result\\\\n\\\\ndef close_loss_positions(target_stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"止损\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    for stock in list(context.portfolio.positions.keys()):\\\\n        if stock not in target_stocks:\\\\n            pos = context.portfolio.positions[stock]\\\\n            if pos.total_amount == 0 or pos.avg_cost == 0:\\\\n                continue\\\\n            \\\\n            if pos.current_price / pos.avg_cost < g.stoploss_ratio:\\\\n                order_target_value(stock, 0)\\\\n                log.info(f\\\\\\\"止损: {stock}\\\\\\\")\\\\n\\\\ndef adjust_positions(target_stocks, context):\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"调仓 - 等权\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not target_stocks:\\\\n        return\\\\n    \\\\n    total_value = context.portfolio.total_value * g.position_scale\\\\n    target_value = total_value / len(target_stocks)\\\\n    \\\\n    # 卖出\\\\n    for stock in list(context.portfolio.positions.keys()):\\\\n        if stock not in target_stocks:\\\\n            order_target_value(stock, 0)\\\\n    \\\\n    # 买入\\\\n    for stock in target_stocks:\\\\n        order_target_value(stock, target_value)\\\\n\\\",\\\"file_path\\\":\\\"/Users/ling/.openclaw/workspace/quant_strategies/聚宽_稳健版_年化30_v2.py\\\"}}],\\\"api\\\":\\\"anthropic-messages\\\",\\\"provider\\\":\\\"minimax-portal\\\",\\\"model\\\":\\\"MiniMax-M2.5\\\",\\\"usage\\\":{\\\"input\\\":31333,\\\"output\\\":2153,\\\"cacheRead\\\":20128,\\\"cacheWrite\\\":0,\\\"totalTokens\\\":53614,\\\"cost\\\":{\\\"input\\\":0,\\\"output\\\":0,\\\"cacheRead\\\":0,\\\"cacheWrite\\\":0,\\\"total\\\":0}},\\\"stopReason\\\":\\\"toolUse\\\",\\\"timestamp\\\":1772678464728}}\\n/Users/ling/.openclaw/agents/main/sessions/34f55a68-da87-4c7f-bf50-b760c84eefb4.jsonl:{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"cde1425b\\\",\\\"parentId\\\":\\\"c22964af\\\",\\\"timestamp\\\":\\\"2026-03-05T02:42:10.107Z\\\",\\\"message\\\":{\\\"role\\\":\\\"toolResult\\\",\\\"toolCallId\\\":\\\"call_function_zu9yqb0n7pz3_1\\\",\\\"toolName\\\":\\\"write\\\",\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Successfully wrote 8003 bytes to /Users/ling/.openclaw/workspace/quant_strategies/聚宽_稳健版_年化30_v2.py\\\"}],\\\"isError\\\":false,\\\"timestamp\\\":1772678530101}}\\n/Users/ling/.openclaw/agents/main/sessions/34f55a68-da87-4c7f-bf50-b760c84eefb4.jsonl:{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"0c595ffb\\\",\\\"parentId\\\":\\\"cde1425b\\\",\\\"timestamp\\\":\\\"2026-03-05T02:42:18.911Z\\\",\\\"message\\\":{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":[{\\\"type\\\":\\\"thinking\\\",\\\"thinking\\\":\\\"完成了三个策略的优化。让我总结一下优化内容。\\\",\\\"thinkingSignature\\\":\\\"3eefacb04a21e9b85860ac1db0481383fd1f7815be4ebe7c949948fb69c9af8a\\\"},{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"## ✅ 优化完成！\\\\n\\\\n已创建三个优化版策略文件：\\\\n\\\\n| 原文件 | 新文件 | 主要优化 |\\\\n|--------|--------|----------|\\\\n| 聚宽_极限版_年化50.py | **聚宽_极限版_年化50_v2.py** | API修正+多因子+风控 |\\\\n| 聚宽_激进版_年化40.py | **聚宽_激进版_年化40_v2.py** | API修正+动量过滤+风控 |\\\\n| 聚宽_稳健版_年化30.py | **聚宽_稳健版_年化30_v2.py** | API修正+严格筛选+风控 |\\\\n\\\\n### 🔧 优化内容\\\\n\\\\n1. **API修正** - `indicator.market_cap` → `valuation.market_cap`\\\\n2. **多因子选股** - ROE、净利率、营收增长、动量综合评分\\\\n3. **动量过滤** - 剔除下跌超过5%的股票\\\\n4. **风控增强**:\\\\n   - 最大回撤控制（超过阈值自动降仓）\\\\n   - 单票止损（90%-92%）\\\\n5. **更严格筛选**:\\\\n   - 白马股增加PB上限、ROE要求\\\\n   - 稳健版更注重基本面\\\"}],\\\"api\\\":\\\"anthropic-messages\\\",\\\"provider\\\":\\\"minimax-portal\\\",\\\"model\\\":\\\"MiniMax-M2.5\\\",\\\"usage\\\":{\\\"input\\\":33536,\\\"output\\\":282,\\\"cacheRead\\\":20128,\\\"cacheWrite\\\":0,\\\"totalTokens\\\":53946,\\\"cost\\\":{\\\"input\\\":0,\\\"output\\\":0,\\\"cacheRead\\\":0,\\\"cacheWrite\\\":0,\\\"total\\\":0}},\\\"stopReason\\\":\\\"stop\\\",\\\"timestamp\\\":1772678530108}}\\n/Users/ling/.openclaw/agents/main/sessions/34f55a68-da87-4c7f-bf50-b760c84eefb4.jsonl:{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"10fa3522\\\",\\\"parentId\\\":\\\"de492cc2\\\",\\\"timestamp\\\":\\\"2026-03-05T03:22:45.839Z\\\",\\\"message\\\":{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":[{\\\"type\\\":\\\"thinking\\\",\\\"thinking\\\":\\\"用户告诉我他正在开发一个个人量化投资系统。我之前已经帮他下载了全部A股历史数据（654万条记录），也帮他优化了聚宽策略。这是一个重要的信息，我应该记住。\\\",\\\"thinkingSignature\\\":\\\"f6cfb71c8fddb501f56f0e727141edba8fd932708575d6556da33d1935ee0630\\\"},{\\\"type\\\":\\\"toolCall\\\",\\\"id\\\":\\\"call_function_hs6rygqwavkq_1\\\",\\\"name\\\":\\\"exec\\\",\\\"arguments\\\":{\\\"command\\\":\\\"cd ~/.openclaw/workspace/skills/memory-system && python3 memory_v3.py add knowledge \\\\\\\"个人量化投资系统\\\\\\\" \\\\\\\"正在开发中，使用Tushare获取数据，已下载654万条A股历史数据\\\\\\\"\\\"}}],\\\"api\\\":\\\"anthropic-messages\\\",\\\"provider\\\":\\\"minimax-portal\\\",\\\"model\\\":\\\"MiniMax-M2.5\\\",\\\"usage\\\":{\\\"input\\\":36,\\\"output\\\":109,\\\"cacheRead\\\":9476,\\\"cacheWrite\\\":85992,\\\"totalTokens\\\":95613,\\\"cost\\\":{\\\"input\\\":0,\\\"output\\\":0,\\\"cacheRead\\\":0,\\\"cacheWrite\\\":0,\\\"total\\\":0}},\\\"stopReason\\\":\\\"toolUse\\\",\\\"timestamp\\\":1772680943526}}\",\"cwd\":\"/Users/ling/.openclaw/workspace\"},\"isError\":false,\"timestamp\":1772727664129}}\n/Users/ling/.openclaw/agents/main/sessions/961aad07-32fc-4531-8b4f-31cd6e7fe5a4.jsonl.deleted.2026-03-05T02-18-01.247Z:174:{\"type\":\"message\",\"id\":\"27f190b1\",\"parentId\