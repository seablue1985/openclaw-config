{"type":"message","id":"600d2ed0","parentId":"035c20ff","timestamp":"2026-03-06T01:00:44.112Z","message":{"role":"toolResult","toolCallId":"call_d1672Y5FJRvaecK9PF5yVi56|fc_0572d43a1c78b9cd0169aa273b99e481a19970140e45c4ceaa","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n早盘准备脚本 - 每日9:00执行\n功能：更新数据、筛选股票、生成信号\n\"\"\"\n\nimport akshare as ak\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\nimport json\nimport os\n\nDATA_DIR = os.path.expanduser(\"~/qlib_data/cn_data\")\nos.makedirs(DATA_DIR, exist_ok=True)\n\nLOG_FILE = os.path.expanduser(\"~/qlib_data/morning_log.md\")\n\ndef log(msg):\n    \"\"\"记录日志\"\"\"\n    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    with open(LOG_FILE, 'a') as f:\n        f.write(f\"[{timestamp}] {msg}\\n\")\n    print(msg)\n\ndef get_realtime_data():\n    \"\"\"获取实时行情\"\"\"\n    log(\"📊 获取实时行情...\")\n    try:\n        df = ak.stock_zh_a_spot_em()\n        df.to_csv(f\"{DATA_DIR}/realtime_spot.csv\", index=False)\n        log(f\"   获取 {len(df)} 只股票实时行情\")\n        return df\n    except Exception as e:\n        log(f\"   获取失败: {e}\")\n        return None\n\ndef get_market_index():\n    \"\"\"获取指数行情\"\"\"\n    log(\"📈 获取指数行情...\")\n    indices = {\n        \"上证指数\": \"000001\",\n        \"深证成指\": \"399001\",\n        \"创业板指\": \"399006\",\n        \"中证2000\": \"000010\",\n        \"沪深300\": \"000300\"\n    }\n    \n    index_data = {}\n    for name, code in indices.items():\n        try:\n            df = ak.stock_zh_index_daily(symbol=f\"sh{code}\")\n            if len(df) > 0:\n                latest = df.iloc[-1]\n                index_data[name] = {\n                    \"close\": latest['close'],\n                    \"change\": latest['close'] / latest['open'] - 1\n                }\n                log(f\"   {name}: {latest['close']:.2f} ({latest['close']/latest['open']-1:.2%})\")\n        except Exception as e:\n            log(f\"   {name} 获取失败: {e}\")\n    \n    return index_data\n\ndef get_fund_flow():\n    \"\"\"获取资金流向\"\"\"\n    log(\"💰 获取资金流向...\")\n    try:\n        # 使用正确的API\n        df = ak.stock_individual_fund_flow_rank(indicator=\"今日\", n=\"10\")\n        if df is not None:\n            log(f\"   主力净流入前10\")\n            for _, row in df.head(5).iterrows():\n                if '名称' in row and '主力净流入-净额' in row:\n                    log(f\"   {row['名称']}: {row['主力净流入-净额']}\")\n        return df\n    except Exception as e:\n        log(f\"   获取失败: {e}\")\n        return None\n\ndef get_hot_stocks():\n    \"\"\"获取热门股票\"\"\"\n    log(\"🔥 获取热门股票...\")\n    try:\n        df = ak.stock_hot_rank_em()\n        if df is not None:\n            log(f\"   热门股票前5:\")\n            for _, row in df.head(5).iterrows():\n                if '名称' in row:\n                    log(f\"   {row['名称']}\")\n        return df\n    except Exception as e:\n        log(f\"   获取失败: {e}\")\n        return None\n\ndef analyze_stocks(df):\n    \"\"\"分析股票池\"\"\"\n    log(\"📋 分析股票池...\")\n    \n    if df is None or len(df) == 0:\n        return pd.DataFrame()\n    \n    # 尝试获取量比和换手率字段\n    available_cols = df.columns.tolist()\n    \n    # 筛选条件\n    candidates = pd.DataFrame()\n    \n    if '涨跌幅' in available_cols:\n        # 基本筛选\n        temp = df[df['涨跌幅'] > 0].copy()\n        \n        # 量比筛选\n        if '量比' in available_cols:\n            temp = temp[temp['量比'] > 1.5]\n        \n        # 换手率筛选\n        if '换手率' in available_cols:\n            temp = temp[temp['换手率'] > 3]\n        \n        candidates = temp.sort_values('涨跌幅', ascending=False)\n    \n    log(f\"   符合条件: {len(candidates)} 只\")\n    \n    if len(candidates) > 0:\n        log(\"   Top 5:\")\n        for _, row in candidates.head(5).iterrows():\n            name = row.get('名称', row.get('代码', 'N/A'))\n            change = row.get('涨跌幅', 0)\n            log(f\"   {name} {change:.2f}%\")\n    \n    return candidates\n\ndef generate_signal(index_data, candidates):\n    \"\"\"生成交易信号\"\"\"\n    log(\"🎯 生成交易信号...\")\n    \n    signal = {\n        \"大盘强度\": \"neutral\",\n        \"小盘强度\": \"neutral\",\n        \"建议\": \"观望\"\n    }\n    \n    # 沪深300判断\n    csi300 = index_data.get(\"沪深300\", {})\n    csi2000 = index_data.get(\"中证2000\", {})\n    \n    if csi300.get(\"change\", 0) > 0.5:\n        signal[\"大盘强度\"] = \"强势\"\n        signal[\"建议\"] = \"可以做多\"\n    elif csi300.get(\"change\", 0) < -0.5:\n        signal[\"大盘强度\"] = \"弱势\"\n        signal[\"建议\"] = \"谨慎观望\"\n    \n    # 小盘股判断\n    if csi2000.get(\"change\", 0) > csi300.get(\"change\", 0):\n        signal[\"小盘强度\"] = \"相对强势\"\n    \n    log(f\"   大盘: {signal['大盘强度']}, 小盘: {signal['小盘强度']}\")\n    log(f\"   建议: {signal['建议']}\")\n    \n    return signal\n\ndef save_report(index_data, candidates, signal):\n    \"\"\"保存日报\"\"\"\n    report = f\"\"\"# 量化交易日报\n生成时间: {datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")}\n\n## 大盘行情\n| 指数 | 收盘价 | 涨跌幅 |\n|------|--------|--------|\n\"\"\"\n    for name, data in index_data.items():\n        report += f\"| {name} | {data['close']:.2f} | {data['change']:.2%} |\\n\"\n    \n    report += f\"\"\"\n## 交易信号\n- 大盘强度: {signal['大盘强度']}\n- 小盘强度: {signal['小盘强度']}\n- 建议: {signal['建议']}\n\n## 候选股票\n| 股票 | 涨跌幅 |\n|------|--------|\n\"\"\"\n    \n    for _, row in candidates.head(10).iterrows():\n        name = row.get('名称', row.get('代码', 'N/A'))\n        change = row.get('涨跌幅', 0)\n        report += f\"| {name} | {change:.2f}% |\\n\"\n    \n    with open(os.path.expanduser(\"~/qlib_data/daily_report.md\"), 'w') as f:\n        f.write(report)\n    \n    log(\"📄 日报已保存\")\n\ndef main():\n    print(\"=\"*50)\n    print(\"🚀 早盘准备脚本启动\")\n    print(\"=\"*50)\n    \n    log(\"=\"*50)\n    log(\"开始早盘准备\")\n    \n    # 1. 获取实时数据\n    df = get_realtime_data()\n    \n    # 2. 获取指数\n    index_data = get_market_index()\n    \n    # 3. 获取资金流向\n    get_fund_flow()\n    \n    # 4. 获取热门股票\n    get_hot_stocks()\n    \n    # 5. 分析候选股票\n    candidates = analyze_stocks(df) if df is not None else pd.DataFrame()\n    \n    # 6. 生成信号\n    signal = generate_signal(index_data, candidates)\n    \n    # 7. 保存日报\n    save_report(index_data, candidates, signal)\n    \n    log(\"✅ 早盘准备完成\")\n    print(\"=\"*50)\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1772758844110}}
