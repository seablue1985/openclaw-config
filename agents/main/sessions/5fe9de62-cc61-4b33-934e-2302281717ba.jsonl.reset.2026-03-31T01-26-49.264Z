{"type":"message","id":"565fa40e","parentId":"3711fd95","timestamp":"2026-03-30T07:42:27.252Z","message":{"role":"toolResult","toolCallId":"call_function_1wqzudi7ueuw_1","toolName":"read","content":[{"type":"text","text":"def write_brief(\n    path: Path,\n    config: dict[str, Any],\n    live_payload: dict[str, Any],\n    runtime: RuntimeState,\n    stats: dict[str, Any],\n    tickets_file: Path,\n    orders_file: Path,\n    journal_file: Path,\n    index_ret_pct: float,\n    gray_context: dict[str, Any] | None = None,\n    holdings_meta: dict[str, Any] | None = None,\n) -> None:\n    combo = live_payload.get(\"combo_v1\", {})\n    risk = config[\"risk\"]\n    ex = config[\"execution\"]\n    exit_rules = config.get(\"exit_rules\", {}) or {}\n    stop_soft_pct = parse_optional_float(exit_rules.get(\"stop_loss_soft_pct\"))\n    stop_hard_pct = parse_optional_float(exit_rules.get(\"stop_loss_hard_pct\"))\n    stop_soft_ratio = parse_optional_float(exit_rules.get(\"stop_loss_soft_sell_ratio\"))\n    legacy_stop_pct = parse_optional_float(exit_rules.get(\"stop_loss_pct\"))\n\n    gray_context = gray_context or {}\n    holdings_meta = holdings_meta or {}\n    snapshot_quality = evaluate_holdings_snapshot_quality(runtime.date_tag, holdings_meta, stats)\n    lines = [\n        f\"# 实盘执行简报 v1（{runtime.date_tag}）\",\n        \"\",\n        \"## 回放口径可信度\",\n        f\"- 状态：`{snapshot_quality.get('label', '-')}`\",\n        f\"- 告警：`{' | '.join(snapshot_quality.get('warnings', [])) if snapshot_quality.get('warnings') else '无'}`\",\n        \"\",\n        \"## 模式判断\",\n        f\"- mode：`{runtime.mode}`\",\n        f\"- risk_off：`{runtime.risk_off}` / hard_stop：`{runtime.hard_stop}`\",\n        f\"- 是否禁止新开仓：`{runtime.halt_new_buy}`\",\n        f\"- 触发原因：{runtime.halt_reason or '无'}\",\n        f\"- 统一门控命中：`{' | '.join(runtime.gate_reasons or []) or '无'}`\",\n        f\"- 中证2000最新单日涨跌：`{index_ret_pct:.2f}%`\",\n        f\"- 市场宽度（上涨家数占比）：`{runtime.market_breadth:.3f}`\" if runtime.market_breadth is not None else \"- 市场宽度（上涨家数占比）：`N/A`\",\n        (\n            f\"- 风格因子：{(runtime.style_snapshot or {}).get('smallcap_index', 'ZZ2000')}相对\"\n            f\"{(runtime.style_snapshot or {}).get('broad_index', 'HS300')} \"\n            f\"{int((runtime.style_snapshot or {}).get('short_window', 5))}日超额=\"\n            f\"`{(runtime.style_snapshot or {}).get('short_excess_pct', '-')}`%` / \"\n            f\"{int((runtime.style_snapshot or {}).get('medium_window', 20))}日超额=\"\n            f\"`{(runtime.style_snapshot or {}).get('medium_excess_pct', '-')}`%`\"\n        ) if runtime.style_snapshot else \"- 风格因子：`N/A`\",\n        \"\",\n        \"## Top2灰度策略接入\",\n        f\"- enabled：`{gray_context.get('enabled', False)}`\",\n        f\"- phase：`{gray_context.get('phase', '-')}`\",\n        f\"- policy_loaded：`{gray_context.get('policy_loaded', False)}`\",\n        f\"- phase_cash_cap：`{gray_context.get('phase_cash_cap', '-')}`\",\n        f\"- effective_add_ratio：`{gray_context.get('effective_add_ratio', '-')}`\",\n        f\"- notes：{' ; '.join(gray_context.get('notes', [])) if gray_context.get('notes') else '无'}\",\n        \"\",\n        \"## 持仓快照来源\",\n        f\"- holdings_source：`{holdings_meta.get('path', '') or '-'}`\",\n        f\"- holdings_date：`{holdings_meta.get('date_tag', '') or '-'}`\",\n\n[396 more lines in file. Use offset=2381 to continue.]"}],"isError":false,"timestamp":1774856547235}}
