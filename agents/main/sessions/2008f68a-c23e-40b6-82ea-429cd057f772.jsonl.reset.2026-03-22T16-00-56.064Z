      weights.get(\"ret5\", 0.25) * filtered[\"rank_ret5\"] +\n        weights.get(\"excess_ret5\", 0.20) * filtered[\"rank_excess\"] +\n        weights.get(\"range_pos20\", 0.15) * filtered[\"rank_range\"] +\n        weights.get(\"reversal\", 0.10) * filtered[\"rank_reversal\"]\n    )\n    \n    # Select top K\n    top_k = sf.get(\"top_k\", 12)\n    selected = filtered.nlargest(top_k, \"score\").copy()\n    \n    # Allocate weights\n    total_exp = sf.get(\"total_exposure\", 0.72) * gate[\"scale\"]\n    max_single = sf.get(\"max_single_weight\", 0.08)\n    raw_weights = selected[\"score\"].clip(lower=0.001)\n    weights = (raw_weights / raw_weights.sum() * total_exp).clip(upper=max_single)\n    selected[\"target_weight\"] = weights.round(4)\n    \n    print(f\"Selected: {len(selected)} stocks, total weight={selected['target_weight'].sum():.2%}\")\n    \n    # Output files\n    tag = target_date.replace(\"-\", \"\")\n    out_cfg = cfg[\"outputs\"]\n    \n    # Candidates\n    cand_cols = [\"trade_date\", \"ts_code\", \"close\", \"ret5\", \"excess_ret5\", \"dist_ma10\", \"range_pos20\", \"score\", \"target_weight\"]\n    cand_path = Path(out_cfg[\"candidate_dir\"]) / f\"day1_3_candidates_{tag}.csv\"\n    cand_path.parent.mkdir(parents=True, exist_ok=True)\n    selected[cand_cols].to_csv(cand_path, index=False)\n    \n    # RD Factor\n    factor_cols = [\"date\", \"instrument\", \"score\"]\n    factor_path = Path(out_cfg[\"rd_factor_dir\"]) / f\"day1_3_mean_reversion_factor_{tag}.csv\"\n    factor_path.parent.mkdir(parents=True, exist_ok=True)\n    factor_df = pd.DataFrame({\n        \"date\": target_date,\n        \"instrument\": selected[\"ts_code\"],\n        \"score\": selected[\"score\"]\n    })\n    factor_df.to_csv(factor_path, index=False)\n    \n    # Raw signal\n    raw_path = Path(out_cfg[\"raw_signal_dir\"]) / f\"day1_3_mean_reversion_{tag}.csv\"\n    raw_path.parent.mkdir(parents=True, exist_ok=True)\n    raw = pd.DataFrame({\n        \"trade_date\": target_date,\n        \"ts_code\": selected[\"ts_code\"],\n        \"signal_type\": \"BUY\",\n        \"score\": selected[\"score\"].round(6),\n        \"target_weight\": selected[\"target_weight\"],\n        \"strategy_id\": \"day1_3_mean_reversion\",\n        \"risk_flag\": gate[\"regime\"],\n        \"comment\": f\"day1_3|regime={gate['regime']}|trend={gate['trend']}\",\n        \"source_run_id\": f\"day1_3_{tag}\",\n        \"generated_at\": pd.Timestamp.now(tz=\"Asia/Shanghai\").isoformat(),\n    })\n    raw.to_csv(raw_path, index=False)\n    \n    # Summary\n    summary = {\n        \"trade_date\": target_date,\n        \"market_regime\": gate[\"regime\"],\n        \"market_breadth\": gate[\"breadth\"],\n        \"index_trend\": gate[\"trend\"],\n        \"exposure_scale\": gate[\"scale\"],\n        \"candidates\": len(selected),\n        \"total_weight\": round(float(selected[\"target_weight\"].sum()), 4),\n        \"top3\": selected[[\"ts_code\", \"score\", \"target_weight\"]].head(3).to_dict(orient=\"records\"),\n        \"files\": {\n            \"candidates\": str(cand_path),\n            \"factor\": str(factor_path),\n            \"raw\": str(raw_path),\n        }\n    }\n    sum_path = Path(out_cfg[\"summary_dir\"]) / f\"day1_3_summary_{tag}.json\"\n    sum_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2))\n    \n    print(json.dumps(summary, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774085913637}}
