'~/.openclaw/workspace/memory/global_market_morning_0850_state.json'),\n 'precheck': '/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports/auto_premarket_precheck_20260317.json',\n 'audit': '/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports/daily_strategy_audit_20260317.json',\n 'enh': '/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports/daily_enhancement_20260317.json',\n 'main': '/Users/ling/.openclaw/workspace/research/reports/investment_research_mainline_health_20260317.json',\n}\nfor name,p in paths.items():\n    print(f'[{name}]')\n    if not os.path.exists(p):\n        print('missing')\n        continue\n    d=json.load(open(p,'r',encoding='utf-8'))\n    if name=='news':\n        for k in ['status','generated_at','last_success_at','last_failure_at','error','log_path']:\n            print(f'{k}={d.get(k)}')\n    elif name=='precheck':\n        for k in ['status','generated_at','brief_path','orders_path','precheck_path']:\n            print(f'{k}={d.get(k)}')\n    elif name=='audit':\n        for k in ['overall_status','strategy_health_status','precheck_status','annual_return_pct','max_drawdown_pct','sharpe']:\n            print(f'{k}={d.get(k)}')\n    elif name=='enh':\n        ds=d.get('dual_source',{})\n        hm=d.get('heatmap',{})\n        print('timestamp=', d.get('timestamp'))\n        print('dual_source_status=', ds.get('status'))\n        print('valid_count=', ds.get('valid_count'))\n        print('symbols_checked=', ds.get('symbols_checked'))\n        print('heatmap_status=', hm.get('status'))\n    elif name=='main':\n        print('overall_status=', d.get('overall_status'))\n        print('missing_or_failed=', ','.join(d.get('missing_or_failed',[])))\nPY","timeout":30,"workdir":"/Users/ling/.openclaw/workspace"}}],"api":"openai-completions","provider":"gmn","model":"gpt-5.4","usage":{"input":0,"output":0,"cacheRead"