{"type":"message","id":"4ce7cc27","parentId":"740187f8","timestamp":"2026-03-04T03:33:18.020Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good results! Let me run a more complete backtest with the best parameters (8 stocks, 80亿 max market cap) to get the full 4-year results.","thinkingSignature":"2aea451f92a1808394e5f59c73b56c65ac1a0e71f82b0ecc205e23339c9fda9c"},{"type":"toolCall","id":"call_function_ubvv11x4m83x_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/daily_stock_analysis && python3 << 'EOF'\nimport os\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\n\nDATA_DIR = 'data'\n\ndef load_data():\n    dfs = []\n    for year in [2021,2022,2023,2024]:\n        path = f'{DATA_DIR}/daily_{year}.csv'\n        if os.path.exists(path):\n            dfs.append(pd.read_csv(path))\n    return pd.concat(dfs, ignore_index=True) if dfs else None\n\ndaily = load_data()\ndates = sorted(daily['trade_date'].unique())\nweekly_dates = [d for d in dates if datetime.strptime(str(d), '%Y%m%d').weekday() == 1]\n\nprint(\"=\"*50)\nprint(\"📊 优化版小市值动量策略 (2021-2024)\")\nprint(\"=\"*50)\n\n# 最佳参数: 持仓8只, 市值80亿\nstock_num = 8\nmax_mv = 80\n\nreturns_list = []\nfor i, trade_date in enumerate(weekly_dates):\n    day_df = daily[daily['trade_date'] == trade_date].copy()\n    day_df['mv'] = day_df['circ_mv'] / 10000\n    day_df = day_df[(day_df['mv'] <= max_mv) & (day_df['mv'] > 0) & (day_df['pe'] > 0) & (day_df['pe'] < 80)]\n    day_df = day_df.sort_values('mv').head(stock_num)\n    \n    if i+1 < len(weekly_dates):\n        next_date = weekly_dates[i+1]\n        next_df = daily[daily['trade_date'] == next_date]\n        \n        ret_list = []\n        for _, row in day_df.iterrows():\n            s = next_df[next_df['ts_code'] == row['ts_code']]\n            if len(s) > 0:\n                ret = (s['close'].values[0] - row['close']) / row['close']\n                ret_list.append(ret)\n        \n        if ret_list:\n            returns_list.append(np.mean(ret_list))\n\n# 统计\ntotal = np.prod([1+r for r in returns_list]) - 1\nn = len(returns_list)\nannual = (1+total) ** (52/n) - 1\nvol = np.std(returns_list)\nannual_vol = vol * np.sqrt(52)\nsharpe = (annual - 0.03) / annual_vol\n\ncumprod = np.cumprod([1+r for r in returns_list])\npeak = np.maximum.accumulate(cumprod)\ndd = (cumprod - peak) / peak\nmax_dd = np.min(dd)\n\nwin = len([r for r in returns_list if r > 0]) / n\n\nprint(f\"\\n📈 回测结果\")\nprint(f\"调仓次数: {n}\")\nprint(f\"总收益率: {total*100:.2f}%\")\nprint(f\"年化收益率: {annual*100:.2f}%\")\nprint(f\"年化波动率: {annual_vol*100:.2f}%\")\nprint(f\"夏普比率: {sharpe:.2f}\")\nprint(f\"最大回撤: {max_dd*100:.2f}%\")\nprint(f\"胜率: {win*100:.1f}%\")\n\nprint(f\"\\n📉 最近收益:\")\nfor r in returns_list[-10:]:\n    idx = returns_list.index(r)\n    print(f\"  {weekly_dates[idx]}: {r*100:+.2f}%\")\nEOF","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":136652,"output":836,"cacheRead":19690,"cacheWrite":0,"totalTokens":157178,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772595174191}}
