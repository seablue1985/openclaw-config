{"type":"message","id":"1b0c01c1","parentId":"b684082e","timestamp":"2026-03-04T13:31:56.304Z","message":{"role":"user","content":[{"type":"text","text":"Conversation info (untrusted metadata):\n```json\n{\n  \"message_id\": \"07593b3b-9feb-4aba-905f-427537decab0\",\n  \"sender_id\": \"openclaw-control-ui\",\n  \"sender\": \"openclaw-control-ui\"\n}\n```\n\nSender (untrusted metadata):\n```json\n{\n  \"label\": \"openclaw-control-ui\",\n  \"id\": \"openclaw-control-ui\"\n}\n```\n\n[Wed 2026-03-04 21:31 GMT+8] # 导入函数库\nfrom jqdata import *\nfrom jqfactor import *\nimport numpy as np\nimport pandas as pd\nfrom datetime import time, datetime, timedelta\n\nSW1 = {\n '801010': '农林牧渔I', '801020': '采掘I', '801030': '化工I', '801040': '钢铁I',\n '801050': '有色金属I', '801060': '建筑建材I', '801070': '机械设备I', '801080': '电子I',\n '801090': '交运设备I', '801100': '信息设备I', '801110': '家用电器I', '801120': '食品饮料I',\n '801130': '纺织服装I', '801140': '轻工制造I', '801150': '医药生物I', '801160': '公用事业I',\n '801170': '交通运输I', '801180': '房地产I', '801190': '金融服务I', '801200': '商业贸易I',\n '801210': '休闲服务I', '801220': '信息服务I', '801230': '综合I', '801710': '建筑材料I',\n '801720': '建筑装饰I', '801730': '电气设备I', '801740': '国防军工I', '801750': '计算机I',\n '801760': '传媒I', '801770': '通信I', '801780': '银行I', '801790': '非银金融I',\n '801880': '汽车I', '801890': '机械设备I', '801950': '煤炭I', '801960': '石油石化I',\n '801970': '环保I', '801980': '美容护理I'\n}\n\ndef initialize(context):\n # 【V2.0 升级】：基准切换为创业板指，真实反映超额收益\n set_benchmark('399101.XSHE')\n set_option('use_real_price', True)\n \n # 真实摩擦成本：单边千二滑点，拒绝利润幻觉\n set_slippage(PriceRelatedSlippage(0.002))\n set_order_cost(OrderCost(open_tax=0, close_tax=0.001, \n open_commission=0.85/10000, close_commission=0.85/10000, \n close_today_commission=0, min_commission=0), type='stock')\n \n log.set_level('order', 'error')\n log.set_level('system', 'error')\n \n g.no_trading_today_signal = False\n g.run_stoploss = True\n g.hold_list = []\n g.yesterday_HL_list = []\n g.target_list = []\n g.not_buy_again = []\n \n g.stock_num = 7\n g.reason_to_sell = ''\n \n g.stoploss_strategy = 3\n g.stoploss_limit = 0.90 \n g.stoploss_market = 0.94\n g.HV_control = True \n g.HV_duration = 60 \n g.HV_ratio = 2.0 \n \n # 【V2.0 升级】：调仓时间延后至尾盘 14:30，避开早盘高滑点冲击\n run_daily(prepare_stock_list, '9:05')\n run_weekly(weekly_adjustment, 2, '14:30') \n run_daily(sell_stocks, time='10:00')\n run_daily(trade_afternoon, time='14:40')\n run_daily(close_account, '14:50')\n run_weekly(print_position_info, 5, time='15:10')\n\ndef prepare_stock_list(context):\n g.hold_list = list(context.portfolio.positions.keys())\n if g.hold_list:\n df = get_price(g.hold_list, end_date=context.previous_date, frequency='daily',\n fields=['close', 'high_limit'], count=1, panel=False, fill_paused=False)\n df = df[df['close'] == df['high_limit']]\n g.yesterday_HL_list = list(df.code)\n else:\n g.yesterday_HL_list = []\n g.no_trading_today_signal = False\n\n# ==================== 第一层：存量搅屎棍雷达 (宏观避险) ====================\ndef judge_market_env(context, ma_window=20, slope_window=5):\n yesterday = context.previous_date\n trade_days = get_trade_days(end_date=yesterday, count=ma_window + slope_window)\n if len(trade_days) < ma_window + slope_window: return '增量'\n start_date = trade_days[0]\n\n df_sh = get_price('000001.XSHG', start_date=start_date, end_date=yesterday, fields=['money'])\n df_sz = get_price('399001.XSHE', start_date=start_date, end_date=yesterday, fields=['money'])\n total_money = df_sh['money'] + df_sz['money']\n \n ma_total = total_money.rolling(ma_window).mean().dropna()\n change_total = (ma_total.iloc[-1] - ma_total.iloc[-slope_window - 1]) / ma_total.iloc[-slope_window - 1] if len(ma_total) >= slope_window + 1 else 1.0\n\n price_df = get_price('399986.XSHE', end_date=yesterday, count=ma_window, fields=['close'], skip_paused=True)\n bank_return = price_df['close'].iloc[-1] / price_df['close'].iloc[0] if len(price_df) >= 1 else 1.0\n\n if change_total <= 0.1 or bank_return <= 0.9: return '存量'\n return '增量'\n\ndef check_shit_stirrer_risk(context):\n yesterday = context.previous_date\n market_env = judge_market_env(context)\n\n initial_list = get_index_stocks('000985.XSHG', context.current_dt)\n h = history(21, '1d', 'close', initial_list, df=True)\n if h.empty: return False\n\n df_bias = h.iloc[-1] > h.iloc[-20:].mean()\n ind_dict = get_industry(initial_list, date=yesterday)\n s_stk_2_ind = {stk: ind_dict[stk]['sw_l1']['industry_code'] for stk in ind_dict if 'sw_l1' in ind_dict[stk]}\n\n df_bias_df = pd.DataFrame({'bias': df_bias, 'industry_code': pd.Series(s_stk_2_ind)}).dropna()\n df_ratio = (df_bias_df.groupby('industry_code')['bias'].sum() * 100.0 / df_bias_df.groupby('industry_code')['bias'].count()).round()\n if df_ratio.empty: return False\n \n top_industry_code = df_ratio.sort_values(ascending=False).index[0]\n log.info(f\"🔍 全市场宽度最强: {SW1.get(top_industry_code, top_industry_code)} | 宏观环境: {market_env}\")\n\n if top_industry_code in ['801780','801050','801950','801040'] and market_env == '存量':\n return True\n return False\n\n# ==================== 第二层：V2.0 实盘财务排雷与过滤 ====================\ndef filter_liquidity(context, stock_list):\n \"\"\"【V2.0 升级】：流动性硬门槛，防实盘滑点失控\"\"\"\n if not stock_list: return []\n h_money = history(20, '1d', 'money', stock_list, df=True).mean()\n h_vol = history(20, '1d', 'volume', stock_list, df=True).mean()\n \n q = query(valuation.code, valuation.circulating_cap).filter(valuation.code.in_(stock_list))\n cap_df = get_fundamentals(q).set_index('code')\n \n valid_stocks = []\n for stock in stock_list:\n if stock not in cap_df.index: continue\n money_20d = h_money.get(stock, 0)\n vol_20d = h_vol.get(stock, 0)\n cap_shares = cap_df.loc[stock, 'circulating_cap'] * 10000\n turnover_20d = vol_20d / cap_shares if cap_shares > 0 else 0\n \n # 日均成交额 > 3000万 且 日均换手率 > 2%\n if money_20d > 30000000 and turnover_20d > 0.02:\n valid_stocks.append(stock)\n return valid_stocks\n\ndef filter_financials_2yr(context, stock_list):\n \"\"\"【V2.0 升级】：连续两年盈利+营收达标，防死退市预警\"\"\"\n if not stock_list: return []\n year = context.previous_date.year\n # 根据4月30日年报披露期，智能判定应查阅的历史年份\n if context.previous_date.month < 5:\n y1, y2 = str(year - 2), str(year - 3)\n else:\n y1, y2 = str(year - 1), str(year - 2)\n \n q = query(income.code).filter(\n income.code.in_(stock_list),\n income.net_profit > 0,\n income.operating_revenue > 1e8\n )\n df1 = get_fundamentals(q, statDate=y1)\n df2 = get_fundamentals(q, statDate=y2)\n \n if df1.empty or df2.empty: return []\n valid_codes = set(df1['code']) & set(df2['code'])\n return [s for s in stock_list if s in valid_codes]\n\ndef filter_audit(context, code_list):\n \"\"\"剔除三年内非无保留意见的雷股\"\"\"\n if not code_list: return []\n last_year = (context.previous_date.replace(year=context.previous_date.year - 3, month=1, day=1)).strftime('%Y-%m-%d')\n q = query(finance.STK_AUDIT_OPINION.code, finance.STK_AUDIT_OPINION.opinion_type_id) \\\n .filter(finance.STK_AUDIT_OPINION.code.in_(code_list), finance.STK_AUDIT_OPINION.pub_date >= last_year)\n df = finance.run_query(q)\n bad_codes = df[df['opinion_type_id'].isin([3, 4, 5, 7])]['code'].unique().tolist()\n return [s for s in code_list if s not in bad_codes]\n\ndef bonus_filter(context, stock_list):\n \"\"\"【V2.0 升级】：真实分红校验，过去1年内必须有过实施记录，彻底碾碎铁公鸡\"\"\"\n if not stock_list: return []\n end_date = context.previous_date\n start_date = end_date - timedelta(days=365)\n \n q = query(finance.STK_XR_XD.code).filter(\n finance.STK_XR_XD.code.in_(stock_list),\n finance.STK_XR_XD.implementation_pub_date >= start_date,\n finance.STK_XR_XD.implementation_pub_date <= end_date,\n finance.STK_XR_XD.bonus_ratio_rmb > 0\n )\n df = finance.run_query(q)\n return df['code'].unique().tolist()\n\n# ==================== 第三层：V2.0 筹码峰精选 (进攻) ====================\ndef get_stock_list(context):\n initial_list = get_index_stocks('399101.XSHE')\n initial_list = filter_new_stock(context, initial_list)\n initial_list = filter_kcbj_stock(initial_list)\n initial_list = filter_st_stock(initial_list)\n initial_list = filter_paused_stock(initial_list)\n initial_list = filter_limitup_stock(context, initial_list)\n initial_list = filter_limitdown_stock(context, initial_list)\n \n # 1. 基础退市财务防线 (连续2年达标)\n stock_list = filter_financials_2yr(context, initial_list)\n \n # 2. 审计与红利防线\n stock_list = filter_audit(context, stock_list)\n stock_list = bonus_filter(context, stock_list)\n \n # 3. 流动性防线 (卡死实盘容量)\n stock_list = filter_liquidity(context, stock_list)\n \n # 获取通过安检的最小市值批次\n q = query(valuation.code, valuation.market_cap).filter(valuation.code.in_(stock_list)).order_by(valuation.market_cap.asc()).limit(50)\n df = get_fundamentals(q)\n if df.empty: return []\n stock_list = list(df.code)\n \n # 【V2.0 升级：筹码峰打分防骗线】\n scored_stocks = []\n for stock in stock_list:\n score = -stock_list.index(stock) \n score += get_chip_score(context, stock) * 10 \n scored_stocks.append((stock, score))\n \n scored_stocks.sort(key=lambda x: x[1], reverse=True)\n final_list = [stock for stock, score in scored_stocks][:2 * g.stock_num]\n log.info('🎯 经【V2.0 漏斗】筛出精选标的:%s' % final_list[:10])\n return final_list\n\ndef get_chip_score(context, stock):\n try:\n # 【V2.0 升级】：数据提取扩容至120天（半年），降低主力短期画图骗线影响\n price_data = get_bars(stock, 120, '1d', ['close', 'high', 'low', 'volume'], include_now=False, end_dt=context.previous_date)\n if len(price_data) < 61: return 0\n \n current_price = price_data['close'][-1] \n historical_data = price_data[:-1] \n score = 0\n \n # 波动与获利计算：立足于近60天（长周期下的一波完整建仓行情）\n price_std = np.std(historical_data['close'][-60:])\n avg_price = np.mean(historical_data['close'][-60:])\n if avg_price > 0:\n volatility = price_std / avg_price\n if volatility < 0.15: score += 0.4\n elif volatility < 0.20: score += 0.2\n \n recent_high = max(historical_data['high'][-60:])\n if recent_high > 0:\n profit_ratio = current_price / recent_high\n if profit_ratio > 0.85: score += 0.3\n elif profit_ratio > 0.75: score += 0.15\n \n recent_low = min(historical_data['low'][-60:])\n range_mid = (recent_high + recent_low) / 2\n if current_price > range_mid: score += 0.3 \n \n vol_data = historical_data['volume'][-20:]\n if len(vol_data) >= 10:\n avg_vol_5 = np.mean(vol_data[-5:])\n avg_vol_20 = np.mean(vol_data)\n if avg_vol_5 > avg_vol_20 * 1.5: score += 0.2\n \n return min(score, 1.0) \n except Exception as e:\n return 0\n\n# ==================== 核心交易执行 ====================\ndef weekly_adjustment(context):\n if g.no_trading_today_signal == False:\n g.not_buy_again = []\n log.info(\"=\"*45)\n \n if check_shit_stirrer_risk(context):\n log.info(\"🚨 【防暴跌系统】触发存量博弈熔断，尾盘强制清仓！\")\n for stock in list(context.portfolio.positions.keys()):\n close_position(context.portfolio.positions[stock])\n g.target_list = []\n return\n\n g.target_list = get_stock_list(context)\n target_list = g.target_list[:g.stock_num]\n \n for stock in g.hold_list:\n if (stock not in target_list) and (stock not in g.yesterday_HL_list):\n log.info(\"📉 卖出不达标持仓 [%s]\" % stock)\n close_position(context.portfolio.positions[stock])\n else:\n log.info(\"🛡️ 继续持有 [%s]\" % stock)\n \n buy_security(context, target_list)\n for pos in context.portfolio.positions.values():\n g.not_buy_again.append(pos.security)\n\ndef check_limit_up(context):\n current_data = get_current_data()\n for stock in g.yesterday_HL_list:\n if current_data[stock].paused: continue\n if current_data[stock].last_price < current_data[stock].high_limit:\n log.info(\"🔓 [%s]涨停打开，落袋为安\" % stock)\n if stock in context.portfolio.positions:\n close_position(context.portfolio.positions[stock])\n g.reason_to_sell = 'limitup'\n else:\n log.info(\"🔒 [%s]封死涨停，安全\" % stock)\n\ndef check_remain_amount(context):\n if g.reason_to_sell == 'limitup':\n g.hold_list = list(context.portfolio.positions.keys())\n if len(g.hold_list) < g.stock_num:\n target_list = [s for s in g.target_list if s not in g.not_buy_again][:g.stock_num - len(g.hold_list)]\n if target_list and context.portfolio.cash > 0:\n buy_security(context, target_list)\n g.reason_to_sell = ''\n\ndef trade_afternoon(context):\n if g.no_trading_today_signal == False:\n check_limit_up(context)\n if g.HV_control: check_high_volume(context)\n check_remain_amount(context)\n\ndef sell_stocks(context):\n if g.run_stoploss:\n current_data = get_current_data()\n market_down = False\n if g.stoploss_strategy == 3:\n index_data = get_price('399101.XSHE', end_date=context.previous_date, frequency='daily', fields=['close', 'open'], count=2)\n if len(index_data) >= 2 and index_data['open'][-2] > 0:\n if (index_data['close'][-2] / index_data['open'][-2]) <= g.stoploss_market:\n market_down = True\n g.reason_to_sell = 'stoploss'\n \n for stock, position in list(context.portfolio.positions.items()):\n if current_data[stock].paused: continue\n price, cost = current_data[stock].last_price, position.avg_cost\n if price >= cost * 1.35:\n order_target_value(stock, 0)\n log.info(\"💰 35%暴利止盈: %s\" % stock)\n elif market_down:\n order_target_value(stock, 0)\n log.info(\"🩸 大盘暴跌止损: %s\" % stock)\n elif price < cost * g.stoploss_limit:\n order_target_value(stock, 0)\n log.info(\"🔪 个股破位止损: %s\" % stock)\n g.reason_to_sell = 'stoploss'\n\ndef check_high_volume(context):\n current_data = get_current_data()\n for stock in context.portfolio.positions:\n # 1. 过滤停牌、涨停和不可卖出的股票\n if current_data[stock].paused or current_data[stock].last_price == current_data[stock].high_limit or context.portfolio.positions[stock].closeable_amount == 0: \n continue\n \n # 2. 获取长期成交量数据，必须加上 df=True\n df_volume = get_bars(stock, g.HV_duration, '1d', ['volume'], include_now=False, end_dt=context.previous_date, df=True)\n \n if len(df_volume) >= g.HV_duration - 1:\n max_vol = df_volume['volume'].max()\n \n # 3. 获取近期成交量数据，必须加上 df=True\n prev_vol_data = get_bars(stock, 2, '1d', ['volume'], include_now=False, end_dt=context.previous_date, df=True)\n \n if len(prev_vol_data) >= 2:\n prev_vol = prev_vol_data['volume'].iloc[-1]\n \n # 4. 天量逃顶判断\n if prev_vol > g.HV_ratio * max_vol:\n log.info(\"🌋 [%s]天量游资砸盘，卖出逃顶！\" % stock)\n close_position(context.portfolio.positions[stock])\n \ndef filter_paused_stock(stock_list):\n current_data = get_current_data()\n return [stock for stock in stock_list if not current_data[stock].paused]\n\ndef filter_st_stock(stock_list):\n current_data = get_current_data()\n return [stock for stock in stock_list if not current_data[stock].is_st and 'ST' not in current_data[stock].name and '*' not in current_data[stock].name and '退' not in current_data[stock].name]\n\ndef filter_kcbj_stock(stock_list):\n return [stock for stock in stock_list if not (stock.startswith('4') or stock.startswith('8') or stock.startswith('68'))]\n\ndef filter_limitup_stock(context, stock_list):\n if not stock_list: return []\n prev_data = get_price(stock_list, end_date=context.previous_date, frequency='daily', fields=['close', 'high_limit'], count=1, panel=False, fill_paused=False)\n result = [s for s in stock_list if s in context.portfolio.positions]\n result.extend([s for s in stock_list if s not in result and not prev_data[prev_data['code']==s].empty and prev_data[prev_data['code']==s].iloc[0]['close'] < prev_data[prev_data['code']==s].iloc[0]['high_limit']])\n return list(set(result))\n\ndef filter_limitdown_stock(context, stock_list):\n if not stock_list: return []\n prev_data = get_price(stock_list, end_date=context.previous_date, frequency='daily', fields=['close', 'low_limit'], count=1, panel=False, fill_paused=False)\n result = [s for s in stock_list if s in context.portfolio.positions]\n result.extend([s for s in stock_list if s not in result and not prev_data[prev_data['code']==s].empty and prev_data[prev_data['code']==s].iloc[0]['close'] > prev_data[prev_data['code']==s].iloc[0]['low_limit']])\n return list(set(result))\n\ndef filter_new_stock(context, stock_list):\n yesterday = context.previous_date\n return [stock for stock in stock_list if not (yesterday - get_security_info(stock).start_date < timedelta(days=375))]\n\ndef close_position(position):\n order = order_target_value(position.security, 0)\n return order != None and order.status == OrderStatus.held and order.filled == order.amount\n\ndef buy_security(context, target_list):\n position_count = len(context.portfolio.positions)\n target_num = len(target_list)\n if target_num > position_count and context.portfolio.cash > 0:\n value = context.portfolio.cash / (target_num - position_count)\n for stock in target_list:\n if context.portfolio.positions[stock].total_amount == 0:\n order = order_target_value(stock, value)\n if order != None and order.filled > 0: g.not_buy_again.append(stock)\n if len(context.portfolio.positions) == target_num: break\n\ndef close_account(context):\n pass\n\ndef print_position_info(context):\n positions = list(context.portfolio.positions.values())\n if not positions:\n log.info(\"【账户状态】: 空仓避险中\")\n return\n log.info(\"【账户状态】: 满仓进攻中\")\n for p in positions:\n ret = 100 * (p.price / p.avg_cost - 1) if p.avg_cost > 0 else 0\n print(f\"代码:{p.security} 成本:{p.avg_cost:.2f} 现价:{p.price:.2f} 盈亏:{ret:.2f}% 市值:{p.value:.2f}\")\n print('=' * 80)"}],"timestamp":1772631116301}}
