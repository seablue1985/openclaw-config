{"type":"message","id":"e56ef28e","parentId":"3b86f6c2","timestamp":"2026-03-04T13:33:33.425Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user is asking if I can convert the JoinQuant strategy to run locally. They want me to adapt it to work with local data.\n\nLet me try to create a version that:\n1. Uses Tushare to get the data we need (high/low/vol for 60 days)\n2. Implements the core strategy logic\n3. Runs locally\n\nThe key challenge is that we need to fetch historical data for each stock, which could be slow. But let me try to create a practical version.","thinkingSignature":"58539a51a7f617eb781c4ab4bdeb5989e42131aad08d9dc411a38ba1e7f7951d"},{"type":"text","text":"好的，我来把核心逻辑改成适配本地数据的版本：\n"},{"type":"toolCall","id":"call_function_z5z31y7ao0z9_1","name":"write","arguments":{"content":"\"\"\"\n策略91本地版 - 核心逻辑适配\n基于聚宽原版，使用Tushare获取缺失数据\n\"\"\"\n\nimport tushare as ts\nimport pandas as pd\nimport numpy as np\nimport os\nfrom datetime import datetime, timedelta\n\n# Tushare Token\nTOKEN = 'fa7fe5039b58853bd0df3fc31f1770fc4a8cfaa79c6bff0473829bbc'\npro = ts.pro_api(TOKEN)\n\nDATA_DIR = os.path.expanduser(\"~/.openclaw/workspace/quant_system/data\")\n\ndef get_stock_daily_data(ts_code, start_date, end_date):\n    \"\"\"获取日线数据(含high/low/vol)\"\"\"\n    try:\n        df = pro.daily(ts_code=ts_code, start_date=start_date, end_date=end_date)\n        df = df.sort_values('trade_date')\n        return df\n    except:\n        return None\n\ndef get_gem_stocks():\n    \"\"\"获取创业板成分股\"\"\"\n    try:\n        df = pro.stock_basic(exchange='', list_status='L', market='GEM')\n        return set(df['ts_code'].unique())\n    except:\n        # 备用：使用深证成指\n        df = pro.index_weight(index_code='399001.SZ')\n        latest = df['trade_date'].max()\n        return set(df[df['trade_date']==latest]['con_code'].unique())\n\ndef get_financial_data():\n    \"\"\"加载本地财务数据\"\"\"\n    fin_file = os.path.join(DATA_DIR, 'financial_tushare.csv')\n    if os.path.exists(fin_file):\n        df = pd.read_csv(fin_file)\n        return set(df[df['roe'] > 0]['ts_code'].unique())\n    return None\n\ndef load_local_price():\n    \"\"\"加载本地价格数据\"\"\"\n    files = [os.path.join(DATA_DIR, f) for f in os.listdir(DATA_DIR) \n             if f.startswith('daily_') and 'financial' not in f and 'basic' not in f]\n    if not files:\n        return None\n    dfs = [pd.read_csv(f) for f in files]\n    df = pd.concat(dfs, ignore_index=True)\n    df = df.dropna(subset=['trade_date', 'ts_code', 'close', 'total_mv'])\n    df['trade_date'] = df['trade_date'].astype(str)\n    return df\n\ndef calculate_chip_score(hist_data):\n    \"\"\"筹码峰打分 - 核心选股逻辑\"\"\"\n    if hist_data is None or len(hist_data) < 60:\n        return 0\n    \n    current_price = hist_data['close'].iloc[-1]\n    score = 0\n    \n    # 取最近60天数据\n    if len(hist_data) >= 60:\n        close_60 = hist_data['close'].iloc[-60:]\n        high_60 = hist_data['high'].iloc[-60:]\n        low_60 = hist_data['low'].iloc[-60:]\n        vol_60 = hist_data['vol'].iloc[-60:]\n        \n        # 1. 波动率得分\n        volatility = np.std(close_60) / np.mean(close_60)\n        if volatility < 0.15:\n            score += 0.4\n        elif volatility < 0.20:\n            score += 0.2\n        \n        # 2. 获利比例得分\n        recent_high = high_60.max()\n        if recent_high > 0:\n            profit_ratio = current_price / recent_high\n            if profit_ratio > 0.85:\n                score += 0.3\n            elif profit_ratio > 0.75:\n                score += 0.15\n        \n        # 3. 位置得分\n        range_mid = (high_60.max() + low_60.min()) / 2\n        if current_price > range_mid:\n            score += 0.3\n        \n        # 4. 量价配合\n        if len(vol_60) >= 20:\n            avg_vol_5 = vol_60.iloc[-5:].mean()\n            avg_vol_20 = vol_60.mean()\n            if avg_vol_5 > avg_vol_20 * 1.5:\n                score += 0.2\n    \n    return min(score, 1.0)\n\ndef run_backtest():\n    print(\"=\" * 50)\n    print(\"策略91 本地版\")\n    print(\"=\" * 50)\n    \n    # 获取股票列表\n    gem_stocks = get_gem_stocks()\n    valid_stocks = get_financial_data()\n    print(f\"创业板: {len(gem_stocks)}, 财务达标: {len(valid_stocks) if valid_stocks else 0}\")\n    \n    # 加载本地数据\n    local_df = load_local_price()\n    if local_df is not None:\n        local_stocks = set(local_df['ts_code'].unique())\n        # 取交集\n        available_stocks = gem_stocks & local_stocks if valid_stocks is None else (gem_stocks & local_stocks & valid_stocks)\n        print(f\"本地可用: {len(available_stocks)}\")\n    else:\n        available_stocks = gem_stocks\n        print(\"本地无数据，使用Tushare\")\n    \n    # 交易日\n    trade_dates = sorted(local_df['trade_date'].unique()) if local_df is not None else []\n    trade_dates = [d for d in trade_dates if '2021' <= d <= '2024']\n    print(f\"交易日: {len(trade_dates)}\")\n    \n    if len(trade_dates) == 0:\n        print(\"没有交易数据!\")\n        return\n    \n    # 策略参数\n    cash = 1000000\n    positions = {}\n    hold_days = {}\n    max_stocks = 7\n    stop_loss = 0.90\n    profit_take = 1.35\n    \n    portfolio = [cash]\n    \n    for i, date in enumerate(trade_dates):\n        is_rebalance = (i % 5 == 1)  # 每周调仓\n        \n        # ===== 卖出 =====\n        stocks_sell = []\n        for stock in list(positions.keys()):\n            hold_days[stock] = hold_days.get(stock, 0) + 1\n            \n            price_data = local_df[(local_df['ts_code']==stock) & (local_df['trade_date']==date)]['close']\n            if len(price_data) == 0:\n                continue\n            \n            cur = price_data.values[0]\n            cost = positions[stock]['cost']\n            pnl = (cur - cost) / cost\n            \n            if pnl <= -0.10 or pnl >= 0.35 or hold_days[stock] >= 5:\n                stocks_sell.append(stock)\n        \n        for stock in stocks_sell:\n            price = local_df[(local_df['ts_code']==stock) & (local_df['trade_date']==date)]['close']\n            if len(price) > 0:\n                cash += positions[stock]['shares'] * price.values[0] * 0.999\n                del positions[stock]\n                hold_days.pop(stock, None)\n        \n        # ===== 买入 =====\n        if is_rebalance:\n            # 选股\n            d = local_df[(local_df['trade_date']==date) & \n                    (local_df['close']>=3) & (local_df['close']<=50)]\n            \n            if valid_stocks:\n                d = d[d['ts_code'].isin(valid_stocks)]\n            \n            if len(d) > 0:\n                d = d.sort_values('total_mv').head(50)\n                \n                # 简化评分\n                scored = []\n                for _, row in d.iterrows():\n                    stock = row['ts_code']\n                    # 基础分 = 100 - 市值排名\n                    base_score = 50 - list(d['ts_code']).index(stock)\n                    scored.append((stock, base_score))\n                \n                scored.sort(key=lambda x: x[1], reverse=True)\n                buy_list = [s[0] for s in scored[:max_stocks]]\n                \n                for stock in buy_list:\n                    if len(positions) >= max_stocks:\n                        break\n                    if stock in positions:\n                        continue\n                    \n                    price = local_df[(local_df['ts_code']==stock) & (local_df['trade_date']==date)]['close']\n                    if len(price) > 0:\n                        p = price.values[0]\n                        shares = int(cash / max_stocks / p / 100) * 100\n                        if shares > 0:\n                            cost_val = shares * p * 1.001\n                            if cost_val <= cash:\n                                cash -= cost_val\n                                positions[stock] = {'shares': shares, 'cost': p}\n                                hold_days[stock] = 0\n        \n        # 记录价值\n        total = cash\n        for stock, pos in positions.items():\n            price = local_df[(local_df['ts_code']==stock) & (local_df['trade_date']==date)]['close']\n            if len(price) > 0:\n                total += pos['shares'] * price.values[0]\n        portfolio.append(total)\n    \n    # 结果\n    initial = 1000000\n    final = portfolio[-1]\n    ret = (final - initial) / initial * 100\n    years = len(trade_dates) / 252\n    ann = ((final / initial) ** (1 / years) - 1) * 100 if years > 0 else 0\n    \n    peak, mdd = initial, 0\n    for v in portfolio:\n        if v > peak: peak = v\n        dd = (peak - v) / peak\n        if dd > mdd: mdd = dd\n    \n    rets = np.diff(portfolio) / np.array(portfolio)[:-1]\n    sharpe = np.mean(rets) / np.std(rets) * np.sqrt(252) if len(rets) > 0 and np.std(rets) > 0 else 0\n    \n    print(f\"\"\"\n========================================\n策略91 本地版 结果\n========================================\n初始: {initial:,.0f}\n最终: {final:,.0f}\n总收益: {ret:.2f}%\n年化: {ann:.2f}%\n回撤: {-mdd*100:.2f}%\n夏普: {sharpe:.2f}\n========================================\"\"\")\n\nif __name__ == \"__main__\":\n    run_backtest()\n","file_path":"/Users/ling/.openclaw/workspace/quant_system/strategy91_local.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":36,"output":2401,"cacheRead":132096,"cacheWrite":5592,"totalTokens":140125,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772631166418}}
