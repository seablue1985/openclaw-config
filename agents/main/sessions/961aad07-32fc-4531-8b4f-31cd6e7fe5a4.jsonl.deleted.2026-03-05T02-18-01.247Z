{"type":"message","id":"13883309","parentId":"68320a51","timestamp":"2026-03-04T10:40:09.927Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"找到了！这是zycash的\"2024国九小市值实盘收益50.64%\"策略。这个策略：\n- 2024年5月-12月实盘收益50.64%\n- 年化100%+（回测）\n- 回撤25.6%\n- 1885人克隆\n\n这个策略之前我们已经分析过了。让我基于这个策略的逻辑，在本地实现并优化它。","thinkingSignature":"d14d93f8493f8e22d43dffaae34a3d53f5d9a8dbcec5c99d00006d78b846b0d8"},{"type":"text","text":"找到了！**zycash的\"国九小市值策略\"**：\n- 2024实盘收益：**50.64%**\n- 回测年化：**100%+**\n- 回撤：25.6%\n- 1885人克隆\n\n这个策略我们之前已经分析过了，让我基于它的核心逻辑实现并优化：\n"},{"type":"toolCall","id":"call_function_1mkmemotzg0w_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n国九小市值策略 - 基于聚宽zycash的策略逻辑优化版\n核心:\n1. 小市值选股 (<1亿)\n2. 国九条筛选 (净利润>0)\n3. 每周二调仓\n4. 空仓月: 1月、4月\n5. 加入止损优化\n\"\"\"\nimport os\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\n\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'data')\n\n\ndef load_data(years):\n    dfs = []\n    for year in years:\n        path = f'{DATA_DIR}/daily_{year}.csv'\n        if os.path.exists(path):\n            dfs.append(pd.read_csv(path))\n    return pd.concat(dfs, ignore_index=True) if dfs else None\n\n\ndef run_strategy(start_year=2021, end_year=2024):\n    \"\"\"运行国九小市值策略优化版\"\"\"\n    print(\"=\"*60)\n    print(\"📊 国九小市值策略优化版\")\n    print(\"=\"*60)\n    \n    # 参数\n    MAX_MV = 50  # 最大市值50亿\n    TOP_N = 25    # 持仓25只\n    STOP_LOSS = -0.10  # 止损10%\n    \n    years = list(range(start_year, end_year + 1))\n    daily = load_data(years)\n    \n    if daily is None:\n        print(\"❌ 没有数据\")\n        return\n    \n    dates = sorted(daily['trade_date'].unique())\n    print(f\"数据范围: {dates[0]} ~ {dates[-1]}\")\n    \n    # 按周提取交易日 (每周二)\n    from datetime import datetime\n    trade_dates = []\n    for d in dates:\n        try:\n            dt = datetime.strptime(str(d), '%Y%m%d')\n            if dt.weekday() == 1:  # 周二\n                trade_dates.append(d)\n        except:\n            pass\n    \n    # 过滤空仓月份 (1月和4月)\n    active_dates = []\n    for d in trade_dates:\n        month = (d // 100) % 100\n        if month not in [1, 4]:  # 空仓月\n            active_dates.append(d)\n    \n    print(f\"调仓日: {len(active_dates)}\")\n    \n    # 选股函数\n    def select_stocks(df, top_n=25):\n        df = df.copy()\n        df['circ_mv_yi'] = df['circ_mv'] / 10000\n        # 小市值筛选\n        df = df[df['circ_mv_yi'] <= MAX_MV]\n        df = df[df['circ_mv_yi'] > 0]\n        # PE筛选 (盈利筛选)\n        df = df[df['pe'] > 0]\n        df = df[df['pe'] < 80]\n        # 过滤ST\n        df = df[~df['ts_code'].str.contains('ST|ST', na=False)]\n        # 按市值升序\n        return df.sort_values('circ_mv_yi').head(top_n)\n    \n    # 回测\n    monthly_returns = []\n    prev_positions = {}\n    \n    for i, trade_date in enumerate(active_dates):\n        day_df = daily[daily['trade_date'] == trade_date]\n        if len(day_df) == 0:\n            continue\n        \n        selected = select_stocks(day_df, TOP_N)\n        \n        if len(selected) == 0:\n            continue\n        \n        # 计算收益\n        if i + 1 < len(active_dates):\n            next_date = active_dates[i + 1]\n            next_df = daily[daily['trade_date'] == next_date]\n            \n            stock_returns = []\n            for ts_code in selected['ts_code'].values:\n                # 止损检查\n                if ts_code in prev_positions:\n                    stock_start = day_df[day_df['ts_code'] == ts_code]\n                    if len(stock_start) > 0:\n                        current_price = stock_start['close'].values[0]\n                        ret = (current_price - prev_positions[ts_code]) / prev_positions[ts_code]\n                        if ret < STOP_LOSS:\n                            continue\n                \n                stock_start = day_df[day_df['ts_code'] == ts_code]\n                stock_end = next_df[next_df['ts_code'] == ts_code]\n                \n                if len(stock_start) > 0 and len(stock_end) > 0:\n                    ret = (stock_end['close'].values[0] - stock_start['close'].values[0]) / stock_start['close'].values[0]\n                    stock_returns.append(ret)\n            \n            if stock_returns:\n                avg_ret = np.mean(stock_returns)\n                monthly_returns.append({'date': trade_date, 'return': avg_ret})\n            \n            # 更新持仓\n            prev_positions = {}\n            for _, row in selected.iterrows():\n                prev_positions[row['ts_code']] = row['close']\n    \n    # 统计结果\n    if not monthly_returns:\n        print(\"❌ 没有收益数据\")\n        return\n    \n    returns = [r['return'] for r in monthly_returns]\n    total_return = np.prod([1 + r for r in returns]) - 1\n    n = len(returns)\n    annual_return = (1 + total_return) ** (52 / n) - 1\n    \n    vol = np.std(returns)\n    annual_vol = vol * np.sqrt(52)\n    sharpe = (annual_return - 0.03) / annual_vol if annual_vol > 0 else 0\n    \n    # 最大回撤\n    cumprod = np.cumprod([1 + r for r in returns])\n    peak = np.maximum.accumulate(cumprod)\n    drawdown = (cumprod - peak) / peak\n    max_dd = np.min(drawdown)\n    \n    win_rate = len([r for r in returns if r > 0]) / n\n    \n    print(f\"\\n📈 回测结果\")\n    print(f\"{'='*50}\")\n    print(f\"调仓次数: {n}\")\n    print(f\"总收益率: {total_return*100:.2f}%\")\n    print(f\"年化收益率: {annual_return*100:.2f}%\")\n    print(f\"年化波动率: {annual_vol*100:.2f}%\")\n    print(f\"夏普比率: {sharpe:.2f}\")\n    print(f\"最大回撤: {max_dd*100:.2f}%\")\n    print(f\"胜率: {win_rate*100:.1f}%\")\n    \n    print(f\"\\n📉 最近收益:\")\n    for r in monthly_returns[-10:]:\n        print(f\"  {r['date']}: {r['return']*100:+.2f}%\")\n    \n    return {\n        'total_return': total_return,\n        'annual_return': annual_return,\n        'sharpe': sharpe,\n        'max_drawdown': max_dd,\n        'win_rate': win_rate\n    }\n\n\nif __name__ == '__main__':\n    run_strategy(2021, 2024)\n","file_path":"/Users/ling/.openclaw/workspace/daily_stock_analysis/backtest_guojiu_v2.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":151352,"output":1719,"cacheRead":19905,"cacheWrite":0,"totalTokens":172976,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772620773485}}
