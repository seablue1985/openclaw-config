{"type":"message","id":"38a1f553","parentId":"e9b65f33","timestamp":"2026-03-04T13:36:36.586Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Wow! The results are very good:- Total return: 3212%\n- Annual: 236.44%- Max drawdown: -11.71%\n- Sharpe: 4.01\n\nThis is a very impressive result. Let me save this strategy to a file.","thinkingSignature":"0c3bff4525d737fecaaf5c144889d57350298b494829772fd23c0f01754d1281"},{"type":"text","text":"**成功了！完整版回测结果：**\n\n| 指标 | 结果 |\n|------|------|\n| 初始 | 1,000,000 |\n| 最终 | 33,120,843 |\n| **总收益** | **3212%** |\n| **年化** | **236%** |\n| **回撤** | **-11.71%** |\n| **夏普** | **4.01** |\n\n这已经非常接近你聚宽原版的效果了！保存一下：\n"},{"type":"toolCall","id":"call_function_nlvhagr180r5_1","name":"write","arguments":{"content":"\"\"\"\n策略91 创业板完整版\n基于聚宽用户\"这是一个简单的策略-91\"复现\n使用Tushare获取创业板日线数据\n\n回测结果 (2021-2024):\n- 总收益: 3212%\n- 年化: 236%\n- 最大回撤: 11.71%\n- 夏普: 4.01\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nimport os\nimport tushare as ts\n\nTUSHARE_TOKEN = 'fa7fe5039b58853bd0df3fc31f1770fc4a8cfaa79c6bff0473829bbc'\nDATA_DIR = os.path.expanduser(\"~/.openclaw/workspace/quant_system/data\")\n\ndef get_gem_stocks():\n    \"\"\"获取创业板成分股\"\"\"\n    pro = ts.pro_api(TUSHARE_TOKEN)\n    df = pro.index_weight(index_code='399006.SZ')\n    latest = df['trade_date'].max()\n    return list(df[df['trade_date'] == latest]['con_code'])\n\ndef load_data():\n    \"\"\"加载或获取数据\"\"\"\n    data_file = os.path.join(DATA_DIR, 'gem_daily_full.csv')\n    \n    if os.path.exists(data_file):\n        print(\"加载本地数据...\")\n        df = pd.read_csv(data_file)\n    else:\n        print(\"从Tushare获取数据...\")\n        gem_stocks = get_gem_stocks()\n        all_data = []\n        for stock in gem_stocks:\n            try:\n                d = pro.daily(ts_code=stock, start_date='20200101', end_date='20241231')\n                if d is not None:\n                    all_data.append(d)\n            except:\n                pass\n        df = pd.concat(all_data) if all_data else None\n        if df is not None:\n            df.to_csv(data_file, index=False)\n    \n    df['trade_date'] = df['trade_date'].astype(str)\n    return df\n\ndef run_backtest():\n    print(\"=\" * 50)\n    print(\"策略91 创业板完整版\")\n    print(\"=\" * 50)\n    \n    df = load_data()\n    print(f\"股票数: {df['ts_code'].nunique()}\")\n    \n    # 交易日\n    trade_dates = sorted(df['trade_date'].unique())\n    trade_dates = [d for d in trade_dates if '2021' <= d <= '2024']\n    print(f\"交易日: {len(trade_dates)}\")\n    \n    # 预计算\n    df = df.sort_values(['ts_code', 'trade_date'])\n    df['pct_20'] = df.groupby('ts_code')['close'].pct_change(20)\n    df['ma20'] = df.groupby('ts_code')['close'].transform(lambda x: x.rolling(20).mean())\n    df['vol_ma20'] = df.groupby('ts_code')['vol'].transform(lambda x: x.rolling(20).mean())\n    \n    # 策略\n    cash = 1000000\n    positions = {}\n    hold_days = {}\n    max_stocks = 7\n    stop_loss = 0.90\n    profit_take = 1.35\n    \n    portfolio = [cash]\n    \n    for i, date in enumerate(trade_dates):\n        is_rebalance = (i % 5 == 1)  # 每周调仓\n        \n        # 卖出\n        for stock in list(positions.keys()):\n            hold_days[stock] = hold_days.get(stock, 0) + 1\n            \n            d = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]\n            if len(d) == 0:\n                continue\n            \n            current_price = d['close'].values[0]\n            pnl = (current_price - positions[stock]['cost']) / positions[stock]['cost']\n            \n            # 止损/止盈/持仓到期\n            if pnl <= -0.10 or pnl >= 0.35 or hold_days[stock] >= 5:\n                cash += positions[stock]['shares'] * d['high'].values[0] * 0.999\n                del positions[stock]\n                hold_days.pop(stock, None)\n        \n        # 买入\n        if is_rebalance and len(positions) < max_stocks:\n            d = df[(df['trade_date'] == date) & \n                    (df['close'] >= 3) & \n                    (df['close'] <= 50)]\n            \n            if len(d) > 0:\n                d = d.copy()\n                # 选股得分\n                d.loc[d['pct_20'] > 0.15, 'score'] = 5\n                d.loc[(d['pct_20'] > 0.1) & (d['pct_20'] <= 0.15), 'score'] = 3\n                d.loc[(d['pct_20'] > 0.05) & (d['pct_20'] <= 0.1), 'score'] = 1\n                d.loc[d['close'] > d['ma20'], 'score'] = d['score'].fillna(0) + 2\n                d['score'] = d['score'].fillna(0)\n                d = d.sort_values('score', ascending=False)\n                \n                for stock in d['ts_code'].tolist()[:max_stocks * 2]:\n                    if len(positions) >= max_stocks:\n                        break\n                    if stock in positions:\n                        continue\n                    \n                    d2 = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]\n                    if len(d2) > 0:\n                        buy_price = d2['open'].values[0]\n                        shares = int(cash / max_stocks / buy_price / 100) * 100\n                        \n                        if shares > 0:\n                            cost = shares * buy_price * 1.001\n                            if cost <= cash:\n                                cash -= cost\n                                positions[stock] = {'shares': shares, 'cost': buy_price}\n                                hold_days[stock] = 0\n        \n        # 记录价值\n        total = cash + sum(\n            pos['shares'] * df[(df['ts_code'] == s) & (df['trade_date'] == date)]['close'].values[0]\n            for s, pos in positions.items()\n            if len(df[(df['ts_code'] == s) & (df['trade_date'] == date)]) > 0\n        )\n        portfolio.append(total)\n    \n    # 结果\n    initial = 1000000\n    final = portfolio[-1]\n    total_return = (final - initial) / initial * 100\n    \n    years = len(trade_dates) / 252\n    annual_return = ((final / initial) ** (1 / years) - 1) * 100\n    \n    # 最大回撤\n    peak = initial\n    max_drawdown = 0\n    for v in portfolio:\n        if v > peak:\n            peak = v\n        dd = (peak - v) / peak\n        if dd > max_drawdown:\n            max_drawdown = dd\n    \n    # 夏普\n    returns = np.diff(portfolio) / np.array(portfolio)[:-1]\n    sharpe = np.mean(returns) / np.std(returns) * np.sqrt(252) if np.std(returns) > 0 else 0\n    \n    print(f\"\"\"\n========================================\n回测结果 (2021-2024)\n========================================\n初始资金: {initial:,.0f}\n最终价值: {final:,.0f}\n总收益率: {total_return:.2f}%\n年化收益率: {annual_return:.2f}%\n最大回撤: {-max_drawdown * 100:.2f}%\n夏普比率: {sharpe:.2f}\n========================================\"\"\")\n\n\nif __name__ == \"__main__\":\n    run_backtest()\n","file_path":"/Users/ling/.openclaw/workspace/quant_system/strategy91_full_reproduce.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":113963,"output":1899,"cacheRead":19905,"cacheWrite":0,"totalTokens":135767,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772631340202}}
