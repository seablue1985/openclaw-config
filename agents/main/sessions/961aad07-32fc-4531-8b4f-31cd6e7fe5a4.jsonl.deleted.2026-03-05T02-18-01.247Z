{"type":"message","id":"414cc0dd","parentId":"044f4254","timestamp":"2026-03-04T13:33:18.556Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Great! I've downloaded 50创业板 stocks with full data (including high, low, vol). Now let me create a more complete backtest using this data.","thinkingSignature":"4866e0a8f5054688f214aab100e176b9629becc4f32ae13a706948c95ceaaf61"},{"type":"toolCall","id":"call_function_xvcm8s132fsb_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && python3 -c \"\nimport pandas as pd\nimport numpy as np\nimport os\n\nDATA_DIR = 'data'\n\n# 加载完整日线数据\ndf = pd.read_csv(os.path.join(DATA_DIR, 'gem_daily_full.csv'))\ndf['trade_date'] = df['trade_date'].astype(str)\nprint(f'股票数: {df[\\\"ts_code\\\"].nunique()}')\nprint(f'记录数: {len(df)}')\nprint(f'列: {df.columns.tolist()}')\n\n# 财务\nfin = pd.read_csv(os.path.join(DATA_DIR, 'financial_tushare.csv'))\nvalid = set(fin[fin['roe']>0]['ts_code'])\nprint(f'ROE>0: {len(valid)}')\n\n# 交易日\ntrade_dates = sorted(df['trade_date'].unique())\ntrade_dates = [d for d in trade_dates if '2021' <= d <= '2024']\nprint(f'交易日: {len(trade_dates)}')\n\n# 预计算\ndf = df.sort_values(['ts_code', 'trade_date'])\ndf['pct_20'] = df.groupby('ts_code')['close'].pct_change(20)\ndf['ma20'] = df.groupby('ts_code')['close'].transform(lambda x: x.rolling(20).mean())\ndf['vol_ma20'] = df.groupby('ts_code')['vol'].transform(lambda x: x.rolling(20).mean())\n\ncash = 1000000\npositions = {}\nhold_days = {}\nmax_stocks = 7\nstop_loss = 0.90\nprofit_take = 1.35\n\nfor i, date in enumerate(trade_dates):\n    is_reb = (i % 5 == 1)\n    \n    # 卖出\n    for stock in list(positions.keys()):\n        hold_days[stock] = hold_days.get(stock, 0) + 1\n        d = df[(df['ts_code']==stock) & (df['trade_date']==date)]\n        if len(d) == 0: continue\n        cur = d['close'].values[0]\n        pnl = (cur - positions[stock]['cost']) / positions[stock]['cost']\n        if pnl <= -0.10 or pnl >= 0.35 or hold_days[stock] >= 5:\n            cash += positions[stock]['shares'] * d['high'].values[0] * 0.999\n            del positions[stock]\n            hold_days.pop(stock, None)\n    \n    # 买入\n    if is_reb:\n        d = df[(df['trade_date']==date) & (df['close']>=3) & (df['close']<=50) & (df['ts_code'].isin(valid))]\n        if len(d) > 0:\n            d = d.copy()\n            # 选股得分\n            d['score'] = 0\n            # 涨幅\n            d.loc[d['pct_20']>0.15, 'score'] += 3\n            d.loc[(d['pct_20']>0.1)&(d['pct_20']<=0.15), 'score'] += 2\n            d.loc[(d['pct_20']>0.05)&(d['pct_20']<=0.1), 'score'] += 1\n            # 站上20日均线\n            d.loc[d['close']>d['ma20'], 'score'] += 2\n            # 放量\n            d.loc[d['vol']>d['vol_ma20']*1.5, 'score'] += 1\n            # 市值(用换手近似)\n            d = d.sort_values('score', ascending=False)\n            \n            for stock in d['ts_code'].tolist()[:max_stocks]:\n                if len(positions) >= max_stocks: break\n                if stock in positions: continue\n                d2 = df[(df['ts_code']==stock) & (df['trade_date']==date)]\n                if len(d2) > 0:\n                    p = d2['open'].values[0]\n                    shares = int(cash / max_stocks / p / 100) * 100\n                    if shares > 0:\n                        cost = shares * p * 1.001\n                        if cost <= cash:\n                            cash -= cost\n                            positions[stock] = {'shares': shares, 'cost': p}\n                            hold_days[stock] = 0\n    \n    if i % 50 == 0:\n        total = cash + sum(pos['shares'] * df[(df['ts_code']==s) & (df['trade_date']==date)]['close'].values[0] for s,pos in positions.items() if len(df[(df['ts_code']==s) & (df['trade_date']==date)])>0)\n        print(f'{date}: {total:,.0f}')\n\n# 最终价值\ntotal = cash\nfor stock, pos in positions.items():\n    d = df[(df['ts_code']==stock) & (df['trade_date']==trade_dates[-1])]\n    if len(d) > 0:\n        total += pos['shares'] * d['close'].values[0]\n\ninit = 1000000\nret = (total-init)/init*100\nyears = len(trade_dates)/252\nann = ((total/init)**(1/years)-1)*100\nprint(f'''\n========================================\n策略91 Tushare完整版 (创业板50只)\n========================================\n初始: {init:,.0f}\n最终: {total:,.0f}\n总收益: {ret:.2f}%\n年化: {ann:.2f}%\n========================================''')\n\"","timeout":180}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":113172,"output":1301,"cacheRead":19999,"cacheWrite":0,"totalTokens":134472,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772631166782}}
