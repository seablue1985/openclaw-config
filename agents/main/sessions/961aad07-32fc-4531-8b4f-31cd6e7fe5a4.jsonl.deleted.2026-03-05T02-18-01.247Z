e32]:\n        - /url: \"#daily-errors-tab\"\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\"256eea5c8b7714a5\">>>"}],"details":{"ok":true,"format":"ai","targetId":"22189B40DC6074D8F95FD2917A02AA87","url":"https://www.joinquant.com/algorithm/index/edit?algorithmId=93cf2c7fe1ade5ed3fbcf8d8071e3ead","stats":{"lines":70,"chars":2952,"refs":32,"interactive":31},"refs":32,"externalContent":{"untrusted":true,"source":"browser","kind":"snapshot","format":"ai","wrapped":true}},"isError":false,"timestamp":1772587076250}}
