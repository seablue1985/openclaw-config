{"type":"message","id":"4165b41e","parentId":"c91c3911","timestamp":"2026-03-04T12:10:58.493Z","message":{"role":"toolResult","toolCallId":"call_function_ezez1m921gis_1","toolName":"read","content":[{"type":"text","text":"\"\"\"\n这是一个简单的策略-91 优化版\n基于聚宽用户的策略，在本地用Tushare数据回测\n\n优化方向：\n1. 添加更严格的止损（-8%）\n2. 添加财务过滤（ROE>0）\n3. 添加空仓月（1月、4月）\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nimport os\n\n# 数据路径\nDATA_DIR = os.path.expanduser(\"~/.openclaw/workspace/quant_system/data\")\n\nclass Strategy:\n    def __init__(self):\n        self.stock_pool = []\n        self.buy_list = []\n        self.hold_days = {}\n        self.positions = {}\n        self.cash = 1000000\n        \n        # 策略参数\n        self.max_stocks = 3\n        self.hold_days_max = 3\n        self.stop_loss = -0.08\n        self.market_cap_min = 10\n        self.market_cap_max = 100\n\ndef load_stock_data():\n    \"\"\"加载股票数据\"\"\"\n    files = []\n    for f in os.listdir(DATA_DIR):\n        if f.endswith('.csv') and 'financial' not in f:\n            files.append(os.path.join(DATA_DIR, f))\n    \n    if not files:\n        print(\"未找到股票数据文件\")\n        return None\n    \n    dfs = []\n    for f in files:\n        try:\n            df = pd.read_csv(f)\n            dfs.append(df)\n        except:\n            pass\n    \n    if dfs:\n        data = pd.concat(dfs, ignore_index=True)\n        return data\n    return None\n\ndef load_financial_data():\n    \"\"\"加载财务数据\"\"\"\n    fin_file = os.path.join(DATA_DIR, 'financial_tushare.csv')\n    if os.path.exists(fin_file):\n        return pd.read_csv(fin_file)\n    return None\n\ndef filter_stocks(date, stocks_df, s):\n    \"\"\"过滤股票\"\"\"\n    available = stocks_df[stocks_df['trade_date'] == date].copy()\n    \n    if len(available) == 0:\n        return []\n    \n    # 市值过滤 (10-100亿)\n    available = available[\n        (available['total_mv'] >= s.market_cap_min * 100000000) &\n        (available['total_mv'] <= s.market_cap_max * 100000000)\n    ]\n    \n    # 股价过滤 (3-50元)\n    available = available[\n        (available['close'] >= 3) & \n        (available['close'] <= 50)\n    ]\n    \n    # 按市值排序，选最小的\n    available = available.sort_values('total_mv', ascending=True)\n    \n    return available['ts_code'].tolist()[:s.max_stocks]\n\ndef run_backtest(start_date='2021-01-01', end_date='2024-12-31'):\n    \"\"\"运行回测\"\"\"\n    print(f\"开始回测: {start_date} - {end_date}\")\n    \n    stocks_df = load_stock_data()\n    financial_df = load_financial_data()\n    \n    if stocks_df is None:\n        print(\"无法加载数据\")\n        return\n    \n    # 转换日期格式\n\n[197 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1772626258490}}
{"type":"message","id":"6f813d2e","parentId":"4165b41e","timestamp":"2026-03-04T12:11:49.575Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me just rewrite the entire backtest file properly.","thinkingSignature":"d80b29d5e9f19044342bec056c7e93c876fa2801caf8d24d16a6d39f2087b05f"},{"type":"toolCall","id":"call_function_g5szhrqun5vz_1","name":"write","arguments":{"content":"\"\"\"\n策略91优化版 - 小市值轮动策略\n基于聚宽用户的策略优化\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nimport os\n\nDATA_DIR = os.path.expanduser(\"~/.openclaw/workspace/quant_system/data\")\n\nclass Strategy:\n    def __init__(self):\n        self.hold_days = {}\n        self.positions = {}\n        self.cash = 1000000\n        self.max_stocks = 3\n        self.hold_days_max = 3\n        self.stop_loss = -0.08\n        self.market_cap_min = 10\n        self.market_cap_max = 100\n\ndef load_data():\n    files = [os.path.join(DATA_DIR, f) for f in os.listdir(DATA_DIR) \n             if f.endswith('.csv') and 'financial' not in f]\n    dfs = [pd.read_csv(f) for f in files]\n    return pd.concat(dfs, ignore_index=True) if dfs else None\n\ndef run_backtest(start_date='20210101', end_date='20241231'):\n    print(f\"回测: {start_date} - {end_date}\")\n    \n    df = load_data()\n    if df is None:\n        print(\"无法加载数据\")\n        return\n    \n    df['trade_date'] = df['trade_date'].astype(str)\n    trade_dates = sorted(df['trade_date'].unique())\n    trade_dates = [d for d in trade_dates if start_date <= d <= end_date]\n    \n    print(f\"交易日: {len(trade_dates)}\")\n    \n    s = Strategy()\n    portfolio = [s.cash]\n    trades = []\n    \n    for i, date in enumerate(trade_dates):\n        # 月份切换检查空仓月\n        if i > 0 and date[4:6] != trade_dates[i-1][4:6]:\n            if date[4:6] in ['01', '04']:\n                for stock in list(s.positions.keys()):\n                    price = df[(df['ts_code']==stock) & (df['trade_date']==date)]['close']\n                    if len(price) > 0:\n                        s.cash += s.positions[stock]['shares'] * price.values[0] * 0.999\n                        trades.append(('sell', stock, '空仓月'))\n                        del s.positions[stock]\n        \n        # 持仓处理\n        for stock in list(s.positions.keys()):\n            s.hold_days[stock] = s.hold_days.get(stock, 0) + 1\n            \n            price = df[(df['ts_code']==stock) & (df['trade_date']==date)]['close']\n            if len(price) > 0:\n                pnl = (price.values[0] - s.positions[stock]['cost']) / s.positions[stock]['cost']\n                if s.hold_days[stock] >= s.hold_days_max or pnl <= s.stop_loss:\n                    s.cash += s.positions[stock]['shares'] * price.values[0] * 0.999\n                    trades.append(('sell', stock, f'持{s.hold_days[stock]}天' if pnl>s.stop_loss else f'止损{int(pnl*100)}%'))\n                    del s.positions[stock]\n        \n        # 买入\n        if len(s.positions) < s.max_stocks:\n            available = df[(df['trade_date']==date) & \n                          (df['total_mv']>=s.market_cap_min*1e8) & \n                          (df['total_mv']<=s.market_cap_max*1e8) &\n                          (df['close']>=3) & (df['close']<=50)]\n            buy_list = available.sort_values('total_mv')['ts_code'].tolist()[:s.max_stocks]\n            \n            for stock in buy_list:\n                if len(s.positions) >= s.max_stocks:\n                    break\n                if stock in s.positions:\n                    continue\n                \n                price = df[(df['ts_code']==stock) & (df['trade_date']==date)]['close']\n                if len(price) > 0:\n                    buy_price = price.values[0]\n                    shares = int(s.cash / (s.max_stocks - len(s.positions)) / buy_price / 100) * 100\n                    if shares > 0:\n                        cost = shares * buy_price * 1.001\n                        if cost <= s.cash:\n                            s.cash -= cost\n                            s.positions[stock] = {'shares': shares, 'cost': buy_price}\n                            s.hold_days[stock] = 0\n                            trades.append(('buy', stock, buy_price))\n        \n        # 计算组合价值\n        total = s.cash\n        for stock, pos in s.positions.items():\n            price = df[(df['ts_code']==stock) & (df['trade_date']==date)]['close']\n            if len(price) > 0:\n                total += pos['shares'] * price.values[0]\n        portfolio.append(total)\n    \n    # 结果\n    init, final = 1000000, portfolio[-1]\n    ret = (final-init)/init*100\n    years = len(trade_dates)/252\n    ann_ret = ((final/init)**(1/years)-1)*100\n    \n    peak, max_dd = init, 0\n    for v in portfolio:\n        if v > peak: peak = v\n        dd = (peak-v)/peak\n        if dd > max_dd: max_dd = dd\n    \n    rets = np.diff(portfolio)/portfolio[:-1]\n    sharpe = np.mean(rets)/np.std(rets)*np.sqrt(252) if np.std(rets)>0 else 0\n    \n    print(\"\\n\" + \"=\"*45)\n    print(\"策略91优化版 回测结果\")\n    print(\"=\"*45)\n    print(f\"时间: {start_date} - {end_date}\")\n    print(f\"初始: {init:,.0f}\")\n    print(f\"最终: {final:,.0f}\")\n    print(f\"总收益: {ret:.2f}%\")\n    print(f\"年化: {ann_ret:.2f}%\")\n    print(f\"最大回撤: {-max_dd*100:.2f}%\")\n    print(f\"夏普: {sharpe:.2f}\")\n    print(f\"交易次数: {len(trades)}\")\n    print(\"=\"*45)\n\nif __name__ == \"__main__\":\n    run_backtest('20210101', '20241231')\n","file_path":"/Users/ling/.openclaw/workspace/quant_system/backtest_strategy91.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":73701,"output":1467,"cacheRead":19905,"cacheWrite":0,"totalTokens":95073,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772626258494}}
