n            print(f'失败 {fail} 只')\n\nprint(f'\\\\n完成! 成功: {success}, 失败: {fail}')\n\nif all_data:\n    df_all = pd.concat(all_data)\n    df_all.to_csv('data/all_stocks_daily.csv', index=False)\n    print(f'已保存到 data/all_stocks_daily.csv, 总记录: {len(df_all)}')\n\" 2>&1","name":"cd ~/.openclaw/workspace/quant_system","tail":"","truncated":false},{"sessionId":"tidal-trail","status":"completed","startedAt":1772629874164,"endedAt":1772629905823,"runtimeMs":31659,"cwd":"/Users/ling/.openclaw/workspace","command":"cd ~/.openclaw/workspace/quant_system && python3 -c \"\nimport pandas as pd\nimport numpy as np\nimport os\n\nDATA_DIR = os.path.expanduser('~/.openclaw/workspace/quant_system/data')\n\n# 快速回测\nfiles = [os.path.join(DATA_DIR, f) for f in os.listdir(DATA_DIR) \n         if f.startswith('daily_') and 'financial' not in f and 'basic' not in f]\ndfs = [pd.read_csv(f) for f in files]\ndf = pd.concat(dfs, ignore_index=True)\ndf = df.dropna(subset=['trade_date', 'ts_code', 'close', 'total_mv'])\ndf['trade_date'] = df['trade_date'].astype(str)\n\n# 财务数据\nfin = pd.read_csv(os.path.join(DATA_DIR, 'financial_tushare.csv'))\nvalid_stocks = set(fin[fin['roe'] > 0]['ts_code'].unique())\n\n# 交易日\ntrade_dates = sorted(df['trade_date'].unique())\ntrade_dates = [d for d in trade_dates if '2021' <= d <= '2024']\nprint(f'交易日: {len(trade_dates)}')\n\n# 简化策略\ncash = 1000000\npositions = {}\nhold_days = {}\nmax_stocks = 7\n\nportfolio = [cash]\n\nfor i, date in enumerate(trade_dates[::5]):  # 每5天调仓\n    # 选股\n    d = df[(df['trade_date'] == date) & (df['close'] >= 3) & (df['close'] <= 50)]\n    d = d[d['ts_code'].isin(valid_stocks)]\n    d = d.sort_values('total_mv').head(30)\n    buy_list = d['ts_code'].tolist()[:max_stocks]\n    \n    # 卖出\n    for stock in list(positions.keys()):\n        price = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n        if len(price) > 0:\n            pnl = (price.values[0] - positions[stock]['cost']) / positions[stock]['cost']\n            if pnl <= -0.10 or pnl >= 0.35:\n                cash += positions[stock]['shares'] * price.values[0] * 0.999\n                del positions[stock]\n    \n    # 买入\n    for stock in buy_list:\n        if len(positions) >= max_stocks:\n            break\n        if stock in positions:\n            continue\n        price = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n        if len(price) > 0:\n            buy_price = price.values[0]\n            shares = int(cash / max_stocks / buy_price / 100) * 100\n            if shares > 0:\n                cost = shares * buy_price * 1.001\n                if cost <= cash:\n                    cash -= cost\n                    positions[stock] = {'shares': shares, 'cost': buy_price}\n    \n    # 价值\n    total = cash\n    for stock, pos in positions.items():\n        price = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n        if len(price) > 0:\n            total += pos['shares'] * price.values[0]\n    portfolio.append(total)\n\n# 结果\ninit, final = 1000000, portfolio[-1]\nret = (final-init)/init*100\nyears = len(trade_dates)/252\nann = ((final/init)**(1/years)-1)*100\npeak, mdd = init, 0\nfor v in portfolio:\n    if v > peak: peak = v\n    dd = (peak-v)/peak\n    if dd > mdd: mdd = dd\n\nrets = np.diff(portfolio)/portfolio[:-1]\nsharpe = np.mean(rets)/np.std(rets)*np.sqrt(252) if np.std(rets)>0 else 0\n\nprint(f'''\n========================================\n策略91 简化版 回测结果\n========================================\n初始: {init:,.0f}\n最终: {final:,.0f}\n总收益: {ret:.2f}%\n年化: {ann:.2f}%\n最大回撤: {-mdd*100:.2f}%\n夏普: {sharpe:.2f}\n========================================\n''')\n\" 2>&1","name":"cd ~/.openclaw/workspace/quant_system","tail":"交易日: 727\n\n========================================\n策略91 简化版 回测结果\n========================================\n初始: 1,000,000\n最终: 1,549,421\n总收益: 54.94%\n年化: 16.39%\n最大回撤: -12.36%\n夏普: 2.24\n========================================\n\n","truncated