{"type":"message","id":"58f3b6c6","parentId":"fe2fe810","timestamp":"2026-03-03T23:29:30.026Z","message":{"role":"toolResult","toolCallId":"call_function_5ioer94vglag_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n小市值策略回测\n基于历史数据的策略回测\n\"\"\"\nimport os\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\n\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'data')\n\ndef load_all_data(years=None):\n    \"\"\"加载所有数据\n    Args:\n        years: 要加载的年份列表，如 [2021, 2022]。如果为None，则加载默认数据。\n    \"\"\"\n    basic = pd.read_csv(f'{DATA_DIR}/stock_basic.csv')\n    \n    if years:\n        # 加载指定年份的数据\n        dfs = []\n        for year in years:\n            file_path = f'{DATA_DIR}/daily_{year}.csv'\n            if os.path.exists(file_path):\n                df = pd.read_csv(file_path)\n                dfs.append(df)\n                print(f\"📊 加载 {year} 年数据: {len(df)} 条记录\")\n        \n        if dfs:\n            daily = pd.concat(dfs, ignore_index=True)\n            print(f\"📊 合计加载: {daily.ts_code.nunique()} 只股票, {len(daily)} 条记录\")\n        else:\n            # 如果没有找到文件，回退到默认数据\n            if os.path.exists(f'{DATA_DIR}/daily_basic_all.csv'):\n                daily = pd.read_csv(f'{DATA_DIR}/daily_basic_all.csv')\n                print(f\"⚠️ 未找到历史数据文件，使用完整数据\")\n            else:\n                daily = pd.read_csv(f'{DATA_DIR}/daily_basic_500.csv')\n                print(f\"⚠️ 使用样本数据: 500 只\")\n    else:\n        # 优先使用完整数据\n        if os.path.exists(f'{DATA_DIR}/daily_basic_all.csv'):\n            daily = pd.read_csv(f'{DATA_DIR}/daily_basic_all.csv')\n            print(f\"📊 使用完整数据: {daily.ts_code.nunique()} 只股票\")\n        else:\n            daily = pd.read_csv(f'{DATA_DIR}/daily_basic_500.csv')\n            print(f\"⚠️ 使用样本数据: 500 只\")\n    \n    return basic, daily\n\ndef get_universe_by_date(date, daily_df):\n    \"\"\"获取指定日期的股票池\"\"\"\n    df = daily_df[daily_df['trade_date'] == int(date)].copy()\n    df['circ_mv_yi'] = df['circ_mv'] / 10000\n    return df\n\ndef select_stocks(df, top_n=30, max_mv=50):\n    \"\"\"选股\"\"\"\n    # 计算市值\n    df = df.copy()\n    df['circ_mv_yi'] = df['circ_mv'] / 10000\n    \n    # 过滤市值\n    df = df[df['circ_mv_yi'] <= max_mv]\n    df = df[df['circ_mv_yi'] > 0]\n    \n    # 过滤PE (排除亏损)\n    df = df[df['pe'] > 0]\n    df = df[df['pe'] < 80]\n    \n    # 按市值排序，取最小的\n    df = df.sort_values('circ_mv_yi').head(top_n)\n    \n    return df\n\ndef calculate_returns(daily_df, stock_list, start_date, end_date):\n    \"\"\"计算持仓期收益\"\"\"\n    # 获取时间范围内的所有日期\n    dates = sorted(daily_df['trade_date'].unique())\n\n[169 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1772580570022}}
{"type":"message","id":"371a59a7","parentId":"58f3b6c6","timestamp":"2026-03-03T23:30:08.056Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"我需要创建一个优化版的回测，加入止损、仓位管理和风控。让我创建一个新文件 backtest_optimized.py。","thinkingSignature":"9618b6188324820c5796d3e440ecbc19ef5723db515d4479419451147dfd9585"},{"type":"toolCall","id":"call_function_sx9lkabm7hvd_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n小市值策略优化版 - 加入止损、仓位管理、风控\n\"\"\"\nimport os\nimport pandas as pd\nimport numpy as np\n\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'data')\n\n# ==================== 策略参数 ====================\nclass Config:\n    # 选股参数\n    top_n = 30           # 持仓数量\n    max_mv = 50          # 最大市值(亿)\n    \n    # 止损参数\n    stop_loss = -0.07     # 止损线 -7%\n    take_profit = 0.15   # 止盈线 +15%\n    \n    # 仓位管理\n    max_position = 0.05  # 单只股票最大仓位 5%\n    base_position = 0.8  # 基础仓位 80%\n    \n    # 风控\n    max_drawdown_alert = -0.15  # 回撤15%警报，减仓\n    max_drawdown_stop = -0.25   # 回撤25%清仓\n\n\ndef load_data(years):\n    \"\"\"加载数据\"\"\"\n    basic = pd.read_csv(f'{DATA_DIR}/stock_basic.csv')\n    dfs = []\n    for year in years:\n        path = f'{DATA_DIR}/daily_{year}.csv'\n        if os.path.exists(path):\n            dfs.append(pd.read_csv(path))\n    daily = pd.concat(dfs, ignore_index=True) if dfs else None\n    return basic, daily\n\n\ndef select_stocks(df, top_n=30, max_mv=50):\n    \"\"\"选股\"\"\"\n    df = df.copy()\n    df['circ_mv_yi'] = df['circ_mv'] / 10000\n    df = df[(df['circ_mv_yi'] <= max_mv) & (df['circ_mv_yi'] > 0)]\n    df = df[(df['pe'] > 0) & (df['pe'] < 80)]\n    return df.sort_values('circ_mv_yi').head(top_n)\n\n\ndef run_backtest_optimized(start_year=2021, end_year=2024):\n    \"\"\"运行优化版回测\"\"\"\n    print(\"=\"*60)\n    print(\"📊 小市值策略优化版 (止损+仓位管理+风控)\")\n    print(\"=\"*60)\n    \n    years = list(range(start_year, end_year + 1))\n    basic, daily = load_data(years)\n    \n    dates = sorted(daily['trade_date'].unique())\n    print(f\"数据范围: {dates[0]} ~ {dates[-1]}\")\n    print(f\"交易日数: {len(dates)}\")\n    \n    # 按月回测\n    months = sorted(set(d // 100 for d in dates))\n    \n    # 账户状态\n    cash = 1000000  # 初始资金100万\n    positions = {}  # 持仓\n    position_value = 0\n    \n    # 风控状态\n    current_position_ratio = Config.base_position  # 当前仓位比例\n    peak_value = cash  # 最高点\n    \n    # 回撤控制记录\n    drawdown_adjustments = []\n    \n    # 每月收益记录\n    monthly_results = []\n    \n    for i, month in enumerate(months):\n        month_dates = [d for d in dates if d // 100 == month]\n        if not month_dates:\n            continue\n        \n        trade_date = month_dates[0]\n        \n        # 更新持仓市值\n        current_positions_value = 0\n        for ts_code in list(positions.keys()):\n            stock_data = daily[(daily['ts_code'] == ts_code) & (daily['trade_date'] == trade_date)]\n            if len(stock_data) > 0:\n                positions[ts_code]['current_price'] = stock_data['close'].values[0]\n                current_positions_value += positions[ts_code]['shares'] * positions[ts_code]['current_price']\n            else:\n                # 如果没有当天数据，使用上次价格\n                current_positions_value += positions[ts_code]['shares'] * positions[ts_code].get('current_price', positions[ts_code]['buy_price'])\n        \n        total_value = cash + current_positions_value\n        \n        # 检查风控 - 回撤控制\n        if total_value > peak_value:\n            peak_value = total_value\n        \n        drawdown = (total_value - peak_value) / peak_value\n        \n        # 回撤超过阈值，减仓\n        if drawdown < Config.max_drawdown_alert and current_position_ratio > 0.5:\n            current_position_ratio = 0.5\n            drawdown_adjustments.append({'month': month, 'action': '减仓50%', 'drawdown': drawdown})\n            print(f\"⚠️ {month} 回撤{drawdown*100:.1f}%，减仓至50%\")\n        elif drawdown < Config.max_drawdown_stop:\n            current_position_ratio = 0.2\n            drawdown_adjustments.append({'month': month, 'action': '清仓至20%', 'drawdown': drawdown})\n            print(f\"🚨 {month} 回撤{drawdown*100:.1f}%，清仓至20%\")\n        \n        # 选股\n        day_df = daily[daily['trade_date'] == trade_date]\n        selected = select_stocks(day_df, Config.top_n, Config.max_mv)\n        \n        if len(selected) == 0:\n            continue\n        \n        # 计算目标持仓\n        target_value = total_value * current_position_ratio\n        target_per_stock = target_value / len(selected) * Config.max_position\n        \n        # 调仓\n        new_positions = {}\n        sell_value = 0\n        \n        # 卖出不再持有的股票\n        for ts_code in list(positions.keys()):\n            if ts_code not in selected['ts_code'].values:\n                # 止损检查\n                current_price = positions[ts_code].get('current_price', positions[ts_code]['buy_price'])\n                stock_ret = (current_price - positions[ts_code]['buy_price']) / positions[ts_code]['buy_price']\n                \n                # 止损/止盈检查\n                if stock_ret < Config.stop_loss or stock_ret > Config.take_profit:\n                    sell_value += positions[ts_code]['shares'] * current_price\n                else:\n                    # 保留持仓\n                    new_positions[ts_code] = positions[ts_code]\n        \n        positions = new_positions\n        cash += sell_value\n        \n        # 买入新股票\n        for _, stock in selected.iterrows():\n            ts_code = stock['ts_code']\n            if ts_code not in positions:\n                buy_price = stock['close']\n                if cash > target_per_stock:\n                    shares = int(target_per_stock / buy_price)\n                    if shares > 0:\n                        cost = shares * buy_price\n                        cash -= cost\n                        positions[ts_code] = {\n                            'buy_price': buy_price,\n                            'current_price': buy_price,\n                            'shares': shares\n                        }\n        \n        # 计算月末价值\n        end_of_month = month_dates[-1]\n        month_end_value = 0\n        for ts_code in list(positions.keys()):\n            stock_data = daily[(daily['ts_code'] == ts_code) & (daily['trade_date'] == end_of_month)]\n            if len(stock_data) > 0:\n                month_end_value += positions[ts_code]['shares'] * stock_data['close'].values[0]\n            else:\n                month_end_value += positions[ts_code]['shares'] * positions[ts_code].get('current_price', positions[ts_code]['buy_price'])\n        \n        month_return = (cash + month_end_value - total_value) / total_value\n        \n        monthly_results.append({\n            'month': month,\n            'cash': cash,\n            'position_value': month_end_value,\n            'total_value': cash + month_end_value,\n            'return': month_return,\n            'position_ratio': current_position_ratio\n        })\n        \n        # 更新现金为月末值\n        cash = cash + month_end_value\n    \n    # ==================== 结果统计 ====================\n    results_df = pd.DataFrame(monthly_results)\n    results_df['cumulative'] = (1 + results_df['return']).cumprod()\n    \n    # 计算关键指标\n    total_return = results_df['cumulative'].iloc[-1] - 1\n    n_months = len(results_df)\n    annual_return = (1 + total_return) ** (12 / n_months) - 1\n    \n    # 波动率和夏普\n    monthly_vol = results_df['return'].std()\n    annual_vol = monthly_vol * np.sqrt(12)\n    sharpe = (annual_return - 0.03) / annual_vol if annual_vol > 0 else 0\n    \n    # 最大回撤\n    results_df['peak'] = results_df['cumulative'].cummax()\n    results_df['drawdown'] = (results_df['cumulative'] - results_df['peak']) / results_df['peak']\n    max_drawdown = results_df['drawdown'].min()\n    \n    # 胜率\n    win_rate = len(results_df[results_df['return'] > 0]) / len(results_df)\n    \n    # 年度表现\n    results_df['year'] = results_df['month'] // 100\n    yearly = results_df.groupby('year')['return'].agg(lambda x: (1+x).prod()-1)\n    \n    print(\"\\n\" + \"=\"*60)\n    print(\"📈 回测结果\")\n    print(\"=\"*60)\n    print(f\"调仓次数: {n_months}\")\n    print(f\"总收益率: {total_return*100:.2f}%\")\n    print(f\"年化收益率: {annual_return*100:.2f}%\")\n    print(f\"年化波动率: {annual_vol*100:.2f}%\")\n    print(f\"夏普比率: {sharpe:.2f}\")\n    print(f\"最大回撤: {max_drawdown*100:.2f}%\")\n    print(f\"胜率: {win_rate*100:.1f}%\")\n    \n    print(\"\\n📅 年度表现:\")\n    for year, ret in yearly.items():\n        print(f\"  {year}: {ret*100:+.2f}%\")\n    \n    print(\"\\n📉 月度收益:\")\n    for _, row in results_df.iterrows():\n        print(f\"  {int(row['month'])}: {row['return']*100:+.2f}%\")\n    \n    if drawdown_adjustments:\n        print(\"\\n⚠️ 风控操作:\")\n        for adj in drawdown_adjustments:\n            print(f\"  {adj['month']}: {adj['action']} (回撤{adj['drawdown']*100:.1f}%)\")\n    \n    return results_df\n\n\nif __name__ == '__main__':\n    run_backtest_optimized(2021, 2024)\n","file_path":"/Users/ling/.openclaw/workspace/quant_system/backtest_optimized.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":14843,"output":2387,"cacheRead":18417,"cacheWrite":0,"totalTokens":35647,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772580570027}}
