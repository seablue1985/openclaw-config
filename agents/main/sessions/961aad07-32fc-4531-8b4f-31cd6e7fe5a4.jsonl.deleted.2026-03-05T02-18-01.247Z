{"type":"message","id":"5e2ca35b","parentId":"e842e708","timestamp":"2026-03-03T23:25:44.062Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户想要进一步分析回测结果。我可以进行以下分析：\n1. 最大回撤分析\n2. 风险分析\n3. 与基准（如沪深300）对比\n4. 持仓分析\n5. 策略改进建议\n\n让我创建一个更详细的分析脚本。","thinkingSignature":"beda182521e4a7e1e1a10208ba3d98f839878a4ad585bc8ca4bb1ca5b479fbbe"},{"type":"toolCall","id":"call_function_61666a8b19vm_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && source .venv/bin/activate && python3 << 'EOF'\nimport pandas as pd\nimport numpy as np\nimport os\n\nDATA_DIR = 'data'\n\n# 加载2021-2025年数据\nyears = [2021, 2022, 2023, 2024]\nbasic = pd.read_csv(f'{DATA_DIR}/stock_basic.csv')\n\ndfs = []\nfor year in years:\n    file_path = f'{DATA_DIR}/daily_{year}.csv'\n    if os.path.exists(file_path):\n        dfs.append(pd.read_csv(file_path))\ndaily = pd.concat(dfs, ignore_index=True)\n\ndates = sorted(daily['trade_date'].unique())\nprint(f\"数据范围: {dates[0]} ~ {dates[-1]}\")\nprint(f\"交易日数: {len(dates)}\")\nprint(f\"股票数: {daily.ts_code.nunique()}\")\n\n# 选股函数\ndef select_stocks(df, top_n=30, max_mv=50):\n    df = df.copy()\n    df['circ_mv_yi'] = df['circ_mv'] / 10000\n    df = df[df['circ_mv_yi'] <= max_mv]\n    df = df[df['circ_mv_yi'] > 0]\n    df = df[df['pe'] > 0]\n    df = df[df['pe'] < 80]\n    df = df.sort_values('circ_mv_yi').head(top_n)\n    return df\n\n# 按月回测，计算累计收益和回撤\nmonthly_returns = []\nmonths = sorted(set(d // 100 for d in dates))\n\nportfolio_value = 1.0\nvalues = []\n\nfor i, month in enumerate(months):\n    month_dates = [d for d in dates if d // 100 == month]\n    if not month_dates:\n        continue\n    \n    trade_date = month_dates[0]\n    day_df = daily[daily['trade_date'] == trade_date]\n    selected = select_stocks(day_df, top_n=30, max_mv=50)\n    \n    if len(selected) == 0 or i == len(months) - 1:\n        continue\n    \n    # 计算下月收益\n    next_month = months[i + 1] if i + 1 < len(months) else None\n    if not next_month:\n        continue\n        \n    next_dates = [d for d in dates if d // 100 == next_month]\n    if not next_dates:\n        continue\n    \n    end_date = next_dates[-1]\n    \n    returns = []\n    for _, stock in selected.iterrows():\n        stock_start = daily[(daily['ts_code'] == stock['ts_code']) & (daily['trade_date'] == trade_date)]\n        stock_end = daily[(daily['ts_code'] == stock['ts_code']) & (daily['trade_date'] == end_date)]\n        \n        if len(stock_start) > 0 and len(stock_end) > 0:\n            ret = (stock_end['close'].values[0] - stock_start['close'].values[0]) / stock_start['close'].values[0]\n            returns.append(ret)\n    \n    if returns:\n        monthly_ret = np.mean(returns)\n        monthly_returns.append({\n            'month': month,\n            'return': monthly_ret,\n            'win_rate': len([r for r in returns if r > 0]) / len(returns)\n        })\n        portfolio_value *= (1 + monthly_ret)\n        values.append(portfolio_value)\n\n# 转换为DataFrame\nresults_df = pd.DataFrame(monthly_returns)\nresults_df['cumulative'] = (1 + results_df['return']).cumprod()\n\n# 计算回撤\nresults_df['peak'] = results_df['cumulative'].cummax()\nresults_df['drawdown'] = (results_df['cumulative'] - results_df['peak']) / results_df['peak']\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"📈 策略深度分析\")\nprint(\"=\"*60)\n\n# 年度统计\nresults_df['year'] = results_df['month'] // 100\nyearly = results_df.groupby('year').agg({\n    'return': ['sum', 'mean', 'std', 'count'],\n    'win_rate': 'mean'\n}).round(4)\nyearly.columns = ['年度收益', '月均收益', '收益波动率', '交易月数', '月胜率']\nyearly['年度收益'] = (yearly['年度收益'] * 100).round(2).astype(str) + '%'\nyearly['月均收益'] = (yearly['月均收益'] * 100).round(2).astype(str) + '%'\nyearly['收益波动率'] = (yearly['收益波动率'] * 100).round(2).astype(str) + '%'\nyearly['月胜率'] = (yearly['月胜率'] * 100).round(1).astype(str) + '%'\n\nprint(\"\\n📅 年度表现:\")\nprint(yearly.to_string())\n\n# 最大回撤\nmax_dd = results_df['drawdown'].min()\nmax_dd_date = results_df.loc[results_df['drawdown'].idxmin(), 'month']\nprint(f\"\\n📉 最大回撤: {max_dd*100:.2f}% (发生在 {max_dd_date} 月)\")\n\n# 波动率\nannual_vol = results_df['return'].std() * np.sqrt(12)\nprint(f\"📊 年化波动率: {annual_vol*100:.2f}%\")\n\n# 夏普比率 (假设无风险利率3%)\nrisk_free = 0.03\ntotal_return = results_df['cumulative'].iloc[-1] - 1\nyears = len(monthly_returns) / 12\nannual_return = (1 + total_return) ** (1/years) - 1\nsharpe = (annual_return - risk_free) / annual_vol\nprint(f\"📈 夏普比率: {sharpe:.2f} (假设无风险利率3%)\")\n\n# 盈利 vs 亏损月份\nprofit_months = len(results_df[results_df['return'] > 0])\nloss_months = len(results_df[results_df['return'] < 0])\nprint(f\"\\n✅ 盈利月份: {profit_months} 个月\")\nprint(f\"❌ 亏损月份: {loss_months} 个月\")\n\n# 最好和最差的月份\nbest_month = results_df.loc[results_df['return'].idxmax()]\nworst_month = results_df.loc[results_df['return'].idxmin()]\nprint(f\"\\n🏆 最佳月份: {best_month['month']} ({best_month['return']*100:+.2f}%)\")\nprint(f\"💔 最差月份: {worst_month['month']} ({worst_month['return']*100:+.2f}%)\")\n\n# 收益风险比\nreturn_risk = annual_return / annual_vol\nprint(f\"\\n⚖️ 收益风险比: {return_risk:.2f}\")\n\nprint(\"\\n\" + \"=\"*60)\nEOF","timeout":120}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":36,"output":1604,"cacheRead":27930,"cacheWrite":1778,"totalTokens":31348,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772580319529}}
