,20201229,19.17,13.1942,37201145.1856,37200827.8876\n000001.SZ,20201228,18.85,12.974,36580155.8032,36579843.8018\n\n==> /Users/ling/.openclaw/workspace/quant_system/data/daily_2021.csv <==\nts_code,trade_date,close,pe,total_mv,circ_mv\n000001.SZ,20211231,16.48,11.0554,31980953.1903,31980683.3748\n000001.SZ,20211230,16.82,11.2834,32640754.409,32640479.027\n000001.SZ,20211229,16.75,11.2365,32504912.9817,32504638.7456\n000001.SZ,20211228,17.17,11.5182,33319961.546,33319680.4336","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1772626169732}}
{"type":"message","id":"fd7b8490","parentId":"65d39a43","timestamp":"2026-03-04T12:10:21.554Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The data format looks good. The issue is that trade_date is an integer like 20191231. Let me fix the code to handle this format.","thinkingSignature":"a26ffdb3a94cd955e2d9b7e5563f75b954bff34a542040a425300cf6fec15ef8"},{"type":"toolCall","id":"call_function_1zbkizsywfvt_1","name":"edit","arguments":{"file_path":"/Users/ling/.openclaw/workspace/quant_system/backtest_strategy91.py","oldText":"\"\"\"\n这是一个简单的策略-91 优化版\n基于聚宽用户的策略，在本地用Tushare数据回测\n\n优化方向：\n1. 添加更严格的止损（-8%）\n2. 添加财务过滤（ROE>0）\n3. 添加空仓月（1月、4月）\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nimport os\n\n# 数据路径\nDATA_DIR = os.path.expanduser(\"~/.openclaw/workspace/quant_system/data\")\n\ndef load_stock_data():\n    \"\"\"加载股票数据\"\"\"\n    files = []\n    for f in os.listdir(DATA_DIR):\n        if f.endswith('.csv') and 'financial' not in f:\n            files.append(os.path.join(DATA_DIR, f))\n    \n    if not files:\n        print(\"未找到股票数据文件\")\n        return None\n    \n    # 读取所有CSV\n    dfs = []\n    for f in files[:50]:  # 限制数量\n        try:\n            df = pd.read_csv(f)\n            dfs.append(df)\n        except:\n            pass\n    \n    if dfs:\n        data = pd.concat(dfs, ignore_index=True)\n        return data\n    return None\n\ndef load_financial_data():\n    \"\"\"加载财务数据\"\"\"\n    fin_file = os.path.join(DATA_DIR, 'financial_tushare.csv')\n    if os.path.exists(fin_file):\n        return pd.read_csv(fin_file)\n    return None\n\ndef initialize():\n    \"\"\"初始化策略参数\"\"\"\n    g.stock_pool = []  # 股票池\n    g.buy_list = []    # 买入列表\n    g.hold_days = {}   # 持仓天数\n    g.positions = {}    # 持仓\n    g.cash = 1000000   # 初始资金100万\n    \n    # 策略参数\n    g.max_stocks = 3          # 每天最多买3只\n    g.hold_days_max = 3       # 持仓天数\n    g.stop_loss = -0.08       # 止损-8%（原版-10%）\n    g.market_cap_min = 10     # 最小市值10亿\n    g.market_cap_max = 100    # 最大市值100亿\n    \n    # 排除的行业\n    g.exclude_industry = [\n        '房地产', '金融服务', '商业贸易', '休闲服务', '综合',\n        '银行', '非银金融'\n    ]\n    \n    # 需要的行业\n    g.include_industry = [\n        '农林牧渔', '化工', '钢铁', '有色金属', '建筑建材', \n        '机械设备', '电子', '交通运输', '公用事业', '食品饮料'\n    ]\n\ndef filter_stocks(date, stocks_df, financial_df=None):\n    \"\"\"过滤股票\"\"\"\n    # 当天可以交易的股票\n    available = stocks_df[stocks_df['trade_date'] == date].copy()\n    \n    if len(available) == 0:\n        return []\n    \n    # 市值过滤 (10-100亿)\n    available = available[\n        (available['total_mv'] >= g.market_cap_min * 100000000) &\n        (available['total_mv'] <= g.market_cap_max * 100000000)\n    ]\n    \n    # 股价过滤 (3-50元)\n    available = available[\n        (available['close'] >= 3) & \n        (available['close'] <= 50)\n    ]\n    \n    # 市净率过滤 (0.5-5)\n    if 'pb' in available.columns:\n        available = available[\n            (available['pb'] >= 0.5) & \n            (available['pb'] <= 5)\n        ]\n    \n    # 按市值排序，选最小的\n    available = available.sort_values('total_mv', ascending=True)\n    \n    # 返回市值最小的股票\n    return available['ts_code'].tolist()[:g.max_stocks]\n\ndef run_backtest(start_date='2021-01-01', end_date='2024-12-31'):\n    \"\"\"运行回测\"\"\"\n    print(f\"开始回测: {start_date} - {end_date}\")\n    \n    # 加载数据\n    stocks_df = load_stock_data()\n    financial_df = load_financial_data()\n    \n    if stocks_df is None:\n        print(\"无法加载数据\")\n        return\n    \n    # 转换日期格式\n    stocks_df['trade_date'] = pd.to_datetime(stocks_df['trade_date'])\n    \n    # 生成交易日期\n    trade_dates = sorted(stocks_df['trade_date'].unique())\n    trade_dates = [d for d in trade_dates if start_date <= str(d)[:10] <= end_date]\n    \n    print(f\"共 {len(trade_dates)} 个交易日\")","newText":"\"\"\"\n这是一个简单的策略-91 优化版\n基于聚宽用户的策略，在本地用Tushare数据回测\n\n优化方向：\n1. 添加更严格的止损（-8%）\n2. 添加财务过滤（ROE>0）\n3. 添加空仓月（1月、4月）\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nimport os\n\n# 数据路径\nDATA_DIR = os.path.expanduser(\"~/.openclaw/workspace/quant_system/data\")\n\nclass Strategy:\n    def __init__(self):\n        self.stock_pool = []\n        self.buy_list = []\n        self.hold_days = {}\n        self.positions = {}\n        self.cash = 1000000\n        \n        # 策略参数\n        self.max_stocks = 3\n        self.hold_days_max = 3\n        self.stop_loss = -0.08\n        self.market_cap_min = 10\n        self.market_cap_max = 100\n\ndef load_stock_data():\n    \"\"\"加载股票数据\"\"\"\n    files = []\n    for f in os.listdir(DATA_DIR):\n        if f.endswith('.csv') and 'financial' not in f:\n            files.append(os.path.join(DATA_DIR, f))\n    \n    if not files:\n        print(\"未找到股票数据文件\")\n        return None\n    \n    dfs = []\n    for f in files:\n        try:\n            df = pd.read_csv(f)\n            dfs.append(df)\n        except:\n            pass\n    \n    if dfs:\n        data = pd.concat(dfs, ignore_index=True)\n        return data\n    return None\n\ndef load_financial_data():\n    \"\"\"加载财务数据\"\"\"\n    fin_file = os.path.join(DATA_DIR, 'financial_tushare.csv')\n    if os.path.exists(fin_file):\n        return pd.read_csv(fin_file)\n    return None\n\ndef filter_stocks(date, stocks_df, s):\n    \"\"\"过滤股票\"\"\"\n    available = stocks_df[stocks_df['trade_date'] == date].copy()\n    \n    if len(available) == 0:\n        return []\n    \n    # 市值过滤 (10-100亿)\n    available = available[\n        (available['total_mv'] >= s.market_cap_min * 100000000) &\n        (available['total_mv'] <= s.market_cap_max * 100000000)\n    ]\n    \n    # 股价过滤 (3-50元)\n    available = available[\n        (available['close'] >= 3) & \n        (available['close'] <= 50)\n    ]\n    \n    # 按市值排序，选最小的\n    available = available.sort_values('total_mv', ascending=True)\n    \n    return available['ts_code'].tolist()[:s.max_stocks]\n\ndef run_backtest(start_date='2021-01-01', end_date='2024-12-31'):\n    \"\"\"运行回测\"\"\"\n    print(f\"开始回测: {start_date} - {end_date}\")\n    \n    stocks_df = load_stock_data()\n    financial_df = load_financial_data()\n    \n    if stocks_df is None:\n        print(\"无法加载数据\")\n        return\n    \n    # 转换日期格式\n    stocks_df['trade_date'] = stocks_df['trade_date'].astype(str)\n    \n    # 生成交易日期\n    trade_dates = sorted(stocks_df['trade_date'].unique())\n    trade_dates = [d for d in trade_dates if start_date.replace('-','') <= d <= end_date.replace('-','')]\n    \n    print(f\"共 {len(trade_dates)} 个交易日\")\n    \n    # 初始化策略\n    s = Strategy()"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":68884,"output":1850,"cacheRead":19905,"cacheWrite":0,"totalTokens":90639,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772626169737}}
