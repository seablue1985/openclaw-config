     d.loc[d['pct_20']>0.15, 'score'] = 5\n            d.loc[(d['pct_20']>0.1)&(d['pct_20']<=0.15), 'score'] = 3\n            d.loc[(d['pct_20']>0.05)&(d['pct_20']<=0.1), 'score'] = 1\n            d.loc[d['close']>d['ma20'], 'score'] = d['score'].fillna(0) + 2\n            d['score'] = d['score'].fillna(0)\n            d = d.sort_values('score', ascending=False)\n            \n            for stock in d['ts_code'].tolist()[:max_stocks*2]:\n                if len(positions) >= max_stocks: break\n                if stock in positions: continue\n                d2 = df[(df['ts_code']==stock) & (df['trade_date']==date)]\n                if len(d2) > 0:\n                    p = d2['open'].values[0]\n                    shares = int(cash / max_stocks / p / 100) * 100\n                    if shares > 0:\n                        cost = shares * p * 1.001\n                        if cost <= cash:\n                            cash -= cost\n                            positions[stock] = {'shares': shares, 'cost': p}\n                            hold_days[stock] = 0\n    \n    total = cash + sum(pos['shares'] * df[(df['ts_code']==s) & (df['trade_date']==date)]['close'].values[0] for s,pos in positions.items() if len(df[(df['ts_code']==s) & (df['trade_date']==date)])>0)\n    portfolio.append(total)\n\n# 完整结果\ninit = 1000000\nfinal = portfolio[-1]\nret = (final-init)/init*100\nyears = len(trade_dates)/252\nann = ((final/init)**(1/years)-1)*100\n\npeak, mdd = init, 0\nfor v in portfolio:\n    if v > peak: peak = v\n    dd = (peak-v)/peak\n    if dd > mdd: mdd = dd\n\nrets = np.diff(portfolio)/np.array(portfolio)[:-1]\nsharpe = np.mean(rets)/np.std(rets)*np.sqrt(252) if np.std(rets)>0 else 0\n\nprint(f'''\n========================================\n策略91 创业板完整版\n========================================\n初始: {init:,.0f}\n最终: {final:,.0f}\n总收益: {ret:.2f}%\n年化: {ann:.2f}%\n最大回撤: {-mdd*100:.2f}%\n夏普: {sharpe:.2f}\n========================================''')\n\"","timeout":180}}],"api":"