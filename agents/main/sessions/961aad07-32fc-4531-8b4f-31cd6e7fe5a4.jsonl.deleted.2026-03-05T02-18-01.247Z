roupby('ts_code')['vol'].transform(lambda x: x.rolling(20).mean())\n\ncash = 1000000\npositions = {}\nhold_days = {}\nmax_stocks = 7\n\nfor i, date in enumerate(trade_dates):\n    is_reb = (i % 5 == 1)\n    \n    # 卖出\n    stocks_sell = []\n    for stock in list(positions.keys()):\n        hold_days[stock] = hold_days.get(stock, 0) + 1\n        d = df[(df['ts_code']==stock) & (df['trade_date']==date)]\n        if len(d) == 0: continue\n        cur = d['close'].values[0]\n        pnl = (cur - positions[stock]['cost']) / positions[stock]['cost']\n        if pnl <= -0.10 or pnl >= 0.35 or hold_days[stock] >= 5:\n            stocks_sell.append(stock)\n    \n    for stock in stocks_sell:\n        d = df[(df['ts_code']==stock) & (df['trade_date']==date)]\n        if len(d) > 0:\n            cash += positions[stock]['shares'] * d['high'].values[0] * 0.999\n            del positions[stock]\n            hold_days.pop(stock, None)\n    \n    # 买入 - 不做财务过滤\n    if is_reb and len(positions) < max_stocks:\n        d = df[(df['trade_date']==date) & (df['close']>=3) & (df['close']<=50)]\n        if len(d) > 0:\n            d = d.copy()\n            # 得分\n            d.loc[d['pct_20']>0.15, 'score'] = 5\n            d.loc[(d['pct_20']>0.1)&(d['pct_20']<=0.15), 'score'] = 3\n            d.loc[(d['pct_20']>0.05)&(d['pct_20']<=0.1), 'score'] = 1\n            d.loc[d['close']>d['ma20'], 'score'] = d['score'].fillna(0) + 2\n            d['score'] = d['score'].fillna(0)\n            d = d.sort_values('score', ascending=False)\n            \n            for stock in d['ts_code'].tolist()[:max_stocks*2]:\n                if len(positions) >= max_stocks: break\n                if stock in positions: continue\n                d2 = df[(df['ts_code']==stock) & (df['trade_date']==date)]\n                if len(d2) > 0:\n                    p = d2['open'].values[0]\n                    shares = int(cash / max_stocks / p / 100) * 100\n                    if shares > 0:\n                        cost = shares * p * 1.001\n                        if cost <= cash:\n                            cash -= cost\n                            positions[stock] = {'shares': shares, 'cost': p}\n                            hold_days[stock] = 0\n\n# 最终价值\ntotal = cash\nfor stock, pos in positions.items():\n    d = df[(df['ts_code']==stock) & (df['trade_date']==trade_dates[-1])]\n    if len(d) > 0:\n        total += pos['shares'] * d['close'].values[0]\n\ninit = 1000000\nret = (total-init)/init*100\nyears = len(trade_dates)/252\nann = ((total/init)**(1/years)-1)*100 if years > 0 else 0\nprint(f'''\n========================================\n策略91 创业板50只版\n========================================\n初始: {init:,.0f}\n最终: {total:,.0f}\n总收益: {ret:.2f}%\n年化: {ann:.2f}%\n持仓: {len(positions)}\n========================================''')\n\"","name":"cd ~/.openclaw/workspace/quant_system","tail":"交易日: 727\n\n========================================\n策略91 创业板50只版\n========================================\n初始: 1,000,000\n最终: 33,120,843\n总收益: 3212.08%\n年化: 236.44%\n持仓: 7\n========================================\n","truncated":false,"exitCode":0},{"sessionId":"keen-zephyr","status":"completed","startedAt":1772631294965,"endedAt":1772631340199,"runtimeMs":45234,"cwd":"/Users/ling/.openclaw/workspace","command":"cd ~/.openclaw/workspace/quant_system && python3 -c \"\nimport pandas as pd\nimport numpy as np\nimport os\n\nDATA_DIR = 'data'\n\ndf = pd.read_csv(os.path.join(DATA_DIR, 'gem_daily_full.csv'))\ndf['trade_date'] = df['trade_date'].astype(str)\n\ntrade_dates = sorted(df['trade_date'].unique())\ntrade_dates = [d for d in trade_dates if '2021' <= d <= '2024']\n\ndf = df.sort_values(['ts_code', 'trade_date'])\ndf['pct_20'] = df.groupby('ts_code')['close'].pct_change(20)\ndf['ma20'] = df.groupby('ts_code')['close'].transform(lambda x: x.rolling(20).mean())\ndf['vol_ma20'] = df.groupby('ts_code')['vol'].transform(lambda x: x.rolling(20).mean())\n\ncash = 1000000\npositions = {}\nhold_days = {}\nmax_stocks = 7\nportfolio = [cash]\n\nfor i, date in enumerate(trade_dates):\n    is_reb = (i % 5 == 1)\n    \n    for stock in list(positions.keys()):\n        hold_days[stock] = hold_days.get(stock, 0) + 1\n        d = df[(df['ts_code']==stock) & (df['trade_date']==date)]\n        if len(d) == 0: continue\n        cur = d['close'].values[0]\n        pnl = (cur - positions[stock]['cost']) / positions[stock]['cost']\n        if pnl <= -0.10 or pnl >= 0.35 or hold_days[stock] >= 5:\n            cash += positions[stock]['shares'] * d['high'].values[0] * 0.999\n            del positions[stock]\n            hold_days.pop(stock, None)\n    \n    if is_reb and len(positions) < max_stocks:\n        d = df[(df['trade_date']==date) & (df['close']>=3) & (df['close']<=50)]\n        if len(d) > 0:\n            d = d.copy()\n            d.loc[d['pct_20']>0.15, 'score'] = 5\n            d.loc[(d['pct_20']>0.1)&(d['pct_20']<=0.15), 'score'] = 3\n            d.loc[(d['pct_20']>0.05)&(d['pct_20']<=0.1), 'score'] = 1\n            d.loc[d['close']>d['ma20'], 'score'] = d['score'].fillna(0) + 2\n            d['score'] = d['score'].fillna(0)\n            d = d.sort_values('score', ascending=False)\n            \n            for stock in d['ts_code'].tolist()[:max_stocks*2]:\n                if len(positions) >= max_stocks: break\n                if stock in positions: continue\n                d2 = df[(df['ts_code']==stock) & (df['trade_date']==date)]\n                if len(d2) > 0:\n                    p = d2['open'].values[0]\n                    shares = int(cash / max_stocks / p / 100) * 100\n                    if shares > 0:\n                        cost = shares * p * 1.001\n                        if cost <= cash:\n                            cash -= cost\n                            positions[stock] = {'shares': shares, 'cost': p}\n                            hold_days[stock] = 0\n    \n    total = cash + sum(pos['shares'] * df[(df['ts_code']==s) & (df['trade_date']==date)]['close'].values[0] for s,pos in positions.items() if len(df[(df['ts_code']==s) & (df['trade_date']==date)])>0)\n    portfolio.append(total)\n\n# 完整结果\ninit = 1000000\nfinal = portfolio[-1]\nret = (final-init)/init*100\nyears = len(trade_dates)/252\nann = ((final/init)**(1/years)-1)*100\n\npeak, mdd = init, 0\nfor v in portfolio:\n    if v > peak: peak = v\n    dd = (peak-v)/peak\n    if dd > mdd: mdd = dd\n\nrets = np.diff(portfolio)/np.array(portfolio)[:-1]\nsharpe = np.mean(rets)/np.std(rets)*np.sqrt(252) if np.std(rets)>0 else 0\n\nprint(f'''\n========================================\n策略91 创业板完整版\n========================================\n初始: {init:,.0f}\n最终: {final:,.0f}\n总收益: {ret:.2f}%\n年化: {ann:.2f}%\n最大回撤: {-mdd*100:.2f}%\n夏普: {sharpe:.2f}\n========================================''')\n\"","name":"cd ~/.openclaw/workspace/quant_system","tail":"\n========================================\n策略91 创业板完整版\n========================================\n初始: 1,000,000\n最终: 33,120,843\n总收益: 3212.08%\n年化: 236.44%\n最大回撤: -11.71%\n夏普: 4.01\n========================================\n","truncated":false,"exitCode":0}]},"isError":false,"timestamp":1772631744340}}
