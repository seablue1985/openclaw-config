{"type":"message","id":"6c15a23b","parentId":"063d23a5","timestamp":"2026-03-03T23:23:36.079Z","message":{"role":"toolResult","toolCallId":"call_function_oohaawwcrecg_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n小市值策略回测\n基于历史数据的策略回测\n\"\"\"\nimport os\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\n\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'data')\n\ndef load_all_data():\n    \"\"\"加载所有数据\"\"\"\n    basic = pd.read_csv(f'{DATA_DIR}/stock_basic.csv')\n    \n    # 优先使用完整数据\n    if os.path.exists(f'{DATA_DIR}/daily_basic_all.csv'):\n        daily = pd.read_csv(f'{DATA_DIR}/daily_basic_all.csv')\n        print(f\"📊 使用完整数据: {daily.ts_code.nunique()} 只股票\")\n    else:\n        daily = pd.read_csv(f'{DATA_DIR}/daily_basic_500.csv')\n        print(f\"⚠️ 使用样本数据: 500 只\")\n    \n    return basic, daily\n\ndef get_universe_by_date(date, daily_df):\n    \"\"\"获取指定日期的股票池\"\"\"\n    df = daily_df[daily_df['trade_date'] == int(date)].copy()\n    df['circ_mv_yi'] = df['circ_mv'] / 10000\n\n[192 more lines in file. Use offset=31 to continue.]"}],"isError":false,"timestamp":1772580216073}}
{"type":"message","id":"75ca7201","parentId":"6c15a23b","timestamp":"2026-03-03T23:23:43.881Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"我需要修改 load_all_data 函数来支持加载指定年份的数据。让我添加一个参数来选择加载哪些年份的数据。","thinkingSignature":"1855913aada2d31672341cb40e8989d18d444742a55fbbcdb3f76120f4406537"},{"type":"toolCall","id":"call_function_p7fbclk91ghu_1","name":"edit","arguments":{"file_path":"/Users/ling/.openclaw/workspace/quant_system/backtest.py","newText":"def load_all_data(years=None):\n    \"\"\"加载所有数据\n    Args:\n        years: 要加载的年份列表，如 [2021, 2022]。如果为None，则加载默认数据。\n    \"\"\"\n    basic = pd.read_csv(f'{DATA_DIR}/stock_basic.csv')\n    \n    if years:\n        # 加载指定年份的数据\n        dfs = []\n        for year in years:\n            file_path = f'{DATA_DIR}/daily_{year}.csv'\n            if os.path.exists(file_path):\n                df = pd.read_csv(file_path)\n                dfs.append(df)\n                print(f\"📊 加载 {year} 年数据: {len(df)} 条记录\")\n        \n        if dfs:\n            daily = pd.concat(dfs, ignore_index=True)\n            print(f\"📊 合计加载: {daily.ts_code.nunique()} 只股票, {len(daily)} 条记录\")\n        else:\n            # 如果没有找到文件，回退到默认数据\n            if os.path.exists(f'{DATA_DIR}/daily_basic_all.csv'):\n                daily = pd.read_csv(f'{DATA_DIR}/daily_basic_all.csv')\n                print(f\"⚠️ 未找到历史数据文件，使用完整数据\")\n            else:\n                daily = pd.read_csv(f'{DATA_DIR}/daily_basic_500.csv')\n                print(f\"⚠️ 使用样本数据: 500 只\")\n    else:\n        # 优先使用完整数据\n        if os.path.exists(f'{DATA_DIR}/daily_basic_all.csv'):\n            daily = pd.read_csv(f'{DATA_DIR}/daily_basic_all.csv')\n            print(f\"📊 使用完整数据: {daily.ts_code.nunique()} 只股票\")\n        else:\n            daily = pd.read_csv(f'{DATA_DIR}/daily_basic_500.csv')\n            print(f\"⚠️ 使用样本数据: 500 只\")\n    \n    return basic, daily","oldText":"def load_all_data():\n    \"\"\"加载所有数据\"\"\"\n    basic = pd.read_csv(f'{DATA_DIR}/s