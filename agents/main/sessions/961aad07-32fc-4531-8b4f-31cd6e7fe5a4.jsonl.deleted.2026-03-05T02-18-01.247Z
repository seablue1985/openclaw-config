{"type":"message","id":"8c537896","parentId":"837dfc6b","timestamp":"2026-03-04T13:13:12.719Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user wants to save the strategy. Let me save it as a proper Python file in the quant_system directory.","thinkingSignature":"4f9f6626a64ef5ed2bd21458386a348ab3c5fd42e60437d6f49c6d9f055609c5"},{"type":"toolCall","id":"call_function_sj3npmffaihq_1","name":"write","arguments":{"content":"\"\"\"\n策略91简化版 - 小市值轮动策略\n基于聚宽用户\"这是一个简单的策略-91\"核心逻辑移植\n\n策略特点：\n- 股价3-50元\n- ROE>0 财务过滤\n- 市值排序选小盘股\n- 止损10%，止盈35%\n- 每5天轮动\n\n回测结果(2021-2024):\n- 总收益: 54.94%\n- 年化: 16.39%\n- 最大回撤: 12.36%\n- 夏普: 2.24\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nimport os\n\nDATA_DIR = os.path.expanduser(\"~/.openclaw/workspace/quant_system/data\")\n\nclass Strategy91Simplified:\n    \"\"\"策略91简化版\"\"\"\n    \n    def __init__(self, initial_cash=1000000):\n        self.initial_cash = initial_cash\n        self.cash = initial_cash\n        self.positions = {}\n        self.hold_days = {}\n        \n        # 策略参数\n        self.max_stocks = 7          # 持仓数量\n        self.stop_loss = 0.90         # 止损10%\n        self.profit_take = 1.35       # 止盈35%\n        self.rebalance_days = 5       # 调仓周期(天)\n        self.price_min = 3            # 最低股价\n        self.price_max = 50           # 最高股价\n        \n    def load_data(self):\n        \"\"\"加载数据\"\"\"\n        # 加载价格数据\n        files = [os.path.join(DATA_DIR, f) for f in os.listdir(DATA_DIR) \n                 if f.startswith('daily_') and 'financial' not in f and 'basic' not in f]\n        dfs = [pd.read_csv(f) for f in files]\n        df = pd.concat(dfs, ignore_index=True)\n        df = df.dropna(subset=['trade_date', 'ts_code', 'close', 'total_mv'])\n        df['trade_date'] = df['trade_date'].astype(str)\n        \n        # 加载财务数据\n        fin = pd.read_csv(os.path.join(DATA_DIR, 'financial_tushare.csv'))\n        self.valid_stocks = set(fin[fin['roe'] > 0]['ts_code'].unique())\n        \n        return df\n    \n    def select_stocks(self, df, date, n=30):\n        \"\"\"选股\"\"\"\n        # 基础过滤\n        d = df[(df['trade_date'] == date) & \n                (df['close'] >= self.price_min) & \n                (df['close'] <= self.price_max)]\n        \n        # 财务过滤\n        d = d[d['ts_code'].isin(self.valid_stocks)]\n        \n        if len(d) == 0:\n            return []\n        \n        # 按市值升序排列，取最小的n只\n        d = d.sort_values('total_mv')\n        return d['ts_code'].tolist()[:n]\n    \n    def should_sell(self, current_price, cost):\n        \"\"\"判断是否卖出\"\"\"\n        pnl = (current_price - cost) / cost\n        return pnl <= (self.stop_loss - 1) or pnl >= (self.profit_take - 1)\n    \n    def run_backtest(self, start_date='20210101', end_date='20241231'):\n        \"\"\"运行回测\"\"\"\n        print(\"=\" * 50)\n        print(\"策略91简化版 回测\")\n        print(\"=\" * 50)\n        \n        df = self.load_data()\n        \n        # 交易日\n        trade_dates = sorted(df['trade_date'].unique())\n        trade_dates = [d for d in trade_dates if start_date <= d <= end_date]\n        print(f\"交易日: {len(trade_dates)}\")\n        \n        portfolio = [self.cash]\n        \n        for i, date in enumerate(trade_dates):\n            is_rebalance = (i > 0 and i % self.rebalance_days == 0)\n            \n            # ===== 卖出处理 =====\n            stocks_to_sell = []\n            \n            for stock in list(self.positions.keys()):\n                self.hold_days[stock] = self.hold_days.get(stock, 0) + 1\n                \n                price_data = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n                if len(price_data) == 0:\n                    continue\n                \n                current_price = price_data.values[0]\n                cost = self.positions[stock]['cost']\n                \n                # 止损/止盈检查\n                if self.should_sell(current_price, cost):\n                    stocks_to_sell.append(stock)\n            \n            # 执行卖出\n            for stock in stocks_to_sell:\n                price_data = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n                if len(price_data) > 0:\n                    sell_price = price_data.values[0]\n                    shares = self.positions[stock]['shares']\n                    self.cash += shares * sell_price * 0.999  # 手续费\n                    del self.positions[stock]\n                    if stock in self.hold_days:\n                        del self.hold_days[stock]\n            \n            # ===== 买入处理 =====\n            if is_rebalance:\n                buy_list = self.select_stocks(df, date, n=self.max_stocks * 2)\n                \n                for stock in buy_list:\n                    if len(self.positions) >= self.max_stocks:\n                        break\n                    if stock in self.positions:\n                        continue\n                    \n                    price_data = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n                    if len(price_data) > 0:\n                        buy_price = price_data.values[0]\n                        # 均分资金\n                        max_position = self.cash / (self.max_stocks - len(self.positions))\n                        shares = int(max_position / buy_price / 100) * 100  # 整手\n                        \n                        if shares > 0:\n                            cost = shares * buy_price * 1.001  # 手续费\n                            if cost <= self.cash:\n                                self.cash -= cost\n                                self.positions[stock] = {\n                                    'shares': shares,\n                                    'cost': buy_price\n                                }\n                                self.hold_days[stock] = 0\n            \n            # ===== 记录组合价值 =====\n            total_value = self.cash\n            for stock, pos in self.positions.items():\n                price_data = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n                if len(price_data) > 0:\n                    total_value += pos['shares'] * price_data.values[0]\n            \n            portfolio.append(total_value)\n        \n        # ===== 计算结果 =====\n        initial = self.initial_cash\n        final = portfolio[-1]\n        \n        total_return = (final - initial) / initial * 100\n        years = len(trade_dates) / 252\n        annual_return = ((final / initial) ** (1 / years) - 1) * 100\n        \n        # 最大回撤\n        peak = initial\n        max_drawdown = 0\n        for v in portfolio:\n            if v > peak:\n                peak = v\n            dd = (peak - v) / peak\n            if dd > max_drawdown:\n                max_drawdown = dd\n        \n        # 夏普比率\n        returns = np.diff(portfolio) / np.array(portfolio)[:-1]\n        sharpe = np.mean(returns) / np.std(returns) * np.sqrt(252) if np.std(returns) > 0 else 0\n        \n        print(f\"\\n{'=' * 50}\")\n        print(\"回测结果\")\n        print(f\"{'=' * 50}\")\n        print(f\"时间范围: {start_date} - {end_date}\")\n        print(f\"初始资金: {initial:,.0f}\")\n        print(f\"最终价值: {final:,.0f}\")\n        print(f\"总收益率: {total_return:.2f}%\")\n        print(f\"年化收益率: {annual_return:.2f}%\")\n        print(f\"最大回撤: {-max_drawdown * 100:.2f}%\")\n        print(f\"夏普比率: {sharpe:.2f}\")\n        print(f\"{'=' * 50}\")\n        \n        return {\n            'total_return': total_return,\n            'annual_return': annual_return,\n            'max_drawdown': -max_drawdown * 100,\n            'sharpe': sharpe\n        }\n\n\ndef main():\n    \"\"\"主函数\"\"\"\n    strategy = Strategy91Simplified(initial_cash=1000000)\n    strategy.run_backtest('20210101', '20241231')\n\n\nif __name__ == \"__main__\":\n    main()\n","file_path":"/Users/ling/.openclaw/workspace/quant_system/strategy91_simplified.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":36,"output":1954,"cacheRead":9476,"cacheWrite":110288,"totalTokens":121754,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772629957873}}
