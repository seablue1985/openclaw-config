df = daily[daily['trade_date']==trade_date].copy()\n            if len(day_df)==0: continue\n            \n            day_df['mv'] = day_df['circ_mv']/10000\n            day_df = day_df[(day_df['mv']<=50)&(day_df['mv']>0)&(day_df['pe']>0)&(day_df['pe']<80)]\n            if len(day_df)==0: continue\n            \n            scored = []\n            for _, r in day_df.iterrows():\n                score = calculate_momentum(daily, r['ts_code'], trade_date)\n"},"partialJson":"{\"command\": \"cd ~/.openclaw/workspace/daily_stock_analysis && python3 << 'EOF'\\nimport os\\nimport pandas as pd\\nimport numpy as np\\nfrom datetime import datetime\\n\\nDATA_DIR = 'data'\\n\\ndef load_data(years):\\n    dfs = []\\n    for year in years:\\n        path = f'{DATA_DIR}/daily_{year}.csv'\\n        if os.path.exists(path):\\n            dfs.append(pd.read_csv(path))\\n    return pd.concat(dfs, ignore_index=True) if dfs else None\\n\\ndef calculate_momentum(df, ts_code, trade_date):\\n    stock = df[(df['ts_code'] == ts_code) & (df['trade_date'] < trade_date)].sort_values('trade_date').tail(30)\\n    if len(stock) < 20:\\n        return 0\\n    current = stock['close'].iloc[-1]\\n    prices = stock['close'].values\\n    ma5, ma10, ma20 = np.mean(prices[-5:]), np.mean(prices[-10:]), np.mean(prices[-20:])\\n    score = 0\\n    if ma5 > ma10 > ma20: score += 0.5\\n    elif ma5 > ma10: score += 0.3\\n    if current > ma20: score += 0.3\\n    if len(prices) >= 10:\\n        ret = (current - prices[-10]) / prices[-10]\\n        if ret > 0.05: score += 0.2\\n    return min(score, 1.0)\\n\\n# 测试不同参数\\ndaily = load_data([2021,2022,2023,2024])\\ndates = sorted(daily['trade_date'].unique())\\nweekly = [d for d in dates if datetime.strptime(str(d),'%Y%m%d').weekday()==1]\\n\\nbest_result = None\\nbest_params = None\\n\\nfor stock_num in [5, 8, 10, 15]:\\n    for stop_loss in [-0.08, -0.10, -0.15]:\\n        prev = {}\\n        returns = []\\n        \\n        for i, trade_date in enumerate(w