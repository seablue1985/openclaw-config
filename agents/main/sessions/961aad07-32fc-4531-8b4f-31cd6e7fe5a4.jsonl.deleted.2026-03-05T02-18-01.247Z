{"type":"message","id":"8c86542e","parentId":"7a46e4a6","timestamp":"2026-03-04T13:18:31.112Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The issue is that the scoring function is too slow because it's iterating over stocks and calculating historical data for each one. Let me optimize it significantly by using vectorized operations and simplifying the logic.","thinkingSignature":"9adadf0829a981b5576641209a83b63a0584e36af8a70256423b962b46669777"},{"type":"text","text":"太慢了，我优化一下算法：\n"},{"type":"toolCall","id":"call_function_ra7gpt9s01yn_1","name":"write","arguments":{"content":"\"\"\"\n策略91完整版 - 优化版\n使用向量化操作加速回测\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nimport os\n\nDATA_DIR = os.path.expanduser(\"~/.openclaw/workspace/quant_system/data\")\n\ndef run_backtest():\n    print(\"=\" * 50)\n    print(\"策略91完整版 回测\")\n    print(\"=\" * 50)\n    \n    # 加载数据\n    files = [os.path.join(DATA_DIR, f) for f in os.listdir(DATA_DIR) \n             if f.startswith('daily_') and 'financial' not in f and 'basic' not in f]\n    dfs = [pd.read_csv(f) for f in files]\n    df = pd.concat(dfs, ignore_index=True)\n    df = df.dropna(subset=['trade_date', 'ts_code', 'close', 'total_mv'])\n    df['trade_date'] = df['trade_date'].astype(str)\n    \n    # 财务数据\n    fin = pd.read_csv(os.path.join(DATA_DIR, 'financial_tushare.csv'))\n    valid_stocks = set(fin[fin['roe'] > 0]['ts_code'].unique())\n    \n    # 交易日\n    trade_dates = sorted(df['trade_date'].unique())\n    trade_dates = [d for d in trade_dates if '2021' <= d <= '2024']\n    print(f\"交易日: {len(trade_dates)}\")\n    \n    # 预计算每日涨幅\n    print(\"预计算涨幅数据...\")\n    df = df.sort_values(['ts_code', 'trade_date'])\n    df['prev_close'] = df.groupby('ts_code')['close'].shift(1)\n    df['pct_change'] = (df['close'] - df['prev_close']) / df['prev_close']\n    \n    # 预计算20日涨幅\n    df['pct_change_20'] = df.groupby('ts_code')['close'].pct_change(periods=20)\n    \n    # 策略参数\n    cash = 1000000\n    positions = {}\n    hold_days = {}\n    max_stocks = 7\n    stop_loss = 0.90\n    profit_take = 1.35\n    price_min = 3\n    price_max = 50\n    \n    portfolio = [cash]\n    \n    # 每周调仓\n    for i, date in enumerate(trade_dates):\n        # 每周二调仓\n        is_rebalance = (i % 5 == 1)\n        \n        # ===== 卖出 =====\n        stocks_to_sell = []\n        \n        for stock in list(positions.keys()):\n            hold_days[stock] = hold_days.get(stock, 0) + 1\n            \n            price_data = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n            if len(price_data) == 0:\n                continue\n            \n            current_price = price_data.values[0]\n            cost = positions[stock]['cost']\n            pnl = (current_price - cost) / cost\n            \n            # 止损/止盈/到期\n            if pnl <= stop_loss - 1 or pnl >= profit_take - 1 or hold_days[stock] >= 5:\n                stocks_to_sell.append(stock)\n        \n        # 执行卖出\n        for stock in stocks_to_sell:\n            price_data = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n            if len(price_data) > 0:\n                sell_price = price_data.values[0]\n                shares = positions[stock]['shares']\n                cash += shares * sell_price * 0.999\n                del positions[stock]\n                if stock in hold_days:\n                    del hold_days[stock]\n        \n        # ===== 买入 =====\n        if is_rebalance:\n            # 选股\n            d = df[(df['trade_date'] == date) & \n                    (df['close'] >= price_min) & \n                    (df['close'] <= price_max) &\n                    (df['ts_code'].isin(valid_stocks))]\n            \n            if len(d) > 0:\n                # 按市值排序\n                d = d.sort_values('total_mv')\n                \n                # 取前50只候选\n                candidates = d.head(50)\n                \n                # 计算得分 (简化版)\n                scored = []\n                for _, row in candidates.iterrows():\n                    stock = row['ts_code']\n                    change_20 = row.get('pct_change_20', 0)\n                    if pd.isna(change_20):\n                        change_20 = 0\n                    \n                    # 得分 = 基础分 + 涨幅分\n                    score = (50 - list(candidates['ts_code']).index(stock)) + change_20 * 100\n                    scored.append((stock, score))\n                \n                scored.sort(key=lambda x: x[1], reverse=True)\n                buy_list = [s[0] for s in scored[:max_stocks]]\n                \n                for stock in buy_list:\n                    if len(positions) >= max_stocks:\n                        break\n                    if stock in positions:\n                        continue\n                    \n                    price_data = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n                    if len(price_data) > 0:\n                        buy_price = price_data.values[0]\n                        max_pos = cash / (max_stocks - len(positions))\n                        shares = int(max_pos / buy_price / 100) * 100\n                        \n                        if shares > 0:\n                            cost_val = shares * buy_price * 1.001\n                            if cost_val <= cash:\n                                cash -= cost_val\n                                positions[stock] = {'shares': shares, 'cost': buy_price}\n                                hold_days[stock] = 0\n        \n        # 记录价值\n        total = cash\n        for stock, pos in positions.items():\n            price_data = df[(df['ts_code'] == stock) & (df['trade_date'] == date)]['close']\n            if len(price_data) > 0:\n                total += pos['shares'] * price_data.values[0]\n        portfolio.append(total)\n    \n    # 结果\n    initial = 1000000\n    final = portfolio[-1]\n    ret = (final - initial) / initial * 100\n    years = len(trade_dates) / 252\n    ann = ((final / initial) ** (1 / years) - 1) * 100\n    \n    peak, mdd = initial, 0\n    for v in portfolio:\n        if v > peak: peak = v\n        dd = (peak - v) / peak\n        if dd > mdd: mdd = dd\n    \n    rets = np.diff(portfolio) / np.array(portfolio)[:-1]\n    sharpe = np.mean(rets) / np.std(rets) * np.sqrt(252) if np.std(rets) > 0 else 0\n    \n    print(f\"\"\"\n========================================\n策略91完整版 回测结果\n========================================\n初始: {initial:,.0f}\n最终: {final:,.0f}\n总收益: {ret:.2f}%\n年化: {ann:.2f}%\n回撤: {-mdd*100:.2f}%\n夏普: {sharpe:.2f}\n========================================\"\"\")\n\nif __name__ == \"__main__\":\n    run_backtest()\n","file_path":"/Users/ling/.openclaw/workspace/quant_system/strategy91_full_v2.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":106098,"output":1674,"cacheRead":19905,"cacheWrite":0,"totalTokens":127677,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772630270643}}
