{"type":"message","id":"aec522c8","parentId":"a4be2255","timestamp":"2026-03-04T13:48:10.294Z","message":{"role":"toolResult","toolCallId":"call_function_o67xmj4vhq1i_1","toolName":"exec","content":[{"type":"text","text":"股票数: 500\n记录数: 603468\n列: ['ts_code', 'trade_date', 'open', 'high', 'low', 'close', 'pre_close', 'change', 'pct_chg', 'vol', 'amount']\n日期范围: 20200102 - 20241231\n     ts_code  trade_date   open  ...  pct_chg         vol       amount\n0  000001.SZ    20241231  11.93  ...  -2.0921  1475367.33  1747242.074\n1  000001.SZ    20241230  11.78  ...   1.0144  1351846.36  1610892.096\n2  000001.SZ    20241227  11.87  ...  -0.2530  1290012.28  1518383.345\n3  000001.SZ    20241226  11.92  ...  -0.5034  1000074.70  1183745.519\n4  000001.SZ    20241225  11.86  ...   0.5059  1475282.94  1759956.630\n\n[5 rows x 11 columns]"}],"details":{"status":"completed","exitCode":0,"durationMs":391,"aggregated":"股票数: 500\n记录数: 603468\n列: ['ts_code', 'trade_date', 'open', 'high', 'low', 'close', 'pre_close', 'change', 'pct_chg', 'vol', 'amount']\n日期范围: 20200102 - 20241231\n     ts_code  trade_date   open  ...  pct_chg         vol       amount\n0  000001.SZ    20241231  11.93  ...  -2.0921  1475367.33  1747242.074\n1  000001.SZ    20241230  11.78  ...   1.0144  1351846.36  1610892.096\n2  000001.SZ    20241227  11.87  ...  -0.2530  1290012.28  1518383.345\n3  000001.SZ    20241226  11.92  ...  -0.5034  1000074.70  1183745.519\n4  000001.SZ    20241225  11.86  ...   0.5059  1475282.94  1759956.630\n\n[5 rows x 11 columns]","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1772632090293}}
{"type":"message","id":"a0af3577","parentId":"aec522c8","timestamp":"2026-03-04T13:48:44.691Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"We have 500 stocks with 603,468 records from 2020-01-02 to 2024-12-31. This is excellent data. Now let me run the full strategy backtest with this data.","thinkingSignature":"707494c5820516055d44d362ef983f38f300fce046be94ae9d94d9e977787c94"},{"type":"text","text":"**数据下载完成！**\n\n| 项目 | 数量 |\n|------|------|\n| 股票数 | 500只 |\n| 记录数 | 60万+ |\n| 日期范围 | 2020-2024 |\n| 字段 | open/high/low/close/vol |\n\n现在用完整数据回测策略：\n"},{"type":"toolCall","id":"call_function_fm2b6je9u1p3_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && python3 -c \"\nimport pandas as pd\nimport numpy as np\n\nDATA = 'data'\n\ndf = pd.read_csv(f'{DATA}/all_stocks_daily.csv')\ndf['trade_date'] = df['trade_date'].astype(str)\ntrade_dates = sorted(df['trade_date'].unique())\ntrade_dates = [d for d in trade_dates if '2021' <= d <= '2024']\nprint(f'交易日: {len(trade_dates)}')\n\n# 预计算\ndf = df.sort_values(['ts_code', 'trade_date'])\ndf['pct_20'] = df.groupby('ts_code')['close'].pct_change(20)\ndf['ma20'] = df.groupby('ts_code')['close'].transform(lambda x: x.rolling(20).mean())\ndf['vol_ma20'] = df.groupby('ts_code')['vol'].transform(lambda x: x.rolling(20).mean())\n\ncash = 1000000\npositions = {}\nhold_days = {}\nmax_stocks = 7\n\nfor i, date in enumerate(trade_dates):\n    is_reb = (i % 5 == 1)\n    \n    for stock in list(positions.keys()):\n        hold_days[stock] = hold_days.get(stock, 0) + 1\n        d = df[(df['ts_code']==stock) & (df['trade_date']==date)]\n        if len(d) == 0: continue\n        pnl = (d['close'].values[0] - positions[stock]['cost']) / positions[stock]['cost']\n        if pnl <= -0.10 or pnl >= 0.35 or hold_days[stock] >= 5:\n            cash += positions[stock]['shares'] * d['high'].values[0] * 0.999\n            del positions[stock]\n            hold_days.pop(stock, None)\n    \n    if is_reb and len(positions) < max_stocks:\n        d = df[(df['trade_date']==date) & (df['close']>=3) & (df['close']<=50)]\n        if len(d) > 0:\n            d = d.copy()\n            d.loc[d['pct_20']>0.15, 'score'] = 5\n            d.loc[(d['pct_20']>0.1)&(d['pct_20']<=0.15), 'score'] = 3\n            d.loc[(d['pct_20']>0.05)&(d['pct_20']<=0.1), 'score'] = 1\n            d.loc[d['close']>d['ma20'], 'score'] = d['score'].fillna(0) + 2\n            d['score'] = d['score'].fillna(0)\n            d = d.sort_values('score', ascending=False)\n            \n            for stock in d['ts_code'].tolist()[:max_stocks*2]:\n                if len(positions) >= max_stocks: break\n                if stock in positions: continue\n                d2 = df[(df['ts_code']==stock) & (df['trade_date']==date)]\n                if len(d2) > 0:\n                    p = d2['open'].values[0]\n                    shares = int(cash / max_stocks / p / 100) * 100\n                    if shares > 0:\n                        cost = shares * p * 1.001\n                        if cost <= cash:\n                            cash -= cost\n                            positions[stock] = {'shares': shares, 'cost': p}\n                            hold_days[stock] = 0\n\ntotal = cash\nfor stock, pos in positions.items():\n    d = df[(df['ts_code']==stock) & (df['trade_date']==trade_dates[-1])]\n    if len(d) > 0:\n        total += pos['shares'] * d['close'].values[0]\n\ninit = 1000000\nret = (total-init)/init*100\nyears = len(trade_dates)/252\nann = ((total/init)**(1/years)-1)*100\nprint(f'''\n========================================\n策略91 全部A股500只版\n========================================\n初始: {init:,.0f}\n最终: {total:,.0f}\n总收益: {ret:.2f}%\n年化: {ann:.2f}%\n========================================''')\n\"","timeout":180}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":115714,"output":1090,"cacheRead":19954,"cacheWrite":0,"totalTokens":136758,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772632090295}}
