{"type":"message","id":"6662495d","parentId":"ec24af9b","timestamp":"2026-03-04T02:56:14.767Z","message":{"role":"toolResult","toolCallId":"call_function_ozkro7vtdu7k_1","toolName":"exec","content":[{"type":"text","text":"{\\rtf1\\ansi\\ansicpg936\\cocoartf2868\n\\cocoatextscaling0\\cocoaplatform0{\\fonttbl\\f0\\fswiss\\fcharset0 Helvetica;}\n{\\colortbl;\\red255\\green255\\blue255;}\n{\\*\\expandedcolortbl;;}\n\\paperw11900\\paperh16840\\margl1440\\margr1440\\vieww11520\\viewh8400\\viewkind0\n\\pard\\tx720\\tx1440\\tx2160\\tx2880\\tx3600\\tx4320\\tx5040\\tx5760\\tx6480\\tx7200\\tx7920\\tx8640\\pardirnatural\\partightenfactor0\n\n\\f0\\fs24 \\cf0 # \\uc0\\u23548 \\u20837 \\u20989 \\u25968 \\u24211 \r\\\nfrom jqdata import *\r\\\nfrom jqfactor import *\r\\\nimport numpy as np\r\\\nimport pandas as pd\r\\\nfrom datetime import time, datetime, timedelta\r\\\n\r\\\n# \\uc0\\u21021 \\u22987 \\u21270 \\u20989 \\u25968  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u20132 \\u26131 \\u29256 \\u26412 \r\\\ndef initialize(context):\r\\\n    # \\uc0\\u31227 \\u38500  avoid_future_data \\u35774 \\u32622 \\u65292 \\u23454 \\u26102 \\u20132 \\u26131 \\u20013 \\u26080 \\u25928 \r\\\n    # set_option('avoid_future_data', True)\r\\\n    \r\\\n    # \\uc0\\u35774 \\u23450 \\u22522 \\u20934 \r\\\n    set_benchmark('000001.XSHG')\r\\\n    # \\uc0\\u29992 \\u30495 \\u23454 \\u20215 \\u26684 \\u20132 \\u26131 \r\\\n    set_option('use_real_price', True)\r\\\n    # \\uc0\\u23558 \\u28369 \\u28857 \\u35774 \\u32622 \\u20026 0\r\\\n    set_slippage(FixedSlippage(3/10000))\r\\\n    # \\uc0\\u35774 \\u32622 \\u20132 \\u26131 \\u25104 \\u26412 \\u19975 \\u20998 \\u20043 \\u19977 \r\\\n    set_order_cost(OrderCost(open_tax=0, close_tax=0.001, \r\\\n                           open_commission=0.85/10000, close_commission=0.85/10000, \r\\\n                           close_today_commission=0, min_commission=0), type='stock')\r\\\n    \r\\\n    # \\uc0\\u36807 \\u28388 order\\u20013 \\u20302 \\u20110 error\\u32423 \\u21035 \\u30340 \\u26085 \\u24535 \r\\\n    log.set_level('order', 'error')\r\\\n    log.set_level('system', 'error')\r\\\n    \r\\\n    # \\uc0\\u21021 \\u22987 \\u21270 \\u20840 \\u23616 \\u21464 \\u37327  bool - \\u23436 \\u20840 \\u20445 \\u25345 \\u21407 \\u31574 \\u30053 \r\\\n    g.no_trading_today_signal = False\r\\\n    g.pass_april = False  # \\uc0\\u20462 \\u25913 \\u65306 \\u35774 \\u32622 \\u20026 False\\u65292 \\u21462 \\u28040 \\u31354 \\u20179 \r\\\n    g.run_stoploss = True\r\\\n    \r\\\n    # \\uc0\\u20840 \\u23616 \\u21464 \\u37327 list\r\\\n    g.hold_list = []\r\\\n    g.yesterday_HL_list = []\r\\\n    g.target_list = []\r\\\n    g.not_buy_again = []\r\\\n    \r\\\n    # \\uc0\\u20840 \\u23616 \\u21464 \\u37327 float/strs - \\u23436 \\u20840 \\u20445 \\u25345 \\u21407 \\u31574 \\u30053 \\u21442 \\u25968 \r\\\n    g.stock_num = 7\r\\\n    g.up_price = 100\r\\\n    g.reason_to_sell = ''\r\\\n    g.stoploss_strategy = 3\r\\\n    g.stoploss_limit = 0.88\r\\\n    g.stoploss_market = 0.94\r\\\n    g.HV_control = False\r\\\n    g.HV_duration = 120\r\\\n    g.HV_ratio = 0.9\r\\\n    \r\\\n    # \\uc0\\u35774 \\u32622 \\u20132 \\u26131 \\u36816 \\u34892 \\u26102 \\u38388  - \\u35843 \\u25972 \\u20026 \\u23454 \\u26102 \\u20132 \\u26131 \\u26102 \\u38388 \r\\\n    run_daily(prepare_stock_list, '9:05')\r\\\n    run_weekly(weekly_adjustment, 2, '10:30')\r\\\n    run_daily(sell_stocks, time='10:00')\r\\\n    run_daily(trade_afternoon, time='14:30')\r\\\n    run_daily(close_account, '14:50')\r\\\n    run_weekly(print_position_info, 5, time='15:10')\r\\\n\r\\\n# \\uc0\\u20934 \\u22791 \\u32929 \\u31080 \\u27744  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef prepare_stock_list(context):\r\\\n    g.hold_list = []\r\\\n    for position in list(context.portfolio.positions.values()):\r\\\n        stock = position.security\r\\\n        g.hold_list.append(stock)\r\\\n    \r\\\n    if g.hold_list != []:\r\\\n        # \\uc0\\u23454 \\u26102 \\u20132 \\u26131 \\u20013 \\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n        previous_date = context.previous_date\r\\\n        df = get_price(g.hold_list, end_date=previous_date, frequency='daily',\r\\\n                      fields=['close', 'high_limit', 'low_limit'], count=1, panel=False, fill_paused=False)\r\\\n        df = df[df['close'] == df['high_limit']]\r\\\n        g.yesterday_HL_list = list(df.code)\r\\\n    else:\r\\\n        g.yesterday_HL_list = []\r\\\n    \r\\\n    g.no_trading_today_signal = False  # \\uc0\\u20462 \\u25913 \\u65306 \\u30452 \\u25509 \\u35774 \\u32622 \\u20026 False\\u65292 \\u19981 \\u20877 \\u26816 \\u26597 \\u31354 \\u20179 \\u26399 \r\\\n\r\\\n# \\uc0\\u36873 \\u32929 \\u27169 \\u22359  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef get_stock_list(context):\r\\\n    final_list = []\r\\\n    MKT_index = '399101.XSHE'\r\\\n    initial_list = get_index_stocks(MKT_index)\r\\\n    \r\\\n    # \\uc0\\u23436 \\u20840 \\u20445 \\u25345 \\u21407 \\u31574 \\u30053 \\u30340 \\u36807 \\u28388 \\u26465 \\u20214 \r\\\n    initial_list = filter_new_stock(context, initial_list)\r\\\n    initial_list = filter_kcbj_stock(initial_list)\r\\\n    initial_list = filter_st_stock(initial_list)\r\\\n    initial_list = filter_paused_stock(initial_list)\r\\\n    initial_list = filter_limitup_stock(context, initial_list)\r\\\n    initial_list = filter_limitdown_stock(context, initial_list)\r\\\n    \r\\\n    # \\uc0\\u21407 \\u31574 \\u30053 \\u65306 \\u25353 \\u24066 \\u20540 \\u21319 \\u24207 \\u25490 \\u21015 \r\\\n    q = query(valuation.code, valuation.market_cap\r\\\n             ).filter(valuation.code.in_(initial_list)\r\\\n             ).order_by(valuation.market_cap.asc())\r\\\n    df = get_fundamentals(q)\r\\\n    stock_list = list(df.code)\r\\\n    stock_list = stock_list[:100]  # \\uc0\\u21462 \\u21069 100\\u21482 \\u23567 \\u24066 \\u20540 \\u32929 \\u31080 \r\\\n    \r\\\n    # \\uc0\\u21807 \\u19968 \\u20462 \\u25913 \\u65306 \\u22312 \\u26368 \\u32456 \\u36873 \\u32929 \\u26102 \\u21152 \\u20837 \\u31609 \\u30721 \\u23792 \\u26465 \\u20214 \\u20316 \\u20026 \\u25490 \\u24207 \\u22240 \\u32032 \r\\\n    # \\uc0\\u23545 \\u32929 \\u31080 \\u36827 \\u34892 \\u35780 \\u20998 \\u65306 \\u24066 \\u20540 \\u25490 \\u21517  + \\u31609 \\u30721 \\u23792 \\u21152 \\u20998 \r\\\n    scored_stocks = []\r\\\n    for stock in stock_list:\r\\\n        score = 0\r\\\n        # \\uc0\\u24066 \\u20540 \\u25490 \\u21517 \\u65288 \\u36234 \\u23567 \\u36234 \\u22909 \\u65289 \r\\\n        market_cap_rank = stock_list.index(stock)\r\\\n        score -= market_cap_rank  # \\uc0\\u24066 \\u20540 \\u36234 \\u23567 \\u65292 \\u20943 \\u20998 \\u36234 \\u23569 \\u65288 \\u23454 \\u38469 \\u25490 \\u21517 \\u38752 \\u21069 \\u65289 \r\\\n        \r\\\n        # \\uc0\\u31609 \\u30721 \\u23792 \\u26465 \\u20214 \\u21152 \\u20998 \r\\\n        chip_score = get_chip_score(context, stock)\r\\\n        score += chip_score * 10  # \\uc0\\u31609 \\u30721 \\u23792 \\u26465 \\u20214 \\u32473 \\u20104 \\u39069 \\u22806 \\u21152 \\u20998 \r\\\n        \r\\\n        scored_stocks.append((stock, score))\r\\\n    \r\\\n    # \\uc0\\u25353 \\u32508 \\u21512 \\u35780 \\u20998 \\u25490 \\u24207 \r\\\n    scored_stocks.sort(key=lambda x: x[1], reverse=True)\r\\\n    final_list = [stock for stock, score in scored_stocks]\r\\\n    \r\\\n    final_list = final_list[:2 * g.stock_num]\r\\\n    log.info('\\uc0\\u20170 \\u26085 \\u36873 \\u32929 \\u32467 \\u26524 :%s' % final_list[:10])\r\\\n    \r\\\n    return final_list\r\\\n\r\\\n# \\uc0\\u31609 \\u30721 \\u23792 \\u35780 \\u20998 \\u20989 \\u25968  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef get_chip_score(context, stock):\r\\\n    \"\"\"\r\\\n    \\uc0\\u36820 \\u22238 0-1\\u30340 \\u35780 \\u20998 \\u65292 1\\u34920 \\u31034 \\u23436 \\u20840 \\u31526 \\u21512 \\u31609 \\u30721 \\u23792 \\u26465 \\u20214 \\u65292 0\\u34920 \\u31034 \\u23436 \\u20840 \\u19981 \\u31526 \\u21512 \r\\\n    \\uc0\\u23454 \\u26102 \\u20132 \\u26131 \\u29256 \\u26412 \\u65292 \\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n    \"\"\"\r\\\n    try:\r\\\n        # \\uc0\\u23454 \\u26102 \\u20132 \\u26131 \\u20013 \\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n        end_date = context.previous_date\r\\\n        \r\\\n        # \\uc0\\u33719 \\u21462 \\u21382 \\u21490 \\u20215 \\u26684 \\u25968 \\u25454 , \\u33719 \\u21462 60\\u22825 \\u30340 \\u25968 \\u25454 \\u29992 \\u20110 \\u35745 \\u31639 \r\\\n        price_data = get_bars(stock, 60, '1d', ['close', 'high', 'low', 'volume'], \r\\\n                             include_now=False, end_dt=end_date)\r\\\n        \r\\\n        if len(price_data) < 31: # \\uc0\\u38656 \\u35201 \\u33267 \\u23569 30\\u22825 \\u21382 \\u21490 +1\\u22825 \\u24403 \\u21069 \r\\\n            return 0\r\\\n        \r\\\n        # \\uc0\\u23558 \\u25968 \\u25454 \\u26126 \\u30830 \\u20998 \\u31163 \\u65292 \\u36991 \\u20813 \\u26410 \\u26469 \\u20989 \\u25968 \r\\\n        current_price = price_data['close'][-1]         # T-1\\uc0\\u26085 \\u30340 \\u25910 \\u30424 \\u20215 \r\\\n        historical_data = price_data[:-1]               # T-60\\uc0\\u21040 T-2\\u26085 \\u30340 \\u25968 \\u25454 \r\\\n        \r\\\n        score = 0\r\\\n        \r\\\n        # 1. \\uc0\\u31609 \\u30721 \\u23494 \\u38598 \\u24230 \\u35780 \\u20998 \\u65288 \\u20215 \\u26684 \\u27874 \\u21160 \\u29575 \\u65289 \r\\\n        # \\uc0\\u20351 \\u29992 \\u26368 \\u36817 30\\u22825 \\u30340 \\u21382 \\u21490 \\u25968 \\u25454 \r\\\n        price_std = np.std(historical_data['close'][-30:])\r\\\n        avg_price = np.mean(historical_data['close'][-30:])\r\\\n        if avg_price > 0:\r\\\n            volatility = price_std / avg_price\r\\\n            if volatility < 0.12:  # \\uc0\\u27874 \\u21160 \\u29575 \\u23567 \\u65292 \\u31609 \\u30721 \\u23494 \\u38598 \r\\\n                score += 0.4\r\\\n            elif volatility < 0.18:\r\\\n                score += 0.2\r\\\n        \r\\\n        # 2. \\uc0\\u33719 \\u21033 \\u27604 \\u20363 \\u35780 \\u20998 \r\\\n        # \\uc0\\u20351 \\u29992 \\u26368 \\u36817 20\\u22825 \\u30340 \\u21382 \\u21490 \\u25968 \\u25454 \\u35745 \\u31639 \\u26368 \\u39640 \\u20215 \r\\\n        recent_high = max(historical_data['high'][-20:])\r\\\n        if recent_high > 0:\r\\\n            profit_ratio = current_price / recent_high\r\\\n            if profit_ratio > 0.85:  # \\uc0\\u33719 \\u21033 \\u27604 \\u20363 \\u39640 \r\\\n                score += 0.3\r\\\n            elif profit_ratio > 0.75:\r\\\n                score += 0.15\r\\\n        \r\\\n        # 3. \\uc0\\u31361 \\u30772 \\u21644 \\u25104 \\u20132 \\u37327 \\u35780 \\u20998 \r\\\n        # \\uc0\\u20351 \\u29992 \\u26368 \\u36817 20\\u22825 \\u30340 \\u21382 \\u21490 \\u25968 \\u25454 \\u35745 \\u31639 \\u39640 \\u20302 \\u28857 \r\\\n        recent_low = min(historical_data['low'][-20:])\r\\\n        range_mid = (recent_high + recent_low) / 2\r\\\n        if current_price > range_mid:  # \\uc0\\u31361 \\u30772 \\u20013 \\u36724 \r\\\n            score += 0.2\r\\\n        \r\\\n        # \\uc0\\u20351 \\u29992 \\u26368 \\u36817 10\\u22825 \\u30340 \\u21382 \\u21490 \\u25968 \\u25454 \\u35745 \\u31639 \\u25104 \\u20132 \\u37327 \r\\\n        vol_data = historical_data['volume'][-10:]\r\\\n        if len(vol_data) >= 5:\r\\\n            avg_vol_5 = np.mean(vol_data[-5:])\r\\\n            avg_vol_10 = np.mean(vol_data)\r\\\n            if avg_vol_5 > avg_vol_10 * 1.1:  # \\uc0\\u36817 \\u26399 \\u25918 \\u37327 \r\\\n                score += 0.1\r\\\n        \r\\\n        return min(score, 1.0)  # \\uc0\\u30830 \\u20445 \\u35780 \\u20998 \\u19981 \\u36229 \\u36807 1\r\\\n        \r\\\n    except Exception as e:\r\\\n        log.error(\"\\uc0\\u35745 \\u31639 \\u31609 \\u30721 \\u23792 \\u35780 \\u20998 \\u20986 \\u38169 : \\{\\}\".format(str(e)))\r\\\n        return 0\r\\\n\r\\\n# \\uc0\\u21608 \\u35843 \\u25972 \\u20989 \\u25968  - \\u20445 \\u25345 \\u21407 \\u36923 \\u36753 \r\\\ndef weekly_adjustment(context):\r\\\n    if g.no_trading_today_signal == False:\r\\\n        g.not_buy_again = []\r\\\n        g.target_list = get_stock_list(context)\r\\\n        target_list = g.target_list[:g.stock_num]\r\\\n        log.info(str(target_list))\r\\\n        \r\\\n        for stock in g.hold_list:\r\\\n            if (stock not in target_list) and (stock not in g.yesterday_HL_list):\r\\\n                log.info(\"\\uc0\\u21334 \\u20986 [%s]\" % (stock))\r\\\n                position = context.portfolio.positions[stock]\r\\\n                close_position(position)\r\\\n            else:\r\\\n                log.info(\"\\uc0\\u24050 \\u25345 \\u26377 [%s]\" % (stock))\r\\\n        \r\\\n        buy_security(context, target_list)\r\\\n        \r\\\n        for position in list(context.portfolio.positions.values()):\r\\\n            stock = position.security\r\\\n            g.not_buy_again.append(stock)\r\\\n\r\\\n# \\uc0\\u26816 \\u26597 \\u28072 \\u20572  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef check_limit_up(context):\r\\\n    current_data = get_current_data()\r\\\n    if g.yesterday_HL_list != []:\r\\\n        for stock in g.yesterday_HL_list:\r\\\n            if current_data[stock].paused:\r\\\n                continue\r\\\n            current_price = current_data[stock].last_price\r\\\n            high_limit = current_data[stock].high_limit\r\\\n            if current_price < high_limit:\r\\\n                log.info(\"[%s]\\uc0\\u28072 \\u20572 \\u25171 \\u24320 \\u65292 \\u21334 \\u20986 \" % (stock))\r\\\n                position = context.portfolio.positions[stock]\r\\\n                close_position(position)\r\\\n                g.reason_to_sell = 'limitup'\r\\\n            else:\r\\\n                log.info(\"[%s]\\uc0\\u28072 \\u20572 \\u65292 \\u32487 \\u32493 \\u25345 \\u26377 \" % (stock))\r\\\n\r\\\ndef check_remain_amount(context):\r\\\n    if g.reason_to_sell == 'limitup':\r\\\n        g.hold_list = []\r\\\n        for position in list(context.portfolio.positions.values()):\r\\\n            stock = position.security\r\\\n            g.hold_list.append(stock)\r\\\n        \r\\\n        if len(g.hold_list) < g.stock_num:\r\\\n            target_list = g.target_list\r\\\n            target_list = [stock for stock in target_list if stock not in g.not_buy_again]\r\\\n            target_list = target_list[:min(g.stock_num - len(g.hold_list), len(target_list))]\r\\\n            \r\\\n            if target_list and context.portfolio.cash > 0:\r\\\n                log.info('\\uc0\\u26377 \\u20313 \\u39069 \\u21487 \\u29992 '+str(round((context.portfolio.cash),2))+'\\u20803 \\u12290 '+ str(target_list))\r\\\n                buy_security(context, target_list)\r\\\n                g.reason_to_sell = ''\r\\\n            else:\r\\\n                log.info('\\uc0\\u34429 \\u28982 \\u26377 \\u20313 \\u39069 \\u21487 \\u29992 \\u65292 \\u20294 \\u26159 \\u20026 \\u27490 \\u25439 \\u21518 \\u20313 \\u39069 \\u65292 \\u19979 \\u21608 \\u20877 \\u20132 \\u26131 ')\r\\\n                g.reason_to_sell = ''\r\\\n\r\\\ndef trade_afternoon(context):\r\\\n    if g.no_trading_today_signal == False:\r\\\n        check_limit_up(context)\r\\\n        if g.HV_control == True:\r\\\n            check_high_volume(context)\r\\\n        check_remain_amount(context)\r\\\n\r\\\n# \\uc0\\u27490 \\u25439 \\u20989 \\u25968  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef sell_stocks(context):\r\\\n    if g.run_stoploss == True:\r\\\n        current_data = get_current_data()\r\\\n        if g.stoploss_strategy == 1:\r\\\n            for stock in context.portfolio.positions.keys():\r\\\n                if current_data[stock].paused:\r\\\n                    continue\r\\\n                position = context.portfolio.positions[stock]\r\\\n                # \\uc0\\u23454 \\u26102 \\u20132 \\u26131 \\u20013 \\u20351 \\u29992 \\u24403 \\u21069 \\u20215 \\u26684 \r\\\n                current_price = current_data[stock].last_price\r\\\n                avg_cost = position.avg_cost\r\\\n                if current_price >= avg_cost * 2:\r\\\n                    order_target_value(stock, 0)\r\\\n                    log.debug(\"\\uc0\\u25910 \\u30410 100%\\u27490 \\u30408 ,\\u21334 \\u20986 \\{\\}\".format(stock))\r\\\n                elif current_price < avg_cost * g.stoploss_limit:\r\\\n                    order_target_value(stock, 0)\r\\\n                    log.debug(\"\\uc0\\u25910 \\u30410 \\u27490 \\u25439 ,\\u21334 \\u20986 \\{\\}\".format(stock))\r\\\n                    g.reason_to_sell = 'stoploss'\r\\\n        elif g.stoploss_strategy == 2:\r\\\n            # \\uc0\\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n            index_data = get_price('399101.XSHE', end_date=context.previous_date,\r\\\n                                 frequency='daily', fields=['close', 'open'], count=2, fill_paused=False)\r\\\n            if len(index_data) >= 2:\r\\\n                prev_close = index_data['close'][-2]\r\\\n                prev_open = index_data['open'][-2]\r\\\n                if prev_open > 0:\r\\\n                    down_ratio = prev_close / prev_open\r\\\n                    if down_ratio <= g.stoploss_market:\r\\\n                        g.reason_to_sell = 'stoploss'\r\\\n                        log.debug(\"\\uc0\\u21069 \\u19968 \\u26085 \\u22823 \\u30424 \\u24808 \\u36300 ,\\u38477 \\u24133 \\{:.2%\\}\".format(1-down_ratio))\r\\\n                        for stock in context.portfolio.positions.keys():\r\\\n                            if not current_data[stock].paused:\r\\\n                                order_target_value(stock, 0)\r\\\n        elif g.stoploss_strategy == 3:\r\\\n            # \\uc0\\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n            index_data = get_price('399101.XSHE', end_date=context.previous_date,\r\\\n                                 frequency='daily', fields=['close', 'open'], count=2, fill_paused=False)\r\\\n            market_down = False\r\\\n            if len(index_data) >= 2:\r\\\n                prev_close = index_data['close'][-2]\r\\\n                prev_open = index_data['open'][-2]\r\\\n                if prev_open > 0:\r\\\n                    down_ratio = prev_close / prev_open\r\\\n                    if down_ratio <= g.stoploss_market:\r\\\n                        market_down = True\r\\\n                        g.reason_to_sell = 'stoploss'\r\\\n                        log.debug(\"\\uc0\\u21069 \\u19968 \\u26085 \\u22823 \\u30424 \\u24808 \\u36300 ,\\u38477 \\u24133 \\{:.2%\\}\".format(1-down_ratio))\r\\\n            for stock in context.portfolio.positions.keys():\r\\\n                if current_data[stock].paused:\r\\\n                    continue\r\\\n                position = context.portfolio.positions[stock]\r\\\n                # \\uc0\\u23454 \\u26102 \\u20132 \\u26131 \\u20013 \\u20351 \\u29992 \\u24403 \\u21069 \\u20215 \\u26684 \r\\\n                current_price = current_data[stock].last_price\r\\\n                avg_cost = position.avg_cost\r\\\n                if market_down:\r\\\n                    order_target_value(stock, 0)\r\\\n                    log.debug(\"\\uc0\\u22823 \\u30424 \\u27490 \\u25439 ,\\u21334 \\u20986 \\{\\}\".format(stock))\r\\\n                elif current_price < avg_cost * g.stoploss_limit:\r\\\n                    order_target_value(stock, 0)\r\\\n                    log.debug(\"\\uc0\\u25910 \\u30410 \\u27490 \\u25439 ,\\u21334 \\u20986 \\{\\}\".format(stock))\r\\\n                    g.reason_to_sell = 'stoploss'\r\\\n\r\\\n# \\uc0\\u39640 \\u25104 \\u20132 \\u37327 \\u26816 \\u26597  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef check_high_volume(context):\r\\\n    current_data = get_current_data()\r\\\n    for stock in context.portfolio.positions:\r\\\n        if current_data[stock].paused:\r\\\n            continue\r\\\n        if current_data[stock].last_price == current_data[stock].high_limit:\r\\\n            continue\r\\\n        if context.portfolio.positions[stock].closeable_amount == 0:\r\\\n            continue\r\\\n        # \\uc0\\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n        df_volume = get_bars(stock, count=g.HV_duration, unit='1d',\r\\\n                            fields=['volume'], include_now=False, df=True,\r\\\n                            end_dt=context.previous_date)\r\\\n        if len(df_volume) >= g.HV_duration-1:\r\\\n            historical_max_volume = df_volume['volume'].max()\r\\\n            prev_volume_data = get_bars(stock, count=2, unit='1d',\r\\\n                                      fields=['volume'], include_now=False, df=True,\r\\\n                                      end_dt=context.previous_date)\r\\\n            if len(prev_volume_data) >= 2:\r\\\n                prev_volume = prev_volume_data['volume'].iloc[-1]\r\\\n                if prev_volume > g.HV_ratio * historical_max_volume:\r\\\n                    log.info(\"[%s]\\uc0\\u22825 \\u37327 \\u65292 \\u21334 \\u20986 \" % stock)\r\\\n                    position = context.portfolio.positions[stock]\r\\\n                    close_position(position)\r\\\n\r\\\n# \\uc0\\u25152 \\u26377 \\u36807 \\u28388 \\u20989 \\u25968 \\u20445 \\u25345 \\u21407 \\u26679 \r\\\ndef filter_paused_stock(stock_list):\r\\\n    current_data = get_current_data()\r\\\n    return [stock for stock in stock_list if not current_data[stock].paused]\r\\\n\r\\\ndef filter_st_stock(stock_list):\r\\\n    current_data = get_current_data()\r\\\n    return [stock for stock in stock_list\r\\\n            if not current_data[stock].is_st\r\\\n            and 'ST' not in current_data[stock].name\r\\\n            and '*' not in current_data[stock].name\r\\\n            and '\\uc0\\u36864 ' not in current_data[stock].name]\r\\\n\r\\\ndef filter_kcbj_stock(stock_list):\r\\\n    return [stock for stock in stock_list\r\\\n            if not (stock.startswith('4') or stock.startswith('8') or stock.startswith('68'))]\r\\\n\r\\\ndef filter_limitup_stock(context, stock_list):\r\\\n    if len(stock_list) == 0:\r\\\n        return []\r\\\n    # \\uc0\\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n    prev_data = get_price(stock_list, end_date=context.previous_date,\r\\\n                         frequency='daily', fields=['close', 'high_limit'],\r\\\n                         count=1, panel=False, fill_paused=False)\r\\\n    current_data = get_current_data()\r\\\n    result = []\r\\\n    for stock in stock_list:\r\\\n        if stock in context.portfolio.positions:\r\\\n            result.append(stock)\r\\\n            continue\r\\\n        stock_data = prev_data[prev_data['code'] == stock]\r\\\n        if len(stock_data) == 0:\r\\\n            continue\r\\\n        if stock_data.iloc[0]['close'] < stock_data.iloc[0]['high_limit']:\r\\\n            result.append(stock)\r\\\n    return result\r\\\n\r\\\ndef filter_limitdown_stock(context, stock_list):\r\\\n    if len(stock_list) == 0:\r\\\n        return []\r\\\n    # \\uc0\\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n    prev_data = get_price(stock_list, end_date=context.previous_date,\r\\\n                         frequency='daily', fields=['close', 'low_limit'],\r\\\n                         count=1, panel=False, fill_paused=False)\r\\\n    current_data = get_current_data()\r\\\n    result = []\r\\\n    for stock in stock_list:\r\\\n        if stock in context.portfolio.positions:\r\\\n            result.append(stock)\r\\\n            continue\r\\\n        stock_data = prev_data[prev_data['code'] == stock]\r\\\n        if len(stock_data) == 0:\r\\\n            continue\r\\\n        if stock_data.iloc[0]['close'] > stock_data.iloc[0]['low_limit']:\r\\\n            result.append(stock)\r\\\n    return result\r\\\n\r\\\ndef filter_new_stock(context, stock_list):\r\\\n    yesterday = context.previous_date\r\\\n    return [stock for stock in stock_list\r\\\n            if not (yesterday - get_security_info(stock).start_date < timedelta(days=375))]\r\\\n\r\\\n# \\uc0\\u20132 \\u26131 \\u20989 \\u25968 \\u20445 \\u25345 \\u21407 \\u26679 \r\\\ndef order_target_value_(security, value):\r\\\n    if value == 0:\r\\\n        log.debug(\"Selling out %s\" % (security))\r\\\n    else:\r\\\n        log.debug(\"Order %s to value %f\" % (security, value))\r\\\n    return order_target_value(security, value)\r\\\n\r\\\ndef open_position(security, value):\r\\\n    order = order_target_value_(security, value)\r\\\n    if order != None and order.filled > 0:\r\\\n        return True\r\\\n    return False\r\\\n\r\\\ndef close_position(position):\r\\\n    security = position.security\r\\\n    order = order_target_value_(security, 0)\r\\\n    if order != None:\r\\\n        if order.status == OrderStatus.held and order.filled == order.amount:\r\\\n            return True\r\\\n    return False\r\\\n\r\\\ndef buy_security(context, target_list):\r\\\n    position_count = len(context.portfolio.positions)\r\\\n    target_num = len(target_list)\r\\\n    if target_num > position_count and context.portfolio.cash > 0:\r\\\n        value = context.portfolio.cash / (target_num - position_count)\r\\\n        for stock in target_list:\r\\\n            if context.portfolio.positions[stock].total_amount == 0:\r\\\n                if open_position(stock, value):\r\\\n                    log.info(\"\\uc0\\u20080 \\u20837 [%s]\\u65288 %s\\u20803 \\u65289 \" % (stock, value))\r\\\n                    g.not_buy_again.append(stock)\r\\\n                if len(context.portfolio.positions) == target_num:\r\\\n                    break\r\\\n\r\\\n# \\uc0\\u20854 \\u20182 \\u36741 \\u21161 \\u20989 \\u25968 \\u20445 \\u25345 \\u21407 \\u26679 \r\\\ndef today_is_between(context):\r\\\n    # \\uc0\\u20462 \\u25913 \\u65306 \\u30452 \\u25509 \\u36820 \\u22238 False\\u65292 \\u19981 \\u20877 \\u26816 \\u26597 \\u31354 \\u20179 \\u26399 \r\\\n    return False\r\\\n\r\\\ndef close_account(context):\r\\\n    # \\uc0\\u20462 \\u25913 \\u65306 \\u31227 \\u38500 \\u31354 \\u20179 \\u28165 \\u20179 \\u36923 \\u36753 \r\\\n    # \\uc0\\u19981 \\u20877 \\u22240 \\u31354 \\u20179 \\u26399 \\u32780 \\u28165 \\u20179 \\u65292 \\u21482 \\u22788 \\u29702 \\u20854 \\u20182 \\u24773 \\u20917 \r\\\n    pass\r\\\n\r\\\ndef print_position_info(context):\r\\\n    for position in list(context.portfolio.positions.values()):\r\\\n        securities = position.security\r\\\n        cost = position.avg_cost\r\\\n        price = position.price\r\\\n        ret = 100 * (price / cost - 1)\r\\\n        value = position.value\r\\\n        amount = position.total_amount\r\\\n        print('\\uc0\\u20195 \\u30721 :\\{\\}'.format(securities))\r\\\n        print('\\uc0\\u25104 \\u26412 \\u20215 :\\{\\}'.format(format(cost, '.2f')))\r\\\n        print('\\uc0\\u29616 \\u20215 :\\{\\}'.format(price))\r\\\n        print('\\uc0\\u25910 \\u30410 \\u29575 :\\{\\}%'.format(format(ret, '.2f')))\r\\\n        print('\\uc0\\u25345 \\u20179 (\\u32929 ):\\{\\}'.format(amount))\r\\\n        print('\\uc0\\u24066 \\u20540 :\\{\\}'.format(format(value, '.2f')))\r\\\n        print('-' * 100)\r\\\n    print('=' * 200)}"}],"details":{"status":"completed","exitCode":0,"durationMs":18,"aggregated":"{\\rtf1\\ansi\\ansicpg936\\cocoartf2868\n\\cocoatextscaling0\\cocoaplatform0{\\fonttbl\\f0\\fswiss\\fcharset0 Helvetica;}\n{\\colortbl;\\red255\\green255\\blue255;}\n{\\*\\expandedcolortbl;;}\n\\paperw11900\\paperh16840\\margl1440\\margr1440\\vieww11520\\viewh8400\\viewkind0\n\\pard\\tx720\\tx1440\\tx2160\\tx2880\\tx3600\\tx4320\\tx5040\\tx5760\\tx6480\\tx7200\\tx7920\\tx8640\\pardirnatural\\partightenfactor0\n\n\\f0\\fs24 \\cf0 # \\uc0\\u23548 \\u20837 \\u20989 \\u25968 \\u24211 \r\\\nfrom jqdata import *\r\\\nfrom jqfactor import *\r\\\nimport numpy as np\r\\\nimport pandas as pd\r\\\nfrom datetime import time, datetime, timedelta\r\\\n\r\\\n# \\uc0\\u21021 \\u22987 \\u21270 \\u20989 \\u25968  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u20132 \\u26131 \\u29256 \\u26412 \r\\\ndef initialize(context):\r\\\n    # \\uc0\\u31227 \\u38500  avoid_future_data \\u35774 \\u32622 \\u65292 \\u23454 \\u26102 \\u20132 \\u26131 \\u20013 \\u26080 \\u25928 \r\\\n    # set_option('avoid_future_data', True)\r\\\n    \r\\\n    # \\uc0\\u35774 \\u23450 \\u22522 \\u20934 \r\\\n    set_benchmark('000001.XSHG')\r\\\n    # \\uc0\\u29992 \\u30495 \\u23454 \\u20215 \\u26684 \\u20132 \\u26131 \r\\\n    set_option('use_real_price', True)\r\\\n    # \\uc0\\u23558 \\u28369 \\u28857 \\u35774 \\u32622 \\u20026 0\r\\\n    set_slippage(FixedSlippage(3/10000))\r\\\n    # \\uc0\\u35774 \\u32622 \\u20132 \\u26131 \\u25104 \\u26412 \\u19975 \\u20998 \\u20043 \\u19977 \r\\\n    set_order_cost(OrderCost(open_tax=0, close_tax=0.001, \r\\\n                           open_commission=0.85/10000, close_commission=0.85/10000, \r\\\n                           close_today_commission=0, min_commission=0), type='stock')\r\\\n    \r\\\n    # \\uc0\\u36807 \\u28388 order\\u20013 \\u20302 \\u20110 error\\u32423 \\u21035 \\u30340 \\u26085 \\u24535 \r\\\n    log.set_level('order', 'error')\r\\\n    log.set_level('system', 'error')\r\\\n    \r\\\n    # \\uc0\\u21021 \\u22987 \\u21270 \\u20840 \\u23616 \\u21464 \\u37327  bool - \\u23436 \\u20840 \\u20445 \\u25345 \\u21407 \\u31574 \\u30053 \r\\\n    g.no_trading_today_signal = False\r\\\n    g.pass_april = False  # \\uc0\\u20462 \\u25913 \\u65306 \\u35774 \\u32622 \\u20026 False\\u65292 \\u21462 \\u28040 \\u31354 \\u20179 \r\\\n    g.run_stoploss = True\r\\\n    \r\\\n    # \\uc0\\u20840 \\u23616 \\u21464 \\u37327 list\r\\\n    g.hold_list = []\r\\\n    g.yesterday_HL_list = []\r\\\n    g.target_list = []\r\\\n    g.not_buy_again = []\r\\\n    \r\\\n    # \\uc0\\u20840 \\u23616 \\u21464 \\u37327 float/strs - \\u23436 \\u20840 \\u20445 \\u25345 \\u21407 \\u31574 \\u30053 \\u21442 \\u25968 \r\\\n    g.stock_num = 7\r\\\n    g.up_price = 100\r\\\n    g.reason_to_sell = ''\r\\\n    g.stoploss_strategy = 3\r\\\n    g.stoploss_limit = 0.88\r\\\n    g.stoploss_market = 0.94\r\\\n    g.HV_control = False\r\\\n    g.HV_duration = 120\r\\\n    g.HV_ratio = 0.9\r\\\n    \r\\\n    # \\uc0\\u35774 \\u32622 \\u20132 \\u26131 \\u36816 \\u34892 \\u26102 \\u38388  - \\u35843 \\u25972 \\u20026 \\u23454 \\u26102 \\u20132 \\u26131 \\u26102 \\u38388 \r\\\n    run_daily(prepare_stock_list, '9:05')\r\\\n    run_weekly(weekly_adjustment, 2, '10:30')\r\\\n    run_daily(sell_stocks, time='10:00')\r\\\n    run_daily(trade_afternoon, time='14:30')\r\\\n    run_daily(close_account, '14:50')\r\\\n    run_weekly(print_position_info, 5, time='15:10')\r\\\n\r\\\n# \\uc0\\u20934 \\u22791 \\u32929 \\u31080 \\u27744  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef prepare_stock_list(context):\r\\\n    g.hold_list = []\r\\\n    for position in list(context.portfolio.positions.values()):\r\\\n        stock = position.security\r\\\n        g.hold_list.append(stock)\r\\\n    \r\\\n    if g.hold_list != []:\r\\\n        # \\uc0\\u23454 \\u26102 \\u20132 \\u26131 \\u20013 \\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n        previous_date = context.previous_date\r\\\n        df = get_price(g.hold_list, end_date=previous_date, frequency='daily',\r\\\n                      fields=['close', 'high_limit', 'low_limit'], count=1, panel=False, fill_paused=False)\r\\\n        df = df[df['close'] == df['high_limit']]\r\\\n        g.yesterday_HL_list = list(df.code)\r\\\n    else:\r\\\n        g.yesterday_HL_list = []\r\\\n    \r\\\n    g.no_trading_today_signal = False  # \\uc0\\u20462 \\u25913 \\u65306 \\u30452 \\u25509 \\u35774 \\u32622 \\u20026 False\\u65292 \\u19981 \\u20877 \\u26816 \\u26597 \\u31354 \\u20179 \\u26399 \r\\\n\r\\\n# \\uc0\\u36873 \\u32929 \\u27169 \\u22359  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef get_stock_list(context):\r\\\n    final_list = []\r\\\n    MKT_index = '399101.XSHE'\r\\\n    initial_list = get_index_stocks(MKT_index)\r\\\n    \r\\\n    # \\uc0\\u23436 \\u20840 \\u20445 \\u25345 \\u21407 \\u31574 \\u30053 \\u30340 \\u36807 \\u28388 \\u26465 \\u20214 \r\\\n    initial_list = filter_new_stock(context, initial_list)\r\\\n    initial_list = filter_kcbj_stock(initial_list)\r\\\n    initial_list = filter_st_stock(initial_list)\r\\\n    initial_list = filter_paused_stock(initial_list)\r\\\n    initial_list = filter_limitup_stock(context, initial_list)\r\\\n    initial_list = filter_limitdown_stock(context, initial_list)\r\\\n    \r\\\n    # \\uc0\\u21407 \\u31574 \\u30053 \\u65306 \\u25353 \\u24066 \\u20540 \\u21319 \\u24207 \\u25490 \\u21015 \r\\\n    q = query(valuation.code, valuation.market_cap\r\\\n             ).filter(valuation.code.in_(initial_list)\r\\\n             ).order_by(valuation.market_cap.asc())\r\\\n    df = get_fundamentals(q)\r\\\n    stock_list = list(df.code)\r\\\n    stock_list = stock_list[:100]  # \\uc0\\u21462 \\u21069 100\\u21482 \\u23567 \\u24066 \\u20540 \\u32929 \\u31080 \r\\\n    \r\\\n    # \\uc0\\u21807 \\u19968 \\u20462 \\u25913 \\u65306 \\u22312 \\u26368 \\u32456 \\u36873 \\u32929 \\u26102 \\u21152 \\u20837 \\u31609 \\u30721 \\u23792 \\u26465 \\u20214 \\u20316 \\u20026 \\u25490 \\u24207 \\u22240 \\u32032 \r\\\n    # \\uc0\\u23545 \\u32929 \\u31080 \\u36827 \\u34892 \\u35780 \\u20998 \\u65306 \\u24066 \\u20540 \\u25490 \\u21517  + \\u31609 \\u30721 \\u23792 \\u21152 \\u20998 \r\\\n    scored_stocks = []\r\\\n    for stock in stock_list:\r\\\n        score = 0\r\\\n        # \\uc0\\u24066 \\u20540 \\u25490 \\u21517 \\u65288 \\u36234 \\u23567 \\u36234 \\u22909 \\u65289 \r\\\n        market_cap_rank = stock_list.index(stock)\r\\\n        score -= market_cap_rank  # \\uc0\\u24066 \\u20540 \\u36234 \\u23567 \\u65292 \\u20943 \\u20998 \\u36234 \\u23569 \\u65288 \\u23454 \\u38469 \\u25490 \\u21517 \\u38752 \\u21069 \\u65289 \r\\\n        \r\\\n        # \\uc0\\u31609 \\u30721 \\u23792 \\u26465 \\u20214 \\u21152 \\u20998 \r\\\n        chip_score = get_chip_score(context, stock)\r\\\n        score += chip_score * 10  # \\uc0\\u31609 \\u30721 \\u23792 \\u26465 \\u20214 \\u32473 \\u20104 \\u39069 \\u22806 \\u21152 \\u20998 \r\\\n        \r\\\n        scored_stocks.append((stock, score))\r\\\n    \r\\\n    # \\uc0\\u25353 \\u32508 \\u21512 \\u35780 \\u20998 \\u25490 \\u24207 \r\\\n    scored_stocks.sort(key=lambda x: x[1], reverse=True)\r\\\n    final_list = [stock for stock, score in scored_stocks]\r\\\n    \r\\\n    final_list = final_list[:2 * g.stock_num]\r\\\n    log.info('\\uc0\\u20170 \\u26085 \\u36873 \\u32929 \\u32467 \\u26524 :%s' % final_list[:10])\r\\\n    \r\\\n    return final_list\r\\\n\r\\\n# \\uc0\\u31609 \\u30721 \\u23792 \\u35780 \\u20998 \\u20989 \\u25968  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef get_chip_score(context, stock):\r\\\n    \"\"\"\r\\\n    \\uc0\\u36820 \\u22238 0-1\\u30340 \\u35780 \\u20998 \\u65292 1\\u34920 \\u31034 \\u23436 \\u20840 \\u31526 \\u21512 \\u31609 \\u30721 \\u23792 \\u26465 \\u20214 \\u65292 0\\u34920 \\u31034 \\u23436 \\u20840 \\u19981 \\u31526 \\u21512 \r\\\n    \\uc0\\u23454 \\u26102 \\u20132 \\u26131 \\u29256 \\u26412 \\u65292 \\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n    \"\"\"\r\\\n    try:\r\\\n        # \\uc0\\u23454 \\u26102 \\u20132 \\u26131 \\u20013 \\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n        end_date = context.previous_date\r\\\n        \r\\\n        # \\uc0\\u33719 \\u21462 \\u21382 \\u21490 \\u20215 \\u26684 \\u25968 \\u25454 , \\u33719 \\u21462 60\\u22825 \\u30340 \\u25968 \\u25454 \\u29992 \\u20110 \\u35745 \\u31639 \r\\\n        price_data = get_bars(stock, 60, '1d', ['close', 'high', 'low', 'volume'], \r\\\n                             include_now=False, end_dt=end_date)\r\\\n        \r\\\n        if len(price_data) < 31: # \\uc0\\u38656 \\u35201 \\u33267 \\u23569 30\\u22825 \\u21382 \\u21490 +1\\u22825 \\u24403 \\u21069 \r\\\n            return 0\r\\\n        \r\\\n        # \\uc0\\u23558 \\u25968 \\u25454 \\u26126 \\u30830 \\u20998 \\u31163 \\u65292 \\u36991 \\u20813 \\u26410 \\u26469 \\u20989 \\u25968 \r\\\n        current_price = price_data['close'][-1]         # T-1\\uc0\\u26085 \\u30340 \\u25910 \\u30424 \\u20215 \r\\\n        historical_data = price_data[:-1]               # T-60\\uc0\\u21040 T-2\\u26085 \\u30340 \\u25968 \\u25454 \r\\\n        \r\\\n        score = 0\r\\\n        \r\\\n        # 1. \\uc0\\u31609 \\u30721 \\u23494 \\u38598 \\u24230 \\u35780 \\u20998 \\u65288 \\u20215 \\u26684 \\u27874 \\u21160 \\u29575 \\u65289 \r\\\n        # \\uc0\\u20351 \\u29992 \\u26368 \\u36817 30\\u22825 \\u30340 \\u21382 \\u21490 \\u25968 \\u25454 \r\\\n        price_std = np.std(historical_data['close'][-30:])\r\\\n        avg_price = np.mean(historical_data['close'][-30:])\r\\\n        if avg_price > 0:\r\\\n            volatility = price_std / avg_price\r\\\n            if volatility < 0.12:  # \\uc0\\u27874 \\u21160 \\u29575 \\u23567 \\u65292 \\u31609 \\u30721 \\u23494 \\u38598 \r\\\n                score += 0.4\r\\\n            elif volatility < 0.18:\r\\\n                score += 0.2\r\\\n        \r\\\n        # 2. \\uc0\\u33719 \\u21033 \\u27604 \\u20363 \\u35780 \\u20998 \r\\\n        # \\uc0\\u20351 \\u29992 \\u26368 \\u36817 20\\u22825 \\u30340 \\u21382 \\u21490 \\u25968 \\u25454 \\u35745 \\u31639 \\u26368 \\u39640 \\u20215 \r\\\n        recent_high = max(historical_data['high'][-20:])\r\\\n        if recent_high > 0:\r\\\n            profit_ratio = current_price / recent_high\r\\\n            if profit_ratio > 0.85:  # \\uc0\\u33719 \\u21033 \\u27604 \\u20363 \\u39640 \r\\\n                score += 0.3\r\\\n            elif profit_ratio > 0.75:\r\\\n                score += 0.15\r\\\n        \r\\\n        # 3. \\uc0\\u31361 \\u30772 \\u21644 \\u25104 \\u20132 \\u37327 \\u35780 \\u20998 \r\\\n        # \\uc0\\u20351 \\u29992 \\u26368 \\u36817 20\\u22825 \\u30340 \\u21382 \\u21490 \\u25968 \\u25454 \\u35745 \\u31639 \\u39640 \\u20302 \\u28857 \r\\\n        recent_low = min(historical_data['low'][-20:])\r\\\n        range_mid = (recent_high + recent_low) / 2\r\\\n        if current_price > range_mid:  # \\uc0\\u31361 \\u30772 \\u20013 \\u36724 \r\\\n            score += 0.2\r\\\n        \r\\\n        # \\uc0\\u20351 \\u29992 \\u26368 \\u36817 10\\u22825 \\u30340 \\u21382 \\u21490 \\u25968 \\u25454 \\u35745 \\u31639 \\u25104 \\u20132 \\u37327 \r\\\n        vol_data = historical_data['volume'][-10:]\r\\\n        if len(vol_data) >= 5:\r\\\n            avg_vol_5 = np.mean(vol_data[-5:])\r\\\n            avg_vol_10 = np.mean(vol_data)\r\\\n            if avg_vol_5 > avg_vol_10 * 1.1:  # \\uc0\\u36817 \\u26399 \\u25918 \\u37327 \r\\\n                score += 0.1\r\\\n        \r\\\n        return min(score, 1.0)  # \\uc0\\u30830 \\u20445 \\u35780 \\u20998 \\u19981 \\u36229 \\u36807 1\r\\\n        \r\\\n    except Exception as e:\r\\\n        log.error(\"\\uc0\\u35745 \\u31639 \\u31609 \\u30721 \\u23792 \\u35780 \\u20998 \\u20986 \\u38169 : \\{\\}\".format(str(e)))\r\\\n        return 0\r\\\n\r\\\n# \\uc0\\u21608 \\u35843 \\u25972 \\u20989 \\u25968  - \\u20445 \\u25345 \\u21407 \\u36923 \\u36753 \r\\\ndef weekly_adjustment(context):\r\\\n    if g.no_trading_today_signal == False:\r\\\n        g.not_buy_again = []\r\\\n        g.target_list = get_stock_list(context)\r\\\n        target_list = g.target_list[:g.stock_num]\r\\\n        log.info(str(target_list))\r\\\n        \r\\\n        for stock in g.hold_list:\r\\\n            if (stock not in target_list) and (stock not in g.yesterday_HL_list):\r\\\n                log.info(\"\\uc0\\u21334 \\u20986 [%s]\" % (stock))\r\\\n                position = context.portfolio.positions[stock]\r\\\n                close_position(position)\r\\\n            else:\r\\\n                log.info(\"\\uc0\\u24050 \\u25345 \\u26377 [%s]\" % (stock))\r\\\n        \r\\\n        buy_security(context, target_list)\r\\\n        \r\\\n        for position in list(context.portfolio.positions.values()):\r\\\n            stock = position.security\r\\\n            g.not_buy_again.append(stock)\r\\\n\r\\\n# \\uc0\\u26816 \\u26597 \\u28072 \\u20572  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef check_limit_up(context):\r\\\n    current_data = get_current_data()\r\\\n    if g.yesterday_HL_list != []:\r\\\n        for stock in g.yesterday_HL_list:\r\\\n            if current_data[stock].paused:\r\\\n                continue\r\\\n            current_price = current_data[stock].last_price\r\\\n            high_limit = current_data[stock].high_limit\r\\\n            if current_price < high_limit:\r\\\n                log.info(\"[%s]\\uc0\\u28072 \\u20572 \\u25171 \\u24320 \\u65292 \\u21334 \\u20986 \" % (stock))\r\\\n                position = context.portfolio.positions[stock]\r\\\n                close_position(position)\r\\\n                g.reason_to_sell = 'limitup'\r\\\n            else:\r\\\n                log.info(\"[%s]\\uc0\\u28072 \\u20572 \\u65292 \\u32487 \\u32493 \\u25345 \\u26377 \" % (stock))\r\\\n\r\\\ndef check_remain_amount(context):\r\\\n    if g.reason_to_sell == 'limitup':\r\\\n        g.hold_list = []\r\\\n        for position in list(context.portfolio.positions.values()):\r\\\n            stock = position.security\r\\\n            g.hold_list.append(stock)\r\\\n        \r\\\n        if len(g.hold_list) < g.stock_num:\r\\\n            target_list = g.target_list\r\\\n            target_list = [stock for stock in target_list if stock not in g.not_buy_again]\r\\\n            target_list = target_list[:min(g.stock_num - len(g.hold_list), len(target_list))]\r\\\n            \r\\\n            if target_list and context.portfolio.cash > 0:\r\\\n                log.info('\\uc0\\u26377 \\u20313 \\u39069 \\u21487 \\u29992 '+str(round((context.portfolio.cash),2))+'\\u20803 \\u12290 '+ str(target_list))\r\\\n                buy_security(context, target_list)\r\\\n                g.reason_to_sell = ''\r\\\n            else:\r\\\n                log.info('\\uc0\\u34429 \\u28982 \\u26377 \\u20313 \\u39069 \\u21487 \\u29992 \\u65292 \\u20294 \\u26159 \\u20026 \\u27490 \\u25439 \\u21518 \\u20313 \\u39069 \\u65292 \\u19979 \\u21608 \\u20877 \\u20132 \\u26131 ')\r\\\n                g.reason_to_sell = ''\r\\\n\r\\\ndef trade_afternoon(context):\r\\\n    if g.no_trading_today_signal == False:\r\\\n        check_limit_up(context)\r\\\n        if g.HV_control == True:\r\\\n            check_high_volume(context)\r\\\n        check_remain_amount(context)\r\\\n\r\\\n# \\uc0\\u27490 \\u25439 \\u20989 \\u25968  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef sell_stocks(context):\r\\\n    if g.run_stoploss == True:\r\\\n        current_data = get_current_data()\r\\\n        if g.stoploss_strategy == 1:\r\\\n            for stock in context.portfolio.positions.keys():\r\\\n                if current_data[stock].paused:\r\\\n                    continue\r\\\n                position = context.portfolio.positions[stock]\r\\\n                # \\uc0\\u23454 \\u26102 \\u20132 \\u26131 \\u20013 \\u20351 \\u29992 \\u24403 \\u21069 \\u20215 \\u26684 \r\\\n                current_price = current_data[stock].last_price\r\\\n                avg_cost = position.avg_cost\r\\\n                if current_price >= avg_cost * 2:\r\\\n                    order_target_value(stock, 0)\r\\\n                    log.debug(\"\\uc0\\u25910 \\u30410 100%\\u27490 \\u30408 ,\\u21334 \\u20986 \\{\\}\".format(stock))\r\\\n                elif current_price < avg_cost * g.stoploss_limit:\r\\\n                    order_target_value(stock, 0)\r\\\n                    log.debug(\"\\uc0\\u25910 \\u30410 \\u27490 \\u25439 ,\\u21334 \\u20986 \\{\\}\".format(stock))\r\\\n                    g.reason_to_sell = 'stoploss'\r\\\n        elif g.stoploss_strategy == 2:\r\\\n            # \\uc0\\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n            index_data = get_price('399101.XSHE', end_date=context.previous_date,\r\\\n                                 frequency='daily', fields=['close', 'open'], count=2, fill_paused=False)\r\\\n            if len(index_data) >= 2:\r\\\n                prev_close = index_data['close'][-2]\r\\\n                prev_open = index_data['open'][-2]\r\\\n                if prev_open > 0:\r\\\n                    down_ratio = prev_close / prev_open\r\\\n                    if down_ratio <= g.stoploss_market:\r\\\n                        g.reason_to_sell = 'stoploss'\r\\\n                        log.debug(\"\\uc0\\u21069 \\u19968 \\u26085 \\u22823 \\u30424 \\u24808 \\u36300 ,\\u38477 \\u24133 \\{:.2%\\}\".format(1-down_ratio))\r\\\n                        for stock in context.portfolio.positions.keys():\r\\\n                            if not current_data[stock].paused:\r\\\n                                order_target_value(stock, 0)\r\\\n        elif g.stoploss_strategy == 3:\r\\\n            # \\uc0\\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n            index_data = get_price('399101.XSHE', end_date=context.previous_date,\r\\\n                                 frequency='daily', fields=['close', 'open'], count=2, fill_paused=False)\r\\\n            market_down = False\r\\\n            if len(index_data) >= 2:\r\\\n                prev_close = index_data['close'][-2]\r\\\n                prev_open = index_data['open'][-2]\r\\\n                if prev_open > 0:\r\\\n                    down_ratio = prev_close / prev_open\r\\\n                    if down_ratio <= g.stoploss_market:\r\\\n                        market_down = True\r\\\n                        g.reason_to_sell = 'stoploss'\r\\\n                        log.debug(\"\\uc0\\u21069 \\u19968 \\u26085 \\u22823 \\u30424 \\u24808 \\u36300 ,\\u38477 \\u24133 \\{:.2%\\}\".format(1-down_ratio))\r\\\n            for stock in context.portfolio.positions.keys():\r\\\n                if current_data[stock].paused:\r\\\n                    continue\r\\\n                position = context.portfolio.positions[stock]\r\\\n                # \\uc0\\u23454 \\u26102 \\u20132 \\u26131 \\u20013 \\u20351 \\u29992 \\u24403 \\u21069 \\u20215 \\u26684 \r\\\n                current_price = current_data[stock].last_price\r\\\n                avg_cost = position.avg_cost\r\\\n                if market_down:\r\\\n                    order_target_value(stock, 0)\r\\\n                    log.debug(\"\\uc0\\u22823 \\u30424 \\u27490 \\u25439 ,\\u21334 \\u20986 \\{\\}\".format(stock))\r\\\n                elif current_price < avg_cost * g.stoploss_limit:\r\\\n                    order_target_value(stock, 0)\r\\\n                    log.debug(\"\\uc0\\u25910 \\u30410 \\u27490 \\u25439 ,\\u21334 \\u20986 \\{\\}\".format(stock))\r\\\n                    g.reason_to_sell = 'stoploss'\r\\\n\r\\\n# \\uc0\\u39640 \\u25104 \\u20132 \\u37327 \\u26816 \\u26597  - \\u20462 \\u25913 \\u20026 \\u23454 \\u26102 \\u29256 \\u26412 \r\\\ndef check_high_volume(context):\r\\\n    current_data = get_current_data()\r\\\n    for stock in context.portfolio.positions:\r\\\n        if current_data[stock].paused:\r\\\n            continue\r\\\n        if current_data[stock].last_price == current_data[stock].high_limit:\r\\\n            continue\r\\\n        if context.portfolio.positions[stock].closeable_amount == 0:\r\\\n            continue\r\\\n        # \\uc0\\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n        df_volume = get_bars(stock, count=g.HV_duration, unit='1d',\r\\\n                            fields=['volume'], include_now=False, df=True,\r\\\n                            end_dt=context.previous_date)\r\\\n        if len(df_volume) >= g.HV_duration-1:\r\\\n            historical_max_volume = df_volume['volume'].max()\r\\\n            prev_volume_data = get_bars(stock, count=2, unit='1d',\r\\\n                                      fields=['volume'], include_now=False, df=True,\r\\\n                                      end_dt=context.previous_date)\r\\\n            if len(prev_volume_data) >= 2:\r\\\n                prev_volume = prev_volume_data['volume'].iloc[-1]\r\\\n                if prev_volume > g.HV_ratio * historical_max_volume:\r\\\n                    log.info(\"[%s]\\uc0\\u22825 \\u37327 \\u65292 \\u21334 \\u20986 \" % stock)\r\\\n                    position = context.portfolio.positions[stock]\r\\\n                    close_position(position)\r\\\n\r\\\n# \\uc0\\u25152 \\u26377 \\u36807 \\u28388 \\u20989 \\u25968 \\u20445 \\u25345 \\u21407 \\u26679 \r\\\ndef filter_paused_stock(stock_list):\r\\\n    current_data = get_current_data()\r\\\n    return [stock for stock in stock_list if not current_data[stock].paused]\r\\\n\r\\\ndef filter_st_stock(stock_list):\r\\\n    current_data = get_current_data()\r\\\n    return [stock for stock in stock_list\r\\\n            if not current_data[stock].is_st\r\\\n            and 'ST' not in current_data[stock].name\r\\\n            and '*' not in current_data[stock].name\r\\\n            and '\\uc0\\u36864 ' not in current_data[stock].name]\r\\\n\r\\\ndef filter_kcbj_stock(stock_list):\r\\\n    return [stock for stock in stock_list\r\\\n            if not (stock.startswith('4') or stock.startswith('8') or stock.startswith('68'))]\r\\\n\r\\\ndef filter_limitup_stock(context, stock_list):\r\\\n    if len(stock_list) == 0:\r\\\n        return []\r\\\n    # \\uc0\\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n    prev_data = get_price(stock_list, end_date=context.previous_date,\r\\\n                         frequency='daily', fields=['close', 'high_limit'],\r\\\n                         count=1, panel=False, fill_paused=False)\r\\\n    current_data = get_current_data()\r\\\n    result = []\r\\\n    for stock in stock_list:\r\\\n        if stock in context.portfolio.positions:\r\\\n            result.append(stock)\r\\\n            continue\r\\\n        stock_data = prev_data[prev_data['code'] == stock]\r\\\n        if len(stock_data) == 0:\r\\\n            continue\r\\\n        if stock_data.iloc[0]['close'] < stock_data.iloc[0]['high_limit']:\r\\\n            result.append(stock)\r\\\n    return result\r\\\n\r\\\ndef filter_limitdown_stock(context, stock_list):\r\\\n    if len(stock_list) == 0:\r\\\n        return []\r\\\n    # \\uc0\\u20351 \\u29992 \\u21069 \\u19968 \\u26085 \\u25968 \\u25454 \r\\\n    prev_data = get_price(stock_list, end_date=context.previous_date,\r\\\n                         frequency='daily', fields=['close', 'low_limit'],\r\\\n                         count=1, panel=False, fill_paused=False)\r\\\n    current_data = get_current_data()\r\\\n    result = []\r\\\n    for stock in stock_list:\r\\\n        if stock in context.portfolio.positions:\r\\\n            result.append(stock)\r\\\n            continue\r\\\n        stock_data = prev_data[prev_data['code'] == stock]\r\\\n        if len(stock_data) == 0:\r\\\n            continue\r\\\n        if stock_data.iloc[0]['close'] > stock_data.iloc[0]['low_limit']:\r\\\n            result.append(stock)\r\\\n    return result\r\\\n\r\\\ndef filter_new_stock(context, stock_list):\r\\\n    yesterday = context.previous_date\r\\\n    return [stock for stock in stock_list\r\\\n            if not (yesterday - get_security_info(stock).start_date < timedelta(days=375))]\r\\\n\r\\\n# \\uc0\\u20132 \\u26131 \\u20989 \\u25968 \\u20445 \\u25345 \\u21407 \\u26679 \r\\\ndef order_target_value_(security, value):\r\\\n    if value == 0:\r\\\n        log.debug(\"Selling out %s\" % (security))\r\\\n    else:\r\\\n        log.debug(\"Order %s to value %f\" % (security, value))\r\\\n    return order_target_value(security, value)\r\\\n\r\\\ndef open_position(security, value):\r\\\n    order = order_target_value_(security, value)\r\\\n    if order != None and order.filled > 0:\r\\\n        return True\r\\\n    return False\r\\\n\r\\\ndef close_position(position):\r\\\n    security = position.security\r\\\n    order = order_target_value_(security, 0)\r\\\n    if order != None:\r\\\n        if order.status == OrderStatus.held and order.filled == order.amount:\r\\\n            return True\r\\\n    return False\r\\\n\r\\\ndef buy_security(context, target_list):\r\\\n    position_count = len(context.portfolio.positions)\r\\\n    target_num = len(target_list)\r\\\n    if target_num > position_count and context.portfolio.cash > 0:\r\\\n        value = context.portfolio.cash / (target_num - position_count)\r\\\n        for stock in target_list:\r\\\n            if context.portfolio.positions[stock].total_amount == 0:\r\\\n                if open_position(stock, value):\r\\\n                    log.info(\"\\uc0\\u20080 \\u20837 [%s]\\u65288 %s\\u20803 \\u65289 \" % (stock, value))\r\\\n                    g.not_buy_again.append(stock)\r\\\n                if len(context.portfolio.positions) == target_num:\r\\\n                    break\r\\\n\r\\\n# \\uc0\\u20854 \\u20182 \\u36741 \\u21161 \\u20989 \\u25968 \\u20445 \\u25345 \\u21407 \\u26679 \r\\\ndef today_is_between(context):\r\\\n    # \\uc0\\u20462 \\u25913 \\u65306 \\u30452 \\u25509 \\u36820 \\u22238 False\\u65292 \\u19981 \\u20877 \\u26816 \\u26597 \\u31354 \\u20179 \\u26399 \r\\\n    return False\r\\\n\r\\\ndef close_account(context):\r\\\n    # \\uc0\\u20462 \\u25913 \\u65306 \\u31227 \\u38500 \\u31354 \\u20179 \\u28165 \\u20179 \\u36923 \\u36753 \r\\\n    # \\uc0\\u19981 \\u20877 \\u22240 \\u31354 \\u20179 \\u26399 \\u32780 \\u28165 \\u20179 \\u65292 \\u21482 \\u22788 \\u29702 \\u20854 \\u20182 \\u24773 \\u20917 \r\\\n    pass\r\\\n\r\\\ndef print_position_info(context):\r\\\n    for position in list(context.portfolio.positions.values()):\r\\\n        securities = position.security\r\\\n        cost = position.avg_cost\r\\\n        price = position.price\r\\\n        ret = 100 * (price / cost - 1)\r\\\n        value = position.value\r\\\n        amount = position.total_amount\r\\\n        print('\\uc0\\u20195 \\u30721 :\\{\\}'.format(securities))\r\\\n        print('\\uc0\\u25104 \\u26412 \\u20215 :\\{\\}'.format(format(cost, '.2f')))\r\\\n        print('\\uc0\\u29616 \\u20215 :\\{\\}'.format(price))\r\\\n        print('\\uc0\\u25910 \\u30410 \\u29575 :\\{\\}%'.format(format(ret, '.2f')))\r\\\n        print('\\uc0\\u25345 \\u20179 (\\u32929 ):\\{\\}'.format(amount))\r\\\n        print('\\uc0\\u24066 \\u20540 :\\{\\}'.format(format(value, '.2f')))\r\\\n        print('-' * 100)\r\\\n    print('=' * 200)}","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1772592974756}}
{"type":"message","id":"de29e42f","parentId":"6662495d","timestamp":"2026-03-04T02:57:09.744Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"This is a complex strategy with multiple components. Let me extract the key logic and create a backtest version. The strategy includes:\n\n1. Stock selection from 国证2000 (399101)\n2. Filtering: new stocks, ST, paused, limit up/down\n3. Small cap selection (top 100 by market cap)\n4. Chip/scoring system (筹码峰):\n   - Volatility score (low volatility = good)\n   - Profit ratio score (close to recent high = good)\n   - Position score (above midpoint = good)\n   - Volume surge score\n5. Weekly rebalancing\n6. Stop loss strategies\n\nLet me implement a simplified version for backtesting locally.","thinkingSignature":"8ae00486e28d560fd6f31a88846fcc263766efecae8cca3b2ac4060e3a344afc"},{"type":"text","text":"这是一个复杂的策略！让我提取核心逻辑并实现回测：\n"},{"type":"toolCall","id":"call_function_b5ixgv715b9x_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n小市值动量+筹码峰策略\n基于聚宽社区策略改编\n\"\"\"\nimport os\nimport pandas as pd\nimport numpy as np\n\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'data')\n\n\ndef load_data(years):\n    \"\"\"加载数据\"\"\"\n    dfs = []\n    for year in years:\n        path = f'{DATA_DIR}/daily_{year}.csv'\n        if os.path.exists(path):\n            dfs.append(pd.read_csv(path))\n    return pd.concat(dfs, ignore_index=True) if dfs else None\n\n\ndef calculate_chip_score(df, ts_code):\n    \"\"\"计算筹码峰评分\"\"\"\n    # 获取历史数据\n    stock_data = df[df['ts_code'] == ts_code].sort_values('trade_date')\n    if len(stock_data) < 31:\n        return 0\n    \n    # 取最近60天数据\n    recent = stock_data.tail(60)\n    if len(recent) < 31:\n        return 0\n    \n    current_price = recent['close'].iloc[-1]\n    historical = recent.iloc[:-1]  # 排除当天\n    \n    if len(historical) < 30:\n        return 0\n    \n    score = 0\n    \n    # 1. 波动率评分 (低波动 = 好)\n    volatility = historical['close'].std() / historical['close'].mean()\n    if volatility < 0.12:\n        score += 0.4\n    elif volatility < 0.18:\n        score += 0.2\n    \n    # 2. 盈利比例评分 (接近近期高点 = 好)\n    recent_high = historical['high'].tail(20).max()\n    if recent_high > 0:\n        profit_ratio = current_price / recent_high\n        if profit_ratio > 0.85:\n            score += 0.3\n        elif profit_ratio > 0.75:\n            score += 0.15\n    \n    # 3. 位置评分 (在区间中部以上 = 好)\n    recent_low = historical['low'].tail(20).min()\n    range_mid = (recent_high + recent_low) / 2\n    if current_price > range_mid:\n        score += 0.2\n    \n    # 4. 量能评分 (近期放量 = 好)\n    vol = historical['volume'].tail(10)\n    if len(vol) >= 5:\n        avg_vol_5 = vol.tail(5).mean()\n        avg_vol_10 = vol.mean()\n        if avg_vol_5 > avg_vol_10 * 1.1:\n            score += 0.1\n    \n    return min(score, 1.0)\n\n\ndef run_strategy(start_year=2021, end_year=2024):\n    \"\"\"运行小市值动量+筹码峰策略\"\"\"\n    print(\"=\"*60)\n    print(\"📊 小市值动量+筹码峰策略\")\n    print(\"=\"*60)\n    \n    # 参数\n    STOCK_NUM = 7  # 持仓数量\n    STOP_LOSS = -0.12  # 止损12%\n    \n    years = list(range(start_year, end_year + 1))\n    daily = load_data(years)\n    \n    if daily is None:\n        print(\"❌ 没有数据\")\n        return\n    \n    dates = sorted(daily['trade_date'].unique())\n    print(f\"数据范围: {dates[0]} ~ {dates[-1]}\")\n    \n    # 按周回测 (每周调仓)\n    weekly_dates = []\n    for i, d in enumerate(dates):\n        # 每周二调仓\n        from datetime import datetime\n        try:\n            dt = datetime.strptime(str(d), '%Y%m%d')\n            if dt.weekday() == 1:  # 周二\n                weekly_dates.append(d)\n        except:\n            pass\n    \n    print(f\"调仓日数量: {len(weekly_dates)}\")\n    \n    # 回测\n    prev_positions = {}\n    weekly_returns = []\n    \n    for i, trade_date in enumerate(weekly_dates):\n        # 获取当日数据\n        day_df = daily[daily['trade_date'] == trade_date].copy()\n        if len(day_df) == 0:\n            continue\n        \n        # 基本筛选\n        day_df['circ_mv_yi'] = day_df['circ_mv'] / 10000\n        day_df = day_df[day_df['circ_mv_yi'] <= 100]  # 小市值\n        day_df = day_df[day_df['circ_mv_yi'] > 0]\n        day_df = day_df[day_df['pe'] > 0]  # 盈利\n        day_df = day_df[day_df['pe'] < 80]\n        day_df = day_df[~day_df['ts_code'].str.contains('ST|ST')]  # 过滤ST\n        \n        if len(day_df) == 0:\n            continue\n        \n        # 按市值排序，取前100只\n        day_df = day_df.sort_values('circ_mv_yi').head(100)\n        \n        # 计算筹码峰评分\n        stocks_with_scores = []\n        for _, row in day_df.iterrows():\n            score = calculate_chip_score(daily, row['ts_code'])\n            # 市值排名减分，筹码峰评分加分\n            final_score = -day_df.index.get_loc(row.name) + score * 10\n            stocks_with_scores.append((row['ts_code'], row['close'], final_score))\n        \n        # 按评分排序\n        stocks_with_scores.sort(key=lambda x: x[2], reverse=True)\n        \n        # 选前N只\n        selected = stocks_with_scores[:STOCK_NUM * 2]\n        \n        # 计算收益\n        if i + 1 < len(weekly_dates):\n            next_date = weekly_dates[i + 1]\n            next_df = daily[daily['trade_date'] == next_date]\n            \n            stock_returns = []\n            for ts_code, buy_price, score in selected:\n                # 止损检查\n                if ts_code in prev_positions:\n                    stock_start = day_df[day_df['ts_code'] == ts_code]\n                    if len(stock_start) > 0:\n                        current_price = stock_start['close'].values[0]\n                        ret = (current_price - prev_positions[ts_code]) / prev_positions[ts_code]\n                        if ret < STOP_LOSS:\n                            continue\n                \n                stock_start = day_df[day_df['ts_code'] == ts_code]\n                stock_end = next_df[next_df['ts_code'] == ts_code]\n                \n                if len(stock_start) > 0 and len(stock_end) > 0:\n                    ret = (stock_end['close'].values[0] - stock_start['close'].values[0]) / stock_start['close'].values[0]\n                    stock_returns.append(ret)\n            \n            if stock_returns:\n                avg_ret = np.mean(stock_returns)\n                weekly_returns.append({'date': trade_date, 'return': avg_ret})\n            \n            # 更新持仓\n            prev_positions = {}\n            for ts_code, close_price, score in selected[:STOCK_NUM]:\n                prev_positions[ts_code] = close_price\n    \n    # 统计结果\n    if not weekly_returns:\n        print(\"❌ 没有收益数据\")\n        return\n    \n    returns = [r['return'] for r in weekly_returns]\n    total_return = np.prod([1 + r for r in returns]) - 1\n    n = len(returns)\n    annual_return = (1 + total_return) ** (52 / n) - 1\n    \n    vol = np.std(returns)\n    annual_vol = vol * np.sqrt(52)\n    sharpe = (annual_return - 0.03) / annual_vol if annual_vol > 0 else 0\n    \n    # 最大回撤\n    cumprod = np.cumprod([1 + r for r in returns])\n    peak = np.maximum.accumulate(cumprod)\n    drawdown = (cumprod - peak) / peak\n    max_dd = np.min(drawdown)\n    \n    win_rate = len([r for r in returns if r > 0]) / n\n    \n    print(f\"\\n📈 回测结果\")\n    print(f\"{'='*50}\")\n    print(f\"交易次数: {n}\")\n    print(f\"总收益率: {total_return*100:.2f}%\")\n    print(f\"年化收益率: {annual_return*100:.2f}%\")\n    print(f\"年化波动率: {annual_vol*100:.2f}%\")\n    print(f\"夏普比率: {sharpe:.2f}\")\n    print(f\"最大回撤: {max_dd*100:.2f}%\")\n    print(f\"胜率: {win_rate*100:.1f}%\")\n    \n    print(f\"\\n📉 最近收益:\")\n    for r in weekly_returns[-10:]:\n        print(f\"  {r['date']}: {r['return']*100:+.2f}%\")\n    \n    return {\n        'total_return': total_return,\n        'annual_return': annual_return,\n        'sharpe': sharpe,\n        'max_drawdown': max_dd,\n        'win_rate': win_rate\n    }\n\n\nif __name__ == '__main__':\n    run_strategy(2021, 2024)\n","file_path":"/Users/ling/.openclaw/workspace/daily_stock_analysis/backtest_momentum_chip.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":128852,"output":2183,"cacheRead":18336,"cacheWrite":0,"totalTokens":149371,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772592974768}}
