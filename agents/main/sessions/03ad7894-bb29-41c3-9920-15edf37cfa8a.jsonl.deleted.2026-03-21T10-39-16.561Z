{"type":"message","id":"4b7fc7da","parentId":"e00f4f52","timestamp":"2026-03-21T09:39:17.230Z","message":{"role":"toolResult","toolCallId":"call_function_s5mn29vgd5wz_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"Generate day1-3 style mean reversion signals.\n\nSimplified version: compute features directly for target date.\n\"\"\"\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nDEFAULT_CONFIG = PROJECT_ROOT / \"config\" / \"day1_3_mean_reversion.yaml\"\n\n\ndef load_yaml(path: Path) -> dict[str, Any]:\n    data = yaml.safe_load(path.read_text(encoding=\"utf-8\"))\n    return data or {}\n\n\ndef normalize_ts_code(raw: str) -> str:\n    s = raw.strip().upper()\n    if not s or s == \"NAN\":\n        return \"\"\n    if s.endswith((\".SH\", \".SZ\", \".BJ\")):\n        return s\n    if s.startswith((\"60\", \"68\", \"90\")):\n        return f\"{s}.SH\"\n    if s.startswith((\"00\", \"30\")):\n        return f\"{s}.SZ\"\n    if s.startswith((\"4\", \"8\")):\n        return f\"{s}.BJ\"\n    return s\n\n\ndef load_history(path: Path, target_date: str, lookback_days: int = 120) -> pd.DataFrame:\n    \"\"\"Load history from cutoff date.\"\"\"\n    cutoff_date = str(int(target_date.replace(\"-\", \"\")) - lookback_days * 100)  # rough estimate\n    \n    chunks = []\n    for chunk in pd.read_csv(path, chunksize=500000, dtype={\"trade_date\": str}):\n        chunk = chunk[chunk[\"trade_date\"] >= cutoff_date]\n        if not chunk.empty:\n            chunks.append(chunk)\n    \n    if not chunks:\n        raise ValueError(f\"No data after cutoff {cutoff_date}\")\n    \n    df = pd.concat(chunks, ignore_index=True)\n    df[\"ts_code\"] = df[\"ts_code\"].map(normalize_ts_code)\n    df[\"trade_date\"] = pd.to_datetime(df[\"trade_date\"], format=\"%Y%m%d\", errors=\"coerce\")\n    return df.dropna(subset=[\"trade_date\", \"ts_code\", \"close\"]).sort_values([\"ts_code\", \"trade_date\"])\n\n\ndef compute_features_for_date(df: pd.DataFrame, target_date: str, index_df: pd.DataFrame = None) -> pd.DataFrame:\n    \"\"\"Compute technical features for a specific date.\"\"\"\n    trade_date = pd.to_datetime(target_date)\n    \n    # Get latest date data\n    latest = df[df[\"trade_date\"] == trade_date].copy()\n    if len(latest) == 0:\n        # Try previous date\n        dates = df[\"trade_date\"].drop_duplicates().sort_values()\n        trade_date = dates.iloc[-1]\n        latest = df[df[\"trade_date\"] == trade_date].copy()\n        print(f\"Using previous date: {trade_date}\")\n    \n    # Compute rolling features on FULL history, then filter to latest date\n    # This ensures we have enough history for rolling calculations\n    g = df.groupby(\"ts_code\", group_keys=False)\n    df[\"ma10\"] = g[\"close\"].transform(lambda s: s.rolling(10, min_periods=5).mean())\n    df[\"ma20\"] = g[\"close\"].transform(lambda s: s.rolling(20, min_periods=10).mean())\n    df[\"hh20\"] = g[\"high\"].transform(lambda s: s.rolling(20, min_periods=10).max())\n    df[\"ll20\"] = g[\"low\"].transform(lambda s: s.rolling(20, min_periods=10).min())\n    \n    # Get latest date features after rolling is computed\n    latest = df[df[\"trade_date\"] == trade_date].copy()\n    \n    # Compute ret5 using pivot on recent data\n    recent = df[df[\"trade_date\"] <= trade_date].groupby(\"ts_code\").tail(6).sort_values([\"ts_code\", \"trade_date\"])\n    piv = recent.pivot(index=\"trade_date\", columns=\"ts_code\", values=\"close\")\n    if len(piv) >= 6:\n        ret5 = (piv.iloc[-1] / piv.iloc[-6] - 1).to_dict()\n        latest[\"ret5\"] = latest[\"ts_code\"].map(ret5)\n    else:\n        latest[\"ret5\"] = np.nan\n    \n    # Compute excess_ret5 relative to HS300 index\n    if index_df is not None:\n        idx = index_df[index_df[\"date\"] <= trade_date].copy()\n        if len(idx) >= 6:\n            idx = idx.sort_values(\"date\").tail(6)\n            hs300_ret5 = float(idx[\"close\"].iloc[-1] / idx[\"close\"].iloc[0] - 1)\n            latest[\"excess_ret5\"] = latest[\"ret5\"].fillna(0) - hs300_ret5\n        else:\n            latest[\"excess_ret5\"] = 0.0\n    else:\n        latest[\"excess_ret5\"] = 0.0\n    \n    # Derived features\n    latest[\"dist_ma10\"] = (latest[\"close\"] / latest[\"ma10\"] - 1.0).fillna(0)\n    rng = (latest[\"hh20\"] - latest[\"ll20\"]).replace(0, np.nan)\n    latest[\"range_pos20\"] = ((latest[\"close\"] - latest[\"ll20\"]) / rng).clip(0, 1).fillna(0.5)\n    latest[\"reversal_bar\"] = ((latest[\"close\"] - latest[\"open\"]) / latest[\"open\"].replace(0, np.nan)).fillna(0)\n    \n    return latest, trade_date\n\n\ndef compute_market_gate(index_df: pd.DataFrame, history_df: pd.DataFrame, trade_date: pd.Timestamp, cfg: dict) -> dict:\n    \"\"\"Compute market regime with real breadth calculation.\"\"\"\n    # Get index trend\n    idx = index_df[index_df[\"date\"] <= trade_date].copy()\n    if len(idx) < 20:\n        return {\"regime\": \"neutral\", \"breadth\": 0.5, \"trend\": 0.0, \"scale\": 0.6}\n    \n    idx[\"ma20\"] = idx[\"close\"].rolling(20, min_periods=10).mean()\n    latest_idx = idx.iloc[-1]\n    trend = float(latest_idx[\"close\"] / latest_idx[\"ma20\"] - 1.0) if pd.notna(latest_idx[\"ma20\"]) else 0.0\n    \n    # Compute REAL market breadth: % of stocks above their 20-day MA\n    # First compute MA20 for all stocks up to trade_date\n    hist = history_df[history_df[\"trade_date\"] <= trade_date].copy()\n    g = hist.groupby(\"ts_code\", group_keys=False)\n    hist[\"ma20_stock\"] = g[\"close\"].transform(lambda s: s.rolling(20, min_periods=10).mean())\n    \n    # Get latest date data\n    latest = hist[hist[\"trade_date\"] == trade_date].copy()\n    latest = latest.dropna(subset=[\"ma20_stock\"])\n    \n    if len(latest) >= 50:  # Need enough stocks for meaningful breadth\n        breadth = float((latest[\"close\"] > latest[\"ma20_stock\"]).mean())\n    else:\n        breadth = 0.5  # Default if not enough data\n    \n    strong_breadth = cfg.get(\"strong_breadth\", 0.58)\n    neutral_breadth = cfg.get(\"neutral_breadth\", 0.48)\n    weak_floor = cfg.get(\"weak_index_trend_floor\", -0.03)\n    \n    # Determine regime based on BOTH trend AND breadth\n    if breadth >= strong_breadth and trend >= 0:\n        regime, scale = \"strong\", cfg.get(\"strong_scale\", 1.0)\n    elif breadth >= neutral_breadth and trend >= weak_floor:\n        regime, scale = \"neutral\", cfg.get(\"neutral_scale\", 0.6)\n    else:\n        regime, scale = \"weak\", cfg.get(\"weak_scale\", 0.3)\n    \n    return {\"regime\": regime, \"breadth\": round(breadth, 4), \"trend\": round(trend, 4), \"scale\": scale}\n\n\ndef main():\n    ap = argparse.ArgumentParser(description=\"Generate day1-3 mean reversion signals\")\n    ap.add_argument(\"--config\", default=str(DEFAULT_CONFIG))\n    ap.add_argument(\"--trade-date\", default=\"\", help=\"YYYY-MM-DD\")\n    args = ap.parse_args()\n    \n    cfg = load_yaml(Path(args.config).expanduser().resolve())\n    \n    # Determine target date\n    if args.trade_date:\n        target_date = args.trade_date\n    else:\n        hist_path = Path(cfg[\"history\"][\"csv\"]).expanduser()\n        dates = pd.read_csv(hist_path, usecols=[\"trade_date\"], dtype={\"trade_date\": str})\n        target_date = str(dates[\"trade_date\"].max())\n        target_date = f\"{target_date[:4]}-{target_date[4:6]}-{target_date[6:]}\"\n    \n    print(f\"Processing trade date: {target_date}\")\n    \n    # Load data\n    history = load_history(Path(cfg[\"history\"][\"csv\"]), target_date, 120)\n    print(f\"Loaded history: {len(history)} rows, {history['ts_code'].nunique()} stocks\")\n    \n    # Load index data for excess return calculation\n    market_cfg = cfg[\"market\"]\n    index_df = pd.read_csv(Path(market_cfg[\"index_csv\"]).expanduser())\n    index_df[\"date\"] = pd.to_datetime(index_df[\"date\"], errors=\"coerce\")\n    \n    # Compute features (with index for excess return)\n    latest, actual_date = compute_features_for_date(history, target_date, index_df)\n    target_date = str(actual_date.date())\n    print(f\"Features computed: {len(latest)} stocks\")\n    \n    # Compute market gate (with real breadth)\n    market_cfg = cfg[\"market\"]\n    index_df = pd.read_csv(Path(market_cfg[\"index_csv\"]).expanduser())\n    index_df[\"date\"] = pd.to_datetime(index_df[\"date\"], errors=\"coerce\")\n    gate = compute_market_gate(index_df, history, actual_date, market_cfg)\n    print(f\"Market regime: {gate['regime']}, trend={gate['trend']}, scale={gate['scale']}\")\n    \n    # Apply filters (tightened for mean reversion)\n    sf = cfg.get(\"signal\", {})\n    fc = cfg.get(\"fundamentals\", {})\n    \n    filtered = latest.copy()\n    if \"close\" in filtered.columns:\n        filtered = filtered[filtered[\"close\"] >= fc.get(\"min_price\", 3.0)]\n    # Amount filter (liquidity)\n    filtered = filtered[filtered[\"amount\"].fillna(0) >= sf.get(\"min_amount\", 5_000_000)]\n    # Core mean reversion filters\n    filtered = filtered[filtered[\"ret5\"].fillna(0) <= sf.get(\"max_ret5\", -0.01)]\n    filtered = filtered[filtered[\"dist_ma10\"].fillna(0) <= sf.get(\"max_dist_ma10\", -0.005)]\n    filtered = filtered[filtered[\"range_pos20\"].fillna(0.5) <= sf.get(\"max_range_pos20\", 0.55)]\n    # Excess return vs HS300 filter\n    if \"excess_ret5\" in filtered.columns:\n        filtered = filtered[filtered[\"excess_ret5\"].fillna(0) <= sf.get(\"max_excess_ret5\", -0.01)]\n    # Positive reversal requirement\n    if sf.get(\"require_positive_reversal\", False):\n        filtered = filtered[filtered[\"reversal_bar\"] > 0]\n    \n    print(f\"After filters: {len(filtered)} candidates\")\n    \n    if len(filtered) == 0:\n        print(\"No candidates - creating empty outputs\")\n        tag = target_date.replace(\"-\", \"\")\n        out_cfg = cfg[\"outputs\"]\n        \n        cand_path = Path(out_cfg[\"candidate_dir\"]) / f\"day1_3_candidates_{tag}.csv\"\n        cand_path.parent.mkdir(parents=True, exist_ok=True)\n        pd.DataFrame(columns=[\"trade_date\", \"ts_code\"]).to_csv(cand_path, index=False)\n        \n        factor_path = Path(out_cfg[\"rd_factor_dir\"]) / f\"day1_3_mean_reversion_factor_{tag}.csv\"\n        factor_path.parent.mkdir(parents=True, exist_ok=True)\n        pd.DataFrame(columns=[\"date\", \"instrument\", \"score\"]).to_csv(factor_path, index=False)\n        \n        raw_path = Path(out_cfg[\"raw_signal_dir\"]) / f\"day1_3_mean_reversion_{tag}.csv\"\n        raw_path.parent.mkdir(parents=True, exist_ok=True)\n        pd.DataFrame(columns=[\"trade_date\", \"ts_code\"]).to_csv(raw_path, index=False)\n        \n        print(json.dumps({\"status\": \"no_candidates\", \"trade_date\": target_date}))\n        return\n    \n    # Score (all features - lower is better for mean reversion except reversal)\n    weights = sf.get(\"weights\", {\"dist_ma10\": 0.30, \"ret5\": 0.25, \"excess_ret5\": 0.20, \"range_pos20\": 0.15, \"reversal\": 0.10})\n    filtered[\"rank_dist\"] = filtered[\"dist_ma10\"].rank(pct=True, ascending=True)  # lower = better\n    filtered[\"rank_ret5\"] = filtered[\"ret5\"].rank(pct=True, ascending=True)  # lower = better\n    if \"excess_ret5\" in filtered.columns:\n        filtered[\"rank_excess\"] = filtered[\"excess_ret5\"].rank(pct=True, ascending=True)  # lower = better\n    else:\n        filtered[\"rank_excess\"] = 0.5\n    filtered[\"rank_range\"] = filtered[\"range_pos20\"].rank(pct=True, ascending=True)  # lower = better\n    filtered[\"rank_reversal\"] = filtered[\"reversal_bar\"].rank(pct=False)  # higher = better\n    \n    filtered[\"score\"] = (\n        weights.get(\"dist_ma10\", 0.30) * filtered[\"rank_dist\"] +\n        weights.get(\"ret5\", 0.25) * filtered[\"rank_ret5\"] +\n        weights.get(\"excess_ret5\", 0.20) * filtered[\"rank_excess\"] +\n        weights.get(\"range_pos20\", 0.15) * filtered[\"rank_range\"] +\n        weights.get(\"reversal\", 0.10) * filtered[\"rank_reversal\"]\n    )\n    \n    # Select top K\n    top_k = sf.get(\"top_k\", 12)\n    selected = filtered.nlargest(top_k, \"score\").copy()\n    \n    # Allocate weights\n    total_exp = sf.get(\"total_exposure\", 0.72) * gate[\"scale\"]\n    max_single = sf.get(\"max_single_weight\", 0.08)\n    raw_weights = selected[\"score\"].clip(lower=0.001)\n    weights = (raw_weights / raw_weights.sum() * total_exp).clip(upper=max_single)\n    selected[\"target_weight\"] = weights.round(4)\n    \n    print(f\"Selected: {len(selected)} stocks, total weight={selected['target_weight'].sum():.2%}\")\n    \n    # Output files\n    tag = target_date.replace(\"-\", \"\")\n    out_cfg = cfg[\"outputs\"]\n    \n    # Candidates\n    cand_cols = [\"trade_date\", \"ts_code\", \"close\", \"ret5\", \"excess_ret5\", \"dist_ma10\", \"range_pos20\", \"score\", \"target_weight\"]\n    cand_path = Path(out_cfg[\"candidate_dir\"]) / f\"day1_3_candidates_{tag}.csv\"\n    cand_path.parent.mkdir(parents=True, exist_ok=True)\n    selected[cand_cols].to_csv(cand_path, index=False)\n    \n    # RD Factor\n    factor_cols = [\"date\", \"instrument\", \"score\"]\n    factor_path = Path(out_cfg[\"rd_factor_dir\"]) / f\"day1_3_mean_reversion_factor_{tag}.csv\"\n    factor_path.parent.mkdir(parents=True, exist_ok=True)\n    factor_df = pd.DataFrame({\n        \"date\": target_date,\n        \"instrument\": selected[\"ts_code\"],\n        \"score\": selected[\"score\"]\n    })\n    factor_df.to_csv(factor_path, index=False)\n    \n    # Raw signal\n    raw_path = Path(out_cfg[\"raw_signal_dir\"]) / f\"day1_3_mean_reversion_{tag}.csv\"\n    raw_path.parent.mkdir(parents=True, exist_ok=True)\n    raw = pd.DataFrame({\n        \"trade_date\": target_date,\n        \"ts_code\": selected[\"ts_code\"],\n        \"signal_type\": \"BUY\",\n        \"score\": selected[\"score\"].round(6),\n        \"target_weight\": selected[\"target_weight\"],\n        \"strategy_id\": \"day1_3_mean_reversion\",\n        \"risk_flag\": gate[\"regime\"],\n        \"comment\": f\"day1_3|regime={gate['regime']}|trend={gate['trend']}\",\n        \"source_run_id\": f\"day1_3_{tag}\",\n        \"generated_at\": pd.Timestamp.now(tz=\"Asia/Shanghai\").isoformat(),\n    })\n    raw.to_csv(raw_path, index=False)\n    \n    # Summary\n    summary = {\n        \"trade_date\": target_date,\n        \"market_regime\": gate[\"regime\"],\n        \"market_breadth\": gate[\"breadth\"],\n        \"index_trend\": gate[\"trend\"],\n        \"exposure_scale\": gate[\"scale\"],\n        \"candidates\": len(selected),\n        \"total_weight\": round(float(selected[\"target_weight\"].sum()), 4),\n        \"top3\": selected[[\"ts_code\", \"score\", \"target_weight\"]].head(3).to_dict(orient=\"records\"),\n        \"files\": {\n            \"candidates\": str(cand_path),\n            \"factor\": str(factor_path),\n            \"raw\": str(raw_path),\n        }\n    }\n    sum_path = Path(out_cfg[\"summary_dir\"]) / f\"day1_3_summary_{tag}.json\"\n    sum_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2))\n    \n    print(json.dumps(summary, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774085957219}}
{"type":"message","id":"4b0aecef","parentId":"4b7fc7da","timestamp":"2026-03-21T09:39:32.889Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the current state:\n\n1. The script `generate_day1_3_mean_reversion_signals.py` already has `excess_ret5` computation in the `compute_features_for_date` function, but it's using a different config key (`sf.get(\"max_excess_ret5\", -0.01)`) and config file reference (`DEFAULT_CONFIG = PROJECT_ROOT / \"config\" / \"day1_3_mean_reversion.yaml\"`) — note it references a different file than `day1_3_config.yaml`.\n\n2. The config file `day1_3_config.yaml` already has `excess_ret5` defined in `scoring_weights` section, but doesn't have the actual filtering parameters like `max_excess_ret5`.\n   \n3. The smoke test output shows the standard `date,instrument,score` format, and the `compute_features_for_date` function is already calculating `excess_ret5` relative to HS300, but the config key references are mismatched between the two files.\n\nLooking at the actual config structure, `day1_3_config.yaml` has `features.scoring_weights.excess_ret5: 0.20` and `max_excess_ret5: 0.05` defined, but the script is trying to access these through `sf.get()` where `sf = cfg.get(\"signal\", {})`. The issue is that `features` sits at the top level of the config, not nested under `signal`, so the script needs to reference `cfg[\"features\"]` instead to properly retrieve the scoring weights and filtering thresholds. The config file already references a different yaml path than what the script uses, and there's a mismatch between the actual config structure and what the script expects to find—the `signal` key doesn't exist in the yaml, so those `get()` calls would return defaults anyway. I need to check which config file is actually correct and align the script's references accordingly.\n\nLooking at the config structure more carefully, `scoring_weights` is nested under `features` rather than `signal`, so the script needs to either extract those values from the right location or the yaml needs restructuring to match what the script is trying to access. I see the disconnect now — the script is reading from `day1_3_mean_reversion.yaml` while the smoke test references `day1_3_config.yaml`, so I need to figure out which config file is actually being used in production. Let me check what files actually exist in the config directory to clarify which one is the source of truth.","thinkingSignature":"db44a4eedd2494258e65ac61d1a61f52e67b6c9128a581168310524b18a4d3b7"},{"type":"toolCall","id":"call_function_498r87uclxy6_1","name":"exec","arguments":{"command":"ls /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/config/"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":8425,"output":564,"cacheRead":21263,"cacheWrite":0,"totalTokens":30252,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774085957231}}
