{"type":"message","id":"81105449","parentId":"8493ea9f","timestamp":"2026-04-01T00:33:42.129Z","message":{"role":"toolResult","toolCallId":"call_FWtysnWHnsVpORUxsBxDUfuh|fc_077585180826814c0169cc67dbcc64819aaae76af99c049136","toolName":"exec","content":[{"type":"text","text":"Command still running (session glow-trail, pid 30825). Use process (list/poll/log/write/kill/clear/remove) for follow-up."}],"details":{"status":"running","sessionId":"glow-trail","pid":30825,"startedAt":1775003612112,"cwd":"/Users/ling/.openclaw/workspace","tail":"/Users/ling/Library/Python/3.9/lib/python/site-packages/urllib3/__init__.py:35: NotOpenSSLWarning: urllib3 v2 only supports OpenSSL 1.1.1+, currently the 'ssl' module is compiled with 'LibreSSL 2.8.3'. See: https://github.com/urllib3/urllib3/issues/3020\n  warnings.warn(\n2026-04-01 08:33:32,469 - INFO - start incremental Tushare refresh\n2026-04-01 08:33:32,580 - INFO - resolved target_trade_date=20260331\n2026-04-01 08:33:39,577 - INFO - fetch daily market data: 20260330\n2026-04-01 08:33:39,900 - INFO - daily 20260330 rows=5476\n2026-04-01 08:33:40,250 - INFO - fetch daily market data: 20260331\n2026-04-01 08:33:40,655 - INFO - daily 20260331 rows=5482\n2026-04-01 08:33:40,952 - INFO - fetch index data: 000001.SH 20260328 -> 20260331\n2026-04-01 08:33:41,436 - INFO - fetch index data: 000300.SH 20260328 -> 20260331\n2026-04-01 08:33:41,887 - INFO - fetch index data: 000852.SH 20260328 -> 20260331\n"},"isError":false,"timestamp":1775003622116}}
{"type":"message","id":"14b7ee82","parentId":"81105449","timestamp":"2026-04-01T00:33:42.135Z","message":{"role":"toolResult","toolCallId":"call_ygc3PxSSWiq2kv9Q1yabSBrS|fc_077585180826814c0169cc67dbcc74819a8555066bd4f928bb","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"Incrementally refresh workspace A-share and index market data from Tushare.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\nimport os\nimport sys\nimport time\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\nimport tushare as ts\nfrom dotenv import load_dotenv\n\nROOT = Path(__file__).resolve().parents[1]\nDATA_DIR = ROOT / \"data\"\nANALYSIS_DIR = ROOT / \"quant_projects\" / \"daily_stock_analysis\"\nLOG_DIR = ROOT / \"logs\"\n\nPRICE_CSV = DATA_DIR / \"a_stock_history.csv\"\nLIST_CSV = DATA_DIR / \"a_stock_list.csv\"\nREPORT_JSON = LOG_DIR / \"download_tushare_update_latest.json\"\nLOG_FILE = LOG_DIR / \"download_tushare_update.log\"\n\nINDEX_TARGETS = {\n    \"000001.SH\": ANALYSIS_DIR / \"index_000001_SH.csv\",\n    \"000300.SH\": ANALYSIS_DIR / \"index_000300_SH.csv\",\n    \"000852.SH\": ANALYSIS_DIR / \"index_000852_SH.csv\",\n    \"000905.SH\": ANALYSIS_DIR / \"index_000905_SH.csv\",\n    \"399001.SZ\": ANALYSIS_DIR / \"index_399001_SZ.csv\",\n}\n\nEOD_READY_HOUR = 18\n\n\ndef setup_logging() -> logging.Logger:\n    LOG_DIR.mkdir(parents=True, exist_ok=True)\n    logger = logging.getLogger(\"download_tushare\")\n    logger.setLevel(logging.INFO)\n    logger.handlers.clear()\n\n    formatter = logging.Formatter(\"%(asctime)s - %(levelname)s - %(message)s\")\n\n    file_handler = logging.FileHandler(LOG_FILE, encoding=\"utf-8\")\n    file_handler.setFormatter(formatter)\n    logger.addHandler(file_handler)\n\n    stream_handler = logging.StreamHandler(sys.stdout)\n    stream_handler.setFormatter(formatter)\n    logger.addHandler(stream_handler)\n    return logger\n\n\nLOGGER = setup_logging()\n\n\ndef load_token() -> str:\n    env_candidates = [\n        ROOT / \"scripts\" / \".env\",\n        ANALYSIS_DIR / \".env.tushare\",\n        ROOT / \".env\",\n    ]\n    for path in env_candidates:\n        if path.exists():\n            load_dotenv(path, override=False)\n\n    token = os.getenv(\"TUSHARE_TOKEN\", \"\").strip()\n    if not token:\n        raise RuntimeError(\"TUSHARE_TOKEN is not configured\")\n    return token\n\n\ndef get_pro() -> Any:\n    token = load_token()\n    return ts.pro_api(token)\n\n\ndef now_local() -> datetime:\n    return datetime.now()\n\n\ndef resolve_target_trade_date(pro: Any, now: datetime) -> str:\n    reference_date = now.date()\n    if now.hour < EOD_READY_HOUR:\n        reference_date = reference_date - timedelta(days=1)\n\n    start_date = (reference_date - timedelta(days=14)).strftime(\"%Y%m%d\")\n    end_date = reference_date.strftime(\"%Y%m%d\")\n\n    cal = pro.trade_cal(\n        exchange=\"SSE\",\n        start_date=start_date,\n        end_date=end_date,\n        fields=\"cal_date,is_open,pretrade_date\",\n    )\n    if cal is None or cal.empty:\n        raise RuntimeError(\"failed to resolve latest trading day from trade_cal\")\n\n    cal = cal.copy()\n    cal[\"is_open\"] = pd.to_numeric(cal[\"is_open\"], errors=\"coerce\").fillna(0).astype(int)\n    open_days = cal.loc[cal[\"is_open\"] == 1, \"cal_date\"].astype(str).tolist()\n    if not open_days:\n        raise RuntimeError(\"no open trading day found in trade_cal window\")\n    return max(open_days)\n\n\ndef get_open_trade_days(pro: Any, start_date: str, end_date: str) -> list[str]:\n    cal = pro.trade_cal(\n        exchange=\"SSE\",\n        start_date=start_date,\n        end_date=end_date,\n        fields=\"cal_date,is_open\",\n    )\n    if cal is None or cal.empty:\n        return []\n    cal = cal.copy()\n    cal[\"is_open\"] = pd.to_numeric(cal[\"is_open\"], errors=\"coerce\").fillna(0).astype(int)\n    days = cal.loc[cal[\"is_open\"] == 1, \"cal_date\"].astype(str).tolist()\n    return sorted(days)\n\n\ndef read_latest_trade_date(path: Path, date_col: str = \"trade_date\") -> str:\n    if not path.exists():\n        return \"\"\n    frame = pd.read_csv(path, usecols=[date_col])\n    if frame.empty:\n        return \"\"\n    values = frame[date_col].dropna().astype(str).str.strip()\n    if values.empty:\n        return \"\"\n    normalized = values.str.replace(\"-\", \"\", regex=False).str[:8]\n    normalized = normalized[normalized.str.len() == 8]\n    return normalized.max() if not normalized.empty else \"\"\n\n\ndef refresh_stock_list(pro: Any) -> dict[str, Any]:\n    frames: list[pd.DataFrame] = []\n    for status in (\"L\", \"P\", \"D\"):\n        frame = pro.stock_basic(\n            exchange=\"\",\n            list_status=status,\n            fields=\"ts_code,symbol,name,area,industry,list_date,market,exchange,list_status,delist_date\",\n        )\n        if frame is not None and not frame.empty:\n            frames.append(frame)\n        time.sleep(0.15)\n\n    if not frames:\n        return {\"rows\": 0, \"path\": str(LIST_CSV), \"updated\": False}\n\n    combined = pd.concat(frames, ignore_index=True)\n    combined = combined.drop_duplicates(subset=[\"ts_code\"], keep=\"first\")\n    combined = combined.sort_values([\"ts_code\"]).reset_index(drop=True)\n    LIST_CSV.parent.mkdir(parents=True, exist_ok=True)\n    combined.to_csv(LIST_CSV, index=False)\n    return {\"rows\": int(len(combined)), \"path\": str(LIST_CSV), \"updated\": True}\n\n\ndef fetch_daily_by_trade_date(pro: Any, trade_date: str) -> pd.DataFrame:\n    frame = pro.daily(\n        trade_date=trade_date,\n        fields=\"ts_code,trade_date,open,high,low,close,vol,amount\",\n    )\n    if frame is None or frame.empty:\n        return pd.DataFrame(columns=[\"ts_code\", \"trade_date\", \"open\", \"high\", \"low\", \"close\", \"vol\", \"amount\"])\n\n    frame = frame.copy()\n    frame[\"trade_date\"] = pd.to_numeric(frame[\"trade_date\"], errors=\"coerce\").astype(\"Int64\")\n    for col in [\"open\", \"high\", \"low\", \"close\", \"vol\", \"amount\"]:\n        frame[col] = pd.to_numeric(frame[col], errors=\"coerce\")\n    frame = frame.dropna(subset=[\"ts_code\", \"trade_date\"])\n    frame[\"trade_date\"] = frame[\"trade_date\"].astype(int)\n    frame = frame.sort_values([\"trade_date\", \"ts_code\"]).reset_index(drop=True)\n    return frame\n\n\ndef update_price_history(pro: Any, target_trade_date: str) -> dict[str, Any]:\n    latest_existing = read_latest_trade_date(PRICE_CSV)\n    if latest_existing and latest_existing >= target_trade_date:\n        return {\n            \"path\": str(PRICE_CSV),\n            \"latest_before\": latest_existing,\n            \"latest_after\": latest_existing,\n            \"missing_trade_dates\": [],\n            \"added_rows\": 0,\n            \"updated\": False,\n        }\n\n    start_date = latest_existing if latest_existing else \"20150101\"\n    start_date_dt = datetime.strptime(start_date, \"%Y%m%d\") + timedelta(days=1 if latest_existing else 0)\n    missing_trade_dates = get_open_trade_days(pro, start_date_dt.strftime(\"%Y%m%d\"), target_trade_date)\n    if not missing_trade_dates:\n        return {\n            \"path\": str(PRICE_CSV),\n            \"latest_before\": latest_existing,\n            \"latest_after\": latest_existing,\n            \"missing_trade_dates\": [],\n            \"added_rows\": 0,\n            \"updated\": False,\n        }\n\n    frames: list[pd.DataFrame] = []\n    for trade_date in missing_trade_dates:\n        LOGGER.info(\"fetch daily market data: %s\", trade_date)\n        frame = fetch_daily_by_trade_date(pro, trade_date)\n        if not frame.empty:\n            frames.append(frame)\n            LOGGER.info(\"daily %s rows=%s\", trade_date, len(frame))\n        else:\n            LOGGER.warning(\"daily %s returned no rows\", trade_date)\n        time.sleep(0.2)\n\n    if not frames:\n        return {\n            \"path\": str(PRICE_CSV),\n            \"latest_before\": latest_existing,\n\n[128 more lines in file. Use offset=221 to continue.]"}],"isError":false,"timestamp":1775003622129}}
