{"type":"message","id":"56cbc297","parentId":"d7fc5576","timestamp":"2026-03-31T22:45:20.280Z","message":{"role":"toolResult","toolCallId":"call_zcHw9wk6YM7BJB5LC72lOS4b|fc_077585180826814c0169cc4e7ff238819aa0c151358e1eb2d4","toolName":"exec","content":[{"type":"text","text":"def send_feishu(msg):\n    import requests\n\n    payload = {\"msg_type\": \"text\", \"content\": {\"text\": msg}}\n    resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\n    return resp.json()\n\n\ndef main():\n    if not is_trading_day():\n        print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] 非 A 股交易日，跳过每日执行卡\")\n        return\n\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] 生成每日执行卡 v2...\")\n\n    strategy = parse_strategy(get_strategy_report())\n    audit = get_audit()\n    try:\n        holdings = get_holdings()\n    except Exception as e:\n        print(f\"[{datetime.now().strftime('%H:%M:%S')}] 中止发送：{e}\")\n        return\n    ibrief = get_intelligence_brief()\n\n    card = build_exec_card(strategy, audit, holdings, ibrief)\n\n    out_file = REPORTS / \"daily_exec_card_latest.md\"\n    out_file.write_text(card, encoding=\"utf-8\")\n    print(f\"已保存: {out_file.name}\")\n\n    print(\"\\n发送飞书...\")\n    result = send_feishu(card)\n    print(f\"发送结果: {result}\")\n\n    print(\"\\n\" + card)\n\n\nif __name__ == \"__main__\":\n    main()\n---\n\n\ndef main():\n    if not is_trading_day():\n        print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] 非 A 股交易日，跳过可执行简报\")\n        return\n\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] 生成可执行简报...\")\n\n    trade_card = get_latest_trade_card()\n    audit = get_latest_audit()\n    strategy = get_latest_strategy()\n    real_holdings, real_meta = get_real_holdings()\n    if real_meta.get(\"fallback_reason\") == \"missing_selected_real_holdings_source\":\n        print(f\"[{datetime.now().strftime('%H:%M:%S')}] 中止发送：missing_selected_real_holdings_source\")\n        return\n    sim_meta = get_simulated_holdings_summary()\n\n    brief = build_actionable_brief(\n        trade_card,\n        audit,\n        strategy,\n        real_holdings,\n        real_meta,\n        sim_meta,\n    )\n\n    out_file = REPORTS / \"actionable_brief_latest.md\"\n    out_file.write_text(brief, encoding=\"utf-8\")\n    print(f\"已保存: {out_file.name}\")\n\n    print(\"\\n发送飞书...\")\n    result = send_feishu(brief)\n    print(f\"发送结果: {result}\")\n\n    print(\"\\n\" + brief)\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n---\n        for h in ok_holds:\n            icon = \"🟢\" if h[\"pnl_pct\"] > 0 else \"🔵\"\n            lines.append(f\"  {icon} {h['code']} {h.get('name', '')[:8]} {h['pnl_pct']:+.1f}%\")\n\n    if failed:\n        lines.append(f\"\\n⚠️ 行情获取失败（{len(failed)} 只）\")\n        for h in failed:\n            lines.append(f\"  • {h['code']} {h.get('name', '')[:8]}\")\n\n    lines.append(f\"\\n【风控参数】软止损:{soft_stop}% 硬止损:{hard_stop}%\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    return \"\\n\".join(lines), len(hard_stop_hits) > 0 or len(soft_stop_hits) > 0\n\n\ndef main():\n    if not is_trading_day():\n        print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] 非 A 股交易日，跳过止损监控\")\n        return\n\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] 持仓止损监控...\")\n\n    try:\n        holdings = get_holdings()\n    except Exception as e:\n        print(f\"[{datetime.now().strftime('%H:%M:%S')}] 中止发送：{e}\")\n        return\n    audit = get_audit()\n\n    if not holdings:\n        print(\"无持仓数据\")\n        return\n\n    print(f\"监控 {len(holdings)} 只持仓...\")\n\n    checked = check_holdings_prices(holdings)\n    alert_msg, has_alert = build_alert(checked, audit)\n\n    print(\"\\n\" + alert_msg)\n\n    if has_alert:\n        print(\"\\n发送飞书告警...\")\n        result = send_feishu(alert_msg)\n        print(f\"发送结果: {result}\")\n    else:\n        print(\"无告警，不推送\")\n\n\nif __name__ == \"__main__\":\n    main()"}],"details":{"status":"completed","exitCode":0,"durationMs":8,"agg