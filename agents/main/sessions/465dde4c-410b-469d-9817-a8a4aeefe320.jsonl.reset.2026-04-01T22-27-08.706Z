ush.py to use this cleaner style. The key changes:1. Use strict financial keyword filtering (only show relevant news)2. Use 🔴🟢⚪ for market direction3. Group by category with count4. Use clean separators\\n5. Truncate headlines at 50 chars\\n6. Send as text card (not interactive - simpler and more reliable)\\n\\nLet me rewrite the script.\",\"thinkingSignature\":\"23d00889cc4a39697abe83fcac65440f8d71699a4b51987d9445c0e520ca85cb\"},{\"type\":\"text\",\"text\":\"这个格式好多了。现在重写一个更严格的版本，只保留财经相关、过滤噪音：\\n\"},{\"type\":\"toolCall\",\"id\":\"call_function_2b0nasz5bt1l_1\",\"name\":\"write\",\"arguments\":{\"content\":\"#!/usr/bin/env python3\\n\\\"\\\"\\\"\\nTrendRadar 格式化推送 V2 - 彭博/华尔街见闻风格\\n只筛选财经相关新闻，按类别分组，用专业格式推送到飞书\\n\\\"\\\"\\\"\\n\\nimport json, re, sys, html\\nfrom pathlib import Path\\nfrom datetime import datetime\\n\\nFEISHU_WEBHOOK = \\\"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\\\"\\n\\n# 严格筛选 - 只保留财经相关关键词\\nFINANCIAL_KEYWORDS = [\\n    # 市场\\n    \\\"股\\\", \\\"A股\\\", \\\"上证\\\", \\\"深证\\\", \\\"创业板\\\", \\\"科创板\\\", \\\"北证\\\", \\\"大盘\\\", \\\"指数\\\",\\n    \\\"涨\\\", \\\"跌\\\", \\\"涨停\\\", \\\"跌停\\\", \\\"牛市\\\", \\\"熊市\\\", \\\"回调\\\", \\\"反弹\\\", \\\"突破\\\",\\n    \\\"两市\\\", \\\"成交\\\", \\\"放量\\\", \\\"缩量\\\", \\\"净流入\\\", \\\"净流出\\\",\\n    # 宏观\\n    \\\"美联储\\\", \\\"降息\\\", \\\"加息\\\", \\\"CPI\\\", \\\"PPI\\\", \\\"GDP\\\", \\\"央行\\\", \\\"货币政策\\\",\\n    \\\"人民币\\\", \\\"美元\\\", \\\"汇率\\\", \\\"美债\\\", \\\"国债\\\", \\\"通胀\\\", \\\"衰退\\\", \\\"非农\\\", \\\"就业\\\",\\n    # 地缘\\n    \\\"中美\\\", \\\"关税\\\", \\\"贸易战\\\", \\\"制裁\\\", \\\"俄乌\\\", \\\"中东\\\", \\\"伊朗\\\", \\\"以色列\\\", \\\"油价\\\", \\\"原油\\\",\\n    \\\"战争\\\", \\\"冲突\\\", \\\"特朗普\\\", \\\"普京\\\",\\n    # 行业\\n    \\\"板块\\\", \\\"概念\\\", \\\"龙头\\\", \\\"主力\\\", \\\"资金\\\", \\\"热点\\\", \\\"轮动\\\", \\\"ETF\\\", \\\"外资\\\", \\\"北向\\\",\\n    # 商品\\n    \\\"黄金\\\", \\\"白银\\\", \\\"铜\\\", \\\"铝\\\", \\\"天然气\\\", \\\"大宗商品\\\",\\n    # 公司\\n    \\\"业绩\\\", \\\"财报\\\", \\\"营收\\\", \\\"利润\\\", \\\"分红\\\", \\\"回购\\\", \\\"增持\\\", \\\"减持\\\", \\\"预盈\\\", \\\"预亏\\\",\\n    # 科技\\n    \\\"AI\\\", \\\"人工智能\\\", \\\"芯片\\\", \\\"半导体\\\", \\\"英伟达\\\", \\\"算力\\\",\\n]\\n\\n# 分类关键词（互斥，只匹配一个分类）\\nCATEGORY_MAP = [\\n    (\\\"🌐 地缘政治\\\", [\\\"战争\\\", \\\"冲突\\\", \\\"制裁\\\", \\\"中东\\\", \\\"伊朗\\\", \\\"以色列\\\", \\\"中美\\\", \\\"俄乌\\\", \\\"俄罗斯\\\", \\\"普京\\\", \\\"关税\\\", \\\"贸易战\\\", \\\"北约\\\", \\\"胡塞\\\", \\\"导弹\\\", \\\"美以\\\", \\\"伊朗核\\\"]),\\n    (\\\"📊 宏观经济\\\", [\\\"美联储\\\", \\\"降息\\\", \\\"加息\\\", \\\"CPI\\\", \\\"PPI\\\", \\\"GDP\\\", \\\"央行\\\", \\\"货币政策\\\", \\\"通胀\\\", \\\"衰退\\\", \\\"非农\\\", \\\"就业\\\", \\\"财政\\\"]),\\n    (\\\"💹 A股市场\\\", [\\\"A股\\\", \\\"上证\\\", \\\"深证\\\", \\\"创业板\\\", \\\"科创板\\\", \\\"北证\\\", \\\"大盘\\\", \\\"指数\\\", \\\"涨\\\", \\\"跌\\\", \\\"涨停\\\", \\\"跌停\\\", \\\"牛市\\\", \\\"熊市\\\", \\\"回调\\\", \\\"反弹\\\", \\\"两市\\\", \\\"成交额\\\"]),\\n    (\\\"🏭 板块资金\\\", [\\\"板块\\\", \\\"概念\\\", \\\"龙头\\\", \\\"主力\\\", \\\"资金\\\", \\\"净流入\\\", \\\"净流出\\\", \\\"热点\\\", \\\"轮动\\\", \\\"ETF\\\", \\\"外资\\\", \\\"北向\\\", \\\"融资\\\", \\\"融券\\\"]),\\n    (\\\"💰 大宗商品\\\", [\\\"黄金\\\", \\\"白银\\\", \\\"铜\\\", \\\"铝\\\", \\\"原油\\\", \\\"天然气\\\", \\\"大宗商品\\\", \\\"商品期货\\\"]),\\n    (\\\"🏢 公司财报\\\", [\\\"业绩\\\", \\\"财报\\\", \\\"营收\\\", \\\"利润\\\", \\\"分红\\\", \\\"回购\\\", \\\"增持\\\", \\\"减持\\\", \\\"预盈\\\", \\\"预亏\\\", \\\"ST\\\", \\\"退市\\\"]),\\n    (\\\"🤖 AI/科技\\\", [\\\"AI\\\", \\\"人工智能\\\", \\\"芯片\\\", \\\"半导体\\\", \\\"英伟达\\\", \\\"算力\\\", \\\"大模型\\\", \\\"科技股\\\"]),\\n]\\n\\ndef clean(text):\\n    text = re.sub(r'<[^>]+>', '', str(text))\\n    text = html.unescape(text)\\n    return text.strip()\\n\\ndef parse_txt(filepath):\\n    \\\"\\\"\\\"解析 TrendRadar txt 文件\\\"\\\"\\\"\\n    content = Path(filepath).read_text(encoding='utf-8')\\n    items = []\\n    for line in content.split('\\\\n'):\\n        line = line.strip()\\n        if not line or ' | ' not in line:\\n            continue\\n        parts = line.split(' | ')\\n        if len(parts) != 2:\\n            continue\\n        source, rest = parts[0].strip(), parts[1].strip()\\n        # 检查是否是新闻条目\\n        match = re.match(r'^\\\\d+\\\\.\\\\s*(.+?)\\\\s*\\\\[URL:(.+?)\\\\]$', rest)\\n        if match:\\n            title = clean(match.group(1))\\n            url = match.group(2)\\n            items.append({'title': title, 'url': url, 'source': source})\\n    return items\\n\\ndef is_financial(item):\\n    \\\"\\\"\\\"判断是否是财经相关新闻\\\"\\\"\\\"\\n    title = item['title']\\n    count = sum(1 for kw in FINANCIAL_KEYWORDS if kw in title)\\n    return count >= 1\\n\\ndef classify(item):\\n    \\\"\\\"\\\"给新闻分类\\\"\\\"\\\"\\n    title = item['title']\\n    for cat_name, keywords in CATEGORY_MAP:\\n        for kw in keywords:\\n            if kw in title:\\n                return cat_name\\n    return None\\n\\ndef market_signal(title):\\n    \\\"\\\"\\\"判断市场信号\\\"\\\"\\\"\\n    down = ['跌', '熊市', '回调', '利空', '大跌', '创新低', '缩量下跌', '净流出', '倒']\\n    up = ['涨', '牛市', '反弹', '利好', '大涨', '创新高', '放量上涨', '净流入', '升']\\n    t = title.lower()\\n    for w in down:\\n        if w in title: return '🔴'\\n    for w in up:\\n        if w in title: return '🟢'\\n    return '⚪'\\n\\ndef build_report(items, date_str):\\n    \\\"\\\"\\\"构建彭博风格报告\\\"\\\"\\\"\\n    # 过滤只保留财经\\n    fin_items = [i for i in items if is_financial(i)]\\n    \\n    if not fin_items:\\n        return None\\n    \\n    # 按分类整理\\n    categories = {}\\n    for item in fin_items:\\n        cat = classify(item) or \\\"📰 其他\\\"\\n        if cat not in categories:\\n            categories[cat] = []\\n        categories[cat].append(item)\\n    \\n    # 构建消息\\n    lines = []\\n    lines.append(\\\"━━━━━━━━━━━━━━━━━━━━\\\")\\n    lines.append(f\\\"📡 财经热点晨报 | {date_str}\\\")\\n    lines.append(f\\\"📊 共筛选 {len(fin_items)} 条财经要闻\\\")\\n    lines.append(\\\"━━━━━━━━━━━━━━━━━━━━\\\")\\n    \\n    # 按优先级输出分类\\n    for cat_name, _ in CATEGORY_MAP:\\n        cat_items = categories.get(cat_name, [])\\n        if not cat_items:\\n            continue\\n        lines.append(\\\"\\\")\\n        lines.append(f\\\"{cat_name} ({len(cat_items)} 条)\\\")\\n        lines.append(\\\"\\\")\\n        for item in cat_items[:6]:  # 每类最多6条\\n            signal = market_signal(item['title'])\\n            title = item['title'][:48] + ('…' if len(item['title']) > 48 else '')\\n            lines.append(f\\\"  {signal} {title}\\\")\\n    \\n    # 其他财经\\n    other = categories.get(\\\"📰 其他\\\", [])\\n    if other:\\n        lines.append(\\\"\\\")\\n        lines.append(f\\\"📰 其他财经 ({len(other)} 条)\\\")\\n        lines.append(\\\"\\\")\\n        for item in other[:4]:\\n            title = item['title'][:48] + ('…' if len(item['title']) > 48 else '')\\n            lines.append(f\\\"  ⚪ {title}\\\")\\n    \\n    lines.append(\\\"\\\")\\n    lines.append(\\\"━━━━━━━━━━━━━━━━━━━━\\\")\\n    lines.append(f\\\"📊 数据来源：TrendRadar | {datetime.now().strftime('%H:%M:%S')}\\\")\\n    \\n    return '\\\\n'.join(lines)\\n\\ndef send_feishu(text):\\n    \\\"\\\"\\\"发送飞书\\\"\\\"\\\"\\n    import requests\\n    payload = {\\\"msg_type\\\": \\\"text\\\", \\\"content\\\": {\\\"text\\\": text}}\\n    resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\\n    return resp.json()\\n\\ndef main():\\n    today = datetime.now().strftime('%Y年%m月%d日')\\n    txt_dir = Path(f\\\"/Users/ling/.openclaw/workspace/other_projects/TrendRadar/output/{today}/txt\\\")\\n    \\n    if not txt_dir.exists():\\n        print(f\\\"未找到目录: {txt_dir}\\\")\\n        sys.exit(1)\\n    \\n    txt_files = sorted(txt_dir.glob(\\\"*.txt\\\"), key=lambda p: p.stat().st_mtime, reverse=True)\\n    if not txt_files:\\n        print(\\\"未找到 txt 文件\\\")\\n        sys.exit(1)\\n    \\n    latest = txt_files[0]\\n    print(f\\\"读取: {latest.name}\\\")\\n    \\n    items = parse_txt(latest)\\n    print(f\\\"共 {len(items)} 条新闻\\\")\\n    \\n    fin_count = sum(1 for i in items if is_financial(i))\\n    print(f\\\"财经相关: {fin_count} 条\\\")\\n    \\n    date_str = datetime.now().strftime('%Y-%m-%d %H:%M')\\n    report = build_report(items, date_str)\\n    \\n    if report:\\n        print(\\\"\\\\n发送飞书...\\\")\\n        result = send_feishu(report)\\n        print(f\\\"结果: {result}\\\")\\n    else:\\n        print(\\\"无财经内容，跳过发送\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n\",\"path\":\"/Users/ling/.openclaw/workspace/other_projects/TrendRadar/format_push_v2.py\"}}],\"api\":\"anthropic-messages\",\"provider\":\"minimax-portal\",\"model\":\"MiniMax-M2.7\",\"usage\":{\"input\":110058,\"output\":2205,\"cacheRead\":33192,\"cacheWrite\":0,\"totalTokens\":145455,\"cost\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"total\":0}},\"stopReason\":\"toolUse\",\"timestamp\":1774110546321}}\n/Users/ling/.openclaw/agents/coding-agent/sessions/6e3e57ac-1a2d-47ba-93df-8864dc12137e.jsonl.reset.2026-03-22T01-46-19.731Z:500:{\"type\":\"message\",\"id\":\"e11e4ac2\",\"parentId\":\"3bbed60a\",\"timestamp\":\"2026-03-21T16:29:58.110Z\",\"message\":{\"role\":\"toolResult\",\"toolCallId\":\"call_function_ohslzkzh08lm_1\",\"toolName\":\"exec\",\"content\":[{\"type\":\"text\",\"text\":\"读取: 00时05分.txt\\n共 0 条新闻\\n财经相关: 0 条\\n无财经内容，跳过发送\"}],\"details\":{\"status\":\"completed\",\"exitCode\":0,\"durationMs\":60,\"aggregated\":\"读取: 00时05分.txt\\n共 0 条新闻\\n财经相关: 0 条\\n无财经内容，跳过发送\",\"cwd\":\"/Users/ling/.openclaw/workspace-coding-agent\"},\"isError\":false,\"timestamp\":1774110598106}}\n/Users/ling/.openclaw/agents/main/sessions/5efd0625-fb87-4b70-a145-9d28f932deed.jsonl.reset.2026-03-30T23-04-10.553Z:285:{\"type\":\"message\",\"id\":\"97e1943e\",\"parentId\":\"ae6e05f3\",\"timestamp\":\"2026-03-30T12:52:18.908Z\",\"message\":{\"role\":\"toolResult\",\"toolCallId\":\"call_function_rs851d1nwtif_1\",\"toolName\":\"exec\",\"content\":[{\"type\":\"text\",\"text\":\"[📘 晚间版] 生成时间: 2026-03-30 20:00\\n\\n📊 **微博财经大V每日简报**\\n🕐 2026-03-30 20:00  |  共 10 位大V  |  财经内容 0 条\\n\\n── 重点内容摘录 ──\\n\\n── 今日要闻 ──\\n\\n⚠️ 仅供参考，不构成投资建议。\"}],\"details\":{\"status\":\"completed\",\"exitCode\":0,\"durationMs\":43,\"aggregated\":\"[📘 晚间版] 生成时间: 2026-03-30 20:00\\n\\n📊 **微博财经大V每日简报**\\n🕐 2026-03-30 20:00  |  共 10 位大V  |  财经内容 0 条\\n\\n── 重点内容摘录 ──\\n\\n── 今日要闻 ──\\n\\n⚠️ 仅供参考，不构成投资建议。\",\"cwd\":\"/Users/ling/.openclaw/workspace\"},\"isError\":false,\"timestamp\":1774875138893}}\n/Users/ling/.openclaw/agents/main/sessions/5efd0625-fb87-4b70-a145-9d28f932deed.jsonl.reset.2026-03-30T23-04-10.553Z:287:{\"type\":\"message\",\"id\":\"8dfaeed2\",\"parentId\":\"e88ad885\",\"timestamp\":\"2026-03-30T12:52:24.356Z\",\"message\":{\"role\":\"toolResult\",\"toolCallId\":\"call_function_88onm9hw0fil_1\",\"toolName\":\"exec\",\"content\":[{\"type\":\"text\",\"text\":\"[🌅 早间版] 生成时间: 2026-03-30 08:30\\n\\n📊 **微博财经大V每日简报**\\n🕐 2026-03-30 08:30  |  共 10 位大V  |  财经内容 0 条\\n\\n── 重点内容摘录 ──\\n\\n── 今日要闻 ──\\n\\n⚠️ 仅供参考，不构成投资建议。\"}],\"details\":{\"status\":\"completed\",\"exitCode\":0,\"durationMs\":30,\"aggregated\":\"[🌅 早间版] 生成时间: 2026-03-30 08:30\\n\\n📊 **微博财经大V每日简报**\\n🕐 2026-03-30 08:30  |  共 10 位大V  |  财经内容 0 条\\n\\n── 重点内容摘录 ──\\n\\n── 今日要闻 ──\\n\\n⚠️ 仅供参考，不构成投资建议。\",\"cwd\":\"/Users/ling/.openclaw/workspace\"},\"isError\":false,\"timestamp\":1774875144341}}\n/Users/ling/.openclaw/agents/main/sessions/5efd0625-fb87-4b70-a145-9d28f932deed.jsonl.reset.2026-03-30T23-04-10.553Z:288:{\"type\":\"message\",\"id\":\"c4ae6a6b\",\"parentId\":\"8dfaeed2\",\"timestamp\":\"2026-03-30T12:52:28.496Z\",\"message\":{\"role\":\"assistant\",\"content\":[{\"type\":\"thinking\",\"thinking\":\"Both reports today show \\\"财经内容 0 条\\\" - meaning no financial content was captured. This seems like the Weibo monitor skill might not be functioning correctly or the monitored accounts didn't post any financial content today.\\n\\nLet me check the log file to understand what happened.\",\"thinkingSignature\":\"f6bd0d98817476cf59e2674391a958960f451bf8551537530f4ac767438bccf6\"},{\"type\":\"toolCall\",\"id\":\"call_function_lu9u0mh7ovz2_1\",\"name\"