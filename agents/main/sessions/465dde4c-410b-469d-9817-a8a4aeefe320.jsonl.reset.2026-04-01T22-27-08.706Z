{"type":"message","id":"60809c78","parentId":"fa862fa4","timestamp":"2026-04-01T00:32:10.627Z","message":{"role":"toolResult","toolCallId":"call_4POrFDJx07rkWnXFfWcVFIql|fc_077585180826814c0169cc6789f90c819ab3df72a596c8a320","toolName":"exec","content":[{"type":"text","text":"usage: prepare_live_signal_tickets.py [-h] [--date DATE]\n                                      [--available-cash AVAILABLE_CASH]\n                                      [--account-nav ACCOUNT_NAV]\n                                      [--lot-size LOT_SIZE] [--force-rebuild]\n\n准备当日可消费的 live signal tickets\n\noptional arguments:\n  -h, --help            show this help message and exit\n  --date DATE           YYYYMMDD，默认今天\n  --available-cash AVAILABLE_CASH\n  --account-nav ACCOUNT_NAV\n  --lot-size LOT_SIZE\n  --force-rebuild       忽略现有当日产物并重建 tickets"}],"details":{"status":"completed","exitCode":0,"durationMs":238,"aggregated":"usage: prepare_live_signal_tickets.py [-h] [--date DATE]\n                                      [--available-cash AVAILABLE_CASH]\n                                      [--account-nav ACCOUNT_NAV]\n                                      [--lot-size LOT_SIZE] [--force-rebuild]\n\n准备当日可消费的 live signal tickets\n\noptional arguments:\n  -h, --help            show this help message and exit\n  --date DATE           YYYYMMDD，默认今天\n  --available-cash AVAILABLE_CASH\n  --account-nav ACCOUNT_NAV\n  --lot-size LOT_SIZE\n  --force-rebuild       忽略现有当日产物并重建 tickets","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1775003530624}}
{"type":"message","id":"451b008b","parentId":"60809c78","timestamp":"2026-04-01T00:32:10.631Z","message":{"role":"toolResult","toolCallId":"call_LzYZuFD681mq8npwMDoZ8TJv|fc_077585180826814c0169cc6789f93c819aa86bc2a562526f1f","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env bash\nset -euo pipefail\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\nWORKSPACE_ROOT=\"$(cd \"$ROOT/../..\" && pwd)\"\nPYRUN=\"$ROOT/scripts/cron_python.sh\"\nREPORT_DIR=\"$ROOT/research/reports\"\nexport REPORT_DIR\ncd \"$ROOT\"\n\n# shellcheck disable=SC1091\nsource \"$ROOT/scripts/source_optional_env.sh\"\n\nexport LITELLM_LOCAL_MODEL_COST_MAP=true\n\"$PYRUN\" --runtime-only\n\nfor ENV_FILE in \\\n  \"$ROOT/.env.tushare\" \\\n  \"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis/.env.tushare\"\ndo\n  source_optional_env_file \"$ENV_FILE\"\ndone\n\nDATE_TAG=\"${1:-$(date +%Y%m%d)}\"\nTICKETS_FILE=\"${2:-}\"\nRUN_MODE=\"${3:-${PAPER_PROFILE_RUN_MODE:-eod}}\"\nRETRY_MAX=\"${PAPER_PROFILES_RETRY_MAX:-2}\"\nRETRY_SLEEP_SEC=\"${PAPER_PROFILES_RETRY_SLEEP_SEC:-5}\"\nLIVE_SCHEDULER_CFG=\"$ROOT/config/live_scheduler_v1.json\"\nTODAY_TAG=\"$(date +%Y%m%d)\"\nLIVE_SYSTEM_FILE=\"$ROOT/research/reports/live_system_v1_${DATE_TAG}.json\"\nMERGED_FILE=\"$ROOT/signals/merged/merged_signals_${DATE_TAG}.csv\"\n\ncheck_runtime_halt_before_profiles() {\n  local runtime_file=\"$REPORT_DIR/runtime_risk_state_latest.json\"\n  if [[ ! -f \"$runtime_file\" ]]; then\n    return 0\n  fi\n  local halt\n  halt=\"$(\"$PYRUN\" --no-runtime-log - \"$runtime_file\" \"$DATE_TAG\" <<'PY2'\nimport json, sys\nfrom pathlib import Path\np = Path(sys.argv[1])\ndate_tag = sys.argv[2]\nobj = json.loads(p.read_text(encoding=\"utf-8\"))\nlatest = obj.get(\"latest_runtime\") or {}\nif str(obj.get(\"date_tag\") or \"\") != str(date_tag):\n    print(\"0\")\nelse:\n    print(\"1\" if latest.get(\"halt_new_buy\") else \"0\")\nPY2\n)\"\n  if [[ \"$halt\" == \"1\" ]]; then\n    echo \"[BLOCK] runtime halt_new_buy=true; skip paper profile execution before account write\"\n    return 2\n  fi\n  return 0\n}\n\nread_live_sizing() {\n  \"$PYRUN\" --no-runtime-log - \"$LIVE_SCHEDULER_CFG\" <<'PY'\nimport json\nimport sys\nfrom pathlib import Path\n\ncfg_path = Path(sys.argv[1])\npayload = json.loads(cfg_path.read_text(encoding=\"utf-8\")) if cfg_path.exists() else {}\nprint(payload.get(\"available_cash\", 1000000))\nprint(payload.get(\"account_nav\", payload.get(\"available_cash\", 1000000)))\nPY\n}\n\nensure_same_day_merged_signals() {\n  local sizing available_cash account_nav force_flag=\"\"\n  sizing=\"$(read_live_sizing)\"\n  available_cash=\"$(printf '%s\\n' \"$sizing\" | sed -n '1p')\"\n  account_nav=\"$(printf '%s\\n' \"$sizing\" | sed -n '2p')\"\n  if [[ \"${FORCE_REFRESH:-0}\" == \"1\" ]]; then\n    force_flag=\"--force-rebuild\"\n    echo \"[INFO] force rebuilding same-day merged signals date=${DATE_TAG}\"\n  else\n    echo \"[INFO] missing merged_signals, materializing same-day live signal chain date=${DATE_TAG}\"\n  fi\n  \"$PYRUN\" scripts/prepare_live_signal_tickets.py \\\n    --date \"$DATE_TAG\" \\\n    --available-cash \"$available_cash\" \\\n    --account-nav \"$account_nav\" \\\n    $force_flag\n}\n\nensure_same_day_live_system() {\n  if [[ \"$DATE_TAG\" != \"$TODAY_TAG\" ]]; then\n    return 0\n  fi\n  if [[ \"${FORCE_REFRESH:-0}\" == \"1\" ]]; then\n    echo \"[INFO] force rebuilding same-day live system date=${DATE_TAG}\"\n  else\n    echo \"[INFO] missing live_system, materializing same-day live system date=${DATE_TAG}\"\n  fi\n  \"$PYRUN\" scripts/run_live_system_v1.py\n}\n\nrun_once() {\n  if [[ -n \"$TICKETS_FILE\" ]]; then\n    bash scripts/run_paper_trading_profiles_v1.sh \"$DATE_TAG\" \"$TICKETS_FILE\" \"$RUN_MODE\"\n  else\n    bash scripts/run_paper_trading_profiles_v1.sh \"$DATE_TAG\" \"\" \"$RUN_MODE\"\n  fi\n}\n\ncheck_runtime_halt_before_profiles || exit $?\n\nif [[ \"${FORCE_REFRESH:-0}\" == \"1\" || ! -f \"$LIVE_SYSTEM_FILE\" ]]; then\n  ensure_same_day_live_system\nfi\n\nif [[ ! -f \"$LIVE_SYSTEM_FILE\" ]]; then\n  echo \"[ERROR] 缺少当日 live_system: $LIVE_SYSTEM_FILE\"\n  exit 2\nfi\n\nif [[ -z \"$TICKETS_FILE\" && ( ! -f \"$MERGED_FILE\" || \"${FORCE_REFRESH:-0}\" == \"1\" ) ]]; then\n  ensure_same_day_merged_signals\nfi\n\nif [[ -z \"$TICKETS_FILE\" && ! -f \"$MERGED_FILE\" ]]; then\n  echo \"[ERROR] 缺少当日 merged_signals: $MERGED_FILE\"\n  exit 2\nfi\n\nattempt=1\nwhile (( attempt <= RETRY_MAX )); do\n  echo \"[RUN] paper_profiles attempt ${attempt}/${RETRY_MAX} date=${DATE_TAG} mode=${RUN_MODE}\"\n  if run_once; then\n    echo \"[OK] paper_profiles updated date=${DATE_TAG}\"\n    echo \"- defensive: research/reports/paper_defensive_trading_dashboard_latest.html\"\n    echo \"- balanced: research/reports/paper_balanced_trading_dashboard_latest.html\"\n    echo \"- aggressive: research/reports/paper_aggressive_trading_dashboard_latest.html\"\n    echo \"- comparison: research/reports/paper_profiles_comparison_latest.html\"\n    exit 0"}],"details":{"status":"completed","exitCode":0,"durationMs":18,"aggregated":"#!/usr/bin/env bash\nset -euo pipefail\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\nWORKSPACE_ROOT=\"$(cd \"$ROOT/../..\" && pwd)\"\nPYRUN=\"$ROOT/scripts/cron_python.sh\"\nREPORT_DIR=\"$ROOT/research/reports\"\nexport REPORT_DIR\ncd \"$ROOT\"\n\n# shellcheck disable=SC1091\nsource \"$ROOT/scripts/source_optional_env.sh\"\n\nexport LITELLM_LOCAL_MODEL_COST_MAP=true\n\"$PYRUN\" --runtime-only\n\nfor ENV_FILE in \\\n  \"$ROOT/.env.tushare\" \\\n  \"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis/.env.tushare\"\ndo\n  source_optional_env_file \"$ENV_FILE\"\ndone\n\nDATE_TAG=\"${1:-$(date +%Y%m%d)}\"\nTICKETS_FILE=\"${2:-}\"\nRUN_MODE=\"${3:-${PAPER_PROFILE_RUN_MODE:-eod}}\"\nRETRY_MAX=\"${PAPER_PROFILES_RETRY_MAX:-2}\"\nRETRY_SLEEP_SEC=\"${PAPER_PROFILES_RETRY_SLEEP_SEC:-5}\"\nLIVE_SCHEDULER_CFG=\"$ROOT/config/live_scheduler_v1.json\"\nTODAY_TAG=\"$(date +%Y%m%d)\"\nLIVE_SYSTEM_FILE=\"$ROOT/research/reports/live_system_v1_${DATE_TAG}.json\"\nMERGED_FILE=\"$ROOT/signals/merged/merged_signals_${DATE_TAG}.csv\"\n\ncheck_runtime_halt_before_profiles() {\n  local runtime_file=\"$REPORT_DIR/runtime_risk_state_latest.json\"\n  if [[ ! -f \"$runtime_file\" ]]; then\n    return 0\n  fi\n  local halt\n  halt=\"$(\"$PYRUN\" --no-runtime-log - \"$runtime_file\" \"$DATE_TAG\" <<'PY2'\nimport json, sys\nfrom pathlib import Path\np = Path(sys.argv[1])\ndate_tag = sys.argv[2]\nobj = json.loads(p.read_text(encoding=\"utf-8\"))\nlatest = obj.get(\"latest_runtime\") or {}\nif str(obj.get(\"date_tag\") or \"\") != str(date_tag):\n    print(\"0\")\nelse:\n    print(\"1\" if latest.get(\"halt_new_buy\") else \"0\")\nPY2\n)\"\n  if [[ \"$halt\" == \"1\" ]]; then\n    echo \"[BLOCK] runtime halt_new_buy=true; skip paper profile execution before account write\"\n    return 2\n  fi\n  return 0\n}\n\nread_live_sizing() {\n  \"$PYRUN\" --no-runtime-log - \"$LIVE_SCHEDULER_CFG\" <<'PY'\nimport json\nimport sys\nfrom pathlib import Path\n\ncfg_path = Path(sys.argv[1])\npayload = json.loads(cfg_path.read_text(encoding=\"utf-8\")) if cfg_path.exists() else {}\nprint(payload.get(\"available_cash\", 1000000))\nprint(payload.get(\"account_nav\", payload.get(\"available_cash\", 1000000)))\nPY\n}\n\nensure_same_day_merged_signals() {\n  local sizing available_cash account_nav force_flag=\"\"\n  sizing=\"$(read_live_sizing)\"\n  available_cash=\"$(printf '%s\\n' \"$sizing\" | sed -n '1p')\"\n  account_nav=\"$(printf '%s\\n' \"$sizing\" | sed -n '2p')\"\n  if [[ \"${FORCE_REFRESH:-0}\" == \"1\" ]]; then\n    force_flag=\"--force-rebuild\"\n    echo \"[INFO] force rebuilding same-day merged signals date=${DATE_TAG}\"\n  else\n    echo \"[INFO] missing merged_signals, materializing same-day live signal chain date=${DATE_TAG}\"\n  fi\n  \"$PYRUN\" scripts/prepare_live_signal_tickets.py \\\n    --date \"$DATE_TAG\" \\\n    --available-cash \"$available_cash\" \\\n    --account-nav \"$account_nav\" \\\n    $force_flag\n}\n\nensure_same_day_live_system() {\n  if [[ \"$DATE_TAG\" != \"$TODAY_TAG\" ]]; then\n    return 0\n  fi\n  if [[ \"${FORCE_REFRESH:-0}\" == \"1\" ]]; then\n    echo \"[INFO] force rebuilding same-day live system date=${DATE_TAG}\"\n  else\n    echo \"[INFO] missing live_system, materializing same-day live system date=${DATE_TAG}\"\n  fi\n  \"$PYRUN\" scripts/run_live_system_v1.py\n}\n\nrun_once() {\n  if [[ -n \"$TICKETS_FILE\" ]]; then\n    bash scripts/run_paper_trading_profiles_v1.sh \"$DATE_TAG\" \"$TICKETS_FILE\" \"$RUN_MODE\"\n  else\n    bash scripts/run_paper_trading_profiles_v1.sh \"$DATE_TAG\" \"\" \"$RUN_MODE\"\n  fi\n}\n\ncheck_runtime_halt_before_profiles || exit $?\n\nif [[ \"${FORCE_REFRESH:-0}\" == \"1\" || ! -f \"$LIVE_SYSTEM_FILE\" ]]; then\n  ensure_same_day_live_system\nfi\n\nif [[ ! -f \"$LIVE_SYSTEM_FILE\" ]]; then\n  echo \"[ERROR] 缺少当日 live_system: $LIVE_SYSTEM_FILE\"\n  exit 2\nfi\n\nif [[ -z \"$TICKETS_FILE\" && ( ! -f \"$MERGED_FILE\" || \"${FORCE_REFRESH:-0}\" == \"1\" ) ]]; then\n  ensure_same_day_merged_signals\nfi\n\nif [[ -z \"$TICKETS_FILE\" && ! -f \"$MERGED_FILE\" ]]; then\n  echo \"[ERROR] 缺少当日 merged_signals: $MERGED_FILE\"\n  exit 2\nfi\n\nattempt=1\nwhile (( attempt <= RETRY_MAX )); do\n  echo \"[RUN] paper_profiles attempt ${attempt}/${RETRY_MAX} date=${DATE_TAG} mode=${RUN_MODE}\"\n  if run_once; then\n    echo \"[OK] paper_profiles updated date=${DATE_TAG}\"\n    echo \"- defensive: research/reports/paper_defensive_trading_dashboard_latest.html\"\n    echo \"- balanced: research/reports/paper_balanced_trading_dashboard_latest.html\"\n    echo \"- aggressive: research/reports/paper_aggressive_trading_dashboard_latest.html\"\n    echo \"- comparison: research/reports/paper_profiles_comparison_latest.html\"\n    exit 0","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1775003530627}}
