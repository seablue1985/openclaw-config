signals/raw | tail -20\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":15}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":116690,"output":413,"cacheRead":0,"cacheWrite":0,"totalTokens":117103,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775003475435,"responseId":"resp_077585180826814c0169cc6772b2ac819a92718ef20db5c9ec"}}
{"type":"message","id":"5684ee26","parentId":"e222defd","timestamp":"2026-04-01T00:32:00.404Z","message":{"role":"toolResult","toolCallId":"call_itmxfYHAKIb5mhzmuJyWnxNY|fc_077585180826814c0169cc677c6230819a9205de87273eb3e6","toolName":"read","content":[{"type":"text","text":"                \"strategy\": str(row.get(\"strategy_id\") or \"\"),\n                \"risk\": str(row.get(\"risk_status\") or row.get(\"risk_adjustment\") or \"\"),\n                \"comment\": str(row.get(\"reason\") or \"\"),\n            })\n        normalized.sort(key=lambda x: x[\"score\"], reverse=True)\n        return normalized\n\n    # 优先读取当天 latest 策略报告，保证候选随盘中/推送时间变化\n    strategy_report = reports / \"today_stock_strategy_report_latest.json\"\n    if strategy_report.exists():\n        try:\n            data = json.loads(strategy_report.read_text(encoding=\"utf-8\"))\n            date_tag = str(data.get(\"date_tag\") or \"\")\n            if today_str in date_tag or today_short in date_tag.replace(\"-\", \"\"):\n                result[\"signal_file\"] = strategy_report.name\n                result[\"signal_generated_at\"] = str(data.get(\"generated_at\") or \"\")\n                result[\"buy_candidates_count\"] = int(data.get(\"buy_candidates\") or 0)\n                result[\"research_buy_candidates_count\"] = int(data.get(\"research_buy_candidates\") or 0)\n\n                current_rows = list(data.get(\"priority_candidates\") or []) + list(data.get(\"guarded_candidates\") or [])\n                research_rows = list(data.get(\"research_priority_candidates\") or []) + list(data.get(\"research_guarded_candidates\") or [])\n                display_rows = list(data.get(\"display_tech_candidates\") or []) + list(data.get(\"display_guard_candidates\") or [])\n\n                top_rows = current_rows or research_rows or display_rows\n                result[\"top_buy\"] = _normalize_candidate_rows(top_rows)[:8]\n                result[\"top_sell\"] = _normalize_candidate_rows(list(data.get(\"sell_candidates_list\") or []))[:5]\n                result[\"signals_source_kind\"] = \"today_strategy_report\"\n                return result\n        except Exception as e:\n            result[\"signal_error\"] = str(e)\n\n    # fallback：找最新 merged 信号 CSV（今天或昨天）\n    today_csv = signals_dir / f\"merged_signals_{today_short}.csv\"\n    yesterday = (today - timedelta(days=1)).strftime(\"%Y%m%d\")\n    yesterday_csv = signals_dir / f\"merged_signals_{yesterday}.csv\"\n\n    signal_file = today_csv if today_csv.exists() else (\n        yesterday_csv if yesterday_csv.exists() else None\n    )\n\n    if signal_file is None:\n        all_csv = sorted(signals_dir.glob(\"merged_signals_*.csv\"),\n                         key=lambda p: p.stat().st_mtime, reverse=True)\n        if all_csv:\n            signal_file = all_csv[0]\n\n    if signal_file and signal_file.exists():\n        result[\"signal_file\"] = str(signal_file.name)\n        result[\"signal_generated_at\"] = datetime.fromtimestamp(signal_file.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\")\n        try:\n            reader = csv.DictReader(signal_file.open(encoding=\"utf-8\"))\n            for row in reader:\n                if row.get(\"trade_date\"):\n                    code = row.get(\"ts_code\", \"\")\n                    name = stock_name(code, fallback_to_code=False)\n                    entry = {\n                        \"date\": row.get(\"trade_date\", \"\"),\n                        \"code\": code,\n                        \"name\": name,\n                        \"signal\": row.get(\"signal_type\", \"\"),\n                        \"score\": float(row.get(\"score\", 0)),\n                        \"weight\": float(row.get(\"target_weight\", 0)),\n                        \"strategy\": row.get(\"strategy_id\", \"\"),\n                        \"risk\": row.get(\"risk_flag\", \"\"),\n                        \"comment\": row.get(\"comment\", \"\"),\n                    }\n                    result[\"signals\"].append(entry)\n        except Exception as e:\n            result[\"signal_error\"] = str(e)\n\n        buy_signals = [s for s in result[\"signals\"] if s[\"signal\"] == \"BUY\"]\n        buy_signals.sort(key=lambda x: x[\"score\"], reverse=True)\n        result[\"top_buy\"] = buy_signals[:8]\n        result[\"top_sell\"] = [s for s in result[\"signals\"] if s[\"signal\"] == \"SELL\"][:5]\n        result[\"signals_source_kind\"] = \"merged_signals\"\n\n    return result\n\n\n# ============ 4. 读取最新持仓 ============\n\n[301 more lines in file. Use offset=440 to continue.]"}],"isError":false,"timestamp":1775003520401}}
