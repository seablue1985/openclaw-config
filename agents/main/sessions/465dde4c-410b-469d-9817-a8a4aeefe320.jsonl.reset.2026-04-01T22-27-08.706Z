{"type":"message","id":"e5706033","parentId":"e457c620","timestamp":"2026-03-31T22:43:35.056Z","message":{"role":"toolResult","toolCallId":"call_eh8NZJiIlnXbVg8s5pQJUYHZ|fc_077585180826814c0169cc4e167790819a962000b2248795b1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"从 ths-local-holdings skill 同步“已选择”的真实持仓。\n\n行为：\n1. 总是生成账本候选报告（供人工核对）\n2. 读取 config/ths_local_holdings_selection.json\n3. 调用 skill 导出经选择后的持仓\n4. 写入标准化输出，供日报/止损/简报优先消费\n\"\"\"\n\nfrom __future__ import annotations\n\nimport csv\nimport json\nimport shutil\nimport subprocess\nimport sys\nimport tempfile\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nWORKSPACE = Path.home() / \".openclaw/workspace\"\nQUANT_ROOT = WORKSPACE / \"quant_projects\" / \"personal-a-share-research-system\"\nQUANT_REPORTS = QUANT_ROOT / \"research\" / \"reports\"\nWORKSPACE_REPORTS = WORKSPACE / \"research\" / \"reports\"\nQUANT_CONFIG = QUANT_ROOT / \"config\"\nSKILL_SCRIPT = Path.home() / \".openclaw/skills/ths-local-holdings/scripts/ths_local_holdings.py\"\nSELECTION_CONFIG = QUANT_CONFIG / \"ths_local_holdings_selection.json\"\n\n\ndef run_cmd(args: list[str]) -> subprocess.CompletedProcess[str]:\n    return subprocess.run(args, capture_output=True, text=True, check=False)\n\n\ndef load_json(path: Path) -> Any:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef write_candidates() -> list[dict[str, Any]]:\n    proc = run_cmd([sys.executable, str(SKILL_SCRIPT), \"list\"])\n    if proc.returncode != 0:\n        raise RuntimeError(proc.stderr.strip() or proc.stdout.strip() or \"ths-local-holdings list failed\")\n    payload = json.loads(proc.stdout)\n\n    QUANT_REPORTS.mkdir(parents=True, exist_ok=True)\n    WORKSPACE_REPORTS.mkdir(parents=True, exist_ok=True)\n\n    json_path = QUANT_REPORTS / \"ths_local_holdings_candidates_latest.json\"\n    md_path = QUANT_REPORTS / \"ths_local_holdings_candidates_latest.md\"\n    json_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n    lines = [\"# THS 本地持仓候选账本\", \"\"]\n    for item in payload:\n        summary = item.get(\"summary\", {})\n        lines.append(f\"## {item.get('path','')}\")\n        lines.append(f\"- ledger_ids: {', '.join(item.get('ledger_ids', [])) or '-'}\")\n        lines.append(\n            f\"- 摘要: 总数 {summary.get('total',0)} | A股 {summary.get('a_stock',0)} | 港股 {summary.get('hk_stock',0)} | 基金 {summary.get('fund',0)}\"\n        )\n        symbols = summary.get(\"symbols\", []) or []\n        if symbols:\n            lines.append(f\"- 标的: {', '.join(symbols)}\")\n        lines.append(\"\")\n    md_path.write_text(\"\\n\".join(lines), encoding=\"utf-8\")\n\n    for src in [json_path, md_path]:\n        dst = WORKSPACE_REPORTS / src.name\n        dst.write_bytes(src.read_bytes())\n\n    return payload\n\n\ndef normalize_currency(symbol: str) -> str:\n    return \"HKD\" if str(symbol).endswith(\".HK\") else \"CNY\"\n\n\ndef build_compat_rows(rich_rows: list[dict[str, str]]) -> list[dict[str, Any]]:\n    out = []\n    for row in rich_rows:\n        symbol = str(row.get(\"symbol\") or \"\").strip().upper()\n        if not symbol:\n            continue\n        qty = int(float(str(row.get(\"quantity\") or \"0\").strip() or 0))\n        if qty <= 0:\n            continue\n        cost_raw = str(row.get(\"cost_price\") or \"\").strip()\n        cost = float(cost_raw) if cost_raw else 0.0\n        asset_type = str(row.get(\"asset_type\") or \"stock\").strip().lower()\n        out.append(\n            {\n                \"ts_code\": symbol,\n                \"qty\": qty,\n                \"name\": str(row.get(\"name\") or \"\").strip(),\n                \"cost_price\": cost,\n                \"currency\": normalize_currency(symbol),\n                \"asset_type\": asset_type,\n            }\n        )\n    return out\n\n\ndef write_csv(path: Path, rows: list[dict[str, Any]], fieldnames: list[str]) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with path.open(\"w\", newline=\"\", encoding=\"utf-8-sig\") as f:\n        writer = csv.DictWriter(f, fieldnames=fieldnames)\n        writer.writeheader()\n        writer.writerows(rows)\n\n\ndef sync_selected() -> int:\n    candidates = write_candidates()\n\n    if not SELECTION_CONFIG.exists():\n        print(f\"未找到选择配置: {SELECTION_CONFIG}\")\n        print(\"已生成候选账本报告，请先填写配置后再同步。\")\n        return 2\n\n    cfg = load_json(SELECTION_CONFIG)\n    if not isinstance(cfg, dict) or not cfg.get(\"enabled\", True):\n        print(f\"选择配置未启用: {SELECTION_CONFIG}\")\n        return 2\n\n    date_tag = datetime.now().strftime(\"%Y%m%d\")\n\n    with tempfile.TemporaryDirectory(prefix=\"ths-selected-\") as tmp:\n        tmpdir = Path(tmp)\n        proc = run_cmd(\n            [\n                sys.executable,\n                str(SKILL_SCRIPT),\n                \"export\",\n                \"--selection-config\",\n                str(SELECTION_CONFIG),\n                \"--out-dir\",\n                str(tmpdir),\n                \"--csv-name\",\n                \"ths_selected_holdings.csv\",\n                \"--json-name\",\n                \"ths_selected_holdings.json\",\n            ]\n        )\n        if proc.returncode != 0:\n            print(proc.stderr.strip() or proc.stdout.strip() or \"selected export failed\")\n            return proc.returncode or 1\n\n        payload = json.loads(proc.stdout)\n        rich_csv = Path(payload[\"csv\"])\n        rich_json = Path(payload[\"json\"])\n\n        with rich_csv.open(encoding=\"utf-8-sig\") as f:\n            rich_rows = list(csv.DictReader(f))\n        compat_rows = build_compat_rows(rich_rows)\n\n        ths_latest_csv = QUANT_REPORTS / \"ths_selected_holdings_latest.csv\"\n        ths_dated_csv = QUANT_REPORTS / f\"ths_selected_holdings_{date_tag}.csv\"\n        ths_latest_json = QUANT_REPORTS / \"ths_selected_holdings_latest.json\"\n        ths_dated_json = QUANT_REPORTS / f\"ths_selected_holdings_{date_tag}.json\"\n        account_latest_csv = QUANT_REPORTS / \"account_holdings_selected_latest.csv\"\n        account_dated_csv = QUANT_REPORTS / f\"account_holdings_selected_{date_tag}.csv\"\n\n        shutil.copy2(rich_csv, ths_latest_csv)\n        shutil.copy2(rich_csv, ths_dated_csv)\n        shutil.copy2(rich_json, ths_latest_json)\n        shutil.copy2(rich_json, ths_dated_json)\n\n        write_csv(\n            account_latest_csv,\n            compat_rows,\n            [\"ts_code\", \"qty\", \"name\", \"cost_price\", \"currency\", \"asset_type\"],\n        )\n        write_csv(\n            account_dated_csv,\n            compat_rows,\n            [\"ts_code\", \"qty\", \"name\", \"cost_price\", \"currency\", \"asset_type\"],\n        )\n\n        summary_md = QUANT_REPORTS / \"ths_selected_holdings_sync_latest.md\"\n        lines = [\n            \"# THS 已选择持仓同步\",\n            \"\",\n            f\"- 生成时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\",\n            f\"- 选择配置：{SELECTION_CONFIG}\",\n            f\"- 候选账本数：{len(candidates)}\",\n            f\"- 选中账本文件：{', '.join(payload.get('selected_files', [])) or '-'}\",\n            f\"- 股票摘要：总数 {payload['summary'].get('total',0)} | A股 {payload['summary'].get('a_stock',0)} | 港股 {payload['summary'].get('hk_stock',0)} | 基金 {payload['summary'].get('fund',0)}\",\n            f\"- 输出：{ths_latest_csv.name} / {account_latest_csv.name}\",\n        ]\n        summary_md.write_text(\"\\n\".join(lines), encoding=\"utf-8\")\n\n        for src in [ths_latest_csv, ths_dated_csv, ths_latest_json, ths_dated_json, account_latest_csv, account_dated_csv, summary_md]:\n            dst = WORKSPACE_REPORTS / src.name\n            dst.write_bytes(src.read_bytes())\n\n    print(json.dumps({\n        \"ths_selected_csv\": str(ths_latest_csv),\n        \"account_selected_csv\": str(account_latest_csv),\n        \"summary\": payload[\"summary\"],\n        \"selected_files\": payload.get(\"selected_files\", []),\n    }, ensure_ascii=False, indent=2))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(sync_selected())\n"}],"isError":false,"timestamp":1774997015050}}
{"type":"message","id":"30028e0f","parentId":"e5706033","timestamp":"2026-03-31T22:44:48.853Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Revising code structure**\n\nI think I need to make a larger edit. I should consider replacing the code after the `write_csv` function, and it makes sense to insert some helper functions. There’s this need to rewrite the `sync_selected` function. I want to use exact code blocks, so my approach will be to craft the replacement from right after `write_csv` to the end. It feels like this will make things more manageable moving forward!","thinkingSignature":"{\"id\":\"rs_077585180826814c0169cc4e1a6534819ab2dd413b938aa9e5\",\"type\":\"reasoning\",\"encrypted_content\":\"gAAAAABpzE4dnA1Iwkl4hQDGVAAGfFkdIiMhlr2Bm8WUqSANbssWvEpoKkIpnvEiPJU0607IIJVa3kQODJYlKo5cLYcrhK-tEpwLdTegEZGuIMyeWZC_8l5clUzjC4akuD_92HZYuAsFRcF-JeP1V7kfnQeZq5T__Y-rKCCz2HFAkazQ1C4J0bNNpHU71Gvpj-3Mzp2bypw_tPX55sNrpsiB6m60apGg_y3ERe01prtpoYE2dOzlxzUGYGjtJMMv_asvVySCm62gSajFzIA11nT_ZZZPi_NSQXEeTK32akMrAZeBnbv5n_TXQe1vE89peQzmHZ_xT_002Hd8-lUgHpZZXFwei4taJxGtZzqTRiwegCacK9mKCwtzxQMqb6pfc-QNCJT_Qw1xgSdnss67kXctiUhY1yUQbyZmLgvdcHDU8sfKV8oymAofp6P2D0Whndv1jOOHk1-3yBID5HdIrZhjsgeeGud4LOImdXAQDSO7rXuhxTXLihtCg2Qp8-oRaoSDI2pOcrwDWXnXnlToatMNb7Vq8tfgfjIfOlMFgjWRoz_L4cCR_VNOy2Wyr_RWzjkGpMKKVVCuHNPwX6wZVN5x1sG93abtV8Db1FwHJhi6xFddihR8GktDCfg3I_yPUxwqt7DQMWpLnUu44LXY0btPoGOyC8aYDnp-May585rOsVRukELI2HY1Ylw1d6vwHRtV1L-3i_wmgxBQFajJuw4DMlGBOVYnN55Oap_EE1vIUHFTuGv9v0Q1dzAqwPCDFyIrVNFfBqGiSVVk4tlTHXthM-iGzPMKwJKRKaVNWUdg5Gy4Gq5rmzNlWvzKi2qoq9kXV8o4jBCYn12nungIvdTEtDH58JtVpbM4kzif8pSkGNNbzS92oXju-r58ruKDbS3WbwwbLVFvLogYCl_xstUUfHNbGhKqWenEINBPV6jkJkWSqGKzZup4Ls6lxBU8VWh9gi4WZfKtI8XRF694kbPk_23QWU1UKtD-B6YagfOvwiA5nBkqPEveGdT3fQcKkbp-r2wDwxZaxojldL0XnAbNQ2xh2mV3RyC03tc1uGKGvml4QmQ88ZHnV3uK_9EO4XW3Il_7IhW3\",\"summary\":[{\"type\":\"summary_text\",\"text\":\"**Revising code structure**\\n\\nI think I need to make a larger edit. I should consider replacing the code after the `write_csv` function, and it makes sense to insert some helper functions. There’s this need to rewrite the `sync_selected` function. I want to use exact code blocks, so my approach will be to craft the replacement from right after `write_csv` to the end. It feels like this will make things more manageable moving forward!\"}]}"},{"type":"toolCall","id":"call_DQrX054lIocFjBqlap7Wx2eq|fc_077585180826814c0169cc4e1d9620819a96f60b3a996fee9a","name":"edit","arguments":{"file":"/Users/ling/.openclaw/workspace/scripts/sync_selected_real_holdings.py","oldText":"def write_csv(path: Path, rows: list[dict[str, Any]], fieldnames: list[str]) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with path.open(\"w\", newline=\"\", encoding=\"utf-8-sig\") as f:\n        writer = csv.DictWriter(f, fieldnames=fieldnames)\n        writer.writeheader()\n        writer.writerows(rows)\n\n\ndef sync_selected() -> int:\n    candidates = write_candidates()\n\n    if not SELECTION_CONFIG.exists():\n        print(f\"未找到选择配置: {SELECTION_CONFIG}\")\n        print(\"已生成候选账本报告，请先填写配置后再同步。\")\n        return 2\n\n    cfg = load_json(SELECTION_CONFIG)\n    if not isinstance(cfg, dict) or not cfg.get(\"enabled\", True):\n        print(f\"选择配置未启用: {SELECTION_CONFIG}\")\n        return 2\n\n    date_tag = datetime.now().strftime(\"%Y%m%d\")\n\n    with tempfile.TemporaryDirectory(prefix=\"ths-selected-\") as tmp:\n        tmpdir = Path(tmp)\n        proc = run_cmd(\n            [\n                sys.executable,\n                str(SKILL_SCRIPT),\n                \"export\",\n                \"--selection-config\",\n                str(SELECTION_CONFIG),\n                \"--out-dir\",\n                str(tmpdir),\n                \"--csv-name\",\n                \"ths_selected_holdings.csv\",\n                \"--json-name\",\n                \"ths_selected_holdings.json\",\n            ]\n        )\n        if proc.returncode != 0:\n            print(proc.stderr.strip() or proc.stdout.strip() or \"selected export failed\")\n            return proc.returncode or 1\n\n        payload = json.loads(proc.stdout)\n        rich_csv = Path(payload[\"csv\"])\n        rich_json = Path(payload[\"json\"])\n\n        with rich_csv.open(encoding=\"utf-8-sig\") as f:\n            rich_rows = list(csv.DictReader(f))\n        compat_rows = build_compat_rows(rich_rows)\n\n        ths_latest_csv = QUANT_REPORTS / \"ths_selected_holdings_latest.csv\"\n        ths_dated_csv = QUANT_REPORTS / f\"ths_selected_holdings_{date_tag}.csv\"\n        ths_latest_json = QUANT_REPORTS / \"ths_selected_holdings_latest.json\"\n        ths_dated_json = QUANT_REPORTS / f\"ths_selected_holdings_{date_tag}.json\"\n        account_latest_csv = QUANT_REPORTS / \"account_holdings_selected_latest.csv\"\n        account_dated_csv = QUANT_REPORTS / f\"account_holdings_selected_{date_tag}.csv\"\n\n        shutil.copy2(rich_csv, ths_latest_csv)\n        shutil.copy2(rich_csv, ths_dated_csv)\n        shutil.copy2(rich_json, ths_latest_json)\n        shutil.copy2(rich_json, ths_dated_json)\n\n        write_csv(\n            account_latest_csv,\n            compat_rows,\n            [\"ts_code\", \"qty\", \"name\", \"cost_price\", \"currency\", \"asset_type\"],\n        )\n        write_csv(\n            account_dated_csv,\n            compat_rows,\n            [\"ts_code\", \"qty\", \"name\", \"cost_price\", \"currency\", \"asset_type\"],\n        )\n\n        summary_md = QUANT_REPORTS / \"ths_selected_holdings_sync_latest.md\"\n        lines = [\n            \"# THS 已选择持仓同步\",\n            \"\",\n            f\"- 生成时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\",\n            f\"- 选择配置：{SELECTION_CONFIG}\",\n            f\"- 候选账本数：{len(candidates)}\",\n            f\"- 选中账本文件：{', '.join(payload.get('selected_files', [])) or '-'}\",\n            f\"- 股票摘要：总数 {payload['summary'].get('total',0)} | A股 {payload['summary'].get('a_stock',0)} | 港股 {payload['summary'].get('hk_stock',0)} | 基金 {payload['summary'].get('fund',0)}\",\n            f\"- 输出：{ths_latest_csv.name} / {account_latest_csv.name}\",\n        ]\n        summary_md.write_text(\"\\n\".join(lines), encoding=\"utf-8\")\n\n        for src in [ths_latest_csv, ths_dated_csv, ths_latest_json, ths_dated_json, account_latest_csv, account_dated_csv, summary_md]:\n            dst = WORKSPACE_REPORTS / src.name\n            dst.write_bytes(src.read_bytes())\n\n    print(json.dumps({\n        \"ths_selected_csv\": str(ths_latest_csv),\n        \"account_selected_csv\": str(account_latest_csv),\n        \"summary\": payload[\"summary\"],\n        \"selected_files\": payload.get(\"selected_files\", []),\n    }, ensure_ascii=False, indent=2))\n    return 0\n","newText":"def write_csv(path: Path, rows: list[dict[str, Any]], fieldnames: list[str]) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with path.open(\"w\", newline=\"\", encoding=\"utf-8-sig\") as f:\n        writer = csv.DictWriter(f, fieldnames=fieldnames)\n        writer.writeheader()\n        writer.writerows(rows)\n\n\ndef _extract_date_tag(path: Path) -> str:\n    digits = \"\".join(ch for ch in path.stem if ch.isdigit())\n    if len(digits) >= 8:\n        return digits[:8]\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef _load_csv_rows(path: Path) -> list[dict[str, str]]:\n    with path.open(encoding=\"utf-8-sig\", newline=\"\") as f:\n        return [dict(row) for row in csv.DictReader(f) if row]\n\n\ndef _manual_source_candidates() -> list[tuple[Path, str, str]]:\n    dated_web = sorted(\n        [p for p in QUANT_REPORTS.glob(\"ths_web_selected_holdings_*.csv\") if \"latest\" not in p.name],\n        key=lambda p: p.stat().st_mtime,\n        reverse=True,\n    )\n    dated_xlsx = sorted(\n        QUANT_REPORTS.glob(\"real_holdings_from_feishu_xlsx_*.csv\"),\n        key=lambda p: p.stat().st_mtime,\n        reverse=True,\n    )\n    candidates: list[tuple[Path, str, str]] = []\n    ordered = [\n        (QUANT_REPORTS / \"ths_web_selected_holdings_latest.csv\", \"web_selected_latest\", \"web\"),\n        *[(p, \"web_selected_dated\", \"web\") for p in dated_web],\n        *[(p, \"feishu_xlsx_manual\", \"manual\") for p in dated_xlsx],\n        (QUANT_CONFIG / \"portfolio_positions_manual.csv\", \"portfolio_positions_manual\", \"manual\"),\n    ]\n    seen: set[Path] = set()\n    for path, reason, source_type in ordered:\n        if not path.exists():\n            continue\n        resolved = path.resolve()\n        if resolved in seen:\n            continue\n        seen.add(resolved)\n        candidates.append((path, reason, source_type))\n    return candidates\n\n\ndef _materialize_selected_outputs(\n    rich_rows: list[dict[str, str]],\n    *,\n    date_tag: str,\n    selected_files: list[str],\n    source_reason: str,\n    source_type: str,\n    candidates_count: int,\n) -> dict[str, Any]:\n    compat_rows = build_compat_rows(rich_rows)\n    if not compat_rows:\n        raise RuntimeError(\"selected holdings rows empty after normalization\")\n\n    ths_latest_csv = QUANT_REPORTS / \"ths_selected_holdings_latest.csv\"\n    ths_dated_csv = QUANT_REPORTS / f\"ths_selected_holdings_{date_tag}.csv\"\n    ths_latest_json = QUANT_REPORTS / \"ths_selected_holdings_latest.json\"\n    ths_dated_json = QUANT_REPORTS / f\"ths_selected_holdings_{date_tag}.json\"\n    account_latest_csv = QUANT_REPORTS / \"account_holdings_selected_latest.csv\"\n    account_dated_csv = QUANT_REPORTS / f\"account_holdings_selected_{date_tag}.csv\"\n    source_meta_latest = QUANT_REPORTS / \"selected_real_holdings_source_latest.json\"\n\n    rich_fieldnames = list(dict.fromkeys(k for row in rich_rows for k in row.keys()))\n    if not rich_fieldnames:\n        rich_fieldnames = [\"symbol\", \"asset_type\", \"name\", \"quantity\", \"cost_price\"]\n    write_csv(ths_latest_csv, rich_rows, rich_fieldnames)\n    write_csv(ths_dated_csv, rich_rows, rich_fieldnames)\n\n    payload = {\n        \"selected_holdings_source\": source_type,\n        \"source_reason\": source_reason,\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"selected_files\": selected_files,\n        \"summary\": {\n            \"total\": len(rich_rows),\n            \"a_stock\": sum(1 for row in rich_rows if str(row.get(\"symbol\") or \"\").endswith((\".SZ\", \".SH\"))),\n            \"hk_stock\": sum(1 for row in rich_rows if str(row.get(\"symbol\") or \"\").endswith(\".HK\")),\n            \"fund\": sum(1 for row in rich_rows if str(row.get(\"asset_type\") or \"\").lower() in {\"fund\", \"etf\"}),\n            \"symbols\": [str(row.get(\"symbol\") or \"\").strip().upper() for row in rich_rows if str(row.get(\"symbol\") or \"\").strip()],\n        },\n        \"holdings\": rich_rows,\n        \"meta\": {\n            \"selection_config\": str(SELECTION_CONFIG),\n            \"candidates_count\": candidates_count,\n        },\n    }\n    ths_latest_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    ths_dated_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n    write_csv(\n        account_latest_csv,\n        compat_rows,\n        [\"ts_code\", \"qty\", \"name\", \"cost_price\", \"currency\", \"asset_type\"],\n    )\n    write_csv(\n        account_dated_csv,\n        compat_rows,\n        [\"ts_code\", \"qty\", \"name\", \"cost_price\", \"currency\", \"asset_type\"],\n    )\n\n    source_meta = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"selected_holdings_source\": source_type,\n        \"source_reason\": source_reason,\n        \"selected_files\": selected_files,\n        \"holding_count\": len(compat_rows),\n        \"account_selected_csv\": str(account_latest_csv),\n        \"ths_selected_csv\": str(ths_latest_csv),\n    }\n    source_meta_latest.write_text(json.dumps(source_meta, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n    summary_md = QUANT_REPORTS / \"ths_selected_holdings_sync_latest.md\"\n    lines = [\n        \"# THS 已选择持仓同步\",\n        \"\",\n        f\"- 生成时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\",\n        f\"- 选择配置：{SELECTION_CONFIG}\",\n        f\"- 候选账本数：{candidates_count}\",\n        f\"- 来源类型：{source_type}\",\n        f\"- 来源原因：{source_reason}\",\n        f\"- 选中源文件：{', '.join(selected_files) or '-'}\",\n        f\"- 股票摘要：总数 {payload['summary'].get('total',0)} | A股 {payload['summary'].get('a_stock',0)} | 港股 {payload['summary'].get('hk_stock',0)} | 基金 {payload['summary'].get('fund',0)}\",\n        f\"- 输出：{ths_latest_csv.name} / {account_latest_csv.name}\",\n    ]\n    summary_md.write_text(\"\\n\".join(lines), encoding=\"utf-8\")\n\n    for src in [\n        ths_latest_csv,\n        ths_dated_csv,\n        ths_latest_json,\n        ths_dated_json,\n        account_latest_csv,\n        account_dated_csv,\n        source_meta_latest,\n        summary_md,\n    ]:\n        dst = WORKSPACE_REPORTS / src.name\n        dst.write_bytes(src.read_bytes())\n\n    return {\n        \"ths_selected_csv\": str(ths_latest_csv),\n        \"account_selected_csv\": str(account_latest_csv),\n        \"summary\": payload[\"summary\"],\n        \"selected_files\": selected_files,\n        \"source_reason\": source_reason,\n        \"source_type\": source_type,\n    }\n\n\ndef _materialize_from_existing_trusted_source(candidates_count: int) -> dict[str, Any] | None:\n    for path, source_reason, source_type in _manual_source_candidates():\n        try:\n            rich_rows = _load_csv_rows(path)\n        except Exception:\n            continue\n        compat_rows = build_compat_rows(rich_rows)\n        if not compat_rows:\n            continue\n        return _materialize_selected_outputs(\n            rich_rows,\n            date_tag=_extract_date_tag(path),\n            selected_files=[str(path)],\n            source_reason=source_reason,\n            source_type=source_type,\n            candidates_count=candidates_count,\n        )\n    return None\n\n\ndef _has_explicit_selection(cfg: dict[str, Any]) -> bool:\n    return bool((cfg.get(\"selected_ledger_ids\") or []) or (cfg.get(\"symbol_allowlist\") or []))\n\n\ndef sync_selected() -> int:\n    candidates = write_candidates()\n\n    cfg: dict[str, Any] = {}\n    if SELECTION_CONFIG.exists():\n        loaded = load_json(SELECTION_CONFIG)\n        if isinstance(loaded, dict):\n            cfg = loaded\n\n    if cfg and not cfg.get(\"enabled\", True):\n        print(f\"选择配置未启用: {SELECTION_CONFIG}\")\n        return 2\n\n    if not cfg or not _has_explicit_selection(cfg):\n        fallback = _materialize_from_existing_trusted_source(len(candidates))\n        if fallback:\n            print(json.dumps(fallback, ensure_ascii=False, indent=2))\n            return 0\n        print(f\"未找到可用显式选择配置: {SELECTION_CONFIG}\")\n        print(\"且未找到可物化的可信 web/xlsx/manual 持仓源。\")\n        return 2\n\n    date_tag = datetime.now().strftime(\"%Y%m%d\")\n\n    with tempfile.TemporaryDirectory(prefix=\"ths-selected-\") as tmp:\n        tmpdir = Path(tmp)\n        proc = run_cmd(\n            [\n                sys.executable,\n                str(SKILL_SCRIPT),\n                \"export\",\n                \"--selection-config\",\n                str(SELECTION_CONFIG),\n                \"--out-dir\",\n                str(tmpdir),\n                \"--csv-name\",\n                \"ths_selected_holdings.csv\",\n                \"--json-name\",\n                \"ths_selected_holdings.json\",\n            ]\n        )\n        if proc.returncode != 0:\n            fallback = _materialize_from_existing_trusted_source(len(candidates))\n            if fallback:\n                print(json.dumps(fallback, ensure_ascii=False, indent=2))\n                return 0\n            print(proc.stderr.strip() or proc.stdout.strip() or \"selected export failed\")\n            return proc.returncode or 1\n\n        payload = json.loads(proc.stdout)\n        rich_csv = Path(payload[\"csv\"])\n\n        with rich_csv.open(encoding=\"utf-8-sig\") as f:\n            rich_rows = list(csv.DictReader(f))\n\n        result = _materialize_selected_outputs(\n            rich_rows,\n            date_tag=date_tag,\n            selected_files=payload.get(\"selected_files\", []),\n            source_reason=\"ths_local_holdings_export\",\n            source_type=\"selected\",\n            candidates_count=len(candidates),\n        )\n\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n    return 0\n"},"partialJson":"{\"file\":\"/Users/ling/.openclaw/workspace/scripts/sync_selected_real_holdings.py\",\"oldText\":\"def write_csv(path: Path, rows: list[dict[str, Any]], fieldnames: list[str]) -> None:\\n    path.parent.mkdir(parents=True, exist_ok=True)\\n    with path.open(\\\"w\\\", newline=\\\"\\\", encoding=\\\"utf-8-sig\\\") as f:\\n        writer = csv.DictWriter(f, fieldnames=fieldnames)\\n        writer.writeheader()\\n        writer.writerows(rows)\\n\\n\\ndef sync_selected() -> int:\\n    candidates = write_candidates()\\n\\n    if not SELECTION_CONFIG.exists():\\n        print(f\\\"未找到选择配置: {SELECTION_CONFIG}\\\")\\n        print(\\\"已生成候选账本报告，请先填写配置后再同步。\\\")\\n        return 2\\n\\n    cfg = load_json(SELECTION_CONFIG)\\n    if not isinstance(cfg, dict) or not cfg.get(\\\"enabled\\\", True):\\n        print(f\\\"选择配置未启用: {SELECTION_CONFIG}\\\")\\n        return 2\\n\\n    date_tag = datetime.now().strftime(\\\"%Y%m%d\\\")\\n\\n    with tempfile.TemporaryDirectory(prefix=\\\"ths-selected-\\\") as tmp:\\n        tmpdir = Path(tmp)\\n        proc = run_cmd(\\n            [\\n                sys.executable,\\n                str(SKILL_SCRIPT),\\n                \\\"export\\\",\\n                \\\"--selection-config\\\",\\n                str(SELECTION_CONFIG),\\n                \\\"--out-dir\\\",\\n                str(tmpdir),\\n                \\\"--csv-name\\\",\\n                \\\"ths_selected_holdings.csv\\\",\\n                \\\"--json-name\\\",\\n                \\\"ths_selected_holdings.json\\\",\\n            ]\\n        )\\n        if proc.returncode != 0:\\n            print(proc.stderr.strip() or proc.stdout.strip() or \\\"selected export failed\\\")\\n            return proc.returncode or 1\\n\\n        payload = json.loads(proc.stdout)\\n        rich_csv = Path(payload[\\\"csv\\\"])\\n        rich_json = Path(payload[\\\"json\\\"])\\n\\n        with rich_csv.open(encoding=\\\"utf-8-sig\\\") as f:\\n            rich_rows = list(csv.DictReader(f))\\n        compat_rows = build_compat_rows(rich_rows)\\n\\n        ths_latest_csv = QUANT_REPORTS / \\\"ths_selected_holdings_latest.csv\\\"\\n        ths_dated_csv = QUANT_REPORTS / f\\\"ths_selected_holdings_{date_tag}.csv\\\"\\n        ths_latest_json = QUANT_REPORTS / \\\"ths_selected_holdings_latest.json\\\"\\n        ths_dated_json = QUANT_REPORTS / f\\\"ths_selected_holdings_{date_tag}.json\\\"\\n        account_latest_csv = QUANT_REPORTS / \\\"account_holdings_selected_latest.csv\\\"\\n        account_dated_csv = QUANT_REPORTS / f\\\"account_holdings_selected_{date_tag}.csv\\\"\\n\\n        shutil.copy2(rich_csv, ths_latest_csv)\\n        shutil.copy2(rich_csv, ths_dated_csv)\\n        shutil.copy2(rich_json, ths_latest_json)\\n        shutil.copy2(rich_json, ths_dated_json)\\n\\n        write_csv(\\n            account_latest_csv,\\n            compat_rows,\\n            [\\\"ts_code\\\", \\\"qty\\\", \\\"name\\\", \\\"cost_price\\\", \\\"currency\\\", \\\"asset_type\\\"],\\n        )\\n        write_csv(\\n            account_dated_csv,\\n            compat_rows,\\n            [\\\"ts_code\\\", \\\"qty\\\", \\\"name\\\", \\\"cost_price\\\", \\\"currency\\\", \\\"asset_type\\\"],\\n        )\\n\\n        summary_md = QUANT_REPORTS / \\\"ths_selected_holdings_sync_latest.md\\\"\\n        lines = [\\n            \\\"# THS 已选择持仓同步\\\",\\n            \\\"\\\",\\n            f\\\"- 生成时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\\",\\n            f\\\"- 选择配置：{SELECTION_CONFIG}\\\",\\n            f\\\"- 候选账本数：{len(candidates)}\\\",\\n            f\\\"- 选中账本文件：{', '.join(payload.get('selected_files', [])) or '-'}\\\",\\n            f\\\"- 股票摘要：总数 {payload['summary'].get('total',0)} | A股 {payload['summary'].get('a_stock',0)} | 港股 {payload['summary'].get('hk_stock',0)} | 基金 {payload['summary'].get('fund',0)}\\\",\\n            f\\\"- 输出：{ths_latest_csv.name} / {account_latest_csv.name}\\\",\\n        ]\\n        summary_md.write_text(\\\"\\\\n\\\".join(lines), encoding=\\\"utf-8\\\")\\n\\n        for src in [ths_latest_csv, ths_dated_csv, ths_latest_json, ths_dated_json, account_latest_csv, account_dated_csv, summary_md]:\\n            dst = WORKSPACE_REPORTS / src.name\\n            dst.write_bytes(src.read_bytes())\\n\\n    print(json.dumps({\\n        \\\"ths_selected_csv\\\": str(ths_latest_csv),\\n        \\\"account_selected_csv\\\": str(account_latest_csv),\\n        \\\"summary\\\": payload[\\\"summary\\\"],\\n        \\\"selected_files\\\": payload.get(\\\"selected_files\\\", []),\\n    }, ensure_ascii=False, indent=2))\\n    return 0\\n\",\"newText\":\"def write_csv(path: Path, rows: list[dict[str, Any]], fieldnames: list[str]) -> None:\\n    path.parent.mkdir(parents=True, exist_ok=True)\\n    with path.open(\\\"w\\\", newline=\\\"\\\", encoding=\\\"utf-8-sig\\\") as f:\\n        writer = csv.DictWriter(f, fieldnames=fieldnames)\\n        writer.writeheader()\\n        writer.writerows(rows)\\n\\n\\ndef _extract_date_tag(path: Path) -> str:\\n    digits = \\\"\\\".join(ch for ch in path.stem if ch.isdigit())\\n    if len(digits) >= 8:\\n        return digits[:8]\\n    return datetime.now().strftime(\\\"%Y%m%d\\\")\\n\\n\\ndef _load_csv_rows(path: Path) -> list[dict[str, str]]:\\n    with path.open(encoding=\\\"utf-8-sig\\\", newline=\\\"\\\") as f:\\n        return [dict(row) for row in csv.DictReader(f) if row]\\n\\n\\ndef _manual_source_candidates() -> list[tuple[Path, str, str]]:\\n    dated_web = sorted(\\n        [p for p in QUANT_REPORTS.glob(\\\"ths_web_selected_holdings_*.csv\\\") if \\\"latest\\\" not in p.name],\\n        key=lambda p: p.stat().st_mtime,\\n        reverse=True,\\n    )\\n    dated_xlsx = sorted(\\n        QUANT_REPORTS.glob(\\\"real_holdings_from_feishu_xlsx_*.csv\\\"),\\n        key=lambda p: p.stat().st_mtime,\\n        reverse=True,\\n    )\\n    candidates: list[tuple[Path, str, str]] = []\\n    ordered = [\\n        (QUANT_REPORTS / \\\"ths_web_selected_holdings_latest.csv\\\", \\\"web_selected_latest\\\", \\\"web\\\"),\\n        *[(p, \\\"web_selected_dated\\\", \\\"web\\\") for p in dated_web],\\n        *[(p, \\\"feishu_xlsx_manual\\\", \\\"manual\\\") for p in dated_xlsx],\\n        (QUANT_CONFIG / \\\"portfolio_positions_manual.csv\\\", \\\"portfolio_positions_manual\\\", \\\"manual\\\"),\\n    ]\\n    seen: set[Path] = set()\\n    for path, reason, source_type in ordered:\\n        if not path.exists():\\n            continue\\n        resolved = path.resolve()\\n        if resolved in seen:\\n            continue\\n        seen.add(resolved)\\n        candidates.append((path, reason, source_type))\\n    return candidates\\n\\n\\ndef _materialize_selected_outputs(\\n    rich_rows: list[dict[str, str]],\\n    *,\\n    date_tag: str,\\n    selected_files: list[str],\\n    source_reason: str,\\n    source_type: str,\\n    candidates_count: int,\\n) -> dict[str, Any]:\\n    compat_rows = build_compat_rows(rich_rows)\\n    if not compat_rows:\\n        raise RuntimeError(\\\"selected holdings rows empty after normalization\\\")\\n\\n    ths_latest_csv = QUANT_REPORTS / \\\"ths_selected_holdings_latest.csv\\\"\\n    ths_dated_csv = QUANT_REPORTS / f\\\"ths_selected_holdings_{date_tag}.csv\\\"\\n    ths_latest_json = QUANT_REPORTS / \\\"ths_selected_holdings_latest.json\\\"\\n    ths_dated_json = QUANT_REPORTS / f\\\"ths_selected_holdings_{date_tag}.json\\\"\\n    account_latest_csv = QUANT_REPORTS / \\\"account_holdings_selected_latest.csv\\\"\\n    account_dated_csv = QUANT_REPORTS / f\\\"account_holdings_selected_{date_tag}.csv\\\"\\n    source_meta_latest = QUANT_REPORTS / \\\"selected_real_holdings_source_latest.json\\\"\\n\\n    rich_fieldnames = list(dict.fromkeys(k for row in rich_rows for k in row.keys()))\\n    if not rich_fieldnames:\\n        rich_fieldnames = [\\\"symbol\\\", \\\"asset_type\\\", \\\"name\\\", \\\"quantity\\\", \\\"cost_price\\\"]\\n    write_csv(ths_latest_csv, rich_rows, rich_fieldnames)\\n    write_csv(ths_dated_csv, rich_rows, rich_fieldnames)\\n\\n    payload = {\\n        \\\"selected_holdings_source\\\": source_type,\\n        \\\"source_reason\\\": source_reason,\\n        \\\"generated_at\\\": datetime.now().strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n        \\\"selected_files\\\": selected_files,\\n        \\\"summary\\\": {\\n            \\\"total\\\": len(rich_rows),\\n            \\\"a_stock\\\": sum(1 for row in rich_rows if str(row.get(\\\"symbol\\\") or \\\"\\\").endswith((\\\".SZ\\\", \\\".SH\\\"))),\\n            \\\"hk_stock\\\": sum(1 for row in rich_rows if str(row.get(\\\"symbol\\\") or \\\"\\\").endswith(\\\".HK\\\")),\\n            \\\"fund\\\": sum(1 for row in rich_rows if str(row.get(\\\"asset_type\\\") or \\\"\\\").lower() in {\\\"fund\\\", \\\"etf\\\"}),\\n            \\\"symbols\\\": [str(row.get(\\\"symbol\\\") or \\\"\\\").strip().upper() for row in rich_rows if str(row.get(\\\"symbol\\\") or \\\"\\\").strip()],\\n        },\\n        \\\"holdings\\\": rich_rows,\\n        \\\"meta\\\": {\\n            \\\"selection_config\\\": str(SELECTION_CONFIG),\\n            \\\"candidates_count\\\": candidates_count,\\n        },\\n    }\\n    ths_latest_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\\\"utf-8\\\")\\n    ths_dated_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\\\"utf-8\\\")\\n\\n    write_csv(\\n        account_latest_csv,\\n        compat_rows,\\n        [\\\"ts_code\\\", \\\"qty\\\", \\\"name\\\", \\\"cost_price\\\", \\\"currency\\\", \\\"asset_type\\\"],\\n    )\\n    write_csv(\\n        account_dated_csv,\\n        compat_rows,\\n        [\\\"ts_code\\\", \\\"qty\\\", \\\"name\\\", \\\"cost_price\\\", \\\"currency\\\", \\\"asset_type\\\"],\\n    )\\n\\n    source_meta = {\\n        \\\"generated_at\\\": datetime.now().strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n        \\\"selected_holdings_source\\\": source_type,\\n        \\\"source_reason\\\": source_reason,\\n        \\\"selected_files\\\": selected_files,\\n        \\\"holding_count\\\": len(compat_rows),\\n        \\\"account_selected_csv\\\": str(account_latest_csv),\\n        \\\"ths_selected_csv\\\": str(ths_latest_csv),\\n    }\\n    source_meta_latest.write_text(json.dumps(source_meta, ensure_ascii=False, indent=2), encoding=\\\"utf-8\\\")\\n\\n    summary_md = QUANT_REPORTS / \\\"ths_selected_holdings_sync_latest.md\\\"\\n    lines = [\\n        \\\"# THS 已选择持仓同步\\\",\\n        \\\"\\\",\\n        f\\\"- 生成时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\\",\\n        f\\\"- 选择配置：{SELECTION_CONFIG}\\\",\\n        f\\\"- 候选账本数：{candidates_count}\\\",\\n        f\\\"- 来源类型：{source_type}\\\",\\n        f\\\"- 来源原因：{source_reason}\\\",\\n        f\\\"- 选中源文件：{', '.join(selected_files) or '-'}\\\",\\n        f\\\"- 股票摘要：总数 {payload['summary'].get('total',0)} | A股 {payload['summary'].get('a_stock',0)} | 港股 {payload['summary'].get('hk_stock',0)} | 基金 {payload['summary'].get('fund',0)}\\\",\\n        f\\\"- 输出：{ths_latest_csv.name} / {account_latest_csv.name}\\\",\\n    ]\\n    summary_md.write_text(\\\"\\\\n\\\".join(lines), encoding=\\\"utf-8\\\")\\n\\n    for src in [\\n        ths_latest_csv,\\n        ths_dated_csv,\\n        ths_latest_json,\\n        ths_dated_json,\\n        account_latest_csv,\\n        account_dated_csv,\\n        source_meta_latest,\\n        summary_md,\\n    ]:\\n        dst = WORKSPACE_REPORTS / src.name\\n        dst.write_bytes(src.read_bytes())\\n\\n    return {\\n        \\\"ths_selected_csv\\\": str(ths_latest_csv),\\n        \\\"account_selected_csv\\\": str(account_latest_csv),\\n        \\\"summary\\\": payload[\\\"summary\\\"],\\n        \\\"selected_files\\\": selected_files,\\n        \\\"source_reason\\\": source_reason,\\n        \\\"source_type\\\": source_type,\\n    }\\n\\n\\ndef _materialize_from_existing_trusted_source(candidates_count: int) -> dict[str, Any] | None:\\n    for path, source_reason, source_type in _manual_source_candidates():\\n        try:\\n            rich_rows = _load_csv_rows(path)\\n        except Exception:\\n            continue\\n        compat_rows = build_compat_rows(rich_rows)\\n        if not compat_rows:\\n            continue\\n        return _materialize_selected_outputs(\\n            rich_rows,\\n            date_tag=_extract_date_tag(path),\\n            selected_files=[str(path)],\\n            source_reason=source_reason,\\n            source_type=source_type,\\n            candidates_count=candidates_count,\\n        )\\n    return None\\n\\n\\ndef _has_explicit_selection(cfg: dict[str, Any]) -> bool:\\n    return bool((cfg.get(\\\"selected_ledger_ids\\\") or []) or (cfg.get(\\\"symbol_allowlist\\\") or []))\\n\\n\\ndef sync_selected() -> int:\\n    candidates = write_candidates()\\n\\n    cfg: dict[str, Any] = {}\\n    if SELECTION_CONFIG.exists():\\n        loaded = load_json(SELECTION_CONFIG)\\n        if isinstance(loaded, dict):\\n            cfg = loaded\\n\\n    if cfg and not cfg.get(\\\"enabled\\\", True):\\n        print(f\\\"选择配置未启用: {SELECTION_CONFIG}\\\")\\n        return 2\\n\\n    if not cfg or not _has_explicit_selection(cfg):\\n        fallback = _materialize_from_existing_trusted_source(len(candidates))\\n        if fallback:\\n            print(json.dumps(fallback, ensure_ascii=False, indent=2))\\n            return 0\\n        print(f\\\"未找到可用显式选择配置: {SELECTION_CONFIG}\\\")\\n        print(\\\"且未找到可物化的可信 web/xlsx/manual 持仓源。\\\")\\n        return 2\\n\\n    date_tag = datetime.now().strftime(\\\"%Y%m%d\\\")\\n\\n    with tempfile.TemporaryDirectory(prefix=\\\"ths-selected-\\\") as tmp:\\n        tmpdir = Path(tmp)\\n        proc = run_cmd(\\n            [\\n                sys.executable,\\n                str(SKILL_SCRIPT),\\n                \\\"export\\\",\\n                \\\"--selection-config\\\",\\n                str(SELECTION_CONFIG),\\n                \\\"--out-dir\\\",\\n                str(tmpdir),\\n                \\\"--csv-name\\\",\\n                \\\"ths_selected_holdings.csv\\\",\\n                \\\"--json-name\\\",\\n                \\\"ths_selected_holdings.json\\\",\\n            ]\\n        )\\n        if proc.returncode != 0:\\n            fallback = _materialize_from_existing_trusted_source(len(candidates))\\n            if fallback:\\n                print(json.dumps(fallback, ensure_ascii=False, indent=2))\\n                return 0\\n            print(proc.stderr.strip() or proc.stdout.strip() or \\\"selected export failed\\\")\\n            return proc.returncode or 1\\n\\n        payload = json.loads(proc.stdout)\\n        rich_csv = Path(payload[\\\"csv\\\"])\\n\\n        with rich_csv.open(encoding=\\\"utf-8-sig\\\") as f:\\n            rich_rows = list(csv.DictReader(f))\\n\\n        result = _materialize_selected_outputs(\\n            rich_rows,\\n            date_tag=date_tag,\\n            selected_files=payload.get(\\\"selected_files\\\", []),\\n            source_reason=\\\"ths_local_holdings_export\\\",\\n            source_type=\\\"selected\\\",\\n            candidates_count=len(candidates),\\n        )\\n\\n    print(json.dumps(result, ensure_ascii=False, indent=2))\\n    return 0\\n\"}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":2104,"output":3888,"cacheRead":58112,"cacheWrite":0,"totalTokens":64104,"cost":{"input":0,"output":0,"cache