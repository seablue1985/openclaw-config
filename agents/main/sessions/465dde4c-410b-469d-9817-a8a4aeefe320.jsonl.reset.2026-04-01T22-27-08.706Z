\\n发送飞书预览...\")\n    ok = send_preview(trend_cats, signals)\n    print(f\"  飞书推送: {'成功' if ok else '失败'}\")\n\n    return brief\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1775044654535}}
