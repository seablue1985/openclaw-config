workspace/scripts/generate_actionable_brief.py\",\"limit\":190}"},{"type":"toolCall","id":"call_AmlRlQFaIZYCS8d8qfGRzQZW|fc_077585180826814c0169cc4da2aecc819a830f3112b4eeb6fa","name":"read","arguments":{"file":"/Users/ling/.openclaw/workspace/scripts/generate_daily_exec_card.py","limit":260},"partialJson":"{\"file\":\"/Users/ling/.openclaw/workspace/scripts/generate_daily_exec_card.py\",\"limit\":260}"},{"type":"toolCall","id":"call_f0mn2tDtRcSZDQUyWMLZ52uB|fc_077585180826814c0169cc4da2aed4819a8cab5472a52ae290","name":"read","arguments":{"file":"/Users/ling/.openclaw/workspace/scripts/check_stop_loss.py","offset":130,"limit":110},"partialJson":"{\"file\":\"/Users/ling/.openclaw/workspace/scripts/check_stop_loss.py\",\"offset\":130,\"limit\":110}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":4740,"output":371,"cacheRead":44288,"cacheWrite":0,"totalTokens":49399,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774996890023,"responseId":"resp_077585180826814c0169cc4d9b0fbc819a9ee6e88b49f6eaac"}}
{"type":"message","id":"2b3f468d","parentId":"7ba2d2fd","timestamp":"2026-03-31T22:41:39.045Z","message":{"role":"toolResult","toolCallId":"call_GHfGqRMYupaalRb22jLwXUMm|fc_077585180826814c0169cc4da2aebc819a8a25834ed72070c0","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n可执行投研简报生成器\n将 orchestrator 的输出转换为高度可执行的每日简报\n\"\"\"\n\nimport csv\nimport html as html_module\nimport json\nimport re\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORTS = WORKSPACE / \"research\" / \"reports\"\nINTELLIGENCE_BRIEF = REPORTS / \"intelligence_brief_latest.md\"\nQUANT_REPORTS = Path.home() / \".openclaw\" / \"workspace\" / \"quant_projects\" / \"personal-a-share-research-system\" / \"research\" / \"reports\"\nFEISHU_WEBHOOK = \"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\"\n\n\ndef clean(text):\n    text = re.sub(r\"<[^>]+>\", \"\", str(text))\n    text = html_module.unescape(text)\n    return text.strip()\n\n\ndef read_csv_rows(path: Path):\n    rows = []\n    if not path.exists():\n        return rows\n    try:\n        with path.open(newline=\"\", encoding=\"utf-8-sig\") as f:\n            reader = csv.DictReader(f)\n            for row in reader:\n                if not row:\n                    continue\n                if not any(str(v or \"\").strip() for v in row.values()):\n                    continue\n                rows.append(row)\n    except Exception:\n        return []\n    return rows\n\n\ndef get_latest_trade_card():\n    \"\"\"找最新的交易建议卡\"\"\"\n    files = sorted((REPORTS).glob(\"investment_research_trade_card_*.md\"), key=lambda p: p.stat().st_mtime, reverse=True)\n    if not files:\n        return None\n    return files[0].read_text(encoding=\"utf-8\")\n\n\ndef get_latest_audit():\n    \"\"\"找最新的审计\"\"\"\n    files = sorted((QUANT_REPORTS).glob(\"daily_strategy_audit_*.json\"), key=lambda p: p.stat().st_mtime, reverse=True)\n    if not files:\n        return None\n    return json.loads(files[0].read_text())\n\n\ndef get_latest_strategy():\n    \"\"\"找最新的策略报告（优先用有日期的版本）\"\"\"\n    files = sorted((QUANT_REPORTS).glob(\"today_stock_strategy_report_????????.md\"), key=lambda p: p.stat().st_mtime, reverse=True)\n    if not files:\n        # fallback to latest\n        f = QUANT_REPORTS / \"today_stock_strategy_report_latest.md\"\n        if f.exists():\n            return f.read_text(encoding=\"utf-8\")\n        return None\n    return files[0].read_text(encoding=\"utf-8\")\n\n\ndef _format_holdings_rows(rows):\n    out = []\n    for row in rows:\n        code = (row.get(\"ts_code\") or row.get(\"symbol\") or \"\").strip()\n        if not code:\n            continue\n        qty_raw = str(row.get(\"qty\") or row.get(\"quantity\") or \"0\").strip()\n        cost_raw = str(row.get(\"cost_price\") or \"0\").strip()\n        name = (row.get(\"name\") or \"\").strip()\n\n        try:\n            qty = int(float(qty_raw))\n        except Exception:\n            qty = 0\n        try:\n            cost = float(cost_raw)\n            cost_text = f\"{cost:.4f}\"\n        except Exception:\n            cost_text = cost_raw or \"0\"\n\n        out.append({\"code\": code, \"name\": name, \"qty\": qty, \"cost\": cost_text})\n    return out\n\n\ndef get_real_holdings():\n    \"\"\"只读取已明确选定的真实持仓源；缺失则返回错误，不再回退到旧口径。\"\"\"\n    files = [\n        QUANT_REPORTS / \"account_holdings_selected_latest.csv\",\n        *sorted(QUANT_REPORTS.glob(\"account_holdings_selected_????????.csv\"), key=lambda p: p.stat().st_mtime, reverse=True),\n    ]\n    snapshots = []\n    seen = set()\n    for f in files:\n        if not f.exists():\n            continue\n        if f.resolve() in seen:\n            continue\n        seen.add(f.resolve())\n        rows = read_csv_rows(f)\n        if rows:\n            snapshots.append((f, rows))\n\n    if not snapshots:\n        return [], {\n            \"latest_file\": \"-\",\n            \"latest_count\": 0,\n            \"selected_file\": \"-\",\n            \"selected_count\": 0,\n            \"fallback_used\": False,\n            \"fallback_reason\": \"missing_selected_real_holdings_source\",\n        }\n\n    latest_file, latest_rows = snapshots[0]\n    latest_count = len(latest_rows)\n    selected_file, selected_rows = latest_file, latest_rows\n    fallback_used = False\n    fallback_reason = \"\"\n\n    return _format_holdings_rows(selected_rows), {\n        \"latest_file\": latest_file.name,\n        \"latest_count\": latest_count,\n        \"selected_file\": selected_file.name,\n        \"selected_count\": len(selected_rows),\n        \"fallback_used\": fallback_used,\n        \"fallback_reason\": fallback_reason,\n    }\n\n\ndef get_simulated_holdings_summary():\n    \"\"\"统计模拟盘最新持仓数量（各盘+合计）。\"\"\"\n    files = sorted(QUANT_REPORTS.glob(\"paper_*_portfolio_positions_latest.csv\"), key=lambda p: p.name)\n    profiles = []\n    total = 0\n\n    for f in files:\n        if f.name.endswith(\"_cn.csv\"):\n            continue\n        rows = read_csv_rows(f)\n        cnt = len(rows)\n        key = f.name.replace(\"paper_\", \"\").replace(\"_portfolio_positions_latest.csv\", \"\")\n        profiles.append({\"profile\": key, \"count\": cnt, \"source\": f.name})\n        total += cnt\n\n    return {\"profiles\": profiles, \"total_count\": total}\n\n\ndef parse_trade_card(content):\n    \"\"\"解析交易建议卡，提取可执行信息\"\"\"\n    result = {\n        \"status\": \"unknown\",\n        \"market_breadth\": None,\n        \"positions\": [],  # 持仓\n        \"buy_candidates\": [],  # 买入候选\n        \"sell_candidates\": [],  # 卖出候选\n        \"blocked\": [],  # 被阻断的\n        \"actions\": [],\n    }\n\n    if not content:\n        return result\n\n    # 状态\n    status_match = re.search(r\"- 状态：`([^`]+)`\", content)\n    if status_match:\n        result[\"status\"] = status_match.group(1)\n\n    # 市场宽度\n    bw_match = re.search(r\"market_breadth\\(([^)]+)\\)\", content)\n    if bw_match:\n        result[\"market_breadth\"] = bw_match.group(1)\n\n    # 持仓（保留接口）\n    for _ in re.finditer(r\"- `(\\d{6})`\\.SZ` (.+?) \\| 动作=(观察|买入|卖出)\", content):\n        pass\n\n    return result\n\n\n[188 more lines in file. Use offset=191 to continue.]"}],"isError":false,"timestamp":1774996899043}}
{"type":"message","id":"9dfaed1a","parentId":"2b3f468d","timestamp":"2026-03-31T22:41:39.047Z","message":{"role":"toolResult","toolCallId":"call_AmlRlQFaIZYCS8d8qfGRzQZW|fc_077585180826814c0169cc4da2aecc819a830f3112b4eeb6fa","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n每日执行卡生成器 v2\n增强版：① 个股目标价/止损价 ② 持仓盈亏分析 ③ 舆情摘要\n\"\"\"\n\nimport csv\nimport html as html_mod\nimport json\nimport re\nfrom datetime import datetime\nfrom pathlib import Path\n\nWORKSPACE = Path.home() / \".openclaw/workspace\"\nREPORTS = WORKSPACE / \"research/reports\"\nQUANT_PROJECT = Path.home() / \".openclaw/workspace/quant_projects/personal-a-share-research-system\"\nQUANT = QUANT_PROJECT / \"research/reports\"\nQUANT_CONFIG = QUANT_PROJECT / \"config\"\nFEISHU_WEBHOOK = \"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\"\n\n\ndef is_trading_day() -> bool:\n    \"\"\"判断今天是否为 A 股交易日（周一~周五）。\"\"\"\n    return datetime.now().weekday() < 5\n\n\ndef clean(text):\n    text = re.sub(r\"<[^>]+>\", \"\", str(text or \"\"))\n    return html_mod.unescape(text).strip()\n\n\ndef load_json(path):\n    try:\n        return json.loads(Path(path).read_text())\n    except Exception:\n        return {}\n\n\ndef load_txt(path):\n    try:\n        return Path(path).read_text(encoding=\"utf-8\")\n    except Exception:\n        return \"\"\n\n\ndef get_latest_file(pattern, base):\n    files = sorted(Path(base).glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)\n    return files[0] if files else None\n\n\ndef get_latest_by_date(pattern, base):\n    \"\"\"按文件名日期（YYYYMMDD）选取最新，不依赖 mtime。\"\"\"\n    files = list(Path(base).glob(pattern))\n    if not files:\n        return None\n    dated = []\n    for f in files:\n        m = re.search(r\"(\\d{8})\", f.name)\n        if m:\n            dated.append((m.group(1), f))\n    if not dated:\n        return None\n    dated.sort(key=lambda x: x[0], reverse=True)\n    return dated[0][1]\n\n\n# ====== 数据获取 ======\ndef get_strategy_report():\n    f = get_latest_file(\"today_stock_strategy_report_????????.md\", QUANT)\n    if not f:\n        f = QUANT / \"today_stock_strategy_report_latest.md\"\n    return load_txt(f) if f.exists() else \"\"\n\n\ndef get_audit():\n    f = get_latest_file(\"daily_strategy_audit_*.json\", QUANT)\n    return load_json(f) if f else {}\n\n\nTHS_NAME_MAP = {\n    \"000930.SZ\": \"中粮科技\",\n    \"001336.SZ\": \"舍得酒业\",\n    \"002188.SZ\": \"新开普\",\n    \"002316.SZ\": \"键桥通讯\",\n    \"002494.SZ\": \"华斯股份\",\n    \"002715.SZ\": \"新澳股份\",\n    \"002719.SZ\": \"麦趣尔\",\n    \"002780.SZ\": \"三棵树\",\n    \"002802.SZ\": \"洪汇新材\",\n    \"002817.SZ\": \"博观\",\n    \"002820.SZ\": \"凯莱英\",\n    \"002827.SZ\": \"百奥泰\",\n    \"002830.SZ\": \"名雕股份\",\n    \"002883.SZ\": \"中设股份\",\n    \"002888.SZ\": \"惠达卫浴\",\n    \"002920.SZ\": \"瑞玛精密\",\n    \"002963.SZ\": \"银都股份\",\n    \"003003.SZ\": \"蓝天燃气\",\n    \"003030.SZ\": \"英特集团\",\n    \"00700.HK\": \"腾讯控股\",\n    \"02611.HK\": \"汇丰控股\",\n    \"06969.HK\": \"中教控股\",\n    \"09988.HK\": \"阿里巴巴\",\n    \"300030.SZ\": \"阳普医疗\",\n    \"300200.SZ\": \"高新兴\",\n    \"300464.SZ\": \"星徽股份\",\n    \"300500.SZ\": \"启迪设计\",\n    \"300622.SZ\": \"博士眼镜\",\n    \"300660.SZ\": \"江苏雷利\",\n    \"300710.SZ\": \"精进电动\",\n    \"300777.SZ\": \"中简科技\",\n    \"300829.SZ\": \"金丹科技\",\n    \"300932.SZ\": \"三友联众\",\n    \"301101.SZ\": \"明月镜片\",\n    \"301333.SZ\": \"长光华芯\",\n    \"301591.SZ\": \"四川黄金\",\n    \"511880.SH\": \"银华日利\",\n    \"600159.SH\": \"大龙地产\",\n    \"600363.SH\": \"联创光电\",\n    \"600493.SH\": \"凤竹纺织\",\n    \"600593.SH\": \"大连圣亚\",\n    \"600805.SH\": \"江苏金智\",\n    \"603629.SH\": \"利通电子\",\n    \"688543.SH\": \"纳睿雷达\",\n    \"688567.SH\": \"金山办公\",\n}\n\n\ndef _to_int(value):\n    try:\n        return int(float(str(value or \"0\").strip()))\n    except Exception:\n        return 0\n\n\ndef _to_float(value, default=0.0):\n    try:\n        return float(str(value or default).strip())\n    except Exception:\n        return default\n\n\ndef _infer_currency_and_asset_type(symbol, asset_type):\n    \"\"\"统一推断币种/资产类型。\"\"\"\n    symbol = str(symbol or \"\").strip().upper()\n    raw_asset_type = str(asset_type or \"\").strip().lower()\n    code = symbol.split(\".\")[0]\n\n    if symbol.endswith(\".HK\"):\n        return \"HKD\", \"stock\"\n    if raw_asset_type in {\"etf\", \"fund\"}:\n        return \"CNY\", raw_asset_type\n    if code.startswith((\"5\", \"1\", \"15\")):\n        return \"CNY\", \"fund\"\n    return \"CNY\", (raw_asset_type or \"stock\")\n\n\ndef _load_csv_rows(path):\n    rows = []\n    with open(path, encoding=\"utf-8-sig\") as fp:\n        for r in csv.DictReader(fp):\n            sym = str(r.get(\"symbol\") or r.get(\"ts_code\") or \"\").strip().upper()\n            qty = _to_int(r.get(\"quantity\") or r.get(\"qty\"))\n            if not sym or qty <= 0:\n                continue\n            currency, inferred_asset_type = _infer_currency_and_asset_type(sym, r.get(\"asset_type\", \"\"))\n            row = dict(r)\n            row[\"symbol\"] = sym\n            row[\"quantity\"] = qty\n            row[\"currency\"] = currency\n            row[\"asset_type\"] = inferred_asset_type\n            row[\"name\"] = str(r.get(\"name\") or THS_NAME_MAP.get(sym, sym)).strip()\n            rows.append(row)\n    return rows\n\n\ndef _load_manual_portfolio_rows(path):\n    rows = []\n    with open(path, encoding=\"utf-8-sig\") as fp:\n        for r in csv.DictReader(fp):\n            sym = str(r.get(\"symbol\") or r.get(\"ts_code\") or r.get(\"code\") or \"\").strip().upper()\n            qty = _to_int(r.get(\"quantity\") or r.get(\"qty\"))\n            if not sym or qty <= 0:\n                continue\n            currency, inferred_asset_type = _infer_currency_and_asset_type(sym, r.get(\"asset_type\", \"\"))\n            rows.append(\n                {\n                    \"symbol\": sym,\n                    \"quantity\": qty,\n                    \"currency\": currency,\n                    \"asset_type\": inferred_asset_type,\n                    \"name\": str(r.get(\"name\") or THS_NAME_MAP.get(sym, sym)).strip(),\n                    \"cost_price\": _to_float(r.get(\"cost_price\"), 0.0),\n                    \"source\": str(path),\n                }\n            )\n    return rows\n\n\ndef get_holdings():\n    # 只读取已明确选定的真实持仓源；缺失则中止，禁止回退到旧口径\n    selected_candidates = [\n        QUANT / \"ths_selected_holdings_latest.csv\",\n        get_latest_by_date(\"ths_selected_holdings_????????.csv\", QUANT),\n        QUANT / \"account_holdings_selected_latest.csv\",\n        get_latest_by_date(\"account_holdings_selected_????????.csv\", QUANT),\n    ]\n    for candidate in selected_candidates:\n        if candidate and Path(candidate).exists():\n            rows = _load_csv_rows(candidate)\n            if rows:\n                return rows\n    raise RuntimeError(\"missing_selected_real_holdings_source\")\n\n\ndef get_intelligence_brief():\n    f = REPORTS / \"intelligence_brief_latest.md\"\n    return load_txt(f) if f.exists() else \"\"\n\n\n# ====== 解析策略报告 ======\ndef parse_strategy(content):\n    result = {\n        \"buy_count\": 0,\n        \"sell_count\": 0,\n        \"buy_candidates\": [],\n        \"risk_off\": None,\n        \"market_breadth\": None,\n        \"report_date\": None,\n    }\n    if not content:\n        return result\n\n    m = re.search(r\"形成 `(\\d+)` 个去重 BUY 候选\", content)\n    if m:\n        result[\"buy_count\"] = int(m.group(1))\n    m = re.search(r\"形成 `(\\d+)` 个去重 SELL 候选\", content)\n    if m:\n        result[\"sell_count\"] = int(m.group(1))\n    m = re.search(r\"宽度门禁：当前 `([\\d.]+)%`\", content)\n    if m:\n        result[\"market_breadth\"] = float(m.group(1))\n\n    for m in re.finditer(\n        r\"^\\|\\s*(\\d+)\\s*\\|\\s*(\\d{6}\\.[A-Z]{2})\\s*\\|\\s*([^|]+?)\\s*\\|\\s*[\\d.]+\\s*\\|\\s*\\w+\\s*\\|\\s*([\\d.]+)\\s*\\|\\s*(买入|卖出|观望)\\s*\\|\",\n        content,\n        re.MULTILINE,\n    ):\n        rank, code, name, price, action = m.group(1), m.group(2), m.group(3).strip(), m.group(4), m.group(5)\n        result[\"buy_candidates\"].append(\n            {\n                \"rank\": rank,\n                \"code\": code,\n                \"name\": clean(name),\n                \"price\": price,\n                \"action\": action,\n                \"stop_loss\": \"\",\n                \"take_profit\": \"\",\n                \"trigger\": \"\",\n            }\n\n[219 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1774996899045}}
{"type":"message","id":"acc2d291","parentId":"9dfaed1a","timestamp":"2026-03-31T22:41:39.049Z","message":{"role":"toolResult","toolCallId":"call_f0mn2tDtRcSZDQUyWMLZ52uB|fc_077585180826814c0169cc4da2aed4819a8cab5472a52ae290","toolName":"read","content":[{"type":"text","text":"    return rows\n\n\ndef _load_manual_portfolio_rows(path):\n    rows = []\n    with open(path, encoding=\"utf-8-sig\") as f:\n        for r in csv.DictReader(f):\n            sym = str(r.get(\"symbol\") or r.get(\"ts_code\") or r.get(\"code\") or \"\").strip().upper()\n            qty = _to_int(r.get(\"quantity\") or r.get(\"qty\"))\n            if not sym or qty <= 0:\n                continue\n            currency, inferred_asset_type = _infer_currency_and_asset_type(sym, r.get(\"asset_type\", \"\"))\n            rows.append(\n                {\n                    \"ts_code\": sym,\n                    \"name\": str(r.get(\"name\") or THS_NAME_MAP.get(sym, sym)).strip(),\n                    \"qty\": qty,\n                    \"cost_price\": _to_float(r.get(\"cost_price\"), 0.0) or 0.0,\n                    \"currency\": currency,\n                    \"asset_type\": inferred_asset_type,\n                    \"source\": str(path),\n                }\n            )\n    return rows\n\n\ndef get_holdings():\n    \"\"\"只读取已明确选定的真实持仓源；缺失则中止，禁止回退到旧口径。\"\"\"\n    selected_candidates = [\n        QUANT / \"ths_selected_holdings_latest.csv\",\n        *sorted(QUANT.glob(\"ths_selected_holdings_????????.csv\"), key=lambda p: p.stat().st_mtime, reverse=True),\n        QUANT / \"account_holdings_selected_latest.csv\",\n        *sorted(QUANT.glob(\"account_holdings_selected_????????.csv\"), key=lambda p: p.stat().st_mtime, reverse=True),\n    ]\n    for candidate in selected_candidates:\n        if candidate.exists():\n            rows = _load_csv_rows(candidate)\n            if rows:\n                return rows\n    raise RuntimeError(\"missing_selected_real_holdings_source\")\n\n\ndef get_audit():\n    files = sorted(QUANT.glob(\"daily_strategy_audit_*.json\"), key=lambda p: p.stat().st_mtime, reverse=True)\n    if not files:\n        return {}\n    try:\n        return json.loads(files[0].read_text())\n    except Exception:\n        return {}\n\n\ndef _ensure_quant_scripts_on_path():\n    path_text = str(QUANT_SCRIPTS)\n    if path_text not in sys.path:\n        sys.path.insert(0, path_text)\n\n\ndef _qq_symbol_for_ts_code(ts_code: str) -> str:\n    ts_code = str(ts_code or \"\").strip().upper()\n    if not ts_code or \".\" not in ts_code:\n        return \"\"\n    code, market = ts_code.split(\".\", 1)\n    if market == \"SH\":\n        return f\"sh{code}\"\n    if market == \"SZ\":\n        return f\"sz{code}\"\n    if market == \"HK\":\n        return f\"hk{code}\"\n    return \"\"\n\n\ndef _load_tencent_quote_func():\n    _ensure_quant_scripts_on_path()\n    from intraday_market_gate import fetch_tencent_quote  # type: ignore\n\n    return fetch_tencent_quote\n\n\ndef _load_unified_fetcher():\n    _ensure_quant_scripts_on_path()\n    from intraday_market_gate import _get_unified_fetcher  # type: ignore\n\n    return _get_unified_fetcher()\n\n\ndef _load_dashboard_quote_funcs():\n    _ensure_quant_scripts_on_path()\n    from generate_live_global_dashboard import quote_cn, quote_stooq  # type: ignore\n\n    return quote_cn, quote_stooq\n\n\ndef _fallback_price_a(ts_code):\n    try:\n        import akshare as ak\n        import warnings\n\n        warnings.filterwarnings(\"ignore\")\n        code = str(ts_code or \"\").split(\".\")[0]\n        today = datetime.now().strftime(\"%Y%m%d\")\n        df = ak.stock_zh_a_hist(symbol=code, period=\"daily\", start_date=today, end_date=today, adjust=\"qfq\")\n        if not df.empty:\n            return _to_float(df.iloc[-1][\"收盘\"]), _to_float(df.iloc[-1][\"涨跌幅\"]), \"ak_a_hist\"\n    except Exception:\n        pass\n    return None, None, None\n\n\ndef get_realtime_price(ts_code):\n\n[179 more lines in file. Use offset=240 to continue.]"}],"isError":false,"timestamp":1774996899047}}
