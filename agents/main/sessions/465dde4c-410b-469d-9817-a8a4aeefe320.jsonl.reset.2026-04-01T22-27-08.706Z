d\":\"tail -30 /Users/ling/.openclaw/workspace/logs/weibo_monitor_evening.log\"}}],\"api\":\"anthropic-messages\",\"provider\":\"minimax-portal\",\"model\":\"MiniMax-M2.7\",\"usage\":{\"input\":33459,\"output\":99,\"cacheRead\":25020,\"cacheWrite\":0,\"totalTokens\":58578,\"cost\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"total\":0}},\"stopReason\":\"toolUse\",\"timestamp\":1774875144357,\"responseId\":\"0619a5086b470322d051dae5fbcbd7aa\"}}\n\n\nProcess exited with signal SIGTERM."}],"details":{"status":"failed","sessionId":"young-ocean","aggregated":"/Users/ling/.openclaw/workspace/other_projects/TrendRadar/format_push_v2.py:491:            print(\"晚报无新增财经内容，跳过重复发送\")\n/Users/ling/.openclaw/workspace/other_projects/TrendRadar/format_push_v2.py:493:            print(\"无财经内容，跳过发送\")\n/Users/ling/.openclaw/workspace/checklists/ACTIVE_TASK.md:21:- 修复微博简报：取消“财经内容”筛除，只做汇总与分析\n/Users/ling/.openclaw/workspace/checklists/ACTIVE_TASK.md:24:- 定位产出“财经大V每日简报 / 财经内容0条”的汇总脚本并删除过滤口径\n/Users/ling/.openclaw/workspace/other_projects/TrendRadar/format_push_v2.py:491:            print(\"晚报无新增财经内容，跳过重复发送\")\n/Users/ling/.openclaw/workspace/other_projects/TrendRadar/format_push_v2.py:493:            print(\"无财经内容，跳过发送\")\n/Users/ling/.openclaw/workspace/checklists/ACTIVE_TASK.md:21:- 修复微博简报：取消“财经内容”筛除，只做汇总与分析\n/Users/ling/.openclaw/workspace/checklists/ACTIVE_TASK.md:24:- 定位产出“财经大V每日简报 / 财经内容0条”的汇总脚本并删除过滤口径\n/Users/ling/.openclaw/agents/coding-agent/sessions/f9c9b6b2-ea82-4178-8214-066ac44ac8ae.jsonl.reset.2026-03-29T00-56-45.582Z:180:{\"type\":\"message\",\"id\":\"dd4a35e5\",\"parentId\":\"c00ecc7c\",\"timestamp\":\"2026-03-28T08:07:45.257Z\",\"message\":{\"role\":\"toolResult\",\"toolCallId\":\"call_fxfXrbdc1O7GCgXLjmpdh8jt|fc_0cc50ece879d91970169c78c50855081918f40803baa57f68a\",\"toolName\":\"read\",\"content\":[{\"type\":\"text\",\"text\":\"    if not left or not right:\\n        return 0.0\\n    if left == right:\\n        return 1.0\\n    return SequenceMatcher(None, left, right).ratio()\\n\\n\\n\\ndef choose_better_item(current: Dict[str, str], candidate: Dict[str, str]) -> Dict[str, str]:\\n    \\\"\\\"\\\"Prefer the more informative title when merging duplicates.\\\"\\\"\\\"\\n    current_title = current[\\\"title\\\"]\\n    candidate_title = candidate[\\\"title\\\"]\\n\\n    current_score = (len(current_title), len(current.get(\\\"url\\\", \\\"\\\")))\\n    candidate_score = (len(candidate_title), len(candidate.get(\\\"url\\\", \\\"\\\")))\\n    return candidate if candidate_score > current_score else current\\n\\n\\n\\ndef is_near_duplicate(normalized: str, existing_normalized: str) -> bool:\\n    \\\"\\\"\\\"Conservative near-duplicate detection for same-event title variants.\\\"\\\"\\\"\\n    if not normalized or not existing_normalized:\\n        return False\\n\\n    shorter, longer = sorted((normalized, existing_normalized), key=len)\\n    similarity = title_similarity(normalized, existing_normalized)\\n\\n    if shorter and shorter in longer and len(shorter) / max(len(longer), 1) >= 0.7:\\n        return True\\n\\n    return similarity >= 0.93\\n\\n\\n\\ndef deduplicate_items(items: List[Dict[str, str]]) -> Tuple[List[Dict[str, str]], int]:\\n    \\\"\\\"\\\"Remove exact and near-duplicate headlines.\\\"\\\"\\\"\\n    deduplicated: List[Dict[str, str]] = []\\n    normalized_keys: List[str] = []\\n\\n    for item in items:\\n        normalized = normalize_title(item[\\\"title\\\"])\\n        duplicate_index = None\\n\\n        for index, existing_normalized in enumerate(normalized_keys):\\n            if normalized == existing_normalized or is_near_duplicate(normalized, existing_normalized):\\n                duplicate_index = index\\n                break\\n\\n        if duplicate_index is None:\\n            deduplicated.append(item)\\n            normalized_keys.append(normalized)\\n            continue\\n\\n        best_item = choose_better_item(deduplicated[duplicate_index], item)\\n        deduplicated[duplicate_index] = best_item\\n        normalized_keys[duplicate_index] = normalize_title(best_item[\\\"title\\\"])\\n\\n    removed = len(items) - len(deduplicated)\\n    return deduplicated, removed\\n\\n\\n\\ndef build_report(items: List[Dict[str, str]], date_str: str) -> str | None:\\n    \\\"\\\"\\\"构建彭博风格报告\\\"\\\"\\\"\\n    fin_items = [item for item in items if is_financial(item)]\\n    if not fin_items:\\n        return None\\n\\n    deduped_items, duplicates_removed = deduplicate_items(fin_items)\\n    if not deduped_items:\\n        return None\\n\\n    categories: Dict[str, List[Dict[str, str]]] = {}\\n    for item in deduped_items:\\n        category = classify(item) or \\\"📰 其他\\\"\\n        categories.setdefault(category, []).append(item)\\n\\n    lines: List[str] = []\\n    lines.append(\\\"━━━━━━━━━━━━━━━━━━━━\\\")\\n    lines.append(f\\\"📡 财经热点晨报 | {date_str}\\\")\\n    lines.append(f\\\"📊 原始财经 {len(fin_items)} 条｜去重后 {len(deduped_items)} 条\\\")\\n    if duplicates_removed:\\n        lines.append(f\\\"🧹 已筛除重复 {duplicates_removed} 条\\\")\\n    lines.append(\\\"━━━━━━━━━━━━━━━━━━━━\\\")\\n\\n    for cat_name, _ in CATEGORY_MAP:\\n        cat_items = categories.get(cat_name, [])\\n        if not cat_items:\\n            continue\\n        lines.append(\\\"\\\")\\n        lines.append(f\\\"{cat_name} ({len(cat_items)} 条)\\\")\\n        lines.append(\\\"\\\")\\n        for item in cat_items[:6]:\\n            signal = market_signal(item[\\\"title\\\"])\\n            title = item[\\\"title\\\"][:48] + (\\\"…\\\" if len(item[\\\"title\\\"]) > 48 else \\\"\\\")\\n            lines.append(f\\\"  {signal} {title}\\\")\\n\\n    other_items = categories.get(\\\"📰 其他\\\", [])\\n    if other_items:\\n        lines.append(\\\"\\\")\\n        lines.append(f\\\"📰 其他财经 ({len(other_items)} 条)\\\")\\n        lines.append(\\\"\\\")\\n        for item in other_items[:4]:\\n            title = item[\\\"title\\\"][:48] + (\\\"…\\\" if len(item[\\\"title\\\"]) > 48 else \\\"\\\")\\n            lines.append(f\\\"  ⚪ {title}\\\")\\n\\n    lines.append(\\\"\\\")\\n    lines.append(\\\"━━━━━━━━━━━━━━━━━━━━\\\")\\n    lines.append(f\\\"📊 数据来源：TrendRadar | {datetime.now().strftime('%H:%M:%S')}\\\")\\n    return \\\"\\\\n\\\".join(lines)\\n\\n\\n\\ndef send_feishu(text: str) -> dict:\\n    \\\"\\\"\\\"发送飞书\\\"\\\"\\\"\\n    import requests\\n\\n    payload = {\\\"msg_type\\\": \\\"text\\\", \\\"content\\\": {\\\"text\\\": text}}\\n    response = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\\n    return response.json()\\n\\n\\n\\ndef main() -> None:\\n    today = datetime.now().strftime(\\\"%Y年%m月%d日\\\")\\n    txt_dir = Path(f\\\"/Users/ling/.openclaw/workspace/other_projects/TrendRadar/output/{today}/txt\\\")\\n\\n    if not txt_dir.exists():\\n        print(f\\\"未找到目录: {txt_dir}\\\")\\n        sys.exit(1)\\n\\n    txt_files = sorted(txt_dir.glob(\\\"*.txt\\\"), key=lambda path: path.stat().st_mtime, reverse=True)\\n    if not txt_files:\\n        print(\\\"未找到 txt 文件\\\")\\n        sys.exit(1)\\n\\n    latest = txt_files[0]\\n    print(f\\\"读取: {latest.name}\\\")\\n\\n    items = parse_txt(latest)\\n    print(f\\\"共 {len(items)} 条新闻\\\")\\n\\n    financial_items = [item for item in items if is_financial(item)]\\n    deduped_items, duplicates_removed = deduplicate_items(financial_items)\\n    print(f\\\"财经相关: {len(financial_items)} 条\\\")\\n    print(f\\\"去重后: {len(deduped_items)} 条（移除 {duplicates_removed} 条重复）\\\")\\n\\n    date_str = datetime.now().strftime(\\\"%Y-%m-%d %H:%M\\\")\\n    report = build_report(items, date_str)\\n\\n    if report:\\n        print(\\\"\\\\n发送飞书...\\\")\\n        result = send_feishu(report)\\n        print(f\\\"结果: {json.dumps(result, ensure_ascii=False)}\\\")\\n    else:\\n        print(\\\"无财经内容，跳过发送\\\")\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n\"}],\"isError\":false,\"timestamp\":1774685265253}}\n/Users/ling/.openclaw/agents/coding-agent/sessions/7bc8138e-a9dd-435a-ab59-0c2519a30721.jsonl.reset.2026-03-24T01-55-34.060Z:406:{\"type\":\"message\",\"id\":\"3f974f61\",\"parentId\":\"0e1f9cbc\",\"timestamp\":\"2026-03-23T13:57:26.471Z\",\"message\":{\"role\":\"toolResult\",\"toolCallId\":\"call_function_bj1c8bivobyb_1\",\"toolName\":\"exec\",\"content\":[{\"type\":\"text\",\"text\":\"[📘 晚间版] 生成时间: 2026-03-23 21:56\\n\\n📊 **微博财经大V每日简报**\\n🕐 2026-03-23 21:57  |  共 10 位大V  |  财经内容 22 条\\n\\n── 重点内容摘录 ──\\n\\n**🔹 wu2198**（投资内容创作者）\\n   18:18 欧洲股市开盘之后纷纷大跌，目前跌2.5%左右！\\n   👍4457 💬208 🔁8\\n\\n   17:53 马斯克认为，全球现有芯片总产能仅能满足其未来需求的2%，由于现有供应链(如台积电、三星等)的扩张速度远不及预期，特斯拉必须亲自下场，建造规模史无前例的Tera超级芯片工厂以填补巨大的算力缺口。\\n   👍4618 💬72 🔁14\\n\\n\\n**🔹 杨德龙**（前海开源基金首席经济学家）\\n   12:29 不要把投资想的太复杂，成功的投资者是把简单做到极致。——本杰明·格雷厄姆\\n   👍43 💬4 🔁4\\n\\n   21:24 发布了头条文章：《杨德龙：2026年资本市场的投资主线》\\n   👍10 💬1 🔁4\\n\\n\\n**🔹 投行泰山**（财经博主）\\n   21:37 转评：古希腊掌管K线的神？一半的A股股民想凑钱给神买火箭，一半想买凶杀了他！\\n   👍8 💬4 🔁2\\n\\n   21:39 大佬说：“明天稳不稳，得看伊朗方面是否认可和美国谈了，以及今晚打成啥样，当然最关键的美股收盘后川普会发啥贴。”\\n   👍4 💬1 🔁1\\n\\n\\n**🔹 洪榕**（职业投资人）\\n   17:01 【别赌虚无的国运，要赌国运兑现的确定性】最近全网都在聊地缘冲突、油价波动、外围风险，很多人盯着战争走势猜涨跌，盯着美股动向慌心神，甚至天天纠结美元会不会崩、外围会不会崩盘。我反复说过，华尔街顶尖机构、顶级操盘手都没法精准预测战争走向和突发黑天鹅，我们普通散户，何苦拿自己的血汗钱 ...\\n   👍569 💬35 🔁81\\n\\n   18:06 这轮牛市，散户的感觉，如图…\\n   👍382 💬72 🔁6\\n\\n\\n**🔹 马靖昊**（财税专家）\\n   07:01 看完佰维存储这份2025年报，我的第一反应是：利润表很性感，现金流量表很骨感。2025年，佰维存储营收113亿，增长69%；净利润8.5亿，暴增429%。从亏损6亿到盈利8.5亿，只用了一年时间。 这成绩单放在A股半导体板块，绝对算得上优等生。但翻开现金流量表，画风突变：经营活动现金流净额-19.65亿，同比暴 ...\\n   👍177 💬27 🔁120\\n\\n   18:08 宇树科技IPO，2025年度营收翻3倍、利润狂飙6倍，财务总监2024年薪46.68万\\n   👍15 💬0 🔁4\\n\\n\\n**🔹 麒炜投资**（财经博主）\\n   11:00 大盘连续下探，很多人心态崩了。投资不是比谁赚得快，是比谁活得久。恐慌杀跌最容易把浮亏变实亏，与其天天盯盘焦虑，不如冷静看看手里的票。基本面和趋势没问题就拿住，大跌从来都是给长线投资者送低价筹码！\\n   👍42 💬4 🔁1\\n\\n\\n**🔹 唐史主任司马迁**（职业投资人/2025微博年度新知博主）\\n   08:22 周指数跌穿了120日线，市场避险情绪上升。分析框架上，还是要把内外因分开。外部因子还是要看海峡--高油价--通胀--降息预期这个传导链。内部问题其实上周五各方也互相指责，猜疑链变长，实际上是市场风偏下降后个股普遍回调导致配置型资金出现年度亏损，这个时候提供流动性和不提供流动性是截然不同的 ...\\n   👍4779 💬275 🔁96\\n\\n\\n── 今日要闻 ──\\n高频词：#股  #投资  #A股  #美股  #芯片\\n\\n⚠️ 仅供参考，不构成投资建议。\"}],\"details\":{\"status\":\"completed\",\"exitCode\":0,\"durationMs\"