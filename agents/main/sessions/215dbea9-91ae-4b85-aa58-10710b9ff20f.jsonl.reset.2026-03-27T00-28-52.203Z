 end_date='20260326', adjust='qfq')\\n    for ma in [5,10,20,60,120]:\\n        df[f'MA{ma}']=df['收盘'].rolling(ma).mean()\\n    high20=df['最高'].rolling(20).max().iloc[-2]\\n    low20=df['最低'].rolling(20).min().iloc[-2]\\n    last=df.iloc[-1]\\n    prev=df.iloc[-2]\\n    print('\\\\n',code,name)\\n    print('last',last['收盘'],'change',last['涨跌幅'],'vol_turnover',last['换手率'])\\n    print('MA5/10/20/60/120', [round(last[f'MA{i}'],2) if pd.notna(last[f'MA{i}']) else None for i in [5,10,20,60,120]])\\n    print('prev20_high',round(high20,2),'prev20_low',round(low20,2))\\n    print('52w high',round(df['最高'].max(),2),'52w low',round(df['最低'].min(),2))\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":120}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":1590,"output":441,"cacheRead":36480,"cacheWrite":0,"totalTokens":38511,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774490079769,"responseId":"resp_0142f9a21f5351e00169c491e0681c819b98b9528274b3f360"}}
