\"guarded\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_trade_card_morning_20260318.json:434:      \"reason\": \"auto_live_v4_2 | auto_live_v4_2b_fundamental_guard\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_trade_card_morning_20260318.json:512:      \"reason\": \"auto_live_v4_2 | auto_live_v4_2b_fundamental_guard\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_trade_card_morning_20260318.json:756:      \"reason\": \"auto_live_v4_2 | auto_live_v4_2b_fundamental_guard\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_trade_card_morning_20260318.json:878:      \"reason\": \"auto_live_v4_2b_fundamental_guard\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_trade_card_morning_20260318.json:1000:      \"reason\": \"auto_live_v4_2 | auto_live_v4_2b_fundamental_guard\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_background_cycle_intraday_20260314.md:7:- 数据源状态：watch_guarded\n/Users/ling/.openclaw/workspace/research/reports/investment_research_background_cycle_intraday_20260314.md:34:- 状态：watch_guarded","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774531459347}}
{"type":"message","id":"5c937cc9","parentId":"26b8045f","timestamp":"2026-03-26T13:24:19.373Z","message":{"role":"toolResult","toolCallId":"call_6Qj0SCYGHHAfLFnW41C8MpzR|fc_0142f9a21f5351e00169c53381e258819bb77c55713fef3657","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nWORKSPACE = Path('/Users/ling/.openclaw/workspace')\nREPORT_DIR = WORKSPACE / 'research' / 'reports'\nQUANT_REPORT_DIR = WORKSPACE / 'quant_projects' / 'personal-a-share-research-system' / 'research' / 'reports'\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding='utf-8'))\n\n\ndef append_issue(issues: list[dict[str, Any]], severity: str, code: str, detail: str) -> None:\n    issues.append({'severity': severity, 'code': code, 'detail': detail})\n\n\ndef main() -> None:\n    date_tag = datetime.now().strftime('%Y%m%d')\n    runtime = load_json(QUANT_REPORT_DIR / 'runtime_risk_state_latest.json')\n    report = load_json(QUANT_REPORT_DIR / f'today_stock_strategy_report_{date_tag}.json')\n    if not report:\n        report = load_json(QUANT_REPORT_DIR / 'today_stock_strategy_report_latest.json')\n    event_watch = load_json(REPORT_DIR / f'investment_research_event_watch_{date_tag}.json')\n\n    issues: list[dict[str, Any]] = []\n\n    latest_runtime = runtime.get('latest_runtime') or {}\n    report_trade_date = str(report.get('trade_date') or '').replace('-', '')\n    runtime_date = str(runtime.get('date_tag') or '')\n    report_mode = str(report.get('risk_mode') or '')\n    runtime_mode = str(latest_runtime.get('mode') or '')\n\n    if runtime and report:\n        if runtime_date == date_tag and report_trade_date == date_tag:\n            if runtime_mode and report_mode and runtime_mode != report_mode:\n                append_issue(issues, 'critical', 'runtime_report_mode_mismatch', f'runtime={runtime_mode}, report={report_mode}')\n            if latest_runtime.get('halt_new_buy') != report.get('halt_new_buy'):\n                append_issue(issues, 'critical', 'runtime_report_halt_mismatch', f\"runtime={latest_runtime.get('halt_new_buy')} report={report.get('halt_new_buy')}\")\n            if latest_runtime.get('market_breadth') != report.get('market_breadth'):\n                append_issue(issues, 'high', 'runtime_report_breadth_mismatch', f\"runtime={latest_runtime.get('market_breadth')} report={report.get('market_breadth')}\")\n\n    # halt 状态下模拟盘不应仍保留当日新增买入\n    if report_trade_date == date_tag and bool(report.get('halt_new_buy')):\n        for profile in ['defensive','balanced','aggressive']:\n            acc = load_json(QUANT_REPORT_DIR / f'paper_{profile}_account_v1_{date_tag}.json')\n            if acc:\n                buys = int(acc.get('today_buy_count') or 0)\n                if buys > 0:\n                    append_issue(issues, 'critical', f'paper_{profile}_buy_under_halt', f'today_buy_count={buys}')\n\n    # 事件监控链是否仍引用旧口径\n    if event_watch:\n        cur = event_watch.get('current') or {}\n        pe = cur.get('paper_execution_status') or {}\n        source = str(pe.get('source') or '')\n        if runtime_date == date_tag and source not in {'runtime_risk_state_latest', 'strategy_report'}:\n            append_issue(issues, 'high', 'event_watch_not_using_runtime', f'source={source}')\n        if runtime_mode and str(pe.get('mode') or '') != runtime_mode:\n            append_issue(issues, 'high', 'event_watch_mode_mismatch', f\"event_watch={pe.get('mode')} runtime={runtime_mode}\")\n\n\n    # ===== 深层防控：早盘 halt 延续一致性检查 =====\n    # 如果上一个交易日收盘后 intraday recheck 为 halt，\n    # 而今日仍有新买入订单通过 → 说明早盘风控未能继承 halt，是严重缺陷\n    import glob as _glob\n\n    # ===== CSV 指数数据新鲜度检查 =====\n    # 如果今日是交易日，但 CSV 最后更新日期 < 今日，\n    # 说明早盘用 T-1 数据生成订单，任何基于 index_ret_pct 的 halt 判断都不可靠\n    csv_index_path = Path(\"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis/index_000852_SH.csv\")\n    if csv_index_path.exists():\n        import pandas as _pd\n        try:\n            df_idx = _pd.read_csv(csv_index_path)\n            last_csv_date = int(df_idx.iloc[-1][\"trade_date\"])\n            today_int = int(datetime.now().strftime(\"%Y%m%d\"))\n            if last_csv_date < today_int:\n                append_issue(\n                    issues,\n                    \"high\",\n                    \"csv_index_data_stale\",\n                    f\"CSV 指数数据陈旧（{last_csv_date} < {today_int}），早盘 halt 判断不可靠\",\n                )\n        except Exception:\n            pass\n    if date_tag:\n        prev_dt = str(int(date_tag) - 1) if len(date_tag) == 8 else None\n        if prev_dt:\n            prev_rt_files = sorted(_glob.glob(str(QUANT_REPORT_DIR / f\"intraday_risk_recheck_{prev_dt}_*.json\")))\n            if prev_rt_files:\n                prev_rt = json.loads(open(prev_rt_files[-1], encoding=\"utf-8\").read())\n                prev_halt = bool(prev_rt.get(\"latest_runtime\", {}).get(\"halt_new_buy\"))\n                if prev_halt:\n                    # 上日 halt，检查今日是否有买\n                    for profile in [\"defensive\", \"balanced\", \"aggressive\"]:\n                        acc = load_json(QUANT_REPORT_DIR / f\"paper_{profile}_account_v1_{date_tag}.json\")\n                        if acc:\n                            buys = int(acc.get(\"today_buy_count\") or 0)\n                            if buys > 0:\n                                # 进一步确认买的是今日新开仓（非持仓维护）\n                                holdings = acc.get(\"holdings\") or {}\n                                if isinstance(holdings, dict):\n                                    from datetime import timedelta\n                                    open_dates = [v.get(\"open_date\", \"\") for v in holdings.values() if isinstance(v, dict)]\n                                    today_str = datetime.now().strftime(\"%Y-%m-%d\")\n                                    is_new_position = today_str in str(open_dates)\n                                    if is_new_position:\n                                        append_issue(\n                                            issues,\n                                            \"critical\",\n                                            f\"prev_halt_buy_through_{profile}\",\n                                            f\"前日 halt 延续，但 {profile} 今日仍有新增买={buys}（应被早盘风控阻断）\",\n                                        )\n\n    # 深层阻断检查链是否持续接通\n    deep_guard = load_json(QUANT_REPORT_DIR / 'paper_sim_deep_guard_check_latest.json')\n    if deep_guard:\n        if str(deep_guard.get('status') or '') not in {'PASS', 'WARN'}:\n            append_issue(issues, 'high', 'paper_sim_deep_guard_not_ready', f\"status={deep_guard.get('status')}\")\n    else:\n        append_issue(issues, 'high', 'paper_sim_deep_guard_missing', 'paper_sim_deep_guard_check_latest.json missing')\n\n    status = 'PASS' if not issues else ('ALERT' if any(i['severity']=='critical' for i in issues) else 'WARN')\n    payload = {\n        'generated_at': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n        'date_tag': date_tag,\n        'status': status,\n        'issue_count': len(issues),\n        'issues': issues,\n        'inputs': {\n            'runtime_state': str(QUANT_REPORT_DIR / 'runtime_risk_state_latest.json'),\n            'strategy_report': str(QUANT_REPORT_DIR / f'today_stock_strategy_report_{date_tag}.json'),\n            'event_watch': str(REPORT_DIR / f'investment_research_event_watch_{date_tag}.json'),\n        }\n    }\n\n    latest_json = REPORT_DIR / 'tester_scheduled_guard_latest.json'\n    dated_json = REPORT_DIR / f'tester_scheduled_guard_{date_tag}.json'\n    latest_md = REPORT_DIR / 'tester_scheduled_guard_latest.md'\n    dated_md = REPORT_DIR / f'tester_scheduled_guard_{date_tag}.md'\n    text = [\n        '# Tester 定时检验',\n        '',\n        f\"- 生成时间：{payload['generated_at']}\",\n        f\"- 状态：`{status}`\",\n        f\"- 问题数：`{len(issues)}`\",\n        '',\n        '## 问题列表',\n    ]\n    if issues:\n        for item in issues:\n            text.append(f\"- [{item['severity']}] `{item['code']}`：{item['detail']}\")\n    else:\n        text.append('- 无问题')\n    text.append('')\n\n    for p in [latest_json, dated_json]:\n        p.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding='utf-8')\n    for p in [latest_md, dated_md]:\n        p.write_text('\\n'.join(text), encoding='utf-8')\n\n    print(json.dumps({'status': status, 'issue_count': len(issues), 'latest_json': str(latest_json), 'latest_md': str(latest_md)}, ensure_ascii=False, indent=2))\n\n\nif __name__ == '__main__':\n    main()\n"}],"isError":false,"timestamp":1774531459360}}
{"type":"message","id":"0ce009db","parentId":"5c937cc9","timestamp":"2026-03-26T13:24:19.386Z","message":{"role":"toolResult","toolCallId":"call_ImoS5NLlPUrjNwcuE7FCnkrW|fc_0142f9a21f5351e00169c53381e264819b9ac88bfa39cb9a35","toolName":"read","content":[{"type":"text","text":"# Tester 定时检验\n\n- 生成时间：2026-03-26 16:35:01\n- 状态：`WARN`\n- 问题数：`1`\n\n## 问题列表\n- [high] `csv_index_data_stale`：CSV 指数数据陈旧（20260325 < 20260326），早盘 halt 判断不可靠\n"}],"isError":false,"timestamp":1774531459373}}
