w/workspace/research/reports/investment_research_background_chief_researcher_post_close_20260318.json:179:        \"触发临时会商监控告警\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_background_chief_researcher_post_close_20260318.json:186:      \"触发临时会商监控告警\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_background_chief_researcher_post_close_20260318.json:192:      \"status\": \"offhours_guarded\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_background_cycle_pre_open_20260324.json:165:    \"status\": \"offhours_guarded\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_background_cycle_pre_open_20260324.json:166:    \"reason\": \"system_gate_warning:precheck_status=blocked; health_probe:offhours_guarded\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_background_cycle_pre_open_20260324.json:194:        \"触发临时会商监控告警\",\n/Users/ling/.openclaw/workspace/research/reports/investment_research_background_cycle_pre_open_20260324.json:201:      \"触发临时会商监控告警\",","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774531942193}}
{"type":"message","id":"d208edaf","parentId":"e3090a20","timestamp":"2026-03-26T13:32:22.214Z","message":{"role":"toolResult","toolCallId":"call_wcj5I301IZsvg40cDIlqn8Ns|fc_0142f9a21f5351e00169c535655a80819b87e1604b28aa380b","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom morning_news_state_utils import normalize_morning_news_state\nfrom report_io import atomic_write_json, atomic_write_text\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\n\n\ndef today_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef maybe_json(path: Path) -> dict[str, Any] | None:\n    return load_json(path) if path.exists() else None\n\n\ndef resolve_latest_meeting_type(tag: str, control_tower: dict[str, Any]) -> str:\n    latest = control_tower.get(\"latest_meeting_type\")\n    if isinstance(latest, str) and latest.strip():\n        return latest.strip()\n\n    for meeting_type in (\"night\", \"close\", \"midday\", \"morning\"):\n        if (REPORT_DIR / f\"investment_research_chief_dashboard_{meeting_type}_{tag}.json\").exists():\n            return meeting_type\n\n    return \"morning\"\n\n\ndef build_alert_message(overall: str, snapshot: dict[str, Any], missing: list[str], paths: dict[str, Any]) -> str:\n    prefix = {\n        \"OK\": \"🩺 量化投研主链巡检：OK\",\n        \"WARN\": \"⚠️ 量化投研主链巡检：WARN\",\n        \"ALERT\": \"🚨 量化投研主链巡检：ALERT\",\n    }.get(overall, \"❓ 量化投研主链巡检：UNKNOWN\")\n    lines = [\n        prefix,\n        f\"- 08:50晨报：`{snapshot.get('morning_news_status', '-')}` | 最近成功：`{snapshot.get('morning_news_last_success_at', '-')}`\",\n        f\"- 晨报状态说明：`{snapshot.get('morning_news_status_reason', '-')}`\",\n        f\"- 稳定策略：`{snapshot.get('strategy_audit_status', '-')}` | 年化/回撤/夏普：`{snapshot.get('strategy_audit_annual_return_pct', '-')}` / `{snapshot.get('strategy_audit_max_drawdown_pct', '-')}` / `{snapshot.get('strategy_audit_sharpe', '-')}`\",\n        f\"- 回测队列：`{snapshot.get('backtest_queue_status', '-')}` | 运行中：`{snapshot.get('backtest_queue_running_count', '-')}` | 已纳入稳定策略：`{snapshot.get('stable_strategy_visible', '-')}`\",\n        f\"- 模拟盘快照：`{snapshot.get('paper_date_tag', '-')}` | 新鲜度：`{snapshot.get('paper_freshness_status', '-')}` | 说明：`{snapshot.get('paper_freshness_summary', '-')}`\",\n        f\"- 缺口：{', '.join(missing) if missing else '无'}\",\n        f\"- 健康报告：`{paths.get('control_tower_json') or '暂无'}`\",\n    ]\n    if overall == 'ALERT':\n        lines.append('- 处理建议：优先检查晨报、稳定策略审计、回测队列三项是否断裂，再决定是否暂停后续自动发布。')\n    elif overall == 'WARN':\n        lines.append('- 处理建议：补齐缺失产物或入口文件，确认 bundle/card/dashboard 已同步更新。')\n    else:\n        lines.append('- 处理建议：当前主链完整，无需额外打扰。')\n    return \"\\n\".join(lines)\n\n\ndef build_health() -> dict[str, Any]:\n    tag = today_tag()\n    control_tower_path = REPORT_DIR / f\"investment_research_control_tower_{tag}.json\"\n    control_tower_card_path = REPORT_DIR / f\"investment_research_control_tower_card_{tag}.json\"\n    control_tower = maybe_json(control_tower_path) or {}\n    meeting_type = resolve_latest_meeting_type(tag, control_tower)\n    publish_bundle_path = REPORT_DIR / f\"investment_research_publish_bundle_{meeting_type}_{tag}.json\"\n    chief_dashboard_path = REPORT_DIR / f\"investment_research_chief_dashboard_{meeting_type}_{tag}.json\"\n    chief_broadcast_path = REPORT_DIR / f\"investment_research_chief_broadcast_{meeting_type}_{tag}.md\"\n    publish_bundle = maybe_json(publish_bundle_path) or {}\n    chief_dashboard = maybe_json(chief_dashboard_path) or {}\n\n    morning_news = control_tower.get(\"morning_news\", {})\n    morning_news_norm = normalize_morning_news_state(morning_news)\n    strategy_audit = control_tower.get(\"strategy_audit\", {})\n    backtest_queue = control_tower.get(\"backtest_queue\", {})\n    paper_execution = control_tower.get(\"paper_execution\", {})\n    paper_freshness = (paper_execution.get(\"freshness\") or {}) if isinstance(paper_execution, dict) else {}\n    bundle_snapshot = publish_bundle.get(\"control_tower_snapshot\", {})\n\n    checks = {\n        \"morning_news_ok\": bool(morning_news.get(\"health_ok\", morning_news_norm.get(\"health_ok\"))),\n        \"strategy_audit_ok\": strategy_audit.get(\"overall_status\") == \"PASS\" and bool(strategy_audit.get(\"robust_pass\")),\n        \"backtest_queue_ok\": backtest_queue.get(\"status\") == \"OK\" and bool(backtest_queue.get(\"stable_strategy_visible\")),\n        \"bundle_snapshot_ok\": bool(\n            bundle_snapshot.get(\"morning_news_ok\", bundle_snapshot.get(\"morning_news_status\") in {\"OK\", \"PENDING_TODAY\", \"SKIP_NON_TRADING_DAY\"})\n        )\n        and bool(bundle_snapshot.get(\"strategy_audit_ok\", bundle_snapshot.get(\"strategy_audit_status\") == \"PASS\"))\n        and bundle_snapshot.get(\"backtest_queue_status\") == \"OK\",\n        \"chief_dashboard_exists\": chief_dashboard_path.exists(),\n        \"chief_broadcast_exists\": chief_broadcast_path.exists(),\n        \"control_tower_card_exists\": control_tower_card_path.exists(),\n        \"paper_execution_fresh\": str(paper_freshness.get(\"status\") or \"\") in {\"fresh\", \"pending_today_refresh\"},\n    }\n\n    missing = [name for name, ok in checks.items() if not ok]\n    if not checks[\"morning_news_ok\"] or not checks[\"strategy_audit_ok\"] or not checks[\"backtest_queue_ok\"]:\n        overall = \"ALERT\"\n    elif missing:\n        overall = \"WARN\"\n    else:\n        overall = \"OK\"\n\n    snapshot = {\n        \"morning_news_status\": morning_news.get(\"status\") or morning_news_norm.get(\"effective_status\"),\n        \"morning_news_last_success_at\": morning_news.get(\"last_success_at\"),\n        \"morning_news_status_reason\": morning_news.get(\"status_reason\") or morning_news_norm.get(\"status_reason\"),\n        \"strategy_audit_status\": strategy_audit.get(\"overall_status\"),\n        \"strategy_audit_annual_return_pct\": strategy_audit.get(\"annual_return_pct\"),\n        \"strategy_audit_max_drawdown_pct\": strategy_audit.get(\"max_drawdown_pct\"),\n        \"strategy_audit_sharpe\": strategy_audit.get(\"sharpe\"),\n        \"backtest_queue_status\": backtest_queue.get(\"status\"),\n        \"backtest_queue_running_count\": backtest_queue.get(\"running_count\"),\n        \"stable_strategy_visible\": backtest_queue.get(\"stable_strategy_visible\"),\n        \"paper_date_tag\": paper_execution.get(\"date_tag\"),\n        \"paper_freshness_status\": paper_freshness.get(\"status\"),\n        \"paper_freshness_summary\": paper_freshness.get(\"summary\"),\n    }\n    paths = {\n        \"control_tower_json\": str(control_tower_path) if control_tower_path.exists() else None,\n        \"publish_bundle_json\": str(publish_bundle_path) if publish_bundle_path.exists() else None,\n        \"chief_dashboard_json\": str(chief_dashboard_path) if chief_dashboard_path.exists() else None,\n        \"chief_broadcast_md\": str(chief_broadcast_path) if chief_broadcast_path.exists() else None,\n        \"control_tower_card_json\": str(control_tower_card_path) if control_tower_card_path.exists() else None,\n    }\n    return {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"date_tag\": tag,\n        \"meeting_type\": meeting_type,\n        \"overall_status\": overall,\n        \"checks\": checks,\n        \"missing_or_failed\": missing,\n        \"snapshot\": snapshot,\n        \"alert_message\": build_alert_message(overall, snapshot, missing, paths),\n        \"paths\": paths,\n    }\n\n\ndef render_md(payload: dict[str, Any]) -> str:\n    snap = payload.get(\"snapshot\", {})\n    lines = [\n        \"# 量化投研主链健康检查\",\n        \"\",\n        f\"- 生成时间：{payload.get('generated_at')}\",\n        f\"- 总体状态：`{payload.get('overall_status')}`\",\n        \"\",\n        \"## 核心快照\",\n        f\"- 08:50晨报：`{snap.get('morning_news_status', '-')}` | 最近成功：`{snap.get('morning_news_last_success_at', '-')}`\",\n        f\"- 晨报状态说明：`{snap.get('morning_news_status_reason', '-')}`\",\n        f\"- 稳定策略：`{snap.get('strategy_audit_status', '-')}` | 年化/回撤/夏普：`{snap.get('strategy_audit_annual_return_pct', '-')}` / `{snap.get('strategy_audit_max_drawdown_pct', '-')}` / `{snap.get('strategy_audit_sharpe', '-')}`\",\n        f\"- 回测队列：`{snap.get('backtest_queue_status', '-')}` | 运行中：`{snap.get('backtest_queue_running_count', '-')}` | 已纳入稳定策略：`{snap.get('stable_strategy_visible', '-')}`\",\n        f\"- 模拟盘快照：`{snap.get('paper_date_tag', '-')}` | 新鲜度：`{snap.get('paper_freshness_status', '-')}` | 说明：`{snap.get('paper_freshness_summary', '-')}`\",\n        \"\",\n        \"## 检查项\",\n    ]\n    for name, ok in payload.get(\"checks\", {}).items():\n        lines.append(f\"- {name}: `{ok}`\")\n    lines.append(\"\")\n    lines.append(\"## 缺口\")\n    missing = payload.get(\"missing_or_failed\", [])\n    if missing:\n        for item in missing:\n            lines.append(f\"- {item}\")\n    else:\n        lines.append(\"- 无\")\n    lines.append(\"\")\n    lines.append(\"## 路径\")\n    for key, value in payload.get(\"paths\", {}).items():\n        lines.append(f\"- {key}: `{value or '暂无'}`\")\n    lines.append(\"\")\n    return \"\\n\".join(lines)\n\n\ndef main() -> None:\n    payload = build_health()\n    md_path = REPORT_DIR / f\"investment_research_mainline_health_{today_tag()}.md\"\n    json_path = REPORT_DIR / f\"investment_research_mainline_health_{today_tag()}.json\"\n    atomic_write_text(md_path, render_md(payload), encoding=\"utf-8\")\n    atomic_write_json(json_path, payload, encoding=\"utf-8\", ensure_ascii=False, indent=2)\n    print(md_path)\n    print(json_path)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774531942203}}
{"type":"message","id":"ff7d35e5","parentId":"d208edaf","timestamp":"2026-03-26T13:32:22.226Z","message":{"role":"toolResult","toolCallId":"call_sYU4Psd8WqF9zGIMcsogOhsC|fc_0142f9a21f5351e00169c535655a88819b9cc7ef558c74784e","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom investment_research_health_snapshot import build_health_snapshot, build_ths_alert_line, latest_health_probe_for_date\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\nCONFIG_FILE = WORKSPACE / \"config\" / \"investment_research_delivery_v1.json\"\nSTATE_FILE = WORKSPACE / \"memory\" / \"investment_research_delivery_state.json\"\nOPENCLAW_BIN_CANDIDATES = [\n    str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"aliases\" / \"default\" / \"bin\" / \"openclaw\"),\n    shutil.which(\"openclaw\") or \"\",\n    \"openclaw\",\n]\n\nMEETING_LABELS = {\n    \"morning\": \"盘前会\",\n    \"midday\": \"午盘巡检\",\n    \"close\": \"收盘复盘\",\n    \"night\": \"夜间研究会\",\n}\n\nMEETING_EMOJIS = {\n    \"morning\": \"🌅\",\n    \"midday\": \"☀️\",\n    \"close\": \"📘\",\n    \"night\": \"🌙\",\n}\n\nSTATUS_LABELS = {\n    \"healthy\": \"健康\",\n    \"offhours_guarded\": \"非交易时段观察\",\n    \"watch_guarded\": \"警戒观察\",\n    \"degraded\": \"降级\",\n    \"normal\": \"正常\",\n    \"cautious\": \"谨慎\",\n    \"observe_defensive\": \"防守观察\",\n    \"halt\": \"暂停\",\n    \"ok\": \"正常\",\n    \"fallback\": \"已回退\",\n    \"failed\": \"部分失败\",\n    \"unavailable\": \"不可用\",\n    \"unknown\": \"未知\",\n    \"fresh\": \"今日已刷新\",\n    \"pending_today_refresh\": \"待今日刷新\",\n    \"stale\": \"已过期\",\n    \"missing\": \"缺失\",\n}\n\n\ndef now_str() -> str:\n    return datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n\ndef default_date_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    try:\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef write_json(path: Path, payload: dict[str, Any]) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n\n\ndef read_text(path: Path) -> str:\n    if not path.exists():\n        return \"\"\n    return path.read_text(encoding=\"utf-8\")\n\n\ndef cn_status(value: Any) -> str:\n    if value is None or value == \"\":\n        return \"-\"\n    return STATUS_LABELS.get(str(value), str(value))\n\n\ndef cn_text(value: Any) -> str:\n    if value is None or value == \"\":\n        return \"-\"\n    text = str(value)\n    replacements = {\n        \"public_source_divergence>\": \"公开网页源存在价差分歧 > \",\n        \"normal模式\": \"正常模式\",\n    }\n    for old, new in replacements.items():\n        text = text.replace(old, new)\n    return text\n\n\ndef resolve_openclaw_bin() -> str:\n    for candidate in OPENCLAW_BIN_CANDIDATES:\n        if candidate and Path(candidate).exists():\n            return candidate\n    for candidate in OPENCLAW_BIN_CANDIDATES:\n        if candidate:\n            return candidate\n    return \"openclaw\"\n\n\ndef run_cmd(cmd: list[str], timeout: int = 120) -> tuple[int, str, str]:\n    try:\n        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)\n        return proc.returncode, proc.stdout or \"\", proc.stderr or \"\"\n    except FileNotFoundError as exc:\n        return 127, \"\", str(exc)\n    except subprocess.TimeoutExpired as exc:\n        return 124, exc.stdout or \"\", exc.stderr or f\"timeout after {timeout}s\"\n\n\ndef selected_targets(config: dict[str, Any]) -> list[tuple[str, dict[str, Any]]]:\n    targets = config.get(\"targets\", {})\n    mode = str(config.get(\"deliveryMode\") or \"dm_and_group\")\n    ordered_names: list[str]\n    if mode == \"dm\":\n        ordered_names = [\"dm\"]\n    elif mode == \"group\":\n        ordered_names = [\"group\"]\n    else:\n        ordered_names = [\"dm\", \"group\"]\n\n    result: list[tuple[str, dict[str, Any]]] = []\n    for name in ordered_names:\n        payload = targets.get(name)\n        if isinstance(payload, dict) and payload.get(\"enabled\", True):\n            result.append((name, payload))\n    if result:\n        return result\n\n    for name, payload in targets.items():\n        if isinstance(payload, dict) and payload.get(\"enabled\", True):\n            result.append((str(name), payload))\n    return result\n\n\ndef compact_watchlist(items: list[Any], limit: int = 5) -> list[str]:\n    result: list[str] = []\n    for item in items[:limit]:\n        if isinstance(item, dict):\n            display = item.get(\"display\") or item.get(\"ticker\") or item.get(\"name\")\n            if display:\n                result.append(str(display))\n        elif item:\n            result.append(str(item))\n    return result\n\n\ndef compact_sell_review(items: list[Any], limit: int = 5) -> list[str]:\n    result: list[str] = []\n    for item in items[:limit]:\n        if isinstance(item, dict):\n            display = item.get(\"display\") or item.get(\"ticker\") or item.get(\"name\")\n            reason = item.get(\"reason\") or item.get(\"action\")\n            if display and reason:\n                result.append(f\"{display} | {reason}\")\n            elif display:\n                result.append(str(display))\n        elif item:\n            result.append(str(item))\n    return result\n\n\ndef resolve_health_snapshot(date_tag: str, bundle: dict[str, Any], control_tower: dict[str, Any]) -> dict[str, Any]:\n    health_scope, health_probe, health_path = latest_health_probe_for_date(REPORT_DIR, date_tag)\n    if health_probe:\n        return build_health_snapshot(health_scope, health_probe, health_path)\n    health_snapshot = control_tower.get(\"health_probe\", {}) if isinstance(control_tower.get(\"health_probe\"), dict) else {}\n    if health_snapshot:\n        return health_snapshot\n    bundle_probe = bundle.get(\"data_source_health\", {}) if isinstance(bundle.get(\"data_source_health\"), dict) else {}\n    if bundle_probe:\n        return build_health_snapshot(bundle_probe.get(\"scope\"), bundle_probe, None)\n    return {}\n\n\ndef should_include_execution_review_summary(meeting_type: str, trade_card: dict[str, Any]) -> bool:\n    if meeting_type not in {\"close\", \"night\"}:\n        return False\n    entries = trade_card.get(\"execution_review_entries\", [])\n    if not entries or not isinstance(entries[0], dict):\n        return False\n    review_item = entries[0]\n    if review_item.get(\"reason\") == \"holding_outside_trade_loop\":\n        return False\n    if review_item.get(\"primary_attribution_label\") == \"holding_without_strategy_exit\":\n        return False\n    if review_item.get(\"stage\") == \"sell_review\" and not trade_card.get(\"sell_review_list\"):\n        return False\n    return True\n\n\ndef build_message(\n    meeting_type: str,\n    date_tag: str,\n    trade_card: dict[str, Any],\n    bundle: dict[str, Any],\n    health_snapshot: dict[str, Any],\n) -> str:\n    watchlist = compact_watchlist(trade_card.get(\"watchlist\", []))\n    sell_review = compact_sell_review(trade_card.get(\"sell_review_list\", []))\n    event_watch = bundle.get(\"event_watch\", {}) if isinstance(bundle.get(\"event_watch\"), dict) else {}\n    ths = health_snapshot.get(\"ths_market\", {}) if isinstance(health_snapshot.get(\"ths_market\"), dict) else {}\n    paper_freshness = trade_card.get(\"paper_execution_freshness\", {}) if isinstance(trade_card.get(\"paper_execution_freshness\"), dict) else {}\n    risk_text = \"偏防守\" if trade_card.get(\"risk_off\") else \"条件化推进\"\n    watchlist_text = \"、\".join(watchlist) if watchlist else str(trade_card.get(\"watchlist_reason\") or \"暂无\")\n    sell_review_text = \"、\".join(sell_review) if sell_review else str(trade_card.get(\"sell_review_reason\") or \"暂无\")\n    alert_line = build_ths_alert_line(health_snapshot)\n\n    lines: list[str] = []\n    if alert_line:\n        lines.append(f\"[THS告警] {alert_line}\")\n\n    lines.extend([\n        f\"{MEETING_EMOJIS.get(meeting_type, '📊')} 模拟交易提示｜{MEETING_LABELS.get(meeting_type, meeting_type)}｜{date_tag}\",\n        f\"- 风险状态：{risk_text}\",\n        f\"- 模拟买入观察：{watchlist_text}\",\n        f\"- 模拟卖出复核：{sell_review_text}\",\n        f\"- 执行门槛：{'需要人工确认' if trade_card.get('user_confirmation_required') else '系统可直接推进'}\",\n    ])\n    loop_entries = trade_card.get(\"trade_loop_buy_entries\", [])[:2]\n    for item in loop_entries:\n        lines.append(\n            f\"- {item.get('display') or item.get('ticker') or '-'}：{item.get('stage_label') or item.get('stage') or '-'}\"\n            f\" | 触发={item.get('trigger_hint') or '-'} | 止损/止盈={item.get('stop_loss') or '-'} / {item.get('take_profit') or '-'}\"\n        )\n    if should_include_execution_review_summary(meeting_type, trade_card):\n        review_item = trade_card[\"execution_review_entries\"][0]\n        lines.append(\n            f\"- 执行归因：{review_item.get('display') or review_item.get('ticker') or '-'} | \"\n            f\"{review_item.get('primary_attribution_label_cn') or '-'} | 下一步={review_item.get('primary_next_action') or '-'}\"\n        )\n\n    if trade_card.get(\"risk_off\"):\n        lines.append(\"- 当前结论：只保留观察名单和触发条件，不自动转成买单。\")\n    if not trade_card.get(\"trading_time\", False):\n        lines.append(\"- 当前非交易时段/非交易日，不提供可执行买价。\")\n    if event_watch.get(\"should_temporary_meet\"):\n        lines.append(\"- 事件监控：已触发临时会商建议。\")\n    if trade_card.get(\"paper_date_tag\") or paper_freshness:\n        lines.append(\n            f\"- 模拟盘快照：{trade_card.get('paper_date_tag') or '-'}\"\n            f\" | 新鲜度={cn_status(paper_freshness.get('status'))}\"\n        )\n        if paper_freshness.get(\"summary\"):\n            lines.append(f\"- 模拟盘说明：{paper_freshness.get('summary')}\")\n    if health_snapshot.get(\"status\"):\n        lines.append(\n            f\"- 数据源健康：{cn_status(health_snapshot.get('status'))}\"\n            f\" | 推荐模式={cn_status(health_snapshot.get('recommended_mode'))}\"\n        )\n    if ths:\n        lines.append(\n            f\"- THS本地行情：{cn_status(ths.get('status'))}\"\n            f\" | THS命中/回退/失败={ths.get('ok_count', 0)}/{ths.get('fallback_count', 0)}/{ths.get('failed_count', 0)}\"\n        )\n        lines.append(f\"- THS摘要：{ths.get('summary') or '-'}\")\n    if health_snapshot.get(\"observations\"):\n        lines.append(f\"- 观察项：{'、'.join(cn_text(item) for item in health_snapshot.get('observations', [])[:2])}\")\n    return \"\\n\".join(lines)\n\n\ndef dedupe_key(\n    meeting_type: str,\n    date_tag: str,\n    target_name: str,\n    target_value: str,\n    message: str,\n    card_payload: dict[str, Any] | None,\n) -> str:\n    base = {\n        \"meeting_type\": meeting_type,\n        \"date_tag\": date_tag,\n        \"target_name\": target_name,\n        \"target_value\": target_value,\n        \"message\": message,\n        \"card\": card_payload or {},\n    }\n    raw = json.dumps(base, ensure_ascii=False, sort_keys=True)\n    return hashlib.sha256(raw.encode(\"utf-8\")).hexdigest()\n\n\ndef send_payload(\n    *,\n    channel: str,\n    account: str,\n    target: str,\n    message: str,\n    card_payload: dict[str, Any] | None,\n    dry_run: bool,\n) -> tuple[bool, str]:\n    cmd = [\n        resolve_openclaw_bin(),\n        \"message\",\n        \"send\",\n        \"--channel\",\n        channel,\n        \"--account\",\n        account,\n        \"--target\",\n        target,\n        \"-m\",\n        message,\n        \"--json\",\n    ]\n    if card_payload:\n        cmd.extend([\"--card\", json.dumps(card_payload, ensure_ascii=False)])\n    if dry_run:\n        cmd.append(\"--dry-run\")\n    rc, out, err = run_cmd(cmd, timeout=180)\n    info = (out.strip() or err.strip())[-4000:]\n    return rc == 0, info\n\n\ndef main() -> int:\n    parser = argparse.ArgumentParser(description=\"Push investment research meeting summary to Feishu\")\n    parser.add_argument(\"--meeting-type\", choices=[\"morning\", \"midday\", \"close\", \"night\"], required=True)\n    parser.add_argument(\"--date-tag\", default=default_date_tag())\n    parser.add_argument(\"--dry-run\", action=\"store_true\")\n    parser.add_argument(\"--force\", action=\"store_true\")\n    args = parser.parse_args()\n\n    meeting_type = str(args.meeting_type)\n    date_tag = str(args.date_tag)\n    config = load_json(CONFIG_FILE)\n    state = load_json(STATE_FILE)\n\n    trade_card_path = REPORT_DIR / f\"investment_research_trade_card_{meeting_type}_{date_tag}.json\"\n    chief_card_path = REPORT_DIR / f\"investment_research_chief_card_{meeting_type}_{date_tag}.json\"\n    control_tower_card_path = REPORT_DIR / f\"investment_research_control_tower_card_{date_tag}.json\"\n    control_tower_path = REPORT_DIR / f\"investment_research_control_tower_{date_tag}.json\"\n    chief_broadcast_path = REPORT_DIR / f\"investment_research_chief_broadcast_{meeting_type}_{date_tag}.md\"\n    group_digest_path = REPORT_DIR / f\"investment_research_group_digest_{meeting_type}_{date_tag}.md\"\n    bundle_path = REPORT_DIR / f\"investment_research_publish_bundle_{meeting_type}_{date_tag}.json\"\n\n    trade_card = load_json(trade_card_path)\n    chief_card = load_json(chief_card_path)\n    control_tower_card = load_json(control_tower_card_path)\n    control_tower = load_json(control_tower_path)\n    bundle = load_json(bundle_path)\n    _chief_broadcast_text = read_text(chief_broadcast_path)\n    _group_digest_text = read_text(group_digest_path)\n\n    if not trade_card:\n        raise SystemExit(f\"missing trade card: {trade_card_path}\")\n\n    preferred_card = chief_card if chief_card else control_tower_card or None\n    health_snapshot = resolve_health_snapshot(date_tag, bundle, control_tower)\n    message = build_message(meeting_type, date_tag, trade_card, bundle, health_snapshot)\n\n    deliveries: list[dict[str, Any]] = []\n    state_deliveries = state.get(\"deliveries\", {}) if isinstance(state.get(\"deliveries\"), dict) else {}\n\n    for target_name, target_cfg in selected_targets(config):\n        channel = str(target_cfg.get(\"channel\") or \"feishu\")\n        account = str(target_cfg.get(\"account\") or \"main\")\n        target = str(target_cfg.get(\"target\") or \"\")\n        if not target:\n            deliveries.append(\n                {\n                    \"target_name\": target_name,\n                    \"status\": \"FAILED\",\n                    \"reason\": \"missing_target\",\n                }\n            )\n            continue\n\n        state_key = f\"{date_tag}:{meeting_type}:{target_name}:{target}\"\n        current_dedupe = dedupe_key(meeting_type, date_tag, target_name, target, message, preferred_card)\n        previous_dedupe = state_deliveries.get(state_key)\n        if previous_dedupe == current_dedupe and not args.force:\n            deliveries.append(\n                {\n                    \"target_name\": target_name,\n                    \"channel\": channel,\n                    \"account\": account,\n                    \"target\": target,\n                    \"status\": \"SKIPPED\",\n                    \"reason\": \"duplicate\",\n                    \"dedupe_key\": current_dedupe,\n                }\n            )\n            continue\n\n        ok, info = send_payload(\n            channel=channel,\n            account=account,\n            target=target,\n            message=message,\n            card_payload=preferred_card,\n            dry_run=args.dry_run,\n        )\n        deliveries.append(\n            {\n                \"target_name\": target_name,\n                \"channel\": channel,\n                \"account\": account,\n                \"target\": target,\n                \"status\": \"OK\" if ok else \"FAILED\",\n                \"dedupe_key\": current_dedupe,\n                \"info\": info,\n                \"dry_run\": args.dry_run,\n            }\n        )\n        if ok and not args.dry_run:\n            state_deliveries[state_key] = current_dedupe\n\n    state[\"deliveries\"] = state_deliveries\n    state[\"updated_at\"] = now_str()\n    if not args.dry_run:\n        write_json(STATE_FILE, state)\n\n    report_payload = {\n        \"generated_at\": now_str(),\n        \"meeting_type\": meeting_type,\n        \"date_tag\": date_tag,\n        \"dry_run\": args.dry_run,\n        \"force\": args.force,\n        \"message\": message,\n        \"source_files\": {\n            \"trade_card\": str(trade_card_path),\n            \"chief_card\": str(chief_card_path) if chief_card_path.exists() else None,\n            \"control_tower_card\": str(control_tower_card_path) if control_tower_card_path.exists() else None,\n            \"control_tower\": str(control_tower_path) if control_tower_path.exists() else None,\n            \"chief_broadcast\": str(chief_broadcast_path) if chief_broadcast_path.exists() else None,\n            \"group_digest\": str(group_digest_path) if group_digest_path.exists() else None,\n            \"publish_bundle\": str(bundle_path) if bundle_path.exists() else None,\n        },\n        \"health_snapshot\": health_snapshot,\n        \"deliveries\": deliveries,\n    }\n    report_path = REPORT_DIR / f\"investment_research_delivery_push_{meeting_type}_{date_tag}.json\"\n    write_json(report_path, report_payload)\n    print(report_path)\n\n    failed = [item for item in deliveries if item.get(\"status\") == \"FAILED\"]\n    return 1 if failed else 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n"}],"isError":false,"timestamp":1774531942214}}
