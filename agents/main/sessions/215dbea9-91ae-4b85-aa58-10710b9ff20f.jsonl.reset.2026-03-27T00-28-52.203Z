\")\n","new_string":"def cn_status(value: Any) -> str:\n    mapping = {\n        \"OK\": \"正常\",\n        \"WARN\": \"预警\",\n        \"ALERT\": \"告警\",\n        \"PASS\": \"通过\",\n        \"ERROR\": \"错误\",\n        \"PENDING_TODAY\": \"待今日晨报\",\n        \"SKIP_NON_TRADING_DAY\": \"非交易日跳过\",\n        \"fresh\": \"今日已刷新\",\n        \"pending_today_refresh\": \"待今日刷新\",\n        \"stale\": \"已过期\",\n        \"missing\": \"缺失\",\n    }\n    if value is None or value == \"\":\n        return \"-\"\n    return mapping.get(str(value), str(value))\n\n\ndef cn_bool(value: Any) -> str:\n    if value is True:\n        return \"是\"\n    if value is False:\n        return \"否\"\n    return \"-\"\n\n\ndef cn_check_name(name: str) -> str:\n    mapping = {\n        \"morning_news_ok\": \"08:50晨报链路正常\",\n        \"strategy_audit_ok\": \"稳定策略审计正常\",\n        \"backtest_queue_ok\": \"回测队列正常\",\n        \"bundle_snapshot_ok\": \"发布汇总快照正常\",\n        \"chief_dashboard_exists\": \"首席面板已生成\",\n        \"chief_broadcast_exists\": \"首席播报已生成\",\n        \"control_tower_card_exists\": \"总控台卡片已生成\",\n        \"paper_execution_fresh\": \"模拟盘快照为今日口径\",\n    }\n    return mapping.get(name, name)\n\n\ndef build_alert_message(overall: str, snapshot: dict[str, Any], missing: list[str], paths: dict[str, Any]) -> str:\n    prefix = {\n        \"OK\": \"🩺 量化投研主链巡检：正常\",\n        \"WARN\": \"⚠️ 量化投研主链巡检：预警\",\n        \"ALERT\": \"🚨 量化投研主链巡检：告警\",\n    }.get(overall, \"❓ 量化投研主链巡检：未知\")\n"},"partialJson":"{\"file_path\":\"/Users/ling/.openclaw/workspace/scripts/generate_investment_research_mainline_health.py\",\"old_string\":\"def build_alert_message(overall: str, snapshot: dict[str, Any], missing: list[str], paths: dict[str, Any]) -> str:\\n    prefix = {\\n        \\\"OK\\\": \\\"🩺 量化投研主链巡检：OK\\\",\\n        \\\"WARN\\\": \\\"⚠️ 量化投研主链巡检：WARN\\\",\\n        \\\"ALERT\\\": \\\"🚨 量化投研主链巡检：ALERT\\\",\\n    }.get(overall, \\\"❓ 量化投研主链巡检：UNKNOWN\\\")\\n\",\"new_string\":\"def cn_status(value: Any) -> str:\