type":"toolCall","id":"call_JZPudjhMVtH8gru41g2M8JZ8|fc_0142f9a21f5351e00169c5389c582c819bb1f1917d04992bdc","name":"read","arguments":{"file_path":"/Users/ling/.openclaw/workspace/scripts/generate_investment_research_control_tower_card.py"},"partialJson":"{\"file_path\":\"/Users/ling/.openclaw/workspace/scripts/generate_investment_research_control_tower_card.py\"}"},{"type":"toolCall","id":"call_4u2T0i78q48Bb7YKr610OMLA|fc_0142f9a21f5351e00169c5389c5834819bb0d937da3494fb29","name":"read","arguments":{"file_path":"/Users/ling/.openclaw/workspace/scripts/generate_investment_research_chief_card.py"},"partialJson":"{\"file_path\":\"/Users/ling/.openclaw/workspace/scripts/generate_investment_research_chief_card.py\"}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":122239,"output":182,"cacheRead":0,"cacheWrite":0,"totalTokens":122421,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774532742326,"responseId":"resp_0142f9a21f5351e00169c538958da0819b814be6e8e8fcacc3"}}
{"type":"message","id":"81bcd435","parentId":"e9f87d2b","timestamp":"2026-03-26T13:46:05.335Z","message":{"role":"toolResult","toolCallId":"call_lmqax5YvkbqS5RySS7Lw6VcA|fc_0142f9a21f5351e00169c5389c5810819bacc40c019c9f00d0","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport subprocess\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom investment_research_health_snapshot import build_health_snapshot, latest_health_probe_for_date\nfrom openclaw_runtime_status import build_runtime_status\nfrom investment_research_paper_bridge import build_paper_execution_snapshot\nfrom morning_news_state_utils import normalize_morning_news_state\nfrom report_io import atomic_write_json, atomic_write_text\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\nQAS_PROJECT_DIR = WORKSPACE / \"quant_projects\" / \"personal-a-share-research-system\"\nQAS_REPORT_DIR = QAS_PROJECT_DIR / \"research\" / \"reports\"\nBACKTEST_QUEUE_SCRIPT = QAS_PROJECT_DIR / \"scripts\" / \"report_backtest_queue_status.py\"\nLIVE_TRADING_CONFIG = QAS_PROJECT_DIR / \"config\" / \"live_trading_v1.json\"\nMEETING_TYPES = [\"morning\", \"midday\", \"close\", \"night\"]\nCYCLES = [\"pre_open\", \"intraday\", \"post_close\", \"overnight\"]\n\n\ndef today_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef maybe_json(path: Path) -> dict[str, Any] | None:\n    return load_json(path) if path.exists() else None\n\n\ndef dashboard_path(meeting_type: str) -> Path:\n    return REPORT_DIR / f\"investment_research_chief_dashboard_{meeting_type}_{today_tag()}.json\"\n\n\ndef chief_broadcast_path(meeting_type: str) -> Path:\n    return REPORT_DIR / f\"investment_research_chief_broadcast_{meeting_type}_{today_tag()}.md\"\n\n\ndef cycle_path(cycle: str) -> Path:\n    return REPORT_DIR / f\"investment_research_background_cycle_{cycle}_{today_tag()}.json\"\n\n\ndef morning_news_state() -> tuple[dict[str, Any] | None, Path]:\n    path = WORKSPACE / \"memory\" / \"global_market_morning_0850_state.json\"\n    return (load_json(path), path) if path.exists() else (None, path)\n\n\ndef latest_strategy_audit() -> tuple[dict[str, Any] | None, Path | None]:\n    candidates = sorted(QAS_REPORT_DIR.glob(\"daily_strategy_audit_*.json\"), key=lambda p: p.stat().st_mtime)\n    if not candidates:\n        return None, None\n    path = candidates[-1]\n    return load_json(path), path\n\n\ndef latest_auto_premarket_precheck() -> tuple[dict[str, Any] | None, Path | None]:\n    candidates = sorted(QAS_REPORT_DIR.glob(\"auto_premarket_precheck_*.json\"), key=lambda p: p.stat().st_mtime)\n    if not candidates:\n        return None, None\n    path = candidates[-1]\n    return load_json(path), path\n\n\ndef live_trading_execution_config() -> dict[str, Any] | None:\n    return load_json(LIVE_TRADING_CONFIG) if LIVE_TRADING_CONFIG.exists() else None\n\n\ndef snapshot_backtest_queue_status() -> tuple[dict[str, Any] | None, Path | None]:\n    if not BACKTEST_QUEUE_SCRIPT.exists():\n        return None, None\n    out_path = REPORT_DIR / f\"investment_research_backtest_queue_status_{today_tag()}.md\"\n    try:\n        proc = subprocess.run(\n            [sys.executable, str(BACKTEST_QUEUE_SCRIPT)],\n            cwd=str(QAS_PROJECT_DIR),\n            capture_output=True,\n            text=True,\n            check=True,\n        )\n        text = proc.stdout.strip()\n        atomic_write_text(out_path, text + \"\\n\", encoding=\"utf-8\")\n        running_count = text.count(\"- PID \")\n        stable_strategy_visible = \"Qlib breadth + turnover hardcap relaxed\" in text\n        return {\n            \"status\": \"OK\",\n            \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"path\": str(out_path),\n            \"running_count\": running_count,\n            \"stable_strategy_visible\": stable_strategy_visible,\n        }, out_path\n    except subprocess.CalledProcessError as exc:\n        atomic_write_text(out_path, (exc.stdout or \"\") + (\"\\n\" + exc.stderr if exc.stderr else \"\"), encoding=\"utf-8\")\n        return {\n            \"status\": \"ERROR\",\n            \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"path\": str(out_path),\n            \"running_count\": None,\n            \"stable_strategy_visible\": False,\n            \"error\": (exc.stderr or exc.stdout or \"\")[-1000:],\n        }, out_path\n\n\ndef parse_dt(text: str | None) -> datetime:\n    if not text:\n        return datetime.min\n    for fmt in [\"%Y-%m-%d %H:%M:%S\", \"%Y-%m-%dT%H:%M:%S.%f\", \"%Y-%m-%dT%H:%M:%S\"]:\n        try:\n            return datetime.strptime(text, fmt)\n        except ValueError:\n            continue\n    return datetime.min\n\n\ndef yes_no(value: Any) -> str:\n    if value is True:\n        return \"是\"\n    if value is False:\n        return \"否\"\n    if value is None or value == \"\":\n        return \"-\"\n    return str(value)\n\n\ndef cn_status(value: Any) -> str:\n    mapping = {\n        \"OK\": \"正常\",\n        \"ERROR\": \"错误\",\n        \"PASS\": \"通过\",\n        \"ALERT\": \"告警\",\n        \"healthy\": \"健康\",\n        \"watch_guarded\": \"警戒观察\",\n        \"offhours_guarded\": \"非交易时段观察\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"halt\": \"暂停\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"observe_defensive\": \"防守观察\",\n        \"RUNNING\": \"运行中\",\n        \"FAILED\": \"失败\",\n        \"SKIP_NON_TRADING_DAY\": \"非交易日跳过\",\n        \"PENDING_TODAY\": \"待今日晨报\",\n        \"STALE\": \"状态过期\",\n        \"PUSH_FAILED\": \"推送失败\",\n        \"GENERATION_FAILED\": \"生成失败\",\n        \"DEADLINE_MISSED\": \"超时未完成\",\n        \"MISSING\": \"缺失\",\n        \"ok\": \"正常\",\n        \"fallback\": \"已回退\",\n        \"failed\": \"部分失败\",\n        \"unavailable\": \"不可用\",\n        \"unknown\": \"未知\",\n        \"fresh\": \"今日已刷新\",\n        \"pending_today_refresh\": \"待今日刷新\",\n        \"stale\": \"已过期\",\n        \"mixed\": \"日期混杂\",\n        \"missing\": \"缺失\",\n    }\n    if value is None or value == \"\":\n        return \"-\"\n    return mapping.get(str(value), str(value))\n\n\ndef cn_text(text: Any) -> str:\n    if text is None or text == \"\":\n        return \"-\"\n    s = str(text)\n    replacements = {\n        \"market_breadth\": \"市场宽度\",\n        \"source_price_divergence\": \"数据源价差分歧\",\n        \"account_sync_age\": \"账户同步时延\",\n        \"observe_defensive\": \"防守观察\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"watch_guarded\": \"警戒观察\",\n        \"healthy\": \"健康\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"strict precheck\": \"严格盘前检查\",\n        \"BUY\": \"买入\",\n        \"SELL\": \"卖出\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"normal模式\": \"正常模式\",\n        \"public_source_divergence>\": \"公开网页源存在价差分歧 > \",\n    }\n    for old, new in replacements.items():\n        s = s.replace(old, new)\n    return s\n\n\ndef build_payload(anchor_meeting: str | None = None) -> dict[str, Any]:\n    dashboards: dict[str, dict[str, Any]] = {}\n    meeting_index: list[dict[str, Any]] = []\n    latest_meeting = None\n    latest_dashboard = None\n    latest_dt = datetime.min\n\n    for meeting_type in MEETING_TYPES:\n        path = dashboard_path(meeting_type)\n        dashboard = maybe_json(path)\n        if not dashboard:\n            continue\n        dashboards[meeting_type] = dashboard\n        generated_at = dashboard.get(\"generated_at\")\n        dt = parse_dt(generated_at)\n        meeting_index.append({\n            \"meeting_type\": meeting_type,\n            \"meeting_label\": dashboard.get(\"meeting_label\", meeting_type),\n            \"generated_at\": generated_at,\n            \"dashboard_json\": str(path),\n            \"dashboard_md\": str(path.with_suffix('.md')),\n            \"chief_broadcast_md\": str(chief_broadcast_path(meeting_type)) if chief_broadcast_path(meeting_type).exists() else None,\n            \"trade_card_md\": dashboard.get(\"export_paths\", {}).get(\"trade_card_md\"),\n        })\n        if dt >= latest_dt:\n            latest_dt = dt\n            latest_meeting = meeting_type\n            latest_dashboard = dashboard\n\n    if anchor_meeting and anchor_meeting in dashboards:\n        latest_meeting = anchor_meeting\n        latest_dashboard = dashboards[anchor_meeting]\n\n    duty_index: list[dict[str, Any]] = []\n    for cycle in CYCLES:\n        path = cycle_path(cycle)\n        payload = maybe_json(path)\n        if not payload:\n            continue\n        duty_index.append({\n            \"cycle\": cycle,\n            \"generated_at\": payload.get(\"generated_at\"),\n            \"status\": payload.get(\"data_source_runtime\", {}).get(\"status\"),\n            \"md\": str(path.with_suffix('.md')),\n            \"json\": str(path),\n        })\n\n    health_scope, health_probe, health_path = latest_health_probe_for_date(REPORT_DIR, today_tag())\n    health_snapshot = build_health_snapshot(health_scope, health_probe, health_path)\n    morning_news, morning_news_path = morning_news_state()\n    morning_news_norm = normalize_morning_news_state(morning_news)\n    strategy_audit, strategy_audit_path = latest_strategy_audit()\n    auto_premarket_precheck, auto_premarket_precheck_path = latest_auto_premarket_precheck()\n    paper_execution = build_paper_execution_snapshot()\n    execution_status = {\n        \"path\": str((paper_execution.get(\"files\") or {}).get(\"summary_json\") or \"\"),\n        \"date\": paper_execution.get(\"date_tag\"),\n        \"time\": paper_execution.get(\"generated_at\"),\n        \"status\": \"paper_only\",\n        \"status_reason\": \"execution_status 已切换为三套模拟盘口径\",\n        \"strict_precheck_passed\": paper_execution.get(\"execution_status\", {}).get(\"allowed_to_open_new_positions\"),\n        \"strict_precheck\": \"paper_profiles_only\",\n        **(paper_execution.get(\"execution_status\") or {}),\n    }\n    backtest_queue, backtest_queue_path = snapshot_backtest_queue_status()\n    event_watch_path = REPORT_DIR / f\"investment_research_event_watch_{today_tag()}.json\"\n    event_watch = maybe_json(event_watch_path)\n    temp_meeting_path = REPORT_DIR / f\"investment_research_temporary_meeting_broadcast_{today_tag()}.json\"\n    temp_meeting = maybe_json(temp_meeting_path)\n    llm_runtime = build_runtime_status()\n\n    latest_dashboard = latest_dashboard or {}\n    latest_status = latest_dashboard.get(\"status\", {})\n    latest_exports = latest_dashboard.get(\"export_paths\", {})\n\n    return {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"latest_meeting_type\": latest_meeting,\n        \"latest_meeting_label\": latest_dashboard.get(\"meeting_label\", latest_meeting),\n        \"latest_status\": latest_status,\n        \"watchlist\": [item.get(\"display\") or item.get(\"ticker\", \"\") for item in latest_dashboard.get(\"watchlist\", [])],\n        \"watchlist_reason\": latest_dashboard.get(\"watchlist_reason\", \"\"),\n        \"holdings_preview\": latest_dashboard.get(\"holdings_preview\", []),\n        \"trades_preview\": latest_dashboard.get(\"trades_preview\", []),\n        \"sell_review_list\": latest_dashboard.get(\"sell_review_list\", []),\n        \"sell_review_reason\": latest_dashboard.get(\"sell_review_reason\", \"\"),\n        \"meeting_index\": meeting_index,\n        \"duty_index\": duty_index,\n        \"health_probe\": health_snapshot,\n        \"event_watch\": {\n            \"path\": str(event_watch_path) if event_watch_path.exists() else None,\n            \"status\": (event_watch or {}).get(\"status\"),\n            \"should_temporary_meet\": (event_watch or {}).get(\"should_temporary_meet\"),\n            \"trigger_types\": [item.get(\"type\") for item in (event_watch or {}).get(\"triggers\", [])],\n        },\n        \"temporary_meeting\": {\n            \"path\": str(temp_meeting_path) if temp_meeting_path.exists() else None,\n            \"status\": (temp_meeting or {}).get(\"status\"),\n            \"participants\": [item.get(\"label\") for item in (temp_meeting or {}).get(\"participants\", [])],\n        },\n        \"morning_news\": {\n            \"path\": str(morning_news_path) if morning_news_path.exists() else None,\n            \"status\": morning_news_norm.get(\"effective_status\"),\n            \"raw_status\": morning_news_norm.get(\"raw_status\"),\n            \"health_ok\": morning_news_norm.get(\"health_ok\"),\n            \"status_reason\": morning_news_norm.get(\"status_reason\"),\n            \"expected_date_tag\": morning_news_norm.get(\"expected_date_tag\"),\n            \"raw_date_tag\": morning_news_norm.get(\"raw_date_tag\"),\n            \"generated_at\": (morning_news or {}).get(\"generated_at\"),\n            \"last_success_at\": (morning_news or {}).get(\"last_success_at\"),\n            \"last_failure_at\": (morning_news or {}).get(\"last_failure_at\"),\n            \"log_file\": (morning_news or {}).get(\"log_file\"),\n            \"brief_message\": (morning_news or {}).get(\"brief_message\"),\n        },\n        \"strategy_audit\": {\n            \"path\": str(strategy_audit_path) if strategy_audit_path else None,\n            \"date_tag\": (strategy_audit or {}).get(\"date_tag\"),\n            \"annual_return_pct\": (strategy_audit or {}).get(\"annual_return_pct\"),\n            \"max_drawdown_pct\": (strategy_audit or {}).get(\"max_drawdown_pct\"),\n            \"sharpe\": (strategy_audit or {}).get(\"sharpe\"),\n            \"robust_pass\": (strategy_audit or {}).get(\"robust_pass\"),\n            \"target_hit\": (strategy_audit or {}).get(\"target_hit\"),\n            \"overall_status\": (strategy_audit or {}).get(\"overall_status\"),\n            \"precheck_status\": (strategy_audit or {}).get(\"precheck_status\"),\n            \"execution_scope\": (strategy_audit or {}).get(\"execution_scope\"),\n            \"paper_runtime_ready\": (strategy_audit or {}).get(\"paper_runtime_ready\"),\n            \"live_runtime_ready\": (strategy_audit or {}).get(\"live_runtime_ready\"),\n            \"paper_profiles_enabled\": (strategy_audit or {}).get(\"paper_profiles_enabled\"),\n        },\n        \"execution_status\": execution_status,\n        \"paper_execution\": paper_execution,\n        \"backtest_queue\": {\n            \"path\": str(backtest_queue_path) if backtest_queue_path else None,\n            \"status\": (backtest_queue or {}).get(\"status\"),\n            \"generated_at\": (backtest_queue or {}).get(\"generated_at\"),\n            \"running_count\": (backtest_queue or {}).get(\"running_count\"),\n            \"stable_strategy_visible\": (backtest_queue or {}).get(\"stable_strategy_visible\"),\n            \"error\": (backtest_queue or {}).get(\"error\"),\n        },\n        \"llm_runtime\": llm_runtime,\n        \"export_paths\": {\n            **latest_exports,\n            \"holdings_csv\": (paper_execution.get(\"files\") or {}).get(\"holdings_csv\") or latest_exports.get(\"holdings_csv\"),\n            \"trades_csv\": (paper_execution.get(\"files\") or {}).get(\"trades_csv\") or latest_exports.get(\"trades_csv\"),\n            \"paper_execution_summary_md\": (paper_execution.get(\"files\") or {}).get(\"summary_md\"),\n            \"paper_execution_summary_json\": (paper_execution.get(\"files\") or {}).get(\"summary_json\"),\n            \"paper_orders_csv\": (paper_execution.get(\"files\") or {}).get(\"orders_csv\"),\n            \"paper_tickets_csv\": (paper_execution.get(\"files\") or {}).get(\"tickets_csv\"),\n            \"paper_execution_brief_md\": execution_status.get(\"brief_path\"),\n            \"paper_journal_csv\": execution_status.get(\"journal_path\"),\n            \"data_source_health_path\": str(health_path) if health_path else None,\n            \"event_watch_json\": str(event_watch_path) if event_watch_path.exists() else None,\n            \"temporary_meeting_json\": str(temp_meeting_path) if temp_meeting_path.exists() else None,\n            \"morning_news_state_json\": str(morning_news_path) if morning_news_path.exists() else None,\n            \"strategy_audit_json\": str(strategy_audit_path) if strategy_audit_path else None,\n            \"backtest_queue_md\": str(backtest_queue_path) if backtest_queue_path else None,\n            \"llm_runtime_json\": str(REPORT_DIR / f\"investment_research_control_tower_{today_tag()}.json\"),\n        },\n    }\n\n\ndef render_markdown(payload: dict[str, Any]) -> str:\n    latest_status = payload.get(\"latest_status\", {})\n    lines: list[str] = []\n    lines.append(\"# 来福投研会 - 首席研究员日内总控台\")\n    lines.append(\"\")\n    lines.append(f\"- 生成时间：{payload.get('generated_at')}\")\n    lines.append(f\"- 当前主视图：`{payload.get('latest_meeting_label') or payload.get('latest_meeting_type') or '暂无'}`\")\n    lines.append(f\"- 审计状态：`{cn_status(latest_status.get('audit_status'))}`\")\n    lines.append(f\"- 盘前强检：`{cn_status(latest_status.get('precheck_status'))}`\")\n    lines.append(f\"- 风险收缩：`{yes_no(latest_status.get('risk_off'))}`\")\n    lines.append(f\"- 年化/回撤/夏普：`{latest_status.get('annual_return_pct', '-')}` / `{latest_status.get('max_drawdown_pct', '-')}` / `{latest_status.get('sharpe', '-')}`\")\n    lines.append(\"\")\n\n    lines.append(\"## 当前总览\")\n    lines.append(f\"- 观察池：{', '.join([str(x) for x in payload.get('watchlist', [])[:5] if x is not None]) if payload.get('watchlist') else payload.get('watchlist_reason') or '暂无'}\")\n    lines.append(f\"- 持仓预览：{', '.join([str(x) for x in payload.get('holdings_preview', [])[:5] if x is not None]) if payload.get('holdings_preview') else '暂无'}\")\n    lines.append(f\"- 成交预览：{', '.join([str(x) for x in payload.get('trades_preview', [])[:5] if x is not None]) if payload.get('trades_preview') else '暂无'}\")\n    lines.append(f\"- 卖出/减仓复核：{', '.join([str(x) for x in payload.get('sell_review_list', [])[:5] if x is not None]) if payload.get('sell_review_list') else payload.get('sell_review_reason') or '暂无'}\")\n    lines.append(\"\")\n\n    hp = payload.get('health_probe', {})\n    ths = hp.get('ths_market', {})\n    ew = payload.get('event_watch', {})\n    tm = payload.get('temporary_meeting', {})\n    mn = payload.get('morning_news', {})\n    sa = payload.get('strategy_audit', {})\n    bq = payload.get('backtest_queue', {})\n    exs = payload.get('execution_status', {})\n    llm = payload.get('llm_runtime', {})\n    llm_summary = llm.get('summary', {})\n    paper_freshness = (payload.get('paper_execution') or {}).get('freshness', {})\n    lines.append(\"## 今日交易控制\")\n    lines.append(\n        f\"- 模拟盘快照：日期 `{payload.get('paper_execution', {}).get('date_tag', '-')}` | \"\n        f\"新鲜度=`{cn_status(paper_freshness.get('status'))}` | 说明=`{paper_freshness.get('summary', '-')}`\"\n    )\n    lines.append(f\"- 今日能否新开仓：`{yes_no(exs.get('allowed_to_open_new_positions'))}`\")\n    lines.append(f\"- 严格盘前检查：`{yes_no(exs.get('strict_precheck_passed'))}` | 模式=`{cn_status(exs.get('mode'))}` | 风险收缩=`{yes_no(exs.get('risk_off'))}` | 硬熔断=`{yes_no(exs.get('hard_stop'))}`\")\n    lines.append(f\"- 是否暂停新开仓：`{yes_no(exs.get('halt_new_buy'))}` | 原因：`{cn_text(exs.get('halt_reason'))}`\")\n    lines.append(f\"- 市场宽度：`{exs.get('market_breadth', '-')}` | 门控原因：`{cn_text(', '.join(exs.get('gate_reasons', [])) if exs.get('gate_reasons') else '无')}`\")\n    lines.append(f\"- 买卖条数：买入 `{exs.get('buy_count', '-')}` / 卖出 `{exs.get('sell_count', '-')}` | 买单拦截 `{exs.get('blocked_buy_halt', '-')}` | 卖单拦截 `{exs.get('blocked_sell_no_holding', '-')}`\")\n    lines.append(f\"- 预算：日新增 `{exs.get('daily_add_budget', '-')}` / 单买单 `{exs.get('per_buy_budget', '-')}` / 单标的上限 `{exs.get('max_single_amount', '-')}` / 当日买入名额 `{exs.get('buy_budget_slots', '-')}`\")\n    lines.append(f\"- 执行窗口：买入 `{exs.get('buy_window', '-')}` | `{exs.get('risk_only_after', '-')}` 后仅风控减仓\")\n    lines.append(f\"- 文件：precheck=`{exs.get('precheck_path') or '-'}` | orders=`{exs.get('orders_path') or '-'}` | brief=`{exs.get('brief_path') or '-'}`\")\n    lines.append(\"\")\n    lines.append(\"## 告警态势\")\n    lines.append(f\"- 数据源健康：`{cn_status(hp.get('status'))}` | 可信度评分：`{hp.get('confidence_score', '-')}/100` | 推荐模式：`{cn_text(hp.get('recommended_mode', '-'))}`\")\n    lines.append(\n        f\"- THS 本地行情：`{cn_status(ths.get('status'))}` | 可用=`{yes_no(ths.get('available'))}` | \"\n        f\"THS命中 `{ths.get('ok_count', 0)}` / 回退 `{ths.get('fallback_count', 0)}` / 失败 `{ths.get('failed_count', 0)}`\"\n    )\n    lines.append(f\"- THS 摘要：`{ths.get('summary', '-')}`\")\n    lines.append(f\"- 最大价差分歧：`{hp.get('max_price_diff_pct', '-')}%`\")\n    lines.append(f\"- 数据源触发项：{cn_text(', '.join(hp.get('breaches', [])) if hp.get('breaches') else '无')}\")\n    lines.append(f\"- 观察项：{cn_text(', '.join(hp.get('observations', [])) if hp.get('observations') else '无')}\")\n    lines.append(f\"- 自动降级动作：{cn_text(', '.join(hp.get('auto_actions', [])) if hp.get('auto_actions') else '无')}\")\n    lines.append(f\"- 临时会商监控：`{cn_status(ew.get('status'))}` | 建议会商：`{yes_no(ew.get('should_temporary_meet'))}`\")\n    lines.append(f\"- 临时会商触发类型：{cn_text(', '.join(ew.get('trigger_types', [])) if ew.get('trigger_types') else '无')}\")\n    lines.append(f\"- 当前建议参与角色：{', '.join(tm.get('participants', [])) if tm.get('participants') else '暂无'}\")\n    lines.append(f\"- 08:50 晨报状态：`{cn_status(mn.get('status'))}` | 最近成功：`{mn.get('last_success_at', '-')}` | 最近失败：`{cn_text(mn.get('last_failure_at', '-'))}`\")\n    if mn.get('status_reason'):\n        lines.append(f\"- 晨报状态说明：`{cn_text(mn.get('status_reason'))}`\")\n    if mn.get('log_file'):\n        lines.append(f\"- 晨报日志：`{mn.get('log_file')}`\")\n    lines.append(f\"- 稳定策略审计：`{cn_status(sa.get('overall_status'))}` | 日期：`{sa.get('date_tag', '-')}` | 是否稳健通过：`{yes_no(sa.get('robust_pass'))}`\")\n    lines.append(f\"- 稳定策略指标：年化 `{sa.get('annual_return_pct', '-')}`% / 回撤 `{sa.get('max_drawdown_pct', '-')}`% / 夏普 `{sa.get('sharpe', '-')}`\")\n    if sa.get('execution_scope'):\n        lines.append(f\"- 审计口径：`{sa.get('execution_scope')}` | 模拟盘运行=`{yes_no(sa.get('paper_runtime_ready'))}` | 实盘自动化=`{yes_no(sa.get('live_runtime_ready'))}`\")\n    lines.append(f\"- 回测队列快照：`{cn_status(bq.get('status'))}` | 运行中任务：`{bq.get('running_count', '-')}` | 已纳入稳定策略：`{yes_no(bq.get('stable_strategy_visible'))}`\")\n    if bq.get('error'):\n        lines.append(f\"- 回测队列错误摘要：`{bq.get('error')}`\")\n    lines.append(\n        f\"- LLM 运行：配置主模型=`{llm_summary.get('primary_configured_model', '-')}` | \"\n        f\"主脑最近成功=`{llm_summary.get('primary_runtime_provider', '-')}/{llm_summary.get('primary_runtime_model', '-')}` | \"\n        f\"编码代理最近成功=`{llm_summary.get('coding_runtime_provider', '-')}/{llm_summary.get('coding_runtime_model', '-')}`\"\n    )\n    lines.append(\n        f\"- 最近 {llm_summary.get('window_hours', 24)}h 回退：到 MiniMax `{llm_summary.get('fallback_to_minimax_count', 0)}` 次 | \"\n        f\"gmn 401 `{llm_summary.get('gmn_auth_401_count', 0)}` 次 | gmn 候选失败 `{llm_summary.get('gmn_candidate_failed_count', 0)}` 次\"\n    )\n    lines.append(\"\")\n\n    lines.append(\"## 会议面板\")\n    for item in payload.get('meeting_index', []):\n        lines.append(f\"- {item.get('meeting_label')} | 时间={item.get('generated_at')} | dashboard=`{item.get('dashboard_md')}` | chief_broadcast=`{item.get('chief_broadcast_md')}`\")\n    if not payload.get('meeting_index'):\n        lines.append(\"- 暂无会议面板\")\n    lines.append(\"\")\n\n    lines.append(\"## 值班面板\")\n    for item in payload.get('duty_index', []):\n        lines.append(f\"- {item.get('cycle')} | 时间={item.get('generated_at')} | 状态=`{item.get('status')}` | md=`{item.get('md')}`\")\n    if not payload.get('duty_index'):\n        lines.append(\"- 暂无值班面板\")\n    lines.append(\"\")\n\n    lines.append(\"## 关键导出入口\")\n    for key in [\n        'holdings_csv', 'trades_csv', 'trade_card_md', 'orchestrated_md', 'group_digest_md',\n        'data_source_health_path', 'event_watch_json', 'temporary_meeting_json'\n    ]:\n        value = payload.get('export_paths', {}).get(key)\n        if value:\n            lines.append(f\"- {key}: `{value}`\")\n    lines.append(\"\")\n    return \"\\n\".join(lines) + \"\\n\"\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser(description=\"Generate chief intraday control tower\")\n    ap.add_argument(\"--anchor-meeting\", choices=MEETING_TYPES, default=None)\n    args = ap.parse_args()\n\n    payload = build_payload(args.anchor_meeting)\n    md_path = REPORT_DIR / f\"investment_research_control_tower_{today_tag()}.md\"\n    json_path = REPORT_DIR / f\"investment_research_control_tower_{today_tag()}.json\"\n    atomic_write_text(md_path, render_markdown(payload), encoding=\"utf-8\")\n    atomic_write_json(json_path, payload, encoding=\"utf-8\", ensure_ascii=False, indent=2)\n    print(md_path)\n    print(json_path)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774532765323}}
{"type":"message","id":"e725e8c5","parentId":"81bcd435","timestamp":"2026-03-26T13:46:05.354Z","message":{"role":"toolResult","toolCallId":"call_dPVLfcLgZbR6ojqHxjLSNyuN|fc_0142f9a21f5351e00169c5389c5824819ba5d1db4b14868353","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom report_io import atomic_write_text\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\n\n\ndef today_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef latest_control_tower() -> Path:\n    import re\n    files = sorted(REPORT_DIR.glob(\"investment_research_control_tower_*.json\"), key=lambda p: p.stat().st_mtime, reverse=True)\n    if files:\n        return files[0]\n    raise FileNotFoundError(\"No control_tower file found\")\n\ndef control_tower_path() -> Path:\n    return latest_control_tower()\n\n\ndef fmt_list(items: list[str], limit: int = 5) -> str:\n    if not items:\n        return \"- 暂无\"\n    return \"\\n\".join(f\"- {item}\" for item in items[:limit])\n\n\ndef yes_no(value: Any) -> str:\n    if value is True:\n        return \"是\"\n    if value is False:\n        return \"否\"\n    if value is None or value == \"\":\n        return \"-\"\n    return str(value)\n\n\ndef cn_status(value: Any) -> str:\n    mapping = {\n        \"OK\": \"正常\",\n        \"ERROR\": \"错误\",\n        \"PASS\": \"通过\",\n        \"ALERT\": \"告警\",\n        \"healthy\": \"健康\",\n        \"watch_guarded\": \"警戒观察\",\n        \"offhours_guarded\": \"非交易时段观察\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"data_source_health_watch\": \"数据源健康监控触发\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"halt\": \"暂停\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"observe_defensive\": \"防守观察\",\n        \"PENDING_TODAY\": \"待今日晨报\",\n        \"STALE\": \"状态过期\",\n        \"PUSH_FAILED\": \"推送失败\",\n        \"GENERATION_FAILED\": \"生成失败\",\n        \"DEADLINE_MISSED\": \"超时未完成\",\n        \"SKIP_NON_TRADING_DAY\": \"非交易日跳过\",\n        \"MISSING\": \"缺失\",\n        \"ok\": \"正常\",\n        \"fallback\": \"已回退\",\n        \"failed\": \"部分失败\",\n        \"unavailable\": \"不可用\",\n        \"unknown\": \"未知\",\n        \"fresh\": \"今日已刷新\",\n        \"pending_today_refresh\": \"待今日刷新\",\n        \"stale\": \"已过期\",\n        \"mixed\": \"日期混杂\",\n        \"missing\": \"缺失\",\n    }\n    if value is None or value == \"\":\n        return \"-\"\n    return mapping.get(str(value), str(value))\n\n\ndef cn_text(text: Any) -> str:\n    if text is None or text == \"\":\n        return \"-\"\n    s = str(text)\n    replacements = {\n        \"market_breadth\": \"市场宽度\",\n        \"source_price_divergence\": \"数据源价差分歧\",\n        \"account_sync_age\": \"账户同步时延\",\n        \"observe_defensive\": \"防守观察\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"watch_guarded\": \"警戒观察\",\n        \"healthy\": \"健康\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"normal模式\": \"正常模式\",\n        \"public_source_divergence>\": \"公开网页源存在价差分歧 > \",\n        \"BUY\": \"买入\",\n        \"SELL\": \"卖出\",\n    }\n    for old, new in replacements.items():\n        s = s.replace(old, new)\n    return s\n\n\ndef render_markdown(payload: dict[str, Any]) -> str:\n    latest_status = payload.get(\"latest_status\", {})\n    hp = payload.get(\"health_probe\", {})\n    ths = hp.get(\"ths_market\", {})\n    ew = payload.get(\"event_watch\", {})\n    tm = payload.get(\"temporary_meeting\", {})\n    mn = payload.get(\"morning_news\", {})\n    sa = payload.get(\"strategy_audit\", {})\n    bq = payload.get(\"backtest_queue\", {})\n    exs = payload.get(\"execution_status\", {})\n    paper_freshness = (payload.get(\"paper_execution\") or {}).get(\"freshness\", {})\n\n    lines: list[str] = []\n    lines.append(\"## 🧭 来福投研会｜总控台播报\")\n    lines.append(\"\")\n    lines.append(\"| 项目 | 当前值 |\")\n    lines.append(\"|---|---|\")\n    lines.append(f\"| 当前主视图 | {payload.get('latest_meeting_label') or payload.get('latest_meeting_type') or '暂无'} |\")\n    lines.append(f\"| 审计状态 | {cn_status(latest_status.get('audit_status'))} |\")\n    lines.append(f\"| 盘前强检 | {cn_status(latest_status.get('precheck_status'))} |\")\n    lines.append(f\"| 风险收缩 | {yes_no(latest_status.get('risk_off'))} |\")\n    lines.append(f\"| 年化/回撤/夏普 | {latest_status.get('annual_return_pct', '-')} / {latest_status.get('max_drawdown_pct', '-')} / {latest_status.get('sharpe', '-')} |\")\n    lines.append(\"\")\n\n    lines.append(\"**当前总览**\")\n    lines.append(f\"- 观察池：{', '.join(payload.get('watchlist', [])[:5]) if payload.get('watchlist') else payload.get('watchlist_reason') or '暂无'}\")\n    lines.append(f\"- 持仓预览：{', '.join(payload.get('holdings_preview', [])[:5]) if payload.get('holdings_preview') else '暂无'}\")\n    lines.append(f\"- 成交预览：{', '.join(payload.get('trades_preview', [])[:5]) if payload.get('trades_preview') else '暂无'}\")\n    lines.append(f\"- 卖出/减仓复核：{', '.join(payload.get('sell_review_list', [])[:5]) if payload.get('sell_review_list') else payload.get('sell_review_reason') or '暂无'}\")\n    lines.append(\"\")\n\n    lines.append(\"**今日交易控制**\")\n    lines.append(\n        f\"- 模拟盘快照：日期=`{payload.get('paper_execution', {}).get('date_tag', '-')}` | \"\n        f\"新鲜度=`{cn_status(paper_freshness.get('status'))}` | 说明=`{paper_freshness.get('summary', '-')}`\"\n    )\n    lines.append(f\"- 今日能否新开仓：`{yes_no(exs.get('allowed_to_open_new_positions'))}`\")\n    lines.append(f\"- 严格盘前检查：`{yes_no(exs.get('strict_precheck_passed'))}` | 模式=`{cn_status(exs.get('mode'))}` | 风险收缩=`{yes_no(exs.get('risk_off'))}` | 硬熔断=`{yes_no(exs.get('hard_stop'))}`\")\n    lines.append(f\"- 是否暂停新开仓：`{yes_no(exs.get('halt_new_buy'))}` | 原因：`{cn_text(exs.get('halt_reason'))}`\")\n    lines.append(f\"- 市场宽度：`{exs.get('market_breadth', '-')}` | 门控原因：`{cn_text(', '.join(exs.get('gate_reasons', [])) if exs.get('gate_reasons') else '无')}`\")\n    lines.append(f\"- 买卖条数：买入 `{exs.get('buy_count', '-')}` / 卖出 `{exs.get('sell_count', '-')}` | 买单拦截 `{exs.get('blocked_buy_halt', '-')}` | 卖单拦截 `{exs.get('blocked_sell_no_holding', '-')}`\")\n    lines.append(f\"- 预算：日新增 `{exs.get('daily_add_budget', '-')}` / 单买单 `{exs.get('per_buy_budget', '-')}` / 单标的上限 `{exs.get('max_single_amount', '-')}` / 买入名额 `{exs.get('buy_budget_slots', '-')}`\")\n    lines.append(f\"- 执行窗口：买入 `{exs.get('buy_window', '-')}` | `{exs.get('risk_only_after', '-')}` 后仅风控减仓\")\n    lines.append(f\"- 文件：summary=`{exs.get('precheck_path') or '-'}` | orders=`{exs.get('orders_path') or '-'}` | brief=`{exs.get('brief_path') or '-'}`\")\n    lines.append(\"\")\n\n    lines.append(\"**告警态势**\")\n    lines.append(f\"- 数据源健康：`{cn_status(hp.get('status'))}` | 可信度评分：`{hp.get('confidence_score', '-')}/100` | 推荐模式：`{cn_text(hp.get('recommended_mode'))}`\")\n    lines.append(\n        f\"- THS 本地行情：`{cn_status(ths.get('status'))}` | 可用=`{yes_no(ths.get('available'))}` | \"\n        f\"THS命中 `{ths.get('ok_count', 0)}` / 回退 `{ths.get('fallback_count', 0)}` / 失败 `{ths.get('failed_count', 0)}`\"\n    )\n    lines.append(f\"- THS 摘要：`{ths.get('summary', '-')}`\")\n    lines.append(f\"- 最大价差分歧：`{hp.get('max_price_diff_pct', '-')}%`\")\n    lines.append(f\"- 数据源触发项：{cn_text(', '.join(hp.get('breaches', [])) if hp.get('breaches') else '无')}\")\n    lines.append(f\"- 观察项：{cn_text(', '.join(hp.get('observations', [])) if hp.get('observations') else '无')}\")\n    lines.append(f\"- 自动降级动作：{cn_text(', '.join(hp.get('auto_actions', [])) if hp.get('auto_actions') else '无')}\")\n    lines.append(f\"- 临时会商监控：`{cn_status(ew.get('status'))}` | 建议会商：`{yes_no(ew.get('should_temporary_meet'))}`\")\n    lines.append(f\"- 临时会商触发类型：{cn_text(', '.join(ew.get('trigger_types', [])) if ew.get('trigger_types') else '无')}\")\n    lines.append(f\"- 当前建议参与角色：{', '.join(tm.get('participants', [])[:6]) if tm.get('participants') else '暂无'}\")\n    lines.append(f\"- 08:50 晨报状态：`{cn_status(mn.get('status'))}` | 最近成功：`{mn.get('last_success_at', '-')}`\")\n    if mn.get('status_reason'):\n        lines.append(f\"- 晨报状态说明：`{cn_text(mn.get('status_reason'))}`\")\n    if mn.get('log_file'):\n        lines.append(f\"- 晨报日志：`{mn.get('log_file')}`\")\n    lines.append(f\"- 稳定策略审计：`{cn_status(sa.get('overall_status'))}` | `{sa.get('date_tag', '-')}` | 是否稳健通过=`{yes_no(sa.get('robust_pass'))}`\")\n    lines.append(f\"- 稳定策略指标：年化 `{sa.get('annual_return_pct', '-')}`% / 回撤 `{sa.get('max_drawdown_pct', '-')}`% / 夏普 `{sa.get('sharpe', '-')}`\")\n    lines.append(f\"- 回测队列快照：`{cn_status(bq.get('status'))}` | 运行中任务=`{bq.get('running_count', '-')}` | 已纳入稳定策略=`{yes_no(bq.get('stable_strategy_visible'))}`\")\n    lines.append(\"\")\n\n    meeting_index = payload.get('meeting_index', [])\n    if meeting_index:\n        lines.append(\"**会议入口**\")\n        for item in meeting_index[:4]:\n            lines.append(f\"- {item.get('meeting_label')}：`{item.get('dashboard_md')}`\")\n        lines.append(\"\")\n\n    duty_index = payload.get('duty_index', [])\n    if duty_index:\n        lines.append(\"**值班入口**\")\n        for item in duty_index[:4]:\n            lines.append(f\"- {item.get('cycle')}：`{item.get('md')}` | 状态=`{cn_status(item.get('status'))}`\")\n        lines.append(\"\")\n\n    exports = payload.get('export_paths', {})\n    export_labels = {\n        'holdings_csv': '持仓明细导出',\n        'trades_csv': '成交明细导出',\n        'trade_card_md': '交易建议卡',\n        'orchestrated_md': '总会纪要',\n        'group_digest_md': '群聊摘要',\n        'data_source_health_path': '数据源健康报告',\n        'event_watch_json': '事件监控记录',\n        'temporary_meeting_json': '临时会商记录',\n    }\n    lines.append(\"**关键导出入口**\")\n    for key in [\n        'holdings_csv', 'trades_csv', 'trade_card_md', 'orchestrated_md', 'group_digest_md',\n        'data_source_health_path', 'event_watch_json', 'temporary_meeting_json'\n    ]:\n        value = exports.get(key)\n        if value:\n            lines.append(f\"- {export_labels.get(key, key)}：`{value}`\")\n    lines.append(\"\")\n\n    if ew.get('should_temporary_meet'):\n        lines.append(\"> 结论：当前总控台显示已进入临时会商建议态，优先由首席研究员组织风控官、交易员和相关研究角色收敛异常。\")\n    elif hp.get('status') in {'watch_guarded', 'degraded'}:\n        lines.append(\"> 结论：当前数据源处于警戒/降级边缘，继续保持防守观察，不放松执行纪律。\")\n    else:\n        lines.append(\"> 结论：当前总控台未见额外异常，可按既定会议 + 值班节奏运行。\")\n    if not latest_status.get('trading_time'):\n        lines.append(\"> 当前非交易时段/非交易日，不提供可执行买价，只保留方向、预算和触发条件。\")\n    lines.append(\"\")\n    return \"\\n\".join(lines) + \"\\n\"\n\n\ndef main() -> None:\n    _ = argparse.ArgumentParser(description=\"Generate chief control tower broadcast markdown\").parse_args()\n    payload = load_json(control_tower_path())\n    out = REPORT_DIR / f\"investment_research_control_tower_broadcast_{today_tag()}.md\"\n    atomic_write_text(out, render_markdown(payload), encoding=\"utf-8\")\n    print(out)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774532765334}}
{"type":"message","id":"69cc11c3","parentId":"e725e8c5","timestamp":"2026-03-26T13:46:05.370Z","message":{"role":"toolResult","toolCallId":"call_JZPudjhMVtH8gru41g2M8JZ8|fc_0142f9a21f5351e00169c5389c582c819bb1f1917d04992bdc","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom report_io import atomic_write_json, atomic_write_text\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\n\n\ndef today_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef control_tower_path() -> Path:\n    path = REPORT_DIR / f\"investment_research_control_tower_{today_tag()}.json\"\n    if not path.exists():\n        raise FileNotFoundError(str(path))\n    return path\n\n\ndef truncate_list(items: list[str], limit: int = 5) -> str:\n    if not items:\n        return \"暂无\"\n    return \"\\n\".join(f\"- {item}\" for item in items[:limit])\n\n\ndef yes_no(value: Any) -> str:\n    if value is True:\n        return \"是\"\n    if value is False:\n        return \"否\"\n    if value is None or value == \"\":\n        return \"-\"\n    return str(value)\n\n\ndef cn_status(value: Any) -> str:\n    mapping = {\n        \"OK\": \"正常\",\n        \"ERROR\": \"错误\",\n        \"PASS\": \"通过\",\n        \"ALERT\": \"告警\",\n        \"healthy\": \"健康\",\n        \"watch_guarded\": \"警戒观察\",\n        \"offhours_guarded\": \"非交易时段观察\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"halt\": \"暂停\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"observe_defensive\": \"防守观察\",\n        \"PENDING_TODAY\": \"待今日晨报\",\n        \"STALE\": \"状态过期\",\n        \"PUSH_FAILED\": \"推送失败\",\n        \"GENERATION_FAILED\": \"生成失败\",\n        \"DEADLINE_MISSED\": \"超时未完成\",\n        \"SKIP_NON_TRADING_DAY\": \"非交易日跳过\",\n        \"MISSING\": \"缺失\",\n        \"ok\": \"正常\",\n        \"fallback\": \"已回退\",\n        \"failed\": \"部分失败\",\n        \"unavailable\": \"不可用\",\n        \"unknown\": \"未知\",\n        \"fresh\": \"今日已刷新\",\n        \"pending_today_refresh\": \"待今日刷新\",\n        \"stale\": \"已过期\",\n        \"mixed\": \"日期混杂\",\n        \"missing\": \"缺失\",\n    }\n    if value is None or value == \"\":\n        return \"-\"\n    return mapping.get(str(value), str(value))\n\n\ndef cn_text(text: Any) -> str:\n    if text is None or text == \"\":\n        return \"-\"\n    s = str(text)\n    replacements = {\n        \"market_breadth\": \"市场宽度\",\n        \"source_price_divergence\": \"数据源价差分歧\",\n        \"account_sync_age\": \"账户同步时延\",\n        \"observe_defensive\": \"防守观察\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"watch_guarded\": \"警戒观察\",\n        \"healthy\": \"健康\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"normal模式\": \"正常模式\",\n        \"public_source_divergence>\": \"公开网页源存在价差分歧 > \",\n        \"BUY\": \"买入\",\n        \"SELL\": \"卖出\",\n    }\n    for old, new in replacements.items():\n        s = s.replace(old, new)\n    return s\n\n\ndef build_card(payload: dict[str, Any]) -> dict[str, Any]:\n    latest_status = payload.get(\"latest_status\", {})\n    watchlist = payload.get(\"watchlist\", [])[:5]\n    watchlist_reason = payload.get(\"watchlist_reason\") or \"暂无\"\n    holdings = payload.get(\"holdings_preview\", [])[:5]\n    trades = payload.get(\"trades_preview\", [])[:5]\n    sell_review = payload.get(\"sell_review_list\", [])[:5]\n    sell_review_reason = payload.get(\"sell_review_reason\") or \"暂无\"\n    hp = payload.get(\"health_probe\", {})\n    ths = hp.get(\"ths_market\", {})\n    ew = payload.get(\"event_watch\", {})\n    tm = payload.get(\"temporary_meeting\", {})\n    mn = payload.get(\"morning_news\", {})\n    sa = payload.get(\"strategy_audit\", {})\n    bq = payload.get(\"backtest_queue\", {})\n    exs = payload.get(\"execution_status\", {})\n    llm = payload.get(\"llm_runtime\", {})\n    llm_summary = llm.get(\"summary\", {})\n    paper_freshness = (payload.get(\"paper_execution\") or {}).get(\"freshness\", {})\n\n    risk_text = \"偏防守\" if latest_status.get(\"risk_off\") else \"条件化推进\"\n    hp_status = hp.get(\"status\", \"-\")\n    hp_color = \"green\" if hp_status == \"healthy\" else \"orange\" if hp_status in {\"watch_guarded\", \"offhours_guarded\"} else \"red\" if hp_status == \"degraded\" else \"grey\"\n    ew_status = ew.get(\"status\", \"-\")\n    should_meet = ew.get(\"should_temporary_meet\", False)\n    morning_news_reason = f\"- 晨报状态说明：{cn_text(mn.get('status_reason'))}\\n\" if mn.get(\"status_reason\") else \"\"\n\n    elements: list[dict[str, Any]] = [\n        {\n            \"tag\": \"div\",\n            \"text\": {\n                \"tag\": \"lark_md\",\n                \"content\": (\n                    f\"**当前主视图**：`{payload.get('latest_meeting_label') or payload.get('latest_meeting_type') or '-'}`\\n\"\n                    f\"**审计状态**：`{latest_status.get('audit_status', '-')}`\\n\"\n                    f\"**盘前强检**：`{latest_status.get('precheck_status', '-')}`\\n\"\n                    f\"**风险状态**：`{risk_text}`\\n\"\n                    f\"**年化/回撤/夏普**：`{latest_status.get('annual_return_pct', '-')}` / `{latest_status.get('max_drawdown_pct', '-')}` / `{latest_status.get('sharpe', '-')}`\"\n                ),\n            },\n        },\n        {\"tag\": \"hr\"},\n        {\n            \"tag\": \"div\",\n            \"text\": {\"tag\": \"lark_md\", \"content\": f\"**观察池**\\n{truncate_list(watchlist) if watchlist else f'- {watchlist_reason}'}\"},\n        },\n        {\n            \"tag\": \"div\",\n            \"text\": {\"tag\": \"lark_md\", \"content\": f\"**持仓预览**\\n{truncate_list(holdings)}\"},\n        },\n        {\n            \"tag\": \"div\",\n            \"text\": {\"tag\": \"lark_md\", \"content\": f\"**近期成交**\\n{truncate_list(trades)}\"},\n        },\n        {\n            \"tag\": \"div\",\n            \"text\": {\"tag\": \"lark_md\", \"content\": f\"**卖出/减仓复核**\\n{truncate_list(sell_review) if sell_review else f'- {sell_review_reason}'}\"},\n        },\n        {\"tag\": \"hr\"},\n        {\n            \"tag\": \"div\",\n            \"text\": {\n                \"tag\": \"lark_md\",\n                \"content\": (\n                    f\"**模拟盘快照**\\n\"\n                    f\"- 日期：`{payload.get('paper_execution', {}).get('date_tag', '-')}` | 新鲜度：`{cn_status(paper_freshness.get('status'))}`\\n\"\n                    f\"- 说明：`{paper_freshness.get('summary', '-')}`\"\n                ),\n            },\n        },\n        {\"tag\": \"hr\"},\n        {\n            \"tag\": \"div\",\n            \"text\": {\n                \"tag\": \"lark_md\",\n                \"content\": (\n                    f\"**告警态势**\\n\"\n                    f\"- 数据源健康：`{cn_status(hp_status)}` | 可信度评分：`{hp.get('confidence_score', '-')}/100` | 推荐模式：`{cn_text(hp.get('recommended_mode', '-'))}`\\n\"\n                    f\"- THS 本地行情：`{cn_status(ths.get('status'))}` | 可用=`{yes_no(ths.get('available'))}` | THS命中 `{ths.get('ok_count', 0)}` / 回退 `{ths.get('fallback_count', 0)}` / 失败 `{ths.get('failed_count', 0)}`\\n\"\n                    f\"- THS 摘要：`{ths.get('summary', '-')}`\\n\"\n                    f\"- 最大价差：`{hp.get('max_price_diff_pct', '-')}%`\\n\"\n                    f\"- 数据源触发项：{cn_text(', '.join(hp.get('breaches', [])) if hp.get('breaches') else '无')}\\n\"\n                    f\"- 观察项：{cn_text(', '.join(hp.get('observations', [])) if hp.get('observations') else '无')}\\n\"\n                    f\"- 自动降级动作：{cn_text(', '.join(hp.get('auto_actions', [])) if hp.get('auto_actions') else '无')}\\n\"\n                    f\"- 临时会商监控：`{cn_status(ew_status)}` | 建议会商：`{yes_no(should_meet)}`\\n\"\n                    f\"- 触发类型：{cn_text(', '.join(ew.get('trigger_types', [])) if ew.get('trigger_types') else '无')}\\n\"\n                    f\"- 建议参与角色：{', '.join(tm.get('participants', [])) if tm.get('participants') else '暂无'}\\n\"\n                    f\"- 08:50晨报：`{cn_status(mn.get('status'))}` | 最近成功：`{mn.get('last_success_at', '-')}`\\n\"\n                    f\"{morning_news_reason}\"\n                    f\"- 稳定策略：`{cn_status(sa.get('overall_status'))}` | 年化/回撤/夏普：`{sa.get('annual_return_pct', '-')}` / `{sa.get('max_drawdown_pct', '-')}` / `{sa.get('sharpe', '-')}`\\n\"\n                    f\"- 回测队列：`{cn_status(bq.get('status'))}` | 运行中：`{bq.get('running_count', '-')}` | 已纳入稳定策略：`{yes_no(bq.get('stable_strategy_visible'))}`\\n\"\n                    f\"- LLM 实况：配置主模型=`{llm_summary.get('primary_configured_model', '-')}` | \"\n                    f\"主脑最近成功=`{llm_summary.get('primary_runtime_provider', '-')}/{llm_summary.get('primary_runtime_model', '-')}` | \"\n                    f\"编码代理最近成功=`{llm_summary.get('coding_runtime_provider', '-')}/{llm_summary.get('coding_runtime_model', '-')}`\\n\"\n                    f\"- 最近 {llm_summary.get('window_hours', 24)}h 回退：MiniMax `{llm_summary.get('fallback_to_minimax_count', 0)}` 次 | \"\n                    f\"gmn 401 `{llm_summary.get('gmn_auth_401_count', 0)}` 次\"\n                ),\n            },\n        },\n        {\"tag\": \"hr\"},\n        {\n            \"tag\": \"div\",\n            \"text\": {\n                \"tag\": \"lark_md\",\n                \"content\": \"**关键导出入口**\\n\"\n                f\"- 持仓明细：`{payload.get('export_paths', {}).get('holdings_csv') or exs.get('holdings_path') or '暂无'}`\\n\"\n                f\"- 成交明细：`{payload.get('export_paths', {}).get('trades_csv') or '暂无'}`\\n\"\n                f\"- 执行总览：`{exs.get('precheck_path') or '暂无'}`\\n\"\n                f\"- 三盘订单汇总：`{exs.get('orders_path') or '暂无'}`\\n\"\n                f\"- 执行简报：`{exs.get('brief_path') or '暂无'}`\\n\"\n                f\"- 交易日志：`{exs.get('journal_path') or '暂无'}`\\n\"\n                f\"- 数据源健康：`{hp.get('path') or '暂无'}`\\n\"\n                f\"- 晨报状态：`{payload.get('export_paths', {}).get('morning_news_state_json') or '暂无'}`\\n\"\n                f\"- 稳定策略审计：`{payload.get('export_paths', {}).get('strategy_audit_json') or '暂无'}`\\n\"\n                f\"- 回测队列快照：`{payload.get('export_paths', {}).get('backtest_queue_md') or '暂无'}`\"\n            },\n        },\n    ]\n\n    note_text = \"\"\n    if should_meet:\n        note_text = \"首席研究员结论：当前总控台显示已进入临时会商建议态，优先由首席研究员组织风控官、交易员和相关研究角色收敛异常。\"\n    elif hp_status in {\"watch_guarded\", \"degraded\"}:\n        note_text = \"首席研究员结论：当前数据源处于警戒/降级边缘，继续保持防守观察，不放松执行纪律。\"\n    else:\n        note_text = \"首席研究员结论：当前总控台未见额外异常，可按既定会议 + 值班节奏运行。\"\n    if not latest_status.get(\"trading_time\"):\n        note_text += \" 当前非交易时段/非交易日，不提供可执行买价。\"\n\n    elements.append({\n        \"tag\": \"note\",\n        \"elements\": [{\"tag\": \"plain_text\", \"content\": note_text}],\n    })\n\n    # 添加用户交互指引（仅在建议态时）\n    if latest_status.get(\"trading_time\") and not latest_status.get(\"risk_off\"):\n        elements.append({\n            \"tag\": \"div\",\n            \"text\": {\n                \"tag\": \"lark_md\",\n                \"content\": \"**操作指引**：如需确认执行，请回复「确认 + 股票代码 + 买入/卖出」，如「确认 301018.SZ 买入」；取消则请回复「取消」。\"\n            },\n        })\n\n    return {\n        \"msg_type\": \"interactive\",\n        \"card\": {\n            \"config\": {\"wide_screen_mode\": True, \"enable_forward\": True},\n            \"header\": {\n                \"title\": {\"tag\": \"plain_text\", \"content\": \"🧭 来福投研会｜总控台\"},\n                \"template\": \"orange\" if should_meet or hp_status in {\"watch_guarded\", \"degraded\"} else \"blue\",\n            },\n            \"elements\": elements,\n        },\n    }\n\n\ndef render_preview(payload: dict[str, Any], card_payload: dict[str, Any]) -> str:\n    lines = [\n        f\"# 来福投研会 - 总控台卡片预览\",\n        \"\",\n        f\"- 生成时间：{payload.get('generated_at')}\",\n        f\"- 当前主视图：`{payload.get('latest_meeting_label') or payload.get('latest_meeting_type') or '-'}`\",\n        f\"- 卡片 JSON：`investment_research_control_tower_card_{today_tag()}.json`\",\n        \"\",\n        \"## 卡片标题\",\n        f\"- {card_payload['card']['header']['title']['content']}\",\n        \"\",\n        \"## 说明\",\n        \"- 该文件为飞书交互卡片载荷，可作为总控台卡片投递模板。\",\n        \"- 当前未直接自动发卡，先固化成 bundle 产物，后续再接主动投递。\",\n        \"\",\n    ]\n    return \"\\n\".join(lines) + \"\\n\"\n\n\ndef main() -> None:\n    _ = argparse.ArgumentParser(description=\"Generate Feishu-card-ready control tower payload\").parse_args()\n    payload = load_json(control_tower_path())\n    card = build_card(payload)\n    json_path = REPORT_DIR / f\"investment_research_control_tower_card_{today_tag()}.json\"\n    md_path = REPORT_DIR / f\"investment_research_control_tower_card_{today_tag()}.md\"\n    atomic_write_json(json_path, card, encoding=\"utf-8\", ensure_ascii=False, indent=2)\n    atomic_write_text(md_path, render_preview(payload, card), encoding=\"utf-8\")\n    print(md_path)\n    print(json_path)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774532765354}}
{"type":"message","id":"dd5e999f","parentId":"69cc11c3","timestamp":"2026-03-26T13:46:05.384Z","message":{"role":"toolResult","toolCallId":"call_4u2T0i78q48Bb7YKr610OMLA|fc_0142f9a21f5351e00169c5389c5834819bb0d937da3494fb29","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom report_io import atomic_write_json, atomic_write_text\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\n\nMEETING_TO_EMOJI = {\n    \"morning\": \"🌅\",\n    \"midday\": \"☀️\",\n    \"close\": \"📘\",\n    \"night\": \"🌙\",\n}\n\n\ndef today_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef required_dashboard(meeting_type: str) -> Path:\n    path = REPORT_DIR / f\"investment_research_chief_dashboard_{meeting_type}_{today_tag()}.json\"\n    if not path.exists():\n        raise FileNotFoundError(str(path))\n    return path\n\n\ndef truncate_list(items: list[str], limit: int = 5) -> str:\n    if not items:\n        return \"暂无\"\n    return \"\\n\".join(f\"- {item}\" for item in items[:limit])\n\n\ndef cn_status(value: Any) -> str:\n    mapping = {\n        \"healthy\": \"健康\",\n        \"offhours_guarded\": \"非交易时段观察\",\n        \"watch_guarded\": \"警戒观察\",\n        \"degraded\": \"降级\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"observe_defensive\": \"防守观察\",\n        \"halt\": \"暂停\",\n        \"ok\": \"正常\",\n        \"fallback\": \"已回退\",\n        \"failed\": \"部分失败\",\n        \"unavailable\": \"不可用\",\n        \"unknown\": \"未知\",\n        \"fresh\": \"今日已刷新\",\n        \"pending_today_refresh\": \"待今日刷新\",\n        \"stale\": \"已过期\",\n        \"mixed\": \"日期混杂\",\n        \"missing\": \"缺失\",\n    }\n    if value is None or value == \"\":\n        return \"-\"\n    return mapping.get(str(value), str(value))\n\n\ndef build_card(dashboard: dict[str, Any]) -> dict[str, Any]:\n    status = dashboard.get(\"status\", {})\n    watchlist = [item.get(\"display\") or item.get(\"ticker\", \"\") for item in dashboard.get(\"watchlist\", [])]\n    watchlist_reason = str(dashboard.get(\"watchlist_reason\") or \"暂无\")\n    sell_review = dashboard.get(\"sell_review_list\", [])\n    sell_review_reason = str(dashboard.get(\"sell_review_reason\") or \"暂无\")\n    role_highlights = dashboard.get(\"role_highlights\", [])[:4]\n    exports = dashboard.get(\"export_paths\", {})\n    hp = dashboard.get(\"health_probe\", {})\n    ths = hp.get(\"ths_market\", {})\n    paper_freshness = dashboard.get(\"paper_execution_freshness\", {})\n    meeting_type = dashboard.get(\"meeting_type\", \"morning\")\n    emoji = MEETING_TO_EMOJI.get(meeting_type, \"📊\")\n    risk_text = \"偏防守\" if status.get(\"risk_off\") else \"条件化推进\"\n    conclusion = \"当前仍以偏防守框架运行，优先观察。\" if status.get(\"risk_off\") else \"当前可条件化推进，但仍需风控门控与用户确认。\"\n    if not status.get(\"trading_time\"):\n        conclusion += \" 当前非交易时段/非交易日，不提供可执行买价。\"\n\n    elements: list[dict[str, Any]] = [\n        {\n            \"tag\": \"div\",\n            \"text\": {\n                \"tag\": \"lark_md\",\n                \"content\": (\n                    f\"**审计状态**：`{status.get('audit_status', 'unknown')}`\\n\"\n                    f\"**盘前强检**：`{status.get('precheck_status', 'unknown')}`\\n\"\n                    f\"**风险状态**：`{risk_text}`\\n\"\n                    f\"**年化/回撤/夏普**：`{status.get('annual_return_pct', '-')}` / `{status.get('max_drawdown_pct', '-')}` / `{status.get('sharpe', '-')}`\"\n                ),\n            },\n        },\n        {\"tag\": \"hr\"},\n        {\n            \"tag\": \"div\",\n            \"text\": {\"tag\": \"lark_md\", \"content\": f\"**观察池**\\n{truncate_list(watchlist) if watchlist else f'- {watchlist_reason}'}\"},\n        },\n        {\n            \"tag\": \"div\",\n            \"text\": {\"tag\": \"lark_md\", \"content\": f\"**卖出/减仓复核**\\n{truncate_list(sell_review) if sell_review else f'- {sell_review_reason}'}\"},\n        },\n        {\n            \"tag\": \"div\",\n            \"text\": {\"tag\": \"lark_md\", \"content\": f\"**持仓预览**\\n{truncate_list(dashboard.get('holdings_preview', []))}\"},\n        },\n        {\n            \"tag\": \"div\",\n            \"text\": {\"tag\": \"lark_md\", \"content\": f\"**近期成交预览**\\n{truncate_list(dashboard.get('trades_preview', []))}\"},\n        },\n        {\"tag\": \"hr\"},\n        {\n            \"tag\": \"div\",\n            \"text\": {\n                \"tag\": \"lark_md\",\n                \"content\": \"**角色摘要**\\n\" + (\"\\n\".join(\n                    f\"- {item.get('role_title', item.get('role_id', '角色'))}：{item.get('highlight', '暂无')}\" for item in role_highlights\n                ) if role_highlights else \"- 暂无角色摘要\"),\n            },\n        },\n        {\"tag\": \"hr\"},\n        {\n            \"tag\": \"div\",\n            \"text\": {\n                \"tag\": \"lark_md\",\n                \"content\": (\n                    f\"**模拟盘快照**\\n\"\n                    f\"- 日期：`{paper_freshness.get('source_date_tag', '-')}` | 新鲜度：`{cn_status(paper_freshness.get('status'))}`\\n\"\n                    f\"- 说明：`{paper_freshness.get('summary', '-')}`\"\n                ),\n            },\n        },\n        {\"tag\": \"hr\"},\n        {\n            \"tag\": \"div\",\n            \"text\": {\n                \"tag\": \"lark_md\",\n                \"content\": (\n                    f\"**数据源健康**\\n\"\n                    f\"- 健康状态：`{cn_status(hp.get('status'))}` | 推荐模式：`{cn_status(hp.get('recommended_mode'))}` | 可信度：`{hp.get('confidence_score', '-')}/100`\\n\"\n                    f\"- THS 状态：`{cn_status(ths.get('status'))}` | 可用=`{ths.get('available', '-')}`\\n\"\n                    f\"- THS 命中/回退/失败：`{ths.get('ok_count', 0)}` / `{ths.get('fallback_count', 0)}` / `{ths.get('failed_count', 0)}`\\n\"\n                    f\"- THS 摘要：`{ths.get('summary', '-')}`\"\n                ),\n            },\n        },\n        {\"tag\": \"hr\"},\n        {\n            \"tag\": \"div\",\n            \"text\": {\n                \"tag\": \"lark_md\",\n                \"content\": (\n                    f\"**导出入口**\\n\"\n                    f\"- 持仓明细：`{exports.get('holdings_csv') or '暂无'}`\\n\"\n                    f\"- 成交明细：`{exports.get('trades_csv') or '暂无'}`\\n\"\n                    f\"- 交易建议卡：`{exports.get('trade_card_md') or '暂无'}`\"\n                ),\n            },\n        },\n        {\n            \"tag\": \"note\",\n            \"elements\": [\n                {\"tag\": \"plain_text\", \"content\": f\"首席研究员结论：{conclusion}\"}\n            ],\n        },\n    ]\n\n    return {\n        \"msg_type\": \"interactive\",\n        \"card\": {\n            \"config\": {\"wide_screen_mode\": True, \"enable_forward\": True},\n            \"header\": {\n                \"title\": {\"tag\": \"plain_text\", \"content\": f\"{emoji} 来福投研会｜{dashboard.get('meeting_label', meeting_type)}｜首席总览\"},\n                \"template\": \"blue\" if not status.get(\"risk_off\") else \"orange\",\n            },\n            \"elements\": elements,\n        },\n    }\n\n\ndef render_preview(dashboard: dict[str, Any], card_payload: dict[str, Any]) -> str:\n    exports = dashboard.get(\"export_paths\", {})\n    lines = [\n        f\"# 来福投研会 - 飞书卡片预览（{dashboard.get('meeting_label', dashboard.get('meeting_type'))}）\",\n        \"\",\n        f\"- 生成时间：{dashboard.get('generated_at')}\",\n        f\"- 卡片 JSON：`investment_research_chief_card_{dashboard.get('meeting_type')}_{today_tag()}.json`\",\n        f\"- 持仓明细：`{exports.get('holdings_csv') or '暂无'}`\",\n        f\"- 成交明细：`{exports.get('trades_csv') or '暂无'}`\",\n        \"\",\n        \"## 卡片标题\",\n        f\"- {card_payload['card']['header']['title']['content']}\",\n        \"\",\n        \"## 说明\",\n        \"- 该文件为飞书交互卡片载荷，可作为后续 DM/群聊卡片投递模板。\",\n        \"- 当前未直接自动发卡，先固化成 bundle 产物，后续再接主动投递。\",\n        \"\",\n    ]\n    return \"\\n\".join(lines) + \"\\n\"\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser(description=\"Generate Feishu-card-ready chief dashboard payload\")\n    ap.add_argument(\"--meeting-type\", choices=[\"morning\", \"midday\", \"close\", \"night\"], default=\"morning\")\n    args = ap.parse_args()\n\n    dashboard = load_json(required_dashboard(args.meeting_type))\n    payload = build_card(dashboard)\n    json_path = REPORT_DIR / f\"investment_research_chief_card_{args.meeting_type}_{today_tag()}.json\"\n    md_path = REPORT_DIR / f\"investment_research_chief_card_{args.meeting_type}_{today_tag()}.md\"\n    atomic_write_json(json_path, payload, encoding=\"utf-8\", ensure_ascii=False, indent=2)\n    atomic_write_text(md_path, render_preview(dashboard, payload), encoding=\"utf-8\")\n    print(md_path)\n    print(json_path)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774532765354}}
{"type":"message","id":"bea46a16","parentId":"dd5e999f","timestamp":"2026-03-26T13:46:44.144Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Evaluating investment research**\n\nI think I need to generate more relevant investment research for the mainline health sector and focus on pushing that research delivery. It seems like inspecting current data or trends could help inform my approach. I want to ensure I'm getting the best insights possible to keep the user informed and make sound recommendations. There's a lot to consider here, but it seems like a solid direction to take.","thinkingSignature":"{\"id\":\"rs_0142f9a21f5351e00169c538bcb1a0819b9dc898c4007d811b\",\"type\":\"reasoning\",\"encrypted_content\":\"gAAAAABpxTjDrD_6gS3wjvLcNq95KeGMw87VQRbsRHcGE511XgHER3mLbgU4aU7F_d-72Fh9t6dIjUMzNiwH9reTbAF8TX5YyhZg_lfDTyzhrmFcmpzWANA42zjgtA2ssrpT9c5ZIFyuw-qESC2EDH_ZiEX8MxNMuK-NRVYZTzl6uHnuPBr9ZT6wACMqpnlkXoUp-eKRMjNXTimUZomuOpwWHzs0ezoWOYiI505Al8QDPl_wNX8GZY1_Ue7GJ_m0vHS1tFSoxDPg_R02qOmnW-lUQcFL7EHf7Iz6Drp8uLKWfb-LeV69lwb_6-eRWlPLoKtydJRQFJtRk59ve0tDZwlZ9L7rM-itScoifjGuaBcwk3XTUBZWjYK7JYo-E-ODZ1bequ_Krp6krRZ9ReajJvCvgTOkYhQYfunWMHzMCFmfYdmtOB3Vl-wivYVNoqa0xbOYSVvrBVBVM3HL-EiFpJPfXI6hXZF_11SZKS8kI5Yegz5CoJroD2djM7aa03dkVIM_bSAGM-gGWfnXF9LjnZpE_t2kGDCinmxF5oo2QDJOXKA-jNLcv-oMWBhcTvAD6ebrv42AK5_jA_sGbrkIHrr14bR2kHHLHbaSeHfVSPO3BvXp8_qSlGRN2_ptuYR76Ee4Bm5_8eGfv5SZORMfIAPAiWi3U7Ol78coxYtEpCSM5C4LiNJEtCdi0-NZEHskpsDJe5fKNiDNMYsuYBPTJpRLy-LFatr7vJkw_kW-JiznLum2BsdMQ9WmniZwfL6xLBu0hJf0hQmhkFAs9xJ0tka-yjP8NQ5K6Dcevs22FHwJbeylkMTiPuXNWJ9_mjTIy83ULZc0iYoQO8Pf_zAG0TKp-sklkZ_tUjOmfRSFimG0_XgPjOFKsbUHLGZtATv58Wd2QCoaXwrRI7HfuzG6fw1YoZN1XdSV6j2zDQvddR9_TuJjSHBAIun0DXTtcvb1-r6d4bJD-nzGD4sS9WcHrD0VtvGnP1alrL2j3BZeoXc1KnUplel8fFA=\",\"summary\":[{\"type\":\"summary_text\",\"text\":\"**Evaluating investment research**\\n\\nI think I need to generate more relevant investment research for the mainline health sector and focus on pushing that research delivery. It seems like inspecting current data or trends could help inform my approach. I want to ensure I'm getting the best insights possible to keep the user informed and make sound recommendations. There's a lot to consider here, but it seems like a solid direction to take.\"}]}"},{"type":"toolCall","id":"call_R7VBYQFBBRUykJVkzGU5xUm9|fc_0142f9a21f5351e00169c538c3b33c819bbb7a41176bf8919f","name":"read","arguments":{"file_path":"/Users/ling/.openclaw/workspace/scripts/generate_investment_research_mainline_health.py"},"partialJson":"{\"file_path\":\"/Users/ling/.openclaw/workspace/scripts/generate_investment_research_mainline_health.py\"}"},{"type":"toolCall","id":"call_OMCNnmc6aFTkw3jHGe2jc4LB|fc_0142f9a21f5351e00169c538c3b374819bb5a87fc330ddc317","name":"read","arguments":{"file_path":"/Users/ling/.openclaw/workspace/scripts/push_investment_research_delivery.py"},"partialJson":"{\"file_path\":\"/Users/ling/.openclaw/workspace/scripts/push_investment_research_delivery.py\"}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":78203,"output":119,"cacheRead":47616,"cacheWrite":0,"totalTokens":125938,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774532765381,"responseId":"resp_0142f9a21f5351e00169c538ae47a8819b938431a28a0465d9"}}
{"type":"message","id":"58fb3f02","parentId":"bea46a16","timestamp":"2026-03-26T13:46:44.305Z","message":{"role":"toolResult","toolCallId":"call_R7VBYQFBBRUykJVkzGU5xUm9|fc_0142f9a21f5351e00169c538c3b33c819bbb7a41176bf8919f","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom morning_news_state_utils import normalize_morning_news_state\nfrom report_io import atomic_write_json, atomic_write_text\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\n\n\ndef today_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef maybe_json(path: Path) -> dict[str, Any] | None:\n    return load_json(path) if path.exists() else None\n\n\ndef resolve_latest_meeting_type(tag: str, control_tower: dict[str, Any]) -> str:\n    latest = control_tower.get(\"latest_meeting_type\")\n    if isinstance(latest, str) and latest.strip():\n        return latest.strip()\n\n    for meeting_type in (\"night\", \"close\", \"midday\", \"morning\"):\n        if (REPORT_DIR / f\"investment_research_chief_dashboard_{meeting_type}_{tag}.json\").exists():\n            return meeting_type\n\n    return \"morning\"\n\n\ndef build_alert_message(overall: str, snapshot: dict[str, Any], missing: list[str], paths: dict[str, Any]) -> str:\n    prefix = {\n        \"OK\": \"🩺 量化投研主链巡检：OK\",\n        \"WARN\": \"⚠️ 量化投研主链巡检：WARN\",\n        \"ALERT\": \"🚨 量化投研主链巡检：ALERT\",\n    }.get(overall, \"❓ 量化投研主链巡检：UNKNOWN\")\n    lines = [\n        prefix,\n        f\"- 08:50晨报：`{snapshot.get('morning_news_status', '-')}` | 最近成功：`{snapshot.get('morning_news_last_success_at', '-')}`\",\n        f\"- 晨报状态说明：`{snapshot.get('morning_news_status_reason', '-')}`\",\n        f\"- 稳定策略：`{snapshot.get('strategy_audit_status', '-')}` | 年化/回撤/夏普：`{snapshot.get('strategy_audit_annual_return_pct', '-')}` / `{snapshot.get('strategy_audit_max_drawdown_pct', '-')}` / `{snapshot.get('strategy_audit_sharpe', '-')}`\",\n        f\"- 回测队列：`{snapshot.get('backtest_queue_status', '-')}` | 运行中：`{snapshot.get('backtest_queue_running_count', '-')}` | 已纳入稳定策略：`{snapshot.get('stable_strategy_visible', '-')}`\",\n        f\"- 模拟盘快照：`{snapshot.get('paper_date_tag', '-')}` | 新鲜度：`{snapshot.get('paper_freshness_status', '-')}` | 说明：`{snapshot.get('paper_freshness_summary', '-')}`\",\n        f\"- 缺口：{', '.join(missing) if missing else '无'}\",\n        f\"- 健康报告：`{paths.get('control_tower_json') or '暂无'}`\",\n    ]\n    if overall == 'ALERT':\n        lines.append('- 处理建议：优先检查晨报、稳定策略审计、回测队列三项是否断裂，再决定是否暂停后续自动发布。')\n    elif overall == 'WARN':\n        lines.append('- 处理建议：补齐缺失产物或入口文件，确认 bundle/card/dashboard 已同步更新。')\n    else:\n        lines.append('- 处理建议：当前主链完整，无需额外打扰。')\n    return \"\\n\".join(lines)\n\n\ndef build_health() -> dict[str, Any]:\n    tag = today_tag()\n    control_tower_path = REPORT_DIR / f\"investment_research_control_tower_{tag}.json\"\n    control_tower_card_path = REPORT_DIR / f\"investment_research_control_tower_card_{tag}.json\"\n    control_tower = maybe_json(control_tower_path) or {}\n    meeting_type = resolve_latest_meeting_type(tag, control_tower)\n    publish_bundle_path = REPORT_DIR / f\"investment_research_publish_bundle_{meeting_type}_{tag}.json\"\n    chief_dashboard_path = REPORT_DIR / f\"investment_research_chief_dashboard_{meeting_type}_{tag}.json\"\n    chief_broadcast_path = REPORT_DIR / f\"investment_research_chief_broadcast_{meeting_type}_{tag}.md\"\n    publish_bundle = maybe_json(publish_bundle_path) or {}\n    chief_dashboard = maybe_json(chief_dashboard_path) or {}\n\n    morning_news = control_tower.get(\"morning_news\", {})\n    morning_news_norm = normalize_morning_news_state(morning_news)\n    strategy_audit = control_tower.get(\"strategy_audit\", {})\n    backtest_queue = control_tower.get(\"backtest_queue\", {})\n    paper_execution = control_tower.get(\"paper_execution\", {})\n    paper_freshness = (paper_execution.get(\"freshness\") or {}) if isinstance(paper_execution, dict) else {}\n    bundle_snapshot = publish_bundle.get(\"control_tower_snapshot\", {})\n\n    checks = {\n        \"morning_news_ok\": bool(morning_news.get(\"health_ok\", morning_news_norm.get(\"health_ok\"))),\n        \"strategy_audit_ok\": strategy_audit.get(\"overall_status\") == \"PASS\" and bool(strategy_audit.get(\"robust_pass\")),\n        \"backtest_queue_ok\": backtest_queue.get(\"status\") == \"OK\" and bool(backtest_queue.get(\"stable_strategy_visible\")),\n        \"bundle_snapshot_ok\": bool(\n            bundle_snapshot.get(\"morning_news_ok\", bundle_snapshot.get(\"morning_news_status\") in {\"OK\", \"PENDING_TODAY\", \"SKIP_NON_TRADING_DAY\"})\n        )\n        and bool(bundle_snapshot.get(\"strategy_audit_ok\", bundle_snapshot.get(\"strategy_audit_status\") == \"PASS\"))\n        and bundle_snapshot.get(\"backtest_queue_status\") == \"OK\",\n        \"chief_dashboard_exists\": chief_dashboard_path.exists(),\n        \"chief_broadcast_exists\": chief_broadcast_path.exists(),\n        \"control_tower_card_exists\": control_tower_card_path.exists(),\n        \"paper_execution_fresh\": str(paper_freshness.get(\"status\") or \"\") in {\"fresh\", \"pending_today_refresh\"},\n    }\n\n    missing = [name for name, ok in checks.items() if not ok]\n    if not checks[\"morning_news_ok\"] or not checks[\"strategy_audit_ok\"] or not checks[\"backtest_queue_ok\"]:\n        overall = \"ALERT\"\n    elif missing:\n        overall = \"WARN\"\n    else:\n        overall = \"OK\"\n\n    snapshot = {\n        \"morning_news_status\": morning_news.get(\"status\") or morning_news_norm.get(\"effective_status\"),\n        \"morning_news_last_success_at\": morning_news.get(\"last_success_at\"),\n        \"morning_news_status_reason\": morning_news.get(\"status_reason\") or morning_news_norm.get(\"status_reason\"),\n        \"strategy_audit_status\": strategy_audit.get(\"overall_status\"),\n        \"strategy_audit_annual_return_pct\": strategy_audit.get(\"annual_return_pct\"),\n        \"strategy_audit_max_drawdown_pct\": strategy_audit.get(\"max_drawdown_pct\"),\n        \"strategy_audit_sharpe\": strategy_audit.get(\"sharpe\"),\n        \"backtest_queue_status\": backtest_queue.get(\"status\"),\n        \"backtest_queue_running_count\": backtest_queue.get(\"running_count\"),\n        \"stable_strategy_visible\": backtest_queue.get(\"stable_strategy_visible\"),\n        \"paper_date_tag\": paper_execution.get(\"date_tag\"),\n        \"paper_freshness_status\": paper_freshness.get(\"status\"),\n        \"paper_freshness_summary\": paper_freshness.get(\"summary\"),\n    }\n    paths = {\n        \"control_tower_json\": str(control_tower_path) if control_tower_path.exists() else None,\n        \"publish_bundle_json\": str(publish_bundle_path) if publish_bundle_path.exists() else None,\n        \"chief_dashboard_json\": str(chief_dashboard_path) if chief_dashboard_path.exists() else None,\n        \"chief_broadcast_md\": str(chief_broadcast_path) if chief_broadcast_path.exists() else None,\n        \"control_tower_card_json\": str(control_tower_card_path) if control_tower_card_path.exists() else None,\n    }\n    return {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"date_tag\": tag,\n        \"meeting_type\": meeting_type,\n        \"overall_status\": overall,\n        \"checks\": checks,\n        \"missing_or_failed\": missing,\n        \"snapshot\": snapshot,\n        \"alert_message\": build_alert_message(overall, snapshot, missing, paths),\n        \"paths\": paths,\n    }\n\n\ndef render_md(payload: dict[str, Any]) -> str:\n    snap = payload.get(\"snapshot\", {})\n    lines = [\n        \"# 量化投研主链健康检查\",\n        \"\",\n        f\"- 生成时间：{payload.get('generated_at')}\",\n        f\"- 总体状态：`{payload.get('overall_status')}`\",\n        \"\",\n        \"## 核心快照\",\n        f\"- 08:50晨报：`{snap.get('morning_news_status', '-')}` | 最近成功：`{snap.get('morning_news_last_success_at', '-')}`\",\n        f\"- 晨报状态说明：`{snap.get('morning_news_status_reason', '-')}`\",\n        f\"- 稳定策略：`{snap.get('strategy_audit_status', '-')}` | 年化/回撤/夏普：`{snap.get('strategy_audit_annual_return_pct', '-')}` / `{snap.get('strategy_audit_max_drawdown_pct', '-')}` / `{snap.get('strategy_audit_sharpe', '-')}`\",\n        f\"- 回测队列：`{snap.get('backtest_queue_status', '-')}` | 运行中：`{snap.get('backtest_queue_running_count', '-')}` | 已纳入稳定策略：`{snap.get('stable_strategy_visible', '-')}`\",\n        f\"- 模拟盘快照：`{snap.get('paper_date_tag', '-')}` | 新鲜度：`{snap.get('paper_freshness_status', '-')}` | 说明：`{snap.get('paper_freshness_summary', '-')}`\",\n        \"\",\n        \"## 检查项\",\n    ]\n    for name, ok in payload.get(\"checks\", {}).items():\n        lines.append(f\"- {name}: `{ok}`\")\n    lines.append(\"\")\n    lines.append(\"## 缺口\")\n    missing = payload.get(\"missing_or_failed\", [])\n    if missing:\n        for item in missing:\n            lines.append(f\"- {item}\")\n    else:\n        lines.append(\"- 无\")\n    lines.append(\"\")\n    lines.append(\"## 路径\")\n    for key, value in payload.get(\"paths\", {}).items():\n        lines.append(f\"- {key}: `{value or '暂无'}`\")\n    lines.append(\"\")\n    return \"\\n\".join(lines)\n\n\ndef main() -> None:\n    payload = build_health()\n    md_path = REPORT_DIR / f\"investment_research_mainline_health_{today_tag()}.md\"\n    json_path = REPORT_DIR / f\"investment_research_mainline_health_{today_tag()}.json\"\n    atomic_write_text(md_path, render_md(payload), encoding=\"utf-8\")\n    atomic_write_json(json_path, payload, encoding=\"utf-8\", ensure_ascii=False, indent=2)\n    print(md_path)\n    print(json_path)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774532804295}}
{"type":"message","id":"8f260fad","parentId":"58fb3f02","timestamp":"2026-03-26T13:46:44.318Z","message":{"role":"toolResult","toolCallId":"call_OMCNnmc6aFTkw3jHGe2jc4LB|fc_0142f9a21f5351e00169c538c3b374819bb5a87fc330ddc317","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom investment_research_health_snapshot import build_health_snapshot, build_ths_alert_line, latest_health_probe_for_date\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\nCONFIG_FILE = WORKSPACE / \"config\" / \"investment_research_delivery_v1.json\"\nSTATE_FILE = WORKSPACE / \"memory\" / \"investment_research_delivery_state.json\"\nOPENCLAW_BIN_CANDIDATES = [\n    str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"aliases\" / \"default\" / \"bin\" / \"openclaw\"),\n    shutil.which(\"openclaw\") or \"\",\n    \"openclaw\",\n]\n\nMEETING_LABELS = {\n    \"morning\": \"盘前会\",\n    \"midday\": \"午盘巡检\",\n    \"close\": \"收盘复盘\",\n    \"night\": \"夜间研究会\",\n}\n\nMEETING_EMOJIS = {\n    \"morning\": \"🌅\",\n    \"midday\": \"☀️\",\n    \"close\": \"📘\",\n    \"night\": \"🌙\",\n}\n\nSTATUS_LABELS = {\n    \"healthy\": \"健康\",\n    \"offhours_guarded\": \"非交易时段观察\",\n    \"watch_guarded\": \"警戒观察\",\n    \"degraded\": \"降级\",\n    \"normal\": \"正常\",\n    \"cautious\": \"谨慎\",\n    \"observe_defensive\": \"防守观察\",\n    \"halt\": \"暂停\",\n    \"ok\": \"正常\",\n    \"fallback\": \"已回退\",\n    \"failed\": \"部分失败\",\n    \"unavailable\": \"不可用\",\n    \"unknown\": \"未知\",\n    \"fresh\": \"今日已刷新\",\n    \"pending_today_refresh\": \"待今日刷新\",\n    \"stale\": \"已过期\",\n    \"missing\": \"缺失\",\n}\n\n\ndef now_str() -> str:\n    return datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n\ndef default_date_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    try:\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef write_json(path: Path, payload: dict[str, Any]) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n\n\ndef read_text(path: Path) -> str:\n    if not path.exists():\n        return \"\"\n    return path.read_text(encoding=\"utf-8\")\n\n\ndef cn_status(value: Any) -> str:\n    if value is None or value == \"\":\n        return \"-\"\n    return STATUS_LABELS.get(str(value), str(value))\n\n\ndef cn_text(value: Any) -> str:\n    if value is None or value == \"\":\n        return \"-\"\n    text = str(value)\n    replacements = {\n        \"public_source_divergence>\": \"公开网页源存在价差分歧 > \",\n        \"normal模式\": \"正常模式\",\n    }\n    for old, new in replacements.items():\n        text = text.replace(old, new)\n    return text\n\n\ndef resolve_openclaw_bin() -> str:\n    for candidate in OPENCLAW_BIN_CANDIDATES:\n        if candidate and Path(candidate).exists():\n            return candidate\n    for candidate in OPENCLAW_BIN_CANDIDATES:\n        if candidate:\n            return candidate\n    return \"openclaw\"\n\n\ndef run_cmd(cmd: list[str], timeout: int = 120) -> tuple[int, str, str]:\n    try:\n        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)\n        return proc.returncode, proc.stdout or \"\", proc.stderr or \"\"\n    except FileNotFoundError as exc:\n        return 127, \"\", str(exc)\n    except subprocess.TimeoutExpired as exc:\n        return 124, exc.stdout or \"\", exc.stderr or f\"timeout after {timeout}s\"\n\n\ndef selected_targets(config: dict[str, Any]) -> list[tuple[str, dict[str, Any]]]:\n    targets = config.get(\"targets\", {})\n    mode = str(config.get(\"deliveryMode\") or \"dm_and_group\")\n    ordered_names: list[str]\n    if mode == \"dm\":\n        ordered_names = [\"dm\"]\n    elif mode == \"group\":\n        ordered_names = [\"group\"]\n    else:\n        ordered_names = [\"dm\", \"group\"]\n\n    result: list[tuple[str, dict[str, Any]]] = []\n    for name in ordered_names:\n        payload = targets.get(name)\n        if isinstance(payload, dict) and payload.get(\"enabled\", True):\n            result.append((name, payload))\n    if result:\n        return result\n\n    for name, payload in targets.items():\n        if isinstance(payload, dict) and payload.get(\"enabled\", True):\n            result.append((str(name), payload))\n    return result\n\n\ndef compact_watchlist(items: list[Any], limit: int = 5) -> list[str]:\n    result: list[str] = []\n    for item in items[:limit]:\n        if isinstance(item, dict):\n            display = item.get(\"display\") or item.get(\"ticker\") or item.get(\"name\")\n            if display:\n                result.append(str(display))\n        elif item:\n            result.append(str(item))\n    return result\n\n\ndef compact_sell_review(items: list[Any], limit: int = 5) -> list[str]:\n    result: list[str] = []\n    for item in items[:limit]:\n        if isinstance(item, dict):\n            display = item.get(\"display\") or item.get(\"ticker\") or item.get(\"name\")\n            reason = item.get(\"reason\") or item.get(\"action\")\n            if display and reason:\n                result.append(f\"{display} | {reason}\")\n            elif display:\n                result.append(str(display))\n        elif item:\n            result.append(str(item))\n    return result\n\n\ndef resolve_health_snapshot(date_tag: str, bundle: dict[str, Any], control_tower: dict[str, Any]) -> dict[str, Any]:\n    health_scope, health_probe, health_path = latest_health_probe_for_date(REPORT_DIR, date_tag)\n    if health_probe:\n        return build_health_snapshot(health_scope, health_probe, health_path)\n    health_snapshot = control_tower.get(\"health_probe\", {}) if isinstance(control_tower.get(\"health_probe\"), dict) else {}\n    if health_snapshot:\n        return health_snapshot\n    bundle_probe = bundle.get(\"data_source_health\", {}) if isinstance(bundle.get(\"data_source_health\"), dict) else {}\n    if bundle_probe:\n        return build_health_snapshot(bundle_probe.get(\"scope\"), bundle_probe, None)\n    return {}\n\n\ndef should_include_execution_review_summary(meeting_type: str, trade_card: dict[str, Any]) -> bool:\n    if meeting_type not in {\"close\", \"night\"}:\n        return False\n    entries = trade_card.get(\"execution_review_entries\", [])\n    if not entries or not isinstance(entries[0], dict):\n        return False\n    review_item = entries[0]\n    if review_item.get(\"reason\") == \"holding_outside_trade_loop\":\n        return False\n    if review_item.get(\"primary_attribution_label\") == \"holding_without_strategy_exit\":\n        return False\n    if review_item.get(\"stage\") == \"sell_review\" and not trade_card.get(\"sell_review_list\"):\n        return False\n    return True\n\n\ndef build_message(\n    meeting_type: str,\n    date_tag: str,\n    trade_card: dict[str, Any],\n    bundle: dict[str, Any],\n    health_snapshot: dict[str, Any],\n) -> str:\n    watchlist = compact_watchlist(trade_card.get(\"watchlist\", []))\n    sell_review = compact_sell_review(trade_card.get(\"sell_review_list\", []))\n    event_watch = bundle.get(\"event_watch\", {}) if isinstance(bundle.get(\"event_watch\"), dict) else {}\n    ths = health_snapshot.get(\"ths_market\", {}) if isinstance(health_snapshot.get(\"ths_market\"), dict) else {}\n    paper_freshness = trade_card.get(\"paper_execution_freshness\", {}) if isinstance(trade_card.get(\"paper_execution_freshness\"), dict) else {}\n    risk_text = \"偏防守\" if trade_card.get(\"risk_off\") else \"条件化推进\"\n    watchlist_text = \"、\".join(watchlist) if watchlist else str(trade_card.get(\"watchlist_reason\") or \"暂无\")\n    sell_review_text = \"、\".join(sell_review) if sell_review else str(trade_card.get(\"sell_review_reason\") or \"暂无\")\n    alert_line = build_ths_alert_line(health_snapshot)\n\n    lines: list[str] = []\n    if alert_line:\n        lines.append(f\"[THS告警] {alert_line}\")\n\n    lines.extend([\n        f\"{MEETING_EMOJIS.get(meeting_type, '📊')} 模拟交易提示｜{MEETING_LABELS.get(meeting_type, meeting_type)}｜{date_tag}\",\n        f\"- 风险状态：{risk_text}\",\n        f\"- 模拟买入观察：{watchlist_text}\",\n        f\"- 模拟卖出复核：{sell_review_text}\",\n        f\"- 执行门槛：{'需要人工确认' if trade_card.get('user_confirmation_required') else '系统可直接推进'}\",\n    ])\n    loop_entries = trade_card.get(\"trade_loop_buy_entries\", [])[:2]\n    for item in loop_entries:\n        lines.append(\n            f\"- {item.get('display') or item.get('ticker') or '-'}：{item.get('stage_label') or item.get('stage') or '-'}\"\n            f\" | 触发={item.get('trigger_hint') or '-'} | 止损/止盈={item.get('stop_loss') or '-'} / {item.get('take_profit') or '-'}\"\n        )\n    if should_include_execution_review_summary(meeting_type, trade_card):\n        review_item = trade_card[\"execution_review_entries\"][0]\n        lines.append(\n            f\"- 执行归因：{review_item.get('display') or review_item.get('ticker') or '-'} | \"\n            f\"{review_item.get('primary_attribution_label_cn') or '-'} | 下一步={review_item.get('primary_next_action') or '-'}\"\n        )\n\n    if trade_card.get(\"risk_off\"):\n        lines.append(\"- 当前结论：只保留观察名单和触发条件，不自动转成买单。\")\n    if not trade_card.get(\"trading_time\", False):\n        lines.append(\"- 当前非交易时段/非交易日，不提供可执行买价。\")\n    if event_watch.get(\"should_temporary_meet\"):\n        lines.append(\"- 事件监控：已触发临时会商建议。\")\n    if trade_card.get(\"paper_date_tag\") or paper_freshness:\n        lines.append(\n            f\"- 模拟盘快照：{trade_card.get('paper_date_tag') or '-'}\"\n            f\" | 新鲜度={cn_status(paper_freshness.get('status'))}\"\n        )\n        if paper_freshness.get(\"summary\"):\n            lines.append(f\"- 模拟盘说明：{paper_freshness.get('summary')}\")\n    if health_snapshot.get(\"status\"):\n        lines.append(\n            f\"- 数据源健康：{cn_status(health_snapshot.get('status'))}\"\n            f\" | 推荐模式={cn_status(health_snapshot.get('recommended_mode'))}\"\n        )\n    if ths:\n        lines.append(\n            f\"- THS本地行情：{cn_status(ths.get('status'))}\"\n            f\" | THS命中/回退/失败={ths.get('ok_count', 0)}/{ths.get('fallback_count', 0)}/{ths.get('failed_count', 0)}\"\n        )\n        lines.append(f\"- THS摘要：{ths.get('summary') or '-'}\")\n    if health_snapshot.get(\"observations\"):\n        lines.append(f\"- 观察项：{'、'.join(cn_text(item) for item in health_snapshot.get('observations', [])[:2])}\")\n    return \"\\n\".join(lines)\n\n\ndef dedupe_key(\n    meeting_type: str,\n    date_tag: str,\n    target_name: str,\n    target_value: str,\n    message: str,\n    card_payload: dict[str, Any] | None,\n) -> str:\n    base = {\n        \"meeting_type\": meeting_type,\n        \"date_tag\": date_tag,\n        \"target_name\": target_name,\n        \"target_value\": target_value,\n        \"message\": message,\n        \"card\": card_payload or {},\n    }\n    raw = json.dumps(base, ensure_ascii=False, sort_keys=True)\n    return hashlib.sha256(raw.encode(\"utf-8\")).hexdigest()\n\n\ndef send_payload(\n    *,\n    channel: str,\n    account: str,\n    target: str,\n    message: str,\n    card_payload: dict[str, Any] | None,\n    dry_run: bool,\n) -> tuple[bool, str]:\n    cmd = [\n        resolve_openclaw_bin(),\n        \"message\",\n        \"send\",\n        \"--channel\",\n        channel,\n        \"--account\",\n        account,\n        \"--target\",\n        target,\n        \"-m\",\n        message,\n        \"--json\",\n    ]\n    if card_payload:\n        cmd.extend([\"--card\", json.dumps(card_payload, ensure_ascii=False)])\n    if dry_run:\n        cmd.append(\"--dry-run\")\n    rc, out, err = run_cmd(cmd, timeout=180)\n    info = (out.strip() or err.strip())[-4000:]\n    return rc == 0, info\n\n\ndef main() -> int:\n    parser = argparse.ArgumentParser(description=\"Push investment research meeting summary to Feishu\")\n    parser.add_argument(\"--meeting-type\", choices=[\"morning\", \"midday\", \"close\", \"night\"], required=True)\n    parser.add_argument(\"--date-tag\", default=default_date_tag())\n    parser.add_argument(\"--dry-run\", action=\"store_true\")\n    parser.add_argument(\"--force\", action=\"store_true\")\n    args = parser.parse_args()\n\n    meeting_type = str(args.meeting_type)\n    date_tag = str(args.date_tag)\n    config = load_json(CONFIG_FILE)\n    state = load_json(STATE_FILE)\n\n    trade_card_path = REPORT_DIR / f\"investment_research_trade_card_{meeting_type}_{date_tag}.json\"\n    chief_card_path = REPORT_DIR / f\"investment_research_chief_card_{meeting_type}_{date_tag}.json\"\n    control_tower_card_path = REPORT_DIR / f\"investment_research_control_tower_card_{date_tag}.json\"\n    control_tower_path = REPORT_DIR / f\"investment_research_control_tower_{date_tag}.json\"\n    chief_broadcast_path = REPORT_DIR / f\"investment_research_chief_broadcast_{meeting_type}_{date_tag}.md\"\n    group_digest_path = REPORT_DIR / f\"investment_research_group_digest_{meeting_type}_{date_tag}.md\"\n    bundle_path = REPORT_DIR / f\"investment_research_publish_bundle_{meeting_type}_{date_tag}.json\"\n\n    trade_card = load_json(trade_card_path)\n    chief_card = load_json(chief_card_path)\n    control_tower_card = load_json(control_tower_card_path)\n    control_tower = load_json(control_tower_path)\n    bundle = load_json(bundle_path)\n    _chief_broadcast_text = read_text(chief_broadcast_path)\n    _group_digest_text = read_text(group_digest_path)\n\n    if not trade_card:\n        raise SystemExit(f\"missing trade card: {trade_card_path}\")\n\n    preferred_card = chief_card if chief_card else control_tower_card or None\n    health_snapshot = resolve_health_snapshot(date_tag, bundle, control_tower)\n    message = build_message(meeting_type, date_tag, trade_card, bundle, health_snapshot)\n\n    deliveries: list[dict[str, Any]] = []\n    state_deliveries = state.get(\"deliveries\", {}) if isinstance(state.get(\"deliveries\"), dict) else {}\n\n    for target_name, target_cfg in selected_targets(config):\n        channel = str(target_cfg.get(\"channel\") or \"feishu\")\n        account = str(target_cfg.get(\"account\") or \"main\")\n        target = str(target_cfg.get(\"target\") or \"\")\n        if not target:\n            deliveries.append(\n                {\n                    \"target_name\": target_name,\n                    \"status\": \"FAILED\",\n                    \"reason\": \"missing_target\",\n                }\n            )\n            continue\n\n        state_key = f\"{date_tag}:{meeting_type}:{target_name}:{target}\"\n        current_dedupe = dedupe_key(meeting_type, date_tag, target_name, target, message, preferred_card)\n        previous_dedupe = state_deliveries.get(state_key)\n        if previous_dedupe == current_dedupe and not args.force:\n            deliveries.append(\n                {\n                    \"target_name\": target_name,\n                    \"channel\": channel,\n                    \"account\": account,\n                    \"target\": target,\n                    \"status\": \"SKIPPED\",\n                    \"reason\": \"duplicate\",\n                    \"dedupe_key\": current_dedupe,\n                }\n            )\n            continue\n\n        ok, info = send_payload(\n            channel=channel,\n            account=account,\n            target=target,\n            message=message,\n            card_payload=preferred_card,\n            dry_run=args.dry_run,\n        )\n        deliveries.append(\n            {\n                \"target_name\": target_name,\n                \"channel\": channel,\n                \"account\": account,\n                \"target\": target,\n                \"status\": \"OK\" if ok else \"FAILED\",\n                \"dedupe_key\": current_dedupe,\n                \"info\": info,\n                \"dry_run\": args.dry_run,\n            }\n        )\n        if ok and not args.dry_run:\n            state_deliveries[state_key] = current_dedupe\n\n    state[\"deliveries\"] = state_deliveries\n    state[\"updated_at\"] = now_str()\n    if not args.dry_run:\n        write_json(STATE_FILE, state)\n\n    report_payload = {\n        \"generated_at\": now_str(),\n        \"meeting_type\": meeting_type,\n        \"date_tag\": date_tag,\n        \"dry_run\": args.dry_run,\n        \"force\": args.force,\n        \"message\": message,\n        \"source_files\": {\n            \"trade_card\": str(trade_card_path),\n            \"chief_card\": str(chief_card_path) if chief_card_path.exists() else None,\n            \"control_tower_card\": str(control_tower_card_path) if control_tower_card_path.exists() else None,\n            \"control_tower\": str(control_tower_path) if control_tower_path.exists() else None,\n            \"chief_broadcast\": str(chief_broadcast_path) if chief_broadcast_path.exists() else None,\n            \"group_digest\": str(group_digest_path) if group_digest_path.exists() else None,\n            \"publish_bundle\": str(bundle_path) if bundle_path.exists() else None,\n        },\n        \"health_snapshot\": health_snapshot,\n        \"deliveries\": deliveries,\n    }\n    report_path = REPORT_DIR / f\"investment_research_delivery_push_{meeting_type}_{date_tag}.json\"\n    write_json(report_path, report_payload)\n    print(report_path)\n\n    failed = [item for item in deliveries if item.get(\"status\") == \"FAILED\"]\n    return 1 if failed else 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n"}],"isError":false,"timestamp":1774532804306}}
