ensive\": \"防守观察\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"watch_guarded\": \"警戒观察\",\n        \"offhours_guarded\": \"非交易时段观察\",\n        \"healthy\": \"健康\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"strict precheck\": \"严格盘前检查\",\n        \"FULL_HALT\": \"全市场暂停新增\",\n        \"BUY_HALT\": \"暂停买入\",\n        \"style_rotation_riskoff\": \"小盘风格转弱\",\n        \"intraday_market_halt\": \"盘中市场门禁触发暂停\",\n        \"halt:\": \"暂停原因：\",\n        \"runtime_risk_state_latest\": \"运行时风控状态\",\n        \"strategy_report\": \"策略报告\",\n        \"BUY\": \"买入\",\n        \"SELL\": \"卖出\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"normal模式\": \"正常模式\",\n        \"public_source_divergence>\": \"公开网页源存在价差分歧 > \",\n    }\n    for old, new in replacements.items():\n        s = s.replace(old, new)\n    return s\n\n\ndef cn_cycle(value: Any) -> str:\n    mapping = {\n        \"pre_open\": \"盘前值班\",\n        \"intraday\": \"盘中值班\",\n        \"post_close\": \"收盘值班\",\n        \"overnight\": \"夜间值班\",\n    }\n    if value is None or value == \"\":\n        return \"-\"\n    return mapping.get(str(value), str(value))\n\n\ndef build_payload(anchor_meeting: str | None = None) -> dict[str, Any]:\n    dashboards: dict[str, dict[str, Any]] = {}\n    meeting_index: list[dict[str, Any]] = []\n    latest_meeting = None\n    latest_dashboard = None\n    latest_dt = datetime.min\n\n    for meeting_type in MEETING_TYPES:\n        path = dashboard_path(meeting_type)\n        dashboard = maybe_json(path)\n        if not dashboard:\n            continue\n        dashboards[meeting_type] = dashboard\n        generated_at = dashboard.get(\"generated_at\")\n        dt = parse_dt(generated_at)\n\n[281 more lines in file. Use offset=240 to continue.]"}],"isError":false,"timestamp":1774533740621}}
{"type":"message","id":"4555ee55","parentId":"869656bf","timestamp":"2026-03-26T14:02:20.649Z","message":{"role":"toolResult","toolCallId":"call_kfth3c6CoDB7Eit0GYHuKntR|fc_0142f9a21f5351e00169c53c6be3a8819ba94867e0f8680e24","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom report_io import atomic_write_json, atomic_write_text\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\n\n\ndef today_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef control_tower_path() -> Path:\n    path = REPORT_DIR / f\"investment_research_control_tower_{today_tag()}.json\"\n    if not path.exists():\n        raise FileNotFoundError(str(path))\n    return path\n\n\ndef truncate_list(items: list[str], limit: int = 5) -> str:\n    if not items:\n        return \"暂无\"\n    return \"\\n\".join(f\"- {item}\" for item in items[:limit])\n\n\ndef yes_no(value: Any) -> str:\n    if value is True:\n        return \"是\"\n    if value is False:\n        return \"否\"\n    if value is None or value == \"\":\n        return \"-\"\n    return str(value)\n\n\ndef cn_status(value: Any) -> str:\n    mapping = {\n        \"OK\": \"正常\",\n        \"WARN\": \"预警\",\n        \"ERROR\": \"错误\",\n        \"PASS\": \"通过\",\n        \"ALERT\": \"告警\",\n        \"healthy\": \"健康\",\n        \"watch_guarded\": \"警戒观察\",\n        \"offhours_guarded\": \"非交易时段观察\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"halt\": \"暂停\",\n        \"FULL_HALT\": \"全市场暂停新增\",\n        \"BUY_HALT\": \"暂停买入\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"observe_defensive\": \"防守观察\",\n        \"no_trigger\": \"无新增触发\",\n        \"PENDING_TODAY\": \"待今日晨报\",\n        \"STALE\": \"状态过期\",\n        \"PUSH_FAILED\": \"推送失败\",\n        \"GENERATION_FAILED\": \"生成失败\",\n        \"DEADLINE_MISSED\": \"超时未完成\",\n        \"SKIP_NON_TRADING_DAY\": \"非交易日跳过\",\n        \"MISSING\": \"缺失\",\n        \"ok\": \"正常\",\n        \"fallback\": \"已回退\",\n        \"failed\": \"部分失败\",\n        \"unavailable\": \"不可用\",\n        \"unknown\": \"未知\",\n        \"fresh\": \"今日已刷新\",\n        \"pending_today_refresh\": \"待今日刷新\",\n        \"stale\": \"已过期\",\n        \"mixed\": \"日期混杂\",\n        \"missing\": \"缺失\",\n    }\n    if value is None or value == \"\":\n        return \"-\"\n    return mapping.get(str(value), str(value))\n\n\ndef cn_text(text: Any) -> str:\n    if text is None or text == \"\":\n        return \"-\"\n    s = str(text)\n    replacements = {\n        \"market_breadth\": \"市场宽度\",\n        \"source_price_divergence\": \"数据源价差分歧\",\n        \"account_sync_age\": \"账户同步时延\",\n        \"observe_defensive\": \"防守观察\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"watch_guarded\": \"警戒观察\",\n        \"offhours_guarded\": \"非交易时段观察\",\n        \"healthy\": \"健康\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"FULL_HALT\": \"全市场暂停新增\",\n        \"BUY_HALT\": \"暂停买入\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"normal模式\": \"正常模式\",\n        \"public_source_divergence>\": \"公开网页源存在价差分歧 > \",\n        \"BUY\": \"买入\",\n        \"SELL\": \"卖出\",\n    }\n    for old, new in replacements.items():\n        s = s.replace(old, new)\n    return s\n\n\ndef build_card(payload: dict[str, Any]) -> dict[str, Any]:\n    latest_status = payload.get(\"latest_status\", {})\n\n[189 more lines in file. Use offset=121 to continue.]"}],"isError":false,"timestamp":1774533740637}}
