{"type":"message","id":"cef31e8f","parentId":"9fedd9f7","timestamp":"2026-03-30T13:10:08.743Z","message":{"role":"toolResult","toolCallId":"call_function_kmf318rexyos_1","toolName":"exec","content":[{"type":"text","text":"key=lambda row: (\n            status_rank.get(str(row.get(\"status\") or \"NO_DATA\"), 3),\n            float(row.get(\"drawdown_pct\", 0.0)),\n            float(row.get(\"total_return_pct\", 0.0)),\n            str(row.get(\"profile_slug\") or \"\"),\n        ),\n    )\n\n    profile_rows = []\n    profile_cards = []\n    for row in sorted_profiles:\n        profile_rows.append(\n            f\"<tr><td>{html.escape(row['profile_slug'])}</td><td>{html.escape(row['status'])}</td><td>{html.escape(str(row['tomorrow_mode']))}</td>\"\n            f\"<td>{row['nav']:.2f}</td><td>{row['total_return_pct']:.2f}%</td><td>{row['drawdown_pct']:.2f}%</td><td>{html.escape(row['issue_codes'] or 'none')}</td></tr>\"\n        )\n        status_class = {\n            \"GREEN\": \"status-green\",\n            \"YELLOW\": \"status-yellow\",\n            \"RED\": \"status-red\",\n        }.get(str(row[\"status\"]), \"\")\n        profile_cards.append(\n            f\"\"\"<article class=\"card {status_class}\">\n              <div class=\"label\">{html.escape(row['profile_slug'])}</div>\n              <div class=\"value\">{html.escape(str(row['status']))}</div>\n              <div class=\"minor\">mode={html.escape(str(row['tomorrow_mode']))} | issues={html.escape(row['issue_codes'] or 'none')}</div>\n              <div class=\"metric-grid\">\n                <div><span>净值</span><strong>{row['nav']:.2f}</strong></div>\n                <div><span>累计收益</span><strong>{row['total_return_pct']:.2f}%</strong></div>\n                <div><span>回撤</span><strong>{row['drawdown_pct']:.2f}%</strong></div>\n                <div><span>持仓数</span><strong>{int(row.get('position_count', 0))}</strong></div>\n              </div>\n            </article>\"\"\"\n        )\n\n    breadth_alert = payload[\"profit_layer\"].get(\"breadth_alert\", {}) or {}\n    breadth_issue_codes = \",\".join(breadth_alert.get(\"issue_codes\") or []) or \"none\"\n    breadth_alert_status = str(breadth_alert.get(\"status\") or \"NO_DATA\")\n    breadth_alert_card_class = {\n        \"GREEN\": \"status-green\",\n        \"YELLOW\": \"status-yellow\",\n        \"RED\": \"status-red\",\n    }.get(breadth_alert_status, \"\")\n    breadth_alert_minor = (\n        f\"issues={html.escape(breadth_issue_codes)} | drift={html.escape(str(breadth_alert.get('target_drift_pct', '-')))}%\"\n    )\n    governance_status = str(payload[\"strategy_layer\"].get(\"governance_status\") or \"UNKNOWN\")\n    governance_card_class = \"status-green\" if governance_status == \"PASS\" else \"status-red\"\n    governance_issues = payload[\"strategy_layer\"].get(\"governance_blocking_issues\") or []\n\n    return f\"\"\"<!doctype html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>控制塔日报</title>\n  <style>\n    :root {{\n      --bg: #f3f6f8; --paper:#fff; --ink:#0f1720; --muted:#627080; --line:#dbe3ea;\n      --green:#146c43; --yellow:#b7791f; --red:#c0392b; --blue:#174ea6;\n    }}\n    * {{ box-sizing:border-box; }}\n    body {{ margin:0; background:\n      linear-gradient(135deg, rgba(23,78,166,.08), transparent 35%),\n      linear-gradient(180deg, #fbfdff, var(--bg)); font-family:\"SF Pro Display\",\"PingFang SC\",sans-serif; color:var(--ink); }}\n    .wrap {{ max-width:1360px; margin:0 auto; padding:28px; }}\n    h1 {{ margin:0 0 8px; font-size:34px; }}\n    .sub {{ color:var(--muted); margin-bottom:20px; }}\n    .hero {{ display:grid; grid-template-columns:2fr 1fr 1fr 1fr 1fr; gap:16px; }}\n    .card {{ background:var(--paper); border:1px solid var(--line); border-radius:18px; padding:18px; box-shadow:0 14px 32px rgba(15,23,32,.05); }}\n    .status-red {{ border-top:6px solid var(--red); }} .status-yellow {{ border-top:6px solid var(--yellow); }} .status-green {{ border-top:6px solid var(--green); }}\n    .label {{ color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.12em; }}\n    .value {{ font-size:32px; font-weight:700; margin-top:6px; }}\n    .minor {{ margin-top:8px; color:var(--muted); }}\n    .section {{ margin-top:18px; }}\n    .strategy-cards {{ display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:16px; }}\n    .metric-grid {{ display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:12px; }}\n    .metric-grid span {{ display:block; color:var(--muted); font-size:12px; }}\n    .metric-grid strong {{ font-size:18px; }}\n    table {{ width:100%; border-collapse:collapse; background:var(--paper); border:1px solid var(--line); border-radius:18px; overflow:hidden; }}\n    th,td {{ padding:12px 10px; border-bottom:1px solid var(--line); text-align:left; vertical-align:top; }}\n    th {{ color:var(--muted); background:#f8fafc; }}\n    .pill {{ display:inline-block; padding:4px 8px; border-radius:999px; color:#fff; font-size:12px; }}\n    .pill.green {{ background:var(--green); }} .pill.yellow {{ background:var(--yellow); }} .pill.red {{ background:var(--red); }} .pill.no_data {{ background:var(--blue); }}\n    code {{ background:#eef3f7; padding:2px 6px; border-radius:6px; }}\n    @media (max-width:1100px) {{ .hero {{ grid-template-columns:1fr 1fr; }} }}\n    @media (max-width:700px) {{ .hero {{ grid-template-columns:1fr; }} }}\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <h1>控制塔日报</h1>\n    <div class=\"sub\">生成时间: {html.escape(payload['generated_at'])} | 目标是让你先看系统有没有活着，再看策略能不能跑，最后看它赚没赚钱</div>\n    <section class=\"hero\">\n      <article class=\"card status-{payload['overall_status'].lower()}\">\n        <div class=\"label\">总状态</div>\n        <div class=\"value\">{html.escape(payload['overall_status'])}</div>\n        <div class=\"minor\">看这张卡就知道今天系统是不是健康。</div>\n      </article>\n      <article class=\"card\">\n        <div class=\"label\">统一交易状态</div>\n        <div class=\"value\">{html.escape(str(payload['trading_status']['status']))}</div>\n        <div class=\"minor\">{html.escape(str(payload['trading_status']['label_cn']))} | reason={html.escape(str(payload['trading_status'].get('reason') or '-'))}</div>\n      </article>\n      <article class=\"card\">\n        <div class=\"label\">执行完整性</div>\n        <div class=\"value\">{html.escape(str(payload['system_checks']['live_execution_integrity']['status']))}</div>\n        <div class=\"minor\">orders={payload['execution_layer']['live_orders_total']} | attempted={payload['execution_layer']['live_execution_attempted']} | journal={payload['execution_layer']['live_journal_records']}</div>\n      </article>\n      <article class=\"card {'status-red' if any(x['status']=='RED' for x in payload['strategy_layer'].get('profile_updates', [])) else 'status-green'}\">\n        <div class=\"label\">策略更新</div>\n        <div class=\"value\">{'STALE' if any(x['status']=='RED' for x in payload['strategy_layer'].get('profile_updates', [])) else 'OK'}</div>\n        <div class=\"minor\">expected={html.escape(str(payload['strategy_layer'].get('expected_date_tag')))}</div>\n      </article>\n      <article class=\"card\">\n        <div class=\"label\">市场闸门</div>\n        <div class=\"value\">{'HARD STOP' if payload['strategy_layer']['hard_stop'] else ('RISK OFF' if payload['strategy_layer']['risk_off'] else 'NORMAL')}</div>\n        <div class=\"minor\">系统市场风控模式</div>\n      </article>\n      <article class=\"card {governance_card_class}\">\n        <div class=\"label\">治理闸门</div>\n        <div class=\"value\">{html.escape(governance_status)}</div>\n        <div class=\"minor\">blocking={len(governance_issues)} | generated_at={html.escape(str(payload['strategy_layer'].get('governance_generated_at') or '-'))}</div>\n      </article>\n      <article class=\"card {breadth_alert_card_class}\">\n        <div class=\"l