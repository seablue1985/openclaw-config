rows:\n        slot_label = str(row.get(\"slot_label\") or \"-\")\n        code = normalized_code(str(row.get(\"ts_code\") or \"-\"))\n        pair = (slot_label, code)\n        if pair in seen:\n            continue\n        if per_slot_count.get(slot_label, 0) >= 2:\n            continue\n        seen.add(pair)\n        per_slot_count[slot_label] = per_slot_count.get(slot_label, 0) + 1\n        result.append(f\"{slot_label} {code}\")\n        if len(result) >= 6:\n            break\n    return result","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774877106763}}
