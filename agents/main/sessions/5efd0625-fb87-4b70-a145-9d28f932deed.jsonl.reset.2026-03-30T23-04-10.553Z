{"type":"message","id":"b5d17857","parentId":"658372cb","timestamp":"2026-03-30T12:54:51.446Z","message":{"role":"toolResult","toolCallId":"call_function_z9870lss6mkw_1","toolName":"exec","content":[{"type":"text","text":"def call_weibo(uid: int, limit: int = MAX_PER_KOL) -> list:\n    \"\"\"调用 mcp-server-weibo 获取某用户最新微博\"\"\"\n    mcporter = str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"node-versions\" / \"v22.22.0\" / \"installation\" / \"bin\" / \"mcporter\")\n    cmd = [mcporter, \"call\", \"weibo.get_feeds\", f\"uid={uid}\", f\"limit={limit}\"]\n    try:\n        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)\n        if result.returncode != 0:\n            return []\n        data = json.loads(result.stdout)\n        return data if isinstance(data, list) else []\n    except Exception as e:\n        print(f\"  ⚠️ 获取UID {uid} 失败: {e}\")\n        return []"}],"details":{"status":"completed","exitCode":0,"durationMs":30,"aggregated":"def call_weibo(uid: int, limit: int = MAX_PER_KOL) -> list:\n    \"\"\"调用 mcp-server-weibo 获取某用户最新微博\"\"\"\n    mcporter = str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"node-versions\" / \"v22.22.0\" / \"installation\" / \"bin\" / \"mcporter\")\n    cmd = [mcporter, \"call\", \"weibo.get_feeds\", f\"uid={uid}\", f\"limit={limit}\"]\n    try:\n        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)\n        if result.returncode != 0:\n            return []\n        data = json.loads(result.stdout)\n        return data if isinstance(data, list) else []\n    except Exception as e:\n        print(f\"  ⚠️ 获取UID {uid} 失败: {e}\")\n        return []","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774875291431}}
