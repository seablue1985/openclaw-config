{"type":"message","id":"31652fca","parentId":"cb801ae0","timestamp":"2026-03-30T03:51:32.539Z","message":{"role":"toolResult","toolCallId":"call_function_qkaa6p5zd1nl_1","toolName":"exec","content":[{"type":"text","text":"raise FileNotFoundError(f\"缺少指定日期的票据文件: {dated}\")\n\n\ndef materialize_profile_signal_chain(\n    *,\n    paper_cfg: dict[str, Any],\n    state: dict[str, Any],\n    date_tag: str,\n    merged_signals_path: Path,\n    risk_config_path: Path | None,\n) -> dict[str, Any]:\n    profile_slug = profile_slug_from_config(paper_cfg)\n    live_config_path = resolve_path(str(paper_cfg.get(\"live_config\", \"config/live_trading_v1.json\")))\n    live_cfg = load_json(live_config_path)\n    runtime_metrics = resolve_runtime_metrics(date_tag, live_cfg)\n    lot_size = int(((live_cfg.get(\"execution\", {}) or {}).get(\"lot_size\", 100)) or 100)\n    available_cash = round(float(state.get(\"available_cash\", 0.0) or 0.0), 2)\n    account_nav = round(float(state.get(\"account_nav\", 0.0) or 0.0), 2)\n    artifacts = build_profile_artifact_paths(profile_slug, date_tag)\n\n    positions_df = state.get(\"positions_df\", pd.DataFrame())\n    if not isinstance(positions_df, pd.DataFrame):\n        positions_df = pd.DataFrame(columns=[\"symbol\", \"quantity\", \"cost_price\"])\n    write_holdings_snapshot(artifacts[\"holdings_input\"], positions_df)\n\n    # 盘前/盘中生成当日下单计划时，只能使用“当前日期之前”的已落地成交，\n    # 否则同日残留 journal 会被误读成历史成交，形成幽灵 BUY/SELL。\n    trade_history_df = load_all_trade_rows(\n        REPORT_DIR,\n        profile_slug=profile_slug,\n        end_date_tag=date_tag,\n        include_end_date=False,\n    )\n    write_trade_history(artifacts[\"trade_history\"], trade_history_df)\n\n    apply_cmd = [\n        \"python3\",\n        \"scripts/apply_risk_to_merged_signals.py\",\n        \"--input\",\n        str(merged_signals_path),\n        \"--trade-date\",\n        tag_to_iso(date_tag),\n        \"--account-nav\",\n        str(account_nav),\n        \"--available-cash\",\n        str(available_cash),\n        \"--index-ret-pct\",\n        str(runtime_metrics.get(\"index_ret_pct\")),\n        \"--strategy-max-dd-pct\",\n        str(runtime_metrics.get(\"strategy_max_dd_pct\")),\n        \"--strategy-sharpe\",\n        str(runtime_metrics.get(\"strategy_sharpe\")),\n        \"--live-config\",\n        str(live_config_path),\n        \"--holdings\",\n        str(artifacts[\"holdings_input\"]),\n        \"--trade-history\",\n        str(artifacts[\"trade_history\"]),\n        \"--approved-output\",\n        str(artifacts[\"approved\"]),\n        \"--orders-output\","}],"details":{"status":"completed","exitCode":0,"durationMs":31,"aggregated":"raise FileNotFoundError(f\"缺少指定日期的票据文件: {dated}\")\n\n\ndef materialize_profile_signal_chain(\n    *,\n    paper_cfg: dict[str, Any],\n    state: dict[str, Any],\n    date_tag: str,\n    merged_signals_path: Path,\n    risk_config_path: Path | None,\n) -> dict[str, Any]:\n    profile_slug = profile_slug_from_config(paper_cfg)\n    live_config_path = resolve_path(str(paper_cfg.get(\"live_config\", \"config/live_trading_v1.json\")))\n    live_cfg = load_json(live_config_path)\n    runtime_metrics = resolve_runtime_metrics(date_tag, live_cfg)\n    lot_size = int(((live_cfg.get(\"execution\", {}) or {}).get(\"lot_size\", 100)) or 100)\n    available_cash = round(float(state.get(\"available_cash\", 0.0) or 0.0), 2)\n    account_nav = round(float(state.get(\"account_nav\", 0.0) or 0.0), 2)\n    artifacts = build_profile_artifact_paths(profile_slug, date_tag)\n\n    positions_df = state.get(\"positions_df\", pd.DataFrame())\n    if not isinstance(positions_df, pd.DataFrame):\n        positions_df = pd.DataFrame(columns=[\"symbol\", \"quantity\", \"cost_price\"])\n    write_holdings_snapshot(artifacts[\"holdings_input\"], positions_df)\n\n    # 盘前/盘中生成当日下单计划时，只能使用“当前日期之前”的已落地成交，\n    # 否则同日残留 journal 会被误读成历史成交，形成幽灵 BUY/SELL。\n    trade_history_df = load_all_trade_rows(\n        REPORT_DIR,\n        profile_slug=profile_slug,\n        end_date_tag=date_tag,\n        include_end_date=False,\n    )\n    write_trade_history(artifacts[\"trade_history\"], trade_history_df)\n\n    apply_cmd = [\n        \"python3\",\n        \"scripts/apply_risk_to_merged_signals.py\",\n        \"--input\",\n        str(merged_signals_path),\n        \"--trade-date\",\n        tag_to_iso(date_tag),\n        \"--account-nav\",\n        str(account_nav),\n        \"--available-cash\",\n        str(available_cash),\n        \"--index-ret-pct\",\n        str(runtime_metrics.get(\"index_ret_pct\")),\n        \"--strategy-max-dd-pct\",\n        str(runtime_metrics.get(\"strategy_max_dd_pct\")),\n        \"--strategy-sharpe\",\n        str(runtime_metrics.get(\"strategy_sharpe\")),\n        \"--live-config\",\n        str(live_config_path),\n        \"--holdings\",\n        str(artifacts[\"holdings_input\"]),\n        \"--trade-history\",\n        str(artifacts[\"trade_history\"]),\n        \"--approved-output\",\n        str(artifacts[\"approved\"]),\n        \"--orders-output\",","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774842692523}}
