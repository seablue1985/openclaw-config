n152:        avg_turnover = round(float(pd.to_numeric(journal_df.get(turnover_col), errors=\"coerce\").diff().abs().fillna(0.0).mean()), 4)\n153:    if avg_turnover > parse_float(thresholds.get(\"paper_avg_turnover_cap\"), 0.12):\n154:        issues.append({\"level\": \"YELLOW\", \"code\": \"AVG_TURNOVER_BREACH\", \"value\": avg_turnover, \"limit\": thresholds.get(\"paper_avg_turnover_cap\")})\n156:    journal_records = int(len(journal_df))\n157:    if journal_records <= int(parse_float(thresholds.get(\"paper_missing_journal_records_cap\"), 0.0)) and positions_df.empty:\n159:            issues.append({\"level\": \"RED\", \"code\": \"NO_JOURNAL_WITH_PLANNED_ORDERS\", \"value\": int(len(orders_df)), \"limit\": 0})\n161:            issues.append({\"level\": \"YELLOW\", \"code\": \"NO_ACTIVITY_DAY\", \"value\": journal_records, \"limit\": thresholds.get(\"paper_missing_journal_records_cap\")})\n163:    error_trade_count = int(journal_df.get(\"risk_reason\", pd.Series(dtype=str)).astype(str).str.contains(\"error|reject|failed\", case=False, na=False).sum()) if not journal_df.empty else 0\n164:    if error_trade_count > int(parse_float(thresholds.get(\"paper_error_trade_count_cap\"), 0.0)):\n165:        issues.append({\"level\": \"RED\", \"code\": \"ERROR_TRADE_COUNT_BREACH\", \"value\": error_trade_count, \"limit\": thresholds.get(\"paper_error_trade_count_cap\")})\n176:    elif journal_records < observation_days:\n189:            \"journal\": str(journal_path),\n197:            \"planned_orders\": int(len(orders_df)),\n198:            \"journal_records\": journal_records,\n221:        f\"- 日志记录数: `{journal_records}`\",\n233:            md_lines.append(f\"- [{item['level']}] `{item['code']}` value=`{item['value']}` limit=`{item['limit']}`\")"}],"details":{"status":"completed","exitCode":0,"durationMs":47,"aggregated":"45:    pattern = f\"paper_{profile_slug}_trading_journal_*.csv\" if profile_slug else \"paper_trading_journal_*.csv\"\n91:        proc = subprocess.run(cmd