{"type":"message","id":"a87ef6c1","parentId":"d119e936","timestamp":"2026-03-30T03:49:30.927Z","message":{"role":"toolResult","toolCallId":"call_function_f7jfzcbxm4ct_1","toolName":"exec","content":[{"type":"text","text":")\n    proc = subprocess.run(\n        [\n            sys.executable,\n            str(script),\n            \"--level\",\n            \"ERROR\",\n            \"--title\",\n            f\"event_watch_refresh_failed({date_tag})\",\n            \"--text\",\n            text,\n        ],\n        cwd=str(PROJECT_ROOT),\n        capture_output=True,\n        text=True,\n    )\n    payload: dict[str, Any] = {\n        \"sent\": proc.returncode == 0,\n        \"returncode\": int(proc.returncode),\n        \"stdout\": str(proc.stdout or \"\").strip(),\n        \"stderr\": str(proc.stderr or \"\").strip(),\n        \"sent_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n    }\n    return payload\n\n\ndef handle_event_watch_failure(date_tag: str, refresh: dict[str, Any]) -> dict[str, Any]:\n    if not refresh.get(\"ran\"):\n        return {\"escalated\": False, \"reason\": \"event_watch_not_run\"}\n    if bool(refresh.get(\"ok\")):\n        return {\"escalated\": False, \"reason\": \"event_watch_ok\"}\n\n    detail = str(refresh.get(\"stderr\") or \"\").strip()\n    if not detail:\n        outputs = refresh.get(\"outputs\") or []\n        detail = \" | \".join(str(item) for item in outputs[:5])\n\n    tracker_payload = live_chain_failure_mod.record_event(\n        date_tag=date_tag,\n        stage=\"event_watch_refresh\",\n        severity=\"RED\",\n        reason=\"event_watch_refresh_failed\",\n        detail=detail[:1200],\n        blocking=True,\n        source=\"run_intraday_risk_recheck\",\n        report_dir=REPORT_DIR,\n    )\n    incident_registry_mod.sync_registry(write=True)\n    alert_payload = send_event_watch_alert(date_tag, refresh)\n    return {\n        \"escalated\": True,\n        \"tracker_summary\": {\n            \"overall_status\": tracker_payload.get(\"overall_status\"),\n            \"event_count\": tracker_payload.get(\"event_count\"),\n            \"latest_path\": tracker_payload.get(\"latest_path\"),\n            \"reason\": tracker_payload.get(\"reason\"),\n        },\n        \"alert\": alert_payload,\n    }\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"盘中风险复检\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--config\", default=str(LIVE_CONFIG_PATH), help=\"live trading config\")\n    args = parser.parse_args()\n\n    date_tag = parse_date_tag(args.date) if args.date else datetime.now().strftime(\"%Y%m%d\")\n    config_path = Path(args.config).expanduser().resolve()\n    config = load_json(config_path)\n\n    runtime_metrics = load_runtime_metrics_for_date(date_tag, config, report_dir=REPORT_DIR)\n    runtime = evaluate_runtime_state_for_date(\n        config=config,\n        live_payload=runtime_metrics[\"live_payload\"],\n        date_tag=date_tag,\n        index_ret_pct=float(runtime_metrics.get(\"index_ret_pct\", 0.0) or 0.0),\n        market_breadth=runtime_metrics.get(\"market_breadth\"),\n    )\n    base_runtime = runtime_to_dict(\n        runtime,\n        benchmark_code=str(runtime_metrics.get(\"benchmark_code\") or \"\"),\n        index_ret_pct=float(runtime_metrics.get(\"index_ret_pct\", 0.0) or 0.0),\n    )\n    regime_snapshots = compute_regime_snapshots(\n        config,\n        date_tag=date_tag,\n        benchmark_code=str(runtime_metrics.get(\"benchmark_code\") or \"\") or None,\n        market_breadth=float(runtime_metrics.get(\"market_breadth\", 0.0) or 0.0),\n    )\n    base_overlay = apply_regime_overlays(\n        mode=str(base_runtime.get(\"mode\") or \"normal\"),\n        risk_off=bool(base_runtime.get(\"risk_off\")),\n        hard_stop=bool(base_runtime.get(\"hard_stop\")),\n        halt_new_buy=bool(base_runtime.get(\"halt_new_buy\")),\n        gate_reasons=base_runtime.get(\"gate_reasons\") or [],\n        volatility_snapshot=regime_snapshots.get(\"volatility\"),\n        liquidity_snapshot=regime_snapshots.get(\"liquidity\"),\n    )\n    base_runtime.update(base_overlay)\n    base_runtime[\"volatility_snapshot\"] = regime_snapshots.get(\"volatility\")"}],"details":{"status":"completed","exitCode":0,"durationMs":36,"aggregated":")\n    proc = subprocess.run(\n        [\n            sys.executable,\n            str(script),\n            \"--level\",\n            \"ERROR\",\n            \"--title\",\n            f\"event_watch_refresh_failed({date_tag})\",\n            \"--text\",\n            text,\n        ],\n        cwd=str(PROJECT_ROOT),\n        capture_output=True,\n        text=True,\n    )\n    payload: dict[str, Any] = {\n        \"sent\": proc.returncode == 0,\n        \"returncode\": int(proc.returncode),\n        \"stdout\": str(proc.stdout or \"\").strip(),\n        \"stderr\": str(proc.stderr or \"\").strip(),\n        \"sent_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n    }\n    return payload\n\n\ndef handle_event_watch_failure(date_tag: str, refresh: dict[str, Any]) -> dict[str, Any]:\n    if not refresh.get(\"ran\"):\n        return {\"escalated\": False, \"reason\": \"event_watch_not_run\"}\n    if bool(refresh.get(\"ok\")):\n        return {\"escalated\": False, \"reason\": \"event_watch_ok\"}\n\n    detail = str(refresh.get(\"stderr\") or \"\").strip()\n    if not detail:\n        outputs = refresh.get(\"outputs\") or []\n        detail = \" | \".join(str(item) for item in outputs[:5])\n\n    tracker_payload = live_chain_failure_mod.record_event(\n        date_tag=date_tag,\n        stage=\"event_watch_refresh\",\n        severity=\"RED\",\n        reason=\"event_watch_refresh_failed\",\n        detail=detail[:1200],\n        blocking=True,\n        source=\"run_intraday_risk_recheck\",\n        report_dir=REPORT_DIR,\n    )\n    incident_registry_mod.sync_registry(write=True)\n    alert_payload = send_event_watch_alert(date_tag, refresh)\n    return {\n        \"escalated\": True,\n        \"tracker_summary\": {\n            \"overall_status\": tracker_payload.get(\"overall_status\"),\n            \"event_count\": tracker_payload.get(\"event_count\"),\n            \"latest_path\": tracker_payload.get(\"latest_path\"),\n            \"reason\": tracker_payload.get(\"reason\"),\n        },\n        \"alert\": alert_payload,\n    }\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"盘中风险复检\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--config\", default=str(LIVE_CONFIG_PATH), help=\"live trading config\")\n    args = parser.parse_args()\n\n    date_tag = parse_date_tag(args.date) if args.date else datetime.now().strftime(\"%Y%m%d\")\n    config_path = Path(args.config).expanduser().resolve()\n    config = load_json(config_path)\n\n    runtime_metrics = load_runtime_metrics_for_date(date_tag, config, report_dir=REPORT_DIR)\n    runtime = evaluate_runtime_state_for_date(\n        config=config,\n        live_payload=runtime_metrics[\"live_payload\"],\n        date_tag=date_tag,\n        index_ret_pct=float(runtime_metrics.get(\"index_ret_pct\", 0.0) or 0.0),\n        market_breadth=runtime_metrics.get(\"market_breadth\"),\n    )\n    base_runtime = runtime_to_dict(\n        runtime,\n        benchmark_code=str(runtime_metrics.get(\"benchmark_code\") or \"\"),\n        index_ret_pct=float(runtime_metrics.get(\"index_ret_pct\", 0.0) or 0.0),\n    )\n    regime_snapshots = compute_regime_snapshots(\n        config,\n        date_tag=date_tag,\n        benchmark_code=str(runtime_metrics.get(\"benchmark_code\") or \"\") or None,\n        market_breadth=float(runtime_metrics.get(\"market_breadth\", 0.0) or 0.0),\n    )\n    base_overlay = apply_regime_overlays(\n        mode=str(base_runtime.get(\"mode\") or \"normal\"),\n        risk_off=bool(base_runtime.get(\"risk_off\")),\n        har