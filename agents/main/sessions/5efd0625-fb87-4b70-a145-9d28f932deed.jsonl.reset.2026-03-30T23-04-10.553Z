{"type":"message","id":"02e0390f","parentId":"e8b560c9","timestamp":"2026-03-30T03:49:21.173Z","message":{"role":"toolResult","toolCallId":"call_function_vo32abc0yozc_1","toolName":"exec","content":[{"type":"text","text":"base_runtime[\"volatility_snapshot\"] = regime_snapshots.get(\"volatility\")\n    base_runtime[\"liquidity_snapshot\"] = regime_snapshots.get(\"liquidity\")\n    base_runtime[\"runtime_truth\"] = build_runtime_truth(\n        mode=str(base_runtime.get(\"mode\") or \"\"),\n        risk_off=bool(base_runtime.get(\"risk_off\")),\n        hard_stop=bool(base_runtime.get(\"hard_stop\")),\n        halt_new_buy=bool(base_runtime.get(\"halt_new_buy\")),\n        halt_reason=str(base_runtime.get(\"halt_reason\") or \"\"),\n        gate_reasons=base_runtime.get(\"gate_reasons\") or [],\n        source=\"run_intraday_risk_recheck_base\",\n    )\n\n    intraday_gate = get_intraday_market_state(date_tag)\n    intraday_breadth = fetch_intraday_breadth() if intraday_gate.get(\"enabled\") else {\"available\": False, \"reason\": \"gate_disabled\"}\n    intraday_runtime = dict(base_runtime)\n    intraday_runtime[\"intraday_gate_applied\"] = False\n\n    risk_cfg = config.get(\"risk\") or {}\n    breadth_hard_stop = float(risk_cfg.get(\"market_breadth_hard_stop_threshold\", 0.25) or 0.25)\n    breadth_riskoff = float(risk_cfg.get(\"market_breadth_riskoff_threshold\", 0.35) or 0.35)\n    breadth_available = bool(intraday_breadth.get(\"available\"))\n    breadth_ratio = intraday_breadth.get(\"up_ratio\")\n\n    # 即使盘中门禁未启用（午间休市等），若预市场宽度极低也应触发谨慎\n    # 注意：runtime_metrics.market_breadth 与 paper_execution.market_breadth 可能来自不同数据源\n    # 两者都低于阈值时应统一触发 halt，避免 event_watch 与 runtime_risk_state 状态不一致\n    if not intraday_gate.get(\"enabled\"):\n        runtime_breadth = runtime_metrics.get(\"market_breadth\")\n        if runtime_breadth is not None and runtime_breadth < breadth_hard_stop:\n            intraday_runtime.update(\n                {\n                    \"mode\": \"halt\",\n                    \"risk_off\": True,\n                    \"hard_stop\": True,\n                    \"halt_new_buy\": True,\n                    \"halt_reason\": f\"市场宽度 {runtime_breadth:.3f} <= {breadth_hard_stop:.3f}，盘中门禁未启用但宽度极低\",\n                    \"intraday_gate_applied\": False,\n                    \"market_breadth\": runtime_breadth,\n                }\n            )\n            intraday_runtime[\"gate_reasons\"] = [\"premarket_breadth_hard_stop\"]\n\n    if intraday_gate.get(\"enabled\"):\n        gate_action = intraday_gate.get(\"gate_action\", \"none\")\n\n        if gate_action == \"halt\":\n            intraday_runtime.update(\n                {\n                    \"mode\": \"halt\",\n                    \"risk_off\": True,\n                    \"hard_stop\": True,\n                    \"halt_new_buy\": True,\n                    \"halt_reason\": f\"盘中门禁触发 halt: {intraday_gate.get('reason', '')}\",\n                    \"intraday_gate_applied\": True,\n                    \"market_breadth\": breadth_ratio if breadth_available else None,\n                }\n            )\n            intraday_runtime[\"gate_reasons\"] = list(dict.fromkeys((intraday_runtime.get(\"gate_reasons\") or []) + [\"intraday_market_halt\"]))\n        else:\n            # 非 halt 时，盘中宽度缺失不再一刀切 halt，而是回退到更保守但可持续的状态。\n            if not breadth_available:\n                base_mode = str(intraday_runtime.get(\"mode\") or \"normal\")\n                if base_mode == \"halt\" or bool(intraday_runtime.get(\"hard_stop\")):\n                    intraday_runtime[\"intraday_gate_applied\"] = True\n                    intraday_runtime[\"gate_reasons\"] = list(\n                        dict.fromkeys((intraday_runtime.get(\"gate_reasons\") or []) + [\"intraday_breadth_unavailable_keep_base\"])\n                    )\n                elif gate_action == \"cautious\":\n                    intraday_runtime.update(\n                        {\n                            \"mode\": \"cautious\",\n                            \"risk_off\": True,\n                            \"hard_stop\": False,\n                            \"halt_new_buy\": False,\n                            \"halt_reason\": \"盘中宽度不可用，按指数门禁进入 cautious\",\n                            \"intraday_gate_applied\": True,\n                        }\n                    )\n                    intraday_runtime[\"gate_reasons\"] = list(\n                        dict.fromkeys((intraday_runtime.get(\"gate_reasons\") or []) + [\"intraday_breadth_unavailable_cautious\"])\n                    )\n                else:\n                    # gate_action == \"none\" 但盘中宽度不可用时，\n                    # 为防止误在正常模式自动买入，应降至 cautious\n                    base_mode = str(intraday_runtime.get(\"mode\") or \"normal\")\n                    intraday_runtime.update(\n                        {\n                            \"mode\": \"cautious\" if base_mode == \"normal\" else base_mode,\n                            \"risk_off\": True,\n                            \"hard_stop\": False,\n                            \"halt_new_buy\": False,\n                            \"halt_reason\": \"盘中宽度不可用，禁止激进自动操作\",\n                            \"intraday_gate_applied\": True,\n                        }\n                    )\n                    intraday_runtime[\"gate_reasons\"] = list(\n                        dict.fromkeys((intraday_runtime.get(\"gate_reasons\") or []) + [\"intraday_breadth_unavailable_cautious\"])\n                    )\n            else:\n                intraday_runtime[\"market_breadth\"] = breadth_ratio\n                if breadth_ratio is not None and breadth_ratio <= breadth_hard_stop:"}],"details":{"status":"completed","exitCode":0,"durationMs":36,"aggregated":"base_runtime[\"volatility_snapshot\"] = regime_snapshots.get(\"volatility\")\n    base_runtime[\"liquidity_snapshot\"] = regime_snapshots.get(\"liquidity\")\n    base_runtime[\"runtime_truth\"] = build_runtime_truth(\n        mode=s