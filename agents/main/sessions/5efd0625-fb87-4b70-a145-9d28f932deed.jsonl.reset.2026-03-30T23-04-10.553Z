{"type":"message","id":"489309c0","parentId":"3e1cf53f","timestamp":"2026-03-30T13:49:38.540Z","message":{"role":"toolResult","toolCallId":"call_function_98g37fyscti0_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n方案A: 用现有预测数据跑2023~2026纯样本外回测\n- 预测数据来自 ml_predictions.csv（含2023-2026预测）\n- 局限性：模型训练时见过2021~2022数据，但2023~2026预测结果本身是\"训练后预测\"\n- 等同于\"模型从未在2023~2026做过决策学习\"的样本外验证\n\"\"\"\nimport sys, os\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport multiprocessing as mp\nmp.freeze_support()\n\nimport pandas as pd\nimport numpy as np\nfrom pathlib import Path\n\nREPORT_DIR = Path(__file__).resolve().parents[1] / \"research\" / \"reports\"\nREPORT_DIR.mkdir(parents=True, exist_ok=True)\n\nPAPER_CAPITAL = 1_000_000.0\nTODAY_STR = \"20260322\"\n\n\ndef compute_oos_backtest():\n    \"\"\"用已有预测数据跑2023~2026样本外回测\"\"\"\n    import run_qlib_breadth_sanity_check as sanity\n    import run_qlib_breadth_long_turnover_hardcap_relaxed_scan as base_scan\n    from qlib.config import C\n    C[\"joblib_backend\"] = \"sequential\"\n    C[\"kernels\"] = 1\n\n    # 加载预测数据\n    preds = pd.read_csv(\n        REPORT_DIR.parents[1] / \"data\" / \"ml_dataset_full\" / \"ml_predictions.csv\"\n    )\n    preds[\"date\"] = pd.to_datetime(preds[\"date\"])\n    preds = preds.sort_values([\"date\", \"pred_rank\"], ascending=[True, False])\n\n    # 过滤到测试区间 2023-01-03 ~ 2026-03-03"}],"details":{"status":"completed","exitCode":0,"durationMs":45,"aggregated":"#!/usr/bin/env python3\n\"\"\"\n方案A: 用现有预测数据跑2023~2026纯样本外回测\n- 预测数据来自 ml_predictions.csv（含2023-2026预测）\n- 局限性：模型训练时见过2021~2022数据，但2023~2026预测结果本身是\"训练后预测\"\n- 等同于\"模型从未在2023~2026做过决策学习\"的样本外验证\n\"\"\"\nimport sys, os\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport multiprocessing as mp\nmp.freeze_support()\n\nimport pandas as pd\nimport numpy as np\nfrom pathlib import Path\n\nREPORT_DIR = Path(__file__).resolve().parents[1] / \"research\" / \"reports\"\nREPORT_DIR.mkdir(parents=True, exist_ok=True)\n\nPAPER_CAPITAL = 1_000_000.0\nTODAY_STR = \"20260322\"\n\n\ndef compute_oos_backtest():\n    \"\"\"用已有预测数据跑2023~2026样本外回测\"\"\"\n    import run_qlib_breadth_sanity_check as sanity\n    import run_qlib_breadth_long_turnover_hardcap_relaxed_scan as base_scan\n    from qlib.config import C\n    C[\"joblib_backend\"] = \"sequential\"\n    C[\"kernels\"] = 1\n\n    # 加载预测数据\n    preds = pd.read_csv(\n        REPORT_DIR.parents[1] / \"data\" / \"ml_dataset_full\" / \"ml_predictions.csv\"\n    )\n    preds[\"date\"] = pd.to_datetime(preds[\"date\"])\n    preds = preds.sort_values([\"date\", \"pred_rank\"], ascending=[True, False])\n\n    # 过滤到测试区间 2023-01-03 ~ 2026-03-03","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774878578524}}
