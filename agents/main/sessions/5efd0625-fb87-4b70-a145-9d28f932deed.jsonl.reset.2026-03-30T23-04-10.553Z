_pct\": index_ret_pct,\n            \"strategy_max_dd_pct\": strategy_max_dd_pct,\n            \"strategy_sharpe\": strategy_sharpe,\n            \"style_snapshot\": style_snapshot,\n            \"source\": str(live_system_path) if live_system_path is not None else f\"dated_runtime:{date_tag}\",\n        }\n    )\n    return payload\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser()\n    ap.add_argument(\"--input\", required=True, help=\"merged signal csv\")\n    ap.add_argument(\"--trade-date\", required=True)\n    ap.add_argument(\"--account-nav\", type=float, default=1000000)\n    ap.add_argument(\"--available-cash\", type=float, default=1000000)\n    ap.add_argument(\"--market-breadth\", type=float, default=None)\n    ap.add_argument(\"--index-ret-pct\", type=float, default=None)\n    ap.add_argument(\"--strategy-max-dd-pct\", type=float, default=None)\n    ap.add_argument(\"--strategy-sharpe\", type=float, default=None)\n    ap.add_argument(\"--risk-off\", action=\"store_true\")\n    ap.add_argument(\"--hard-stop\", action=\"store_true\")\n    ap.add_argument(\"--risk-config\", type=str, default=None, help=\"path to risk config JSON\")\n    ap.add_argument(\"--live-config\", type=str, default=str(DEFAULT_LIVE_CONFIG_PATH), help=\"path to live config JSON\")\n    ap.add_argument(\"--holdings\", type=str, default=\"\", help=\"optional holdings csv for exit engine\")\n    ap.add_argument(\"--trade-history\", type=str, default=\"\", help=\"optional trade history csv for exit engine\")\n    ap.add_argument(\"--approved-output\", type=str, default=\"\", help=\"optional approved signals output csv\")\n    ap.add_argument(\"--orders-output\", type=str, default=\"\", help=\"optional proposed orders output csv\")\n    args = ap.parse_args()\n\n    input_path = Path(args.input)\n    if not input_path.exists():\n        raise FileNotFoundError(input_path)\n\n    merged = validate_signal_frame(\n        pd.read_csv(input_path),\n        context=f\"apply_risk_to_merged_signals:{input_path.name}\",\n    )\n    live_config_path = Path(args.live_config).expanduser().resolve() if args.live_config else None\n    live_config = load_json(live_config_path)\n    risk_payload = load_json(Path(args.risk_config).expanduser().resolve()) if args.risk_config else {}\n    runtime_inputs = enrich_runtime_inputs(\n        trade_date=args.trade_date,\n        live_config=live_config,\n        market_breadth=args.market_breadth,\n        index_ret_pct=args.index_ret_pct,\n        strategy_max_dd_pct=args.strategy_max_dd_pct,\n        strategy_sharpe=args.strategy_sharpe,\n    )\n\n    engine = RiskEngine(build_risk_config(risk_payload, live_config=live_config))\n    context = RiskContext(\n        trade_date=args.trade_date,\n        market_breadth=runtime_inputs[\"market_breadth\"],\n        risk_off=args.risk_off,\n        hard_stop=args.hard_stop,\n        available_cash=args.available_cash,\n        account_nav=args.account_nav,\n        index_ret_pct=runtime_inputs[\"index_ret_pct\"],\n        strategy_max_drawdown_pct=runtime_inputs[\"strategy_max_dd_pct\"],\n        strategy_sharpe=runtime_inputs[\"strategy_sharpe\"],\n        style_smallcap_short_return_pct=parse_float(\n            (runtime_inputs.get(\"style_snapshot\") or {}).get(\"smallcap_short_return_pct\"),\n            0.0,\n        ) if (runtime_inputs.get(\"style_snapshot\") or {}).get(\"smallcap_short_return_pct\") is not None else None,\n        style_smallcap_medium_return_pct=parse_float(\n            (runtime_inputs.get(\"style_snapshot\") or {}).get(\"smallcap_medium_return_pct\"),\n            0.0,\n        ) if (runtime_inputs.get(\"style_snapshot\") or {}).get(\"smallcap_medium_return_pct\") is not None else None,\n        style_short_excess_pct=parse_float("}],"details":{"status":"completed","exitCode":0,"durationMs":38,"aggregated":"index_ret_pct: float | None,\n    strategy_max_dd_pct: float | None,\n    strategy_sharpe: float | None,\n) -> dict[str, Any]:\n    date