ecution_attempted\", 0),\n        \"live_pending_confirm_not_sent\": (live_review.get(\"orders\") or {}).get(\"pending_confirm_not_sent\", 0),\n        \"live_not_sent\": (live_review.get(\"orders\") or {}).get(\"not_sent\", 0),\n        \"live_journal_records\": (live_review.get(\"journal\") or {}).get(\"records\", 0),\n    }\n\n    profit_layer = {\n        \"profiles\": perf_panel.get(\"rows\", []),\n        \"breadth_alert\": {\n            \"status\": breadth_alert.get(\"status\", \"NO_DATA\"),\n            \"issue_codes\": [str(x.get(\"code\", \"\")) for x in (breadth_alert.get(\"issues\") or []) if x.get(\"code\")],\n            \"actual_position_pct\": breadth_alert.get(\"actual_position_pct\"),\n            \"target_position_pct\": breadth_alert.get(\"target_position_pct\"),\n            \"target_drift_pct\": breadth_alert.get(\"target_drift_pct\"),\n            \"daily_nav_change_pct\": breadth_alert.get(\"daily_nav_change_pct\"),\n            \"max_drawdown_pct\": breadth_alert.get(\"max_drawdown_pct\"),\n            \"captured_at\": breadth_alert.get(\"captured_at\", \"\"),\n            \"signal_date\": breadth_alert.get(\"signal_date\", \"\"),\n            \"stale\": bool(breadth_alert.get(\"stale\", False)),\n            \"stale_reason\": str(breadth_alert.get(\"stale_reason\") or \"\"),\n        },\n        \"future_leak_audit\": {\n            \"passed\": bool(future_leak_audit.get(\"passed\", False)) if future_leak_audit else None,\n            \"issues\": future_leak_audit.get(\"issues\", []) if future_leak_audit else [],\n            \"window_count\": future_leak_audit.get(\"aggressive_window_count\"),\n        },\n        \"recent_interventions\": intervention_rows,\n        \"manual_review_summary\": manual_review_summary,\n        \"premarket_runtime_truth\": premarket_review.get(\"runtime_truth\") or {},\n        \"governance_summary\": governance_summary,\n    }\n\n    return {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H: