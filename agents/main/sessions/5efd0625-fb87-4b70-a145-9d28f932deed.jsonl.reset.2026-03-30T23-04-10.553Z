ay_runtime,\n    }\n\n    dated_path = REPORT_DIR / f\"intraday_risk_recheck_{date_tag}_{now_hhmm()}.json\"\n    latest_path = REPORT_DIR / \"runtime_risk_state_latest.json\"\n    previous_payload = load_json(latest_path) if latest_path.exists() else {}\n    dated_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    latest_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    ensure_log_header()\n    payload[\"intervention_logged\"] = maybe_append_manual_intervention(\n        payload=payload,\n        previous_payload=previous_payload,\n        source=\"run_intraday_risk_recheck\",\n    )\n    payload[\"intervention_audit\"] = write_intervention_audit_report(payload=payload)\n    dated_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    latest_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    event_watch_refresh = refresh_event_watch()\n    if event_watch_refresh:\n        payload[\"event_watch_refresh\"] = event_watch_refresh\n        payload[\"event_watch_escalation\"] = handle_event_watch_failure(date_tag, event_watch_refresh)\n        dated_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n        latest_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    print(\n        json.dumps(\n            {\n                \"status\": \"PASS\",\n                \"date_tag\": date_tag,\n                \"dated_report\": str(dated_path),\n                \"latest_report\": str(latest_path),"}],"details":{"status":"completed","exitCode":0,"durationMs":47,"aggregated":"hard_stop=bool(intraday_runtime.get(\"hard_stop\")),\n        halt_new_buy=bool(intraday_runtime.get(\"halt_new_buy\")),\n        halt_reason=str(intraday_runtime.get(\"halt_reason\") or \"\"),\n        gate_reasons=intraday_runtime.get(\"gate_reasons\") or [],\n        source