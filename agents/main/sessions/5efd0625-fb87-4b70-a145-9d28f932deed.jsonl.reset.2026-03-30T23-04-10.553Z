{"type":"message","id":"94aa4d74","parentId":"47bf5a17","timestamp":"2026-03-30T13:50:45.106Z","message":{"role":"toolResult","toolCallId":"call_function_5e9iph2xi2py_1","toolName":"exec","content":[{"type":"text","text":"# 目标变量：未来5日收益\n        stock['future_return'] = close.shift(-5) / close - 1\n        \n        stock['symbol'] = symbol\n        features_list.append(stock)\n    \n    if not features_list:\n        print(\"警告: 没有有效的特征数据\")\n        return None\n        \n    full_df = pd.concat(features_list, ignore_index=True)\n    print(f\"特征构建完成，有效行数: {len(full_df):,}\")\n    \n    return full_df\n\ndef train_model(full_df):\n    \"\"\"训练ML模型\"\"\"\n    print(\"\\n正在训练ML模型...\")\n    \n    # 过滤有效数据\n    valid_cols = ['date', 'symbol', 'ret_1', 'ret_5', 'ret_10', 'ret_20', 'ret_60',\n                  'vol_5', 'vol_20', 'vol_ratio', 'price_position', 'ma_trend', 'future_return']\n    full_df = full_df[[c for c in valid_cols if c in full_df.columns]]\n    full_df = full_df.dropna()\n    \n    # 分割训练集和测试集\n    train_data = full_df[full_df['date'] < TRAIN_END].copy()\n    test_data = full_df[full_df['date'] >= TEST_START].copy()\n    \n    print(f\"训练集: {len(train_data):,} 行, {train_data['date'].min()} ~ {train_data['date'].max()}\")\n    print(f\"测试集: {len(test_data):,} 行, {test_data['date'].min()} ~ {test_data['date'].max()}\")"}],"details":{"status":"completed","exitCode":0,"durationMs":37,"aggregated":"# 目标变量：未来5日收益\n        stock['future_return'] = close.shift(-5) / close - 1\n        \n        stock['symbol'] = symbol\n        features_list.append(stock)\n    \n    if not features_list:\n        print(\"警告: 没有有效的特征数据\")\n        return None\n        \n    full_df = pd.concat(features_list, ignore_index=True)\n    print(f\"特征构建完成，有效行数: {len(full_df):,}\")\n    \n    return full_df\n\ndef train_model(full_df):\n    \"\"\"训练ML模型\"\"\"\n    print(\"\\n正在训练ML模型...\")\n    \n    # 过滤有效数据\n    valid_cols = ['date', 'symbol', 'ret_1', 'ret_5', 'ret_10', 'ret_20', 'ret_60',\n                  'vol_5', 'vol_20', 'vol_ratio', 'price_position', 'ma_trend', 'future_return']\n    full_df = full_df[[c for c in valid_cols if c in full_df.columns]]\n    full_df = full_df.dropna()\n    \n    # 分割训练集和测试集\n    train_data = full_df[full_df['date'] < TRAIN_END].copy()\n    test_data = full_df[full_df['date'] >= TEST_START].copy()\n    \n    print(f\"训练集: {len(train_data):,} 行, {train_data['date'].min()} ~ {train_data['date'].max()}\")\n    print(f\"测试集: {len(test_data):,} 行, {test_data['date'].min()} ~ {test_data['date'].max()}\")","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774878645094}}
