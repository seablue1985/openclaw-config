s\") or \"RED\"),\n        \"path\": str(audit.get(\"latest_path\") or path),\n        \"mtime\": mtime,\n        \"reason\": str(audit.get(\"reason\") or \"unknown\"),\n    }\n\n\ndef resolve_nextday_handoff_state(\n    live_review: dict[str, Any],\n    *,\n    expected_date_tag: str,\n) -> dict[str, Any]:\n    handoff = live_review.get(\"nextday_manual_sell_handoff\")\n    handoff_path = \"\"\n    payload: dict[str, Any] = {}\n    if isinstance(handoff, dict):\n        handoff_path = str(handoff.get(\"json_path\") or \"\").strip()\n        if handoff_path:\n            path = Path(handoff_path)\n            if path.exists():\n                payload = load_json(path)\n            else:\n                payload = {}\n        else:\n            payload = handoff\n\n    if not payload:\n        candidate = REPORT_DIR / f\"live_nextday_manual_sell_handoff_{expected_date_tag}.json\"\n        if candidate.exists():\n            payload = load_json(candidate)\n            handoff_path = str(candidate)\n\n    ack = payload.get(\"receiver_ack\") or {}\n    ack_status = str(ack.get(\"status\") or \"\").strip().upper()\n    ack_owner = str(ack.get(\"owner\") or \"\").strip()\n    ack_time = str(ack.get(\"timestamp\") or \"\").strip()\n    ack_action = str(ack.get(\"action\") or \"\").strip()","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774842542872}}
