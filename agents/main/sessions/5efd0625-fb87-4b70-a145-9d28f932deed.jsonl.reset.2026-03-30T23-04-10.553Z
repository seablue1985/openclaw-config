{"type":"message","id":"84e2bef4","parentId":"9f0fa829","timestamp":"2026-03-30T12:54:54.364Z","message":{"role":"toolResult","toolCallId":"call_function_cf6j74lxzskt_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n微博财经大V监控 - 定时推送脚本\n每天两次：08:30（盘前） 和 20:00（收盘后）\n\"\"\"\nimport json, os, subprocess, sys\nfrom datetime import datetime\nfrom pathlib import Path\n\n# ── 配置 ────────────────────────────────────────────────────────────────────\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"weibo_monitor_reports\"\nSTATE_FILE = WORKSPACE / \"weibo_monitor_state.json\"\nCONFIG_FILE = WORKSPACE / \"config\" / \"investment_research_delivery_v1.json\"\n\nFEISHU_TARGET = \"chat:oc_8a819be3a90d35b8d0a2d5c1f4642b22\"  # 来福研讨会群\nOPENCLAW_BIN = str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"aliases\" / \"default\" / \"bin\" / \"openclaw\")\n\nsys.path.insert(0, str(Path(__file__).parent))\nfrom fetch_and_report import fetch_all_kols, build_report, save_state\n\n# ── 工具 ─────────────────────────────────────────────────────────────────────\n\ndef send_feishu(message: str, dry_run: bool = False) -> tuple:\n    # cron 环境 PATH 不含 fnm node 路径，需要显式传入\n    fnm_bin = str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"node-versions\" / \"v22.22.0\" / \"installation\" / \"bin\")\n    env = {**os.environ, \"PATH\": f\"{fnm_bin}:{os.environ.get('PATH', '')}\"}\n    cmd = [\n        OPENCLAW_BIN,\n        \"message\", \"send\",\n        \"--channel\", \"feishu\",\n        \"--target\", FEISHU_TARGET,\n        \"-m\", message,\n    ]\n    if dry_run:\n        cmd.append(\"--dry-run\")\n    try:\n        result = subprocess.run(cmd, capture_output=True, text=True, timeout=60, env=env)\n        return result.returncode == 0, result.stdout[:500] or result.stderr[:500]\n    except Exception as e:\n        return False, str(e)\n\n# ── 主程序 ──────────────────────────────────────────────────────────────────\n\ndef main():\n    now = datetime.now()\n    is_morning = len(sys.argv) > 1 and sys.argv[1] == \"morning\"\n    label = \"🌅 早间版\" if is_morning else \"📘 晚间版\"\n\n    print(f\"\\n{'='*60}\")"}],"details":{"status":"completed","exitCode":0,"durationMs":29,"aggregated":"#!/usr/bin/env python3\n\"\"\"\n微博财经大V监控 - 定时推送脚本\n每天两次：08:30（盘前） 和 20:00（收盘后）\n\"\"\"\nimport json, os, subprocess, sys\nfrom datetime import datetime\nfrom pathlib import Path\n\n# ── 配置 ────────────────────────────────────────────────────────────────────\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"weibo_monitor_reports\"\nSTATE_FILE = WORKSPACE / \"weibo_monitor_state.json\"\nCONFIG_FILE = WORKSPACE / \"config\" / \"investment_research_delivery_v1.json\"\n\nFEISHU_TARGET = \"chat:oc_8a819be3a90d35b8d0a2d5c1f4642b22\"  # 来福研讨会群\nOPENCLAW_BIN = str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"aliases\" / \"default\" / \"bin\" / \"openclaw\")\n\nsys.path.insert(0, str(Path(__file__).parent))\nfrom fetch_and_report import fetch_all_kols, build_report, save_state\n\n# ── 工具 ─────────────────────────────────────────────────────────────────────\n\ndef send_feishu(message: str, dry_run: bool = False) -> tuple:\n    # cron 环境 PATH 不含 fnm node 路径，需要显式传入\n    fnm_bin = str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"node-versions\" / \"v22.22.0\" / \"installation\" / \"bin\")\n    env = {**os.environ, \"PATH\": f\"{fnm_bin}:{os.environ.get('PATH', '')}\"}\n    cmd = [\n        OPENCLAW_BIN,\n        \"message\", \"send\",\n        \"--channel\", \"feishu\",\n        \"--target\", FEISHU_TARGET,\n        \"-m\", message,\n    ]\n    if dry_run:\n        cmd.append(\"--dry-run\")\n    try:\n        result = subprocess.run(cmd, capture_output=True, text=True, timeout=60, env=env)\n        return result.returncode == 0, result.stdout[:500] or result.stderr[:500]\n    except Exception as e:\n        return False, str(e)\n\n# ── 主程序 ──────────────────────────────────────────────────────────────────\n\ndef main():\n    now = datetime.now()\n    is_morning = len(sys.argv) > 1 and sys.argv[1] == \"morning\"\n    label = \"🌅 早间版\" if is_morning else \"📘 晚间版\"\n\n    print(f\"\\n{'='*60}\")","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774875294345}}
