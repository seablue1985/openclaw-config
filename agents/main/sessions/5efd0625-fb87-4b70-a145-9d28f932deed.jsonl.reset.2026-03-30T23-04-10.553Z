{"type":"message","id":"4d425aba","parentId":"9e35dbbc","timestamp":"2026-03-30T03:55:15.005Z","message":{"role":"toolResult","toolCallId":"call_function_p00ys1qmgrxt_1","toolName":"exec","content":[{"type":"text","text":"df = pd.read_csv(path)\n    except Exception:\n        return 0\n    return int(len(df.index))\n\n\ndef build_order_diagnostics(\n    *,\n    profile_slug: str,\n    date_tag: str,\n    signal_materialization: dict[str, Any],\n    stats: dict[str, Any],\n    rows: list[dict[str, Any]],\n    runtime: Any,\n    state: dict[str, Any],\n) -> dict[str, Any]:\n    candidate_orders_path = str(signal_materialization.get(\"candidate_orders\") or \"\").strip()\n    candidate_approved_path = str(signal_materialization.get(\"candidate_approved\") or \"\").strip()\n    candidate_tickets_path = str(signal_materialization.get(\"candidate_tickets\") or \"\").strip()\n    candidate_order_rows = csv_row_count(candidate_orders_path)\n    candidate_approved_rows = csv_row_count(candidate_approved_path)\n    candidate_ticket_rows = csv_row_count(candidate_tickets_path)\n    executable_rows = [\n        row for row in rows\n        if str(row.get(\"risk_gate\", \"\")).strip().lower() != \"blocked\"\n        and parse_int(row.get(\"suggest_qty\"), 0) > 0\n    ]\n    executable_buy_rows = [\n        row for row in executable_rows if str(row.get(\"side\", \"\")).strip().upper() == \"BUY\"\n    ]\n    executable_sell_rows = [\n        row for row in executable_rows if str(row.get(\"side\", \"\")).strip().upper() == \"SELL\"\n    ]\n\n    blocked_buy_total = sum(\n        int(parse_float(stats.get(key), 0.0))\n        for key in [\n            \"blocked_buy_halt\",\n            \"blocked_buy_no_price\",\n            \"blocked_buy_intraday_drop\",\n            \"blocked_buy_intraday_chase\",\n            \"blocked_buy_ai_overlay\",\n            \"blocked_buy_budget_cap\",\n            \"blocked_buy_lot\",\n            \"blocked_buy_liquidity\",\n        ]"}],"details":{"status":"completed","exitCode":0,"durationMs":32,"aggregated":"df = pd.read_csv(path)\n    except Exception:\n        return 0\n    return int(len(df.index))\n\n\ndef build_order_diagnostics(\n    *,\n    profile_slug: str,\n    date_tag: str,\n    signal_materialization: dict[str, Any],\n    stats: dict[str, Any],\n    rows: list[dict[str, Any]],\n    runtime: Any,\n    state: dict[str, Any],\n) -> dict[str, Any]:\n    candidate_orders_path = str(signal_materialization.get(\"candidate_orders\") or \"\").strip()\n    candidate_approved_path = str(signal_materialization.get(\"candidate_approved\") or \"\").strip()\n    candidate_tickets_path = str(signal_materialization.get(\"candidate_tickets\") or \"\").strip()\n    candidate_order_rows = csv_row_count(candidate_orders_path)\n    candidate_approved_rows = csv_row_count(candidate_approved_path)\n    candidate_ticket_rows = csv_row_count(candidate_tickets_path)\n    executable_rows = [\n        row for row in rows\n        if str(row.get(\"risk_gate\", \"\")).strip().lower() != \"blocked\"\n        and parse_int(row.get(\"suggest_qty\"), 0) > 0\n    ]\n    executable_buy_rows = [\n        row for row in executable_rows if str(row.get(\"side\", \"\")).strip().upper() == \"BUY\"\n    ]\n    executable_sell_rows = [\n        row for row in executable_rows if str(row.get(\"side\", \"\")).strip().upper() == \"SELL\"\n    ]\n\n    blocked_buy_total = sum(\n        int(parse_float(stats.get(key), 0.0))\n        for key in [\n            \"blocked_buy_halt\",\n            \"blocked_buy_no_price\",\n            \"blocked_buy_intraday_drop\",\n            \"blocked_buy_intraday_chase\",\n            \"blocked_buy_ai_overlay\",\n            \"blocked_buy_budget_cap\",\n            \"blocked_buy_lot\",\n            \"blocked_buy_liquidity\",\n        ]","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774842914982}}
