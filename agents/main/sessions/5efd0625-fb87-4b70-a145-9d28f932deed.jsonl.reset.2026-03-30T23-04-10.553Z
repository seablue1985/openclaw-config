th else {}\n    exit_suite_reports = sorted(REPORT_DIR.glob(\"paper_exit_candidate_suite_*.json\"))\n    manual_review_summary = aggregate_manual_review_state()\n    governance_summary = governance_gate_state()\n\n    system_checks = {\n        \"strategy_report\": file_state(REPORT_DIR / \"today_stock_strategy_report_latest.json\", stale_hours=72),\n        \"premarket_runtime_v2\": file_state(premarket_review_path, stale_hours=72) if premarket_review_path else {\"status\": \"YELLOW\", \"path\": \"\", \"mtime\": \"\", \"reason\": \"missing\"},\n        \"strategy_governance_gate\": {\n            \"status\": governance_summary[\"status\"],\n            \"path\": governance_summary[\"path\"],\n            \"mtime\": governance_summary[\"mtime\"],\n            \"reason\": governance_summary[\"reason\"],\n        },\n        \"guard_summary\": file_state(REPORT_DIR / \"strategy_probe_guard_summary_latest.json\", stale_hours=72),\n        \"performance_panel\": file_state(REPORT_DIR / \"strategy_performance_panel_latest.html\", stale_hours=72),\n        \"breadth_aggressive\": file_state(REPORT_DIR / \"breadth_aggressive_paper_latest.json\", stale_hours=72),\n        \"breadth_strict_oos\": file_state(REPORT_DIR / \"breadth_strict_oos_paper_latest.json\", stale_hours=72),\n        \"breadth_strict_oos_alert\": file_state(REPORT_DIR / \"breadth_strict_oos_alert_state.json\", stale_hours=72),\n        \"alpha55_account\": file_state(REPORT_DIR / \"paper_alpha55_account_v1_latest.json\", stale_hours=72),\n        \"exit_dual_account\": file_state(REPORT_DIR / \"paper_exit_dual_account_v1_latest.json\", stale_hours=72),\n        \"exit_tight_account\": file_state(REPORT_DIR / \"paper_exit_tight_account_v1_latest.json\", stale_hours=72),\n        \"exit_candidate_suite\": file_state(exit_suite_reports[-1], stale_hours=72) if exit_suite_reports else {\"status\": \"RED\", \"path\": \"\", \"mtime\": \"\", \"reason\": \"missing\"},\n        \"future_leak_walkforward_audit\": fi