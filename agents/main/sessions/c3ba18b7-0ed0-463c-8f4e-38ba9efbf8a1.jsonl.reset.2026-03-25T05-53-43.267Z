{"type":"message","id":"8c90f41c","parentId":"d0e6872f","timestamp":"2026-03-24T09:41:43.747Z","message":{"role":"toolResult","toolCallId":"call_yIjwK7YqZG7uUpVlBkOYzGa0|fc_0fb068e88b60a2b20169c25c56fdd48194957c09bb56511965","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n每日投研简报生成脚本\n按顺序调用5个角色，生成结构化投研简报\n\n时间线：\n  08:20 同步持仓\n  08:25 情报简报（aggregate_intelligence_brief.py）\n  08:30 宏观策略师 + 选股分析师 + 风控官 并行\n  08:35 组合优化师\n  08:40 投研简报 → 飞书推送\n  16:30 执行复盘师（收盘后）\n\"\"\"\n\nfrom __future__ import annotations\nimport json, sys, re, html as html_module\nfrom datetime import datetime, date\nfrom pathlib import Path\nfrom typing import Optional\n\n# ── 路径常量 ──────────────────────────────────────────────\nROOT = Path(__file__).resolve().parents[1]\nSYS_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system\")\nWORKSPACE = Path(\"/Users/ling/.openclaw/workspace\")\nREPORT_DIR = SYS_ROOT / \"research\" / \"reports\"\nORG_DIR = SYS_ROOT / \"research\" / \"org\"\nPROMPT_DIR = SYS_ROOT / \"prompts\" / \"org\"\nTREND_DIR = WORKSPACE / \"other_projects\" / \"TrendRadar\"\nWEIBO_DIR = WORKSPACE / \"skills\" / \"weibo-monitor\"\nFEISHU_WEBHOOK = \"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\"\n\ntoday = date.today()\ntoday_str = today.strftime(\"%Y%m%d\")\ndate_display = today.strftime(\"%Y年%m月%d日\")\n\n# ── Prompt 路径 ───────────────────────────────────────────\ndef load_prompt(name: str) -> str:\n    p = PROMPT_DIR / f\"{name}_prompt.md\"\n    if p.exists():\n        return p.read_text(encoding=\"utf-8\")\n    return f\"[Prompt文件不存在: {p}]\"\n\n# ── 工具函数 ──────────────────────────────────────────────\ndef load_json(path: Path) -> dict:\n    if not path.exists():\n        return {}\n    with open(path, encoding=\"utf-8\") as f:\n        return json.load(f)\n\ndef latest_file(pattern: str, directory: Path = REPORT_DIR) -> Optional[Path]:\n    files = sorted(directory.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)\n    return files[0] if files else None\n\ndef get_trendradar() -> dict:\n    \"\"\"读取今日 TrendRadar 彭博格式数据\"\"\"\n    today_txt_dir = TREND_DIR / \"output\" / today.strftime(\"%Y年%m月%d日\") / \"txt\"\n    items = []\n    if today_txt_dir.exists():\n        files = sorted(today_txt_dir.glob(\"*.txt\"), key=lambda p: p.stat().st_mtime, reverse=True)\n        if files:\n            content = files[0].read_text(encoding=\"utf-8\")\n            current_source = None\n            for line in content.split(\"\\n\"):\n                line = line.strip()\n                if not line:\n                    continue\n                if \" | \" in line and not line.startswith(\"http\") and not re.match(r\"^\\d+\\.\", line):\n                    parts = line.split(\" | \")\n                    if len(parts) == 2:\n                        current_source = parts[0].strip()\n                        continue\n                if current_source:\n                    m = re.match(r\"^\\d+\\.\\s+(.+?)\\s+\\[URL:(.+?)\\]$\", line)\n                    if m:\n                        title = re.sub(r\"<[^>]+>\", \"\", m.group(1))\n                        title = html_module.unescape(title).strip()\n                        items.append({\"title\": title, \"url\": m.group(2), \"source\": current_source})\n    return {\"items\": items, \"count\": len(items)}\n\ndef get_weibo_state() -> dict:\n\n[397 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1774345303735}}
