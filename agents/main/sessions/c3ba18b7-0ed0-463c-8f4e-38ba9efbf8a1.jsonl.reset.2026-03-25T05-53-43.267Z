{"type":"message","id":"c282663a","parentId":"55fdcf31","timestamp":"2026-03-24T09:41:21.873Z","message":{"role":"toolResult","toolCallId":"call_g2jX3ufIVkyB9Krphmj0HPid|fc_0fb068e88b60a2b20169c25c40e47c81948f5bbfc29bc525eb","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env bash\nset -euo pipefail\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\nWORKSPACE_ROOT=\"$(cd \"$ROOT/../..\" && pwd)\"\nREPORT_DIR=\"$ROOT/research/reports\"\nexport REPORT_DIR\ncd \"$ROOT\"\n\nexport LITELLM_LOCAL_MODEL_COST_MAP=true\n\nfor ENV_FILE in \\\n  \"$ROOT/.env.tushare\" \\\n  \"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis/.env.tushare\"\ndo\n  if [[ -f \"$ENV_FILE\" ]]; then\n    # shellcheck disable=SC1090\n    source \"$ENV_FILE\"\n  fi\ndone\n\nDATE_TAG=\"${1:-$(date +%Y%m%d)}\"\nTICKETS_FILE=\"${2:-}\"\nRETRY_MAX=\"${PAPER_PROFILES_RETRY_MAX:-2}\"\nRETRY_SLEEP_SEC=\"${PAPER_PROFILES_RETRY_SLEEP_SEC:-5}\"\nLIVE_SCHEDULER_CFG=\"$ROOT/config/live_scheduler_v1.json\"\nTODAY_TAG=\"$(date +%Y%m%d)\"\nLIVE_SYSTEM_FILE=\"$ROOT/research/reports/live_system_v1_${DATE_TAG}.json\"\nMERGED_FILE=\"$ROOT/signals/merged/merged_signals_${DATE_TAG}.csv\"\n\ncheck_runtime_halt_before_profiles() {\n  local runtime_file=\"$REPORT_DIR/runtime_risk_state_latest.json\"\n  if [[ ! -f \"$runtime_file\" ]]; then\n    return 0\n  fi\n  local halt\n  halt=\"$(python3 - \"$runtime_file\" \"$DATE_TAG\" <<'PY2'\nimport json, sys\nfrom pathlib import Path\np = Path(sys.argv[1])\ndate_tag = sys.argv[2]\nobj = json.loads(p.read_text(encoding=\"utf-8\"))\nlatest = obj.get(\"latest_runtime\") or {}\nif str(obj.get(\"date_tag\") or \"\") != str(date_tag):\n    print(\"0\")\nelse:\n    print(\"1\" if latest.get(\"halt_new_buy\") else \"0\")\nPY2\n)\"\n  if [[ \"$halt\" == \"1\" ]]; then\n    echo \"[BLOCK] runtime halt_new_buy=true; skip paper profile execution before account write\"\n    return 2\n  fi\n  return 0\n}\n\nread_live_sizing() {\n  python3 - \"$LIVE_SCHEDULER_CFG\" <<'PY'\nimport json\nimport sys\nfrom pathlib import Path\n\ncfg_path = Path(sys.argv[1])\npayload = json.loads(cfg_path.read_text(encoding=\"utf-8\")) if cfg_path.exists() else {}\nprint(payload.get(\"available_cash\", 1000000))\nprint(payload.get(\"account_nav\", payload.get(\"available_cash\", 1000000)))\nPY\n}\n\nensure_same_day_merged_signals() {\n  local sizing available_cash account_nav force_flag=\"\"\n  sizing=\"$(read_live_sizing)\"\n  available_cash=\"$(printf '%s\\n' \"$sizing\" | sed -n '1p')\"\n  account_nav=\"$(printf '%s\\n' \"$sizing\" | sed -n '2p')\"\n  if [[ \"${FORCE_REFRESH:-0}\" == \"1\" ]]; then\n    force_flag=\"--force-rebuild\"\n    echo \"[INFO] force rebuilding same-day merged signals date=${DATE_TAG}\"\n  else\n    echo \"[INFO] missing merged_signals, materializing same-day live signal chain date=${DATE_TAG}\"\n  fi\n  python3 scripts/prepare_live_signal_tickets.py \\\n    --date \"$DATE_TAG\" \\\n    --available-cash \"$available_cash\" \\\n    --account-nav \"$account_nav\" \\\n    $force_flag\n}\n\nensure_same_day_live_system() {\n  if [[ \"$DATE_TAG\" != \"$TODAY_TAG\" ]]; then\n    return 0\n  fi\n  if [[ \"${FORCE_REFRESH:-0}\" == \"1\" ]]; then\n    echo \"[INFO] force rebuilding same-day live system date=${DATE_TAG}\"\n  else\n    echo \"[INFO] missing live_system, materializing same-day live system date=${DATE_TAG}\"\n  fi\n  python3 scripts/run_live_system_v1.py\n}\n\nrun_once() {\n  if [[ -n \"$TICKETS_FILE\" ]]; then\n    bash scripts/run_paper_trading_profiles_v1.sh \"$DATE_TAG\" \"$TICKETS_FILE\"\n  else\n    bash scripts/run_paper_trading_profiles_v1.sh \"$DATE_TAG\"\n  fi\n}\n\ncheck_runtime_halt_before_profiles || exit $?\n\nif [[ \"${FORCE_REFRESH:-0}\" == \"1\" || ! -f \"$LIVE_SYSTEM_FILE\" ]]; then\n  ensure_same_day_live_system\nfi\n\nif [[ ! -f \"$LIVE_SYSTEM_FILE\" ]]; then\n  echo \"[ERROR] 缺少当日 live_system: $LIVE_SYSTEM_FILE\"\n  exit 2\nfi\n\nif [[ -z \"$TICKETS_FILE\" && ( ! -f \"$MERGED_FILE\" || \"${FORCE_REFRESH:-0}\" == \"1\" ) ]]; then\n  ensure_same_day_merged_signals\nfi\n\nif [[ -z \"$TICKETS_FILE\" && ! -f \"$MERGED_FILE\" ]]; then\n  echo \"[ERROR] 缺少当日 merged_signals: $MERGED_FILE\"\n  exit 2\nfi\n\nattempt=1\nwhile (( attempt <= RETRY_MAX )); do\n  echo \"[RUN] paper_profiles attempt ${attempt}/${RETRY_MAX} date=${DATE_TAG}\"\n  if run_once; then\n    echo \"[OK] paper_profiles updated date=${DATE_TAG}\"\n    echo \"- defensive: research/reports/paper_defensive_trading_dashboard_latest.html\"\n    echo \"- balanced: research/reports/paper_balanced_trading_dashboard_latest.html\"\n    echo \"- aggressive: research/reports/paper_aggressive_trading_dashboard_latest.html\"\n    echo \"- comparison: research/reports/paper_profiles_comparison_latest.html\"\n    exit 0\n  fi\n  code=$?\n  if (( attempt >= RETRY_MAX )); then\n    echo \"[FAIL] paper_profiles exit=${code} date=${DATE_TAG}\"\n    exit \"$code\"\n  fi\n  echo \"[RETRY] paper_profiles exit=${code}; sleep ${RETRY_SLEEP_SEC}s\"\n  sleep \"$RETRY_SLEEP_SEC\"\n  attempt=$((attempt + 1))\ndone\n\necho \"[FAIL] paper_profiles reached unreachable branch\"\nexit 3\n"}],"isError":false,"timestamp":1774345281861}}
