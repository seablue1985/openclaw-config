{"type":"message","id":"958a180f","parentId":"84c83c16","timestamp":"2026-03-24T09:40:16.125Z","message":{"role":"toolResult","toolCallId":"call_INQSe6Ae8nJyWuZvpfwScHh3|fc_0fb068e88b60a2b20169c25bff6c3081948605a75cff0bfeb7","toolName":"read","content":[{"type":"text","text":"            \"orders_csv\": str(orders_csv),\n            \"tickets_csv\": str(tickets_csv),\n            \"summary_json\": str(summary_json),\n            \"summary_md\": str(summary_md),\n        },\n    }\n\n    atomic_write_json(summary_json, payload, encoding=\"utf-8\", ensure_ascii=False, indent=2)\n    atomic_write_text(summary_md, _render_summary_markdown(payload), encoding=\"utf-8\")\n    return payload\n"}],"isError":false,"timestamp":1774345216112}}
{"type":"message","id":"3ebac559","parentId":"958a180f","timestamp":"2026-03-24T09:40:16.138Z","message":{"role":"toolResult","toolCallId":"call_qy60tu82tbpTRnz8mVXidUsW|fc_0fb068e88b60a2b20169c25bff6c408194a371384cb3a739a7","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\nset -euo pipefail\n\nWORKSPACE=\"$HOME/.openclaw/workspace\"\nPYTHON_BIN=\"${PYTHON_BIN:-$(command -v python3)}\"\nLOG_DIR=\"$WORKSPACE/logs\"\nBUNDLE_SCRIPT=\"$WORKSPACE/scripts/run_investment_research_org_publish_bundle.py\"\nGUARD_SCRIPT=\"$WORKSPACE/scripts/run_investment_research_mainline_guard.py\"\nBUNDLE_MORNING_TAG=\"# RESEARCH_BUNDLE_MORNING\"\nBUNDLE_MIDDAY_TAG=\"# RESEARCH_BUNDLE_MIDDAY\"\nBUNDLE_CLOSE_TAG=\"# RESEARCH_BUNDLE_CLOSE\"\nBUNDLE_NIGHT_TAG=\"# RESEARCH_BUNDLE_NIGHT\"\nGUARD_MORNING_TAG=\"# RESEARCH_MAINLINE_GUARD_MORNING\"\nGUARD_MIDDAY_TAG=\"# RESEARCH_MAINLINE_GUARD_MIDDAY\"\nGUARD_CLOSE_TAG=\"# RESEARCH_MAINLINE_GUARD_CLOSE\"\nGUARD_NIGHT_TAG=\"# RESEARCH_MAINLINE_GUARD_NIGHT\"\nBUNDLE_LINES=(\n  \"32 09 * * 1-5 cd $WORKSPACE && $PYTHON_BIN $BUNDLE_SCRIPT --meeting-type morning >> $LOG_DIR/investment_research_bundle_morning.log 2>&1 $BUNDLE_MORNING_TAG\"\n  \"31 11 * * 1-5 cd $WORKSPACE && $PYTHON_BIN $BUNDLE_SCRIPT --meeting-type midday >> $LOG_DIR/investment_research_bundle_midday.log 2>&1 $BUNDLE_MIDDAY_TAG\"\n  \"12 15 * * 1-5 cd $WORKSPACE && $PYTHON_BIN $BUNDLE_SCRIPT --meeting-type close >> $LOG_DIR/investment_research_bundle_close.log 2>&1 $BUNDLE_CLOSE_TAG\"\n  \"32 20 * * 1-5 cd $WORKSPACE && $PYTHON_BIN $BUNDLE_SCRIPT --meeting-type night >> $LOG_DIR/investment_research_bundle_night.log 2>&1 $BUNDLE_NIGHT_TAG\"\n)\nGUARD_LINES=(\n  \"34 09 * * 1-5 cd $WORKSPACE && $PYTHON_BIN $GUARD_SCRIPT >> $LOG_DIR/investment_research_mainline_guard.log 2>&1 $GUARD_MORNING_TAG\"\n  \"33 11 * * 1-5 cd $WORKSPACE && $PYTHON_BIN $GUARD_SCRIPT >> $LOG_DIR/investment_research_mainline_guard.log 2>&1 $GUARD_MIDDAY_TAG\"\n  \"14 15 * * 1-5 cd $WORKSPACE && $PYTHON_BIN $GUARD_SCRIPT >> $LOG_DIR/investment_research_mainline_guard.log 2>&1 $GUARD_CLOSE_TAG\"\n  \"34 20 * * 1-5 cd $WORKSPACE && $PYTHON_BIN $GUARD_SCRIPT >> $LOG_DIR/investment_research_mainline_guard.log 2>&1 $GUARD_NIGHT_TAG\"\n)\n\nmkdir -p \"$LOG_DIR\"\nTMP_CRON=$(mktemp)\ncrontab -l 2>/dev/null | grep -v 'RESEARCH_BUNDLE_' | grep -v 'RESEARCH_MAINLINE_GUARD' > \"$TMP_CRON\" || true\nfor line in \"${BUNDLE_LINES[@]}\"; do\n  echo \"$line\" >> \"$TMP_CRON\"\ndone\nfor line in \"${GUARD_LINES[@]}\"; do\n  echo \"$line\" >> \"$TMP_CRON\"\ndone\ncrontab \"$TMP_CRON\"\nrm -f \"$TMP_CRON\"\n\nfor line in \"${BUNDLE_LINES[@]}\"; do\n  echo \"Installed: $line\"\ndone\nfor line in \"${GUARD_LINES[@]}\"; do\n  echo \"Installed: $line\"\ndone\n"}],"isError":false,"timestamp":1774345216125}}
{"type":"message","id":"3c9bcad6","parentId":"3ebac559","timestamp":"2026-03-24T09:40:16.150Z","message":{"role":"toolResult","toolCallId":"call_PquzqBiFtlv8AxrB2nqrq4Lq|fc_0fb068e88b60a2b20169c25bff6c488194a2307cb5b812212b","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport subprocess\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom report_io import atomic_write_json\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\nQUANT_PROJECT = WORKSPACE / \"quant_projects\" / \"personal-a-share-research-system\"\nDAILY_STRATEGY_AUDIT = QUANT_PROJECT / \"scripts\" / \"run_daily_strategy_audit.py\"\nSTRATEGY_REPORT_GENERATOR = QUANT_PROJECT / \"scripts\" / \"generate_today_stock_strategy_report.py\"\nDATA_SOURCE_HEALTH = WORKSPACE / \"scripts\" / \"run_investment_research_data_source_health_probe.py\"\nEVENT_WATCH = WORKSPACE / \"scripts\" / \"run_investment_research_event_watch.py\"\nTEMP_MEETING = WORKSPACE / \"scripts\" / \"generate_investment_research_temporary_meeting_broadcast.py\"\nORCHESTRATOR = WORKSPACE / \"scripts\" / \"run_investment_research_org_orchestrator.py\"\nROLE_BRIEFS = WORKSPACE / \"scripts\" / \"run_investment_research_role_briefs.py\"\nGROUP_DIGEST = WORKSPACE / \"scripts\" / \"generate_investment_research_group_digest.py\"\nCHIEF_DASHBOARD = WORKSPACE / \"scripts\" / \"generate_investment_research_chief_dashboard.py\"\nCHIEF_CARD = WORKSPACE / \"scripts\" / \"generate_investment_research_chief_card.py\"\nCHIEF_BROADCAST = WORKSPACE / \"scripts\" / \"generate_investment_research_chief_broadcast.py\"\nCONTROL_TOWER = WORKSPACE / \"scripts\" / \"generate_investment_research_control_tower.py\"\nCONTROL_TOWER_BROADCAST = WORKSPACE / \"scripts\" / \"generate_investment_research_control_tower_broadcast.py\"\nCONTROL_TOWER_CARD = WORKSPACE / \"scripts\" / \"generate_investment_research_control_tower_card.py\"\nREVIEW_LEDGER = WORKSPACE / \"scripts\" / \"run_investment_research_review_ledger.py\"\nDELIVERY_PUSH = WORKSPACE / \"scripts\" / \"push_investment_research_delivery.py\"\n\nMEETING_TOPICS = {\n    \"morning\": \"A股盘前会（发布bundle）\",\n    \"midday\": \"A股午盘巡检会（发布bundle）\",\n    \"close\": \"A股收盘复盘会（发布bundle）\",\n    \"night\": \"A股夜间研究会（发布bundle）\",\n}\n\nHEALTH_SCOPE = {\n    \"morning\": \"morning\",\n    \"midday\": \"intraday\",\n    \"close\": \"post_close\",\n    \"night\": \"overnight\",\n}\n\n\ndef run(cmd: list[str]) -> list[str]:\n    proc = subprocess.run(cmd, capture_output=True, text=True, check=True)\n    return [line.strip() for line in proc.stdout.splitlines() if line.strip()]\n\n\ndef run_optional(cmd: list[str], *, cwd: Path | None = None) -> dict[str, Any]:\n    proc = subprocess.run(cmd, capture_output=True, text=True, cwd=str(cwd) if cwd else None)\n    return {\n        \"ok\": proc.returncode == 0,\n        \"returncode\": proc.returncode,\n        \"cmd\": cmd,\n        \"stdout\": [line.strip() for line in proc.stdout.splitlines() if line.strip()],\n        \"stderr\": [line.strip() for line in proc.stderr.splitlines() if line.strip()],\n    }\n\n\ndef maybe_load_json(path_str: str | None) -> dict | None:\n    if not path_str:\n        return None\n    path = Path(path_str)\n    if not path.exists():\n        return None\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef load_report_json(outputs: list[str], stem_prefix: str) -> dict[str, Any] | None:\n    for item in outputs:\n        path = Path(item)\n        if not path.exists() or path.suffix != \".json\":\n            continue\n        if path.stem.startswith(stem_prefix):\n            return json.loads(path.read_text(encoding=\"utf-8\"))\n    return None\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser(description=\"Run full publish bundle for investment research org\")\n    ap.add_argument(\"--meeting-type\", choices=[\"morning\", \"midday\", \"close\", \"night\"], default=\"morning\")\n    args = ap.parse_args()\n\n    REPORT_DIR.mkdir(parents=True, exist_ok=True)\n    now = datetime.now()\n    meeting_type = args.meeting_type\n    topic = MEETING_TOPICS[meeting_type]\n\n    strategy_audit_refresh = None\n    if DAILY_STRATEGY_AUDIT.exists():\n        strategy_audit_refresh = run_optional([sys.executable, str(DAILY_STRATEGY_AUDIT)], cwd=QUANT_PROJECT)\n\n    strategy_report_refresh = None\n    if STRATEGY_REPORT_GENERATOR.exists():\n        strategy_report_refresh = run_optional([sys.executable, str(STRATEGY_REPORT_GENERATOR)], cwd=QUANT_PROJECT)\n\n    def safe_run(label: str, cmd: list[str]) -> list[str]:\n        try:\n            return run(cmd)\n        except subprocess.CalledProcessError as e:\n            print(f\"[WARN] {label} failed (exit {e.returncode}), continuing pipeline\", flush=True)\n            return []\n\n    data_source_health_outputs = safe_run(\"data_source_health\", [sys.executable, str(DATA_SOURCE_HEALTH), \"--scope\", HEALTH_SCOPE[meeting_type]])\n    event_watch_outputs = safe_run(\"event_watch\", [sys.executable, str(EVENT_WATCH)])\n    temporary_meeting_outputs = safe_run(\"temporary_meeting\", [sys.executable, str(TEMP_MEETING)])\n    orchestrator_outputs = safe_run(\"orchestrator\", [sys.executable, str(ORCHESTRATOR), \"--meeting-type\", meeting_type, \"--topic\", topic])\n    role_outputs = safe_run(\"role_briefs\", [sys.executable, str(ROLE_BRIEFS), \"--meeting-type\", meeting_type])\n    digest_outputs = safe_run(\"group_digest\", [sys.executable, str(GROUP_DIGEST), \"--meeting-type\", meeting_type])\n\n    dashboard_outputs = safe_run(\"chief_dashboard\", [sys.executable, str(CHIEF_DASHBOARD), \"--meeting-type\", meeting_type])\n    chief_card_outputs = safe_run(\"chief_card\", [sys.executable, str(CHIEF_CARD), \"--meeting-type\", meeting_type])\n    chief_broadcast_outputs = safe_run(\"chief_broadcast\", [sys.executable, str(CHIEF_BROADCAST), \"--meeting-type\", meeting_type])\n    control_tower_outputs = safe_run(\"control_tower\", [sys.executable, str(CONTROL_TOWER), \"--anchor-meeting\", meeting_type])\n    control_tower_broadcast_outputs = safe_run(\"control_tower_broadcast\", [sys.executable, str(CONTROL_TOWER_BROADCAST)])\n    control_tower_card_outputs = safe_run(\"control_tower_card\", [sys.executable, str(CONTROL_TOWER_CARD)])\n    review_ledger_outputs = safe_run(\"review_ledger\", [sys.executable, str(REVIEW_LEDGER)]) if REVIEW_LEDGER.exists() else []\n\n    data_source_health = load_report_json(data_source_health_outputs, \"investment_research_data_source_health_\")\n    event_watch = load_report_json(event_watch_outputs, \"investment_research_event_watch_\")\n    temporary_meeting = load_report_json(temporary_meeting_outputs, \"investment_research_temporary_meeting_broadcast_\")\n    control_tower_payload = maybe_load_json(control_tower_outputs[-1] if control_tower_outputs else None)\n    summary = {\n        \"generated_at\": now.strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"meeting_type\": meeting_type,\n        \"strategy_audit_refresh\": strategy_audit_refresh,\n        \"strategy_report_refresh\": strategy_report_refresh,\n        \"data_source_health\": data_source_health,\n        \"event_watch\": event_watch,\n        \"temporary_meeting\": temporary_meeting,\n        \"data_source_health_outputs\": data_source_health_outputs,\n        \"event_watch_outputs\": event_watch_outputs,\n        \"temporary_meeting_outputs\": temporary_meeting_outputs,\n        \"orchestrator_outputs\": orchestrator_outputs,\n        \"role_brief_outputs\": role_outputs,\n        \"group_digest_outputs\": digest_outputs,\n        \"chief_dashboard_outputs\": dashboard_outputs,\n        \"chief_card_outputs\": chief_card_outputs,\n        \"chief_broadcast_outputs\": chief_broadcast_outputs,\n        \"control_tower_outputs\": control_tower_outputs,\n        \"control_tower_broadcast_outputs\": control_tower_broadcast_outputs,\n        \"control_tower_card_outputs\": control_tower_card_outputs,\n        \"review_ledger_outputs\": review_ledger_outputs,\n        \"control_tower_snapshot\": {\n            \"morning_news_status\": (control_tower_payload or {}).get(\"morning_news\", {}).get(\"status\"),\n            \"morning_news_last_success_at\": (control_tower_payload or {}).get(\"morning_news\", {}).get(\"last_success_at\"),\n            \"morning_news_ok\": (control_tower_payload or {}).get(\"morning_news\", {}).get(\"health_ok\"),\n            \"morning_news_status_reason\": (control_tower_payload or {}).get(\"morning_news\", {}).get(\"status_reason\"),\n            \"strategy_audit_status\": (control_tower_payload or {}).get(\"strategy_audit\", {}).get(\"overall_status\"),\n            \"strategy_audit_ok\": (\n                (control_tower_payload or {}).get(\"strategy_audit\", {}).get(\"overall_status\") == \"PASS\"\n                and bool((control_tower_payload or {}).get(\"strategy_audit\", {}).get(\"robust_pass\"))\n            ),\n            \"strategy_audit_annual_return_pct\": (control_tower_payload or {}).get(\"strategy_audit\", {}).get(\"annual_return_pct\"),\n            \"strategy_audit_max_drawdown_pct\": (control_tower_payload or {}).get(\"strategy_audit\", {}).get(\"max_drawdown_pct\"),\n            \"strategy_audit_sharpe\": (control_tower_payload or {}).get(\"strategy_audit\", {}).get(\"sharpe\"),\n            \"backtest_queue_status\": (control_tower_payload or {}).get(\"backtest_queue\", {}).get(\"status\"),\n            \"backtest_queue_running_count\": (control_tower_payload or {}).get(\"backtest_queue\", {}).get(\"running_count\"),\n            \"stable_strategy_visible\": (control_tower_payload or {}).get(\"backtest_queue\", {}).get(\"stable_strategy_visible\"),\n            \"ths_market_status\": (control_tower_payload or {}).get(\"health_probe\", {}).get(\"ths_market\", {}).get(\"status\"),\n            \"ths_market_summary\": (control_tower_payload or {}).get(\"health_probe\", {}).get(\"ths_market\", {}).get(\"summary\"),\n            \"ths_market_fallback_count\": (control_tower_payload or {}).get(\"health_probe\", {}).get(\"ths_market\", {}).get(\"fallback_count\"),\n            \"ths_market_failed_count\": (control_tower_payload or {}).get(\"health_probe\", {}).get(\"ths_market\", {}).get(\"failed_count\"),\n            \"paper_date_tag\": (control_tower_payload or {}).get(\"paper_execution\", {}).get(\"date_tag\"),\n            \"paper_freshness_status\": (control_tower_payload or {}).get(\"paper_execution\", {}).get(\"freshness\", {}).get(\"status\"),\n            \"paper_freshness_summary\": (control_tower_payload or {}).get(\"paper_execution\", {}).get(\"freshness\", {}).get(\"summary\"),\n        },\n    }\n    summary_path = REPORT_DIR / f\"investment_research_publish_bundle_{meeting_type}_{now:%Y%m%d}.json\"\n    atomic_write_json(summary_path, summary, encoding=\"utf-8\", ensure_ascii=False, indent=2)\n\n    delivery_push = None\n    if DELIVERY_PUSH.exists():\n        delivery_push = run_optional([sys.executable, str(DELIVERY_PUSH), \"--meeting-type\", meeting_type], cwd=WORKSPACE)\n        summary[\"delivery_push\"] = delivery_push\n        atomic_write_json(summary_path, summary, encoding=\"utf-8\", ensure_ascii=False, indent=2)\n\n    for item in data_source_health_outputs:\n        print(item)\n    for item in event_watch_outputs:\n        print(item)\n    for item in temporary_meeting_outputs:\n        print(item)\n    for item in orchestrator_outputs:\n        print(item)\n    for item in role_outputs:\n        print(item)\n    for item in digest_outputs:\n        print(item)\n    for item in dashboard_outputs:\n        print(item)\n    for item in chief_card_outputs:\n        print(item)\n    for item in chief_broadcast_outputs:\n        print(item)\n    for item in control_tower_outputs:\n        print(item)\n    for item in control_tower_broadcast_outputs:\n        print(item)\n    for item in control_tower_card_outputs:\n        print(item)\n    for item in review_ledger_outputs:\n        print(item)\n    if delivery_push:\n        for item in delivery_push.get(\"stdout\", []):\n            print(item)\n    print(summary_path)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774345216138}}
{"type":"message","id":"0dbfce65","parentId":"3c9bcad6","timestamp":"2026-03-24T09:40:16.163Z","message":{"role":"toolResult","toolCallId":"call_EPg5gdaJUscjPuupgQF5t8Zs|fc_0fb068e88b60a2b20169c25bff6c508194915ca4214469f8bb","toolName":"read","content":[{"type":"text","text":"        duty_index.append({\n            \"cycle\": cycle,\n            \"generated_at\": payload.get(\"generated_at\"),\n            \"status\": payload.get(\"data_source_runtime\", {}).get(\"status\"),\n            \"md\": str(path.with_suffix('.md')),\n            \"json\": str(path),\n        })\n\n    health_scope, health_probe, health_path = latest_health_probe_for_date(REPORT_DIR, today_tag())\n    health_snapshot = build_health_snapshot(health_scope, health_probe, health_path)\n    morning_news, morning_news_path = morning_news_state()\n    morning_news_norm = normalize_morning_news_state(morning_news)\n    strategy_audit, strategy_audit_path = latest_strategy_audit()\n    auto_premarket_precheck, auto_premarket_precheck_path = latest_auto_premarket_precheck()\n    paper_execution = build_paper_execution_snapshot()\n    execution_status = {\n        \"path\": str((paper_execution.get(\"files\") or {}).get(\"summary_json\") or \"\"),\n        \"date\": paper_execution.get(\"date_tag\"),\n        \"time\": paper_execution.get(\"generated_at\"),\n        \"status\": \"paper_only\",\n        \"status_reason\": \"execution_status 已切换为三套模拟盘口径\",\n        \"strict_precheck_passed\": paper_execution.get(\"execution_status\", {}).get(\"allowed_to_open_new_positions\"),\n        \"strict_precheck\": \"paper_profiles_only\",\n        **(paper_execution.get(\"execution_status\") or {}),\n    }\n    backtest_queue, backtest_queue_path = snapshot_backtest_queue_status()\n    event_watch_path = REPORT_DIR / f\"investment_research_event_watch_{today_tag()}.json\"\n    event_watch = maybe_json(event_watch_path)\n    temp_meeting_path = REPORT_DIR / f\"investment_research_temporary_meeting_broadcast_{today_tag()}.json\"\n    temp_meeting = maybe_json(temp_meeting_path)\n    llm_runtime = build_runtime_status()\n\n    latest_dashboard = latest_dashboard or {}\n    latest_status = latest_dashboard.get(\"status\", {})\n    latest_exports = latest_dashboard.get(\"export_paths\", {})\n\n    return {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"latest_meeting_type\": latest_meeting,\n        \"latest_meeting_label\": latest_dashboard.get(\"meeting_label\", latest_meeting),\n        \"latest_status\": latest_status,\n        \"watchlist\": [item.get(\"display\") or item.get(\"ticker\", \"\") for item in latest_dashboard.get(\"watchlist\", [])],\n        \"watchlist_reason\": latest_dashboard.get(\"watchlist_reason\", \"\"),\n        \"holdings_preview\": latest_dashboard.get(\"holdings_preview\", []),\n        \"trades_preview\": latest_dashboard.get(\"trades_preview\", []),\n        \"sell_review_list\": latest_dashboard.get(\"sell_review_list\", []),\n        \"sell_review_reason\": latest_dashboard.get(\"sell_review_reason\", \"\"),\n        \"meeting_index\": meeting_index,\n        \"duty_index\": duty_index,\n        \"health_probe\": health_snapshot,\n        \"event_watch\": {\n            \"path\": str(event_watch_path) if event_watch_path.exists() else None,\n            \"status\": (event_watch or {}).get(\"status\"),\n            \"should_temporary_meet\": (event_watch or {}).get(\"should_temporary_meet\"),\n            \"trigger_types\": [item.get(\"type\") for item in (event_watch or {}).get(\"triggers\", [])],\n        },\n        \"temporary_meeting\": {\n            \"path\": str(temp_meeting_path) if temp_meeting_path.exists() else None,\n            \"status\": (temp_meeting or {}).get(\"status\"),\n            \"participants\": [item.get(\"label\") for item in (temp_meeting or {}).get(\"participants\", [])],\n        },\n        \"morning_news\": {\n            \"path\": str(morning_news_path) if morning_news_path.exists() else None,\n            \"status\": morning_news_norm.get(\"effective_status\"),\n            \"raw_status\": morning_news_norm.get(\"raw_status\"),\n            \"health_ok\": morning_news_norm.get(\"health_ok\"),\n            \"status_reason\": morning_news_norm.get(\"status_reason\"),\n            \"expected_date_tag\": morning_news_norm.get(\"expected_date_tag\"),\n            \"raw_date_tag\": morning_news_norm.get(\"raw_date_tag\"),\n            \"generated_at\": (morning_news or {}).get(\"generated_at\"),\n            \"last_success_at\": (morning_news or {}).get(\"last_success_at\"),\n            \"last_failure_at\": (morning_news or {}).get(\"last_failure_at\"),\n            \"log_file\": (morning_news or {}).get(\"log_file\"),\n            \"brief_message\": (morning_news or {}).get(\"brief_message\"),\n        },\n        \"strategy_audit\": {\n            \"path\": str(strategy_audit_path) if strategy_audit_path else None,\n            \"date_tag\": (strategy_audit or {}).get(\"date_tag\"),\n            \"annual_return_pct\": (strategy_audit or {}).get(\"annual_return_pct\"),\n            \"max_drawdown_pct\": (strategy_audit or {}).get(\"max_drawdown_pct\"),\n            \"sharpe\": (strategy_audit or {}).get(\"sharpe\"),\n            \"robust_pass\": (strategy_audit or {}).get(\"robust_pass\"),\n            \"target_hit\": (strategy_audit or {}).get(\"target_hit\"),\n            \"overall_status\": (strategy_audit or {}).get(\"overall_status\"),\n            \"precheck_status\": (strategy_audit or {}).get(\"precheck_status\"),\n            \"execution_scope\": (strategy_audit or {}).get(\"execution_scope\"),\n            \"paper_runtime_ready\": (strategy_audit or {}).get(\"paper_runtime_ready\"),\n            \"live_runtime_ready\": (strategy_audit or {}).get(\"live_runtime_ready\"),\n            \"paper_profiles_enabled\": (strategy_audit or {}).get(\"paper_profiles_enabled\"),\n        },\n        \"execution_status\": execution_status,\n        \"paper_execution\": paper_execution,\n        \"backtest_queue\": {\n            \"path\": str(backtest_queue_path) if backtest_queue_path else None,\n            \"status\": (backtest_queue or {}).get(\"status\"),\n            \"generated_at\": (backtest_queue or {}).get(\"generated_at\"),\n            \"running_count\": (backtest_queue or {}).get(\"running_count\"),\n            \"stable_strategy_visible\": (backtest_queue or {}).get(\"stable_strategy_visible\"),\n            \"error\": (backtest_queue or {}).get(\"error\"),\n        },\n        \"llm_runtime\": llm_runtime,\n        \"export_paths\": {\n            **latest_exports,\n            \"holdings_csv\": (paper_execution.get(\"files\") or {}).get(\"holdings_csv\") or latest_exports.get(\"holdings_csv\"),\n            \"trades_csv\": (paper_execution.get(\"files\") or {}).get(\"trades_csv\") or latest_exports.get(\"trades_csv\"),\n            \"paper_execution_summary_md\": (paper_execution.get(\"files\") or {}).get(\"summary_md\"),\n            \"paper_execution_summary_json\": (paper_execution.get(\"files\") or {}).get(\"summary_json\"),\n            \"paper_orders_csv\": (paper_execution.get(\"files\") or {}).get(\"orders_csv\"),\n            \"paper_tickets_csv\": (paper_execution.get(\"files\") or {}).get(\"tickets_csv\"),\n            \"paper_execution_brief_md\": execution_status.get(\"brief_path\"),\n            \"paper_journal_csv\": execution_status.get(\"journal_path\"),\n            \"data_source_health_path\": str(health_path) if health_path else None,\n            \"event_watch_json\": str(event_watch_path) if event_watch_path.exists() else None,\n            \"temporary_meeting_json\": str(temp_meeting_path) if temp_meeting_path.exists() else None,\n            \"morning_news_state_json\": str(morning_news_path) if morning_news_path.exists() else None,\n            \"strategy_audit_json\": str(strategy_audit_path) if strategy_audit_path else None,\n            \"backtest_queue_md\": str(backtest_queue_path) if backtest_queue_path else None,\n            \"llm_runtime_json\": str(REPORT_DIR / f\"investment_research_control_tower_{today_tag()}.json\"),\n        },\n    }\n\n\ndef render_markdown(payload: dict[str, Any]) -> str:\n    latest_status = payload.get(\"latest_status\", {})\n    lines: list[str] = []\n    lines.append(\"# 来福投研会 - 首席研究员日内总控台\")\n    lines.append(\"\")\n    lines.append(f\"- 生成时间：{payload.get('generated_at')}\")\n    lines.append(f\"- 当前主视图：`{payload.get('latest_meeting_label') or payload.get('latest_meeting_type') or '暂无'}`\")\n    lines.append(f\"- 审计状态：`{cn_status(latest_status.get('audit_status'))}`\")\n    lines.append(f\"- 盘前强检：`{cn_status(latest_status.get('precheck_status'))}`\")\n    lines.append(f\"- 风险收缩：`{yes_no(latest_status.get('risk_off'))}`\")\n    lines.append(f\"- 年化/回撤/夏普：`{latest_status.get('annual_return_pct', '-')}` / `{latest_status.get('max_drawdown_pct', '-')}` / `{latest_status.get('sharpe', '-')}`\")\n    lines.append(\"\")\n\n    lines.append(\"## 当前总览\")\n    lines.append(f\"- 观察池：{', '.join([str(x) for x in payload.get('watchlist', [])[:5] if x is not None]) if payload.get('watchlist') else payload.get('watchlist_reason') or '暂无'}\")\n    lines.append(f\"- 持仓预览：{', '.join([str(x) for x in payload.get('holdings_preview', [])[:5] if x is not None]) if payload.get('holdings_preview') else '暂无'}\")\n    lines.append(f\"- 成交预览：{', '.join([str(x) for x in payload.get('trades_preview', [])[:5] if x is not None]) if payload.get('trades_preview') else '暂无'}\")\n    lines.append(f\"- 卖出/减仓复核：{', '.join([str(x) for x in payload.get('sell_review_list', [])[:5] if x is not None]) if payload.get('sell_review_list') else payload.get('sell_review_reason') or '暂无'}\")\n    lines.append(\"\")\n\n    hp = payload.get('health_probe', {})\n    ths = hp.get('ths_market', {})\n    ew = payload.get('event_watch', {})\n    tm = payload.get('temporary_meeting', {})\n    mn = payload.get('morning_news', {})\n    sa = payload.get('strategy_audit', {})\n    bq = payload.get('backtest_queue', {})\n    exs = payload.get('execution_status', {})\n    llm = payload.get('llm_runtime', {})\n    llm_summary = llm.get('summary', {})\n    paper_freshness = (payload.get('paper_execution') or {}).get('freshness', {})\n    lines.append(\"## 今日交易控制\")\n    lines.append(\n        f\"- 模拟盘快照：日期 `{payload.get('paper_execution', {}).get('date_tag', '-')}` | \"\n        f\"新鲜度=`{cn_status(paper_freshness.get('status'))}` | 说明=`{paper_freshness.get('summary', '-')}`\"\n    )\n    lines.append(f\"- 今日能否新开仓：`{yes_no(exs.get('allowed_to_open_new_positions'))}`\")\n    lines.append(f\"- 严格盘前检查：`{yes_no(exs.get('strict_precheck_passed'))}` | 模式=`{cn_status(exs.get('mode'))}` | 风险收缩=`{yes_no(exs.get('risk_off'))}` | 硬熔断=`{yes_no(exs.get('hard_stop'))}`\")\n    lines.append(f\"- 是否暂停新开仓：`{yes_no(exs.get('halt_new_buy'))}` | 原因：`{cn_text(exs.get('halt_reason'))}`\")\n    lines.append(f\"- 市场宽度：`{exs.get('market_breadth', '-')}` | 门控原因：`{cn_text(', '.join(exs.get('gate_reasons', [])) if exs.get('gate_reasons') else '无')}`\")\n    lines.append(f\"- 买卖条数：买入 `{exs.get('buy_count', '-')}` / 卖出 `{exs.get('sell_count', '-')}` | 买单拦截 `{exs.get('blocked_buy_halt', '-')}` | 卖单拦截 `{exs.get('blocked_sell_no_holding', '-')}`\")\n    lines.append(f\"- 预算：日新增 `{exs.get('daily_add_budget', '-')}` / 单买单 `{exs.get('per_buy_budget', '-')}` / 单标的上限 `{exs.get('max_single_amount', '-')}` / 当日买入名额 `{exs.get('buy_budget_slots', '-')}`\")\n    lines.append(f\"- 执行窗口：买入 `{exs.get('buy_window', '-')}` | `{exs.get('risk_only_after', '-')}` 后仅风控减仓\")\n    lines.append(f\"- 文件：precheck=`{exs.get('precheck_path') or '-'}` | orders=`{exs.get('orders_path') or '-'}` | brief=`{exs.get('brief_path') or '-'}`\")\n    lines.append(\"\")\n    lines.append(\"## 告警态势\")\n    lines.append(f\"- 数据源健康：`{cn_status(hp.get('status'))}` | 可信度评分：`{hp.get('confidence_score', '-')}/100` | 推荐模式：`{cn_text(hp.get('recommended_mode', '-'))}`\")\n    lines.append(\n        f\"- THS 本地行情：`{cn_status(ths.get('status'))}` | 可用=`{yes_no(ths.get('available'))}` | \"\n        f\"THS命中 `{ths.get('ok_count', 0)}` / 回退 `{ths.get('fallback_count', 0)}` / 失败 `{ths.get('failed_count', 0)}`\"\n    )\n    lines.append(f\"- THS 摘要：`{ths.get('summary', '-')}`\")\n    lines.append(f\"- 最大价差分歧：`{hp.get('max_price_diff_pct', '-')}%`\")\n    lines.append(f\"- 数据源触发项：{cn_text(', '.join(hp.get('breaches', [])) if hp.get('breaches') else '无')}\")\n    lines.append(f\"- 观察项：{cn_text(', '.join(hp.get('observations', [])) if hp.get('observations') else '无')}\")\n    lines.append(f\"- 自动降级动作：{cn_text(', '.join(hp.get('auto_actions', [])) if hp.get('auto_actions') else '无')}\")\n    lines.append(f\"- 临时会商监控：`{cn_status(ew.get('status'))}` | 建议会商：`{yes_no(ew.get('should_temporary_meet'))}`\")\n    lines.append(f\"- 临时会商触发类型：{cn_text(', '.join(ew.get('trigger_types', [])) if ew.get('trigger_types') else '无')}\")\n\n[67 more lines in file. Use offset=420 to continue.]"}],"isError":false,"timestamp":1774345216150}}
