f_industry_researcher_close_20260323.json:59:    \"paper_execution_stale_reason\": \"三套模拟盘仍停留在 20260320，已晚于今日计划刷新时点 15:05。\",\nresearch/reports/investment_research_role_brief_industry_researcher_close_20260323.json:65:      \"freshness_status\": \"stale\",\nresearch/reports/investment_research_role_brief_industry_researcher_morning_20260320.json:82:    \"strategy_report_stale_reason\": \"\",\nresearch/reports/investment_research_role_brief_industry_researcher_morning_20260320.json:85:      \"status\": \"pending_today_refresh\",\nresearch/reports/investment_research_role_brief_industry_researcher_morning_20260320.json:88:      \"stale_days\": 1,\nresearch/reports/investment_research_role_brief_industry_researcher_morning_20260320.json:89:      \"expected_refresh_time\": \"15:05\",\nresearch/reports/investment_research_role_brief_industry_researcher_morning_20260320.json:95:    \"paper_execution_stale_reason\": \"\",\nresearch/reports/investment_research_role_brief_industry_researcher_morning_20260320.json:99:      \"freshness_status\": \"pending_today_refresh\",\nresearch/reports/investment_research_role_brief_buffett_avatar_morning_20260324.json:37:    \"strategy_report_stale_reason\": \"\",\nresearch/reports/investment_research_role_brief_buffett_avatar_morning_20260324.json:40:      \"status\": \"pending_today_refresh\",\nresearch/reports/investment_research_role_brief_buffett_avatar_morning_20260324.json:43:      \"stale_days\": 1,\nresearch/reports/investment_research_role_brief_buffett_avatar_morning_20260324.json:44:      \"expected_refresh_time\": \"15:05\",\nresearch/reports/investment_research_role_brief_buffett_avatar_morning_20260324.json:50:    \"paper_execution_stale_reason\": \"\",\nresearch/reports/investment_research_role_brief_buffett_avatar_morning_20260324.json:56:      \"freshness_status\": \"pending_today_refresh\",\nresearch/reports/investment_research_execution_review_morning_20260324.json:21:    \"freshness_status\": \"pending_today_refresh\",\nresearch/reports/investment_research_role_brief_quant_analyst_midday_20260319.json:84:    \"strategy_report_stale_reason\": \"\",\nresearch/reports/investment_research_role_brief_quant_analyst_midday_20260319.json:90:      \"stale_days\": 0,\nresearch/reports/investment_research_role_brief_quant_analyst_midday_20260319.json:91:      \"expected_refresh_time\": \"15:05\",\nresearch/reports/investment_research_role_brief_quant_analyst_midday_20260319.json:97:    \"paper_execution_stale_reason\": \"\",\nresearch/reports/investment_research_role_brief_quant_analyst_midday_20260319.json:101:      \"freshness_status\": \"fresh\",","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774346246867}}
{"type":"message","id":"e1953e33","parentId":"a1bd79fd","timestamp":"2026-03-24T09:57:26.890Z","message":{"role":"toolResult","toolCallId":"call_Me04UH9dPKAERXYfEtJUKwRJ|fc_0fb068e88b60a2b20169c2600640dc819484d59553fdf50252","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport csv\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nCONFIRMATION_DIR = WORKSPACE / \"memory\" / \"trade_confirmations\"\n\n\ndef normalize_ticker(value: Any) -> str:\n    text = str(value or \"\").strip().upper()\n    return text.replace(\".XSHE\", \".SZ\").replace(\".XSHG\", \".SH\")\n\n\ndef to_float(value: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(value).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef to_int(value: Any, default: int = 0) -> int:\n    try:\n        return int(float(str(value).replace(\",\", \"\").strip()))\n    except Exception:\n        return default\n\n\ndef read_csv_rows(path_like: Any) -> list[dict[str, str]]:\n    path = Path(str(path_like or \"\"))\n    if not path.exists():\n        return []\n    with path.open(\"r\", encoding=\"utf-8-sig\", newline=\"\") as handle:\n        return list(csv.DictReader(handle))\n\n\ndef load_confirmation_rows(date_tag: str) -> list[dict[str, Any]]:\n    path = CONFIRMATION_DIR / f\"trade_confirmation_{date_tag}.jsonl\"\n    if not path.exists():\n        return []\n    rows: list[dict[str, Any]] = []\n    with path.open(\"r\", encoding=\"utf-8\") as handle:\n        for line in handle:\n            line = line.strip()\n            if not line:\n                continue\n            try:\n                rows.append(json.loads(line))\n            except Exception:\n                continue\n    return rows\n\n\ndef parse_note_pairs(notes: Any) -> dict[str, str]:\n    result: dict[str, str] = {}\n    for chunk in str(notes or \"\").split(\";\"):\n        if \"=\" not in chunk:\n            continue\n        key, value = chunk.split(\"=\", 1)\n        key = key.strip()\n        value = value.strip()\n        if key:\n            result[key] = value\n    return result\n\n\ndef latest_confirmation_map(rows: list[dict[str, Any]]) -> dict[tuple[str, str], dict[str, Any]]:\n    result: dict[tuple[str, str], dict[str, Any]] = {}\n    for row in rows:\n        ticker = normalize_ticker(row.get(\"ticker\") or row.get(\"ts_code\") or row.get(\"symbol\"))\n        direction = str(row.get(\"direction\") or row.get(\"side\") or \"\").strip().lower()\n        if ticker and direction:\n            result[(ticker, direction)] = row\n    return result\n\n\ndef build_position_map(rows: list[dict[str, str]]) -> dict[str, dict[str, Any]]:\n    result: dict[str, dict[str, Any]] = {}\n    for row in rows:\n        ticker = normalize_ticker(row.get(\"ts_code\") or row.get(\"symbol\"))\n        if not ticker:\n            continue\n        result[ticker] = {\n            \"ticker\": ticker,\n            \"quantity\": to_int(row.get(\"quantity\")),\n            \"cost_price\": to_float(row.get(\"cost_price\")),\n            \"market_value\": to_float(row.get(\"market_value\")),\n            \"display\": str(row.get(\"display\") or ticker),\n        }\n    return result\n\n\ndef build_trade_map(rows: list[dict[str, str]]) -> dict[tuple[str, str], list[dict[str, str]]]:\n    result: dict[tuple[str, str], list[dict[str, str]]] = {}\n    for row in rows:\n        ticker = normalize_ticker(row.get(\"ts_code\") or row.get(\"symbol\"))\n        side = str(row.get(\"action\") or row.get(\"side\") or \"\").strip().upper()\n        if not ticker or not side:\n            continue\n        result.setdefault((ticker, side), []).append(row)\n    return result\n\n\ndef build_multi_map(rows: list[dict[str, str]], side_field: str) -> dict[tuple[str, str], list[dict[str, str]]]:\n    result: dict[tuple[str, str], list[dict[str, str]]] = {}\n    for row in rows:\n        ticker = normalize_ticker(row.get(\"ts_code\") or row.get(\"symbol\"))\n        side = str(row.get(side_field) or row.get(\"action\") or \"\").strip().upper()\n        if not ticker or not side:\n            continue\n        result.setdefault((ticker, side), []).append(row)\n    return result\n\n\ndef stage_label(stage: str) -> str:\n    mapping = {\n        \"holding\": \"持仓中\",\n        \"executed_today\": \"今日已成交\",\n        \"confirmed_pending_execution\": \"已确认待执行\",\n        \"ready_to_execute\": \"满足执行条件\",\n        \"blocked_by_risk\": \"被风控拦截\",\n        \"watch_only\": \"仅观察\",\n        \"sell_review\": \"卖出复核中\",\n        \"no_position\": \"无持仓\",\n        \"executed_exit\": \"今日已卖出\",\n    }\n    return mapping.get(stage, stage or \"未知\")\n\n\ndef aggregate_stage(profile_stages: list[str], side: str) -> str:\n    preferred = (\n        [\"executed_exit\", \"sell_review\", \"confirmed_pending_execution\", \"no_position\"]\n        if side == \"SELL\"\n        else [\"holding\", \"executed_today\", \"confirmed_pending_execution\", \"ready_to_execute\", \"blocked_by_risk\", \"watch_only\"]\n    )\n    for name in preferred:\n        if name in profile_stages:\n            return name\n    return \"no_position\" if side == \"SELL\" else \"watch_only\"\n\n\ndef build_next_action(\n    stage: str,\n    *,\n    trigger_hint: str,\n    blocker: str,\n    trading_time: bool,\n    risk_off: bool,\n) -> str:\n    if stage == \"holding\":\n        return \"继续跟踪持仓与卖出复核条件，优先看止损/止盈和减仓触发。\"\n    if stage == \"executed_today\":\n        return \"收盘复核成交质量，次日纳入持仓管理。\"\n    if stage == \"executed_exit\":\n        return \"复核卖出原因和执行偏差，确认是否从观察池移除。\"\n    if stage == \"confirmed_pending_execution\":\n        return \"已有人为确认，等待执行回报并写回账本。\"\n    if stage == \"ready_to_execute\":\n        return \"盘中仅在触发区成立后再执行，不满足条件不下单。\"\n    if stage == \"blocked_by_risk\":\n        return f\"当前被风控拦截：{blocker}\" if blocker else \"当前被风控门控拦截，等待 risk_off 解除或门槛修复。\"\n    if stage == \"sell_review\":\n        return \"优先核对仓位、止盈止损和减仓理由，再决定是否卖出。\"\n    if stage == \"no_position\":\n        return \"当前无持仓，不能直接进入卖出链路。\"\n    if not trading_time:\n        return \"当前非交易时段，只保留触发条件与失效条件。\"\n    if risk_off:\n        return \"当前仍是防守模式，只观察，不转执行。\"\n    return trigger_hint or \"继续等待价格进入触发区。\"\n\n\ndef build_profile_cycle(\n    *,\n    ticker: str,\n    side: str,\n    ticket_rows: list[dict[str, str]],\n    order_rows: list[dict[str, str]],\n    trade_rows: list[dict[str, str]],\n    position: dict[str, Any] | None,\n    confirmation: dict[str, Any] | None,\n) -> list[dict[str, Any]]:\n    profiles: list[dict[str, Any]] = []\n    grouped: dict[tuple[str, str], dict[str, Any]] = {}\n    for row in ticket_rows:\n        grouped[(str(row.get(\"slot_label\") or \"-\"), str(row.get(\"profile_slug\") or \"-\"))] = {\"ticket\": row}\n    for row in order_rows:\n        grouped.setdefault((str(row.get(\"slot_label\") or \"-\"), str(row.get(\"profile_slug\") or \"-\")), {})[\"order\"] = row\n    if not grouped and confirmation:\n        grouped[(\"人工确认\", \"manual\")] = {}\n    if not grouped and trade_rows:\n        grouped[(\"成交记录\", \"trade\")] = {}\n    if not grouped and position:\n        grouped[(\"持仓记录\", \"holding\")] = {}\n    if not grouped and not trade_rows and not position:\n        grouped[(\"汇总\", \"aggregate\")] = {}\n\n    for (slot_label, profile_slug), payload in grouped.items():\n        ticket = payload.get(\"ticket\") or {}\n        order = payload.get(\"order\") or {}\n        note_pairs = parse_note_pairs(ticket.get(\"notes\"))\n        execute_status = str(ticket.get(\"execute_status\") or \"\").strip().lower()\n        confirm_status = str(ticket.get(\"confirm_status\") or \"\").strip().lower()\n        risk_gate = str(order.get(\"risk_gate\") or note_pairs.get(\"paper_risk_gate\") or \"\").strip().lower()\n        gate_reason = str(order.get(\"gate_reason\") or note_pairs.get(\"paper_gate_reason\") or \"\").strip()\n        order_qty = to_int(order.get(\"suggest_qty\") or note_pairs.get(\"paper_order_qty\") or ticket.get(\"source_qty\"))\n        position_qty = to_int((position or {}).get(\"quantity\"))\n        has_trade = bool(trade_rows)\n\n        if side == \"SELL\" and position_qty <= 0 and not has_trade:\n            stage = \"no_position\"\n        elif side == \"BUY\" and has_trade:\n            stage = \"executed_today\"\n        elif side == \"SELL\" and has_trade:\n            stage = \"executed_exit\"\n        elif side == \"BUY\" and position_qty > 0:\n            stage = \"holding\"\n        elif execute_status in {\"paper_blocked\", \"blocked\"} or risk_gate == \"blocked\":\n            stage = \"blocked_by_risk\"\n        elif confirmation and str(confirmation.get(\"status\") or \"\").strip().lower() == \"confirmed\":\n            stage = \"confirmed_pending_execution\"\n        elif execute_status in {\"paper_ready\", \"ready\", \"queued\", \"paper_queued\"} or risk_gate == \"pass\" or order_qty > 0:\n            stage = \"ready_to_execute\" if side == \"BUY\" else \"sell_review\"\n        elif side == \"SELL\" and position_qty > 0:\n            stage = \"sell_review\"\n        else:\n            stage = \"watch_only\"\n\n        profiles.append(\n            {\n                \"slot_label\": slot_label,\n                \"profile_slug\": profile_slug,\n                \"stage\": stage,\n                \"stage_label\": stage_label(stage),\n                \"confirm_status\": ticket.get(\"confirm_status\") or confirmation.get(\"status\") if confirmation else ticket.get(\"confirm_status\"),\n                \"execute_status\": ticket.get(\"execute_status\") or \"\",\n                \"position_qty\": position_qty,\n                \"order_qty\": order_qty,\n                \"source_qty\": to_int(ticket.get(\"source_qty\")),\n                \"risk_gate\": risk_gate or \"-\",\n                \"gate_reason\": gate_reason or \"-\",\n            }\n        )\n    return profiles\n\n\ndef build_candidate_entry(\n    *,\n    side: str,\n    candidate: dict[str, Any],\n    strategy: dict[str, Any],\n    summary: dict[str, Any],\n    ticket_map: dict[tuple[str, str], list[dict[str, str]]],\n    order_map: dict[tuple[str, str], list[dict[str, str]]],\n    trade_map: dict[tuple[str, str], list[dict[str, str]]],\n    position_map: dict[str, dict[str, Any]],\n\n[215 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1774346246878}}
{"type":"message","id":"6e2eff7a","parentId":"e1953e33","timestamp":"2026-03-24T09:57:26.903Z","message":{"role":"toolResult","toolCallId":"call_qpn0AfM0feZyBxvsWGXUGM5k|fc_0fb068e88b60a2b20169c2600640e48194ad0ae947bcc6be07","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport subprocess\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom investment_research_health_snapshot import build_health_snapshot, latest_health_probe_for_date\nfrom openclaw_runtime_status import build_runtime_status\nfrom investment_research_paper_bridge import build_paper_execution_snapshot\nfrom morning_news_state_utils import normalize_morning_news_state\nfrom report_io import atomic_write_json, atomic_write_text\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\nQAS_PROJECT_DIR = WORKSPACE / \"quant_projects\" / \"personal-a-share-research-system\"\nQAS_REPORT_DIR = QAS_PROJECT_DIR / \"research\" / \"reports\"\nBACKTEST_QUEUE_SCRIPT = QAS_PROJECT_DIR / \"scripts\" / \"report_backtest_queue_status.py\"\nLIVE_TRADING_CONFIG = QAS_PROJECT_DIR / \"config\" / \"live_trading_v1.json\"\nMEETING_TYPES = [\"morning\", \"midday\", \"close\", \"night\"]\nCYCLES = [\"pre_open\", \"intraday\", \"post_close\", \"overnight\"]\n\n\ndef today_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef maybe_json(path: Path) -> dict[str, Any] | None:\n    return load_json(path) if path.exists() else None\n\n\ndef dashboard_path(meeting_type: str) -> Path:\n    return REPORT_DIR / f\"investment_research_chief_dashboard_{meeting_type}_{today_tag()}.json\"\n\n\ndef chief_broadcast_path(meeting_type: str) -> Path:\n    return REPORT_DIR / f\"investment_research_chief_broadcast_{meeting_type}_{today_tag()}.md\"\n\n\ndef cycle_path(cycle: str) -> Path:\n    return REPORT_DIR / f\"investment_research_background_cycle_{cycle}_{today_tag()}.json\"\n\n\ndef morning_news_state() -> tuple[dict[str, Any] | None, Path]:\n    path = WORKSPACE / \"memory\" / \"global_market_morning_0850_state.json\"\n    return (load_json(path), path) if path.exists() else (None, path)\n\n\ndef latest_strategy_audit() -> tuple[dict[str, Any] | None, Path | None]:\n    candidates = sorted(QAS_REPORT_DIR.glob(\"daily_strategy_audit_*.json\"), key=lambda p: p.stat().st_mtime)\n    if not candidates:\n        return None, None\n    path = candidates[-1]\n    return load_json(path), path\n\n\ndef latest_auto_premarket_precheck() -> tuple[dict[str, Any] | None, Path | None]:\n    candidates = sorted(QAS_REPORT_DIR.glob(\"auto_premarket_precheck_*.json\"), key=lambda p: p.stat().st_mtime)\n    if not candidates:\n        return None, None\n    path = candidates[-1]\n    return load_json(path), path\n\n\ndef live_trading_execution_config() -> dict[str, Any] | None:\n    return load_json(LIVE_TRADING_CONFIG) if LIVE_TRADING_CONFIG.exists() else None\n\n\ndef snapshot_backtest_queue_status() -> tuple[dict[str, Any] | None, Path | None]:\n    if not BACKTEST_QUEUE_SCRIPT.exists():\n        return None, None\n    out_path = REPORT_DIR / f\"investment_research_backtest_queue_status_{today_tag()}.md\"\n    try:\n        proc = subprocess.run(\n            [sys.executable, str(BACKTEST_QUEUE_SCRIPT)],\n            cwd=str(QAS_PROJECT_DIR),\n            capture_output=True,\n            text=True,\n            check=True,\n        )\n        text = proc.stdout.strip()\n        atomic_write_text(out_path, text + \"\\n\", encoding=\"utf-8\")\n        running_count = text.count(\"- PID \")\n        stable_strategy_visible = \"Qlib breadth + turnover hardcap relaxed\" in text\n        return {\n            \"status\": \"OK\",\n            \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"path\": str(out_path),\n            \"running_count\": running_count,\n            \"stable_strategy_visible\": stable_strategy_visible,\n        }, out_path\n    except subprocess.CalledProcessError as exc:\n        atomic_write_text(out_path, (exc.stdout or \"\") + (\"\\n\" + exc.stderr if exc.stderr else \"\"), encoding=\"utf-8\")\n        return {\n            \"status\": \"ERROR\",\n            \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"path\": str(out_path),\n            \"running_count\": None,\n            \"stable_strategy_visible\": False,\n            \"error\": (exc.stderr or exc.stdout or \"\")[-1000:],\n        }, out_path\n\n\ndef parse_dt(text: str | None) -> datetime:\n    if not text:\n        return datetime.min\n    for fmt in [\"%Y-%m-%d %H:%M:%S\", \"%Y-%m-%dT%H:%M:%S.%f\", \"%Y-%m-%dT%H:%M:%S\"]:\n        try:\n            return datetime.strptime(text, fmt)\n        except ValueError:\n            continue\n    return datetime.min\n\n\ndef yes_no(value: Any) -> str:\n    if value is True:\n        return \"是\"\n    if value is False:\n        return \"否\"\n    if value is None or value == \"\":\n        return \"-\"\n    return str(value)\n\n\ndef cn_status(value: Any) -> str:\n    mapping = {\n        \"OK\": \"正常\",\n        \"ERROR\": \"错误\",\n        \"PASS\": \"通过\",\n        \"ALERT\": \"告警\",\n        \"healthy\": \"健康\",\n        \"watch_guarded\": \"警戒观察\",\n        \"offhours_guarded\": \"非交易时段观察\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"halt\": \"暂停\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"observe_defensive\": \"防守观察\",\n        \"RUNNING\": \"运行中\",\n        \"FAILED\": \"失败\",\n        \"SKIP_NON_TRADING_DAY\": \"非交易日跳过\",\n        \"PENDING_TODAY\": \"待今日晨报\",\n        \"STALE\": \"状态过期\",\n        \"PUSH_FAILED\": \"推送失败\",\n        \"GENERATION_FAILED\": \"生成失败\",\n        \"DEADLINE_MISSED\": \"超时未完成\",\n        \"MISSING\": \"缺失\",\n        \"ok\": \"正常\",\n        \"fallback\": \"已回退\",\n        \"failed\": \"部分失败\",\n        \"unavailable\": \"不可用\",\n        \"unknown\": \"未知\",\n        \"fresh\": \"今日已刷新\",\n        \"pending_today_refresh\": \"待今日刷新\",\n        \"stale\": \"已过期\",\n        \"mixed\": \"日期混杂\",\n        \"missing\": \"缺失\",\n    }\n    if value is None or value == \"\":\n        return \"-\"\n    return mapping.get(str(value), str(value))\n\n\ndef cn_text(text: Any) -> str:\n    if text is None or text == \"\":\n        return \"-\"\n    s = str(text)\n    replacements = {\n        \"market_breadth\": \"市场宽度\",\n        \"source_price_divergence\": \"数据源价差分歧\",\n        \"account_sync_age\": \"账户同步时延\",\n        \"observe_defensive\": \"防守观察\",\n        \"halt_new_positions\": \"暂停新增仓位\",\n        \"watch_guarded\": \"警戒观察\",\n        \"healthy\": \"健康\",\n        \"degraded\": \"降级\",\n        \"triggered\": \"已触发\",\n        \"strict precheck\": \"严格盘前检查\",\n        \"BUY\": \"买入\",\n        \"SELL\": \"卖出\",\n        \"normal\": \"正常\",\n        \"cautious\": \"谨慎\",\n        \"normal模式\": \"正常模式\",\n        \"public_source_divergence>\": \"公开网页源存在价差分歧 > \",\n    }\n    for old, new in replacements.items():\n        s = s.replace(old, new)\n    return s\n\n\ndef build_payload(anchor_meeting: str | None = None) -> dict[str, Any]:\n    dashboards: dict[str, dict[str, Any]] = {}\n    meeting_index: list[dict[str, Any]] = []\n    latest_meeting = None\n    latest_dashboard = None\n    latest_dt = datetime.min\n\n    for meeting_type in MEETING_TYPES:\n        path = dashboard_path(meeting_type)\n        dashboard = maybe_json(path)\n        if not dashboard:\n            continue\n        dashboards[meeting_type] = dashboard\n        generated_at = dashboard.get(\"generated_at\")\n        dt = parse_dt(generated_at)\n        meeting_index.append({\n            \"meeting_type\": meeting_type,\n            \"meeting_label\": dashboard.get(\"meeting_label\", meeting_type),\n            \"generated_at\": generated_at,\n            \"dashboard_json\": str(path),\n            \"dashboard_md\": str(path.with_suffix('.md')),\n            \"chief_broadcast_md\": str(chief_broadcast_path(meeting_type)) if chief_broadcast_path(meeting_type).exists() else None,\n            \"trade_card_md\": dashboard.get(\"export_paths\", {}).get(\"trade_card_md\"),\n        })\n        if dt >= latest_dt:\n            latest_dt = dt\n            latest_meeting = meeting_type\n            latest_dashboard = dashboard\n\n    if anchor_meeting and anchor_meeting in dashboards:\n        latest_meeting = anchor_meeting\n        latest_dashboard = dashboards[anchor_meeting]\n\n    duty_index: list[dict[str, Any]] = []\n    for cycle in CYCLES:\n        path = cycle_path(cycle)\n        payload = maybe_json(path)\n        if not payload:\n            continue\n        duty_index.append({\n            \"cycle\": cycle,\n            \"generated_at\": payload.get(\"generated_at\"),\n            \"status\": payload.get(\"data_source_runtime\", {}).get(\"status\"),\n            \"md\": str(path.with_suffix('.md')),\n            \"json\": str(path),\n        })\n\n    health_scope, health_probe, health_path = latest_health_probe_for_date(REPORT_DIR, today_tag())\n    health_snapshot = build_health_snapshot(health_scope, health_probe, health_path)\n    morning_news, morning_news_path = morning_news_state()\n    morning_news_norm = normalize_morning_news_state(morning_news)\n    strategy_audit, strategy_audit_path = latest_strategy_audit()\n    auto_premarket_precheck, auto_premarket_precheck_path = latest_auto_premarket_precheck()\n    paper_execution = build_paper_execution_snapshot()\n    execution_status = {\n        \"path\": str((paper_execution.get(\"files\") or {}).get(\"summary_json\") or \"\"),\n        \"date\": paper_execution.get(\"date_tag\"),\n        \"time\": paper_execution.get(\"generated_at\"),\n        \"status\": \"paper_only\",\n        \"status_reason\": \"execution_status 已切换为三套模拟盘口径\",\n\n[226 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1774346246889}}
{"type":"message","id":"de305222","parentId":"6e2eff7a","timestamp":"2026-03-24T09:57:26.917Z","message":{"role":"toolResult","toolCallId":"call_gjYNSjQuoI9eB2kcV8NpU38i|fc_0fb068e88b60a2b20169c2600640f08194bd628aa6cd4634af","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n每日执行卡生成器 v2\n增强版：① 个股目标价/止损价 ② 持仓盈亏分析 ③ 舆情摘要\n\"\"\"\n\nimport re, json, csv, sys, html as html_mod\nfrom pathlib import Path\nfrom datetime import datetime\n\nWORKSPACE = Path.home() / \".openclaw/workspace\"\nREPORTS = WORKSPACE / \"research/reports\"\nQUANT = Path.home() / \".openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports\"\nFEISHU_WEBHOOK = \"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\"\n\ndef clean(text):\n    text = re.sub(r\"<[^>]+>\", \"\", str(text or \"\"))\n    return html_mod.unescape(text).strip()\n\ndef load_json(path):\n    try:\n        return json.loads(Path(path).read_text())\n    except:\n        return {}\n\ndef load_txt(path):\n    try:\n        return Path(path).read_text(encoding=\"utf-8\")\n    except:\n        return \"\"\n\ndef get_latest_file(pattern, base):\n    files = sorted(Path(base).glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)\n    return files[0] if files else None\n\n# ====== 数据获取 ======\ndef get_strategy_report():\n    f = get_latest_file(\"today_stock_strategy_report_????????.md\", QUANT)\n    if not f:\n        f = QUANT / \"today_stock_strategy_report_latest.md\"\n    return load_txt(f) if f.exists() else \"\"\n\ndef get_audit():\n    f = get_latest_file(\"daily_strategy_audit_*.json\", QUANT)\n    return load_json(f) if f else {}\n\ndef get_holdings():\n    f = get_latest_file(\"account_holdings_????????.csv\", QUANT)\n    if not f:\n        return []\n    rows = []\n    with open(f, encoding=\"utf-8-sig\") as fp:\n        for r in csv.DictReader(fp):\n            rows.append(r)\n    return rows\n\ndef get_intelligence_brief():\n    f = REPORTS / \"intelligence_brief_latest.md\"\n    return load_txt(f) if f.exists() else \"\"\n\n# ====== 解析策略报告 ======\ndef parse_strategy(content):\n    result = {\n        \"buy_count\": 0, \"sell_count\": 0,\n        \"buy_candidates\": [],\n        \"risk_off\": None,\n        \"market_breadth\": None,\n        \"report_date\": None,\n    }\n    if not content:\n        return result\n\n    m = re.search(r\"形成 `(\\d+)` 个去重 BUY 候选\", content)\n    if m: result[\"buy_count\"] = int(m.group(1))\n    m = re.search(r\"形成 `(\\d+)` 个去重 SELL 候选\", content)\n    if m: result[\"sell_count\"] = int(m.group(1))\n    m = re.search(r\"宽度门禁：当前 `([\\d.]+)%`\", content)\n    if m: result[\"market_breadth\"] = float(m.group(1))\n\n    # 从表格提取候选（含价格）\n    for m in re.finditer(\n        r\"^\\|\\s*(\\d+)\\s*\\|\\s*(\\d{6}\\.[A-Z]{2})\\s*\\|\\s*([^|]+?)\\s*\\|\\s*[\\d.]+\\s*\\|\\s*\\w+\\s*\\|\\s*([\\d.]+)\\s*\\|\\s*(买入|卖出|观望)\\s*\\|\",\n        content, re.MULTILINE\n    ):\n        rank, code, name, price, action = m.group(1), m.group(2), m.group(3).strip(), m.group(4), m.group(5)\n        result[\"buy_candidates\"].append({\n            \"rank\": rank, \"code\": code, \"name\": clean(name),\n            \"price\": price, \"action\": action,\n            \"stop_loss\": \"\", \"take_profit\": \"\", \"trigger\": \"\"\n        })\n\n    # 尝试找止损/止盈（从 BUY 候选行的后面部分）\n    for cand in result[\"buy_candidates\"]:\n        code = cand[\"code\"]\n        # 在内容中搜索该代码相关的止损止盈\n        pattern = re.compile(\n            rf\"`{re.escape(code)}`[^\\n]*\\n.*?止损[/:：]\\s*([\\d.]+).*?止[盈盈率][/:：]\\s*([\\d.]+)\",\n            re.DOTALL\n        )\n        sm = pattern.search(content)\n        if sm:\n            cand[\"stop_loss\"] = sm.group(1)\n            cand[\"take_profit\"] = sm.group(2)\n\n    return result\n\n# ====== 解析舆情简报 ======\ndef parse_intelligence(brief):\n    \"\"\"从情报简报提取热点摘要\"\"\"\n    sections = []\n    if not brief:\n        return sections\n\n    # 提取各类别前3条标题\n    current_section = None\n    current_items = []\n    for line in brief.split(\"\\n\"):\n        m = re.match(r\"^\\*\\*([^*]+)\\*\\*（(\\d+) 条）\", line)\n        if m:\n            if current_section and current_items:\n                sections.append({\"name\": current_section, \"items\": current_items[:3]})\n            current_section = m.group(1)\n            current_items = []\n        elif line.strip().startswith(\"- \") and current_section:\n            title = line.strip()[2:]\n            if title and not title.startswith((\"http\", \"PDF\", \"附件\")):\n                current_items.append(clean(title))\n\n    if current_section and current_items:\n        sections.append({\"name\": current_section, \"items\": current_items[:3]})\n\n    return sections\n\n# ====== 统一持仓字段 ======\ndef norm_h(h):\n    return {\n        \"symbol\": h.get(\"ts_code\") or h.get(\"symbol\", \"\"),\n        \"name\": h.get(\"name\", \"\"),\n        \"quantity\": int(h.get(\"qty\") or h.get(\"quantity\") or 0),\n        \"asset_type\": h.get(\"asset_type\", \"stock\"),\n        \"currency\": h.get(\"currency\", \"CNY\"),\n        \"cost_price\": float(h.get(\"cost_price\") or 0),\n    }\n\n# ====== 构建执行卡 ======\ndef build_exec_card(strategy, audit, holdings, ibrief):\n    now = datetime.now()\n    date_str = now.strftime(\"%Y-%m-%d\")\n    holdings = [norm_h(h) for h in holdings]\n\n    lines = []\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"📋 每日执行卡 v2\")\n    lines.append(f\"{date_str} {now.strftime('%H:%M')} | 交易日\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    # ===== 系统状态 =====\n    status = audit.get(\"overall_status\", \"?\")\n    ar = audit.get(\"annual_return_pct\", 0)\n    mdd = audit.get(\"max_drawdown_pct\", 0)\n    sharpe = audit.get(\"sharpe\", 0)\n    mode = audit.get(\"execution_scope\", \"unknown\")\n    risk_off = audit.get(\"risk_off\", None)\n\n    lines.append(f\"\\n【系统状态】{'✅' if status in ('PASS','ok') else '⚠️'} {'正常' if status in ('PASS','ok') else status}\")\n    lines.append(f\"  年化 {ar:.1f}% | 回撤 {mdd:.1f}% | 夏普 {sharpe:.2f}\")\n\n    if risk_off is not None:\n        lines.append(f\"\\n【风险框架】{'🔴' if risk_off else '🟢'} {'风险收缩中' if risk_off else '正常'}\")\n\n    bw = strategy.get(\"market_breadth\")\n    if bw:\n        icon = \"🟢\" if bw >= 28 else \"🟡\" if bw >= 14 else \"🔴\"\n        lines.append(f\"  市场宽度 {bw:.2f}% {icon}\")\n\n    # ===== 执行模式 =====\n    mode_map = {\n        \"halt\": (\"⏸️ 暂停开仓\", \"风控阻断，不追新仓\"),\n        \"probe\": (\"🟡 试探模式\", \"小仓位试探\"),\n        \"normal\": (\"🟢 正常执行\", \"可执行信号\"),\n        \"paper_profiles_only\": (\"🟡 模拟盘模式\", \"观察为主，不执行\"),\n    }\n    mode_text, mode_note = mode_map.get(mode, (f\"❓ {mode}\", \"\"))\n    lines.append(f\"\\n【执行模式】{mode_text}\")\n    if mode_note:\n        lines.append(f\"  → {mode_note}\")\n\n    # ===== 持仓概览 + 盈亏预览 =====  ①\n    a_stock = [h for h in holdings if h[\"currency\"] != \"HKD\"]\n    hk_stock = [h for h in holdings if h[\"currency\"] == \"HKD\"]\n    etf_stock = [h for h in holdings if h[\"asset_type\"] == \"etf\" or h[\"symbol\"].startswith(\"5\") or \"ETF\" in h.get(\"name\",\"\").upper()]\n\n    lines.append(f\"\\n【持仓】A股 {len(a_stock)} 只 | 港股 {len(hk_stock)} 只 | ETF {len(etf_stock)} 只\")\n    lines.append(f\"  注：实时盈亏需网络畅通，akshare断开时显示成本价\")\n\n    # 按代码找策略报告中的相关价格\n    strat_prices = {}\n    for c in strategy.get(\"buy_candidates\", []):\n        strat_prices[c[\"code\"]] = c\n\n    # 展示前5只 + 有信号的持仓\n    shown = 0\n    for h in holdings:\n        if shown >= 5:\n            break\n        code = h[\"symbol\"]\n        name = h.get(\"name\", \"\") or code\n        qty = h[\"quantity\"]\n        cost = h[\"cost_price\"]\n        # 找策略报告中的价格\n        strat = strat_prices.get(code, {})\n        strat_price = strat.get(\"price\", \"\")\n        action = strat.get(\"action\", \"\")\n        stop_loss = strat.get(\"stop_loss\", \"\")\n        take_profit = strat.get(\"take_profit\", \"\")\n\n        # 标注信号\n        sig = \"\"\n        if action == \"卖出\":\n            sig = \" ⚠️ 卖出信号\"\n        elif action == \"观望\":\n            sig = \" 👀 观望\"\n\n        lines.append(f\"  • {code} {name[:8]} ×{qty}手 成本:{cost}{sig}\")\n        if strat_price:\n            lines.append(f\"    当前参考价:{strat_price} | 止损:{stop_loss or '?'} 目标:{take_profit or '?'}\")\n        shown += 1\n\n    if len(holdings) > 5:\n        lines.append(f\"  ... 还有 {len(holdings)-5} 只（见完整持仓）\")\n\n    # ===== 今日 BUY 信号 =====  ②（目标价/止损价）\n    buy_cands = strategy.get(\"buy_candidates\", [])\n    buy_count = strategy.get(\"buy_count\", 0)\n\n    if buy_count > 0:\n        lines.append(f\"\\n【今日 BUY 信号】{buy_count} 个候选\")\n        shown = 0\n        for cand in buy_cands:\n            if shown >= 3:\n                break\n            action = cand.get(\"action\", \"\")\n            exec_icon = \"⚠️\" if \"观望\" in action else (\"✅\" if mode == \"normal\" else (\"🟡\" if mode == \"probe\" else \"⛔\"))\n            lines.append(f\"  {exec_icon} {cand['code']} {cand.get('name','')[:8]} @ {cand['price']}\")\n            sl = cand.get(\"stop_loss\") or \"?\"\n            tp = cand.get(\"take_profit\") or \"?\"\n            lines.append(f\"     止损:{sl} | 目标:{tp}\")\n            shown += 1\n        if buy_count > 3:\n            lines.append(f\"  ... 还有 {buy_count-3} 个（见完整报告）\")\n    else:\n        lines.append(f\"\\n【今日 BUY 信号】0 个（市场宽度或风控阻断）\")\n\n    # ===== SELL 信号 =====\n    sell_count = strategy.get(\"sell_count\", 0)\n    if sell_count > 0:\n        lines.append(f\"\\n【今日 SELL 信号】{sell_count} 个\")\n    else:\n        lines.append(f\"\\n【持仓监控】软止损 {audit.get('soft_stop_pct',-5)}% | 硬止损 {audit.get('stop_loss_pct',-8)}%\")\n\n\n[50 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1774346246890}}
