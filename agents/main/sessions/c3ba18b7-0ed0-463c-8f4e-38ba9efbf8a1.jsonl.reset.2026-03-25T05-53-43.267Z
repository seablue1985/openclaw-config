{"type":"message","id":"c9fab42b","parentId":"ab0f491a","timestamp":"2026-03-24T09:41:33.205Z","message":{"role":"toolResult","toolCallId":"call_PSYpFVV4fdUGG7faQ2dc5yXz|fc_0fb068e88b60a2b20169c25c4c7fc8819489c57879b79210b9","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env bash\nset -euo pipefail\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\nWORKSPACE_ROOT=\"$(cd \"$ROOT/../..\" && pwd)\"\nPUSH_SCRIPT=\"$WORKSPACE_ROOT/scripts/push_investment_research_paper_execution.py\"\ncd \"$ROOT\"\n\nexport LITELLM_LOCAL_MODEL_COST_MAP=true\n\nDATE_TAG=\"${1:-$(date +%Y%m%d)}\"\nstatus=0\n\nif bash scripts/run_paper_trading_profiles_auto_v1.sh \"$DATE_TAG\"; then\n  :\nelse\n  status=$?\n  echo \"[WARN] paper profile refresh failed date=${DATE_TAG} exit=${status}\" >&2\nfi\n\nif [[ $status -eq 0 && -f \"$PUSH_SCRIPT\" ]]; then\n  python3 \"$PUSH_SCRIPT\" --date-tag \"$DATE_TAG\" || true\nfi\n\npython3 scripts/generate_stock_lens_dashboard.py\npython3 scripts/generate_strategy_performance_panel.py\npython3 scripts/generate_control_tower_daily.py\npython3 scripts/push_control_tower_alert_if_changed.py || true\npython3 scripts/generate_cto_real_data_dashboard.py\npython3 scripts/generate_dashboard_portal.py\n\nexit \"$status\"\n"}],"isError":false,"timestamp":1774345293193}}
