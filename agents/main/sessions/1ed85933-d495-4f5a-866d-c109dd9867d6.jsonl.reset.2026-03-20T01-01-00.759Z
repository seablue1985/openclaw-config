{"type":"message","id":"53dfa60d","parentId":"9da63605","timestamp":"2026-03-19T14:47:02.246Z","message":{"role":"toolResult","toolCallId":"call_function_rdknc0wkqfyw_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nimport time\nfrom typing import Any\n\n\ndef fetch_from_akshare(max_retry: int = 2, sleep_sec: float = 1.5) -> dict[str, Any]:\n    last_error = \"\"\n    for attempt in range(1, max_retry + 1):\n        try:\n            import akshare as ak  # lazy import\n            df = ak.stock_zh_a_spot_em()\n            if df is None or df.empty:\n                raise RuntimeError(\"stock_zh_a_spot_em returned empty\")\n            change_col = None\n            for cand in [\"涨跌幅\", \"涨跌幅%\", \"涨跌幅(%)\"]:\n                if cand in df.columns:\n                    change_col = cand\n                    break\n            if change_col is None:\n                raise RuntimeError(f\"missing change column: {list(df.columns)}\")\n            changes = df[change_col]\n            changes = changes.astype(str).str.replace('%', '', regex=False)\n            changes = changes.replace({'-': None, 'None': None, 'nan': None})\n            changes = changes.astype(float).dropna()\n            if changes.empty:\n                raise RuntimeError(\"no valid change pct rows\")\n            up = int((changes > 0).sum())\n            down = int((changes < 0).sum())\n            flat = int((changes == 0).sum())\n            total = int(len(changes))\n            ratio = float(up / total) if total > 0 else None\n            return {\n                \"available\": True,\n                \"source\": \"akshare.stock_zh_a_spot_em\",\n                \"up_count\": up,\n                \"down_count\": down,\n                \"flat_count\": flat,\n                \"total_count\": total,\n                \"up_ratio\": ratio,\n            }\n        except Exception as e:  # noqa: BLE001\n            last_error = repr(e)\n            if attempt < max_retry:\n                time.sleep(sleep_sec)\n    return {\n        \"available\": False,\n        \"source\": \"akshare.stock_zh_a_spot_em\",\n        \"error\": last_error,\n    }\n\n\ndef fetch_from_efinance() -> dict[str, Any]:\n    try:\n        import efinance as ef  # lazy import\n        df = ef.stock.get_realtime_quotes()\n        if df is None or df.empty:\n            raise RuntimeError('efinance realtime quotes empty')\n        change_col = None\n        for cand in ['涨跌幅', '涨跌幅(%)']:\n            if cand in df.columns:\n                change_col = cand\n                break\n        if change_col is None:\n            raise RuntimeError(f'missing change column: {list(df.columns)}')\n        changes = df[change_col]\n        changes = changes.astype(str).str.replace('%', '', regex=False)\n        changes = changes.replace({'-': None, 'None': None, 'nan': None})\n        changes = changes.astype(float).dropna()\n        if changes.empty:\n            raise RuntimeError('no valid change pct rows')\n        up = int((changes > 0).sum())\n        down = int((changes < 0).sum())\n        flat = int((changes == 0).sum())\n        total = int(len(changes))\n        ratio = float(up / total) if total > 0 else None\n        return {\n            \"available\": True,\n            \"source\": \"efinance.stock.get_realtime_quotes\",\n            \"up_count\": up,\n            \"down_count\": down,\n            \"flat_count\": flat,\n            \"total_count\": total,\n            \"up_ratio\": ratio,\n        }\n    except Exception as e:  # noqa: BLE001\n        return {\n            \"available\": False,\n            \"source\": \"efinance.stock.get_realtime_quotes\",\n            \"error\": repr(e),\n        }\n\n\ndef fetch_intraday_breadth(max_retry: int = 2, sleep_sec: float = 1.5) -> dict[str, Any]:\n    \"\"\"双源兜底：AkShare -> Efinance。\"\"\"\n    ak = fetch_from_akshare(max_retry=max_retry, sleep_sec=sleep_sec)\n    if ak.get('available'):\n        return ak\n    ef = fetch_from_efinance()\n    if ef.get('available'):\n        return ef\n    return {\n        \"available\": False,\n        \"source\": \"akshare.stock_zh_a_spot_em|efinance.stock.get_realtime_quotes\",\n        \"error\": {\n            \"akshare\": ak.get('error'),\n            \"efinance\": ef.get('error'),\n        },\n    }\n\n\nif __name__ == \"__main__\":\n    print(json.dumps(fetch_intraday_breadth(), ensure_ascii=False, indent=2))"}],"details":{"status":"completed","exitCode":0,"durationMs":10,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nimport time\nfrom typing import Any\n\n\ndef fetch_from_akshare(max_retry: int = 2, sleep_sec: float = 1.5) -> dict[str, Any]:\n    last_error = \"\"\n    for attempt in range(1, max_retry + 1):\n        try:\n            import akshare as ak  # lazy import\n            df = ak.stock_zh_a_spot_em()\n            if df is None or df.empty:\n                raise RuntimeError(\"stock_zh_a_spot_em returned empty\")\n            change_col = None\n            for cand in [\"涨跌幅\", \"涨跌幅%\", \"涨跌幅(%)\"]:\n                if cand in df.columns:\n                    change_col = cand\n                    break\n            if change_col is None:\n                raise RuntimeError(f\"missing change column: {list(df.columns)}\")\n            changes = df[change_col]\n            changes = changes.astype(str).str.replace('%', '', regex=False)\n            changes = changes.replace({'-': None, 'None': None, 'nan': None})\n            changes = changes.astype(float).dropna()\n            if changes.empty:\n                raise RuntimeError(\"no valid change pct rows\")\n            up = int((changes > 0).sum())\n            down = int((changes < 0).sum())\n            flat = int((changes == 0).sum())\n            total = int(len(changes))\n            ratio = float(up / total) if total > 0 else None\n            return {\n                \"available\": True,\n                \"source\": \"akshare.stock_zh_a_spot_em\",\n                \"up_count\": up,\n                \"down_count\": down,\n                \"flat_count\": flat,\n                \"total_count\": total,\n                \"up_ratio\": ratio,\n            }\n        except Exception as e:  # noqa: BLE001\n            last_error = repr(e)\n            if attempt < max_retry:\n                time.sleep(sleep_sec)\n    return {\n        \"available\": False,\n        \"source\": \"akshare.stock_zh_a_spot_em\",\n        \"error\": last_error,\n    }\n\n\ndef fetch_from_efinance() -> dict[str, Any]:\n    try:\n        import efinance as ef  # lazy import\n        df = ef.stock.get_realtime_quotes()\n        if df is None or df.empty:\n            raise RuntimeError('efinance realtime quotes empty')\n        change_col = None\n        for cand in ['涨跌幅', '涨跌幅(%)']:\n            if cand in df.columns:\n                change_col = cand\n                break\n        if change_col is None:\n            raise RuntimeError(f'missing change column: {list(df.columns)}')\n        changes = df[change_col]\n        changes = changes.astype(str).str.replace('%', '', regex=False)\n        changes = changes.replace({'-': None, 'None': None, 'nan': None})\n        changes = changes.astype(float).dropna()\n        if changes.empty:\n            raise RuntimeError('no valid change pct rows')\n        up = int((changes > 0).sum())\n        down = int((changes < 0).sum())\n        flat = int((changes == 0).sum())\n        total = int(len(changes))\n        ratio = float(up / total) if total > 0 else None\n        return {\n            \"available\": True,\n            \"source\": \"efinance.stock.get_realtime_quotes\",\n            \"up_count\": up,\n            \"down_count\": down,\n            \"flat_count\": flat,\n            \"total_count\": total,\n            \"up_ratio\": ratio,\n        }\n    except Exception as e:  # noqa: BLE001\n        return {\n            \"available\": False,\n            \"source\": \"efinance.stock.get_realtime_quotes\",\n            \"error\": repr(e),\n        }\n\n\ndef fetch_intraday_breadth(max_retry: int = 2, sleep_sec: float = 1.5) -> dict[str, Any]:\n    \"\"\"双源兜底：AkShare -> Efinance。\"\"\"\n    ak = fetch_from_akshare(max_retry=max_retry, sleep_sec=sleep_sec)\n    if ak.get('available'):\n        return ak\n    ef = fetch_from_efinance()\n    if ef.get('available'):\n        return ef\n    return {\n        \"available\": False,\n        \"source\": \"akshare.stock_zh_a_spot_em|efinance.stock.get_realtime_quotes\",\n        \"error\": {\n            \"akshare\": ak.get('error'),\n            \"efinance\": ef.get('error'),\n        },\n    }\n\n\nif __name__ == \"__main__\":\n    print(json.dumps(fetch_intraday_breadth(), ensure_ascii=False, indent=2))","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1773931622235}}
{"type":"message","id":"716d82e6","parentId":"53dfa60d","timestamp":"2026-03-19T14:48:01.894Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The `intraday_market_breadth.py` fetches ALL stocks' real-time data and calculates market breadth (up/down ratio). This is a fundamentally different operation from fetching individual quotes - it needs to fetch ALL stocks in the market to compute the breadth ratio.\n\nThe `DataFetcherManager.get_realtime_quote()` is designed for individual stock fetching, not bulk fetching of all stocks.\n\nHowever, I can add a THS-based approach to `intraday_market_breadth.py`. The THS fetcher might support batch/bulk quote fetching.\n\nActually, looking at the script, the issue is:\n\n\n1. AkShare is blocked by proxy\n2. eFinance is also likely blocked\n\nBut we already confirmed that Tushare works! Tushare has a daily API that gives us the pct_change for all stocks. Though it's end-of-day data rather than real-time breadth, it might be usable as a fallback if the other sources are unavailable.\n\nThe key insight is that while `intraday_market_breadth.py` uses AkShare and eFinance directly, if those fail, the `DataFetcherManager` already has fallback logic built in. The most practical approach is to enhance `intraday_market_breadth.py` to use `DataFetcherManager` for individual stock fetching, then compute breadth from those results - it's slower but ensures unified routing. I should also add Tushare as a fallback since we know it works, which would give us a third data source to try if both AkShare and eFinance are blocked. Tushare as third fallback. Let me check if the `DataFetcherManager` has a method for getting all stocks or if I need to implement this differently.\n\nActually, for market breadth, the cleanest approach is to add Tushare as a third fallback source (since we know Tushare works), and also try to use the unified fetcher for individual quotes.\n\nBut computing breadth from individual quotes for 5000+ stocks would be very slow. \n\nThe better approach: since `intraday_market_breadth.py` is specifically for computing market breadth (up_count/total), and the main issue is both AkShare and eFinance are blocked by proxy, I should add Tushare as a third source.\n\nTushare's `daily` API with `trade_date` gives us today's data including `pct_chg`. This would work for breadth computation. I already successfully fetched from Tushare earlier, so I can use `pro.daily(trade_date='20260319')` to get all stocks' data for today and compute the breadth from that.","thinkingSignature":"7775c3141cf773aa5178167de801ef7857b4f1499a517b5b8fc5ff051deddf14"},{"type":"text","text":"`intraday_market_breadth.py` 的问题是 AkShare 和 eFinance 都被代理堵了。需要给它加 Tushare 作为第三个 fallback：\n"},{"type":"toolCall","id":"call_function_hwm1uaf4h4mf_1","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/intraday_market_breadth.py","content":"#!/usr/bin/env python3\n\"\"\"\n盘中实时市场宽度（上涨家数比）- 多源兜底\n\n数据源优先级（三源兜底）：\n1. AkShare（东方财富实时）\n2. eFinance（腾讯/新浪实时）\n3. Tushare Pro（日线今日数据，降级兜底）\n\n当 1+2 都被代理阻塞时，尝试 Tushare（已知在当前环境可用）。\n\"\"\"\nfrom __future__ import annotations\n\nimport json\nimport time\nfrom pathlib import Path\nfrom typing import Any\n\nROOT = Path(__file__).resolve().parents[1]\n\n\n# ── 1. AkShare ─────────────────────────────────────────────────────────────\ndef fetch_from_akshare(max_retry: int = 2, sleep_sec: float = 1.5) -> dict[str, Any]:\n    last_error = \"\"\n    for attempt in range(1, max_retry + 1):\n        try:\n            import akshare as ak\n            df = ak.stock_zh_a_spot_em()\n            if df is None or df.empty:\n                raise RuntimeError(\"stock_zh_a_a_spot_em returned empty\")\n            change_col = None\n            for cand in [\"涨跌幅\", \"涨跌幅%\", \"涨跌幅(%)\"]:\n                if cand in df.columns:\n                    change_col = cand\n                    break\n            if change_col is None:\n                raise RuntimeError(f\"missing change column: {list(df.columns)}\")\n            changes = df[change_col].astype(str).str.replace('%', '', regex=False)\n            changes = changes.replace({'-': None, 'None': None, 'nan': None}).astype(float).dropna()\n            if changes.empty:\n                raise RuntimeError(\"no valid change pct rows\")\n            up = int((changes > 0).sum())\n            down = int((changes < 0).sum())\n            flat = int((changes == 0).sum())\n            total = int(len(changes))\n            ratio = float(up / total) if total > 0 else None\n            return {\n                \"available\": True,\n                \"source\": \"akshare.stock_zh_a_spot_em\",\n                \"up_count\": up, \"down_count\": down, \"flat_count\": flat,\n                \"total_count\": total, \"up_ratio\": ratio,\n            }\n        except Exception as e:\n            last_error = repr(e)\n            if attempt < max_retry:\n                time.sleep(sleep_sec)\n    return {\"available\": False, \"source\": \"akshare.stock_zh_a_spot_em\", \"error\": last_error}\n\n\n# ── 2. eFinance ─────────────────────────────────────────────────────────────\ndef fetch_from_efinance() -> dict[str, Any]:\n    try:\n        import efinance as ef\n        df = ef.stock.get_realtime_quotes()\n        if df is None or df.empty:\n            raise RuntimeError('efinance realtime quotes empty')\n        change_col = None\n        for cand in ['涨跌幅', '涨跌幅(%)']:\n            if cand in df.columns:\n                change_col = cand\n                break\n        if change_col is None:\n            raise RuntimeError(f'missing change column: {list(df.columns)}')\n        changes = df[change_col].astype(str).str.replace('%', '', regex=False)\n        changes = changes.replace({'-': None, 'None': None, 'nan': None}).astype(float).dropna()\n        if changes.empty:\n            raise RuntimeError('no valid change pct rows')\n        up = int((changes > 0).sum())\n        down = int((changes < 0).sum())\n        flat = int((changes == 0).sum())\n        total = int(len(changes))\n        ratio = float(up / total) if total > 0 else None\n        return {\n            \"available\": True,\n            \"source\": \"efinance.stock.get_realtime_quotes\",\n            \"up_count\": up, \"down_count\": down, \"flat_count\": flat,\n            \"total_count\": total, \"up_ratio\": ratio,\n        }\n    except Exception as e:\n        return {\"available\": False, \"source\": \"efinance.stock.get_realtime_quotes\", \"error\": repr(e)}\n\n\n# ── 3. Tushare（降级兜底）───────────────────────────────────────────────────\ndef _load_tushare_token() -> str | None:\n    \"\"\"从多个位置加载 Tushare token。\"\"\"\n    paths = [\n        ROOT.parent / 'daily_stock_analysis' / '.env.tushare',\n        ROOT / '.env.tushare',\n        Path.home() / '.openclaw' / 'workspace' / 'quant_projects' / 'daily_stock_analysis' / '.env.tushare',\n    ]\n    for p in paths:\n        if p.exists():\n            for line in p.read_text().splitlines():\n                if 'TUSHARE_TOKEN' in line or line.startswith('export '):\n                    parts = line.strip().split('=')\n                    if len(parts) == 2:\n                        return parts[1].strip().strip(\"'\\\"\")\n    return None\n\n\ndef fetch_from_tushare(trade_date: str = \"\") -> dict[str, Any]:\n    \"\"\"通过 Tushare Pro 获取今日全市场日线数据，计算宽度。\"\"\"\n    import tushare as ts\n\n    token = _load_tushare_token()\n    if not token:\n        return {\"available\": False, \"source\": \"tushare.daily\", \"error\": \"no_token\"}\n    pro = ts.pro_api(token)\n\n    if not trade_date:\n        from datetime import datetime\n        trade_date = datetime.now().strftime('%Y%m%d')\n\n    try:\n        # 获取今日全市场日线（分批，每批100只）\n        # 先拿股票列表\n        df_list = pro.stock_basic(exchange='', list_status='L', fields='ts_code')\n        all_codes = df_list['ts_code'].tolist()\n\n        all_daily = []\n        batch_size = 100\n        rate_limited = False\n        for i in range(0, min(len(all_codes), 5000), batch_size):\n            batch = all_codes[i:i + batch_size]\n            try:\n                df = pro.daily(ts_code=','.join(batch), trade_date=trade_date)\n                if df is not None and not df.empty:\n                    all_daily.append(df[['ts_code', 'pct_chg']])\n                time.sleep(0.2)\n            except Exception as e:\n                if '500' in str(e):\n                    rate_limited = True\n                    break\n                time.sleep(0.5)\n\n        if not all_daily:\n            return {\n                \"available\": False,\n                \"source\": \"tushare.daily\",\n                \"error\": \"rate_limited\" if rate_limited else \"no_data_fetched\",\n            }\n\n        import pandas as pd\n        combined = pd.concat(all_daily, ignore_index=True)\n        changes = combined['pct_chg'].dropna().astype(float)\n        up = int((changes > 0).sum())\n        down = int((changes < 0).sum())\n        flat = int((changes == 0).sum())\n        total = int(len(changes))\n        ratio = float(up / total) if total > 0 else None\n        return {\n            \"available\": True,\n            \"source\": \"tushare.daily\",\n            \"up_count\": up, \"down_count\": down, \"flat_count\": flat,\n            \"total_count\": total, \"up_ratio\": ratio,\n            \"note\": f\"降级数据源（AkShare/eFinance 不可用），基于 {len(combined)} 只股票\",\n        }\n    except Exception as e:\n        return {\"available\": False, \"source\": \"tushare.daily\", \"error\": repr(e)}\n\n\n# ── 主入口 ─────────────────────────────────────────────────────────────────\ndef fetch_intraday_breadth(max_retry: int = 2, sleep_sec: float = 1.5) -> dict[str, Any]:\n    \"\"\"\n    三源兜底：AkShare → eFinance → Tushare。\n    当 1+2 被代理阻塞时，触发 Tushare 降级。\n    \"\"\"\n    # 源1：AkShare\n    ak = fetch_from_akshare(max_retry=max_retry, sleep_sec=sleep_sec)\n    if ak.get('available'):\n        return ak\n\n    # 源2：eFinance\n    ef = fetch_from_efinance()\n    if ef.get('available'):\n        return ef\n\n    # 源3：Tushare（降级兜底）\n    ts_result = fetch_from_tushare()\n    if ts_result.get('available'):\n        return ts_result\n\n    return {\n        \"available\": False,\n        \"source\": \"akshare|efinance|tushare\",\n        \"error\": {\n            \"akshare\": ak.get('error'),\n            \"efinance\": ef.get('error'),\n            \"tushare\": ts_result.get('error'),\n        },\n    }\n\n\nif __name__ == \"__main__\":\n    result = fetch_intraday_breadth()\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":113912,"output":2562,"cacheRead":24293,"cacheWrite":0,"totalTokens":140767,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773931622250}}
