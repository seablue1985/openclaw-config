{"type":"message","id":"6da157b9","parentId":"16173443","timestamp":"2026-03-19T13:45:35.269Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user is repeating their request to do all three layers. I'm already working on layer 1 (which is done) and I'm now on layer 2. Let me continue with layer 2 - creating the premarket risk v2 with market_review integration.\n\nLet me create run_premarket_risk_v2.py that adds the perform_market_review() call.","thinkingSignature":"b32525caa2e9cf84fa91ebb04f6b26328401771e1470fd7ffe421fb297620002"},{"type":"text","text":"继续第二层。我已经在写了，让我把 v2 写完：\n"},{"type":"toolCall","id":"call_function_dta445bupeng_1","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_premarket_risk_v2.py","content":"#!/usr/bin/env python3\n\"\"\"\n盘前风控预警 v2：新增大盘复盘（perform_market_review）集成\n\n在 v1 基础上增加：\n- 调用 analyzer_service.perform_market_review() 获取大盘定性分析\n- 将复盘结果写入输出 JSON 的 market_review 字段\n\"\"\"\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nimport signal\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nif str(PROJECT_ROOT) not in sys.path:\n    sys.path.insert(0, str(PROJECT_ROOT))\n\nfrom risk.risk_engine import RiskContext, RiskEngine\nfrom run_live_execution_v1 import build_runtime_risk_config, load_market_breadth_ratio, load_style_rotation_snapshot\n\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nCONFIG_PATH = PROJECT_ROOT / \"config\" / \"live_trading_v1.json\"\nDATA_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis\")\nDSA_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis\")\n\n# ── analyzer_service integration ─────────────────────────────────────────────\nMARKET_REVIEW_TIMEOUT_SEC = 30\n\n\ndef _load_analyzer_service():\n    \"\"\"Lazy-import analyzer_service.\"\"\"\n    if not (DSA_ROOT / 'analyzer_service.py').exists():\n        return None, 'dsa_root_not_found'\n    if str(DSA_ROOT) not in sys.path:\n        sys.path.insert(0, str(DSA_ROOT))\n    try:\n        import importlib\n        mod = importlib.import_module('analyzer_service')\n        return mod, None\n    except Exception as e:\n        return None, repr(e)\n\n\ndef _timeout_handler(signum, frame):\n    raise TimeoutError('perform_market_review timed out')\n\n\ndef fetch_market_review() -> dict[str, Any]:\n    \"\"\"\n    调用 analyzer_service.perform_market_review() 获取大盘复盘。\n    Returns:\n        {\n            \"available\": bool,\n            \"review\": str | None,\n            \"error\": str | None\n        }\n    \"\"\"\n    mod, err = _load_analyzer_service()\n    if err:\n        return {'available': False, 'review': None, 'error': err}\n\n    old_handler = signal.signal(signal.SIGALRM, _timeout_handler)\n    signal.alarm(MARKET_REVIEW_TIMEOUT_SEC)\n    try:\n        review = mod.perform_market_review()\n        signal.alarm(0)\n        if review is None:\n            return {'available': False, 'review': None, 'error': 'perform_market_review returned None'}\n        return {'available': True, 'review': review, 'error': None}\n    except TimeoutError:\n        signal.alarm(0)\n        return {'available': False, 'review': None, 'error': f'timeout_after_{MARKET_REVIEW_TIMEOUT_SEC}s'}\n    except Exception as e:\n        signal.alarm(0)\n        return {'available': False, 'review': None, 'error': repr(e)}\n    finally:\n        signal.signal(signal.SIGALRM, old_handler)\n\n\n# ── v1 code (保持不变) ─────────────────────────────────────────────────────\nINDEX_FILES = {\n    \"ZZ2000\": DATA_ROOT / \"index_000852_SH.csv\",\n    \"HS300\": DATA_ROOT / \"index_000300_SH.csv\",\n    \"ZZ500\": DATA_ROOT / \"index_000905_SH.csv\",\n}\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef latest_file(pattern: str) -> Path:\n    files = sorted(REPORT_DIR.glob(pattern))\n    if not files:\n        raise FileNotFoundError(f\"未找到文件: {pattern}\")\n    return files[-1]\n\n\ndef parse_float(v: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(v).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef latest_index_return_pct(path: Path) -> float:\n    if not path.exists():\n        return 0.0\n    df = pd.read_csv(path)\n    close = pd.to_numeric(df.get(\"close\"), errors=\"coerce\")\n    ret = close.pct_change().fillna(0.0)\n    if ret.empty:\n        return 0.0\n    return float(ret.iloc[-1] * 100)\n\n\ndef map_runtime_reason(\n    reason: str,\n    *,\n    benchmark_code: str,\n    benchmark_ret: float,\n    market_breadth: float | None,\n    combo_dd: float,\n    combo_sharpe: float,\n    style_snapshot: dict[str, Any],\n    index_halt_threshold: float | None,\n    breadth_riskoff_threshold: float | None,\n    breadth_hard_stop_threshold: float | None,\n    max_dd_threshold: float | None,\n    sharpe_threshold: float | None,\n) -> str:\n    if reason.startswith(\"index_ret_pct\"):\n        if index_halt_threshold is not None:\n            return f\"{benchmark_code}单日{benchmark_ret:.2f}% <= {index_halt_threshold:.2f}%（指数硬停）\"\n        return f\"{benchmark_code}单日收益触发指数硬停\"\n\n    if reason.startswith(\"market_breadth\"):\n        if breadth_hard_stop_threshold is not None and market_breadth is not None and market_breadth <= breadth_hard_stop_threshold:\n            return f\"市场宽度{market_breadth:.3f} <= {breadth_hard_stop_threshold:.3f}（宽度硬停）\"\n        if breadth_riskoff_threshold is not None and market_breadth is not None:\n            return f\"市场宽度{market_breadth:.3f} <= {breadth_riskoff_threshold:.3f}（风险收缩）\"\n        return \"市场宽度触发风险门控\"\n\n    if reason.startswith(\"strategy_max_drawdown_pct\"):\n        if max_dd_threshold is not None:\n            return f\"组合历史回撤{combo_dd:.2f}% >= {max_dd_threshold:.2f}%（风险收缩）\"\n        return f\"组合历史回撤{combo_dd:.2f}%触发风险收缩\"\n\n    if reason.startswith(\"strategy_sharpe\"):\n        if sharpe_threshold is not None:\n            return f\"组合Sharpe {combo_sharpe:.3f} < {sharpe_threshold:.3f}（谨慎模式）\"\n        return f\"组合Sharpe {combo_sharpe:.3f}偏低（谨慎模式）\"\n\n    if reason == \"style_rotation_hard_stop\":\n        return (\n            f\"风格切换硬停：{style_snapshot.get('smallcap_index', 'ZZ2000')}相对\"\n            f\"{style_snapshot.get('broad_index', 'HS300')}\"\n            f\"{int(style_snapshot.get('short_window', 5))}日超额=\"\n            f\"{parse_float(style_snapshot.get('short_excess_pct'), 0.0):.2f}% / \"\n            f\"{int(style_snapshot.get('medium_window', 20))}日超额=\"\n            f\"{parse_float(style_snapshot.get('medium_excess_pct'), 0.0):.2f}%\"\n        )\n\n    if reason == \"style_rotation_riskoff\":\n        return (\n            f\"风格切换收缩：{style_snapshot.get('smallcap_index', 'ZZ2000')}相对\"\n            f\"{style_snapshot.get('broad_index', 'HS300')}\"\n            f\"{int(style_snapshot.get('short_window', 5))}日超额=\"\n            f\"{parse_float(style_snapshot.get('short_excess_pct'), 0.0):.2f}% / \"\n            f\"{int(style_snapshot.get('medium_window', 20))}日超额=\"\n            f\"{parse_float(style_snapshot.get('medium_excess_pct'), 0.0):.2f}%\"\n        )\n\n    if reason == \"manual_hard_stop\":\n        return \"人工硬停触发\"\n\n    if reason == \"manual_risk_off\":\n        return \"人工风险收缩触发\"\n\n    return reason\n\n\ndef evaluate_risk(\n    config: dict[str, Any],\n    live_payload: dict[str, Any],\n    index_ret: dict[str, float],\n    market_breadth: float | None,\n) -> dict[str, Any]:\n    combo = live_payload.get(\"combo_v1\", {})\n    target_cfg = config.get(\"targets\", {})\n    constraints_cfg = config.get(\"constraints\", {})\n\n    combo_dd = parse_float(combo.get(\"max_drawdown_pct\"), 0.0)\n    combo_sharpe = parse_float(combo.get(\"sharpe\"), 0.0)\n    dd_target = parse_float(target_cfg.get(\"max_drawdown_max_pct\"), 25.0)\n    style_snapshot = load_style_rotation_snapshot(config)\n\n    benchmark_code = str(constraints_cfg.get(\"benchmark_smallcap\", \"ZZ2000\"))\n    benchmark_ret = parse_float(index_ret.get(benchmark_code), parse_float(index_ret.get(\"ZZ2000\"), 0.0))\n\n    runtime_cfg = build_runtime_risk_config(config=config, target_dd=dd_target)\n    decision = RiskEngine(runtime_cfg).evaluate_runtime_state(\n        RiskContext(\n            trade_date=datetime.now().strftime(\"%Y-%m-%d\"),\n            market_breadth=market_breadth,\n            index_ret_pct=benchmark_ret,\n            strategy_max_drawdown_pct=combo_dd,\n            strategy_sharpe=combo_sharpe,\n            style_smallcap_short_return_pct=parse_float(style_snapshot.get(\"smallcap_short_return_pct\"), 0.0)\n            if style_snapshot.get(\"smallcap_short_return_pct\") is not None else None,\n            style_smallcap_medium_return_pct=parse_float(style_snapshot.get(\"smallcap_medium_return_pct\"), 0.0)\n            if style_snapshot.get(\"smallcap_medium_return_pct\") is not None else None,\n            style_short_excess_pct=parse_float(style_snapshot.get(\"short_excess_pct\"), 0.0)\n            if style_snapshot.get(\"short_excess_pct\") is not None else None,\n            style_medium_excess_pct=parse_float(style_snapshot.get(\"medium_excess_pct\"), 0.0)\n            if style_snapshot.get(\"medium_excess_pct\") is not None else None,\n        )\n    )\n\n    reasons = [\n        map_runtime_reason(\n            item,\n            benchmark_code=benchmark_code,\n            benchmark_ret=benchmark_ret,\n            market_breadth=market_breadth,\n            combo_dd=combo_dd,\n            combo_sharpe=combo_sharpe,\n            style_snapshot=style_snapshot,\n            index_halt_threshold=runtime_cfg.index_halt_threshold_pct,\n            breadth_riskoff_threshold=runtime_cfg.market_breadth_riskoff_threshold,\n            breadth_hard_stop_threshold=runtime_cfg.market_breadth_hard_stop_threshold,\n            max_dd_threshold=runtime_cfg.strategy_max_drawdown_riskoff_pct,\n            sharpe_threshold=runtime_cfg.strategy_sharpe_cautious_threshold,\n        )\n        for item in decision.reasons\n    ]\n\n    score = 0\n    if decision.hard_stop:\n        score += 4\n    elif decision.risk_off:\n        score += 3\n    elif decision.mode == \"cautious\":\n        score += 2\n    score += min(2, max(0, len(decision.reasons) - 1))\n\n    if decision.hard_stop:\n        level = \"RED\"\n        gross_scale = 0.3\n    elif decision.risk_off:\n        level = \"YELLOW\"\n        gross_scale = 0.6\n    elif decision.mode == \"cautious\":\n        level = \"YELLOW\"\n        gross_scale = 0.8\n    else:\n        level = \"GREEN\"\n        gross_scale = 1.0\n\n    return {\n        \"score\": score,\n        \"level\": level,\n        \"mode\": decision.mode,\n        \"halt_new_buy\": decision.halt_new_buy,\n        \"risk_off\": decision.risk_off,\n        \"hard_stop\": decision.hard_stop,\n        \"gross_scale\": gross_scale,\n        \"reasons\": reasons,\n        \"raw_reasons\": decision.reasons,\n        \"market_breadth\": market_breadth,\n        \"style_snapshot\": style_snapshot,\n        \"runtime_gate\": {\n            \"benchmark_code\": benchmark_code,\n            \"benchmark_ret_pct\": round(benchmark_ret, 4),\n            \"index_halt_threshold_pct\": runtime_cfg.index_halt_threshold_pct,\n            \"market_breadth_riskoff_threshold\": runtime_cfg.market_breadth_riskoff_threshold,\n            \"market_breadth_hard_stop_threshold\": runtime_cfg.market_breadth_hard_stop_threshold,\n            \"strategy_max_drawdown_riskoff_pct\": runtime_cfg.strategy_max_drawdown_riskoff_pct,\n            \"strategy_sharpe_cautious_threshold\": runtime_cfg.strategy_sharpe_cautious_threshold,\n            \"style_rotation_riskoff_short_excess_pct\": runtime_cfg.style_rotation_riskoff_short_excess_pct,\n            \"style_rotation_riskoff_medium_excess_pct\": runtime_cfg.style_rotation_riskoff_medium_excess_pct,\n            \"style_rotation_hard_stop_short_excess_pct\": runtime_cfg.style_rotation_hard_stop_short_excess_pct,\n            \"style_rotation_hard_stop_medium_excess_pct\": runtime_cfg.style_rotation_hard_stop_medium_excess_pct,\n        },\n        \"combo\": {\n            \"annual_return_pct\": combo.get(\"annual_return_pct\"),\n            \"max_drawdown_pct\": combo.get(\"max_drawdown_pct\"),\n            \"sharpe\": combo.get(\"sharpe\"),\n        },\n        \"index_ret_pct\": index_ret,\n    }\n\n\ndef build_md(date_tag: str, payload: dict[str, Any], market_review: str | None = None) -> str:\n    reasons = payload.get(\"reasons\", [])\n    reason_lines = [f\"- {x}\" for x in reasons] if reasons else [\"- 无显著风险触发项\"]\n    runtime_gate = payload.get(\"runtime_gate\", {})\n    style_snapshot = payload.get(\"style_snapshot\", {}) or {}\n    breadth_text = (\n        f\"{payload['market_breadth']:.3f}\" if payload.get(\"market_breadth\") is not None else \"N/A\"\n    )\n\n    review_section = \"\"\n    if market_review:\n        review_section = f\"\"\"\n## 大盘复盘（Analyzer）\n{market_review}\n\"\"\"\n\n    return \"\\n\".join(\n        [\n            f\"# 盘前风控预警 v2（{date_tag}）\",\n            \"\",\n            \"## 风险结论\",\n            f\"- 风险等级：`{payload['level']}`\",\n            f\"- 建议模式：`{payload['mode']}`\",\n            f\"- 是否暂停新开仓：`{payload['halt_new_buy']}`\",\n            f\"- risk_off：`{payload.get('risk_off')}` / hard_stop：`{payload.get('hard_stop')}`\",\n            f\"- 建议总仓位系数：`{payload['gross_scale']}`\",\n            f\"- 风险评分：`{payload['score']}`\",\n            f\"- 市场宽度（上涨家数占比）：`{breadth_text}`\",\n            \"\",\n            \"## 指数监控\",\n            f\"- 中证2000：`{payload['index_ret_pct']['ZZ2000']:.2f}%`\",\n            f\"- 沪深300：`{payload['index_ret_pct']['HS300']:.2f}%`\",\n            f\"- 中证500：`{payload['index_ret_pct']['ZZ500']:.2f}%`\",\n            f\"- 统一门控基准指数：`{runtime_gate.get('benchmark_code', '-')}`\",\n            \"\",\n            \"## 风格因子\",\n            f\"- smallcap_index：`{style_snapshot.get('smallcap_index', '-')}` / broad_index：`{style_snapshot.get('broad_index', '-')}`\",\n            f\"- short_excess_pct：`{style_snapshot.get('short_excess_pct', '-')}` / medium_excess_pct：`{style_snapshot.get('medium_excess_pct', '-')}`\",\n            f\"- smallcap_short_return_pct：`{style_snapshot.get('smallcap_short_return_pct', '-')}` / smallcap_medium_return_pct：`{style_snapshot.get('smallcap_medium_return_pct', '-')}`\",\n            \"\",\n            \"## 组合状态（回测口径）\",\n            f\"- 年化：`{payload['combo']['annual_return_pct']}%`\",\n            f\"- 最大回撤：`{payload['combo']['max_drawdown_pct']}%`\",\n            f\"- 夏普：`{payload['combo']['sharpe']}`\",\n            \"\",\n            \"## 触发原因\",\n            *reason_lines,\n            review_section,\n        ]\n    )\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"盘前风控预警 v2（新增大盘复盘）\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--skip-market-review\", action=\"store_true\",\n                        help=\"跳过大盘复盘（analyzer_service 调用）\")\n    args = parser.parse_args()\n\n    date_tag = args.date.strip() if args.date.strip() else datetime.now().strftime(\"%Y%m%d\")\n\n    config = load_json(CONFIG_PATH)\n    live_json = latest_file(\"live_system_v1_*.json\")\n    live_payload = load_json(live_json)\n\n    index_ret = {k: latest_index_return_pct(v) for k, v in INDEX_FILES.items()}\n    market_breadth = load_market_breadth_ratio()\n    risk_payload = evaluate_risk(\n        config=config,\n        live_payload=live_payload,\n        index_ret=index_ret,\n        market_breadth=market_breadth,\n    )\n    risk_payload[\"date\"] = date_tag\n\n    # ── Layer 2: 接入大盘复盘 ───────────────────────────────────────────\n    market_review_data = None\n    if not args.skip_market_review:\n        market_review_data = fetch_market_review()\n        if market_review_data.get('available'):\n            risk_payload[\"market_review\"] = market_review_data.get('review')\n            risk_payload[\"market_review_available\"] = True\n        else:\n            risk_payload[\"market_review\"] = None\n            risk_payload[\"market_review_available\"] = False\n            risk_payload[\"market_review_error\"] = market_review_data.get('error', 'unknown')\n    else:\n        risk_payload[\"market_review_available\"] = False\n        risk_payload[\"market_review\"] = \"skipped_by_flag\"\n\n    out_json = REPORT_DIR / f\"live_premarket_risk_v2_{date_tag}.json\"\n    out_md = REPORT_DIR / f\"live_premarket_risk_v2_{date_tag}.md\"\n\n    out_json.write_text(json.dumps(risk_payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    out_md.write_text(build_md(date_tag, risk_payload, risk_payload.get(\"market_review\")) + \"\\n\", encoding=\"utf-8\")\n\n    print(json.dumps({\n        \"premarket_json\": str(out_json),\n        \"premarket_md\": str(out_md),\n        \"summary\": risk_payload,\n        \"market_review_available\": risk_payload.get(\"market_review_available\")\n    }, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":80,"output":4300,"cacheRead":0,"cacheWrite":94697,"totalTokens":99077,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773927822192}}
