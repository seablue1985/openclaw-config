{"type":"message","id":"8e0665ce","parentId":"e1a5f971","timestamp":"2026-03-19T15:30:05.596Z","message":{"role":"toolResult","toolCallId":"call_function_b0z4inzhf9at_1","toolName":"exec","content":[{"type":"text","text":"return output\n\n\ndef export_live_lancedb(export_path: Path) -> dict[str, Any]:\n    ensure_dir(export_path.parent)\n    try:\n        run_openclaw(\"memory-pro\", \"export\", \"--output\", str(export_path))\n        return json.loads(export_path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef sanitize_scope(scope: str) -> str:\n    return re.sub(r\"[^A-Za-z0-9_.-]+\", \"_\", scope).strip(\"_\") or \"global\"\n\n\ndef is_high_signal_memory(memory: dict[str, Any]) -> tuple[bool, str]:\n    text = str(memory.get(\"text\", \"\")).strip()\n    category = str(memory.get(\"category\", \"\")).strip()\n    if category not in {\"decision\", \"preference\", \"fact\", \"entity\"}:\n        return False, f\"skip_category:{category or 'unknown'}\""}],"details":{"status":"completed","exitCode":0,"durationMs":8,"aggregated":"return output\n\n\ndef export_live_lancedb(export_path: Path) -> dict[str, Any]:\n    ensure_dir(export_path.parent)\n    try:\n        run_openclaw(\"memory-pro\", \"export\", \"--output\", str(export_path))\n        return json.loads(export_path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef sanitize_scope(scope: str) -> str:\n    return re.sub(r\"[^A-Za-z0-9_.-]+\", \"_\", scope).strip(\"_\") or \"global\"\n\n\ndef is_high_signal_memory(memory: dict[str, Any]) -> tuple[bool, str]:\n    text = str(memory.get(\"text\", \"\")).strip()\n    category = str(memory.get(\"category\", \"\")).strip()\n    if category not in {\"decision\", \"preference\", \"fact\", \"entity\"}:\n        return False, f\"skip_category:{category or 'unknown'}\"","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1773934205589}}
