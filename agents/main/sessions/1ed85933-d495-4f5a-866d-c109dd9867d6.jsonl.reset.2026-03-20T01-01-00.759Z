{"type":"message","id":"17083531","parentId":"4670fd67","timestamp":"2026-03-19T13:29:48.667Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the enhanced version. I'll need to add the analyzer_service integration.","thinkingSignature":"d24386e80e5f77e07ee8a1094c4dc8227b44ee3241c211546edaa27eb4d29552"},{"type":"toolCall","id":"call_function_zl65weseaozo_1","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/stock_level_realtime_gate_v2.py","content":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport csv\nimport json\nimport re\nimport sys\nimport urllib.request\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / 'research' / 'reports'\nDSA_ROOT = Path('/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis')\n\n# ── thresholds for analyzer_service veto ────────────────────────────────────\nSENTIMENT_SCORE_MIN = 40          # below this → block\nNEGATIVE_ADVICES = {\"减仓\", \"卖出\"}\n\n# ── normalise helpers ───────────────────────────────────────────────────────\nCODE_FIELDS = ['ts_code', 'ticker', 'symbol', 'code', 'stock_code']\nSIDE_FIELDS = ['side', 'action', 'order_side', 'trade_side', 'signal_side']\nBUY_VALUES = {'buy', 'open_buy', 'long', 'b'}\n\n\ndef normalize_symbol(symbol: str) -> str:\n    s = str(symbol or '').strip().upper()\n    if not s:\n        return s\n    s = s.replace('.', '')\n    if re.fullmatch(r'\\d{6}SH', s):\n        return 'sh' + s[:6]\n    if re.fullmatch(r'\\d{6}SZ', s):\n        return 'sz' + s[:6]\n    if re.fullmatch(r'SH\\d{6}', s):\n        return 'sh' + s[2:]\n    if re.fullmatch(r'SZ\\d{6}', s):\n        return 'sz' + s[2:]\n    if re.fullmatch(r'\\d{6}', s):\n        return ('sh' if s.startswith('6') else 'sz') + s\n    return s.lower()\n\n\n# ── quote ───────────────────────────────────────────────────────────────────\ndef fetch_quote(symbol: str) -> dict[str, Any]:\n    market_symbol = normalize_symbol(symbol)\n    url = f'http://qt.gtimg.cn/q={market_symbol}'\n    try:\n        with urllib.request.urlopen(url, timeout=8) as resp:\n            text = resp.read().decode('gbk', errors='ignore')\n        m = re.match(r'v_\\w+=\"(.*)\";', text.strip())\n        if not m:\n            return {'valid': False, 'symbol': symbol, 'reason': 'parse_failed'}\n        f = m.group(1).split('~')\n        if len(f) < 48:\n            return {'valid': False, 'symbol': symbol, 'reason': 'field_short'}\n        return {\n            'valid': True,\n            'input_symbol': symbol,\n            'market_symbol': market_symbol,\n            'name': f[1] or '',\n            'price': float(f[3] or 0),\n            'change_pct': float(f[32] or 0),\n        }\n    except Exception as e:\n        return {'valid': False, 'symbol': symbol, 'reason': repr(e)}\n\n\n# ── analyzer_service ────────────────────────────────────────────────────────\ndef _load_analyzer_service():\n    \"\"\"Lazy-import analyzer_service; return (module, error).\"\"\"\n    if not (DSA_ROOT / 'analyzer_service.py').exists():\n        return None, 'dsa_root_not_found'\n    if str(DSA_ROOT) not in sys.path:\n        sys.path.insert(0, str(DSA_ROOT))\n    try:\n        import importlib\n        mod = importlib.import_module('analyzer_service')\n        return mod, None\n    except Exception as e:\n        return None, repr(e)\n\n\ndef fetch_analyzer_analysis(symbol: str) -> dict[str, Any]:\n    \"\"\"\n    Call analyzer_service.analyze_stock and return a dict with:\n      - available: bool\n      - sentiment_score: int | None\n      - operation_advice: str | None\n      - core_conclusion: str | None\n      - error: str | None\n    \"\"\"\n    mod, err = _load_analyzer_service()\n    if err:\n        return {'available': False, 'symbol': symbol, 'error': err}\n    try:\n        result = mod.analyze_stock(symbol)\n        if result is None:\n            return {'available': False, 'symbol': symbol, 'error': 'analyze_stock returned None'}\n        return {\n            'available': True,\n            'symbol': symbol,\n            'sentiment_score': getattr(result, 'sentiment_score', None),\n            'operation_advice': getattr(result, 'operation_advice', None),\n            'core_conclusion': getattr(result, 'core_conclusion', None) or '',\n        }\n    except Exception as e:\n        return {'available': False, 'symbol': symbol, 'error': repr(e)}\n\n\ndef analyzer_veto(analysis: dict[str, Any]) -> tuple[bool, str]:\n    \"\"\"\n    Returns (should_block, reason).\n    \"\"\"\n    if not analysis.get('available'):\n        return False, ''   # no data → don't block on analyzer basis\n    score = analysis.get('sentiment_score')\n    advice = analysis.get('operation_advice') or ''\n    reasons = []\n    if score is not None and int(score) < SENTIMENT_SCORE_MIN:\n        reasons.append(f\"sentiment_score {score} < {SENTIMENT_SCORE_MIN}\")\n    if advice in NEGATIVE_ADVICES:\n        reasons.append(f\"operation_advice '{advice}' in {NEGATIVE_ADVICES}\")\n    if reasons:\n        return True, '; '.join(reasons)\n    return False, ''\n\n\n# ── csv reader ───────────────────────────────────────────────────────────────\ndef load_candidates_from_csv(path: Path) -> list[dict[str, Any]]:\n    rows: list[dict[str, Any]] = []\n    if not path.exists():\n        return rows\n    with path.open('r', encoding='utf-8', newline='') as f:\n        reader = csv.DictReader(f)\n        for row in reader:\n            code = None\n            for field in CODE_FIELDS:\n                if row.get(field):\n                    code = row[field]\n                    break\n            if not code:\n                continue\n            side = ''\n            for field in SIDE_FIELDS:\n                if row.get(field):\n                    side = str(row[field]).strip().lower()\n                    break\n            if side and side not in BUY_VALUES:\n                continue\n            rows.append({'symbol': code, 'raw': row})\n    return rows\n\n\n# ── main ────────────────────────────────────────────────────────────────────\ndef main() -> None:\n    ap = argparse.ArgumentParser(description='个股实时前置门禁 V2（增强：接入 analyzer_service）')\n    ap.add_argument('--date', default=datetime.now().strftime('%Y%m%d'))\n    ap.add_argument('--profile', required=True, choices=['defensive', 'balanced', 'aggressive'])\n    ap.add_argument('--max-down-pct', type=float, default=-3.0)\n    ap.add_argument('--use-analyzer', action='store_true',\n                    help='调用 analyzer_service 进行情绪/建议审查（可能较慢）')\n    ap.add_argument('--sentiment-min', type=int, default=SENTIMENT_SCORE_MIN,\n                    help=f'情绪得分最低阈值（默认 {SENTIMENT_SCORE_MIN}）')\n    args = ap.parse_args()\n\n    csv_path = REPORT_DIR / f'paper_{args.profile}_merged_proposed_orders_{args.date}.csv'\n    candidates = load_candidates_from_csv(csv_path)\n\n    checked = []\n    blocked = []\n    passed = []\n    analyzer_available = False\n\n    for item in candidates:\n        symbol = item['symbol']\n        rec: dict[str, Any] = {'symbol': symbol}\n\n        # Layer 1a: quote check\n        q = fetch_quote(symbol)\n        rec['quote'] = q\n        if not q.get('valid'):\n            rec['decision'] = 'block'\n            rec['block_reason'] = f\"quote_unavailable: {q.get('reason','')}\"\n            blocked.append(rec)\n            checked.append(rec)\n            continue\n        if float(q.get('change_pct') or 0) <= args.max_down_pct:\n            rec['decision'] = 'block'\n            rec['block_reason'] = f\"change_pct {q.get('change_pct')} <= {args.max_down_pct}\"\n            blocked.append(rec)\n            checked.append(rec)\n            continue\n\n        # Layer 1b: analyzer_service check (optional)\n        if args.use_analyzer:\n            analysis = fetch_analyzer_analysis(symbol)\n            rec['analyzer'] = analysis\n            analyzer_available = analyzer_available or analysis.get('available', False)\n            veto, veto_reason = analyzer_veto(analysis)\n            rec['analyzer_veto'] = veto\n            if veto:\n                rec['decision'] = 'block'\n                rec['block_reason'] = f\"analyzer: {veto_reason}\"\n                blocked.append(rec)\n                checked.append(rec)\n                continue\n\n        rec['decision'] = 'pass'\n        passed.append(rec)\n        checked.append(rec)\n\n    payload = {\n        'generated_at': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n        'date_tag': args.date,\n        'profile': args.profile,\n        'source_csv': str(csv_path),\n        'use_analyzer': args.use_analyzer,\n        'sentiment_min': args.sentiment_min,\n        'candidate_count': len(candidates),\n        'passed_count': len(passed),\n        'blocked_count': len(blocked),\n        'analyzer_available': analyzer_available,\n        'blocked': blocked,\n        'passed': passed,\n        'status': 'PASS' if not blocked else 'BLOCK',\n    }\n    out = REPORT_DIR / f'stock_level_realtime_gate_v2_{args.profile}_{args.date}.json'\n    out.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding='utf-8')\n    print(json.dumps(payload, ensure_ascii=False, indent=2))\n    if blocked:\n        raise SystemExit(3)\n\n\nif __name__ == '__main__':\n    main()\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":45257,"output":2212,"cacheRead":24293,"cacheWrite":0,"totalTokens":71762,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773926947831}}
