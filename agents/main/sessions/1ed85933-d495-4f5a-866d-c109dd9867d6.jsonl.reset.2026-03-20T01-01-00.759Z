{"type":"message","id":"0dbfd689","parentId":"679f850d","timestamp":"2026-03-19T13:39:10.977Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me add a timeout wrapper to the fetch_analyzer_analysis function.","thinkingSignature":"8345e0e9a372e08031be2541b294b2012f45f368ae6e3521427b0f5d105f2889"},{"type":"toolCall","id":"call_function_up1hvdkzf7d5_1","name":"edit","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/stock_level_realtime_gate_v2.py","oldText":"def fetch_analyzer_analysis(symbol: str) -> dict[str, Any]:\n    \"\"\"\n    Call analyzer_service.analyze_stock and return a dict with:\n      - available: bool\n      - sentiment_score: int | None\n      - operation_advice: str | None\n      - core_conclusion: str | None\n      - error: str | None\n    \"\"\"\n    mod, err = _load_analyzer_service()\n    if err:\n        return {'available': False, 'symbol': symbol, 'error': err}\n    try:\n        result = mod.analyze_stock(symbol)\n        if result is None:\n            return {'available': False, 'symbol': symbol, 'error': 'analyze_stock returned None'}\n        return {\n            'available': True,\n            'symbol': symbol,\n            'sentiment_score': getattr(result, 'sentiment_score', None),\n            'operation_advice': getattr(result, 'operation_advice', None),\n            'core_conclusion': getattr(result, 'core_conclusion', None) or '',\n        }\n    except Exception as e:\n        return {'available': False, 'symbol': symbol, 'error': repr(e)}","newText":"def _timeout_handler(signum, frame):\n    raise TimeoutError('analyzer_service timed out')\n\n\ndef fetch_analyzer_analysis(symbol: str) -> dict[str, Any]:\n    \"\"\"\n    Call analyzer_service.analyze_stock with a per-stock timeout.\n    Returns a dict with:\n      - available: bool\n      - sentiment_score: int | None\n      - operation_advice: str | None\n      - core_conclusion: str | None\n      - error: str | None\n    \"\"\"\n    mod, err = _load_analyzer_service()\n    if err:\n        return {'available': False, 'symbol': symbol, 'error': err}\n    old_handler = signal.signal(signal.SIGALRM, _timeout_handler)\n    signal.alarm(ANALYZER_TIMEOUT_SEC)\n    try:\n        result = mod.analyze_stock(symbol)\n        signal.alarm(0)\n        if result is None:\n            return {'available': False, 'symbol': symbol, 'error': 'analyze_stock returned None'}\n        return {\n            'available': True,\n            'symbol': symbol,\n            'sentiment_score': getattr(result, 'sentiment_score', None),\n            'operation_advice': getattr(result, 'operation_advice', None),\n            'core_conclusion': getattr(result, 'core_conclusion', None) or '',\n        }\n    except TimeoutError:\n        signal.alarm(0)\n        return {'available': False, 'symbol': symbol, 'error': f'timeout_after_{ANALYZER_TIMEOUT_SEC}s'}\n    except Exception as e:\n        signal.alarm(0)\n        return {'available': False, 'symbol': symbol, 'error': repr(e)}\n    finally:\n        signal.signal(signal.SIGALRM, old_handler)"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":52329,"output":688,"cacheRead":24293,"cacheWrite":0,"totalTokens":77310,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773927538392}}
