{"type":"message","id":"eb40a5d2","parentId":"1e76cecf","timestamp":"2026-03-19T14:37:59.863Z","message":{"role":"toolResult","toolCallId":"call_function_bm24a9aqctop_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n盘中实时大盘门禁 - 用于在买入推荐生成前检查当日实时大盘状态\n避免用昨日/前一日收盘口径支撑当日买入决策\n\"\"\"\nfrom __future__ import annotations\n\nimport json\nimport re\nimport ssl\nimport urllib.request\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any, Optional\n\n# 主要监控的指数代码（腾讯格式）\nINDEX_CODES = {\n    \"sh000001\": \"上证指数\",\n    \"sz399001\": \"深证成指\", \n    \"sz399006\": \"创业板指\",\n    \"sh000852\": \"中证1000\",\n}\n\nINDEX_CODE_LIST = list(INDEX_CODES.keys())\n\n\ndef fetch_tencent_quote(symbol: str, timeout: float = 8.0) -> Optional[dict]:\n    \"\"\"从腾讯获取单只股票/指数的实时行情\"\"\"\n    url = f\"http://qt.gtimg.cn/q={symbol}\"\n    try:\n        with urllib.request.urlopen(url, timeout=timeout) as resp:\n            text = resp.read().decode(\"gbk\")\n        m = re.match(r'v_\\w+=\"(.*)\";', text.strip())\n        if not m:\n            return None\n        f = m.group(1).split(\"~\")\n        if len(f) < 48:\n            return None\n        price = float(f[3] or 0)\n        change_pct = float(f[32] or 0)\n        return {\n            \"symbol\": symbol,\n            \"name\": f[1] or \"\",\n            \"price\": price,\n            \"change_pct\": change_pct,\n            \"valid\": price > 0,\n        }\n    except Exception:\n        return None"}],"details":{"status":"completed","exitCode":0,"durationMs":13,"aggregated":"#!/usr/bin/env python3\n\"\"\"\n盘中实时大盘门禁 - 用于在买入推荐生成前检查当日实时大盘状态\n避免用昨日/前一日收盘口径支撑当日买入决策\n\"\"\"\nfrom __future__ import annotations\n\nimport json\nimport re\nimport ssl\nimport urllib.request\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any, Optional\n\n# 主要监控的指数代码（腾讯格式）\nINDEX_CODES = {\n    \"sh000001\": \"上证指数\",\n    \"sz399001\": \"深证成指\", \n    \"sz399006\": \"创业板指\",\n    \"sh000852\": \"中证1000\",\n}\n\nINDEX_CODE_LIST = list(INDEX_CODES.keys())\n\n\ndef fetch_tencent_quote(symbol: str, timeout: float = 8.0) -> Optional[dict]:\n    \"\"\"从腾讯获取单只股票/指数的实时行情\"\"\"\n    url = f\"http://qt.gtimg.cn/q={symbol}\"\n    try:\n        with urllib.request.urlopen(url, timeout=timeout) as resp:\n            text = resp.read().decode(\"gbk\")\n        m = re.match(r'v_\\w+=\"(.*)\";', text.strip())\n        if not m:\n            return None\n        f = m.group(1).split(\"~\")\n        if len(f) < 48:\n            return None\n        price = float(f[3] or 0)\n        change_pct = float(f[32] or 0)\n        return {\n            \"symbol\": symbol,\n            \"name\": f[1] or \"\",\n            \"price\": price,\n            \"change_pct\": change_pct,\n            \"valid\": price > 0,\n        }\n    except Exception:\n        return None","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1773931079849}}
