{"type":"message","id":"92051ab0","parentId":"aec8db3a","timestamp":"2026-03-19T13:42:55.535Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I have the full `run_premarket_risk_v1.py`. For layer 2, I'll create `run_premarket_risk_v2.py` that:\n1. Adds a `perform_market_review()` call\n2. Adds the market review text to the risk payload\n3. Updates the markdown output to include the market reviewI'll add a function `fetch_market_review()` that wraps the analyzer_service call with error handling.","thinkingSignature":"5d2cf732478d663df5153c640b8422309cb090a690366f234dd87a71cef3e7dd"},{"type":"toolCall","id":"call_function_z05ig93kpq6o_1","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_premarket_risk_v2.py","content":"#!/usr/bin/env python3\n\"\"\"\n盘前风控预警 v2\n在 v1 基础上增加 analyzer_service.perform_market_review() 大盘复盘，\n作为整体风险判断的定性补充字段。\n\"\"\"\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport subprocess\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nif str(PROJECT_ROOT) not in sys.path:\n    sys.path.insert(0, str(PROJECT_ROOT))\n\nfrom risk.risk_engine import RiskContext, RiskEngine\nfrom run_live_execution_v1 import build_runtime_risk_config, load_market_breadth_ratio, load_style_rotation_snapshot\n\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nCONFIG_PATH = PROJECT_ROOT / \"config\" / \"live_trading_v1.json\"\nDATA_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis\")\nDSA_ANALYZER = DATA_ROOT / \"analyzer_service.py\"\n\n# Layer 2: analyzer_service timeout (seconds)\nMARKET_REVIEW_TIMEOUT_SEC = 30\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef latest_file(pattern: str) -> Path:\n    files = sorted(REPORT_DIR.glob(pattern))\n    if not files:\n        raise FileNotFoundError(f\"未找到文件: {pattern}\")\n    return files[-1]\n\n\ndef parse_float(v: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(v).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef latest_index_return_pct(path: Path) -> float:\n    if not path.exists():\n        return 0.0\n    df = pd.read_csv(path)\n    close = pd.to_numeric(df.get(\"close\"), errors=\"coerce\")\n    ret = close.pct_change().fillna(0.0)\n    if ret.empty:\n        return 0.0\n    return float(ret.iloc[-1] * 100)\n\n\n# ── Layer 2: 大盘复盘 ──────────────────────────────────────────────────────────\ndef fetch_market_review() -> dict[str, Any]:\n    \"\"\"\n    调用 analyzer_service.perform_market_review()，超时则返回 unavailable。\n    \"\"\"\n    if not DSA_ANALYZER.exists():\n        return {\"available\": False, \"error\": \"dsa_analyzer_not_found\"}\n    try:\n        result = subprocess.run(\n            [\n                sys.executable,\n                \"-c\",\n                (\n                    \"import sys; sys.path.insert(0, %r); \"\n                    \"from analyzer_service import perform_market_review; \"\n                    \"r = perform_market_review(); \"\n                    \"print(r if r else '')\"\n                )\n                % str(DATA_ROOT),\n            ],\n            capture_output=True,\n            text=True,\n            timeout=MARKET_REVIEW_TIMEOUT_SEC,\n        )\n        text = (result.stdout or \"\").strip()\n        if result.returncode == 0 and text:\n            return {\"available\": True, \"review\": text, \"error\": None}\n        return {\"available\": False, \"review\": \"\", \"error\": result.stderr.strip() or \"empty_output\"}\n    except subprocess.TimeoutExpired:\n        return {\"available\": False, \"review\": \"\", \"error\": f\"timeout_after_{MARKET_REVIEW_TIMEOUT_SEC}s\"}\n    except Exception as e:\n        return {\"available\": False, \"review\": \"\", \"error\": repr(e)}\n\n\n# ── 以下复用 v1 原有逻辑 ───────────────────────────────────────────────────────\ndef map_runtime_reason(\n    reason: str,\n    *,\n    benchmark_code: str,\n    benchmark_ret: float,\n    market_breadth: float | None,\n    combo_dd: float,\n    combo_sharpe: float,\n    style_snapshot: dict[str, Any],\n    index_halt_threshold: float | None,\n    breadth_riskoff_threshold: float | None,\n    breadth_hard_stop_threshold: float | None,\n    max_dd_threshold: float | None,\n    sharpe_threshold: float | None,\n) -> str:\n    if reason.startswith(\"index_ret_pct\"):\n        if index_halt_threshold is not None:\n            return f\"{benchmark_code}单日{benchmark_ret:.2f}% <= {index_halt_threshold:.2f}%（指数硬停）\"\n        return f\"{benchmark_code}单日收益触发指数硬停\"\n\n    if reason.startswith(\"market_breadth\"):\n        if breadth_hard_stop_threshold is not None and market_breadth is not None and market_breadth <= breadth_hard_stop_threshold:\n            return f\"市场宽度{market_breadth:.3f} <= {breadth_hard_stop_threshold:.3f}（宽度硬停）\"\n        if breadth_riskoff_threshold is not None and market_breadth is not None:\n            return f\"市场宽度{market_breadth:.3f} <= {breadth_riskoff_threshold:.3f}（风险收缩）\"\n        return \"市场宽度触发风险门控\"\n\n    if reason.startswith(\"strategy_max_drawdown_pct\"):\n        if max_dd_threshold is not None:\n            return f\"组合历史回撤{combo_dd:.2f}% >= {max_dd_threshold:.2f}%（风险收缩）\"\n        return f\"组合历史回撤{combo_dd:.2f}%触发风险收缩\"\n\n    if reason.startswith(\"strategy_sharpe\"):\n        if sharpe_threshold is not None:\n            return f\"组合Sharpe {combo_sharpe:.3f} < {sharpe_threshold:.3f}（谨慎模式）\"\n        return f\"组合Sharpe {combo_sharpe:.3f}偏低（谨慎模式）\"\n\n    if reason == \"style_rotation_hard_stop\":\n        return (\n            f\"风格切换硬停：{style_snapshot.get('smallcap_index', 'ZZ2000')}相对\"\n            f\"{style_snapshot.get('broad_index', 'HS300')}\"\n            f\"{int(style_snapshot.get('short_window', 5))}日超额=\"\n            f\"{parse_float(style_snapshot.get('short_excess_pct'), 0.0):.2f}% / \"\n            f\"{int(style_snapshot.get('medium_window', 20))}日超额=\"\n            f\"{parse_float(style_snapshot.get('medium_excess_pct'), 0.0):.2f}%\"\n        )\n\n    if reason == \"style_rotation_riskoff\":\n        return (\n            f\"风格切换收缩：{style_snapshot.get('smallcap_index', 'ZZ2000')}相对\"\n            f\"{style_snapshot.get('broad_index', 'HS300')}\"\n            f\"{int(style_snapshot.get('short_window', 5))}日超额=\"\n            f\"{parse_float(style_snapshot.get('short_excess_pct'), 0.0):.2f}% / \"\n            f\"{int(style_snapshot.get('medium_window', 20))}日超额=\"\n            f\"{parse_float(style_snapshot.get('medium_excess_pct'), 0.0):.2f}%\"\n        )\n\n    if reason == \"manual_hard_stop\":\n        return \"人工硬停触发\"\n\n    if reason == \"manual_risk_off\":\n        return \"人工风险收缩触发\"\n\n    return reason\n\n\ndef evaluate_risk(\n    config: dict[str, Any],\n    live_payload: dict[str, Any],\n    index_ret: dict[str, float],\n    market_breadth: float | None,\n) -> dict[str, Any]:\n    combo = live_payload.get(\"combo_v1\", {})\n    target_cfg = config.get(\"targets\", {})\n    constraints_cfg = config.get(\"constraints\", {})\n\n    combo_dd = parse_float(combo.get(\"max_drawdown_pct\"), 0.0)\n    combo_sharpe = parse_float(combo.get(\"sharpe\"), 0.0)\n    dd_target = parse_float(target_cfg.get(\"max_drawdown_max_pct\"), 25.0)\n    style_snapshot = load_style_rotation_snapshot(config)\n\n    benchmark_code = str(constraints_cfg.get(\"benchmark_smallcap\", \"ZZ2000\"))\n    benchmark_ret = parse_float(index_ret.get(benchmark_code), parse_float(index_ret.get(\"ZZ2000\"), 0.0))\n\n    runtime_cfg = build_runtime_risk_config(config=config, target_dd=dd_target)\n    decision = RiskEngine(runtime_cfg).evaluate_runtime_state(\n        RiskContext(\n            trade_date=datetime.now().strftime(\"%Y-%m-%d\"),\n            market_breadth=market_breadth,\n            index_ret_pct=benchmark_ret,\n            strategy_max_drawdown_pct=combo_dd,\n            strategy_sharpe=combo_sharpe,\n            style_smallcap_short_return_pct=parse_float(style_snapshot.get(\"smallcap_short_return_pct\"), 0.0)\n            if style_snapshot.get(\"smallcap_short_return_pct\") is not None else None,\n            style_smallcap_medium_return_pct=parse_float(style_snapshot.get(\"smallcap_medium_return_pct\"), 0.0)\n            if style_snapshot.get(\"smallcap_medium_return_pct\") is not None else None,\n            style_short_excess_pct=parse_float(style_snapshot.get(\"short_excess_pct\"), 0.0)\n            if style_snapshot.get(\"short_excess_pct\") is not None else None,\n            style_medium_excess_pct=parse_float(style_snapshot.get(\"medium_excess_pct\"), 0.0)\n            if style_snapshot.get(\"medium_excess_pct\") is not None else None,\n        )\n    )\n\n    reasons = [\n        map_runtime_reason(\n            item,\n            benchmark_code=benchmark_code,\n            benchmark_ret=benchmark_ret,\n            market_breadth=market_breadth,\n            combo_dd=combo_dd,\n            combo_sharpe=combo_sharpe,\n            style_snapshot=style_snapshot,\n            index_halt_threshold=runtime_cfg.index_halt_threshold_pct,\n            breadth_riskoff_threshold=runtime_cfg.market_breadth_riskoff_threshold,\n            breadth_hard_stop_threshold=runtime_cfg.market_breadth_hard_stop_threshold,\n            max_dd_threshold=runtime_cfg.strategy_max_drawdown_riskoff_pct,\n            sharpe_threshold=runtime_cfg.strategy_sharpe_cautious_threshold,\n        )\n        for item in decision.reasons\n    ]\n\n    score = 0\n    if decision.hard_stop:\n        score += 4\n    elif decision.risk_off:\n        score += 3\n    elif decision.mode == \"cautious\":\n        score += 2\n    score += min(2, max(0, len(decision.reasons) - 1))\n\n    if decision.hard_stop:\n        level = \"RED\"\n        gross_scale = 0.3\n    elif decision.risk_off:\n        level = \"YELLOW\"\n        gross_scale = 0.6\n    elif decision.mode == \"cautious\":\n        level = \"YELLOW\"\n        gross_scale = 0.8\n    else:\n        level = \"GREEN\"\n        gross_scale = 1.0\n\n    return {\n        \"score\": score,\n        \"level\": level,\n        \"mode\": decision.mode,\n        \"halt_new_buy\": decision.halt_new_buy,\n        \"risk_off\": decision.risk_off,\n        \"hard_stop\": decision.hard_stop,\n        \"gross_scale\": gross_scale,\n        \"reasons\": reasons,\n        \"raw_reasons\": decision.reasons,\n        \"market_breadth\": market_breadth,\n        \"style_snapshot\": style_snapshot,\n        \"runtime_gate\": {\n            \"benchmark_code\": benchmark_code,\n            \"benchmark_ret_pct\": round(benchmark_ret, 4),\n            \"index_halt_threshold_pct\": runtime_cfg.index_halt_threshold_pct,\n            \"market_breadth_riskoff_threshold\": runtime_cfg.market_breadth_riskoff_threshold,\n            \"market_breadth_hard_stop_threshold\": runtime_cfg.market_breadth_hard_stop_threshold,\n            \"strategy_max_drawdown_riskoff_pct\": runtime_cfg.strategy_max_drawdown_riskoff_pct,\n            \"strategy_sharpe_cautious_threshold\": runtime_cfg.strategy_sharpe_cautious_threshold,\n            \"style_rotation_riskoff_short_excess_pct\": runtime_cfg.style_rotation_riskoff_short_excess_pct,\n            \"style_rotation_riskoff_medium_excess_pct\": runtime_cfg.style_rotation_riskoff_medium_excess_pct,\n            \"style_rotation_hard_stop_short_excess_pct\": runtime_cfg.style_rotation_hard_stop_short_excess_pct,\n            \"style_rotation_hard_stop_medium_excess_pct\": runtime_cfg.style_rotation_hard_stop_medium_excess_pct,\n        },\n        \"combo\": {\n            \"annual_return_pct\": combo.get(\"annual_return_pct\"),\n            \"max_drawdown_pct\": combo.get(\"max_drawdown_pct\"),\n            \"sharpe\": combo.get(\"sharpe\"),\n        },\n        \"index_ret_pct\": index_ret,\n    }\n\n\ndef build_md(date_tag: str, payload: dict[str, Any]) -> str:\n    reasons = payload.get(\"reasons\", [])\n    reason_lines = [f\"- {x}\" for x in reasons] if reasons else [\"- 无显著风险触发项\"]\n    runtime_gate = payload.get(\"runtime_gate\", {})\n    style_snapshot = payload.get(\"style_snapshot\", {}) or {}\n    breadth_text = (\n        f\"{payload['market_breadth']:.3f}\" if"},"partialJson":"{\"path\": \"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_premarket_risk_v2.py\", \"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"\\n盘前风控预警 v2\\n在 v1 基础上增加 analyzer_service.perform_market_review() 大盘复盘，\\n作为整体风险判断的定性补充字段。\\n\\\"\\\"\\\"\\nfrom __future__ import annotations\\n\\nimport argparse\\nimport json\\nimport subprocess\\nimport sys\\nfrom datetime import datetime\\nfrom pathlib import Path\\nfrom typing import Any\\n\\nimport pandas as pd\\n\\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\\nif str(PROJECT_ROOT) not in sys.path:\\n    sys.path.insert(0, str(PROJECT_ROOT))\\n\\nfrom risk.risk_engine import RiskContext, RiskEngine\\nfrom run_live_execution_v1 import build_runtime_risk_config, load_market_breadth_ratio, load_style_rotation_snapshot\\n\\nREPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\nCONFIG_PATH = PROJECT_ROOT / \\\"config\\\" / \\\"live_trading_v1.json\\\"\\nDATA_ROOT = Path(\\\"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis\\\")\\nDSA_ANALYZER = DATA_ROOT / \\\"analyzer_service.py\\\"\\n\\n# Layer 2: analyzer_service timeout (seconds)\\nMARKET_REVIEW_TIMEOUT_SEC = 30\\n\\n\\ndef load_json(path: Path) -> dict[str, Any]:\\n    return json.loads(path.read_text(encoding=\\\"utf-8\\\"))\\n\\n\\ndef latest_file(pattern: str) -> Path:\\n    files = sorted(REPORT_DIR.glob(pattern))\\n    if not files:\\n        raise FileNotFoundError(f\\\"未找到文件: {pattern}\\\")\\n    return files[-1]\\n\\n\\ndef parse_float(v: Any, default: float = 0.0) -> float:\\n    try:\\n        return float(str(v).replace(\\\",\\\", \\\"\\\").strip())\\n    except Exception:\\n        return default\\n\\n\\ndef latest_index_return_pct(path: Path) -> float:\\n    if not path.exists():\\n        return 0.0\\n    df = pd.read_csv(path)\\n    close = pd.to_numeric(df.get(\\\"close\\\"), errors=\\\"coerce\\\")\\n    ret = close.pct_change().fillna(0.0)\\n    if ret.empty:\\n        return 0.0\\n    return float(ret.iloc[-1] * 100)\\n\\n\\n# ── Layer 2: 大盘复盘 ──────────────────────────────────────────────────────────\\ndef fetch_market_review() -> dict[str, Any]:\\n    \\\"\\\"\\\"\\n    调用 analyzer_service.perform_market_review()，超时则返回 unavailable。\\n    \\\"\\\"\\\"\\n    if not DSA_ANALYZER.exists():\\n        return {\\\"available\\\": False, \\\"error\\\": \\\"dsa_analyzer_not_found\\\"}\\n    try:\\n        result = subprocess.run(\\n            [\\n                sys.executable,\\n                \\\"-c\\\",\\n                (\\n                    \\\"import sys; sys.path.insert(0, %r); \\\"\\n                    \\\"from analyzer_service import perform_market_review; \\\"\\n                    \\\"r = perform_market_review(); \\\"\\n                    \\\"print(r if r else '')\\\"\\n                )\\n                % str(DATA_ROOT),\\n            ],\\n            capture_output=True,\\n            text=True,\\n            timeout=MARKET_REVIEW_TIMEOUT_SEC,\\n        )\\n        text = (result.stdout or \\\"\\\").strip()\\n        if result.returncode == 0 and text:\\n            return {\\\"available\\\": True, \\\"review\\\": text, \\\"error\\\": None}\\n        return {\\\"available\\\": False, \\\"review\\\": \\\"\\\", \\\"error\\\": result.stderr.strip() or \\\"empty_output\\\"}\\n    except subprocess.TimeoutExpired:\\n        return {\\\"available\\\": False, \\\"review\\\": \\\"\\\", \\\"error\\\": f\\\"timeout_after_{MARKET_REVIEW_TIMEOUT_SEC}s\\\"}\\n    except Exception as e:\\n        return {\\\"available\\\": False, \\\"review\\\": \\\"\\\", \\\"error\\\": repr(e)}\\n\\n\\n# ── 以下复用 v1 原有逻辑 ───────────────────────────────────────────────────────\\ndef map_runtime_reason(\\n    reason: str,\\n    *,\\n    benchmark_code: str,\\n    benchmark_ret: float,\\n    market_breadth: float | None,\\n    combo_dd: float,\\n    combo_sharpe: float,\\n    style_snapshot: dict[str, Any],\\n    index_halt_threshold: float | None,\\n    breadth_riskoff_threshold: float | None,\\n    breadth_hard_stop_threshold: float | None,\\n    max_dd_threshold: float | None,\\n    sharpe_threshold: float | None,\\n) -> str:\\n    if reason.startswith(\\\"index_ret_pct\\\"):\\n        if index_halt_threshold is not None:\\n            return f\\\"{benchmark_code}单日{benchmark_ret:.2f}% <= {index_halt_threshold:.2f}%（指数硬停）\\\"\\n        return f\\\"{benchmark_code}单日收益触发指数硬停\\\"\\n\\n    if reason.startswith(\\\"market_breadth\\\"):\\n        if breadth_hard_stop_threshold is not None and market_breadth is not None and market_breadth <= breadth_hard_stop_threshold:\\n            return f\\\"市场宽度{market_breadth:.3f} <= {breadth_hard_stop_threshold:.3f}（宽度硬停）\\\"\\n        if breadth_riskoff_threshold is not None and market_breadth is not None:\\n            return f\\\"市场宽度{market_breadth:.3f} <= {breadth_riskoff_threshold:.3f}（风险收缩）\\\"\\n        return \\\"市场宽度触发风险门控\\\"\\n\\n    if reason.startswith(\\\"strategy_max_drawdown_pct\\\"):\\n        if max_dd_threshold is not None:\\n            return f\\\"组合历史回撤{combo_dd:.2f}% >= {max_dd_threshold:.2f}%（风险收缩）\\\"\\n        return f\\\"组合历史回撤{combo_dd:.2f}%触发风险收缩\\\"\\n\\n    if reason.startswith(\\\"strategy_sharpe\\\"):\\n        if sharpe_threshold is not None:\\n            return f\\\"组合Sharpe {combo_sharpe:.3f} < {sharpe_threshold:.3f}（谨慎模式）\\\"\\n        return f\\\"组合Sharpe {combo_sharpe:.3f}偏低（谨慎模式）\\\"\\n\\n    if reason == \\\"style_rotation_hard_stop\\\":\\n        return (\\n            f\\\"风格切换硬停：{style_snapshot.get('smallcap_index', 'ZZ2000')}相对\\\"\\n            f\\\"{style_snapshot.get('broad_index', 'HS300')}\\\"\\n            f\\\"{int(style_snapshot.get('short_window', 5))}日超额=\\\"\\n            f\\\"{parse_float(style_snapshot.get('short_excess_pct'), 0.0):.2f}% / \\\"\\n            f\\\"{int(style_snapshot.get('medium_window', 20))}日超额=\\\"\\n            f\\\"{parse_float(style_snapshot.get('medium_excess_pct'), 0.0):.2f}%\\\"\\n        )\\n\\n    if reason == \\\"style_rotation_riskoff\\\":\\n        return (\\n            f\\\"风格切换收缩：{style_snapshot.get('smallcap_index', 'ZZ2000')}相对\\\"\\n            f\\\"{style_snapshot.get('broad_index', 'HS300')}\\\"\\n            f\\\"{int(style_snapshot.get('short_window', 5))}日超额=\\\"\\n            f\\\"{parse_float(style_snapshot.get('short_excess_pct'), 0.0):.2f}% / \\\"\\n            f\\\"{int(style_snapshot.get('medium_window', 20))}日超额=\\\"\\n            f\\\"{parse_float(style_snapshot.get('medium_excess_pct'), 0.0):.2f}%\\\"\\n        )\\n\\n    if reason == \\\"manual_hard_stop\\\":\\n        return \\\"人工硬停触发\\\"\\n\\n    if reason == \\\"manual_risk_off\\\":\\n        return \\\"人工风险收缩触发\\\"\\n\\n    return reason\\n\\n\\ndef evaluate_risk(\\n    config: dict[str, Any],\\n    live_payload: dict[str, Any],\\n    index_ret: dict[str, float],\\n    market_breadth: float | None,\\n) -> dict[str, Any]:\\n    combo = live_payload.get(\\\"combo_v1\\\", {})\\n    target_cfg = config.get(\\\"targets\\\", {})\\n    constraints_cfg = config.get(\\\"constraints\\\", {})\\n\\n    combo_dd = parse_float(combo.get(\\\"max_drawdown_pct\\\"), 0.0)\\n    combo_sharpe = parse_float(combo.get(\\\"sharpe\\\"), 0.0)\\n    dd_target = parse_float(target_cfg.get(\\\"max_drawdown_max_pct\\\"), 25.0)\\n    style_snapshot = load_style_rotation_snapshot(config)\\n\\n    benchmark_code = str(constraints_cfg.get(\\\"benchmark_smallcap\\\", \\\"ZZ2000\\\"))\\n    benchmark_ret = parse_float(index_ret.get(benchmark_code), parse_float(index_ret.get(\\\"ZZ2000\\\"), 0.0))\\n\\n    runtime_cfg = build_runtime_risk_config(config=config, target_dd=dd_target)\\n    decision = RiskEngine(runtime_cfg).evaluate_runtime_state(\\n        RiskContext(\\n            trade_date=datetime.now().strftime(\\\"%Y-%m-%d\\\"),\\n            market_breadth=market_breadth,\\n            index_ret_pct=benchmark_ret,\\n            strategy_max_drawdown_pct=combo_dd,\\n            strategy_sharpe=combo_sharpe,\\n            style_smallcap_short_return_pct=parse_float(style_snapshot.get(\\\"smallcap_short_return_pct\\\"), 0.0)\\n            if style_snapshot.get(\\\"smallcap_short_return_pct\\\") is not None else None,\\n            style_smallcap_medium_return_pct=parse_float(style_snapshot.get(\\\"smallcap_medium_return_pct\\\"), 0.0)\\n            if style_snapshot.get(\\\"smallcap_medium_return_pct\\\") is not None else None,\\n            style_short_excess_pct=parse_float(style_snapshot.get(\\\"short_excess_pct\\\"), 0.0)\\n            if style_snapshot.get(\\\"short_excess_pct\\\") is not None else None,\\n            style_medium_excess_pct=parse_float(style_snapshot.get(\\\"medium_excess_pct\\\"), 0.0)\\n            if style_snapshot.get(\\\"medium_excess_pct\\\") is not None else None,\\n        )\\n    )\\n\\n    reasons = [\\n        map_runtime_reason(\\n            item,\\n            benchmark_code=benchmark_code,\\n            benchmark_ret=benchmark_ret,\\n            market_breadth=market_breadth,\\n            combo_dd=combo_dd,\\n            combo_sharpe=combo_sharpe,\\n            style_snapshot=style_snapshot,\\n            index_halt_threshold=runtime_cfg.index_halt_threshold_pct,\\n            breadth_riskoff_threshold=runtime_cfg.market_breadth_riskoff_threshold,\\n            breadth_hard_stop_threshold=runtime_cfg.market_breadth_hard_stop_threshold,\\n            max_dd_threshold=runtime_cfg.strategy_max_drawdown_riskoff_pct,\\n            sharpe_threshold=runtime_cfg.strategy_sharpe_cautious_threshold,\\n        )\\n        for item in decision.reasons\\n    ]\\n\\n    score = 0\\n    if decision.hard_stop:\\n        score += 4\\n    elif decision.risk_off:\\n        score += 3\\n    elif decision.mode == \\\"cautious\\\":\\n        score += 2\\n    score += min(2, max(0, len(decision.reasons) - 1))\\n\\n    if decision.hard_stop:\\n        level = \\\"RED\\\"\\n        gross_scale = 0.3\\n    elif decision.risk_off:\\n        level = \\\"YELLOW\\\"\\n        gross_scale = 0.6\\n    elif decision.mode == \\\"cautious\\\":\\n        level = \\\"YELLOW\\\"\\n        gross_scale = 0.8\\n    else:\\n        level = \\\"GREEN\\\"\\n        gross_scale = 1.0\\n\\n    return {\\n        \\\"score\\\": score,\\n        \\\"level\\\": level,\\n        \\\"mode\\\": decision.mode,\\n        \\\"halt_new_buy\\\": decision.halt_new_buy,\\n        \\\"risk_off\\\": decision.risk_off,\\n        \\\"hard_stop\\\": decision.hard_stop,\\n        \\\"gross_scale\\\": gross_scale,\\n        \\\"reasons\\\": reasons,\\n        \\\"raw_reasons\\\": decision.reasons,\\n        \\\"market_breadth\\\": market_breadth,\\n        \\\"style_snapshot\\\": style_snapshot,\\n        \\\"runtime_gate\\\": {\\n            \\\"benchmark_code\\\": benchmark_code,\\n            \\\"benchmark_ret_pct\\\": round(benchmark_ret, 4),\\n            \\\"index_halt_threshold_pct\\\": runtime_cfg.index_halt_threshold_pct,\\n            \\\"market_breadth_riskoff_threshold\\\": runtime_cfg.market_breadth_riskoff_threshold,\\n            \\\"market_breadth_hard_stop_threshold\\\": runtime_cfg.market_breadth_hard_stop_threshold,\\n            \\\"strategy_max_drawdown_riskoff_pct\\\": runtime_cfg.strategy_max_drawdown_riskoff_pct,\\n            \\\"strategy_sharpe_cautious_threshold\\\": runtime_cfg.strategy_sharpe_cautious_threshold,\\n            \\\"style_rotation_riskoff_short_excess_pct\\\": runtime_cfg.style_rotation_riskoff_short_excess_pct,\\n            \\\"style_rotation_riskoff_medium_excess_pct\\\": runtime_cfg.style_rotation_riskoff_medium_excess_pct,\\n            \\\"style_rotation_hard_stop_short_excess_pct\\\": runtime_cfg.style_rotation_hard_stop_short_excess_pct,\\n            \\\"style_rotation_hard_stop_medium_excess_pct\\\": runtime_cfg.style_rotation_hard_stop_medium_excess_pct,\\n        },\\n        \\\"combo\\\": {\\n            \\\"annual_return_pct\\\": combo.get(\\\"annual_return_pct\\\"),\\n            \\\"max_drawdown_pct\\\": combo.get(\\\"max_drawdown_pct\\\"),\\n            \\\"sharpe\\\": combo.get(\\\"sharpe\\\"),\\n        },\\n        \\\"index_ret_pct\\\": index_ret,\\n    }\\n\\n\\ndef build_md(date_tag: str, payload: dict[str, Any]) -> str:\\n    reasons = payload.get(\\\"reasons\\\", [])\\n    reason_lines = [f\\\"- {x}\\\" for x in reasons] if reasons else [\\\"- 无显著风险触发项\\\"]\\n    runtime_gate = payload.get(\\\"runtime_gate\\\", {})\\n    style_snapshot = payload.get(\\\"style_snapshot\\\", {}) or {}\\n    breadth_text = (\\n        f\\\"{payload['market_breadth']:.3f}\\\" if"}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":62390,"output":0,"cacheRead":24293,"cacheWrite":0,"totalTokens":86683,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1773927727113,"errorMessage":"Request was aborted."}}
