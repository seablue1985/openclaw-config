{"type":"message","id":"844e9168","parentId":"d6b93f95","timestamp":"2026-03-19T14:38:41.571Z","message":{"role":"toolResult","toolCallId":"call_function_9a65dux0thj5_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nA股小市值策略数据获取\n获取所有A股的日线基本面数据（市值、PE、PB等）\n\"\"\"\nimport os\nimport sys\nimport pandas as pd\nfrom datetime import datetime, timedelta\nimport time\n\n# 加载环境变量\nfrom dotenv import load_dotenv\nload_dotenv(os.path.join(os.path.dirname(__file__), 'config/.env.tushare'))\n\nTOKEN = os.getenv('TUSHARE_TOKEN')\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'data')\nos.makedirs(DATA_DIR, exist_ok=True)\n\ndef get_pro():\n    \"\"\"初始化tushare pro\"\"\"\n    import tushare as ts\n    pro = ts.pro_api(TOKEN)\n    return pro\n\ndef fetch_stock_basic():\n    \"\"\"获取A股股票基本信息\"\"\"\n    print(\"📥 获取股票基本信息...\")\n    pro = get_pro()\n    \n    # 获取所有A股\n    df = pro.stock_basic(exchange='', list_status='L', \n                         fields='ts_code,symbol,name,area,industry,list_date,market,exchange')\n    \n    # 过滤ST股票\n    df = df[~df['name'].str.contains('ST|退', na=False)]\n    \n    output_file = os.path.join(DATA_DIR, 'stock_basic.csv')\n    df.to_csv(output_file, index=False)\n    print(f\"✅ 股票基本信息: {len(df)} 只\")\n    return df\n\ndef fetch_daily_basic_all():\n    \"\"\"\n    获取所有A股日线基本面\n    包含：市值、PE、PB、换手率等\n    \"\"\"\n    print(\"📥 获取日线基本面数据...\")\n    pro = get_pro()\n    \n    # 读取股票列表\n    stocks = pd.read_csv(os.path.join(DATA_DIR, 'stock_basic.csv'))\n    \n    # 全部股票\n    all_ts_codes = stocks['ts_code'].tolist()\n    print(f\"  📊 共 {len(all_ts_codes)} 只股票\")\n    \n    # 分批获取（每次50只）\n    batch_size = 50\n    all_data = []"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"#!/usr/bin/env python3\n\"\"\"\nA股小市值策略数据获取\n获取所有A股的日线基本面数据（市值、PE、PB等）\n\"\"\"\nimport os\nimport sys\nimport pandas as pd\nfrom datetime import datetime, timedelta\nimport time\n\n# 加载环境变量\nfrom dotenv import load_dotenv\nload_dotenv(os.path.join(os.path.dirname(__file__), 'config/.env.tushare'))\n\nTOKEN = os.getenv('TUSHARE_TOKEN')\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'data')\nos.makedirs(DATA_DIR, exist_ok=True)\n\ndef get_pro():\n    \"\"\"初始化tushare pro\"\"\"\n    import tushare as ts\n    pro = ts.pro_api(TOKEN)\n    return pro\n\ndef fetch_stock_basic():\n    \"\"\"获取A股股票基本信息\"\"\"\n    print(\"📥 获取股票基本信息...\")\n    pro = get_pro()\n    \n    # 获取所有A股\n    df = pro.stock_basic(exchange='', list_status='L', \n                         fields='ts_code,symbol,name,area,industry,list_date,market,exchange')\n    \n    # 过滤ST股票\n    df = df[~df['name'].str.contains('ST|退', na=False)]\n    \n    output_file = os.path.join(DATA_DIR, 'stock_basic.csv')\n    df.to_csv(output_file, index=False)\n    print(f\"✅ 股票基本信息: {len(df)} 只\")\n    return df\n\ndef fetch_daily_basic_all():\n    \"\"\"\n    获取所有A股日线基本面\n    包含：市值、PE、PB、换手率等\n    \"\"\"\n    print(\"📥 获取日线基本面数据...\")\n    pro = get_pro()\n    \n    # 读取股票列表\n    stocks = pd.read_csv(os.path.join(DATA_DIR, 'stock_basic.csv'))\n    \n    # 全部股票\n    all_ts_codes = stocks['ts_code'].tolist()\n    print(f\"  📊 共 {len(all_ts_codes)} 只股票\")\n    \n    # 分批获取（每次50只）\n    batch_size = 50\n    all_data = []","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1773931121559}}
