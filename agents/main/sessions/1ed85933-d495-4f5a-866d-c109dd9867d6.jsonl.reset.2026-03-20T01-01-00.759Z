{"type":"message","id":"cce0288a","parentId":"eb3e916d","timestamp":"2026-03-19T13:48:17.693Z","message":{"role":"toolResult","toolCallId":"call_function_30w6jmta36z9_1","toolName":"exec","content":[{"type":"text","text":"def main() -> None:\n    parser = argparse.ArgumentParser(description=\"收盘复盘生成 v1\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--orders\", default=\"\", help=\"可选：指定 live_orders csv\")\n    parser.add_argument(\"--journal\", default=\"\", help=\"可选：指定 live_journal csv\")\n    args = parser.parse_args()\n\n    date_tag = args.date.strip() if args.date.strip() else datetime.now().strftime(\"%Y%m%d\")\n\n    config = load_json(CONFIG_PATH)\n    live_json = latest_file(\"live_system_v1_*.json\")\n    live_payload = load_json(live_json)\n\n    orders = Path(args.orders).resolve() if args.orders else latest_file(f\"live_orders_v1_{date_tag}.csv\")\n    journal = Path(args.journal).resolve() if args.journal else REPORT_DIR / f\"live_journal_v1_{date_tag}.csv\"\n\n    files = {\n        \"orders\": str(orders),\n        \"journal\": str(journal),\n        \"premarket\": str(REPORT_DIR / f\"live_premarket_risk_v1_{date_tag}.md\"),\n    }\n\n    orders_stats = summarize_orders(orders)\n    journal_stats = summarize_journal(journal)\n\n    payload, md = build_review(\n        date_tag=date_tag,\n        config=config,\n        live_payload=live_payload,\n        orders_stats=orders_stats,\n        journal_stats=journal_stats,\n        files=files,\n    )\n\n    out_json = REPORT_DIR / f\"live_close_review_v1_{date_tag}.json\"\n    out_md = REPORT_DIR / f\"live_close_review_v1_{date_tag}.md\"\n\n    out_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    out_md.write_text(md + \"\\n\", encoding=\"utf-8\")\n\n    print(json.dumps({\"review_json\": str(out_json), \"review_md\": str(out_md), \"summary\": payload}, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()"}],"details":{"status":"completed","exitCode":0,"durationMs":11,"aggregated":"def main() -> None:\n    parser = argparse.ArgumentParser(description=\"收盘复盘生成 v1\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--orders\", default=\"\", help=\"可选：指定 live_orders csv\")\n    parser.add_argument(\"--journal\", default=\"\", help=\"可选：指定 live_journal csv\")\n    args = parser.parse_args()\n\n    date_tag = args.date.strip() if args.date.strip() else datetime.now().strftime(\"%Y%m%d\")\n\n    config = load_json(CONFIG_PATH)\n    live_json = latest_file(\"live_system_v1_*.json\")\n    live_payload = load_json(live_json)\n\n    orders = Path(args.orders).resolve() if args.orders else latest_file(f\"live_orders_v1_{date_tag}.csv\")\n    journal = Path(args.journal).resolve() if args.journal else REPORT_DIR / f\"live_journal_v1_{date_tag}.csv\"\n\n    files = {\n        \"orders\": str(orders),\n        \"journal\": str(journal),\n        \"premarket\": str(REPORT_DIR / f\"live_premarket_risk_v1_{date_tag}.md\"),\n    }\n\n    orders_stats = summarize_orders(orders)\n    journal_stats = summarize_journal(journal)\n\n    payload, md = build_review(\n        date_tag=date_tag,\n        config=config,\n        live_payload=live_payload,\n        orders_stats=orders_stats,\n        journal_stats=journal_stats,\n        files=files,\n    )\n\n    out_json = REPORT_DIR / f\"live_close_review_v1_{date_tag}.json\"\n    out_md = REPORT_DIR / f\"live_close_review_v1_{date_tag}.md\"\n\n    out_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    out_md.write_text(md + \"\\n\", encoding=\"utf-8\")\n\n    print(json.dumps({\"review_json\": str(out_json), \"review_md\": str(out_md), \"summary\": payload}, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1773928097681}}
{"type":"message","id":"6db626c9","parentId":"cce0288a","timestamp":"2026-03-19T13:48:23.688Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I see the structure. The close review gets orders and journal. I can add an `analyze_stocks` call that takes the stock codes from the orders and generates an analysis report.\n\nFor layer 3, I'll create a `run_close_review_v2.py` that:\n1. Does everything v1 does\n2. Gets stock codes from orders and today's traded stocks3. Calls `analyze_stocks()` from analyzer_service\n4. Adds the analysis results to the output JSON\n\nThis is similar to the pattern used in layer 2. Let me create the v2 version.","thinkingSignature":"b6e4b1d8ae482646bff3f2ed68b2bc909555775eed04f9daa44a74b7fb6673d2"},{"type":"text","text":"我来写 `run_close_review_v2.py`，在盘后审计里接入 `analyze_stocks`：\n"},{"type":"toolCall","id":"call_function_dprpe89he4fd_1","name":"exec","arguments":{"command":"head -60 ~/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_close_review_v1.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":81252,"output":192,"cacheRead":24293,"cacheWrite":0,"totalTokens":105737,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773928097695}}
{"type":"message","id":"90da6a22","parentId":"6db626c9","timestamp":"2026-03-19T13:48:23.739Z","message":{"role":"toolResult","toolCallId":"call_function_dprpe89he4fd_1","toolName":"exec","content":[{"type":"text","text":"from __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nCONFIG_PATH = PROJECT_ROOT / \"config\" / \"live_trading_v1.json\"\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef latest_file(pattern: str) -> Path:\n    files = sorted(REPORT_DIR.glob(pattern))\n    if not files:\n        raise FileNotFoundError(f\"未找到文件: {pattern}\")\n    return files[-1]\n\n\ndef parse_float(v: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(v).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef summarize_orders(path: Path) -> dict[str, Any]:\n    df = pd.read_csv(path)\n    if df.empty:\n        return {\n            \"total\": 0,\n            \"buy\": 0,\n            \"sell\": 0,\n            \"blocked_buy\": 0,\n            \"planned_buy_amount\": 0.0,\n            \"planned_sell_amount\": 0.0,\n        }\n\n    buy = df[df[\"side\"].astype(str).str.upper() == \"BUY\"].copy()\n    sell = df[df[\"side\"].astype(str).str.upper() == \"SELL\"].copy()\n\n    blocked_buy = buy[buy.get(\"risk_gate\", \"\").astype(str) == \"blocked\"]\n\n    buy_amt = pd.to_numeric(buy.get(\"est_amount\"), errors=\"coerce\").fillna(0.0).sum()\n    sell_amt = pd.to_numeric(sell.get(\"est_amount\"), errors=\"coerce\").fillna(0.0).sum()\n\n    return {\n        \"total\": int(len(df)),\n        \"buy\": int(len(buy)),\n        \"sell\": int(len(sell)),\n        \"blocked_buy\": int(len(blocked_buy)),\n        \"planned_buy_amount\": round(float(buy_amt), 2),\n        \"planned_sell_amount\": round(float(sell_amt), 2),"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"from __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nCONFIG_PATH = PROJECT_ROOT / \"config\" / \"live_trading_v1.json\"\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef latest_file(pattern: str) -> Path:\n    files = sorted(REPORT_DIR.glob(pattern))\n    if not files:\n        raise FileNotFoundError(f\"未找到文件: {pattern}\")\n    return files[-1]\n\n\ndef parse_float(v: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(v).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef summarize_orders(path: Path) -> dict[str, Any]:\n    df = pd.read_csv(path)\n    if df.empty:\n        return {\n            \"total\": 0,\n            \"buy\": 0,\n            \"sell\": 0,\n            \"blocked_buy\": 0,\n            \"planned_buy_amount\": 0.0,\n            \"planned_sell_amount\": 0.0,\n        }\n\n    buy = df[df[\"side\"].astype(str).str.upper() == \"BUY\"].copy()\n    sell = df[df[\"side\"].astype(str).str.upper() == \"SELL\"].copy()\n\n    blocked_buy = buy[buy.get(\"risk_gate\", \"\").astype(str) == \"blocked\"]\n\n    buy_amt = pd.to_numeric(buy.get(\"est_amount\"), errors=\"coerce\").fillna(0.0).sum()\n    sell_amt = pd.to_numeric(sell.get(\"est_amount\"), errors=\"coerce\").fillna(0.0).sum()\n\n    return {\n        \"total\": int(len(df)),\n        \"buy\": int(len(buy)),\n        \"sell\": int(len(sell)),\n        \"blocked_buy\": int(len(blocked_buy)),\n        \"planned_buy_amount\": round(float(buy_amt), 2),\n        \"planned_sell_amount\": round(float(sell_amt), 2),","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1773928103726}}
{"type":"message","id":"ead3129c","parentId":"90da6a22","timestamp":"2026-03-19T13:48:27.309Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I see. The orders CSV contains the stock codes. Let me read the full v1 to understand its full structure, then create v2.","thinkingSignature":"2603c3f12446469ac09635b9a2e3b7df6cba4496f35ce10b3e0b626fdc6a1dbd"},{"type":"toolCall","id":"call_function_2edj1xnv54g9_1","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_close_review_v1.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":81939,"output":80,"cacheRead":24293,"cacheWrite":0,"totalTokens":106312,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773928103743}}
{"type":"message","id":"26a381cb","parentId":"ead3129c","timestamp":"2026-03-19T13:48:27.352Z","message":{"role":"toolResult","toolCallId":"call_function_2edj1xnv54g9_1","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nCONFIG_PATH = PROJECT_ROOT / \"config\" / \"live_trading_v1.json\"\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef latest_file(pattern: str) -> Path:\n    files = sorted(REPORT_DIR.glob(pattern))\n    if not files:\n        raise FileNotFoundError(f\"未找到文件: {pattern}\")\n    return files[-1]\n\n\ndef parse_float(v: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(v).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef summarize_orders(path: Path) -> dict[str, Any]:\n    df = pd.read_csv(path)\n    if df.empty:\n        return {\n            \"total\": 0,\n            \"buy\": 0,\n            \"sell\": 0,\n            \"blocked_buy\": 0,\n            \"planned_buy_amount\": 0.0,\n            \"planned_sell_amount\": 0.0,\n        }\n\n    buy = df[df[\"side\"].astype(str).str.upper() == \"BUY\"].copy()\n    sell = df[df[\"side\"].astype(str).str.upper() == \"SELL\"].copy()\n\n    blocked_buy = buy[buy.get(\"risk_gate\", \"\").astype(str) == \"blocked\"]\n\n    buy_amt = pd.to_numeric(buy.get(\"est_amount\"), errors=\"coerce\").fillna(0.0).sum()\n    sell_amt = pd.to_numeric(sell.get(\"est_amount\"), errors=\"coerce\").fillna(0.0).sum()\n\n    return {\n        \"total\": int(len(df)),\n        \"buy\": int(len(buy)),\n        \"sell\": int(len(sell)),\n        \"blocked_buy\": int(len(blocked_buy)),\n        \"planned_buy_amount\": round(float(buy_amt), 2),\n        \"planned_sell_amount\": round(float(sell_amt), 2),\n    }\n\n\ndef summarize_journal(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {\n            \"exists\": False,\n            \"records\": 0,\n            \"buy_exec\": 0,\n            \"sell_exec\": 0,\n            \"pnl_day\": 0.0,\n            \"pnl_total\": 0.0,\n            \"drawdown\": 0.0,\n            \"slippage\": 0.0,\n        }\n\n    df = pd.read_csv(path)\n    if df.empty:\n        return {\n            \"exists\": True,\n            \"records\": 0,\n            \"buy_exec\": 0,\n            \"sell_exec\": 0,\n            \"pnl_day\": 0.0,\n            \"pnl_total\": 0.0,\n            \"drawdown\": 0.0,\n            \"slippage\": 0.0,\n        }\n\n    action = df.get(\"action\", pd.Series([], dtype=str)).astype(str).str.upper()\n    buy_exec = int((action == \"BUY\").sum())\n    sell_exec = int((action == \"SELL\").sum())\n\n    pnl_day = pd.to_numeric(df.get(\"pnl_day\"), errors=\"coerce\").fillna(0.0).sum()\n    pnl_total = pd.to_numeric(df.get(\"pnl_total\"), errors=\"coerce\").dropna()\n    pnl_total_last = float(pnl_total.iloc[-1]) if not pnl_total.empty else 0.0\n\n    drawdown = pd.to_numeric(df.get(\"drawdown\"), errors=\"coerce\").dropna()\n    drawdown_min = float(drawdown.min()) if not drawdown.empty else 0.0\n\n    slippage = pd.to_numeric(df.get(\"slippage\"), errors=\"coerce\").dropna()\n    slippage_mean = float(slippage.mean()) if not slippage.empty else 0.0\n\n    return {\n        \"exists\": True,\n        \"records\": int(len(df)),\n        \"buy_exec\": buy_exec,\n        \"sell_exec\": sell_exec,\n        \"pnl_day\": round(float(pnl_day), 2),\n        \"pnl_total\": round(pnl_total_last, 2),\n        \"drawdown\": round(drawdown_min, 2),\n        \"slippage\": round(slippage_mean, 4),\n    }\n\n\ndef build_review(\n    date_tag: str,\n    config: dict[str, Any],\n    live_payload: dict[str, Any],\n    orders_stats: dict[str, Any],\n    journal_stats: dict[str, Any],\n    files: dict[str, str],\n) -> tuple[dict[str, Any], str]:\n    combo = live_payload.get(\"combo_v1\", {})\n    risk_cfg = config.get(\"risk\", {})\n\n    dd_guard = parse_float(risk_cfg.get(\"portfolio_drawdown_guard_pct\"), -2.5)\n    dd_halt = parse_float(risk_cfg.get(\"portfolio_drawdown_halt_pct\"), -3.5)\n    day_dd = parse_float(journal_stats.get(\"drawdown\"), 0.0)\n\n    if day_dd <= dd_halt:\n        risk_level = \"RED\"\n        tomorrow_mode = \"halt\"\n    elif day_dd <= dd_guard:\n        risk_level = \"YELLOW\"\n        tomorrow_mode = \"cautious\"\n    else:\n        risk_level = \"GREEN\"\n        tomorrow_mode = \"normal\"\n\n    summary = {\n        \"date\": date_tag,\n        \"combo\": {\n            \"annual_return_pct\": combo.get(\"annual_return_pct\"),\n            \"max_drawdown_pct\": combo.get(\"max_drawdown_pct\"),\n            \"sharpe\": combo.get(\"sharpe\"),\n        },\n        \"orders\": orders_stats,\n        \"journal\": journal_stats,\n        \"risk_level\": risk_level,\n        \"tomorrow_mode\": tomorrow_mode,\n        \"files\": files,\n    }\n\n    md = \"\\n\".join(\n        [\n            f\"# 收盘复盘 v1（{date_tag}）\",\n            \"\",\n            \"## 组合状态\",\n            f\"- 年化（回测口径）：`{combo.get('annual_return_pct', '-') }%`\",\n            f\"- 最大回撤（回测口径）：`{combo.get('max_drawdown_pct', '-') }%`\",\n            f\"- 夏普（回测口径）：`{combo.get('sharpe', '-') }`\",\n            \"\",\n            \"## 今日计划执行统计\",\n            f\"- 计划订单：`{orders_stats['total']}`（BUY {orders_stats['buy']} / SELL {orders_stats['sell']}）\",\n            f\"- BUY阻断数：`{orders_stats['blocked_buy']}`\",\n            f\"- 计划买入金额：`{orders_stats['planned_buy_amount']}`\",\n            f\"- 计划卖出金额：`{orders_stats['planned_sell_amount']}`\",\n            \"\",\n            \"## 今日实际成交统计\",\n            f\"- 日志记录数：`{journal_stats['records']}`\",\n            f\"- 实际BUY/SELL：`{journal_stats['buy_exec']}` / `{journal_stats['sell_exec']}`\",\n            f\"- 当日PnL：`{journal_stats['pnl_day']}`\",\n            f\"- 累计PnL：`{journal_stats['pnl_total']}`\",\n            f\"- 日内回撤：`{journal_stats['drawdown']}%`\",\n            f\"- 平均滑点：`{journal_stats['slippage']}`\",\n            \"\",\n            \"## 风控结论\",\n            f\"- 风险等级：`{risk_level}`\",\n            f\"- 次日建议模式：`{tomorrow_mode}`\",\n            \"\",\n            \"## 文件\",\n            f\"- 下单模板：`{files['orders']}`\",\n            f\"- 交易日志：`{files['journal']}`\",\n            f\"- 盘前预警（将生成）：`{files['premarket']}`\",\n        ]\n    )\n\n    return summary, md\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"收盘复盘生成 v1\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--orders\", default=\"\", help=\"可选：指定 live_orders csv\")\n    parser.add_argument(\"--journal\", default=\"\", help=\"可选：指定 live_journal csv\")\n    args = parser.parse_args()\n\n    date_tag = args.date.strip() if args.date.strip() else datetime.now().strftime(\"%Y%m%d\")\n\n    config = load_json(CONFIG_PATH)\n    live_json = latest_file(\"live_system_v1_*.json\")\n    live_payload = load_json(live_json)\n\n    orders = Path(args.orders).resolve() if args.orders else latest_file(f\"live_orders_v1_{date_tag}.csv\")\n    journal = Path(args.journal).resolve() if args.journal else REPORT_DIR / f\"live_journal_v1_{date_tag}.csv\"\n\n    files = {\n        \"orders\": str(orders),\n        \"journal\": str(journal),\n        \"premarket\": str(REPORT_DIR / f\"live_premarket_risk_v1_{date_tag}.md\"),\n    }\n\n    orders_stats = summarize_orders(orders)\n    journal_stats = summarize_journal(journal)\n\n    payload, md = build_review(\n        date_tag=date_tag,\n        config=config,\n        live_payload=live_payload,\n        orders_stats=orders_stats,\n        journal_stats=journal_stats,\n        files=files,\n    )\n\n    out_json = REPORT_DIR / f\"live_close_review_v1_{date_tag}.json\"\n    out_md = REPORT_DIR / f\"live_close_review_v1_{date_tag}.md\"\n\n    out_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    out_md.write_text(md + \"\\n\", encoding=\"utf-8\")\n\n    print(json.dumps({\"review_json\": str(out_json), \"review_md\": str(out_md), \"summary\": payload}, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1773928107340}}
{"type":"message","id":"5c8d5262","parentId":"26a381cb","timestamp":"2026-03-19T13:49:49.000Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the v1 structure. I need to create v2 that:1. Extracts stock codes from the orders CSV2. Calls `analyzer_service.analyze_stocks()` on those codes\n3. Adds the analysis results to the output JSONFor simplicity, I'll focus on analyzing the stocks that were in today's orders (both BUY and SELL).\n\nLet me create the v2 script.","thinkingSignature":"6c9a03dbd6607bbd33e08a9cf0d24b3cd1742fa729c9c217cd7fdea5c315c680"},{"type":"toolCall","id":"call_function_95ahjk20ucjz_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n收盘复盘 v2：新增个股分析（analyze_stocks）集成\n\n在 v1 基础上增加：\n- 从当日订单 CSV 提取股票代码\n- 调用 analyzer_service.analyze_stocks() 对这些股票进行深度分析\n- 将分析结果写入输出 JSON 的 stock_analyses 字段\n\"\"\"\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport signal\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nCONFIG_PATH = PROJECT_ROOT / \"config\" / \"live_trading_v1.json\"\nDSA_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis\")\n\n# ── analyzer_service integration ─────────────────────────────────────────────\nANALYZER_TIMEOUT_SEC = 20  # 单只股票超时秒数\n\n\ndef _load_analyzer_service():\n    \"\"\"Lazy-import analyzer_service.\"\"\"\n    if not (DSA_ROOT / 'analyzer_service.py').exists():\n        return None, 'dsa_root_not_found'\n    if str(DSA_ROOT) not in __import__('sys').path:\n        __import__('sys').path.insert(0, str(DSA_ROOT))\n    try:\n        import importlib\n        mod = importlib.import_module('analyzer_service')\n        return mod, None\n    except Exception as e:\n        return None, repr(e)\n\n\ndef _timeout_handler(signum, frame):\n    raise TimeoutError('analyze_stocks timed out')\n\n\ndef fetch_stock_analyses(stock_codes: list[str]) -> dict[str, Any]:\n    \"\"\"\n    调用 analyzer_service.analyze_stocks() 对给定股票列表进行分析。\n    Returns:\n        {\n            \"available\": bool,\n            \"analyses\": [\n                {\n                    \"code\": \"600000\",\n                    \"sentiment_score\": 65,\n                    \"operation_advice\": \"买入\",\n                    \"core_conclusion\": \"...\",\n                    \"error\": null\n                },\n                ...\n            ],\n            \"error\": str | None\n        }\n    \"\"\"\n    if not stock_codes:\n        return {'available': False, 'analyses': [], 'error': 'no_stock_codes'}\n\n    mod, err = _load_analyzer_service()\n    if err:\n        return {'available': False, 'analyses': [], 'error': err}\n\n    results = []\n    for code in stock_codes:\n        old_handler = signal.signal(signal.SIGALRM, _timeout_handler)\n        signal.alarm(ANALYZER_TIMEOUT_SEC)\n        try:\n            result = mod.analyze_stock(code)\n            signal.alarm(0)\n            if result is None:\n                results.append({'code': code, 'error': 'analyze_stock returned None'})\n            else:\n                results.append({\n                    'code': code,\n                    'sentiment_score': getattr(result, 'sentiment_score', None),\n                    'operation_advice': getattr(result, 'operation_advice', None),\n                    'core_conclusion': getattr(result, 'core_conclusion', None) or '',\n                    'error': None\n                })\n        except TimeoutError:\n            signal.alarm(0)\n            results.append({'code': code, 'error': f'timeout_after_{ANALYZER_TIMEOUT_SEC}s'})\n        except Exception as e:\n            signal.alarm(0)\n            results.append({'code': code, 'error': repr(e)})\n        finally:\n            signal.signal(signal.SIGALRM, old_handler)\n\n    return {'available': True, 'analyses': results, 'error': None}\n\n\n# ── v1 code (保持不变) ─────────────────────────────────────────────────────\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef latest_file(pattern: str) -> Path:\n    files = sorted(REPORT_DIR.glob(pattern))\n    if not files:\n        raise FileNotFoundError(f\"未找到文件: {pattern}\")\n    return files[-1]\n\n\ndef parse_float(v: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(v).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef extract_stock_codes_from_orders(path: Path) -> list[str]:\n    \"\"\"从订单 CSV 提取所有涉及的股票代码（去重）\"\"\"\n    if not path.exists():\n        return []\n    df = pd.read_csv(path)\n    if df.empty:\n        return []\n    codes = set()\n    for col in ['ts_code', 'ticker', 'symbol', 'code', 'stock_code']:\n        if col in df.columns:\n            codes.update(df[col].dropna().astype(str).unique())\n    # 清理：只保留 6 位数字代码\n    cleaned = []\n    for c in codes:\n        c = str(c).strip()\n        if len(c) == 6 and c.isdigit():\n            cleaned.append(c)\n    return list(set(cleaned))\n\n\ndef summarize_orders(path: Path) -> dict[str, Any]:\n    df = pd.read_csv(path)\n    if df.empty:\n        return {\n            \"total\": 0,\n            \"buy\": 0,\n            \"sell\": 0,\n            \"blocked_buy\": 0,\n            \"planned_buy_amount\": 0.0,\n            \"planned_sell_amount\": 0.0,\n        }\n\n    buy = df[df[\"side\"].astype(str).str.upper() == \"BUY\"].copy()\n    sell = df[df[\"side\"].astype(str).str.upper() == \"SELL\"].copy()\n\n    blocked_buy = buy[buy.get(\"risk_gate\", \"\").astype(str) == \"blocked\"]\n\n    buy_amt = pd.to_numeric(buy.get(\"est_amount\"), errors=\"coerce\").fillna(0.0).sum()\n    sell_amt = pd.to_numeric(sell.get(\"est_amount\"), errors=\"coerce\").fillna(0.0).sum()\n\n    return {\n        \"total\": int(len(df)),\n        \"buy\": int(len(buy)),\n        \"sell\": int(len(sell)),\n        \"blocked_buy\": int(len(blocked_buy)),\n        \"planned_buy_amount\": round(float(buy_amt), 2),\n        \"planned_sell_amount\": round(float(sell_amt), 2),\n    }\n\n\ndef summarize_journal(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {\n            \"exists\": False,\n            \"records\": 0,\n            \"buy_exec\": 0,\n            \"sell_exec\": 0,\n            \"pnl_day\": 0.0,\n            \"pnl_total\": 0.0,\n            \"drawdown\": 0.0,\n            \"slippage\": 0.0,\n        }\n\n    df = pd.read_csv(path)\n    if df.empty:\n        return {\n            \"exists\": True,\n            \"records\": 0,\n            \"buy_exec\": 0,\n            \"sell_exec\": 0,\n            \"pnl_day\": 0.0,\n            \"pnl_total\": 0.0,\n            \"drawdown\": 0.0,\n            \"slippage\": 0.0,\n        }\n\n    action = df.get(\"action\", pd.Series([], dtype=str)).astype(str).str.upper()\n    buy_exec = int((action == \"BUY\").sum())\n    sell_exec = int((action == \"SELL\").sum())\n\n    pnl_day = pd.to_numeric(df.get(\"pnl_day\"), errors=\"coerce\").fillna(0.0).sum()\n    pnl_total = pd.to_numeric(df.get(\"pnl_total\"), errors=\"coerce\").dropna()\n    pnl_total_last = float(pnl_total.iloc[-1]) if not pnl_total.empty else 0.0\n\n    drawdown = pd.to_numeric(df.get(\"drawdown\"), errors=\"coerce\").dropna()\n    drawdown_min = float(drawdown.min()) if not drawdown.empty else 0.0\n\n    slippage = pd.to_numeric(df.get(\"slippage\"), errors=\"coerce\").dropna()\n    slippage_mean = float(slippage.mean()) if not slippage.empty else 0.0\n\n    return {\n        \"exists\": True,\n        \"records\": int(len(df)),\n        \"buy_exec\": buy_exec,\n        \"sell_exec\": sell_exec,\n        \"pnl_day\": round(float(pnl_day), 2),\n        \"pnl_total\": round(pnl_total_last, 2),\n        \"drawdown\": round(drawdown_min, 2),\n        \"slippage\": round(slippage_mean, 4),\n    }\n\n\ndef build_review(\n    date_tag: str,\n    config: dict[str, Any],\n    live_payload: dict[str, Any],\n    orders_stats: dict[str, Any],\n    journal_stats: dict[str, Any],\n    files: dict[str, str],\n    stock_analyses: dict[str, Any] | None = None,\n) -> tuple[dict[str, Any], str]:\n    combo = live_payload.get(\"combo_v1\", {})\n    risk_cfg = config.get(\"risk\", {})\n\n    dd_guard = parse_float(risk_cfg.get(\"portfolio_drawdown_guard_pct\"), -2.5)\n    dd_halt = parse_float(risk_cfg.get(\"portfolio_drawdown_halt_pct\"), -3.5)\n    day_dd = parse_float(journal_stats.get(\"drawdown\"), 0.0)\n\n    if day_dd <= dd_halt:\n        risk_level = \"RED\"\n        tomorrow_mode = \"halt\"\n    elif day_dd <= dd_guard:\n        risk_level = \"YELLOW\"\n        tomorrow_mode = \"cautious\"\n    else:\n        risk_level = \"GREEN\"\n        tomorrow_mode = \"normal\"\n\n    summary = {\n        \"date\": date_tag,\n        \"combo\": {\n            \"annual_return_pct\": combo.get(\"annual_return_pct\"),\n            \"max_drawdown_pct\": combo.get(\"max_drawdown_pct\"),\n            \"sharpe\": combo.get(\"sharpe\"),\n        },\n        \"orders\": orders_stats,\n        \"journal\": journal_stats,\n        \"risk_level\": risk_level,\n        \"tomorrow_mode\": tomorrow_mode,\n        \"files\": files,\n    }\n\n    # ── Layer 3: 接入个股分析 ─────────────────────────────────────\n    if stock_analyses:\n        summary[\"stock_analyses\"] = stock_analyses.get('analyses', [])\n        summary[\"stock_analyses_available\"] = stock_analyses.get('available', False)\n        summary[\"stock_analyses_error\"] = stock_analyses.get('error')\n    else:\n        summary[\"stock_analyses_available\"] = False\n\n    # 构造 markdown\n    analysis_section = \"\"\n    if stock_analyses and stock_analyses.get('available'):\n        analyses = stock_analyses.get('analyses', [])\n        if analyses:\n            lines = [\"## 今日订单个股分析\\n\"]\n            for a in analyses[:10]:  # 最多显示 10 只\n                code = a.get('code', '-')\n                score = a.get('sentiment_score', '-')\n                advice = a.get('operation_advice', '-')\n                conclusion = a.get('core_conclusion', '')[:100] or '-'\n                err = a.get('error')\n                if err:\n                    lines.append(f\"- **{code}**: 分析失败 ({err})\")\n                else:\n                    lines.append(f\"- **{code}**: 得分={score}, 建议={advice}\")\n            analysis_section = \"\\n\".join(lines)\n\n    md = \"\\n\".join(\n        [\n            f\"# 收盘复盘 v2（{date_tag}）\",\n            \"\",\n            \"## 组合状态\",\n            f\"- 年化（回测口径）：`{combo.get('annual_return_pct', '-') }%`\",\n            f\"- 最大回撤（回测口径）：`{combo.get('max_drawdown_pct', '-') }%`\",\n            f\"- 夏普（回测口径）：`{combo.get('sharpe', '-') }`\",\n            \"\",\n            \"## 今日计划执行统计\",\n            f\"- 计划订单：`{orders_stats['total']}`（BUY {orders_stats['buy']} / SELL {orders_stats['sell']}）\",\n            f\"- BUY阻断数：`{orders_stats['blocked_buy']}`\",\n            f\"- 计划买入金额：`{orders_stats['planned_buy_amount']}`\",\n            f\"- 计划卖出金额：`{orders_stats['planned_sell_amount']}`\",\n            \"\",\n            \"## 今日实际成交统计\",\n            f\"- 日志记录数：`{journal_stats['records']}`\",\n            f\"- 实际BUY/SELL：`{journal_stats['buy_exec']}` / `{journal_stats['sell_exec']}`\",\n            f\"- 当日PnL：`{journal_stats['pnl_day']}`\",\n            f\"- 累计PnL：`{journal_stats['pnl_total']}`\",\n            f\"- 日内回撤：`{journal_stats['drawdown']}%`\",\n            f\"- 平均滑点：`{journal_stats['slippage']}`\",\n            \"\",\n            \"## 风控结论\",\n            f\"- 风险等级：`{risk_level}`\",\n            f\"- 次日建议模式：`{tomorrow_mode}`\",\n            \"\",\n            \"## 文件\",\n            f\"- 下单模板：`{files['orders']}`\",\n            f\"- 交易日志：`{files['journal']}`\",\n            f\"- 盘前预警（将生成）：`{files['premarket']}`\",\n            \"\",\n            analysis_section,\n        ]\n    )\n\n    return summary, md\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"收盘复盘生成 v2（新增个股分析）\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--orders\", default=\"\", help=\"可选：指定 live_orders csv\")\n    parser.add_argument(\"--journal\", default=\"\", help=\"可选：指定 live_journal csv\")\n    parser.add_argument(\"--skip-stock-analysis\", action=\"store_true\",\n                        help=\"跳过个股分析（analyzer_service 调用）\")\n    args = parser.parse_args()\n\n    date_tag = args.date.strip() if args.date.strip() else datetime.now().strftime(\"%Y%m%d\")\n\n    config = load_json(CONFIG_PATH)\n    live_json = latest_file(\"live_system_v1_*.json\")\n    live_payload = load_json(live_json)\n\n    orders = Path(args.orders).resolve() if args.orders else latest_file(f\"live_orders_v1_{date_tag}.csv\")\n    journal = Path(args.journal).resolve() if args.journal else REPORT_DIR / f\"live_journal_v1_{date_tag}.csv\"\n\n    files = {\n        \"orders\": str(orders),\n        \"journal\": str(journal),\n        \"premarket\": str(REPORT_DIR / f\"live_premarket_risk_v1_{date_tag}.md\"),\n    }\n\n    orders_stats = summarize_orders(orders)\n    journal_stats = summarize_journal(journal)\n\n    # ── Layer 3: 个股分析 ───────────────────────────────────────────\n    stock_analyses = None\n    if not args.skip_stock_analysis:\n        stock_codes = extract_stock_codes_from_orders(orders)\n        if stock_codes:\n            stock_analyses = fetch_stock_analyses(stock_codes)\n\n    payload, md = build_review(\n        date_tag=date_tag,\n        config=config,\n        live_payload=live_payload,\n        orders_stats=orders_stats,\n        journal_stats=journal_stats,\n        files=files,\n        stock_analyses=stock_analyses,\n    )\n\n    out_json = REPORT_DIR / f\"live_close_review_v2_{date_tag}.json\"\n    out_md = REPORT_DIR / f\"live_close_review_v2_{date_tag}.md\"\n\n    out_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    out_md.write_text(md + \"\\n\", encoding=\"utf-8\")\n\n    print(json.dumps({\n        \"review_json\": str(out_json),\n        \"review_md\": str(out_md),\n        \"summary\": payload,\n        \"stock_analyses_available\": payload.get(\"stock_analyses_available\", False)\n    }, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()\n","path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_close_review_v2.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":84222,"output":3622,"cacheRead":24293,"cacheWrite":0,"totalTokens":112137,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773928107354}}
