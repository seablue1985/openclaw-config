{"type":"message","id":"b6cf2b70","parentId":"8b0d8f0c","timestamp":"2026-03-26T02:39:11.178Z","message":{"role":"toolResult","toolCallId":"call_function_3he6zc7xtmqq_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n宽度策略模拟盘\n- 默认参数仍兼容旧版进取盘\n- 支持通过命令行覆写参数，生成严格样本外版本的独立模拟盘\n\"\"\"\nimport sys, os\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport multiprocessing as mp\nmp.freeze_support()\n\nimport pandas as pd\nimport numpy as np\nimport json\nimport argparse\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nDATA_DIR = PROJECT_ROOT / \"data\" / \"ml_dataset_full\"\nPREDICTIONS_PATH = DATA_DIR / \"ml_predictions.csv\"\nLIVE_PREDICTIONS_PATH = DATA_DIR / \"ml_predictions_live_latest.csv\"\nFEATURES_PATH = DATA_DIR / \"ml_features_full.csv\"\nMAX_SIGNAL_LAG_DAYS = 2\nTODAY_STR = datetime.now().strftime(\"%Y%m%d\")\nTODAY_ISO = datetime.now().strftime(\"%Y-%m-%d\")\n\n\ndef append_history_records(summary: dict, slug: str) -> dict:\n    csv_path = REPORT_DIR / f\"{slug}_daily_history.csv\"\n    jsonl_path = REPORT_DIR / f\"{slug}_daily_history.jsonl\"\n    nav_history = summary.get(\"nav_history\", []) or []\n    compact_history: list[dict] = []\n    seen_markers: set[tuple[str, float, float]] = set()\n    for item in nav_history:\n        nav = round(float(item.get(\"nav\", 0.0)), 6)\n        cash = round(float(item.get(\"cash\", summary.get(\"cash\", 0.0))), 2)\n        marker = (str(item.get(\"date\") or summary.get(\"signal_date\")), nav, cash)\n        if marker in seen_markers:\n            continue\n        seen_markers.add(marker)\n        compact_history.append(item)\n    nav_history = compact_history\n    records: list[dict] = []\n    for idx, item in enumerate(nav_history):\n        nav = round(float(item.get(\"nav\", 0.0)), 6)\n        cash = round(float(item.get(\"cash\", summary.get(\"cash\", 0.0))), 2)\n        total_value = round(nav * float(summary.get(\"paper_capital\", 0.0)), 2)\n        market_value = round(total_value - cash, 2)\n        records.append(\n            {\n                \"generated_at\": f\"{summary.get('generated_at')}#{idx+1}\",\n                \"signal_date\": item.get(\"date\") or summary.get(\"signal_date\"),\n                \"nav\": nav,\n                \"total_value\": total_value,\n                \"cash\": cash,\n                \"market_value\": market_value,\n                \"position_count\": int(summary.get(\"position_count\", 0) or 0),\n                \"target_position_pct\": round(float(summary.get(\"target_position_pct\", 0.0)), 2),\n                \"actual_position_pct\": round(market_value / total_value * 100.0, 2) if total_value > 0 else 0.0,\n                \"breadth\": round(float(summary.get(\"breadth\", 0.0)), 4),\n                \"buy_count\": len(summary.get(\"buy_list\", []) or []),\n                \"sell_count\": len(summary.get(\"sell_list\", []) or []),\n                \"snapshot_index\": idx + 1,\n            }\n        )\n    if not records:\n        records.append(\n            {\n                \"generated_at\": summary.get(\"generated_at\"),\n                \"signal_date\": summary.get(\"signal_date\"),\n                \"nav\": round(float(summary.get(\"nav\", 0.0)), 6),\n                \"total_value\": round(float(summary.get(\"total_value\", 0.0)), 2),\n                \"cash\": round(float(summary.get(\"cash\", 0.0)), 2),\n                \"market_value\": round(float(summary.get(\"market_value\", 0.0)), 2),\n                \"position_count\": int(summary.get(\"position_count\", 0) or 0),\n                \"target_position_pct\": round(float(summary.get(\"target_position_pct\", 0.0)), 2),\n                \"actual_position_pct\": round(float(summary.get(\"market_value\", 0.0)) / float(summary.get(\"total_value\", 1.0)) * 100.0, 2) if float(summary.get(\"total_value\", 0.0)) > 0 else 0.0,\n                \"breadth\": round(float(summary.get(\"breadth\", 0.0)), 4),\n                \"buy_count\": len(summary.get(\"buy_list\", []) or []),\n                \"sell_count\": len(summary.get(\"sell_list\", []) or []),\n                \"snapshot_index\": 1,\n            }\n        )\n\n    existing: list[dict] = []\n    if jsonl_path.exists():\n        with open(jsonl_path, \"r\", encoding=\"utf-8\") as f:\n            for line in f:\n                line = line.strip()\n                if not line:\n                    continue\n                try:\n                    existing.append(json.loads(line))\n                except Exception:\n                    pass\n\n    current_signal_date = str(summary.get(\"signal_date\", \"\"))\n    deduped = [x for x in existing if str(x.get(\"signal_date\", \"\")) != current_signal_date]\n    deduped.extend(records)\n    deduped.sort(key=lambda x: (str(x.get(\"signal_date\", \"\")), int(x.get(\"snapshot_index\", 0)), str(x.get(\"generated_at\", \"\"))))\n\n    with open(jsonl_path, \"w\", encoding=\"utf-8\") as f:\n        for row in deduped:\n            f.write(json.dumps(row, ensure_ascii=False) + \"\\n\")\n\n    pd.DataFrame(deduped).to_csv(csv_path, index=False, encoding=\"utf-8\")\n    return {\"csv\": str(csv_path), \"jsonl\": str(jsonl_path)}\n\n\ndef get_realtime_prices(symbols):\n    \"\"\"获取实时/最近收盘价\"\"\"\n    prices = {}\n    # 方案1: 用 run_live_execution_v1 的价格接口\n    try:\n        sys.path.insert(0, str(Path(__file__).resolve().parents[1] / \"scripts\"))\n        from run_live_execution_v1 import fetch_realtime_quote\n        for sym in symbols:\n            quote = fetch_realtime_quote(sym)\n            if quote and quote.get(\"last\", 0) > 0:\n                prices[sym] = {\n                    \"price\": quote[\"last\"],\n                    \"change_pct\": quote.get(\"pct\", 0),\n                    \"name\": quote.get(\"name\", \"\"),\n                    \"source\": quote.get(\"source\", \"realtime\"),\n                }\n    except Exception as e:\n        pass\n\n    # 方案2: 从Qlib历史收盘数据获取最近收盘价\n    if len(prices) < len(symbols):\n        try:\n            import run_qlib_breadth_sanity_check as sanity\n            qlib_root = str(sanity.QLIB_LONG_ROOT)\n            from qlib.data import D\n            from qlib.utils.time import Frequency\n            for sym in symbols:\n                if sym in prices:\n                    continue\n                try:\n                    end = (datetime.now() + timedelta(days=5)).strftime(\"%Y-%m-%d\")\n                    start = (datetime.now() - timedelta(days=10)).strftime(\"%Y-%m-%d\")\n                    df = D.features([sym], [\"$close\"], start, end, freq=\"day\")\n                    if df is not None and len(df) > 0:\n                        latest_close = float(df[\"$close\"].dropna().iloc[-1])\n                        prices[sym] = {\n                            \"price\": latest_close,\n                            \"change_pct\": 0.0,\n                            \"name\": \"\",\n                            \"source\": \"qlib_close\",\n                        }\n                except Exception:\n                    pass\n        except Exception:\n            pass\n\n    return prices\n\n\ndef load_feature_latest_date() -> str | None:\n    if not FEATURES_PATH.exists():\n        return None\n    latest_date = None\n    try:\n        for chunk in pd.read_csv(FEATURES_PATH, usecols=[\"date\"], chunksize=500000):\n            dates = pd.to_datetime(chunk[\"date\"], errors=\"coerce\").dropna()\n            if len(dates) == 0:\n                continue\n            chunk_max = dates.max()\n            latest_date = chunk_max if latest_date is None or chunk_max > latest_date else latest_date\n    except Exception:\n        return None\n    return latest_date.date().isoformat() if latest_date is not None else None\n\n\ndef load_latest_signals(topk: int):\n    \"\"\"加载最新预测，优先 live 预测文件；若信号明显落后于特征最新日期，则标记为过期。\"\"\"\n    prediction_path = LIVE_PREDICTIONS_PATH if LIVE_PREDICTIONS_PATH.exists() else PREDICTIONS_PATH\n    preds = pd.read_csv(prediction_path, usecols=[\"date\", \"symbol\", \"pred_rank\"])\n    preds['date'] = pd.to_datetime(preds['date'], errors='coerce')\n    preds = preds.dropna(subset=['date', 'symbol', 'pred_rank']).copy()\n    latest_date = preds['date'].max()\n    latest = preds[preds['date'] == latest_date].copy()\n\n    # 过滤沪深300候选（主板+科创板）\n    hs300_mask = latest['symbol'].astype(str).str.match(r'^(000|001|002|003|600|601|603|688)')\n    hs300 = latest[hs300_mask].copy()\n\n    # 排除ST/*ST股票\n    try:\n        import tushare as ts\n        pro = ts.pro_api()\n        basic = pro.stock_basic(exchange='', list_status='L', fields='ts_code,name')\n        st_set = set(basic[basic['name'].str.contains('ST', na=False)]['ts_code'].tolist())\n        hs300 = hs300[~hs300['symbol'].isin(st_set)]\n        print(f\"  排除ST后候选数: {len(hs300)}\")\n    except Exception as e:\n        print(f\"  ST过滤失败: {e}，跳过\")\n\n    top_stocks = hs300.sort_values('pred_rank', ascending=False).head(topk).copy()\n    signal_date = latest_date.date().isoformat()\n    feature_latest_date = load_feature_latest_date()\n    signal_lag_days = None\n    stale_reason = \"\"\n    is_stale = False\n    if feature_latest_date:\n        lag_days = (datetime.strptime(feature_latest_date, \"%Y-%m-%d\").date() - latest_date.date()).days\n        signal_lag_days = max(lag_days, 0)\n        if lag_days > MAX_SIGNAL_LAG_DAYS:\n            is_stale = True\n            stale_reason = f\"信号已过期：预测文件最新日期 {signal_date}，但特征数据已到 {feature_latest_date}，落后 {lag_days} 天\"\n\n    meta = {\n        \"prediction_path\": str(prediction_path),\n        \"signal_date\": signal_date,\n        \"feature_latest_date\": feature_latest_date,\n        \"signal_lag_days\": signal_lag_days,\n        \"is_stale\": is_stale,\n        \"stale_reason\": stale_reason,\n        \"preferred_live_predictions\": str(LIVE_PREDICTIONS_PATH),\n    }\n    return signal_date, top_stocks, meta\n\n\ndef load_breadth():\n    \"\"\"加载市场宽度\"\"\"\n    import run_qlib_breadth_sanity_check as sanity\n    breadth = sanity.load_market_breadth()\n    latest_date = breadth.index.max()\n    b = breadth.loc[latest_date] if latest_date in breadth.index else breadth.iloc[-1]\n    return float(b)\n\n\ndef compute_position_scale(breadth_val, profile):\n    \"\"\"根据宽度计算仓位系数\"\"\"\n    if breadth_val < profile[\"low_th\"]:\n        return profile[\"low_scale\"]\n    elif breadth_val < profile[\"mid_th\"]:\n        return profile[\"mid_scale\"]\n    else:\n        return profile[\"high_scale\"]\n\n\ndef load_state(state_file, paper_capital):\n    \"\"\"加载持仓状态\"\"\"\n    if state_file.exists():\n        with open(state_file) as f:\n            return json.load(f)\n    return {\n        \"holdings\": {},\n        \"nav_history\": [],\n        \"cash\": paper_capital,\n    }\n\n\ndef save_state(state, state_file):\n    with open(state_file, 'w') as f:\n        json.dump(state, f, ensure_ascii=False, indent=2)\n\n\ndef run_one_day(signals_date, top_stocks, breadth_val, live_prices, *, state_file, paper_capital, risk_degree, profile):\n    \"\"\"每日模拟交易\"\"\"\n    state = load_state(state_file, paper_capital)\n    position_scale = compute_position_scale(breadth_val, profile)\n    target_risk = risk_degree * position_scale\n\n    current_holdings = set(state[\"holdings\"].keys())\n    target_symbols = set(top_stocks['symbol'].tolist())\n    sell_list = current_holdings - target_symbols\n    buy_list = target_symbols - current_holdings\n    keep_list = current_holdings & target_symbols\n\n    # 更新现有持仓价格\n    for sym in keep_list:\n        if sym in live_prices:\n            info = state[\"holdings\"][sym]\n            info[\"current_price\"] = live_prices[sym][\"price\"]\n            info[\"current_value\"] = info[\"shares\"] * info[\"current_price\"]\n\n    # 卖出（全部清仓）\n    for sym in sell_list:\n        info = state[\"holdings\"][sym]\n        price = live_prices.get(sym, {}).get(\"price\", info[\"avg_price\"])\n        proceeds = info[\"shares\"] * price * (1 - 0.001885)\n        state[\"cash\"] += proceeds\n        del state[\"holdings\"][sym]\n\n    # 买入（等权分配）\n    if target_risk > 0.01 and buy_list:\n        total_asset = state[\"cash\"] + sum(h.get(\"current_value\", h[\"shares\"] * h[\"avg_price\"]) for h in state[\"holdings\"].values())\n        per_stock_value = (total_asset * target_risk) / len(buy_list)\n        for sym in buy_list:\n            price = live_prices.get(sym, {}).get(\"price\", 1.0)\n            if price <= 0:\n                price = 1.0\n            shares = int(per_stock_value / price / 100) * 100\n            if shares > 0 and state[\"cash\"] >= shares * price * 1.002:\n                cost = shares * price * (1 + 0.000885)\n                state[\"cash\"] -= cost\n                state[\"holdings\"][sym] = {\n                    \"shares\": shares,\n                    \"avg_price\": price,\n                    \"current_price\": price,\n                    \"current_value\": shares * price,\n                    \"buy_date\": signals_date,\n                }\n\n    # 更新总资产和净值\n    total_value = state[\"cash\"]\n    for sym, info in state[\"holdings\"].items():\n        total_value += info.get(\"current_value\", info[\"shares\"] * info[\"current_price\"])\n\n    nav = total_value / paper_capital\n    state[\"nav_history\"].append({\n        \"date\": signals_date,\n        \"nav\": round(nav, 4),\n        \"cash\": round(state[\"cash\"], 2),\n    })\n\n    save_state(state, state_file)\n    return state, nav, position_scale, breadth_val, buy_list, sell_list\n\n\ndef refresh_holdings_snapshot(state, live_prices, *, state_file, paper_capital, snapshot_date):\n    holdings = state.get(\"holdings\", {})\n    for sym, info in holdings.items():\n        if sym in live_prices and live_prices[sym].get(\"price\", 0) > 0:\n            info[\"current_price\"] = live_prices[sym][\"price\"]\n            info[\"current_value\"] = info[\"shares\"] * info[\"current_price\"]\n    total_value = state.get(\"cash\", 0.0)\n    for info in holdings.values():\n        total_value += info.get(\"current_value\", info[\"shares\"] * info.get(\"current_price\", info[\"avg_price\"]))\n    nav = total_value / paper_capital if paper_capital > 0 else 1.0\n    state.setdefault(\"nav_history\", []).append({\n        \"date\": snapshot_date,\n        \"nav\": round(nav, 4),\n        \"cash\": round(float(state.get(\"cash\", 0.0)), 2),\n    })\n    save_state(state, state_file)\n    return state, nav\n\n\ndef generate_report(state, nav, position_scale, breadth_val, buy_list, sell_list, top_stocks, signals_date, live_prices, *, strategy_name, topk, risk_degree, turnover_cap, profile, signal_meta=None):\n    \"\"\"生成Markdown报告\"\"\"\n    holdings = state[\"holdings\"]\n    total_value = state[\"cash\"] + sum(h.get(\"current_value\", 0) for h in holdings.values())\n\n    target_risk = risk_degree * position_scale\n    total_pct = target_risk * 100\n\n    # 宽度区间说明\n    if breadth_val >= profile[\"mid_th\"]:\n        width_label = f\"高宽度（≥{profile['mid_th']}）→ 满仓系数{profile['high_scale']*100:.0f}%\"\n    elif breadth_val >= profile[\"low_th\"]:\n        width_label = f\"中宽度（{profile['low_th']}~{profile['mid_th']}）→ 半仓系数{profile['mid_scale']*100:.0f}%\"\n    else:\n        width_label = f\"低宽度（<{profile['low_th']}）→ 轻仓系数{profile['low_scale']*100:.0f}%\"\n\n    lines = []\n    lines.append(f\"# {strategy_name}\")\n    lines.append(f\"\")\n    lines.append(f\"**信号日期**: {signals_date}  |  **报告时间**: {datetime.now().strftime('%Y-%m-%d %H:%M')}\")\n    if signal_meta and signal_meta.get(\"is_stale\"):\n        lines.append(f\"\")\n        lines.append(f\"> ⚠️ 信号过期：{signal_meta.get('stale_reason')}\")\n        lines.append(f\"> 当前已停止自动调仓，仅保留持仓估值更新；待 live 预测文件刷新后再恢复正常换仓。\")\n    lines.append(f\"\")\n    lines.append(f\"## 账户概况\")\n    lines.append(f\"| 指标 | 数值 |\")\n    lines.append(f\"|------|------|\")\n    lines.append(f\"| 模拟净值 | **{nav:.4f}** |\")\n    lines.append(f\"| 总资产 | **{total_value:,.0f}** 元 |\")\n    lines.append(f\"| 可用现金 | **{state['cash']:,.0f}** 元 |\")\n    lines.append(f\"| 持仓市值 | **{total_value - state['cash']:,.0f}** 元 |\")\n    lines.append(f\"| 目标仓位 | **{total_pct:.0f}%**（rd={risk_degree}×宽度系数{position_scale:.2f}）|\")\n    lines.append(f\"| 市场宽度 | **{breadth_val:.4f}** |\")\n    lines.append(f\"| 宽度区间 | {width_label} |\")\n    lines.append(f\"| 选股数量 | **{topk}** |\")\n    lines.append(f\"| 换手上限参数 | **{turnover_cap:.2f}** |\")\n    lines.append(f\"\")\n    lines.append(f\"## 持仓明细（{len(holdings)}只）\")\n    if holdings:\n        # 计算浮亏\n        rows_data = []\n        for sym, info in holdings.items():\n            price_info = live_prices.get(sym, {})\n            cur_price = price_info.get(\"price\", info[\"avg_price\"])\n            change_pct = price_info.get(\"change_pct\", 0.0)\n            avg = info[\"avg_price\"]\n            float_pct = (cur_price - avg) / avg * 100 if avg > 0 else 0\n            rows_data.append({\n                \"代码\": sym,\n                \"名称\": price_info.get(\"name\", \"\"),\n                \"持股数\": info[\"shares\"],\n                \"成本价\": f\"{avg:.2f}\",\n                \"现价\": f\"{cur_price:.2f}\",\n                \"现价涨跌\": f\"{change_pct:+.2f}%\" if change_pct else \"-\",\n                \"浮盈亏\": f\"{float_pct:+.1f}%\",\n            })\n        rows_df = pd.DataFrame(rows_data)\n        lines.append(rows_df.to_markdown(index=False))\n    else:\n        lines.append(\"*空仓*\")\n    lines.append(f\"\")\n    lines.append(f\"## 调仓信号\")\n    if sell_list:\n        sell_info = [f\"**卖出**: {', '.join(sorted(sell_list))}\"]\n        lines.extend(sell_info)\n    else:\n        lines.append(\"**卖出**: 无\")\n    if buy_list:\n        buy_info = [f\"**买入**: {', '.join(sorted(buy_list))}\"]\n        lines.extend(buy_info)\n    else:\n        lines.append(\"**买入**: 无（持仓无变化）\")\n    lines.append(f\"\")\n    lines.append(f\"## 当日模型评分 Top {topk}\")\n    top_data = []\n    for i, (_, row) in enumerate(top_stocks.iterrows(), 1):\n        sym = row['symbol']\n        in_holding = \"✅\" if sym in holdings else \"⬜\"\n        top_data.append({\"#\": i, \"代码\": sym, \"pred_rank\": f\"{row['pred_rank']:.4f}\", \"状态\": in_holding})\n    lines.append(pd.DataFrame(top_data).to_markdown(index=False))\n    lines.append(f\"\")\n    lines.append(f\"## 净值历史\")\n    hist = state[\"nav_history\"]\n    if len(hist) >= 5:\n        for h in hist[-5:]:\n            lines.append(f\"- {h['date']}: 净值 **{h['nav']:.4f}**\")\n    elif len(hist) > 0:\n        for h in hist:\n            lines.append(f\"- {h['date']}: 净值 **{h['nav']:.4f}**\")\n    lines.append(f\"\")\n    lines.append(f\"---\")\n    lines.append(f\"*模拟盘仅供研究参考，不构成投资建议。实时价格仅供参考，以实际成交为准。*\")\n\n    return \"\\n\".join(lines)\n\n\ndef build_summary(state, nav, position_scale, breadth_val, buy_list, sell_list, top_stocks, signals_date, live_prices, *, strategy_name, slug, paper_capital, topk, risk_degree, turnover_cap, profile, report_path, state_file, signal_meta=None, execution_status=\"executed\"):\n    holdings = state[\"holdings\"]\n    total_value = state[\"cash\"] + sum(h.get(\"current_value\", 0) for h in holdings.values())\n    signal_meta = signal_meta or {}\n    return {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"strategy_name\": strategy_name,\n        \"slug\": slug,\n        \"signal_date\": signals_date,\n        \"signal_stale\": bool(signal_meta.get(\"is_stale\", False)),\n        \"signal_stale_reason\": signal_meta.get(\"stale_reason\", \"\"),\n        \"signal_lag_days\": signal_meta.get(\"signal_lag_days\"),\n        \"feature_latest_date\": signal_meta.get(\"feature_latest_date\"),\n        \"prediction_source_file\": signal_meta.get(\"prediction_path\", \"\"),\n        \"preferred_live_predictions\": signal_meta.get(\"preferred_live_predictions\", \"\"),\n        \"execution_status\": execution_status,\n        \"paper_capital\": paper_capital,\n        \"nav\": round(nav, 4),\n        \"total_value\": round(total_value, 2),\n        \"cash\": round(state[\"cash\"], 2),\n        \"market_value\": round(total_value - state[\"cash\"], 2),\n        \"position_count\": len(holdings),\n        \"target_position_pct\": round(risk_degree * position_scale * 100, 2),\n        \"breadth\": round(float(breadth_val), 4),\n        \"topk\": topk,\n        \"risk_degree\": risk_degree,\n        \"turnover_cap\": turnover_cap,\n        \"profile\": profile,\n        \"buy_list\": sorted(list(buy_list)),\n        \"sell_list\": sorted(list(sell_list)),\n        \"holdings\": [\n            {\n                \"symbol\": sym,\n                \"shares\": info[\"shares\"],\n                \"avg_price\": info[\"avg_price\"],\n                \"current_price\": info.get(\"current_price\", info[\"avg_price\"]),\n                \"current_value\": info.get(\"current_value\", info[\"shares\"] * info[\"avg_price\"]),\n                \"buy_date\": info.get(\"buy_date\", \"\"),\n                \"name\": live_prices.get(sym, {}).get(\"name\", \"\"),\n            }\n            for sym, info in sorted(holdings.items())\n        ],\n        \"top_stocks\": [\n            {\n                \"symbol\": row[\"symbol\"],\n                \"pred_rank\": float(row[\"pred_rank\"]),\n            }\n            for _, row in top_stocks.iterrows()\n        ],\n        \"nav_history\": state.get(\"nav_history\", []),\n        \"files\": {\n            \"report_md\": str(report_path),\n            \"state_file\": str(state_file),\n        },\n    }\n\n\ndef parse_args():\n    parser = argparse.ArgumentParser(description=\"宽度策略模拟盘\")\n    parser.add_argument(\"--strategy-name\", default=\"进取宽度策略模拟盘\")\n    parser.add_argument(\"--slug\", default=\"breadth_aggressive\")\n    parser.add_argument(\"--paper-capital\", type=float, default=1_000_000)\n    parser.add_argument(\"--topk\", type=int, default=8)\n    parser.add_argument(\"--risk-degree\", type=float, default=0.80)\n    parser.add_argument(\"--turnover-cap\", type=float, default=0.28)\n    parser.add_argument(\"--low-th\", type=float, default=0.45)\n    parser.add_argument(\"--mid-th\", type=float, default=0.55)\n    parser.add_argument(\"--low-scale\", type=float, default=0.40)\n    parser.add_argument(\"--mid-scale\", type=float, default=0.70)\n    parser.add_argument(\"--high-scale\", type=float, default=1.00)\n    return parser.parse_args()\n\n\ndef main():\n    args = parse_args()\n    sim_dir = Path(__file__).resolve().parents[1] / f\"paper_{args.slug}\"\n    sim_dir.mkdir(parents=True, exist_ok=True)\n    state_file = sim_dir / \"portfolio_state.json\"\n    profile = {\n        \"low_th\": float(args.low_th),\n        \"mid_th\": float(args.mid_th),\n        \"low_scale\": float(args.low_scale),\n        \"mid_scale\": float(args.mid_scale),\n        \"high_scale\": float(args.high_scale),\n    }\n\n    print(\"=\" * 60)\n    print(args.strategy_name)\n    print(\"=\" * 60)\n\n    print(\"加载信号...\")\n    signals_date, top_stocks, signal_meta = load_latest_signals(args.topk)\n    print(f\"信号日期: {signals_date}\")\n    if signal_meta.get(\"feature_latest_date\"):\n        print(f\"特征最新日期: {signal_meta.get('feature_latest_date')}\")\n    print(f\"预测来源: {signal_meta.get('prediction_path')}\")\n    if signal_meta.get(\"is_stale\"):\n        print(f\"[WARN] {signal_meta.get('stale_reason')}\")\n\n    print(\"加载市场宽度...\")\n    try:\n        breadth_val = load_breadth()\n    except Exception as e:\n        print(f\"宽度加载失败: {e}，默认0.5\")\n        breadth_val = 0.50\n    print(f\"市场宽度: {breadth_val:.4f}\")\n\n    position_scale = compute_position_scale(breadth_val, profile)\n    print(f\"宽度仓位系数: {position_scale}\")\n\n    # 获取价格\n    all_symbols = list(top_stocks['symbol'].tolist())\n    state = load_state(state_file, args.paper_capital)\n    all_symbols += list(state[\"holdings\"].keys())\n    all_symbols = list(set(all_symbols))\n\n    print(\"获取实时价格...\")\n    live_prices = get_realtime_prices(all_symbols)\n    print(f\"获取到 {len(live_prices)}/{len(all_symbols)} 只股票价格\")\n    for sym, info in live_prices.items():\n        print(f\"  {sym}: {info}\")\n\n    execution_status = \"executed\"\n    print(\"执行模拟交易...\")\n    if signal_meta.get(\"is_stale\"):\n        execution_status = \"signal_stale_hold\"\n        state, nav = refresh_holdings_snapshot(\n            state,\n            live_prices,\n            state_file=state_file,\n            paper_capital=float(args.paper_capital),\n            snapshot_date=TODAY_ISO,\n        )\n        pos_scale, b_val = position_scale, breadth_val\n        buy_list, sell_list = set(), set()\n        print(\"检测到旧信号，已停止自动调仓，仅更新持仓快照。\")\n    else:\n        state, nav, pos_scale, b_val, buy_list, sell_list = run_one_day(\n            signals_date, top_stocks, breadth_val, live_prices,\n            state_file=state_file,\n            paper_capital=float(args.paper_capital),\n            risk_degree=float(args.risk_degree),\n            profile=profile,\n        )\n    print(f\"当前净值: {nav:.4f}\")\n    print(f\"买入: {buy_list}, 卖出: {sell_list}\")\n\n    print(\"生成报告...\")\n    report = generate_report(\n        state, nav, pos_scale, b_val, buy_list, sell_list, top_stocks, signals_date, live_prices,\n        strategy_name=args.strategy_name,\n        topk=int(args.topk),\n        risk_degree=float(args.risk_degree),\n        turnover_cap=float(args.turnover_cap),\n        profile=profile,\n        signal_meta=signal_meta,\n    )\n\n    # 保存报告\n    report_path = REPORT_DIR / f\"{args.slug}_paper_{TODAY_STR}.md\"\n    with open(report_path, 'w', encoding='utf-8') as f:\n        f.write(report)\n    latest_report_path = REPORT_DIR / f\"{args.slug}_paper_latest.md\"\n    with open(latest_report_path, 'w', encoding='utf-8') as f:\n        f.write(report)\n\n    json_state = sim_dir / f\"paper_state_{TODAY_STR}.json\"\n    with open(json_state, 'w', encoding='utf-8') as f:\n        json.dump(state, f, ensure_ascii=False, indent=2)\n\n    summary = build_summary(\n        state, nav, pos_scale, b_val, buy_list, sell_list, top_stocks, signals_date, live_prices,\n        strategy_name=args.strategy_name,\n        slug=args.slug,\n        paper_capital=float(args.paper_capital),\n        topk=int(args.topk),\n        risk_degree=float(args.risk_degree),\n        turnover_cap=float(args.turnover_cap),\n        profile=profile,\n        report_path=report_path,\n        state_file=state_file,\n        signal_meta=signal_meta,\n        execution_status=execution_status,\n    )\n    history_files = append_history_records(summary, args.slug)\n    summary.setdefault(\"files\", {}).update(history_files)\n    summary_path = REPORT_DIR / f\"{args.slug}_paper_{TODAY_STR}.json\"\n    latest_summary_path = REPORT_DIR / f\"{args.slug}_paper_latest.json\"\n    with open(summary_path, 'w', encoding='utf-8') as f:\n        json.dump(summary, f, ensure_ascii=False, indent=2)\n    with open(latest_summary_path, 'w', encoding='utf-8') as f:\n        json.dump(summary, f, ensure_ascii=False, indent=2)\n\n    print(f\"\\n报告已保存: {report_path}\")\n    print(\"\\n\" + \"=\" * 60)\n    print(report)\n    return report\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774492751165}}
{"type":"message","id":"4ba1ff71","parentId":"b6cf2b70","timestamp":"2026-03-26T02:39:29.865Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The script already has signal expiration detection built in (MAX_SIGNAL_LAG_DAYS = 2, is_stale flag, stale_reason, and a hold behavior when signal is stale). But the issue is that the `signal_lag_days` calculation compares against `feature_latest_date` from `load_feature_latest_date()`.\n\nLet me check what `load_feature_latest_date()` returns and whether the stale detection is working properly. The problem mentioned is that `signal_date=2026-03-03` is being used for 03-24/25/26. Let me check:\n1. The ML predictions latest date\n\n\n2. The feature file latest date\n3. Whether the stale detection is actually triggering\n\nThe real issue is that the dashboard and reports are silently showing the stale signal without clearly alerting the user. The script has the stale detection logic, but I need to verify it's actually being triggered and that the dashboard is properly communicating this state to users rather than just displaying old data as if it's current.\n\nLooking at the comparison logic, the code calculates lag days by comparing the feature file date against the signal date. If features are from 03-25 and signals from 03-03, that's a 22-day lag, which should definitely trigger the stale flag and block trading. But the problem is the features file itself might be stale too, or the signal freshness check isn't being enforced properly in the first place.\n\nThe real issue is that even when stale signals are detected, the code just silently holds positions without clearly alerting the user that the system has switched to a degraded mode. The dashboard should be displaying prominent warnings that signals haven't been refreshed in days, not just showing empty buy/sell lists as if nothing is wrong.\n\nLooking at the dashboard generation code, I need to verify it's actually surfacing the signal freshness status - whether it's pulling the `signal_stale` and `signal_stale_reason` fields from the summary and displaying them prominently to the user so they understand why the system isn't generating new signals. I need to check the dashboard generator to see where the staleness warning should be injected—it likely has a section for basic info but might be missing the critical signal freshness alert that would make the issue visible to users.","thinkingSignature":"5a0629eb97f74b6289073530fc274c126dc803a932ac3ac2286b09ba1ad3822a"},{"type":"toolCall","id":"call_function_gv2lgxf6ks84_1","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_breadth_aggressive_dashboard.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":34264,"output":510,"cacheRead":22075,"cacheWrite":0,"totalTokens":56849,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774492751178,"responseId":"0613cf4fb12a0e9893601aeec72f4b96"}}
{"type":"message","id":"426d2e05","parentId":"4ba1ff71","timestamp":"2026-03-26T02:39:29.922Z","message":{"role":"toolResult","toolCallId":"call_function_gv2lgxf6ks84_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"进取宽度独立盘面板（与 paper_aggressive 纸盘分离）\"\"\"\nimport sys, os\nsys.path.insert(0, os.path.dirname(__file__))\n\nimport json\nimport argparse\nfrom datetime import datetime\nfrom pathlib import Path\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nSIM_DIR = PROJECT_ROOT / \"paper_breadth_aggressive\"\nSTATE_FILE = SIM_DIR / \"portfolio_state.json\"\nSUMMARY_FILE = REPORT_DIR / \"breadth_aggressive_paper_latest.json\"\n\nPROFILE_NAME = \"进取宽度独立盘\"\nPROFILE_SLUG = \"breadth_aggressive\"\nINITIAL_CASH = 1_000_000\nTODAY_STR = datetime.now().strftime(\"%Y%m%d\")\nNOW_STR = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n\ndef load_state():\n    if STATE_FILE.exists():\n        with open(STATE_FILE) as f:\n            return json.load(f)\n    return {\"holdings\": {}, \"nav_history\": [], \"cash\": INITIAL_CASH}\n\n\ndef load_latest_summary():\n    if SUMMARY_FILE.exists():\n        with open(SUMMARY_FILE) as f:\n            return json.load(f)\n    return {}\n\n\ndef load_nav_curve(state=None):\n    \"\"\"加载模拟盘自己的资金历史，不再混用长周期回测曲线。\"\"\"\n    import pandas as pd\n\n    history_file = REPORT_DIR / \"breadth_aggressive_daily_history.csv\"\n    if history_file.exists():\n        try:\n            df = pd.read_csv(history_file)\n            if len(df) > 0:\n                if \"generated_at\" in df.columns:\n                    df[\"ts\"] = pd.to_datetime(df[\"generated_at\"].astype(str).str.split(\"#\").str[0], errors=\"coerce\")\n                elif \"date\" in df.columns:\n                    df[\"ts\"] = pd.to_datetime(df[\"date\"], errors=\"coerce\")\n                else:\n                    df[\"ts\"] = pd.RangeIndex(start=0, stop=len(df), step=1)\n                df[\"equity\"] = pd.to_numeric(df.get(\"total_value\"), errors=\"coerce\")\n                df[\"nav\"] = pd.to_numeric(df.get(\"nav\"), errors=\"coerce\")\n                df[\"cash\"] = pd.to_numeric(df.get(\"cash\"), errors=\"coerce\")\n                df = df.dropna(subset=[\"equity\"]).copy()\n                if len(df) > 0:\n                    return df\n        except Exception:\n            pass\n\n    nav_history = (state or {}).get(\"nav_history\", []) if isinstance(state, dict) else []\n    if nav_history:\n        rows = []\n        for item in nav_history:\n            nav = float(item.get(\"nav\", 0) or 0)\n            cash = float(item.get(\"cash\", 0) or 0)\n            rows.append({\n                \"ts\": str(item.get(\"date\", \"-\")),\n                \"date\": str(item.get(\"date\", \"-\")),\n                \"equity\": round(nav * INITIAL_CASH, 2),\n                \"nav\": nav,\n                \"cash\": cash,\n            })\n        return pd.DataFrame(rows)\n    return None\n\n\ndef get_realtime_prices(symbols):\n    prices = {}\n    try:\n        from run_live_execution_v1 import fetch_realtime_quote\n        for sym in symbols:\n            quote = fetch_realtime_quote(sym)\n            if quote and quote.get(\"last\", 0) > 0:\n                prices[sym] = {\n                    \"price\": quote[\"last\"],\n                    \"pct\": quote.get(\"pct\", 0),\n                    \"name\": quote.get(\"name\", \"\"),\n                    \"source\": quote.get(\"source\", \"realtime\"),\n                }\n    except Exception:\n        pass\n    if len(prices) < len(symbols):\n        try:\n            import pandas as pd\n            preds = pd.read_csv(PROJECT_ROOT / \"data\" / \"ml_dataset_full\" / \"ml_predictions.csv\")\n            preds[\"date\"] = pd.to_datetime(preds[\"date\"])\n            latest = preds[preds[\"date\"] == preds[\"date\"].max()]\n            for sym in symbols:\n                if sym in prices:\n                    continue\n                row = latest[latest[\"symbol\"] == sym]\n                if len(row) > 0:\n                    prices[sym] = {\"price\": 1.0, \"pct\": 0.0, \"name\": \"\", \"source\": \"nav\"}\n        except Exception:\n            pass\n    return prices\n\n\ndef load_breadth():\n    try:\n        import run_qlib_breadth_sanity_check as sanity\n        b = sanity.load_market_breadth()\n        latest = b.index.max()\n        return float(b.loc[latest]) if latest in b.index else float(b.iloc[-1])\n    except Exception:\n        return None\n\n\nPROFILE = {\"low_th\": 0.45, \"mid_th\": 0.55, \"low_scale\": 0.40, \"mid_scale\": 0.70, \"high_scale\": 1.00}\nRISK_DEGREE = 0.80\n\n\ndef compute_metrics(state, nav_df, summary=None):\n    \"\"\"计算模拟盘口径绩效指标\"\"\"\n    holdings = state.get(\"holdings\", {})\n    nav_history = state.get(\"nav_history\", [])\n    cash = float(state.get(\"cash\", INITIAL_CASH) or 0)\n    total_value = cash + sum(float(h.get(\"current_value\", 0) or 0) for h in holdings.values())\n\n    nav = total_value / INITIAL_CASH if INITIAL_CASH > 0 else 1.0\n    total_return = (nav - 1.0) * 100\n\n    # 年化：优先按模拟盘自己的历史区间算；如果区间过短，直接回退为累计收益率\n    annual_return = total_return\n    if nav_df is not None and len(nav_df) >= 2:\n        try:\n            ts_series = nav_df[\"ts\"] if \"ts\" in nav_df.columns else None\n            d1 = ts_series.iloc[0] if ts_series is not None else None\n            d2 = ts_series.iloc[-1] if ts_series is not None else None\n            if d1 is not None and d2 is not None and hasattr(d1, 'to_pydatetime'):\n                d1 = d1.to_pydatetime()\n                d2 = d2.to_pydatetime()\n            years = max((d2 - d1).total_seconds() / (365.0 * 24 * 3600), 1 / 365) if d1 is not None and d2 is not None else 0\n            if years > 0:\n                annual_return = ((nav / 1.0) ** (1 / years) - 1) * 100\n        except Exception:\n            annual_return = total_return\n\n    # 最大回撤：严格用模拟盘自己的历史\n    if nav_df is not None and len(nav_df) > 0 and \"nav\" in nav_df.columns:\n        rolling_max = nav_df[\"nav\"].cummax()\n        drawdown = (nav_df[\"nav\"] - rolling_max) / rolling_max * 100\n        max_drawdown = float(drawdown.min())\n        min_idx = drawdown.idxmin()\n        if \"date\" in nav_df.columns:\n            max_dd_date = nav_df.loc[min_idx, \"date\"]\n        else:\n            max_dd_date = str(min_idx)\n    else:\n        max_drawdown = 0.0\n        max_dd_date = None\n\n    breadth_val = load_breadth()\n    position_scale = (PROFILE[\"high_scale\"] if breadth_val and breadth_val >= PROFILE[\"mid_th\"]\n                      else PROFILE[\"mid_scale\"] if breadth_val and breadth_val >= PROFILE[\"low_th\"]\n                      else PROFILE[\"low_scale\"])\n    target_position = RISK_DEGREE * position_scale\n    actual_position_pct = ((total_value - cash) / total_value * 100) if total_value > 0 else 0.0\n\n    summary = summary or {}\n    signal_date = str(summary.get(\"signal_date\") or \"-\")\n    if signal_date == \"-\":\n        if nav_df is not None and len(nav_df) > 0 and \"date\" in nav_df.columns:\n            signal_date = str(nav_df.iloc[-1][\"date\"])\n        elif nav_history:\n            signal_date = str(nav_history[-1].get(\"date\", \"-\"))\n\n    return {\n        \"nav\": nav,\n        \"total_return_pct\": total_return,\n        \"annual_return_pct\": annual_return,\n        \"max_drawdown_pct\": max_drawdown,\n        \"max_dd_date\": str(max_dd_date) if max_dd_date else \"-\",\n        \"cash\": cash,\n        \"market_value\": total_value - cash,\n        \"total_value\": total_value,\n        \"position_count\": len(holdings),\n        \"target_position_pct\": target_position * 100,\n        \"actual_position_pct\": actual_position_pct,\n        \"breadth\": breadth_val,\n        \"position_scale\": position_scale,\n        \"signal_date\": signal_date,\n        \"signal_stale\": bool(summary.get(\"signal_stale\", False)),\n        \"signal_stale_reason\": str(summary.get(\"signal_stale_reason\") or \"\"),\n        \"signal_lag_days\": summary.get(\"signal_lag_days\"),\n        \"feature_latest_date\": str(summary.get(\"feature_latest_date\") or \"-\"),\n        \"prediction_source_file\": str(summary.get(\"prediction_source_file\") or \"\"),\n        \"execution_status\": str(summary.get(\"execution_status\") or \"\"),\n    }\n\n\ndef generate_html(metrics, state, nav_df, prices):\n    holdings = state.get(\"holdings\", {})\n    nav_history = state.get(\"nav_history\", [])\n    b = metrics[\"breadth\"]\n    pos_scale = metrics[\"position_scale\"]\n    b_label = (f\"高宽度(≥{PROFILE['mid_th']})\" if b and b >= PROFILE[\"mid_th\"]\n               else f\"中宽度({PROFILE['low_th']}~{PROFILE['mid_th']})\" if b and b >= PROFILE[\"low_th\"]\n               else f\"低宽度(<{PROFILE['low_th']})\")\n\n    # 资金曲线数据（纯模拟盘口径）\n    nav_payload = []\n    if nav_df is not None and len(nav_df) > 0:\n        for _, row in nav_df.iterrows():\n            label = str(row.get(\"date\") or row.get(\"ts\") or \"-\")\n            if row.get(\"ts\") is not None and hasattr(row.get(\"ts\"), 'strftime'):\n                label = row.get(\"ts\").strftime(\"%Y-%m-%d %H:%M\")\n            nav_payload.append({\n                \"label\": label,\n                \"equity\": round(float(row.get(\"equity\", 0) or 0), 2),\n                \"cash\": round(float(row.get(\"cash\", 0) or 0), 2),\n            })\n\n    holdings_rows = []\n    for sym, info in sorted(holdings.items(), key=lambda x: -x[1].get(\"current_value\", 0)):\n        p = prices.get(sym, {})\n        cur_price = p.get(\"price\", info[\"avg_price\"])\n        pct = p.get(\"pct\", 0)\n        avg = info[\"avg_price\"]\n        float_pnl = info[\"shares\"] * (cur_price - avg)\n        float_pct = (cur_price - avg) / avg * 100 if avg > 0 else 0\n        holdings_rows.append({\n            \"symbol\": sym,\n            \"name\": p.get(\"name\", \"-\"),\n            \"shares\": info[\"shares\"],\n            \"avg_price\": avg,\n            \"cur_price\": cur_price,\n            \"pct\": pct,\n            \"market_value\": info[\"shares\"] * cur_price,\n            \"float_pnl\": float_pnl,\n            \"float_pct\": float_pct,\n            \"buy_date\": info.get(\"buy_date\", \"-\"),\n        })\n\n    total_return = metrics[\"total_return_pct\"]\n    annual_return = metrics[\"annual_return_pct\"]\n    max_dd = metrics[\"max_drawdown_pct\"]\n    stale_banner = \"\"\n    if metrics.get(\"signal_stale\"):\n        stale_banner = (\n            f\"<article class='card span-12 warn'><strong>信号过期告警</strong><br>\"\n            f\"{metrics.get('signal_stale_reason') or '预测信号未刷新'}<br>\"\n            f\"特征最新日期：{metrics.get('feature_latest_date','-')} ｜ 执行状态：{metrics.get('execution_status','-')}<br>\"\n            f\"预测来源：<code>{metrics.get('prediction_source_file') or '-'}</code></article>\"\n        )\n\n    return f\"\"\"<!doctype html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>{PROFILE_NAME}</title>\n  <script src=\"https://cdn.plot.ly/plotly-2.35.2.min.js\"></script>\n  <style>\n    :root {{\n      --bg: #0a1423;\n      --card: rgba(13, 24, 43, 0.88);\n      --line: rgba(133, 167, 214, 0.18);\n      --text: #eef4ff;\n      --muted: #90a4c2;\n      --accent: #6fe3c1;\n      --up: #ff6f6f;\n      --down: #39c885;\n      --warn: #ffb84d;\n    }}\n    * {{ box-sizing: border-box; }}\n    body {{\n      margin: 0; color: var(--text);\n      font-family: \"SF Pro Display\", \"PingFang SC\", \"Noto Sans SC\", sans-serif;\n      background:\n        radial-gradient(circle at 16% 18%, rgba(99, 179, 255, 0.14), transparent 24%),\n        radial-gradient(circle at 82% 12%, rgba(255, 184, 77, 0.10), transparent 22%),\n        linear-gradient(180deg, #07101d, var(--bg) 100%);\n    }}\n    .wrap {{ max-width: 1400px; margin: 0 auto; padding: 28px 20px 60px; }}\n    .hero {{ display: flex; justify-content: space-between; gap: 16px; align-items: flex-end; margin-bottom: 22px; }}\n    .hero h1 {{ margin: 0; font-size: 34px; color: var(--accent); }}\n    .sub {{ color: var(--muted); font-size: 14px; margin-top: 6px; }}\n    .mono {{ color: var(--muted); font-size: 12px; font-family: ui-monospace, \"SFMono-Regular\", Menlo, monospace; }}\n    .grid {{ display: grid; grid-template-columns: repeat(12, 1fr); gap: 16px; margin-bottom: 16px; }}\n    .card {{\n      background: var(--card); border: 1px solid var(--line);\n      border-radius: 18px; padding: 18px;\n      backdrop-filter: blur(10px); box-shadow: 0 18px 60px rgba(0,0,0,0.22);\n    }}\n    .span-3 {{ grid-column: span 3; }}\n    .span-4 {{ grid-column: span 4; }}\n    .span-6 {{ grid-column: span 6; }}\n    .span-8 {{ grid-column: span 8; }}\n    .span-12 {{ grid-column: span 12; }}\n    h3 {{ margin: 0 0 12px; font-size: 17px; }}\n    table {{ width: 100%; border-collapse: collapse; }}\n    th, td {{ padding: 10px 8px; border-bottom: 1px solid var(--line); text-align: left; font-size: 13px; }}\n    th {{ color: var(--muted); font-weight: 600; }}\n    .kpi-value {{ font-size: 28px; font-weight: 700; letter-spacing: -0.5px; }}\n    .kpi-label {{ font-size: 12px; color: var(--muted); margin-top: 4px; }}\n    .pos {{ color: #ff6f6f; }}\n    .neg {{ color: #39c885; }}\n    .warn {{ color: var(--warn); }}\n    .badge {{\n      display: inline-block; padding: 3px 8px; border-radius: 6px;\n      font-size: 11px; font-weight: 600;\n    }}\n    .badge-high {{ background: rgba(111,227,193,0.15); color: var(--accent); }}\n    .badge-mid  {{ background: rgba(255,184,77,0.15); color: var(--warn); }}\n    .badge-low  {{ background: rgba(255,154,139,0.15); color: #ff9a8b; }}\n    .table-wrap {{ max-height: 420px; overflow: auto; }}\n    .param-tag {{ display: inline-block; padding: 2px 8px; background: rgba(255,255,255,0.05); border-radius: 6px; margin: 2px; font-size: 12px; }}\n    @media (max-width: 1100px) {{\n      .span-3,.span-4,.span-6,.span-8,.span-12 {{ grid-column: span 12; }}\n      .hero {{ flex-direction: column; align-items: flex-start; }}\n    }}\n  </style>\n</head>\n<body>\n<div class=\"wrap\">\n  <section class=\"hero\">\n    <div>\n      <h1>{PROFILE_NAME}</h1>\n      <div class=\"sub\">\n        独立盘口径（非 <code>paper_aggressive</code> 纸盘）｜ 100万初始资金 ｜ 信号日期: {metrics['signal_date']} ｜ 市场宽度: {f'{b:.4f}' if b else '-'} ｜ {b_label} ｜ updated: {NOW_STR}\n      </div>\n    </div>\n    <div class=\"mono\">\n      topk=8, rd=0.80, cap=0.28 | low=0.40/mid=0.70/high=1.00<br>\n      纯模拟盘口径：曲线 / 资金 / 持仓统一来自当前模拟盘状态\n    </div>\n  </section>\n\n  <section class=\"grid\">\n    {stale_banner}\n    <article class=\"card span-3\">\n      <div class=\"kpi-label\">模拟资金</div>\n      <div class=\"kpi-value {'pos' if total_return >= 0 else 'neg'}\">{metrics['total_value']:,.0f}</div>\n      <div class=\"kpi-label\">初始 1,000,000</div>\n    </article>\n    <article class=\"card span-3\">\n      <div class=\"kpi-label\">累计收益率</div>\n      <div class=\"kpi-value {'pos' if total_return >= 0 else 'neg'}\">{total_return:+.2f}%</div>\n      <div class=\"kpi-label\">年化 {annual_return:+.2f}%</div>\n    </article>\n    <article class=\"card span-3\">\n      <div class=\"kpi-label\">最大回撤</div>\n      <div class=\"kpi-value neg\">{max_dd:.2f}%</div>\n      <div class=\"kpi-label\">回撤区间: {metrics['max_dd_date']}</div>\n    </article>\n    <article class=\"card span-3\">\n      <div class=\"kpi-label\">目标仓位</div>\n      <div class=\"kpi-value {'warn' if metrics['target_position_pct'] < 60 else 'pos'}\">{metrics['target_position_pct']:.0f}%</div>\n      <div class=\"kpi-label\">rd={RISK_DEGREE} × 宽度{pos_scale:.2f}</div>\n    </article>\n\n    <article class=\"card span-4\">\n      <div class=\"kpi-label\">总资产</div>\n      <div class=\"kpi-value\">{metrics['total_value']:,.0f}</div>\n      <div class=\"kpi-label\">元</div>\n    </article>\n    <article class=\"card span-4\">\n      <div class=\"kpi-label\">可用现金</div>\n      <div class=\"kpi-value\">{metrics['cash']:,.0f}</div>\n      <div class=\"kpi-label\">元</div>\n    </article>\n    <article class=\"card span-4\">\n      <div class=\"kpi-label\">持仓市值</div>\n      <div class=\"kpi-value\">{metrics['market_value']:,.0f}</div>\n      <div class=\"kpi-label\">{metrics['position_count']}只股票</div>\n    </article>\n\n    <article class=\"card span-8\">\n      <h3>资金曲线（100万基准）</h3>\n      <div id=\"navCurve\" style=\"height: 340px;\"></div>\n    </article>\n\n    <article class=\"card span-4\">\n      <h3>策略参数</h3>\n      <table>\n        <tbody>\n          <tr><th>参数</th><th>值</th></tr>\n          <tr><td>topk</td><td>8</td></tr>\n          <tr><td>risk_degree</td><td>0.80</td></tr>\n          <tr><td>turnover_cap</td><td>0.28</td></tr>\n          <tr><td>low_scale</td><td>{PROFILE['low_scale']}</td></tr>\n          <tr><td>mid_scale</td><td>{PROFILE['mid_scale']}</td></tr>\n          <tr><td>high_scale</td><td>{PROFILE['high_scale']}</td></tr>\n          <tr><td>low_th</td><td>{PROFILE['low_th']}</td></tr>\n          <tr><td>mid_th</td><td>{PROFILE['mid_th']}</td></tr>\n          <tr><td>市场宽度</td><td>{f'{b:.4f}' if b else '-'}</td></tr>\n          <tr><td>宽度区间</td><td>{b_label}</td></tr>\n          <tr><td>目标仓位</td><td>{metrics['target_position_pct']:.0f}%</td></tr>\n          <tr><td>实际仓位</td><td>{metrics['actual_position_pct']:.2f}%</td></tr>\n        </tbody>\n      </table>\n    </article>\n\n    <article class=\"card span-12\">\n      <h3>持仓明细（{len(holdings)}只）</h3>\n      <div class=\"table-wrap\">\n        <table>\n          <thead>\n            <tr><th>代码</th><th>名称</th><th>买入日期</th><th>持股数</th><th>成本价</th><th>现价</th><th>现价涨跌</th><th>持仓市值</th><th>持仓收益</th><th>持仓收益率</th></tr>\n          </thead>\n          <tbody>\n            {''.join([\n              f'<tr>'\n              f'<td>{h[\"symbol\"]}</td>'\n              f'<td>{h[\"name\"] or \"-\"}</td>'\n              f'<td>{h[\"buy_date\"]}</td>'\n              f'<td>{h[\"shares\"]:,}</td>'\n              f'<td>{h[\"avg_price\"]:.2f}</td>'\n              f'<td>{h[\"cur_price\"]:.2f}</td>'\n              f'<td class=\"{'pos' if h[\"pct\"] >= 0 else 'neg'}\">{h[\"pct\"]:+.2f}%</td>'\n              f'<td>{h[\"market_value\"]:,.0f}</td>'\n              f'<td class=\"{'pos' if h[\"float_pnl\"] >= 0 else 'neg'}\">{h[\"float_pnl\"]:+,.0f}</td>'\n              f'<td class=\"{'pos' if h[\"float_pct\"] >= 0 else 'neg'}\">{h[\"float_pct\"]:+.2f}%</td>'\n              f'</tr>'\n              for h in holdings_rows\n            ]) if holdings_rows else '<tr><td colspan=\"10\">空仓</td></tr>'}\n          </tbody>\n        </table>\n      </div>\n    </article>\n\n    <article class=\"card span-12\">\n      <h3>资金历史（纯模拟盘）</h3>\n      <table>\n        <thead><tr><th>记录时间</th><th>信号日期</th><th>资金</th><th>现金</th></tr></thead>\n        <tbody>\n          {''.join([\n            f'<tr><td>{(str(h.get(\"generated_at\", h.get(\"date\", \"-\"))).split(\"#\")[0])}</td><td>{h.get(\"date\", \"-\")}</td><td class=\"{'pos' if float(h.get(\"nav\", 0)) >= 1 else 'neg'}\">{float(h.get(\"total_value\", float(h.get(\"nav\", 0)) * INITIAL_CASH)):,.0f}</td><td>{float(h.get(\"cash\", 0)):,.0f}</td></tr>'\n            for h in (nav_df.to_dict(\"records\") if nav_df is not None and len(nav_df) > 0 else nav_history)\n          ])}\n        </tbody>\n      </table>\n    </article>\n  </section>\n</div>\n\n<script>\n  const navData = {json.dumps(nav_payload)};\n  if (navData.length > 0) {{\n    const trace = {{\n      x: navData.map(d => d.label),\n      y: navData.map(d => d.equity),\n      mode: 'lines',\n      line: {{ color: '#6fe3c1', width: 2 }},\n      name: '资金',\n      hovertemplate: '%{{x}}<br>资金: %{{y:,.0f}}<extra></extra>',\n    }};\n    const layout = {{\n      paper_bgcolor: 'transparent',\n      plot_bgcolor: 'transparent',\n      font: {{ color: '#eef4ff', family: 'PingFang SC' }},\n      xaxis: {{ gridcolor: 'rgba(133,167,214,0.12)', zerolinecolor: 'rgba(133,167,214,0.18)' }},\n      yaxis: {{ gridcolor: 'rgba(133,167,214,0.12)', zerolinecolor: 'rgba(133,167,214,0.18)' }},\n      margin: {{ l: 60, r: 20, t: 20, b: 40 }},\n      showlegend: false,\n    }};\n    Plotly.newPlot('navCurve', [trace], layout, {{responsive: true}});\n  }}\n</script>\n</body>\n</html>\"\"\"\n\n\ndef main():\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--output\", default=None)\n    args = parser.parse_args()\n\n    state = load_state()\n    summary = load_latest_summary()\n    nav_df = load_nav_curve(state)\n    holdings = state.get(\"holdings\", {})\n    symbols = list(holdings.keys())\n    prices = get_realtime_prices(symbols)\n    metrics = compute_metrics(state, nav_df, summary)\n    html = generate_html(metrics, state, nav_df, prices)\n\n    output = args.output or str(REPORT_DIR / f\"breadth_aggressive_dashboard_{TODAY_STR}.html\")\n    latest = REPORT_DIR / \"breadth_aggressive_dashboard_latest.html\"\n    with open(output, \"w\", encoding=\"utf-8\") as f:\n        f.write(html)\n    with open(latest, \"w\", encoding=\"utf-8\") as f:\n        f.write(html)\n    print(f\"面板已生成: {output}\")\n    print(f\"最新面板: {latest}\")\n    return output, latest\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774492769911}}
{"type":"message","id":"5ef625b8","parentId":"426d2e05","timestamp":"2026-03-26T02:40:13.394Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Looking at this, I can see that:\n\n1. The `run_breadth_paper_trading.py` already has signal expiration detection with `MAX_SIGNAL_LAG_DAYS = 2` and sets `is_stale=True` when lag > 2 days.\n2. The dashboard already has a `signal_stale` banner that shows when `metrics.get(\"signal_stale\")` is True.\n3. The summary JSON already has `signal_stale` and `signal_stale_reason` fields.\n\nBUT - the problem is the `load_feature_latest_date()` function. Let me check what it returns. The issue from the ACTIVE_TASK says that `ml_predictions.csv` max(date)=2026-03-03, but also the features file... Let me think about what could be going wrong.\n \nNow I'm realizing the real issue might be a chicken-and-egg problem: if the features file itself hasn't been updated since 2026-03-03, then `load_feature_latest_date()` would return 2026-03-03, making the signal appear fresh even though it's actually stale. The calculation would show zero lag days when there should be a much larger gap. the signal wouldn't be flagged as stale even though it's actually outdated. I see the real problem now—the breadth aggressive reports from March 24th and 25th show empty buy and sell lists with a signal date of March 3rd, which suggests the signal freshness check might be working, but the underlying issue is that the features file itself hasn't been updated since March 3rd, making the entire pipeline stale. the signal freshness check isn't triggering properly—either the feature file is also stale as of 2026-03-03, or there's a date parsing issue causing the lag calculation to fail. I need to verify what's actually in the feature file and confirm whether the stale detection logic is correctly comparing the signal date against the feature latest date. The script does generate reports and JSON files for each day, but they're showing empty signal lists even though the signal date is stuck at 03-03. This suggests the stale detection might not be working as expected—the script runs daily but either the feature file is also from 03-03, or there's a bug in how `load_feature_latest_date()` determines staleness that I need to investigate by checking what the feature file actually contains. Looking at the dashboard's staleness logic, it pulls `signal_stale` directly from the summary JSON, so if that flag isn't being set correctly in the trading script's output, the warning won't display. I should verify whether the feature file is actually being read as stale or if there's a mismatch between what the trading script produces and what the dashboard expects.\n\nThe real issue is that even if the signal date matches the feature date (both 2026-03-03), the system should still flag this as stale if it's now 2026-03-26 — the data is 23 days old. The breadth trading script compares signal date against feature date, but that's not the right comparison; it should be comparing against the current date to detect true staleness.\n\nLooking at the trading script, when the signal is stale it sets `execution_status` to \"signal_stale_hold\" and only refreshes the holdings snapshot without executing any trades. The problem is the script doesn't surface a clear warning that trading has halted due to stale data, so users don't realize the system is running in a degraded state.\n\nThe stale banner does appear in the dashboard HTML when `metrics.get(\"signal_stale\")` is true, pulling the reason from the summary. But if the feature and signal dates are both 2026-03-03 (the maximum in the files), the staleness detection might not trigger at all, meaning the banner never shows and there's no indication that trading has stopped.\n\nI need to fix the logic so staleness is determined by comparing the signal date against the current date instead of against the feature date. This way, even if features and signals are aligned, a 23-day-old signal will still be flagged as stale and halt trading. I'll also make sure the warning is prominent enough in both the terminal output and the generated reports so users understand why trading has stopped. the signal date against the current date instead of the feature date, so staleness is based on how old the signal actually is regardless of feature freshness. Then I'll expose a refresh mechanism for live predictions and update the summary JSON to include the current date for reference. I'm realizing the core issue is comparing the signal date against the current date rather than against the feature date—if signals are from 03-03 but the market is already at 03-26, that's a clear staleness problem regardless of feature alignment. The fix should check the actual age of the signals in days and flag anything beyond the threshold as stale, then run through validation before finalizing the changes. The real issue is that when signals and features are both stale, the system incorrectly treats them as synchronized and doesn't flag the problem. I need to compare the signal date against the current date instead—if the signal is more than a couple days old, it should be marked stale regardless of feature freshness. This way, 03-03 signals would correctly trigger a staleness warning even if features are also at 03-03.\n\nBeyond fixing the detection logic, the dashboard also needs clearer communication about what's happening: the banner should be more prominent, the report should clearly state trading is paused, and I should add an option to fetch fresh live predictions when signals become stale.\n\nFor now though, I'll focus on three concrete improvements: updating the staleness check to use current date rather than feature date as the reference, surfacing the refresh trigger more visibly in both the script output and dashboard, and making sure the summary JSON properly reflects the stale state so external monitoring can catch it. Let me start implementing these changes.","thinkingSignature":"c03a0ddec977d6643caec0e827a8dd2abf2ee8546cf96778ba8bd359b22310d3"},{"type":"toolCall","id":"call_function_tcx8q6mlfcfc_1","name":"exec","arguments":{"command":"python3 -c \"\nimport pandas as pd\nfrom datetime import datetime\n\n# Check feature file\nfeat_path = '/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/data/ml_dataset_full/ml_features_full.csv'\ntry:\n    for chunk in pd.read_csv(feat_path, usecols=['date'], chunksize=500000):\n        dates = pd.to_datetime(chunk['date'], errors='coerce').dropna()\n        if len(dates) > 0:\n            print('Feature max date:', dates.max().date())\n            break\nexcept Exception as e:\n    print('Feature error:', e)\n\n# Check prediction file\npred_path = '/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/data/ml_dataset_full/ml_predictions.csv'\ntry:\n    preds = pd.read_csv(pred_path, usecols=['date'])\n    preds['date'] = pd.to_datetime(preds['date'], errors='coerce')\n    print('Prediction max date:', preds['date'].max().date())\nexcept Exception as e:\n    print('Prediction error:', e)\n\n# Current date\nprint('Current date:', datetime.now().date())\n\n# Check if live predictions exist\nimport os\nlive = '/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/data/ml_dataset_full/ml_predictions_live_latest.csv'\nprint('Live predictions exist:', os.path.exists(live))\n\"\n","timeout":30}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":40938,"output":1534,"cacheRead":22075,"cacheWrite":0,"totalTokens":64547,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774492769922,"responseId":"0613cf622a0246ef1641aa5adeaffc0f"}}
