{"type":"message","id":"a2c735e0","parentId":"ca3d4d5f","timestamp":"2026-03-03T16:02:49.527Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"数据已经下载完成了！现在让我进行回测，使用2021-2024年的数据，包含Alpha、Beta等指标。","thinkingSignature":"4c6c88543ceeb8d242d514e2df5796ee839a99e89f4539fcf8f95f4f0efba95c"},{"type":"text","text":"数据已下载完成！现在进行完整回测：\n"},{"type":"toolCall","id":"call_function_n4cudab0g7zm_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && source .venv/bin/activate && python -c \"\nimport pandas as pd\nimport numpy as np\n\nprint('='*60)\nprint('2年完整回测 + Alpha/Beta计算')\nprint('='*60)\n\n# 合并数据\ndfs = []\nfor year in [2024, 2023, 2022, 2021]:\n    try:\n        df = pd.read_csv(f'data/daily_{year}.csv')\n        dfs.append(df)\n    except:\n        pass\n\ndaily = pd.concat(dfs, ignore_index=True)\nbasic = pd.read_csv('data/stock_basic.csv')\ndates = sorted(daily['trade_date'].unique())\nprint(f'数据: {len(dates)}天, {daily.ts_code.nunique()}只股票')\n\n# 基准: 中证1000\nbenchmark = pd.read_csv('data/index_000852_SH.csv')\nbenchmark['date'] = pd.to_datetime(benchmark['trade_date'], format='%Y%m%d')\nbenchmark = benchmark.sort_values('date')\n\n# 策略: 行业动量+小市值\nmonths = sorted(set(d // 100 for d in dates))\nstrategy_rets = []\nbenchmark_rets = []\n\nfor m in months[1:]:\n    md = [d for d in dates if d // 100 == m]\n    if not md: continue\n    td = md[0]\n    prev_m = months[months.index(m)-1]\n    pmd = [d for d in dates if d // 100 == prev_m]\n    if not pmd: continue\n    pd_date = pmd[0]\n    \n    # 策略\n    industry_ret = {}\n    for ind in basic['industry'].unique()[:30]:\n        stocks = basic[basic['industry']==ind]['ts_code'].tolist()\n        if len(stocks) < 3: continue\n        ind_df = daily[(daily['ts_code'].isin(stocks)) & (daily['trade_date'].isin([pd_date, td]))]\n        if len(ind_df) >= 4:\n            start = ind_df.groupby('ts_code')['close'].first()\n            end = ind_df.groupby('ts_code')['close'].last()\n            r = (end / start - 1).mean()\n            if not np.isnan(r):\n                industry_ret[ind] = r\n    \n    if not industry_ret: continue\n    best_ind = max(industry_ret, key=industry_ret.get)\n    ind_stocks = basic[basic['industry']==best_ind]['ts_code'].tolist()\n    mv = daily[(daily['ts_code'].isin(ind_stocks)) & (daily['trade_date']==td)]\n    if len(mv) > 0:\n        mv = mv.nsmallest(5, 'circ_mv')\n        ni = months.index(m) + 1\n        if ni < len(months):\n            nd = [d for d in dates if d // 100 == months[ni]]\n            if nd:\n                ed = nd[-1]\n                rs = []\n                for c in mv['ts_code']:\n                    s = daily[(daily['ts_code']==c) & (daily['trade_date']==td)]\n                    e = daily[(daily['ts_code']==c) & (daily['trade_date']==ed)]\n                    if len(s)>0 and len(e)>0:\n                        rs.append((e['close'].values[0]-s['close'].values[0])/s['close'].values[0])\n                if rs:\n                    strategy_rets.append(np.mean(rs))\n    \n    # 基准\n    bm = benchmark[(benchmark['date'].dt.year == (m//10000)) & (benchmark['date'].dt.month == (m%10000)//100)]\n    if len(bm) >= 2:\n        br = (bm['close'].iloc[-1] / bm['close'].iloc[0] - 1)\n        benchmark_rets.append(br)\n\nif strategy_rets:\n    # 策略指标\n    s_total = np.prod([1+r for r in strategy_rets]) - 1\n    s_annual = (1+s_total)**(12/len(strategy_rets)) - 1\n    s_vol = np.std(strategy_rets) * np.sqrt(12)\n    s_sharpe = (s_annual - 0.04) / s_vol if s_vol > 0 else 0\n    \n    # 基准指标\n    b_total = np.prod([1+r for r in benchmark_rets]) - 1\n    b_annual = (1+b_total)**(12/len(benchmark_rets)) - 1\n    b_vol = np.std(benchmark_rets) * np.sqrt(12)\n    \n    # Beta\n    if len(strategy_rets) == len(benchmark_rets) and np.var(benchmark_rets) > 0:\n        cov = np.cov(strategy_rets, benchmark_rets)[0,1]\n        beta = cov / np.var(benchmark_rets)\n    else:\n        beta = 1.0\n    \n    # Alpha\n    alpha = s_annual - (0.04 + beta * (b_annual - 0.04))\n    \n    # 超额收益\n    excess = s_annual - b_annual\n    \n    # 最大回撤\n    cum = np.cumprod([1+r for r in strategy_rets])\n    peak = np.maximum.accumulate(cum)\n    max_dd = ((cum - peak) / peak).min()\n    \n    print(f'''\n【策略绩效】\n  调仓次数: {len(strategy_rets)}\n  总收益: {s_total*100:+.1f}%\n  年化收益: {s_annual*100:+.1f}%\n  波动率: {s_vol*100:.1f}%\n  夏普比率: {s_sharpe:.2f}\n  最大回撤: {max_dd*100:.1f}%\n\n【基准绩效】\n  年化收益: {b_annual*100:+.1f}%\n\n【风险指标】\n  Alpha: {alpha*100:+.2f}%\n  Beta: {beta:.3f}\n  超额收益: {:+.2fexcess*100}%\n    ''')\n\"","timeout":120}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":151900,"output":1397,"cacheRead":18417,"cacheWrite":0,"totalTokens":171714,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772553744074}}
