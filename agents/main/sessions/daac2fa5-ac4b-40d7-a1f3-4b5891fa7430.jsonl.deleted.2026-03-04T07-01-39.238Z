{"type":"message","id":"ad7adfca","parentId":"0b6446cb","timestamp":"2026-03-03T07:40:28.631Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I have some index data. Let me build a Backtrader-based backtesting framework.","thinkingSignature":"c47c92fe837a8a555d31900b351719bf8ec9c3594f957e036cb5390a5412b3fd"},{"type":"toolCall","id":"call_function_bptlhfjo85ch_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n三策略组合回测框架\n基于Backtrader - ETF轮动 + 小市值 + 白马策略\n\"\"\"\nimport os\nimport backtrader as bt\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\n\n# 数据目录\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'data')\n\nclass MultiStrategy(bt.Strategy):\n    \"\"\"三策略组合\"\"\"\n    \n    # 策略配置\n    params = (\n        ('etf_allocation', 0.4),\n        ('small_cap_allocation', 0.35),\n        ('white_horse_allocation', 0.25),\n    )\n    \n    def __init__(self):\n        # 持仓\n        self.etf_holdings = []\n        self.small_cap_holdings = []\n        self.white_horse_holdings = []\n        \n        # 今日信号\n        self.order_list = []\n        \n    def log(self, txt, dt=None):\n        dt = dt or self.datas[0].datetime.date(0)\n        print(f'{dt.isoformat()} {txt}')\n    \n    def notify_order(self, order):\n        if order.status in [order.Submitted, order.Accepted]:\n            return\n        \n        if order.status in [order.Completed]:\n            if order.isbuy():\n                self.log(f'买入: {order.data._name}, 价格: {order.executed.price:.2f}, 数量: {order.executed.size}')\n            else:\n                self.log(f'卖出: {order.data._name}, 价格: {order.executed.price:.2f}, 数量: {order.executed.size}')\n        \n        self.order_list.remove(order)\n    \n    def next(self):\n        # 每日检查仓位\n        pass\n\nclass ETF MomentumStrategy(bt.Strategy):\n    \"\"\"ETF轮动策略\"\"\"\n    \n    params = (\n        ('etf_pool', ['000300.SH', '000905.SH', '000852.SH']),\n        ('lookback', 20),\n    )\n    \n    def __init__(self):\n        self.etf_data = {}\n        \n        # 预加载ETF数据\n        for etf in self.params.etf_pool:\n            fname = f'data/index_{etf.replace(\".\", \"_\")}.csv'\n            if os.path.exists(fname):\n                df = pd.read_csv(fname)\n                df['date'] = pd.to_datetime(df['trade_date'], format='%Y%m%d')\n                df = df.set_index('date').sort_index()\n                self.etf_data[etf] = df\n    \n    def next(self):\n        if len(self) < self.params.lookback:\n            return\n        \n        current_date = self.datas[0].datetime.date(0)\n        \n        # 计算动量\n        scores = {}\n        for etf, df in self.etf_data.items():\n            if len(df) < self.params.lookback:\n                continue\n            \n            # 获取历史数据\n            try:\n                hist = df[df.index < current_date].tail(self.params.lookback)\n                if len(hist) >= self.params.lookback:\n                    ret = (hist['close'].iloc[-1] / hist['close'].iloc[0]) - 1\n                    scores[etf] = ret\n            except:\n                continue\n        \n        if not scores:\n            return\n        \n        # 选择最强动量\n        best_etf = max(scores, key=scores.get)\n        self.log(f'动量评分: {scores}')\n        \n        # 调仓逻辑...\n\nclass SmallCapStrategy(bt.Strategy):\n    \"\"\"小市值策略\"\"\"\n    \n    params = (\n        ('stock_num', 6),\n        ('lookback', 20),\n    )\n    \n    def __init__(self):\n        # 加载小市值数据\n        basic_file = f'{DATA_DIR}/stock_basic.csv'\n        daily_file = f'{DATA_DIR}/daily_basic_all.csv'\n        \n        if os.path.exists(basic_file) and os.path.exists(daily_file):\n            self.basic = pd.read_csv(basic_file)\n            self.daily = pd.read_csv(daily_file)\n        else:\n            self.basic = None\n            self.daily = None\n    \n    def next(self):\n        if self.basic is None or self.daily is None:\n            return\n        \n        current_date = str(self.datas[0].datetime.date(0)).replace('-', '')\n        \n        # 获取当日小市值股票\n        df = self.daily[self.daily['trade_date'] == int(current_date)]\n        if len(df) == 0:\n            return\n        \n        df = df.copy()\n        df['circ_mv_yi'] = df['circ_mv'] / 10000\n        \n        # 筛选10-50亿\n        df = df[(df['circ_mv_yi'] >= 10) & (df['circ_mv_yi'] <= 50)]\n        df = df[df['pe'] > 0]\n        \n        # 取最小市值\n        df = df.nsmallest(self.params.stock_num * 2, 'circ_mv_yi')\n        \n        # 行业分散\n        df = df.merge(self.basic[['ts_code', 'name', 'industry']], on='ts_code', how='left')\n        df = df.groupby('industry').head(2)\n        \n        if len(df) > 0:\n            self.log(f'小市值候选: {len(df)} 只')\n\n\nclass BacktestRunner:\n    \"\"\"回测运行器\"\"\"\n    \n    def __init__(self, initial_cash=1000000):\n        self.cerebro = bt.Cerebro()\n        self.cerebro.broker.setcash(initial_cash)\n        \n        # 设置交易成本\n        self.cerebro.broker.setcommission(commission=0.001)  # 万十\n        self.cerebro.broker.set_slippage_perc(0.001)  # 万十滑点\n        \n    def add_data(self, name, data):\n        \"\"\"添加数据\"\"\"\n        self.cerebro.adddata(data, name=name)\n    \n    def add_strategy(self, strategy, **kwargs):\n        \"\"\"添加策略\"\"\"\n        self.cerebro.addstrategy(strategy, **kwargs)\n    \n    def run(self):\n        \"\"\"运行回测\"\"\"\n        print(f'初始资金: {self.cerebro.broker.getvalue():,.2f}')\n        \n        self.results = self.cerebro.run()\n        \n        final_value = self.cerebro.broker.getvalue()\n        print(f'最终资金: {final_value:,.2f}')\n        print(f'收益率: {(final_value / 1000000 - 1) * 100:.2f}%')\n        \n        return self.results\n    \n    def get_stats(self):\n        \"\"\"获取统计指标\"\"\"\n        return self.cerebro.stats\n\n\ndef load_index_data(code, start_date='2020-01-01'):\n    \"\"\"加载指数数据\"\"\"\n    fname = f'{DATA_DIR}/index_{code.replace(\".\", \"_\")}.csv'\n    \n    if not os.path.exists(fname):\n        print(f'数据文件不存在: {fname}')\n        return None\n    \n    df = pd.read_csv(fname)\n    df['date'] = pd.to_datetime(df['trade_date'], format='%Y%m%d')\n    df = df.set_index('date')\n    df = df.sort_index()\n    df = df[df.index >= start_date]\n    \n    # 重命名列\n    df = df.rename(columns={'open': 'Open', 'high': 'High', 'low': 'Low', 'close': 'Close', 'vol': 'Volume'})\n    \n    return df\n\n\ndef run_simple_backtest():\n    \"\"\"运行简化版回测\"\"\"\n    print(\"=\" * 60)\n    print(\"三策略组合回测\")\n    print(\"=\" * 60)\n    \n    # 加载数据\n    indices = {\n        '000300.SH': '沪深300',\n        '000905.SH': '中证500', \n        '000852.SH': '中证1000',\n    }\n    \n    # 由于Backtrader需要实时数据，我们用简化的方式计算\n    # 直接用指数数据计算轮动策略收益\n    \n    results = {}\n    for code, name in indices.items():\n        df = load_index_data(code)\n        if df is not None:\n            # 计算20日动量\n            df['momentum'] = df['close'].pct_change(20)\n            results[name] = df\n    \n    if not results:\n        print(\"没有数据\")\n        return\n    \n    # 模拟ETF轮动策略\n    dates = sorted(set(results['沪深300'].index) & set(results['中证500'].index) & set(results['中证1000'].index))\n    print(f\"回测区间: {dates[0]} ~ {dates[-1]}\")\n    print(f\"交易日数: {len(dates)}\")\n    \n    # 按月计算\n    monthly_returns = []\n    for i in range(20, len(dates), 20):  # 每20天调仓\n        current_date = dates[i]\n        \n        # 计算各指数动量\n        momentum = {}\n        for name, df in results.items():\n            if current_date in df.index:\n                mom = df.loc[current_date, 'momentum']\n                if not np.isnan(mom):\n                    momentum[name] = mom\n        \n        if momentum:\n            # 选择最强动量\n            best = max(momentum, key=momentum.get)\n            \n            # 计算下20天收益\n            if i + 20 < len(dates):\n                next_date = dates[i + 20]\n                \n                for name, df in results.items():\n                    if current_date in df.index and next_date in df.index:\n                        ret = (df.loc[next_date, 'close'] / df.loc[current_date, 'close']) - 1\n                        if name == best:\n                            monthly_returns.append({'date': current_date, 'strategy': name, 'return': ret})\n    \n    if monthly_returns:\n        rets = [r['return'] for r in monthly_returns]\n        total = np.prod([1 + r for r in rets]) - 1\n        annual = (1 + total) ** (len(rets) / 12) - 1\n        \n        print(f\"\\nETF轮动策略结果:\")\n        print(f\"  调仓次数: {len(rets)}\")\n        print(f\"  总收益: {total * 100:.2f}%\")\n        print(f\"  年化收益: {annual * 100:.2f}%\")\n        print(f\"  胜率: {len([r for r in rets if r > 0]) / len(rets) * 100:.1f}%\")\n        \n        # 买入持有对比\n        hs300 = results['沪深300']\n        bh_ret = (hs300['close'].iloc[-1] / hs300['close'].iloc[0]) - 1\n        print(f\"\\n沪深300买入持有: {bh_ret * 100:.2f}%\")\n        print(f\"策略超额: {(total - bh_ret) * 100:.2f}%\")\n\n\nif __name__ == '__main__':\n    run_simple_backtest()\n","file_path":"/Users/ling/.openclaw/workspace/quant_system/backtest_framework.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":85414,"output":2420,"cacheRead":18321,"cacheWrite":0,"totalTokens":106155,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772523574710}}
