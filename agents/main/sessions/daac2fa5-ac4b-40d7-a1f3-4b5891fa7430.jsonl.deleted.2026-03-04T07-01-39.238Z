{"type":"message","id":"a3734f69","parentId":"6ebd845f","timestamp":"2026-03-03T02:02:26.023Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，现在让我创建一个数据获取脚本。","thinkingSignature":"02e794ffcbbff3dbdaf7db5b99ec8061bb7bf4e84168ca3391927de4aea5a8e8"},{"type":"toolCall","id":"call_function_co8bi2msaets_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nA股数据获取脚本\n自动获取股票行情、基本面数据并存档\n\"\"\"\nimport os\nimport sys\nimport pandas as pd\nfrom datetime import datetime, timedelta\n\n# 加载环境变量\nfrom dotenv import load_dotenv\nload_dotenv(os.path.join(os.path.dirname(__file__), 'config/.env.tushare'))\n\nTOKEN = os.getenv('TUSHARE_TOKEN')\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'data')\n\n# 确保数据目录存在\nos.makedirs(DATA_DIR, exist_ok=True)\n\ndef get_pro():\n    \"\"\"初始化tushare pro\"\"\"\n    import tushare as ts\n    pro = ts.pro_api(TOKEN)\n    return pro\n\ndef fetch_stock_basic():\n    \"\"\"获取A股股票基本信息\"\"\"\n    print(\"📥 获取股票基本信息...\")\n    pro = get_pro()\n    \n    # 获取所有A股（包括主板、创业板、科创板）\n    df = pro.stock_basic(exchange='', list_status='L', fields='ts_code,symbol,name,area,industry,list_date,market,exchange')\n    \n    # 过滤掉ST股票和退市股票\n    df = df[~df['name'].str.contains('ST|退', na=False)]\n    \n    output_file = os.path.join(DATA_DIR, f'stock_basic_{datetime.now().strftime(\"%Y%m%d\")}.csv')\n    df.to_csv(output_file, index=False)\n    print(f\"✅ 获取 {len(df)} 只股票基本信息 → {output_file}\")\n    return df\n\ndef fetch_daily_kline(ts_code, start_date=None, end_date=None):\n    \"\"\"获取个股日K线数据\"\"\"\n    pro = get_pro()\n    \n    if end_date is None:\n        end_date = datetime.now().strftime('%Y%m%d')\n    if start_date is None:\n        start_date = (datetime.now() - timedelta(days=365)).strftime('%Y%m%d')\n    \n    df = pro.daily(ts_code=ts_code, start_date=start_date, end_date=end_date)\n    return df\n\ndef fetch_index_daily():\n    \"\"\"获取主要指数行情\"\"\"\n    print(\"📥 获取指数行情...\")\n    pro = get_pro()\n    \n    indices = {\n        '000300.SH': '沪深300',\n        '000905.SH': '中证500',\n        '000852.SH': '中证1000',\n        '000001.SH': '上证指数',\n        '399001.SZ': '深证成指',\n    }\n    \n    for ts_code, name in indices.items():\n        df = pro.index_daily(ts_code=ts_code, start_date='20240101')\n        if df is not None and len(df) > 0:\n            output_file = os.path.join(DATA_DIR, f'index_{ts_code.replace(\".\", \"_\")}_{datetime.now().strftime(\"%Y%m%d\")}.csv')\n            df.to_csv(output_file, index=False)\n            print(f\"  ✅ {name}: {len(df)} 条记录\")\n    \n    print(\"✅ 指数数据获取完成\")\n\ndef fetch_equity_daily():\n    \"\"\"获取所有A股日线行情（增量更新）\"\"\"\n    print(\"📥 获取A股日线行情...\")\n    pro = get_pro()\n    \n    # 读取股票列表\n    basic_file = sorted([f for f in os.listdir(DATA_DIR) if f.startswith('stock_basic_')])[-1]\n    stocks = pd.read_csv(os.path.join(DATA_DIR, basic_file))\n    \n    # 限制数量用于测试\n    sample_stocks = stocks.head(100)  # 先测试100只\n    \n    success = 0\n    failed = 0\n    \n    for _, row in sample_stocks.iterrows():\n        ts_code = row['ts_code']\n        try:\n            df = pro.daily(ts_code=ts_code, start_date='20250101')\n            if df is not None and len(df) > 0:\n                output_file = os.path.join(DATA_DIR, f'daily_{ts_code.replace(\".\", \"_\")}.csv')\n                df.to_csv(output_file, index=False)\n                success += 1\n        except Exception as e:\n            failed += 1\n    \n    print(f\"✅ 日线行情: 成功 {success}, 失败 {failed}\")\n\ndef main():\n    print(\"=\" * 50)\n    print(\"🚀 A股数据获取系统启动\")\n    print(\"=\" * 50)\n    \n    # 1. 获取股票基本信息\n    fetch_stock_basic()\n    \n    # 2. 获取指数数据\n    fetch_index_daily()\n    \n    # 3. 获取日线行情（可选，量大会很慢）\n    # fetch_equity_daily()\n    \n    print(\"=\" * 50)\n    print(\"🎉 数据获取完成!\")\n    print(f\"📁 数据目录: {DATA_DIR}\")\n    print(\"=\" * 50)\n\nif __name__ == '__main__':\n    main()\n","file_path":"/Users/ling/.openclaw/workspace/quant_system/fetch_data.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":5674,"output":1102,"cacheRead":18402,"cacheWrite":0,"totalTokens":25178,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772503323477}}
