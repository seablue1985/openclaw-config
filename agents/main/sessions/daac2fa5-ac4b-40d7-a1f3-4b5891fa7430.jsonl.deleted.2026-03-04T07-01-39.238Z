{"type":"message","id":"75cf4605","parentId":"f792fa6a","timestamp":"2026-03-03T16:04:23.644Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"数据不够。让我简化一下回测逻辑。","thinkingSignature":"f32c1cd17ca63fe605f21c54abb8bf0ee95934cff435dd1bcc1ad4f6e148811d"},{"type":"toolCall","id":"call_function_8f4hvilma71j_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && source .venv/bin/activate && python -c \"\nimport pandas as pd\nimport numpy as np\n\nprint('='*60)\nprint('动量策略优化回测')\nprint('='*60)\n\n# 使用2024年数据\ndaily = pd.read_csv('data/daily_2024.csv')\nbasic = pd.read_csv('data/stock_basic.csv')\ndates = sorted(daily['trade_date'].unique())\nprint(f'数据: {dates[0]} ~ {dates[-1]}')\n\n# 基准\nbenchmark = pd.read_csv('data/index_000852_SH.csv')\nbenchmark['date'] = pd.to_datetime(benchmark['trade_date'], format='%Y%m%d')\nbenchmark = benchmark.sort_values('date')\n\n# 月度\nmonths = sorted(set(d // 100 for d in dates))\nprint(f'月份数: {len(months)}')\n\ns_rets = []\nb_rets = []\n\nfor mi, m in enumerate(months[1:], 1):\n    md = [d for d in dates if d // 100 == m]\n    if len(md) < 3: continue\n    td = md[0]\n    \n    # 策略: 行业动量+小市值\n    prev_m = months[mi-1]\n    pmd = [d for d in dates if d // 100 == prev_m]\n    if len(pmd) < 3: continue\n    pd_date = pmd[-1]\n    \n    # 计算行业涨幅\n    ind_ret = {}\n    for ind in basic['industry'].unique()[:20]:\n        stocks = basic[basic['industry']==ind]['ts_code'].tolist()\n        if len(stocks) < 2: continue\n        ind_df = daily[(daily['ts_code'].isin(stocks)) & (daily['trade_date'].isin([pd_date, td]))]\n        if len(ind_df) >= 2:\n            s = ind_df.groupby('ts_code')['close'].first()\n            e = ind_df.groupby('ts_code')['close'].last()\n            r = (e / s - 1).mean()\n            if not np.isnan(r): ind_ret[ind] = r\n    \n    if not ind_ret: continue\n    \n    # 选最强行业的小市值\n    best = max(ind_ret, key=ind_ret.get)\n    best_stocks = basic[basic['industry']==best]['ts_code'].tolist()\n    mv = daily[(daily['ts_code'].isin(best_stocks)) & (daily['trade_date']==td)]\n    if len(mv) >= 2:\n        mv = mv.nsmallest(3, 'circ_mv')\n        \n        # 下月收益\n        if mi < len(months):\n            nd = [d for d in dates if d // 100 == months[mi]]\n            if nd:\n                ed = nd[-1]\n                rs = []\n                for c in mv['ts_code']:\n                    s = daily[(daily['ts_code']==c) & (daily['trade_date']==td)]\n                    e = daily[(daily['ts_code']==c) & (daily['trade_date']==ed)]\n                    if len(s)>0 and len(e)>0:\n                        rs.append((e['close'].values[0]-s['close'].values[0])/s['close'].values[0])\n                if rs: s_rets.append(np.mean(rs))\n    \n    # 基准\n    try:\n        yr = m // 10000\n        mt = (m % 10000) // 100\n        bm = benchmark[(benchmark['date'].dt.year == yr) & (benchmark['date'].dt.month == mt)]\n        if len(bm) >= 1:\n            b_ret = (bm['close'].iloc[-1] / bm['close'].iloc[0] - 1)\n            b_rets.append(b_ret)\n    except: pass\n\nprint(f'策略次数: {len(s_rets)}, 基准: {len(b_rets)}')\n\nif s_rets and len(s_rets) > 3:\n    s_annual = (np.prod([1+r for r in s_rets])**(12/len(s_rets)) - 1) if len(s_rets) > 0 else 0\n    b_annual = (np.prod([1+r for r in b_rets])**(12/len(b_rets)) - 1) if len(b_rets) > 0 else 0\n    \n    s_vol = np.std(s_rets) * np.sqrt(12) if len(s_rets) > 1 else 0.2\n    s_sharpe = (s_annual - 0.04) / s_vol if s_vol > 0 else 0\n    \n    min_len = min(len(s_rets), len(b_rets))\n    if min_len > 1:\n        beta = np.cov(s_rets[:min_len], b_rets[:min_len])[0,1] / np.var(b_rets[:min_len]) if np.var(b_rets[:min_len]) > 0 else 1.0\n    else: beta = 1.0\n    \n    alpha = s_annual - (0.04 + beta * (b_annual - 0.04))\n    \n    print(f'''\n【策略】行业动量+小市值\n  调仓: {len(s_rets)}次\n  年化: {s_annual*100:+.1f}%\n  夏普: {s_sharpe:.2f}\n\n【基准】中证1000\n  年化: {b_annual*100:+.1f}%\n\n【风险】\n  Alpha: {alpha*100:+.1f}%\n  Beta: {beta:.2f}\n  超额: {(s_annual-b_annual)*100:+.1f}%\n    ''')\n\"","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":156302,"output":1298,"cacheRead":18417,"cacheWrite":0,"totalTokens":176017,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772553833773}}
