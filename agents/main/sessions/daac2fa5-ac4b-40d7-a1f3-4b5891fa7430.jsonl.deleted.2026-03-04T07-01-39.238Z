{"type":"message","id":"cf621a44","parentId":"95ad7081","timestamp":"2026-03-03T15:44:16.420Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户说动量策略回测跑输了中证1000，让我优化。让我重新设计动量策略，可能需要调整参数或者换一种动量计算方式。","thinkingSignature":"fdd073da7c4b2ffe22e84ac239d77a41c5512c6ab23fbf911ea60101d22c88b8"},{"type":"toolCall","id":"call_function_5g4pp35jgf0x_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && source .venv/bin/activate && python -c \"\nimport pandas as pd\nimport numpy as np\n\nDATA_DIR = 'data'\n\n# 加载数据\ndaily = pd.read_csv('data/daily_basic_all.csv')\nbasic = pd.read_csv('data/stock_basic.csv')\n\n# 获取日期\ndates = sorted(daily['trade_date'].unique())\nprint(f'数据范围: {dates[0]} ~ {dates[-1]}')\n\n# 改进的动量策略\n# 策略1: 20日动量\n# 策略2: 60日动量  \n# 策略3: 120日动量\n# 策略4: 动量+反转 (近20日涨太多不追,回调买入)\n\ndef calc_momentum(daily, code, date, days):\n    '''计算动量'''\n    stock_df = daily[(daily['ts_code'] == code) & (daily['trade_date'] < date)]\n    stock_df = stock_df.sort_values('trade_date').tail(days)\n    if len(stock_df) >= days // 2:\n        return (stock_df['close'].iloc[-1] / stock_df['close'].iloc[0] - 1)\n    return None\n\nresults = []\nfor days in [20, 40, 60, 80]:\n    monthly_rets = []\n    months = sorted(set(d // 100 for d in dates[-300:]))  # 最近2年\n    \n    for month in months:\n        md = [d for d in dates[-300:] if d // 100 == month]\n        if not md or len(md) < days//2:\n            continue\n        td = md[0]\n        \n        # 计算动量\n        mom = []\n        for code in daily['ts_code'].unique()[:500]:\n            m = calc_momentum(daily, code, td, days)\n            if m is not None and abs(m) < 2:  # 过滤极端值\n                mv = daily[(daily['ts_code']==code) & (daily['trade_date']==td)]\n                if len(mv) > 0:\n                    mom.append({'code': code, 'mom': m, 'mv': mv['circ_mv'].values[0]})\n        \n        if len(mom) < 10:\n            continue\n        \n        df = pd.DataFrame(mom)\n        df['mv_yi'] = df['mv'] / 10000\n        \n        # 选中等市值 + 正动量\n        df = df[(df['mom'] > 0) & (df['mom'] < 1.0) & (df['mv_yi'] >= 20) & (df['mv_yi'] <= 200)]\n        df = df.nlargest(15, 'mom')\n        \n        if len(df) < 3:\n            continue\n        \n        # 下月收益\n        ni = months.index(month) + 1\n        if ni < len(months):\n            nd = [d for d in dates[-300:] if d // 100 == months[ni]]\n            if nd:\n                ed = nd[-1]\n                rs = []\n                for code in df['code']:\n                    sd = daily[(daily['ts_code']==code) & (daily['trade_date']==td)]\n                    edd = daily[(daily['ts_code']==code) & (daily['trade_date']==ed)]\n                    if len(sd)>0 and len(edd)>0:\n                        r = (edd['close'].values[0]-sd['close'].values[0])/sd['close'].values[0]\n                        rs.append(r)\n                if rs:\n                    monthly_rets.append(np.mean(rs))\n    \n    if monthly_rets:\n        total = np.prod([1+r for r in monthly_rets]) - 1\n        annual = (1+total)**(12/len(monthly_rets)) - 1\n        win = len([r for r in monthly_rets if r>0]) / len(monthly_rets)\n        sharpe = np.mean(monthly_rets)/np.std(monthly_rets)*np.sqrt(12) if np.std(monthly_rets)>0 else 0\n        print(f'{days}日动量 | 年化:{annual*100:6.1f}% | 胜率:{win*100:.0f}% | 夏普:{sharpe:.2f}')\n        results.append({'days': days, 'annual': annual, 'win': win, 'sharpe': sharpe})\n\"","timeout":180}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":36,"output":1039,"cacheRead":153593,"cacheWrite":5408,"totalTokens":160076,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772552625676}}
