d.min() if len(dd) > 0 else 0\n    \n    print(f'''【策略绩效】\n  调仓次数: {len(s_rets)}\n  总收益: {s_total*100:+.1f}%\n  年化收益: {s_annual*100:+.1f}%\n  夏普比率: {s_sharpe:.2f}\n  最大回撤: {max_dd*100:.1f}%\n\n【基准绩效】\n  年化收益: {b_annual*100:+.1f}%\n\n【风险指标】\n  Alpha: {alpha*100:+.2f}%\n  Beta: {beta:.3f}\n  超额收益: {excess*100:+.2f}%\n    ''')\nelse:\n    print('数据不足')\n\"","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":154848,"output":1413,"cacheRead":18417,"cacheWrite":0,"totalTokens":174678,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772553800195}}
