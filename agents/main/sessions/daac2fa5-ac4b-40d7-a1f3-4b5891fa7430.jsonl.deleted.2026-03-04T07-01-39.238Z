{"type":"message","id":"20e4a177","parentId":"b2f4f69a","timestamp":"2026-03-03T07:41:31.925Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Actually I think I need to also fix the other places where I use uppercase column names. Let me rewrite the function more simply.","thinkingSignature":"d71097ac547097cd20abea2fa98838630fa09a93e2b2f452a38c14cd81f126b0"},{"type":"toolCall","id":"call_function_f4g2upweyrx3_1","name":"edit","arguments":{"file_path":"/Users/ling/.openclaw/workspace/quant_system/backtest_framework.py","newText":"def run_simple_backtest():\n    \"\"\"运行简化版回测\"\"\"\n    print(\"=\" * 60)\n    print(\"三策略组合回测\")\n    print(\"=\" * 60)\n    \n    # 加载数据\n    indices = {\n        '000300.SH': '沪深300',\n        '000905.SH': '中证500', \n        '000852.SH': '中证1000',\n    }\n    \n    results = {}\n    for code, name in indices.items():\n        df = load_index_data(code)\n        if df is not None:\n            # 计算20日动量\n            df['momentum'] = df['close'].pct_change(20)\n            results[name] = df\n    \n    if not results:\n        print(\"没有数据\")\n        return\n    \n    # 模拟ETF轮动策略\n    dates = sorted(set(results['沪深300'].index) & set(results['中证500'].index) & set(results['中证1000'].index))\n    print(f\"回测区间: {dates[0]} ~ {dates[-1]}\")\n    print(f\"交易日数: {len(dates)}\")\n    \n    # 按月计算\n    monthly_returns = []\n    for i in range(20, len(dates), 20):  # 每20天调仓\n        current_date = dates[i]\n        \n        # 计算各指数动量\n        momentum = {}\n        for name, df in results.items():\n            if current_date in df.index:\n                mom = df.loc[current_date, 'momentum']\n                if not np.isnan(mom):\n                    momentum[name] = mom\n        \n        if momentum:\n            # 选择最强动量\n            best = max(momentum, key=momentum.get)\n            \n            # 计算下20天收益\n            if i + 20 < len(dates):\n                next_date = dates[i + 20]\n                \n                for name, df in results.items():\n                    if current_date in df.index and next_date in df.index:\n                        ret = (df.loc[next_date, 'close'] / df.loc[current_date, 'close']) - 1\n                        if name == best:\n                            monthly_returns.append({'date': current_date, 'strategy': name, 'return': ret})\n    \n    if monthly_returns:\n        rets = [r['return'] for r in monthly_returns]\n        total = np.prod([1 + r for r in rets]) - 1\n        annual = (1 + total) ** (len(rets) / 12) - 1\n        \n        print(f\"\\nETF轮动策略结果:\")\n        print(f\"  调仓次数: {len(rets)}\")\n        print(f\"  总收益: {total * 100:.2f}%\")\n        print(f\"  年化收益: {annual * 100:.2f}%\")\n        print(f\"  胜率: {len([r for r in rets if r > 0]) / len(rets) * 100:.1f}%\")\n        \n        # 买入持有对比\n        hs300 = results['沪深300']\n        bh_ret = (hs300['close'].iloc[-1] / hs300['close'].iloc[0]) - 1\n        print(f\"\\n沪深300买入持有: {bh_ret * 100:.2f}%\")\n        print(f\"策略超额: {(total - bh_ret) * 100:.2f}%\")","oldText":"def run_simple_backtest():\n    \"\"\"运行简化版回测\"\"\"\n    print(\"=\" * 60)\n    print(\"三策略组合回测\")\n    print(\"=\" * 60)\n    \n    # 加载数据\n    indices = {\n        '000300.SH': '沪深300',\n        '000905.SH': '中证500', \n        '000852.SH': '中证1000',\n    }\n    \n    results = {}\n    for code, name in indices.items():\n        df = load_index_data(code)\n        if df is not None:\n            # 计算20日动量\n            df['momentum'] = df['close'].pct_change(20)\n            results[name] = df\n    \n    if not results:\n        print(\"没有数据\")\n        return\n    \n    # 模拟ETF轮动策略\n    dates = sorted(set(results['沪深300'].index) & set(results['中证500'].index) & set(results['中证1000'].index))\n    print(f\"回测区间: {dates[0]} ~ {dates[-1]}\")\n    print(f\"交易日数: {len(dates)}\")\n    \n    # 按月计算\n    monthly_returns = []\n    for i in range(20, len(dates), 20):  # 每20天调仓\n        current_date = dates[i]\n        \n        # 计算各指数动量\n        momentum = {}\n        for name, df in results.items():\n            if current_date in df.index:\n                mom = df.loc[current_date, 'momentum']\n                if not np.isnan(mom):\n                    momentum[name] = mom\n        \n        if momentum:\n            # 选择最强动量\n            best = max(momentum, key=momentum.get)\n            \n            # 计算下20天收益\n            if i + 20 < len(dates):\n                next_date = dates[i + 20]\n                \n                for name, df in results.items():\n                    if current_date in df.index and next_date in df.index:\n                        ret = (df.loc[next_date, 'close'] / df.loc[current_date, 'close']) - 1\n                        if name == best:\n                            monthly_returns.append({'date': current_date, 'strategy': name, 'return': ret})\n    \n    if monthly_returns:\n        rets = [r['return'] for r in monthly_returns]\n        total = np.prod([1 + r for r in rets]) - 1\n        annual = (1 + total) ** (len(rets) / 12) - 1\n        \n        print(f\"\\nETF轮动策略结果:\")\n        print(f\"  调仓次数: {len(rets)}\")\n        print(f\"  总收益: {total * 100:.2f}%\")\n        print(f\"  年化收益: {annual * 100:.2f}%\")\n        print(f\"  胜率: {len([r for r in rets if r > 0]) / len(rets) * 100:.1f}%\")\n        \n        # 买入持有对比\n        hs300 = results['沪深300']\n        bh_ret = (hs300['close'].iloc[-1] / hs300['close'].iloc[0]) - 1\n        print(f\"\\n沪深300买入持有: {bh_ret * 100:.2f}%\")\n        print(f\"策略超额: {(total - bh_ret) * 100:.2f}%\")"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":89268,"output":1518,"cacheRead":18321,"cacheWrite":0,"totalTokens":109107,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772523656438}}
