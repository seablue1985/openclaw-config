{"type":"message","id":"682182a9","parentId":"3d060565","timestamp":"2026-03-03T08:21:14.801Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"测试太慢了，让我简化一下，减少参数组合数量","thinkingSignature":"482da23a3a35d2383a8c99146179993637797eedb8a28dc3906904646a0dc287"},{"type":"toolCall","id":"call_function_7sfvcnmdk88x_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && source .venv/bin/activate && python -c \"\nimport pandas as pd\nimport numpy as np\n\nbasic = pd.read_csv('data/stock_basic.csv')\ndaily = pd.read_csv('data/daily_basic_all.csv')\ndates = sorted(daily['trade_date'].unique())[-60:]\n\nprint('参数区间化测试 (简化版)')\nprint('='*50)\n\n# 测试市值范围\nfor min_mv in [10, 15, 20]:\n    for max_mv in [40, 60, 80]:\n        months = sorted(set(d // 100 for d in dates))\n        rets = []\n        for month in months:\n            md = [d for d in dates if d // 100 == month]\n            if not md: continue\n            td = md[0]\n            \n            df = daily[daily['trade_date'] == td].copy()\n            df['mv_yi'] = df['circ_mv'] / 10000\n            df = df[(df['mv_yi'] >= min_mv) & (df['mv_yi'] <= max_mv)]\n            df = df[(df['pe'] > 0) & (df['pe'] < 50)]\n            df = df.nsmallest(20, 'mv_yi')\n            df = df.merge(basic[['ts_code', 'name', 'industry']], on='ts_code', how='left')\n            df = df.groupby('industry').head(1).head(15)\n            \n            if len(df) < 5: continue\n            \n            ni = months.index(month) + 1\n            if ni < len(months):\n                nd = [d for d in dates if d // 100 == months[ni]]\n                if nd:\n                    ed = nd[-1]\n                    rs = []\n                    for _, s in df.iterrows():\n                        sd = daily[(daily['ts_code']==s['ts_code']) & (daily['trade_date']==td)]\n                        edd = daily[(daily['ts_code']==s['ts_code']) & (daily['trade_date']==ed)]\n                        if len(sd)>0 and len(edd)>0:\n                            r = (edd['close'].values[0]-sd['close'].values[0])/sd['close'].values[0]\n                            rs.append(r)\n                    if rs:\n                        rets.append(np.mean(rs))\n        \n        if len(rets) > 3:\n            total = np.prod([1+r for r in rets]) - 1\n            annual = (1+total)**(12/len(rets)) - 1\n            win = len([r for r in rets if r>0])/len(rets)\n            sharpe = np.mean(rets)/np.std(rets)*np.sqrt(12) if np.std(rets)>0 else 0\n            print(f'mv:{min_mv}-{max_mv}亿 | 年化:{annual*100:6.1f}% | 夏普:{sharpe:4.2f} | 胜率:{win*100:.0f}%')\n\"","timeout":120}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":100256,"output":710,"cacheRead":18321,"cacheWrite":0,"totalTokens":119287,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772526053530}}
