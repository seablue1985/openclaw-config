].values[0]\n                    rets.append(r)\n            if rets:\n                results.append({'date': trade_date, 'return': np.mean(rets)})\n\nrets = [r['return'] for r in results]\ntotal = np.prod([1+r for r in rets]) - 1\nannual = (1+total) ** (12/len(rets)) - 1\nwin = len([r for r in rets if r>0]) / len(rets)\n\nprint(f'v5 (30-150亿, PE<40):')\nprint(f'  总收益: {total*100:.2f}%')\nprint(f'  年化: {annual*100:.2f}%')\nprint(f'  胜率: {win*100:.1f}%')\n\"","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":67981,"output":747,"cacheRead":18402,"cacheWrite":0,"totalTokens":87130,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772523151106}}
