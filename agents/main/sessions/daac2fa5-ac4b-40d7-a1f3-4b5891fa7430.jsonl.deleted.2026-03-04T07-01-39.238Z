{"type":"message","id":"65d2d9be","parentId":"1617423a","timestamp":"2026-03-03T15:48:16.225Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"数据太少了。让我直接做一个更简单有效的策略：用行业动量来选股。","thinkingSignature":"ec2a05123792394ced2ff48e36d8f5a7c9070b3ec6a02ad68f2df63f77ed5efc"},{"type":"toolCall","id":"call_function_irfydcs633wa_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && source .venv/bin/activate && python -c \"\nimport pandas as pd\nimport numpy as np\n\nprint('='*50)\nprint('动量策略优化')\nprint('='*50)\n\ndaily = pd.read_csv('data/daily_basic_all.csv')\nbasic = pd.read_csv('data/stock_basic.csv')\ndates = sorted(daily['trade_date'].unique())\n\n# 方法1: 行业动量 -> 行业内选最强\n# 步骤: 先判断行业走势,再在最强行业选股\n\nmonths = sorted(set(d // 100 for d in dates[-120:]))\nresults = []\n\nfor m in months[1:]:\n    md = [d for d in dates[-120:] if d // 100 == m]\n    if not md: continue\n    td = md[0]\n    prev_m = months[months.index(m)-1]\n    pmd = [d for d in dates[-120:] if d // 100 == prev_m]\n    if not pmd: continue\n    pd_date = pmd[0]\n    \n    # 计算行业20日涨幅\n    industry_ret = {}\n    for ind in basic['industry'].unique()[:30]:\n        stocks = basic[basic['industry']==ind]['ts_code'].tolist()\n        if len(stocks) < 3: continue\n        \n        ind_df = daily[(daily['ts_code'].isin(stocks)) & (daily['trade_date'].isin([pd_date, td]))]\n        if len(ind_df) >= 4:\n            start = ind_df.groupby('ts_code')['close'].first()\n            end = ind_df.groupby('ts_code')['close'].last()\n            r = (end / start - 1).mean()\n            if not np.isnan(r):\n                industry_ret[ind] = r\n    \n    if not industry_ret: continue\n    \n    # 选最强行业\n    best_ind = max(industry_ret, key=industry_ret.get)\n    \n    # 在最强行业选最小市值\n    ind_stocks = basic[basic['industry']==best_ind]['ts_code'].tolist()\n    mv = daily[(daily['ts_code'].isin(ind_stocks)) & (daily['trade_date']==td)]\n    if len(mv) > 0:\n        mv = mv.nsmallest(5, 'circ_mv')\n        \n        # 下月收益\n        ni = months.index(m) + 1\n        if ni < len(months):\n            nd = [d for d in dates[-120:] if d // 100 == months[ni]]\n            if nd:\n                ed = nd[-1]\n                rs = []\n                for c in mv['ts_code']:\n                    s = daily[(daily['ts_code']==c) & (daily['trade_date']==td)]\n                    e = daily[(daily['ts_code']==c) & (daily['trade_date']==ed)]\n                    if len(s)>0 and len(e)>0:\n                        rs.append((e['close'].values[0]-s['close'].values[0])/s['close'].values[0])\n                if rs:\n                    results.append({'month': m, 'ind': best_ind[:6], 'ret': np.mean(rs)})\n\nif results:\n    rets = [r['ret'] for r in results]\n    total = np.prod([1+r for r in rets]) - 1\n    annual = (1+total)**(12/len(rets)) - 1\n    win = len([r for r in rets if r>0]) / len(rets)\n    sharpe = np.mean(rets)/np.std(rets)*np.sqrt(12) if np.std(rets)>0 else 0\n    \n    print(f'行业动量策略:')\n    print(f'  调仓次数: {len(rets)}')\n    print(f'  年化: {annual*100:.1f}%')\n    print(f'  胜率: {win*100:.0f}%')\n    print(f'  夏普: {sharpe:.2f}')\n\"","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":142960,"output":919,"cacheRead":18417,"cacheWrite":0,"totalTokens":162296,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772552873665}}
{"type":"message","id":"fa16567d","parentId":"65d2d9be","timestamp":"2026-03-03T15:48:20.951Z","message":{"role":"toolResult","toolCallId":"call_function_irfydcs633wa_1","toolName":"exec","content":[{"type":"text","text":"==================================================\n动量策略优化\n==================================================\n行业动量策略:\n  调仓次数: 6\n  年化: 69.6%\n  胜率: 50%\n  夏普: 1.59"}],"details":{"status":"completed","exitCode":0,"durationMs":4720,"aggregated":"==================================================\n动量策略优化\n==================================================\n行业动量策略:\n  调仓次数: 6\n  年化: 69.6%\n  胜率: 50%\n  夏普: 1.59","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1772552900947}}
{"type":"message","id":"58bacb8d","parentId":"fa16567d","timestamp":"2026-03-03T15:48:40.248Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"行业动量策略年化69.6%，比之前好多了！让我再做一个更完整的策略对比。","thinkingSignature":"fe7531e70938de62e432fcd074f71be9439bfa54058f4741e01c737362e3b14c"},{"type":"toolCall","id":"call_function_wvm0sxeiqe5g_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && source .venv/bin/activate && python -c \"\nimport pandas as pd\nimport numpy as np\n\nprint('='*60)\nprint('优化后动量策略 vs 基准')\nprint('='*60)\n\ndaily = pd.read_csv('data/daily_basic_all.csv')\nbasic = pd.read_csv('data/stock_basic.csv')\ndates = sorted(daily['trade_date'].unique())\n\n# 基准: 中证1000\nbenchmark = pd.read_csv('data/index_000852_SH.csv')\nbenchmark['date'] = pd.to_datetime(benchmark['trade_date'], format='%Y%m%d')\nbenchmark = benchmark.sort_values('date')\n\n# 优化策略: 行业动量+行业内小市值\nmonths = sorted(set(d // 100 for d in dates[-120:]))\nstrategy_rets = []\nbenchmark_rets = []\n\nfor m in months[1:]:\n    md = [d for d in dates[-120:] if d // 100 == m]\n    if not md: continue\n    td = md[0]\n    prev_m = months[months.index(m)-1]\n    pmd = [d for d in dates[-120:] if d // 100 == prev_m]\n    if not pmd: continue\n    pd_date = pmd[0]\n    \n    # 策略\n    industry_ret = {}\n    for ind in basic['industry'].unique()[:30]:\n        stocks = basic[basic['industry']==ind]['ts_code'].tolist()\n        if len(stocks) < 3: continue\n        ind_df = daily[(daily['ts_code'].isin(stocks)) & (daily['trade_date'].isin([pd_date, td]))]\n        if len(ind_df) >= 4:\n            start = ind_df.groupby('ts_code')['close'].first()\n            end = ind_df.groupby('ts_code')['close'].last()\n            r = (end / start - 1).mean()\n            if not np.isnan(r):\n                industry_ret[ind] = r\n    \n    if not industry_ret: continue\n    best_ind = max(industry_ret, key=industry_ret.get)\n    ind_stocks = basic[basic['industry']==best_ind]['ts_code'].tolist()\n    mv = daily[(daily['ts_code'].isin(ind_stocks)) & (daily['trade_date']==td)]\n    if len(mv) > 0:\n        mv = mv.nsmallest(5, 'circ_mv')\n        ni = months.index(m) + 1\n        if ni < len(months):\n            nd = [d for d in dates[-120:] if d // 100 == months[ni]]\n            if nd:\n                ed = nd[-1]\n                rs = []\n                for c in mv['ts_code']:\n                    s = daily[(daily['ts_code']==c) & (daily['trade_date']==td)]\n                    e = daily[(daily['ts_code']==c) & (daily['trade_date']==ed)]\n                    if len(s)>0 and len(e)>0:\n                        rs.append((e['close'].values[0]-s['close'].values[0])/s['close'].values[0])\n                if rs:\n                    strategy_rets.append(np.mean(rs))\n    \n    # 基准\n    bm = benchmark[(benchmark['date'].dt.year == (m//10000)) & (benchmark['date'].dt.month == (m%10000)//100)]\n    if len(bm) >= 2:\n        br = (bm['close'].iloc[-1] / bm['close'].iloc[0] - 1)\n        benchmark_rets.append(br)\n\nif strategy_rets:\n    s_total = np.prod([1+r for r in strategy_rets]) - 1\n    s_annual = (1+s_total)**(12/len(strategy_rets)) - 1\n    s_sharpe = np.mean(strategy_rets)/np.std(strategy_rets)*np.sqrt(12) if np.std(strategy_rets)>0 else 0\n    \n    b_total = np.prod([1+r for r in benchmark_rets]) - 1\n    b_annual = (1+b_total)**(12/len(benchmark_rets)) - 1\n    \n    print(f'''\n【优化后动量策略】\n  年化收益: {s_annual*100:+.1f}%\n  胜率: {len([r for r in strategy_rets if r>0])/len(strategy_rets)*100:.0f}%\n  夏普比率: {s_sharpe:.2f}\n\n【中证1000基准】\n  年化收益: {b_annual*100:+.1f}%\n\n【超额】\n  年化超额: {(s_annual-b_annual)*100:+.1f}%\n    ''')\n\"","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":143945,"output":1076,"cacheRead":18417,"cacheWrite":0,"totalTokens":163438,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772552900952}}
