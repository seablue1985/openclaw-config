{"type":"message","id":"0a9e62e0","parentId":"396ca3bc","timestamp":"2026-03-03T15:47:31.172Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"超时了，让我简化一下代码重新运行。","thinkingSignature":"0dde3f4c23417e6db9b9a94a1ac892c63b166dba4abe395a94b55e95f5b7acfc"},{"type":"toolCall","id":"call_function_z51ak0vloyjv_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && source .venv/bin/activate && python -c \"\nimport pandas as pd\nimport numpy as np\n\ndaily = pd.read_csv('data/daily_basic_all.csv')\ndates = sorted(daily['trade_date'].unique())\nprint(f'数据: {len(dates)}天')\n\n# 简化版动量策略\nmonths = sorted(set(d // 100 for d in dates[-120:]))\n\nrets = []\nfor m in months[1:]:\n    md = [d for d in dates[-120:] if d // 100 == m]\n    if not md: continue\n    td = md[0]\n    \n    # 取过去20天涨幅\n    mom = []\n    for c in daily['ts_code'].unique()[:300]:\n        df = daily[(daily['ts_code']==c) & (daily['trade_date']<=td)].tail(20)\n        if len(df) >= 10:\n            r = (df['close'].iloc[-1] / df['close'].iloc[0] - 1)\n            mv = daily[(daily['ts_code']==c) & (daily['trade_date']==td)]\n            if len(mv) > 0 and r > 0 and r < 1:\n                mom.append({'c': c, 'r': r, 'mv': mv['circ_mv'].values[0]})\n    \n    if len(mom) < 10: continue\n    df = pd.DataFrame(mom)\n    df['mv_yi'] = df['mv'] / 10000\n    df = df[(df['mv_yi'] >= 20) & (df['mv_yi'] <= 200)]\n    df = df.nlargest(10, 'r')\n    \n    ni = months.index(m) + 1\n    if ni < len(months):\n        nd = [d for d in dates[-120:] if d // 100 == months[ni]]\n        if nd:\n            ed = nd[-1]\n            rs = []\n            for c in df['c']:\n                s = daily[(daily['ts_code']==c) & (daily['trade_date']==td)]\n                e = daily[(daily['ts_code']==c) & (daily['trade_date']==ed)]\n                if len(s)>0 and len(e)>0:\n                    rs.append((e['close'].values[0]-s['close'].values[0])/s['close'].values[0])\n            if rs:\n                rets.append(np.mean(rs))\n\nif rets:\n    total = np.prod([1+r for r in rets]) - 1\n    annual = (1+total)**(12/len(rets)) - 1\n    win = len([r for r in rets if r>0]) / len(rets)\n    sharpe = np.mean(rets)/np.std(rets)*np.sqrt(12) if np.std(rets)>0 else 0\n    print(f'动量(正动量+市值过滤): 年化{annual*100:.1f}%, 胜率{win*100:.0f}%, 夏普{sharpe:.2f}')\n\"","timeout":120}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":141866,"output":720,"cacheRead":18417,"cacheWrite":0,"totalTokens":161003,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772552836523}}
