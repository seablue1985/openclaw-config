{"type":"message","id":"d9a0159f","parentId":"a0c52763","timestamp":"2026-03-03T07:41:35.896Z","message":{"role":"toolResult","toolCallId":"call_function_32ljqsdysrw5_1","toolName":"read","content":[{"type":"text","text":"    \"\"\"加载指数数据\"\"\"\n    fname = f'{DATA_DIR}/index_{code.replace(\".\", \"_\")}.csv'\n    \n    if not os.path.exists(fname):\n        print(f'数据文件不存在: {fname}')\n        return None\n    \n    df = pd.read_csv(fname)\n    df['date'] = pd.to_datetime(df['trade_date'], format='%Y%m%d')\n    df = df.set_index('date')\n    df = df.sort_index()\n    df = df[df.index >= start_date]\n    \n        # 计算20日动量\n        df['momentum'] = df['close'].pct_change(20)\n    \n    return df\n\n\ndef run_simple_backtest():\n    \"\"\"运行简化版回测\"\"\"\n    print(\"=\" * 60)\n    print(\"三策略组合回测\")\n    print(\"=\" * 60)\n    \n    # 加载数据\n    indices = {\n        '000300.SH': '沪深300',\n        '000905.SH': '中证500', \n        '000852.SH': '中证1000',\n    }\n    \n    # 由于Backtrader需要实时数据，我们用简化的方式计算\n    # 直接用指数数据计算轮动策略收益\n    \n    results = {}\n    for code, name in indices.items():\n        df = load_index_data(code)\n        if df is not None:\n            # 计算20日动量\n            df['momentum'] = df['close'].pct_change(20)\n            results[name] = df\n    \n    if not results:\n        print(\"没有数据\")\n        return\n    \n    # 模拟ETF轮动策略\n    dates = sorted(set(results['沪深300'].index) & set(results['中证500'].index) & set(results['中证1000'].index))\n    print(f\"回测区间: {dates[0]} ~ {dates[-1]}\")\n\n[50 more lines in file. Use offset=240 to continue.]"}],"isError":false,"timestamp":1772523695887}}
{"type":"message","id":"ecf33fad","parentId":"d9a0159f","timestamp":"2026-03-03T07:41:54.630Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I see there's some leftover code in the wrong place. Let me simplify and fix the file properly by rewriting it.","thinkingSignature":"4f4998ec54b44751acf7a455d6918f278b2f23e954260b5c3b169e642169a255"},{"type":"toolCall","id":"call_function_xm99k1a4jqm4_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n三策略组合回测框架\n基于Backtrader - ETF轮动 + 小市值 + 白马策略\n\"\"\"\nimport os\nimport backtrader as bt\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\n\n# 数据目录\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'data')\n\n\ndef load_index_data(code, start_date='2020-01-01'):\n    \"\"\"加载指数数据\"\"\"\n    fname = f'{DATA_DIR}/index_{code.replace(\".\", \"_\")}.csv'\n    \n    if not os.path.exists(fname):\n        print(f'数据文件不存在: {fname}')\n        return None\n    \n    df = pd.read_csv(fname)\n    df['date'] = pd.to_datetime(df['trade_date'], format='%Y%m%d')\n    df = df.set_index('date')\n    df = df.sort_index()\n    df = df[df.index >= start_date]\n    \n    return df\n\n\ndef run_simple_backtest():\n    \"\"\"运行简化版回测\"\"\"\n    print(\"=\" * 60)\n    print(\"ETF轮动策略回测\")\n    print(\"=\" * 60)\n    \n    # 加载数据\n    indices = {\n        '000300.SH': '沪深300',\n        '000905.SH': '中证500', \n        '000852.SH': '中证1000',\n    }\n    \n    results = {}\n    for code, name in indices.items():\n        df = load_index_data(code)\n        if df is not None:\n            # 计算20日动量\n            df['momentum'] = df['close'].pct_change(20)\n            results[name] = df\n    \n    if not results:\n        print(\"没有数据\")\n        return\n    \n    # 模拟ETF轮动策略\n    dates = sorted(set(results['沪深300'].index) & set(results['中证500'].index) & set(results['中证1000'].index))\n    print(f\"回测区间: {dates[0]} ~ {dates[-1]}\")\n    print(f\"交易日数: {len(dates)}\")\n    \n    # 按20天调仓\n    monthly_returns = []\n    for i in range(20, len(dates), 20):\n        current_date = dates[i]\n        \n        # 计算各指数动量\n        momentum = {}\n        for name, df in results.items():\n            if current_date in df.index:\n                mom = df.loc[current_date, 'momentum']\n                if not np.isnan(mom):\n                    momentum[name] = mom\n        \n        if momentum:\n            # 选择最强动量\n            best = max(momentum, key=momentum.get)\n            \n            # 计算下20天收益\n            if i + 20 < len(dates):\n                next_date = dates[i + 20]\n                \n                for name, df in results.items():\n                    if current_date in df.index and next_date in df.index:\n                        ret = (df.loc[next_date, 'close'] / df.loc[current_date, 'close']) - 1\n                        if name == best:\n                            monthly_returns.append({'date': current_date, 'strategy': name, 'return': ret})\n    \n    if monthly_returns:\n        rets = [r['return'] for r in monthly_returns]\n        total = np.prod([1 + r for r in rets]) - 1\n        annual = (1 + total) ** (len(rets) / 12) - 1\n        \n        print(f\"\\nETF轮动策略结果:\")\n        print(f\"  调仓次数: {len(rets)}\")\n        print(f\"  总收益: {total * 100:.2f}%\")\n        print(f\"  年化收益: {annual * 100:.2f}%\")\n        print(f\"  胜率: {len([r for r in rets if r > 0]) / len(rets) * 100:.1f}%\")\n        \n        # 买入持有对比\n        hs300 = results['沪深300']\n        bh_ret = (hs300['close'].iloc[-1] / hs300['close'].iloc[0]) - 1\n        print(f\"\\n沪深300买入持有: {bh_ret * 100:.2f}%\")\n        print(f\"策略超额: {(total - bh_ret) * 100:.2f}%\")\n        \n        # 调仓详情\n        print(f\"\\n调仓记录:\")\n        for r in monthly_returns[:10]:\n            print(f\"  {r['date'].strftime('%Y-%m-%d')}: {r['strategy']} {r['return']*100:+.2f}%\")\n\n\nif __name__ == '__main__':\n    run_simple_backtest()\n","file_path":"/Users/ling/.openclaw/workspace/quant_system/backtest_framework.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":91351,"output":1067,"cacheRead":18321,"cacheWrite":0,"totalTokens":110739,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772523695897}}
