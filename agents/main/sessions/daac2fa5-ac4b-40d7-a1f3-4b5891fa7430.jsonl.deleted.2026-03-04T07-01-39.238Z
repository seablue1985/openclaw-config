{"type":"message","id":"67b56257","parentId":"3e213d91","timestamp":"2026-03-03T07:31:56.506Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"被终止了。让我简化计算，用更高效的方式。","thinkingSignature":"8430af3da5d92f484173affaae77541aabec44df303422ff5730484e3bb007c8"},{"type":"toolCall","id":"call_function_cigf8lylczht_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_system && source .venv/bin/activate && python -c \"\nimport pandas as pd\nimport numpy as np\n\nbasic = pd.read_csv('data/stock_basic.csv')\ndaily = pd.read_csv('data/daily_basic_all.csv')\n\ndates = sorted(daily['trade_date'].unique())\nrecent = dates[-120:]\nmonths = sorted(set(d // 100 for d in recent))\n\nresults = []\nfor month in months:\n    md = [d for d in recent if d // 100 == month]\n    if not md: continue\n    trade_date = md[0]\n    \n    # 选股\n    df = daily[daily['trade_date'] == trade_date].copy()\n    df['circ_mv_yi'] = df['circ_mv'] / 10000\n    df = df[(df['circ_mv_yi'] >= 20) & (df['circ_mv_yi'] <= 80)]\n    df = df[(df['pe'] > 0) & (df['pe'] < 60)]\n    df = df.sort_values('circ_mv_yi').head(50)  # 取最小50只\n    \n    if len(df) == 0: continue\n    \n    # 合并名称\n    df = df.merge(basic[['ts_code', 'name', 'industry']], on='ts_code', how='left')\n    df = df.groupby('industry').head(2).head(20)\n    \n    # 下月收益\n    next_idx = months.index(month) + 1\n    if next_idx < len(months):\n        nd = [d for d in recent if d // 100 == months[next_idx]]\n        if nd:\n            end_d = nd[-1]\n            rets = []\n            for _, s in df.iterrows():\n                sd = daily[(daily['ts_code'] == s['ts_code']) & (daily['trade_date'] == trade_date)]\n                ed = daily[(daily['ts_code'] == s['ts_code']) & (daily['trade_date'] == end_d)]\n                if len(sd) > 0 and len(ed) > 0:\n                    r = (ed['close'].values[0] - sd['close'].values[0]) / sd['close'].values[0]\n                    rets.append(r)\n            if rets:\n                results.append({'date': trade_date, 'return': np.mean(rets)})\n\nrets = [r['return'] for r in results]\ntotal = np.prod([1+r for r in rets]) - 1\nannual = (1+total) ** (12/len(rets)) - 1\nwin = len([r for r in rets if r>0]) / len(rets)\nsharpe = np.mean(rets) / np.std(rets) * np.sqrt(12) if np.std(rets) > 0 else 0\n\nprint(f'v3简化版:')\nprint(f'  总收益: {total*100:.2f}%')\nprint(f'  年化: {annual*100:.2f}%')\nprint(f'  胜率: {win*100:.1f}%')\nprint(f'  夏普: {sharpe:.2f}')\n\"","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":66317,"output":736,"cacheRead":18402,"cacheWrite":0,"totalTokens":85455,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772523100946}}
