============================\\nSTART OF FILE:')\n    for p in parts[1:]:\n        if url in p:\n            return p\n    return None\n\ndef features(code):\n    t=code.lower()\n    f={}\n    f['stop']= any(k in t for k in ['止损','stoploss','止盈','drawdown'])\n    f['timing']= any(k in t for k in ['rsrs','择时','market_timing','signal'])\n    f['freq_daily']= 'run_daily' in t\n    f['freq_weekly']= 'run_weekly' in t\n    f['freq_monthly']= 'run_monthly' in t\n    f['etf']= ('etf' in t) or ('.xshe' in t and '159' in t)\n    f['factor']= any(k in t for k in ['jqfactor','get_factor_values','因子','factor'])\n    f['hedge']= any(k in t for k in ['对冲','if88','ic88','ih88','futures'])\n    f['smallcap']= '小市值' in code\n    f['risk_words']= sum(1 for k in ['止损','仓位','风控','回撤','风险'] if k in code)\n    return f\n\nrecords=[]\ntexts=[]\nfor fp in files:\n    try:\n        with open(fp,'r',encoding='utf-8',errors='ignore') as f:\n            texts.append((fp,f.read()))\n    except Exception:\n        pass\n\nfor url,name in cands:\n    found=None\n    for fp,txt in texts:\n        b=extract_block(txt,url)\n        if b:\n            found=(fp,b)\n            break\n    if not found:\n        continue\n    fp,b=found\n    lines=b.splitlines()\n    title=''\n    if lines:\n        title=lines[0].strip()\n    m=re.search(r'标题：(.*)',b)\n    if m:\n        title=m.group(1).strip()\n    year='unknown'\n    m2=re.search(r'Strategies_(\\d{4})_Combined',fp)\n    if m2: year=int(m2.group(1))\n    f=features(b)\n    # scoring\n    score=0\n    score += (year-2020)*0.8 if isinstance(year,int) else 0\n    score += 2.0 if f['stop'] else 0\n    score += 1.6 if f['timing'] else 0\n    score += 1.2 if f['etf'] else 0\n    score += 1.2 if f['factor'] else 0\n    score += 0.8 if f['freq_monthly'] else 0\n    score += 0.4 if f['freq_weekly'] else 0\n    score -= 0.8 if f['freq_daily'] else 0\n    score += 0.6 if f['hedge'] else 0\n    score += min(f['risk_words']*0.2,1.0)\n    score -= 0.6 if f['smallcap'] else 0\n    records.append({'url':url,'name':name,'title':title,'year':year,'score':round(score,2),**f})\n\nrecords.sort(key=lambda x:x['score'],reverse=True)\nprint(json.dumps(records[:20],ensure_ascii=False,indent=2))\nPY"},"partialJson":"{\"command\":\"python3 - <<'PY'\\nimport re,glob,os,json\\nbase='/tmp/jq_strategies.1wb2f2/聚宽策略合集'\\nfiles=glob.glob(base+'/*/Strategies_*_Combined.txt')\\n# candidates (url, display)\\ncands=[\\n('https://www.joinquant.com/post/47966','带上止损的核心资产轮动'),\\n('https://www.joinquant.com/post/47566','大容量低回撤价值投资'),\\n('https://www.joinquant.com/post/35959','ETF轮动多类别低回撤'),\\n('https://www.joinquant.com/post/35174','漂亮50止损版本'),\\n('https://www.joinquant.com/post/36162','ETF动量RSRS+北上择时+盘中止损'),\\n('https://www.joinquant.com/post/38838','ETF轮动增加盘中止损'),\\n('https://www.joinquant.com/post/48789','低风险中等收益策略'),\\n('https://www.joinquant.com/post/47208','ETF动量轮动+EPO优化'),\\n('https://www.joinquant.com/post/49615','波动率过滤相关性最小ETF轮动'),\\n('https://www.joinquant.com/post/47888','核心资产ETF轮动线性加权'),\\n('https://www.joinquant.com/post/47033','趋势拥挤景气行业轮动'),\\n('https://www.joinquant.com/post/49507','趋势筛选相关性最小ETF轮动'),\\n('https://www.joinquant.com/post/48989','稳健型ETF策略'),\\n('https://www.joinquant.com/post/49180','行业宽度轮动研究'),\\n('https://www.joinquant.com/post/36805','实盘更新分钟级+盘中止损'),\\n('https://www.joinquant.com/post/34745','价值成长轮动策略'),\\n('https://www.joinquant.com/post/39774','高股息低杠杆小市值轮动'),\\n('https://www.joinquant.com/post/19490','ETF二八轮动对冲模型'),\\n('https://www.joinquant.com/post/22440','螺纹钢供需轮动带止损'),\\n('https://www.joinquant.com/post/29940','多因子指数增强'),\\n]\\n\\ndef extract_block(text,url):\\n    # split by strategy blocks\\n    parts=text.split('==================================================\\\\nSTART OF FILE:')\\n    for p in parts[1:]:\\n        if url in p:\\n            return p\\n    return None\\n\\ndef features(code):\\n    t=code.lower()\\n    f={}\\n    f['stop']= any(k in t for k in ['止损','stoploss','止盈','drawdown'])\\n    f['timing']= any(k in t for k in ['rsrs','择时','market_timing','signal'])\\n    f['freq_daily']= 'run_daily' in t\\n    f['freq_weekly']= 'run_weekly' in t\\n    f['freq_monthly']= 'run_monthly' in t\\n    f['etf']= ('etf' in t) or ('.xshe' in t and '159' in t)\\n    f['factor']= any(k in t for k in ['jqfactor','get_factor_values','因子','factor'])\\n    f['hedge']= any(k in t for k in ['对冲','if88','ic88','ih88','futures'])\\n    f['smallcap']= '小市值' in code\\n    f['risk_words']= sum(1 for k in ['止损','仓位','风控','回撤','风险'] if k in code)\\n    return f\\n\\nrecords=[]\\ntexts=[]\\nfor fp in files:\\n    try:\\n        with open(fp,'r',encoding='utf-8',errors='ignore') as f:\\n            texts.append((fp,f.read()))\\n    except Exception:\\n        pass\\n\\nfor url,name in cands:\\n    found=None\\n    for fp,txt in texts:\\n        b=extract_block(txt,url)\\n        if b:\\n            found=(fp,b)\\n            break\\n    if not found:\\n        continue\\n    fp,b=found\\n    lines=b.splitlines()\\n    title=''\\n    if lines:\\n        title=lines[0].strip()\\n    m=re.search(r'标题：(.*)',b)\\n    if m:\\n        title=m.group(1).strip()\\n    year='unknown'\\n    m2=re.search(r'Strategies_(\\\\d{4})_Combined',fp)\\n    if m2: year=int(m2.group(1))\\n    f=features(b)\\n    # scoring\\n    score=0\\n    score += (year-2020)*0.8 if isinstance(year,int) else 0\\n    score += 2.0 if f['stop'] else 0\\n    score += 1.6 if f['timing'] else 0\\n    score += 1.2 if f['etf'] else 0\\n    score += 1.2 if f['factor'] else 0\\n    score += 0.8 if f['freq_monthly'] else 0\\n    score += 0.4 if f['freq_weekly'] else 0\\n    score -= 0.8 if f['freq_daily'] else 0\\n    score += 0.6 if f['hedge'] else 0\\n    score += min(f['risk_words']*0.2,1.0)\\n    score -= 0.6 if f['smallcap'] else 0\\n    records.append({'url':url,'name':name,'title':title,'year':year,'score':round(score,2),**f})\\n\\nrecords.sort(key=lambda x:x['score'],reverse=True)\\nprint(json.dumps(records[:20],ensure_ascii=False