cklists/ACTIVE_TASK.md >/dev/null 2>&1 && echo ACTIVE || echo NONE\"}"},{"type":"toolCall","id":"call_Cnz0YfMaVdbAByu1Jax6Ynkw|fc_0411becee4eea9850169cb362515408199a7516661ab1b6b28","name":"exec","arguments":{"command":"python3 - <<'PY'\nimport json, os\nfor p in [\n '/Users/ling/.openclaw/workspace/memory/global_market_morning_0850_state.json',\n '/Users/ling/.openclaw/workspace/memory/premarket_precheck_state.json'\n]:\n    print('FILE', os.path.basename(p))\n    if not os.path.exists(p):\n        print('MISSING')\n        continue\n    try:\n        d=json.load(open(p))\n    except Exception as e:\n        print('INVALID', e)\n        continue\n    if 'global_market' in p:\n        print({k:d.get(k) for k in ['status','generated_at','last_success_at','last_failure_at','error']})\n    else:\n        print({k:d.get(k) for k in ['last_run_date']})\n        ls=d.get('last_status') or {}\n        print({k:ls.get(k) for k in ['status','status_reason','date','time','passed','strict_precheck','hard_stop','halt_reason','report_file']})\nPY"},"partialJson":"{\"command\":\"python3 - <<'PY'\\nimport json, os\\nfor p in [\\n '/Users/ling/.openclaw/workspace/memory/global_market_morning_0850_state.json',\\n '/Users/ling/.openclaw/workspace/memory/premarket_precheck_state.json'\\n]:\\n    print('FILE', os.path.basename(p))\\n    if not os.path.exists(p):\\n        print('MISSING')\\n        continue\\n    try:\\n        d=json.load(open(p))\\n    except Exception as e:\\n        print('INVALID', e)\\n        continue\\n    if 'global_market' in p:\\n        print({k:d.get(k) for k in ['status','generated_at','last_success_at','last_failure_at','error']})\\n    else:\\n        print({k:d.get(k) for k in ['last_run_date']})\\n        ls=d.get('last_status') or {}\\n        print({k:ls.get(k) for k in ['status','status_reason','date','time','passed','strict_precheck','hard_stop','halt_reason','report_file']})\\nPY\"}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","