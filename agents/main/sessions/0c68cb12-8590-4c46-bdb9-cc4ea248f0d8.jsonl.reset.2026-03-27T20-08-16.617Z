{"type":"message","id":"ad35af05","parentId":"16e7d661","timestamp":"2026-03-27T01:09:42.594Z","message":{"role":"toolResult","toolCallId":"call_function_mhqj8tuq9rx9_1","toolName":"read","content":[{"type":"text","text":"{\n  \"schema_name\": \"al_brooks_a_share_state_machine\",\n  \"schema_version\": \"v1\",\n  \"generated_at\": \"2026-03-27T09:02:00+08:00\",\n  \"description\": \"阿尔布鲁克斯价格行为理论的A股量化状态机字典，用于状态标签、门控放行与风险提示。\",\n  \"states\": [\n    {\n      \"code\": \"S0\",\n      \"name\": \"平衡震荡\",\n      \"category\": \"balance\",\n      \"description\": \"多空围绕公允成交区反复拉扯，趋势延续性不足。\",\n      \"entry_conditions\": [\n        \"区间包络占比高\",\n        \"均线斜率绝对值较低\",\n        \"突破失败率较高\"\n      ],\n      \"exit_conditions\": [\n        \"向上突破尝试成立\",\n        \"向下突破尝试成立\"\n      ],\n      \"default_actions\": [\n        \"降低追涨\",\n        \"只在区间边缘参与\",\n        \"区间中部等待\"\n      ]\n    },\n    {\n      \"code\": \"S1\",\n      \"name\": \"向上试图突破\",\n      \"category\": \"breakout_attempt_up\",\n      \"description\": \"价格尝试摆脱平衡区向上扩张，但尚未确认进入稳定趋势。\",\n      \"entry_conditions\": [\n        \"突破近期区间高点\",\n        \"放量或实体扩张\",\n        \"短周期跟随确认尚不足\"\n      ],\n      \"exit_conditions\": [\n        \"上升趋势延续确认\",\n        \"失败突破并回到区间\"\n      ],\n      \"default_actions\": [\n        \"小仓试错\",\n        \"等待后续跟随确认\",\n        \"板块不共振则降权\"\n      ]\n    },\n    {\n      \"code\": \"S2\",\n      \"name\": \"向下试图突破\",\n      \"category\": \"breakout_attempt_down\",\n      \"description\": \"价格尝试向下脱离平衡区，常用于组合风控与风险退潮识别。\",\n      \"entry_conditions\": [\n        \"跌破近期区间低点\",\n        \"风险偏好下降\",\n        \"指数与宽度偏弱\"\n      ],\n      \"exit_conditions\": [\n        \"下降趋势延续确认\",\n        \"失败突破并回到区间\"\n      ],\n      \"default_actions\": [\n        \"减仓\",\n        \"提高现金权重\",\n        \"启动防守门禁\"\n      ]\n    },\n    {\n      \"code\": \"S3\",\n      \"name\": \"上升趋势延续\",\n      \"category\": \"trend_up\",\n      \"description\": \"突破已被市场接受，回踩后承接有效，价格沿趋势继续推进。\",\n      \"entry_conditions\": [\n        \"更高高点与更高低点结构成立\",\n        \"回撤深度受控\",\n        \"相对指数保持强势\"\n      ],\n      \"exit_conditions\": [\n        \"趋势衰减信号累积\",\n        \"关键结构被破坏\"\n      ],\n      \"default_actions\": [\n        \"顺势持有\",\n        \"优先做高质量回踩\",\n        \"适度放宽止盈\"\n      ]\n    },\n    {\n      \"code\": \"S4\",\n      \"name\": \"下降趋势延续\",\n      \"category\": \"trend_down\",\n      \"description\": \"更低价格区被市场接受，反弹多为弱修复。\",\n      \"entry_conditions\": [\n        \"更低高点与更低低点结构成立\",\n        \"反弹承接弱\",\n        \"相对指数持续走弱\"\n      ],\n      \"exit_conditions\": [\n        \"趋势衰减\",\n        \"反转确认\"\n      ],\n      \"default_actions\": [\n        \"禁做多或大幅降权\",\n        \"组合降风险\",\n        \"优先控制回撤\"\n      ]\n    },\n    {\n      \"code\": \"S5\",\n      \"name\": \"趋势衰减/失败突破\",\n      \"category\": \"trend_exhaustion\",\n      \"description\": \"原趋势仍在，但延续质量明显变差，失败突破与重叠K线增多。\",\n      \"entry_conditions\": [\n        \"新高/新低成功率下降\",\n        \"K线重叠率上升\",\n        \"突破后回落频繁\"\n      ],\n      \"exit_conditions\": [\n        \"回到平衡震荡\",\n        \"反转确认\"\n      ],\n      \"default_actions\": [\n        \"停止追涨\",\n        \"部分止盈\",\n        \"收紧风控\"\n      ]\n    },\n    {\n      \"code\": \"S6\",\n      \"name\": \"反转确认\",\n      \"category\": \"reversal_confirmed\",\n      \"description\": \"原方向关键结构已被破坏，新方向取得至少初步接管。\",\n      \"entry_conditions\": [\n        \"关键摆动点破坏\",\n        \"反向跟随至少2至3根有效延续\",\n        \"原有顺势买入逻辑失效\"\n      ],\n      \"exit_conditions\": [\n        \"进入新趋势延续\",\n        \"再次回到平衡震荡\"\n      ],\n      \"default_actions\": [\n        \"切换风控模式\",\n        \"重新评估方向\",\n        \"确认后再参与\"\n      ]\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"range_width_20\",\n      \"group\": \"price_structure\",\n      \"type\": \"float\",\n      \"description\": \"最近20根K线最高价与最低价之间的区间宽度，可做归一化。\"\n    },\n    {\n      \"name\": \"inside_range_ratio_20\",\n      \"group\": \"price_structure\",\n      \"type\": \"float\",\n      \"description\": \"最近20根中收盘仍位于区间内部的比例。\"\n    },\n    {\n      \"name\": \"ma_slope_20\",\n      \"group\": \"trend_strength\",\n      \"type\": \"float\",\n      \"description\": \"20期均线斜率，用于判断趋势倾斜程度。\"\n    },\n    {\n      \"name\": \"adx_14\",\n      \"group\": \"trend_strength\",\n      \"type\": \"float\",\n      \"description\": \"趋势强度代理，越低越接近平衡震荡。\"\n    },\n    {\n      \"name\": \"breakout_fail_rate_10\",\n      \"group\": \"breakout_quality\",\n      \"type\": \"float\",\n      \"description\": \"最近10次突破尝试中未形成持续脱离的比例。\"\n    },\n    {\n      \"name\": \"breakout_up_strength\",\n      \"group\": \"breakout_quality\",\n      \"type\": \"float\",\n      \"description\": \"向上突破实体或收盘脱离幅度相对区间宽度的归一化指标。\"\n    },\n    {\n      \"name\": \"breakout_down_strength\",\n      \"group\": \"breakout_quality\",\n      \"type\": \"float\",\n      \"description\": \"向下突破脱离幅度的归一化指标。\"\n    },\n    {\n      \"name\": \"follow_through_score_3\",\n      \"group\": \"breakout_quality\",\n      \"type\": \"float\",\n      \"description\": \"突破后3根K线内继续朝突破方向推进的强度评分。\"\n    },\n    {\n      \"name\": \"higher_high_count_10\",\n      \"group\": \"trend_structure\",\n      \"type\": \"integer\",\n      \"description\": \"最近10根中形成更高高点的次数。\"\n    },\n    {\n      \"name\": \"higher_low_count_10\",\n      \"group\": \"trend_structure\",\n      \"type\": \"integer\",\n      \"description\": \"最近10根中形成更高低点的次数。\"\n    },\n    {\n      \"name\": \"lower_high_count_10\",\n      \"group\": \"trend_structure\",\n      \"type\": \"integer\",\n      \"description\": \"最近10根中形成更低高点的次数。\"\n    },\n    {\n      \"name\": \"lower_low_count_10\",\n      \"group\": \"trend_structure\",\n      \"type\": \"integer\",\n      \"description\": \"最近10根中形成更低低点的次数。\"\n    },\n    {\n      \"name\": \"pullback_depth_ratio\",\n      \"group\": \"trend_structure\",\n      \"type\": \"float\",\n      \"description\": \"当前回撤深度相对上一段推进幅度的比例。\"\n    },\n    {\n      \"name\": \"bar_overlap_ratio_10\",\n      \"group\": \"exhaustion\",\n      \"type\": \"float\",\n      \"description\": \"最近10根K线相互重叠的比例，越高说明双向交易越多。\"\n    },\n    {\n      \"name\": \"new_high_success_rate_10\",\n      \"group\": \"exhaustion\",\n      \"type\": \"float\",\n      \"description\": \"创新高后还能继续推进的成功率。\"\n    },\n    {\n      \"name\": \"relative_strength_vs_index_20\",\n      \"group\": \"cross_asset\",\n      \"type\": \"float\",\n      \"description\": \"标的相对基准指数20期收益差。\"\n    },\n    {\n      \"name\": \"sector_strength\",\n      \"group\": \"market_context\",\n      \"type\": \"float\",\n      \"description\": \"所属板块强度评分。\"\n    },\n    {\n      \"name\": \"market_breadth\",\n      \"group\": \"market_context\",\n      \"type\": \"float\",\n      \"description\": \"市场宽度或赚钱效应评分。\"\n    },\n    {\n      \"name\": \"style_regime\",\n      \"group\": \"market_context\",\n      \"type\": \"string\",\n      \"description\": \"风格状态，如小盘主导、大盘主导、防守状态等。\"\n    },\n    {\n      \"name\": \"limit_up_flag\",\n      \"group\": \"a_share_specific\",\n      \"type\": \"integer\",\n      \"description\": \"是否涨停，用于A股情绪异常处理。\"\n    }\n  ],\n  \"threshold_defaults\": {\n    \"inside_range_ratio_20_min\": 0.8,\n    \"adx_14_range_max\": 18.0,\n    \"breakout_fail_rate_10_range_min\": 0.5,\n    \"breakout_strength_min\": 0.35,\n    \"follow_through_score_3_confirm_min\": 0.25,\n    \"trend_hh_hl_min_count\": 3,\n    \"trend_lh_ll_min_count\": 3,\n    \"pullback_depth_ratio_max\": 0.45,\n    \"bar_overlap_ratio_10_exhaustion_min\": 0.55,\n    \"new_high_success_rate_10_exhaustion_max\": 0.4,\n    \"relative_strength_vs_index_20_min\": 0.0\n  },\n  \"output_record_schema\": {\n    \"date\": \"YYYY-MM-DD\",\n    \"symbol\": \"证券代码\",\n    \"state_code\": \"S0~S6\",\n    \"state_name\": \"状态中文名\",\n    \"confidence\": \"0到1之间的小数\",\n    \"action_hint\": [\n      \"动作提示1\",\n      \"动作提示2\"\n    ],\n    \"trigger_features\": {\n      \"feature_name\": \"feature_value\"\n    },\n    \"notes\": \"补充说明\"\n  }\n}\n"}],"isError":false,"timestamp":1774573782581}}
{"type":"message","id":"fc1d6e8f","parentId":"ad35af05","timestamp":"2026-03-27T01:09:42.607Z","message":{"role":"toolResult","toolCallId":"call_function_mhqj8tuq9rx9_2","toolName":"read","content":[{"type":"text","text":"# 阿尔布鲁克斯理论 → A股量化状态机字段定义表与 JSON 字典\n\n生成时间：2026-03-27 09:02（Asia/Shanghai）\n依赖基线：`research/reports/阿尔布鲁克斯理论_A股量化状态机框架_20260327.md`\n配套字典：`research/specs/al_brooks_a_share_state_machine_v1.json`\n\n---\n\n## 一、这份文件解决什么问题\n\n上一轮报告已经把阿尔布鲁克斯理论翻译成了 A 股量化状态机框架；这份文件继续把它压缩成可直接接入系统的数据层定义。\n\n本文件的目标是三件事：\n\n1. 给出统一状态字段定义\n2. 给出统一特征字段定义\n3. 给出统一 JSON 字典结构，方便后续脚本、回测、看板、门控系统直接读取\n\n换句话说，这一版开始从“研究语言”进入“工程语言”。\n\n---\n\n## 二、推荐的最小输出记录结构\n\n每个交易日 / 每只股票 / 每个周期，最终都建议输出一条标准化记录：\n\n| 字段 | 类型 | 说明 |\n|---|---|---|\n| `date` | 字符串 | 交易日期 |\n| `symbol` | 字符串 | 股票代码 |\n| `state_code` | 字符串 | 状态编码，取值 `S0~S6` |\n| `state_name` | 字符串 | 状态中文名 |\n| `confidence` | 浮点数 | 当前状态置信度，范围建议为 `0~1` |\n| `action_hint` | 数组 | 动作建议，如“顺势持有”“降低追涨” |\n| `trigger_features` | 对象 | 本次状态判定最核心的触发字段 |\n| `notes` | 字符串 | 说明、警告、异常提示 |\n\n这是后续接任何系统的最小公共接口。\n\n---\n\n## 三、状态字段定义\n\n| 状态编码 | 状态名 | 定义 | 适合的动作 |\n|---|---|---|---|\n| `S0` | 平衡震荡 | 多空围绕公允成交区反复拉扯，突破延续性弱 | 区间边缘参与，中部等待 |\n| `S1` | 向上试图突破 | 价格尝试脱离平衡区向上扩张，但尚未获得充分确认 | 小仓试错，等确认 |\n| `S2` | 向下试图突破 | 价格尝试向下脱离平衡区，常伴随风险偏好回落 | 减仓、防守 |\n| `S3` | 上升趋势延续 | 突破被接受，回踩承接有效，价格持续推进 | 顺势持有、回踩参与 |\n| `S4` | 下降趋势延续 | 更低价格区被接受，反弹质量差 | 降权或禁做多 |\n| `S5` | 趋势衰减/失败突破 | 原趋势还在，但延续质量显著下降 | 停止追涨、部分止盈 |\n| `S6` | 反转确认 | 原结构被有效破坏，新方向接管 | 切换模式、重评方向 |\n\n---\n\n## 四、特征字段建议按六组管理\n\n### 1. 价格结构组\n用于识别市场是否仍在区间内、是否已脱离平衡区。\n\n| 字段名 | 类型 | 说明 |\n|---|---|---|\n| `range_width_20` | 浮点数 | 最近20根最高价到最低价的区间宽度 |\n| `inside_range_ratio_20` | 浮点数 | 最近20根仍在区间内部的比例 |\n| `close_position_in_range` | 浮点数 | 收盘在当前区间中的相对位置 |\n\n### 2. 趋势强度组\n用于识别趋势是否存在、是否足够强。\n\n| 字段名 | 类型 | 说明 |\n|---|---|---|\n| `ma_slope_20` | 浮点数 | 20期均线斜率 |\n| `adx_14` | 浮点数 | 趋势强度代理 |\n| `trend_efficiency_ratio` | 浮点数 | 单位波动下的净推进效率 |\n\n### 3. 突破质量组\n用于区分“试图突破”与“有效突破”。\n\n| 字段名 | 类型 | 说明 |\n|---|---|---|\n| `breakout_up_strength` | 浮点数 | 向上脱离区间的强度 |\n| `breakout_down_strength` | 浮点数 | 向下脱离区间的强度 |\n| `breakout_fail_rate_10` | 浮点数 | 最近10次突破失败率 |\n| `follow_through_score_3` | 浮点数 | 突破后3根内延续评分 |\n\n### 4. 趋势结构组\n用于判断趋势是否真的在延续。\n\n| 字段名 | 类型 | 说明 |\n|---|---|---|\n| `higher_high_count_10` | 整数 | 最近10根更高高点次数 |\n| `higher_low_count_10` | 整数 | 最近10根更高低点次数 |\n| `lower_high_count_10` | 整数 | 最近10根更低高点次数 |\n| `lower_low_count_10` | 整数 | 最近10根更低低点次数 |\n| `pullback_depth_ratio` | 浮点数 | 当前回撤深度占上一段推进的比例 |\n\n### 5. 衰减识别组\n用于识别趋势质量恶化、失败突破、双向交易增加。\n\n| 字段名 | 类型 | 说明 |\n|---|---|---|\n| `bar_overlap_ratio_10` | 浮点数 | 最近10根K线重叠率 |\n| `new_high_success_rate_10` | 浮点数 | 新高后继续推进的成功率 |\n| `trend_leg_length_decay` | 浮点数 | 每一段趋势腿长度衰减程度 |\n\n### 6. 市场环境组\n用于A股适配，避免只盯单票图形。\n\n| 字段名 | 类型 | 说明 |\n|---|---|---|\n| `relative_strength_vs_index_20` | 浮点数 | 相对基准指数20期强弱 |\n| `sector_strength` | 浮点数 | 所属板块强度评分 |\n| `market_breadth` | 浮点数 | 市场宽度或赚钱效应评分 |\n| `style_regime` | 字符串 | 市场风格状态 |\n| `limit_up_flag` | 整数 | 是否涨停 |\n\n---\n\n## 五、推荐阈值默认值（第一版）\n\n这不是最终参数，而是原型阶段默认值，目的是让系统先跑起来。\n\n| 字段 | 默认值 | 用途 |\n|---|---:|---|\n| `inside_range_ratio_20_min` | 0.80 | 识别平衡震荡 |\n| `adx_14_range_max` | 18.0 | 低趋势强度阈值 |\n| `breakout_fail_rate_10_range_min` | 0.50 | 判断区间突破失败偏多 |\n| `breakout_strength_min` | 0.35 | 初步突破成立强度 |\n| `follow_through_score_3_confirm_min` | 0.25 | 确认突破延续 |\n| `trend_hh_hl_min_count` | 3 | 上升趋势结构最低要求 |\n| `trend_lh_ll_min_count` | 3 | 下降趋势结构最低要求 |\n| `pullback_depth_ratio_max` | 0.45 | 趋势回撤上限 |\n| `bar_overlap_ratio_10_exhaustion_min` | 0.55 | 衰减判定阈值 |\n| `new_high_success_rate_10_exhaustion_max` | 0.40 | 新高质量下降阈值 |\n| `relative_strength_vs_index_20_min` | 0.00 | 至少不弱于指数 |\n\n---\n\n## 六、建议的 JSON 顶层结构\n\n```json\n{\n  \"schema_name\": \"al_brooks_a_share_state_machine\",\n  \"schema_version\": \"v1\",\n  \"states\": [],\n  \"features\": [],\n  \"threshold_defaults\": {},\n  \"output_record_schema\": {}\n}\n```\n\n其中各部分职责如下：\n\n- `states`：描述所有状态的定义、进入条件、退出条件、默认动作\n- `features`：给出特征字段名、分组、类型与说明\n- `threshold_defaults`：给原型阶段一版默认阈值\n- `output_record_schema`：规定标签器最终输出字段格式\n\n---\n\n## 七、推荐的工程接入方式\n\n### 1. 先把字典文件作为只读配置\n\n第一阶段不要把阈值写死在脚本里，建议：\n\n- 脚本读取 `research/specs/al_brooks_a_share_state_machine_v1.json`\n- 先按默认阈值运行\n- 后续回测时只替换 JSON，不先改脚本逻辑\n\n### 2. 让标签器只做三件事\n\n- 计算特征\n- 判定状态\n- 输出标准记录\n\n先不要把下单、风控、看板全揉进去。\n\n### 3. 先做“单票日线标签器”，再升级\n\n推荐顺序：\n\n1. 单票日线\n2. 指数日线\n3. 板块日线\n4. 多层共振门控\n5. 30 分钟 / 60 分钟扩展\n\n---\n\n## 八、最值得直接复用的标准输出样例\n\n```json\n{\n  \"date\": \"2026-03-27\",\n  \"symbol\": \"600519.SH\",\n  \"state_code\": \"S3\",\n  \"state_name\": \"上升趋势延续\",\n  \"confidence\": 0.74,\n  \"action_hint\": [\"顺势持有\", \"优先做高质量回踩\"],\n  \"trigger_features\": {\n    \"higher_high_count_10\": 4,\n    \"higher_low_count_10\": 4,\n    \"pullback_depth_ratio\": 0.28,\n    \"relative_strength_vs_index_20\": 0.06\n  },\n  \"notes\": \"趋势延续有效，但需继续观察板块共振是否保持。\"\n}\n```\n\n---\n\n## 九、这份字典最适合用在哪\n\n优先级最高的不是选股，而是：\n\n1. 市场门禁\n2. 买入放行条件\n3. 高位减仓提示\n4. 组合风险切换\n5. 状态分层回测\n\n也就是说，这份字典更适合作为**量化中间层协议**，而不是最终交易策略本身。\n\n---\n\n## 十、配套文件\n\n- 基线框架报告：`research/reports/阿尔布鲁克斯理论_A股量化状态机框架_20260327.md`\n- JSON 字典：`research/specs/al_brooks_a_share_state_machine_v1.json`\n- 下一步原型脚本：`scripts/al_brooks_a_share_state_labeler.py`\n"}],"isError":false,"timestamp":1774573782595}}
{"type":"message","id":"17fb3636","parentId":"fc1d6e8f","timestamp":"2026-03-27T01:09:54.820Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I have a clear picture. Current task is to write the Python state labeler prototype script. Let me now write it.\n\nThe script should:\n1. Load the JSON dict\n2. Compute features from price data (simulated/mock since we don't have live data)\n3. Determine state\n4. Output standard record\n\nLet me write a clean prototype that:\n- Reads the JSON config\n- Has feature computation functions (with mock data capability)\n- Has state decision logic\n- Outputs standard records\n- Can be run standalone\n\nLet me also check if there's already a scripts directory.","thinkingSignature":"0d7d65021d5d4c1674b9f1c5434b8e0b7a7f0341654fc2155a37d43ea1b16b96"},{"type":"toolCall","id":"call_function_mrkuofawvlxt_1","name":"exec","arguments":{"command":"ls scripts/al_brooks* 2>/dev/null; echo \"---\"; ls research/specs/ 2>/dev/null","workdir":"/Users/ling/.openclaw/workspace"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":10276,"output":189,"cacheRead":22332,"cacheWrite":0,"totalTokens":32797,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774573782608,"responseId":"06150bd6d014efa5b8e267b690afe93c"}}
{"type":"message","id":"e9043c07","parentId":"17fb3636","timestamp":"2026-03-27T01:09:54.931Z","message":{"role":"toolResult","toolCallId":"call_function_mrkuofawvlxt_1","toolName":"exec","content":[{"type":"text","text":"zsh:1: no matches found: scripts/al_brooks*\n---\nal_brooks_a_share_state_machine_v1.json"}],"details":{"status":"completed","exitCode":0,"durationMs":13,"aggregated":"zsh:1: no matches found: scripts/al_brooks*\n---\nal_brooks_a_share_state_machine_v1.json","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774573794921}}
{"type":"message","id":"1731999d","parentId":"e9043c07","timestamp":"2026-03-27T01:11:35.543Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I'll write the prototype script. It should:\n1. Load the JSON schema\n2. Compute features (with simulated/mock data for prototype)\n3. Run the state machine logic\n4. Output labeled records\n\nI'll write it as a standalone script with clear sections, comments, and example usage.","thinkingSignature":"3eba7a1fe559f79d34dd481c72cb581ea2a4603c31ea0d09fc6498f93b4e1d20"},{"type":"text","text":"Now writing the prototype:\n"},{"type":"toolCall","id":"call_function_1ee4semnjvxz_1","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/scripts/al_brooks_a_share_state_labeler.py","content":"#!/usr/bin/env python3\n\"\"\"\n阿尔布鲁克斯A股量化状态标签器 - Python原型 v1\n===============================================\n基于 research/specs/al_brooks_a_share_state_machine_v1.json 配置运行。\n设计目标：先跑通，再迭代。\n\n功能：\n  1. 从 JSON Schema 加载状态定义与默认阈值\n  2. 计算20个特征（可注入真实K线数据，也可使用内置模拟数据）\n  3. 按决策树逻辑输出标准化状态标签 record\n\n使用方式：\n  python3 scripts/al_brooks_a_share_state_labeler.py [--symbol 600519.SH] [--date 2026-03-27]\n\"\"\"\n\nimport json\nimport argparse\nfrom pathlib import Path\nfrom typing import Optional\n\n# ── 路径配置 ──────────────────────────────────────────────\nWORKSPACE = Path(__file__).parent.parent.resolve()\nSCHEMA_PATH = WORKSPACE / \"research\" / \"specs\" / \"al_brooks_a_share_state_machine_v1.json\"\n\n# ── 特征计算 ──────────────────────────────────────────────\n\ndef compute_features_from_bars(bars: list[dict]) -> dict:\n    \"\"\"\n    根据K线列表计算20个特征。\n    bars: [{'high', 'low', 'close', 'open', 'volume', 'limit_up'}, ...]\n          按时间正序，最新一根在最后。\n    \"\"\"\n    n = len(bars)\n    if n < 20:\n        raise ValueError(f\"K线数据不足，需要至少20根，当前{n}根\")\n\n    highs  = [b[\"high\"]  for b in bars]\n    lows   = [b[\"low\"]   for b in bars]\n    closes = [b[\"close\"] for b in bars]\n    opens  = [b[\"open\"]  for b in bars]\n\n    # --- 价格结构组 ---\n    range_width_20 = max(highs) - min(lows)\n    inside_range_ratio_20 = sum(\n        1 for i in range(n) if lows[i] <= closes[i] <= highs[i]\n    ) / n\n    rng_low  = min(lows)\n    rng_high = max(highs)\n    rng      = rng_high - rng_low\n    close_position_in_range = (closes[-1] - rng_low) / rng if rng > 0 else 0.5\n\n    # --- 趋势强度组 ---\n    ma20 = sum(closes[-20:]) / 20\n    ma20_prev = sum(closes[-21:-1]) / 20\n    ma_slope_20 = (ma20 - ma20_prev) / ma20_prev if ma20_prev != 0 else 0.0\n\n    # ADX-14 简化代理：用HHV/LLV构造\n    tr14 = sum(\n        max(highs[i] - lows[i],\n            abs(highs[i] - closes[i-1]),\n            abs(lows[i]  - closes[i-1]))\n        for i in range(n-14, n)\n    ) / 14\n    dm_plus  = max(highs[-1] - highs[-2], 0)\n    dm_minus = max(lows[-2]  - lows[-1],  0)\n    adx_14 = 25.0 if tr14 == 0 else min(abs(dm_plus - dm_minus) / tr14 * 50, 60)\n\n    # 趋势效率：净推进 / 总波动\n    net_change = closes[-1] - closes[-20]\n    total_move  = sum(abs(closes[i] - closes[i-1]) for i in range(n-19, n))\n    trend_efficiency_ratio = net_change / total_move if total_move > 0 else 0.0\n\n    # --- 突破质量组 ---\n    rng_mid = (rng_high + rng_low) / 2\n    breakout_up_strength = (closes[-1] - rng_high) / rng if rng > 0 else 0.0\n    breakout_down_strength = (rng_low - closes[-1]) / rng if rng > 0 else 0.0\n    breakout_up_strength  = max(breakout_up_strength,  0.0)\n    breakout_down_strength = max(breakout_down_strength, 0.0)\n\n    # 近10根突破失败率\n    fail_count = 0\n    for i in range(max(1, n-10), n):\n        prev_close = closes[i-1]\n        if prev_close < rng_high and closes[i] >= rng_high:\n            # 向上突破尝试——检查是否3根内回落\n            if i+2 < n and max(closes[i:i+3]) < rng_high:\n                fail_count += 1\n        elif prev_close > rng_low and closes[i] <= rng_low:\n            if i+2 < n and min(closes[i:i+3]) > rng_low:\n                fail_count += 1\n    breakout_fail_rate_10 = fail_count / min(10, n-1)\n\n    # 突破后3根跟随评分\n    ft3 = 0.0\n    if breakout_up_strength > 0.35 and n >= 3:\n        gains = [closes[i] - closes[i-1] for i in range(n-2, n)]\n        ft3 = sum(g for g in gains if g > 0) / (sum(abs(g) for g in gains) + 1e-9)\n    follow_through_score_3 = ft3\n\n    # --- 趋势结构组 ---\n    hh = sum(1 for i in range(1, n-1) if closes[i] > closes[i-1] and closes[i] > closes[i+1])\n    hl = sum(1 for i in range(1, n-1) if closes[i] < closes[i-1] and closes[i] < closes[i+1])\n    lh = sum(1 for i in range(1, n-1) if highs[i] < highs[i-1] and highs[i] < highs[i+1])\n    ll = sum(1 for i in range(1, n-1) if lows[i]  > lows[i-1]  and lows[i]  > lows[i+1])\n    higher_high_count_10  = hh\n    higher_low_count_10   = hl\n    lower_high_count_10   = lh\n    lower_low_count_10    = ll\n\n    # 回撤深度（简化版）\n    pullback_depth_ratio = 0.3  # 待接真实数据后改写\n\n    # --- 衰减识别组 ---\n    overlap = sum(1 for i in range(1, n) if max(opens[i], closes[i]) <= min(opens[i-1], closes[i-1]))\n    bar_overlap_ratio_10 = overlap / (n - 1)\n\n    # 新高成功率\n    new_highs = sum(1 for i in range(1, n) if highs[i] > max(highs[:i]))\n    cont_after_high = sum(1 for i in range(1, n-1) if highs[i] > max(highs[:i]) and highs[i] <= highs[i+1])\n    new_high_success_rate_10 = cont_after_high / new_highs if new_highs > 0 else 0.5\n\n    # 趋势腿衰减（简化）\n    trend_leg_length_decay = 0.35\n\n    # --- 市场环境组（原型阶段用占位值） ---\n    relative_strength_vs_index_20 = 0.02\n    sector_strength = 0.5\n    market_breadth  = 0.5\n    style_regime     = \"大盘主导\"\n    limit_up_flag    = 1 if bars[-1].get(\"limit_up\", 0) else 0\n\n    return {\n        \"range_width_20\":                    round(range_width_20, 4),\n        \"inside_range_ratio_20\":             round(inside_range_ratio_20, 4),\n        \"close_position_in_range\":           round(close_position_in_range, 4),\n        \"ma_slope_20\":                       round(ma_slope_20, 6),\n        \"adx_14\":                            round(adx_14, 2),\n        \"trend_efficiency_ratio\":            round(trend_efficiency_ratio, 4),\n        \"breakout_up_strength\":              round(breakout_up_strength, 4),\n        \"breakout_down_strength\":            round(breakout_down_strength, 4),\n        \"breakout_fail_rate_10\":             round(breakout_fail_rate_10, 4),\n        \"follow_through_score_3\":            round(follow_through_score_3, 4),\n        \"higher_high_count_10\":              hh,\n        \"higher_low_count_10\":               hl,\n        \"lower_high_count_10\":              lh,\n        \"lower_low_count_10\":               ll,\n        \"pullback_depth_ratio\":              round(pullback_depth_ratio, 4),\n        \"bar_overlap_ratio_10\":             round(bar_overlap_ratio_10, 4),\n        \"new_high_success_rate_10\":          round(new_high_success_rate_10, 4),\n        \"trend_leg_length_decay\":            round(trend_leg_length_decay, 4),\n        \"relative_strength_vs_index_20\":    round(relative_strength_vs_index_20, 4),\n        \"sector_strength\":                   round(sector_strength, 4),\n        \"market_breadth\":                    round(market_breadth, 4),\n        \"style_regime\":                      style_regime,\n        \"limit_up_flag\":                     limit_up_flag,\n    }\n\n\ndef generate_mock_bars(n: int = 25, trend: str = \"neutral\") -> list[dict]:\n    \"\"\"生成模拟K线用于原型测试。trend: neutral / up / down / exhaustion\"\"\"\n    import random\n    random.seed(42)\n    bars = []\n    base = 100.0\n    for i in range(n):\n        if trend == \"up\":\n            close = base + i * 0.4 + random.gauss(0, 0.3)\n        elif trend == \"down\":\n            close = base - i * 0.3 + random.gauss(0, 0.3)\n        elif trend == \"exhaustion\":\n            close = base + i * 0.1 + random.gauss(0, 0.6)\n        else:\n            close = base + random.gauss(0, 0.5)\n        high  = close + abs(random.gauss(0.2, 0.15))\n        low   = close - abs(random.gauss(0.2, 0.15))\n        bars.append({\"open\": close, \"high\": high, \"low\": low, \"close\": close, \"volume\": 1_000_000})\n    return bars\n\n\n# ── 状态决策 ──────────────────────────────────────────────\n\ndef decide_state(features: dict, schema: dict) -> tuple[str, str, float, list[str], dict]:\n    \"\"\"\n    核心决策函数。\n    返回: (state_code, state_name, confidence, action_hints, trigger_features)\n    \"\"\"\n    thr  = schema[\"threshold_defaults\"]\n    f    = features\n\n    # 辅助\n    is_bullish_structure = (\n        f[\"higher_high_count_10\"] >= thr[\"trend_hh_hl_min_count\"] and\n        f[\"higher_low_count_10\"]  >= thr[\"trend_hh_hl_min_count\"]\n    )\n    is_bearish_structure = (\n        f[\"lower_high_count_10\"] >= thr[\"trend_lh_ll_min_count\"] and\n        f[\"lower_low_count_10\"]  >= thr[\"trend_lh_ll_min_count\"]\n    )\n    is_range = (\n        f[\"inside_range_ratio_20\"] >= thr[\"inside_range_ratio_20_min\"] and\n        f[\"adx_14\"] <= thr[\"adx_14_range_max\"]\n    )\n\n    # ── 突破尝试优先 ─────────────────────────────────────\n    if f[\"breakout_up_strength\"] >= thr[\"breakout_strength_min\"]:\n        # 强向上突破\n        if is_bullish_structure:\n            if f[\"follow_through_score_3\"] >= thr[\"follow_through_score_3_confirm_min\"]:\n                return \"S3\", \"上升趋势延续\", 0.78,\n                       [\"顺势持有\", \"优先做高质量回踩\"],\n                       {\"breakout_up_strength\": f[\"breakout_up_strength\"],\n                        \"higher_high_count_10\": f[\"higher_high_count_10\"],\n                        \"follow_through_score_3\": f[\"follow_through_score_3\"]}\n            else:\n                return \"S1\", \"向上试图突破\", 0.62,\n                       [\"小仓试错\", \"等待后续跟随确认\"],\n                       {\"breakout_up_strength\": f[\"breakout_up_strength\"],\n                        \"follow_through_score_3\": f[\"follow_through_score_3\"]}\n        else:\n            return \"S1\", \"向上试图突破\", 0.55,\n                   [\"等待确认\", \"注意板块共振\"],\n                   {\"breakout_up_strength\": f[\"breakout_up_strength\"]}\n\n    if f[\"breakout_down_strength\"] >= thr[\"breakout_strength_min\"]:\n        if is_bearish_structure:\n            return \"S4\", \"下降趋势延续\", 0.78,\n                   [\"降权或禁做多\", \"组合降风险\"],\n                   {\"breakout_down_strength\": f[\"breakout_down_strength\"],\n                    \"lower_low_count_10\": f[\"lower_low_count_10\"]}\n        else:\n            return \"S2\", \"向下试图突破\", 0.62,\n                   [\"减仓\", \"提高现金权重\"],\n                   {\"breakout_down_strength\": f[\"breakout_down_strength\"]}\n\n    # ── 趋势延续 ─────────────────────────────────────────\n    if is_bullish_structure:\n        if f[\"bar_overlap_ratio_10\"] >= thr[\"bar_overlap_ratio_10_exhaustion_min\"]:\n            return \"S5\", \"趋势衰减/失败突破\", 0.68,\n                   [\"停止追涨\", \"部分止盈\", \"收紧风控\"],\n                   {\"bar_overlap_ratio_10\": f[\"bar_overlap_ratio_10\"],\n                    \"new_high_success_rate_10\": f[\"new_high_success_rate_10\"]}\n        return \"S3\", \"上升趋势延续\", 0.71,\n               [\"顺势持有\", \"优先做高质量回踩\"],\n               {\"higher_high_count_10\": f[\"higher_high_count_10\"],\n                \"higher_low_count_10\": f[\"higher_low_count_10\"]}\n\n    if is_bearish_structure:\n        return \"S4\", \"下降趋势延续\", 0.71,\n               [\"降权或禁做多\", \"优先控制回撤\"],\n               {\"lower_high_count_10\": f[\"lower_high_count_10\"],\n                \"lower_low_count_10\": f[\"lower_low_count_10\"]}\n\n    # ── 衰减识别 ──────────────────────────────────────────\n    if f[\"bar_overlap_ratio_10\"] >= thr[\"bar_overlap_ratio_10_exhaustion_min\"]:\n        return \"S5\", \"趋势衰减/失败突破\", 0.65,\n               [\"停止追涨\", \"部分止盈\", \"收紧风控\"],\n               {\"bar_overlap_ratio_10\": f[\"bar_overlap_ratio_10\"]}\n\n    if f[\"new_high_success_rate_10\"] <= thr[\"new_high_success_rate_10_exhaustion_max\"]:\n        return \"S5\", \"趋势衰减/失败突破\", 0.60,\n               [\"停止追涨\", \"收紧风控\"],\n               {\"new_high_success_rate_10\": f[\"new_high_success_rate_10\"]}\n\n    # ── 区间震荡（默认兜底） ──────────────────────────────\n    return \"S0\", \"平衡震荡\", 0.55,\n           [\"区间边缘参与\", \"中部等待\", \"降低追涨\"],\n           {\"inside_range_ratio_20\": f[\"inside_range_ratio_20\"],\n            \"adx_14\": f[\"adx_14\"]}\n\n\n# ── 标签器主函数 ──────────────────────────────────────────\n\ndef label_state(symbol: str, date: str, bars: list[dict],\n                schema_path: Path = SCHEMA_PATH) -> dict:\n    schema = json.loads(schema_path.read_text(encoding=\"utf-8\"))\n    features = compute_features_from_bars(bars)\n    state_code, state_name, confidence, action_hints, trigger_feats = decide_state(features, schema)\n    return {\n        \"date\":          date,\n        \"symbol\":        symbol,\n        \"state_code\":    state_code,\n        \"state_name\":    state_name,\n        \"confidence\":    confidence,\n        \"action_hint\":   action_hints,\n        \"trigger_features\": trigger_feats,\n        \"features\":      features,   # 完整特征也一并输出\n        \"notes\":         f\"原型脚本v1输出，阈值来自 {schema_path.name}\"\n    }\n\n\n# ── CLI ───────────────────────────────────────────────────\n\nif __name__ == \"__main__\":\n    ap = argparse.ArgumentParser(description=\"阿尔布鲁克斯A股状态标签器原型\")\n    ap.add_argument(\"--symbol\", default=\"600519.SH\")\n    ap.add_argument(\"--date\",   default=\"2026-03-27\")\n    ap.add_argument(\"--trend\",  choices=[\"neutral\",\"up\",\"down\",\"exhaustion\"],\n                    default=\"neutral\", help=\"模拟数据趋势类型\")\n    args = ap.parse_args()\n\n    bars = generate_mock_bars(trend=args.trend)\n    result = label_state(args.symbol, args.date, bars)\n\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":10508,"output":3891,"cacheRead":22332,"cacheWrite":0,"totalTokens":36731,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774573794931,"responseId":"06150be392ecb862db915e5d8f108db2"}}
