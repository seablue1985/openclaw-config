{"type":"message","id":"0e90aaa1","parentId":"c804a665","timestamp":"2026-03-27T03:55:18.669Z","message":{"role":"toolResult","toolCallId":"call_function_xt3i1vnvkz3i_1","toolName":"read","content":[{"type":"text","text":"\n\ndef event_watch_refresh_state(expected_date_tag: str) -> dict[str, Any]:\n    path = REPORT_DIR / \"runtime_risk_state_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_runtime_risk_state\",\n        }\n    payload = load_json(path)\n    report_date = str(payload.get(\"date_tag\") or \"\").strip()\n    event_watch = payload.get(\"event_watch_refresh\") or {}\n    if report_date and report_date != expected_date_tag:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": f\"stale_event_watch_state:{report_date}\",\n        }\n    if not isinstance(event_watch, dict) or not event_watch:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"missing_event_watch_refresh\",\n        }\n    if bool(event_watch.get(\"ok\")):\n        return {\n            \"status\": \"GREEN\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"ok\",\n        }\n    return {\n        \"status\": \"RED\",\n        \"path\": str(path),\n        \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"reason\": f\"event_watch_refresh_failed:returncode={event_watch.get('returncode')}\",\n    }\n\n\ndef live_chain_failure_state(expected_date_tag: str) -> dict[str, Any]:\n    path = REPORT_DIR / \"live_chain_failure_summary_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_live_chain_failure_summary\",\n        }\n    try:\n        payload = json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {\n            \"status\": \"RED\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"invalid_live_chain_failure_summary\",\n        }\n    summary_date = str(payload.get(\"date_tag\") or \"\")\n    if summary_date and summary_date != expected_date_tag:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": f\"stale_live_chain_failure_summary:{summary_date}\",\n        }\n    return {\n        \"status\": str(payload.get(\"overall_status\") or \"YELLOW\"),\n        \"path\": str(path),\n        \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"reason\": str(payload.get(\"reason\") or \"ok\"),\n    }\n\n\ndef manual_review_closure_alert_state(expected_date_tag: str) -> dict[str, Any]:\n    path = REPORT_DIR / \"manual_review_closure_alert_latest.json\"\n    if not path.exists():\n\n[673 more lines in file. Use offset=375 to continue.]"}],"isError":false,"timestamp":1774583718656}}
