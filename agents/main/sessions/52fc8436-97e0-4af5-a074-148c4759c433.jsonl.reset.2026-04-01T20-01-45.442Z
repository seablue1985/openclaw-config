{"type":"message","id":"538d0080","parentId":"26b423cf","timestamp":"2026-03-31T21:19:05.973Z","message":{"role":"toolResult","toolCallId":"call_function_vzdh2q3sou43_1","toolName":"read","content":[{"type":"text","text":"        return RiskConfig(\n            max_total_exposure=choose(\"max_total_exposure\", 1.0),\n            max_single_weight=choose(\"max_single_weight\", 0.10),\n            riskoff_total_exposure=choose(\"riskoff_total_exposure\", 0.65),\n            hard_stop_enabled=choose(\"hard_stop_enabled\", True),\n            allow_new_buy_when_riskoff=choose(\"allow_new_buy_when_riskoff\", False),\n            max_order_to_adv20_ratio=choose(\"max_order_to_adv20_ratio\", 0.02),\n            index_halt_threshold_pct=choose(\"index_halt_threshold_pct\"),\n            market_breadth_riskoff_threshold=choose(\"market_breadth_riskoff_threshold\"),\n            market_breadth_hard_stop_threshold=choose(\"market_breadth_hard_stop_threshold\"),\n            strategy_max_drawdown_riskoff_pct=choose(\"strategy_max_drawdown_riskoff_pct\"),\n            strategy_sharpe_cautious_threshold=choose(\"strategy_sharpe_cautious_threshold\"),\n            blocked_codes=choose(\"blocked_codes\", []),\n            style_rotation_enabled=bool(choose_style(\"enabled\", False)),\n            style_rotation_riskoff_short_excess_pct=choose_style(\"riskoff_short_excess_pct\"),\n            style_rotation_riskoff_medium_excess_pct=choose_style(\"riskoff_medium_excess_pct\"),\n            style_rotation_hard_stop_short_excess_pct=choose_style(\"hard_stop_short_excess_pct\"),\n            style_rotation_hard_stop_medium_excess_pct=choose_style(\"hard_stop_medium_excess_pct\"),\n            style_rotation_hard_stop_requires_negative_smallcap=bool(\n                choose_style(\"hard_stop_requires_negative_smallcap\", True)\n            ),\n        )\n    return RiskConfig(\n        max_total_exposure=parse_float(live_risk_cfg.get(\"max_total_exposure\"), 1.0),\n        max_single_weight=parse_float(live_risk_cfg.get(\"max_single_weight\"), 0.10),\n        riskoff_total_exposure=parse_float(live_risk_cfg.get(\"riskoff_total_exposure\"), 0.65),\n        allow_new_buy_when_riskoff=bool(live_risk_cfg.get(\"allow_new_buy_when_riskoff\", False)),\n        index_halt_threshold_pct=live_risk_cfg.get(\"index_halt_threshold_pct\"),\n        market_breadth_riskoff_threshold=live_risk_cfg.get(\"market_breadth_riskoff_threshold\"),\n        market_breadth_hard_stop_threshold=live_risk_cfg.get(\"market_breadth_hard_stop_threshold\"),\n        strategy_max_drawdown_riskoff_pct=live_risk_cfg.get(\"strategy_max_drawdown_riskoff_pct\"),\n        strategy_sharpe_cautious_threshold=live_risk_cfg.get(\"strategy_sharpe_cautious_threshold\"),\n        style_rotation_enabled=bool(choose_style(\"enabled\", False)),\n        style_rotation_riskoff_short_excess_pct=choose_style(\"riskoff_short_excess_pct\"),\n        style_rotation_riskoff_medium_excess_pct=choose_style(\"riskoff_medium_excess_pct\"),\n        style_rotation_hard_stop_short_excess_pct=choose_style(\"hard_stop_short_excess_pct\"),\n        style_rotation_hard_stop_medium_excess_pct=choose_style(\"hard_stop_medium_excess_pct\"),\n        style_rotation_hard_stop_requires_negative_smallcap=bool(\n            choose_style(\"hard_stop_requires_negative_smallcap\", True)\n        ),\n    )\n\n\ndef merge_exit_signals(approved: pd.DataFrame, exit_signals: pd.DataFrame) -> pd.DataFrame:\n    if approved is None or approved.empty:\n        base = pd.DataFrame()\n    else:\n        base = approved.copy()\n    if exit_signals is None or exit_signals.empty:\n        return base\n\n    exit_signals = exit_signals.copy()\n    exit_codes = {\n        normalize_ts_code(code)\n        for code in exit_signals[\"ts_code\"].fillna(\"\").astype(str).tolist()\n        if normalize_ts_code(code)\n    }\n    if not base.empty and \"signal_type\" in base.columns and \"ts_code\" in base.columns:\n        signal_series = base[\"signal_type\"].fillna(\"\").astype(str).str.upper().str.strip()\n        code_series = base[\"ts_code\"].map(normalize_ts_code)\n        existing_sell_codes = set(code_series[signal_series.isin(SELL_SIGNAL_TYPES)].tolist())\n        exit_signals = exit_signals[\n            ~exit_signals[\"ts_code\"].map(normalize_ts_code).isin(existing_sell_codes)\n        ].copy()\n        all_sell_codes = existing_sell_codes | exit_codes\n        buy_mask = signal_series.isin(BUY_SIGNAL_TYPES) & code_series.isin(all_sell_codes)\n        if bool(buy_mask.any()):\n            base = base.loc[~buy_mask].copy()\n\n    if exit_signals.empty:\n        return base\n\n    combined = pd.concat([base, exit_signals], ignore_index=True, sort=False)\n    if {\"trade_date\", \"ts_code\", \"signal_type\"}.issubset(combined.columns):\n        if \"score\" not in combined.columns:\n            combined[\"score\"] = 0.0\n        combined[\"ts_code\"] = combined[\"ts_code\"].map(normalize_ts_code)\n        combined[\"signal_type\"] = combined[\"signal_type\"].fillna(\"\").astype(str).str.upper().str.strip()\n        combined = combined.sort_values([\"trade_date\", \"ts_code\", \"signal_type\", \"score\"], ascending=[True, True, True, False])\n        combined = combined.drop_duplicates(subset=[\"trade_date\", \"ts_code\", \"signal_type\"], keep=\"first\")\n    return combined.reset_index(drop=True)\n\n\ndef build_orders_frame(approved: pd.DataFrame, *, account_nav: float, available_cash: float, input_path: Path) -> pd.DataFrame:\n    keep_cols = [\n        \"trade_date\",\n        \"ts_code\",\n        \"action\",\n        \"target_value\",\n        \"target_weight\",\n        \"target_qty\",\n        \"ref_price\",\n        \"strategy_id\",\n        \"score\",\n        \"risk_adjustment\",\n        \"risk_status\",\n        \"exit_type\",\n        \"exit_reason\",\n        \"reduce_score\",\n        \"reduce_rank_reason\",\n        \"reason\",\n        \"source_signal_file\",\n        \"generated_at\",\n        \"approved\",\n    ]\n    if approved is None or approved.empty:\n        return pd.DataFrame(columns=keep_cols)\n\n    orders = approved[approved[\"approved\"].fillna(False)].copy() if \"approved\" in approved.columns else approved.copy()\n    if orders.empty:\n        return pd.DataFrame(columns=keep_cols)\n\n    orders[\"signal_type\"] = orders[\"signal_type\"].fillna(\"\").astype(str).str.upper().str.strip()\n    buy_mask = orders[\"signal_type\"].isin(BUY_SIGNAL_TYPES)\n    sell_mask = orders[\"signal_type\"].isin(SELL_SIGNAL_TYPES)\n\n    orders[\"target_value\"] = 0.0\n    if \"target_weight\" in orders.columns:\n        orders[\"target_weight\"] = pd.to_numeric(orders[\"target_weight\"], errors=\"coerce\")\n        orders.loc[buy_mask, \"target_value\"] = orders.loc[buy_mask, \"target_weight\"].fillna(0.0) * account_nav\n\n[244 more lines in file. Use offset=200 to continue.]"}],"isError":false,"timestamp":1774991945965}}
