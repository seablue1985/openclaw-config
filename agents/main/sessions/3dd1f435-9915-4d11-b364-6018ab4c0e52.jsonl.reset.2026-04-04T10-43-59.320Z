tegy_max_dd_pct\",\n      \"strategy_sharpe\",\n      \"annual_return_pct\",\n      \"annual_vol_pct\",\n      \"risk_off\",\n      \"halt_new_buy\"\n    ],\n    \"output_fields\": [\n      \"candidate_approved_rows\",\n      \"candidate_order_rows\",\n      \"candidate_ticket_rows\",\n      \"executable_buy_rows\",\n      \"executable_sell_rows\",\n      \"blocked_buy_halt\",\n      \"blocked_buy_budget_cap\",\n      \"risk_off\",\n      \"halt_new_buy\",\n      \"gross_scale\",\n      \"gate_reasons\",\n      \"root_cause\"\n    ],\n    \"comparison_mode\": \"parallel_shadow\",\n    \"shadow_behavior\": \"不替换 baseline paper orders，只输出 diff 对照\",\n    \"output_file_pattern\": \"paper_shadow_diff_{profile}_{date}.{json,md}\"\n  },\n  \"required_files\": [\n    \"research/reports/live_system_v1_YYYYMMDD.json\",\n    \"research/reports/live_system_v1_combo_curve_YYYYMMDD.csv\",\n    \"research/reports/runtime_risk_state_latest.json\",\n    \"research/reports/dual_factor_formal_params.json\",\n    \"research/reports/dual_factor_robustness_report.json\",\n    \"scripts/run_live_system_v1_dual_shadow.py\",\n    \"scripts/prepare_paper_orders_dual_shadow.py\",\n    \"scripts/integrate_dual_factor_overlay.py\"\n  ],\n  \"new_files_created\": [\n    \"scripts/run_live_system_v1_dual_shadow.py\",\n    \"scripts/prepare_paper_orders_dual_shadow.py\",\n    \"research/reports/dual_factor_gray_readiness.json\"\n  ],\n  \"live_system_side\": {\n    \"new_script\": \"scripts/run_live_system_v1_dual_shadow.py\",\n    \"usage\": \"python3 scripts/run_live_system_v1_dual_shadow.py --profile <off|default|conservative> [--write-artifacts] [--dry-run]\",\n    \"inputs\": [\"research/reports/live_system_v1_YYYYMMDD.json\"],\n    \"outputs\": [\n      \"dual_factor_shadow_*_default_YYYYMMDD_summary.json\",\n      \"dual_factor_shadow_*_default_YYYYMMDD_curve.csv\",\n      \"dual_factor_shadow_*_default_YYYYMMDD_live_payload.json\"\n    ],\n    \"feature_flag_profiles\": {\n      \"off\": 