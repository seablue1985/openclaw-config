{"type":"message","id":"9dc3a56a","parentId":"b7fd5bcb","timestamp":"2026-04-02T23:43:21.527Z","message":{"role":"toolResult","toolCallId":"call_ursLEl406cePThWSiTOFJoFS|fc_0593218ebc10f81b0169ceff1849788198a7210d5802eeb9f6","toolName":"read","content":[{"type":"text","text":"class RiskEngine:\n    BUY_SIGNAL_TYPES = {\"BUY\", \"ADD\", \"INCREASE\", \"OPEN\"}\n    SELL_SIGNAL_TYPES = {\"SELL\", \"REDUCE\", \"EXIT\", \"CLOSE\"}\n\n    def __init__(self, config: RiskConfig):\n        self.config = config\n\n    @staticmethod\n    def _append_adjustment(df: pd.DataFrame, mask: pd.Series, tag: str) -> None:\n        if not bool(mask.any()):\n            return\n        current = df.loc[mask, \"risk_adjustment\"].fillna(\"\").astype(str).str.strip()\n        df.loc[mask, \"risk_adjustment\"] = current.where(current == \"\", current + \"|\") + tag\n\n    @staticmethod\n    def _fmt_threshold_trigger(name: str, current: float, threshold: float, op: str) -> str:\n        return f\"{name}({current:.4f}) {op} {threshold:.4f}\"\n\n    @staticmethod\n    def _style_rotation_trigger(\n        *,\n        short_excess: Optional[float],\n        medium_excess: Optional[float],\n        short_threshold: Optional[float],\n        medium_threshold: Optional[float],\n    ) -> bool:\n        checks: list[bool] = []\n        if short_threshold is not None and short_excess is not None:\n            checks.append(short_excess <= short_threshold)\n        if medium_threshold is not None and medium_excess is not None:\n            checks.append(medium_excess <= medium_threshold)\n        return bool(checks) and all(checks)\n\n    def evaluate_runtime_state(self, context: RiskContext) -> RiskDecision:\n        reasons: list[str] = []\n        hard_stop = bool(context.hard_stop and self.config.hard_stop_enabled)\n        risk_off = bool(context.risk_off)\n        soft_cautious = False\n\n        if context.hard_stop and self.config.hard_stop_enabled:\n            reasons.append(\"manual_hard_stop\")\n        if context.risk_off:\n            reasons.append(\"manual_risk_off\")\n\n        idx_th = self.config.index_halt_threshold_pct\n        idx_ret = context.index_ret_pct\n        if idx_th is not None and idx_ret is not None and idx_ret <= idx_th:\n            hard_stop = True\n            reasons.append(self._fmt_threshold_trigger(\"index_ret_pct\", idx_ret, idx_th, \"<=\"))\n\n        if self.config.style_rotation_enabled:\n            short_excess = context.style_short_excess_pct\n            medium_excess = context.style_medium_excess_pct\n            hard_style_triggered = self._style_rotation_trigger(\n                short_excess=short_excess,\n                medium_excess=medium_excess,\n                short_threshold=self.config.style_rotation_hard_stop_short_excess_pct,\n                medium_threshold=self.config.style_rotation_hard_stop_medium_excess_pct,\n            )\n            if hard_style_triggered:\n                negative_smallcap_checks: list[bool] = []\n                if context.style_smallcap_short_return_pct is not None:\n                    negative_smallcap_checks.append(context.style_smallcap_short_return_pct <= 0)\n                if context.style_smallcap_medium_return_pct is not None:\n                    negative_smallcap_checks.append(context.style_smallcap_medium_return_pct <= 0)\n                if (\n                    (not self.config.style_rotation_hard_stop_requires_negative_smallcap)\n                    or (negative_smallcap_checks and all(negative_smallcap_checks))\n                ):\n                    hard_stop = True\n                    reasons.append(\"style_rotation_hard_stop\")\n\n            if not hard_stop and self._style_rotation_trigger(\n                short_excess=short_excess,\n                medium_excess=medium_excess,\n                short_threshold=self.config.style_rotation_riskoff_short_excess_pct,\n                medium_threshold=self.config.style_rotation_riskoff_medium_excess_pct,\n            ):\n                risk_off = True\n                reasons.append(\"style_rotation_riskoff\")\n\n        breadth = context.market_breadth\n        breadth_hard_th = self.config.market_breadth_hard_stop_threshold\n        breadth_risk_th = self.config.market_breadth_riskoff_threshold\n        if breadth is not None:\n            if breadth_hard_th is not None and breadth <= breadth_hard_th:\n                hard_stop = True\n                reasons.append(self._fmt_threshold_trigger(\"market_breadth\", breadth, breadth_hard_th, \"<=\"))\n            elif breadth_risk_th is not None and breadth <= breadth_risk_th:\n                risk_off = True\n                reasons.append(self._fmt_threshold_trigger(\"market_breadth\", breadth, breadth_risk_th, \"<=\"))\n\n        max_dd = context.strategy_max_drawdown_pct\n        max_dd_th = self.config.strategy_max_drawdown_riskoff_pct\n        if max_dd_th is not None and max_dd is not None and max_dd >= max_dd_th:\n            risk_off = True\n            reasons.append(self._fmt_threshold_trigger(\"strategy_max_drawdown_pct\", max_dd, max_dd_th, \">=\"))\n\n        sharpe = context.strategy_sharpe\n        sharpe_th = self.config.strategy_sharpe_cautious_threshold\n        if sharpe_th is not None and sharpe is not None and sharpe < sharpe_th:\n            soft_cautious = True\n            reasons.append(self._fmt_threshold_trigger(\"strategy_sharpe\", sharpe, sharpe_th, \"<\"))\n\n        if hard_stop:\n            risk_off = True\n            mode = \"halt\"\n            halt_new_buy = True\n        elif risk_off:\n            mode = \"cautious\"\n            halt_new_buy = not self.config.allow_new_buy_when_riskoff\n        elif soft_cautious:\n            mode = \"cautious\"\n            halt_new_buy = False\n        else:\n            mode = \"normal\"\n            halt_new_buy = False\n\n        return RiskDecision(\n            mode=mode,\n            risk_off=risk_off,\n            hard_stop=hard_stop,\n            halt_new_buy=halt_new_buy,\n            reason=reasons[0] if reasons else \"\",\n            reasons=reasons,\n        )\n\n    def _apply_weight_caps(self, df: pd.DataFrame, *, exposure_cap: float) -> pd.DataFrame:\n        if \"target_weight\" not in df.columns:\n            return df\n\n        buy_mask = df[\"signal_type\"].isin(self.BUY_SIGNAL_TYPES)\n        approved_buy_mask = buy_mask & df[\"approved\"].fillna(False)\n\n        if not bool(approved_buy_mask.any()):\n            return df\n\n        df[\"target_weight\"] = pd.to_numeric(df[\"target_weight\"], errors=\"coerce\")\n        df.loc[approved_buy_mask, \"target_weight\"] = (\n            df.loc[approved_buy_mask, \"target_weight\"].fillna(0.0).clip(lower=0.0)\n        )\n\n        single_cap_mask = approved_buy_mask & (df[\"target_weight\"] > self.config.max_single_weight)\n        if bool(single_cap_mask.any()):\n            df.loc[single_cap_mask, \"target_weight\"] = self.config.max_single_weight\n            self._append_adjustment(df, single_cap_mask, \"cap_single_weight\")\n\n        total_buy_weight = float(df.loc[approved_buy_mask, \"target_weight\"].sum())\n        if exposure_cap > 0 and total_buy_weight > exposure_cap:\n            scale = exposure_cap / total_buy_weight\n            df.loc[approved_buy_mask, \"target_weight\"] = df.loc[approved_buy_mask, \"target_weight\"] * scale\n            self._append_adjustment(df, approved_buy_mask, \"scale_total_exposure\")\n\n        return df\n\n    def apply(self, signals: pd.DataFrame, context: RiskContext) -> pd.DataFrame:\n        \"\"\"Apply basic risk rules to standardized signals.\n\n        Expected columns:\n        - trade_date\n\n[64 more lines in file. Use offset=234 to continue.]"}],"isError":false,"timestamp":1775173401516}}
