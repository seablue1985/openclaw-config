{"type":"message","id":"41cca7e1","parentId":"f9dba372","timestamp":"2026-04-03T01:36:31.777Z","message":{"role":"toolResult","toolCallId":"call_EJObrSAwo8Y5kKcL91uMXXQo|fc_00990316fdaeab850169cf199f4f5881989e9fd667b6d5b882","toolName":"exec","content":[{"type":"text","text":"\"files\": {\n            \"registry\": str(REGISTRY_PATH),\n            \"experiment_registry\": str(EXPERIMENT_REGISTRY_PATH),\n            \"owners\": str(OWNERS_PATH),\n            \"incident_template\": str(INCIDENT_TEMPLATE_PATH),\n        },\n        \"incident_template_exists\": incident_template_exists,\n        \"experiment_registry_sync_error\": experiment_sync_error,\n        \"experiment_strategy_summaries\": experiment_registry.get(\"strategy_summaries\") or [],\n        \"registry_rows\": registry_rows,\n        \"ownership_issues\": ownership_issues,\n        \"drawdown_review\": drawdown_review,\n        \"runtime_risk_path\": str(RUNTIME_RISK_PATH),\n        \"drawdown_watch_state_path\": str(DRAWDOWN_WATCH_STATE_PATH),\n        \"blocking_issues\": blocking_issues,\n    }\n\n\ndef render_md(payload: dict[str, Any]) -> str:\n    lines = [\n        \"# Strategy Governance Gate\",\n        \"\",\n        f\"- generated_at: `{payload['generated_at']}`\",\n        f\"- overall_status: `{payload['overall_status']}`\",\n        f\"- incident_template_exists: `{payload['incident_template_exists']}`\",\n        f\"- experiment_registry_sync_error: `{payload.get('experiment_registry_sync_error') or 'none'}`\",\n        \"\",\n        \"## Registry\",\n    ]\n    for row in payload.get(\"registry_rows\", []):\n        lines.append(\n            f\"- {row['strategy_id']}: state=`{row['state']}` owner=`{row['owner_role']}` status=`{row['status']}` issues=`{', '.join(row['issues']) if row['issues'] else 'none'}`\"\n        )\n    lines.extend([\n        \"\",\n        \"## Experiment Registry\",\n    ])\n    for row in payload.get(\"experiment_strategy_summaries\", []):\n        lines.append(\n            f\"- {row['strategy_id']}: ready=`{row['registry_ready']}` missing=`{'|'.join(row['missing_required_experiment_types']) if row['missing_required_experiment_types'] else 'none'}` latest_state=`{row['latest_promotion_state']}` latest_experiment=`{row['latest_experiment_id'] or 'none'}`\"\n        )\n    lines.extend([\n        \"\",\n        \"## Drawdown Review\",\n    ])\n    drawdown = payload.get(\"drawdown_review\") or {}\n    lines.append(\n        f\"- runtime_date_tag=`{drawdown.get('runtime_date_tag', '')}` \"\n        f\"max_dd=`{drawdown.get('strategy_max_drawdown_pct', '-')}` \"\n        f\"threshold=`{drawdown.get('threshold_pct', '-')}` \"\n        f\"trigger_hit=`{drawdown.get('trigger_hit', False)}`\"\n    )\n    for row in drawdown.get(\"rows\") or []:\n        lines.append(\n            f\"- {row['strategy_id']}: review_required=`{row['review_required']}` \"\n            f\"consecutive=`{row['consecutive_trigger_days']}/{row['required_consecutive_days']}` \"\n            f\"owner_signature=`{row['owner_signature']}` conclusion=`{row['review_conclusion']}`\"\n        )\n    lines.extend([\n        \"\",\n        \"## Ownership Issues\",\n    ])\n    if payload.get(\"ownership_issues\"):\n        for issue in payload[\"ownership_issues\"]:\n            lines.append(f\"- {issue}\")\n    else:\n        lines.append(\"- none\")\n    lines.extend([\n        \"\",\n        \"## Blocking Issues\",\n    ])\n    if payload.get(\"blocking_issues\"):\n        for issue in payload[\"blocking_issues\"]:\n            lines.append(f\"- {issue}\")\n    else:\n        lines.append(\"- none\")\n    return \"\\n\".join(lines) + \"\\n\"\n\n\ndef main() -> None:\n    payload = build_payload()\n    runtime_date_tag = str(((payload.get(\"drawdown_review\") or {}).get(\"runtime_date_tag\")) or \"\").strip()\n    date_tag = runtime_date_tag if (len(runtime_date_tag) == 8 and runtime_date_tag.isdigit()) else datetime.now().strftime(\"%Y%m%d\")\n    out_json = REPORT_DIR / f\"strategy_governance_gate_{date_tag}.json\"\n    out_md = REPORT_DIR / f\"strategy_governance_gate_{date_tag}.md\"\n    latest_json = REPORT_DIR / \"strategy_governance_gate_latest.json\"\n    latest_md = REPORT_DIR / \"strategy_governance_gate_latest.md\"\n\n    content = json.dumps(payload, ensure_ascii=False, indent=2)\n    out_json.write_text(content, encoding=\"utf-8\")\n    latest_json.write_text(content, encoding=\"utf-8\")\n    md = render_md(payload)\n    out_md.write_text(md, encoding=\"utf-8\")\n    latest_md.write_text(md, encoding=\"utf-8\")\n    print(json.dumps({\"status\": payload[\"overall_status\"], \"json\": str(out_json), \"md\": str(out_md)}, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()"}],"details":{"status":"completed","exitCode":0,"durationMs":35,"aggregated":"\"files\": {\n            \"registry\": str(REGISTRY_PATH),\n            \"experiment_registry\": str(EXPERIMENT_REGISTRY_PATH),\n            \"owners\": str(OWNERS_PATH),\n            \"incident_template\": str(INCIDENT_TEMPLATE_PATH),\n        },\n        \"incident_template_exists\": incident_template_exists,\n        \"experiment_registry_sync_error\": experiment_sync_error,\n        \"experiment_strategy_summaries\": experiment_registry.get(\"strategy_summaries\") or [],\n        \"registry_rows\": registry_rows,\n        \"ownership_issues\": ownership_issues,\n        \"drawdown_review\": drawdown_review,\n        \"runtime_risk_path\": str(RUNTIME_RISK_PATH),\n        \"drawdown_watch_state_path\": str(DRAWDOWN_WATCH_STATE_PATH),\n        \"blocking_issues\": blocking_issues,\n    }\n\n\ndef render_md(payload: dict[str, Any]) -> str:\n    lines = [\n        \"# Strategy Governance Gate\",\n        \"\",\n        f\"- generated_at: `{payload['generated_at']}`\",\n        f\"- overall_status: `{payload['overall_status']}`\",\n        f\"- incident_template_exists: `{payload['incident_template_exists']}`\",\n        f\"- experiment_registry_sync_error: `{payload.get('experiment_registry_sync_error') or 'none'}`\",\n        \"\",\n        \"## Registry\",\n    ]\n    for row in payload.get(\"registry_rows\", []):\n        lines.append(\n            f\"- {row['strategy_id']}: state=`{row['state']}` owner=`{row['owner_role']}` status=`{row['status']}` issues=`{', '.join(row['issues']) if row['issues'] else 'none'}`\"\n        )\n    lines.extend([\n        \"\",\n        \"## Experiment Registry\",\n    ])\n    for row in payload.get(\"experiment_strategy_summaries\", []):\n        lines.append(\n            f\"- {row['strategy_id']}: ready=`{row['registry_ready']}` missing=`{'|'.join(row['missing_required_experiment_types']) if row['missing_required_experiment_types'] else 'none'}` latest_state=`{row['latest_promotion_state']}` latest_experiment=`{row['latest_experiment_id'] or 'none'}`\"\n        )\n    lines.extend([\n        \"\",\n        \"## Drawdown Review\",\n    ])\n    drawdown = payload.get(\"drawdown_review\") or {}\n    lines.append(\n        f\"- runtime_date_tag=`{drawdown.get('runtime_date_tag', '')}` \"\n        f\"max_dd=`{drawdown.get('strategy_max_drawdown_pct', '-')}` \"\n        f\"threshold=`{drawdown.get('threshold_pct', '-')}` \"\n        f\"trigger_hit=`{drawdown.get('trigger_hit', False)}`\"\n    )\n    for row in drawdown.get(\"rows\") or []:\n        lines.append(\n            f\"- {row['strategy_id']}: review_required=`{row['review_required']}` \"\n            f\"consecutive=`{row['consecutive_trigger_days']}/{row['required_consecutive_days']}` \"\n            f\"owner_signature=`{row['owner_signature']}` conclusion=`{row['review_conclusion']}`\"\n        )\n    lines.extend([\n        \"\",\n        \"## Ownership Issues\",\n    ])\n    if payload.get(\"ownership_issues\"):\n        for issue in payload[\"ownership_issues\"]:\n            lines.append(f\"- {issue}\")\n    else:\n        lines.append(\"- none\")\n    lines.extend([\n        \"\",\n        \"## Blocking Issues\",\n    ])\n    if payload.get(\"blocking_issues\"):\n        for issue in payload[\"blocking_issues\"]:\n            lines.append(f\"- {issue}\")\n    else:\n        lines.append(\"- none\")\n    return \"\\n\".join(lines) + \"\\n\"\n\n\ndef main() -> None:\n    payload = build_payload()\n    runtime_date_tag = str(((payload.get(\"drawdown_review\") or {}).get(\"runtime_date_tag\")) or \"\").strip()\n    date_tag = runtime_date_tag if (len(runtime_date_tag) == 8 and runtime_date_tag.isdigit()) else datetime.now().strftime(\"%Y%m%d\")\n    out_json = REPORT_DIR / f\"strategy_governance_gate_{date_tag}.json\"\n    out_md = REPORT_DIR / f\"strategy_governance_gate_{date_tag}.md\"\n    latest_json = REPORT_DIR / \"strategy_governance_gate_latest.json\"\n    latest_md = REPORT_DIR / \"strategy_governance_gate_latest.md\"\n\n    content = json.dumps(payload, ensure_ascii=False, indent=2)\n    out_json.write_text(content, encoding=\"utf-8\")\n    latest_json.write_text(content, encoding=\"utf-8\")\n    md = render_md(payload)\n    out_md.write_text(md, encoding=\"utf-8\")\n    latest_md.write_text(md, encoding=\"utf-8\")\n    print(json.dumps({\"status\": payload[\"overall_status\"], \"json\": str(out_json), \"md\": str(out_md)}, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1775180191769}}
