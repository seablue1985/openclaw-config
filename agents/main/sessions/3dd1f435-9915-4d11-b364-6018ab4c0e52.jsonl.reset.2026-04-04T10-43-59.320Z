{"type":"message","id":"bdbb0b25","parentId":"1e20e76d","timestamp":"2026-04-02T23:41:37.322Z","message":{"role":"toolResult","toolCallId":"call_LQ73zrDpSD4IP9kvDRMm8z27|fc_0593218ebc10f81b0169cefeb0b9f08198b434f534e65a991f","toolName":"read","content":[{"type":"text","text":"            f\"请先运行 scripts/run_live_system_v1_dual_shadow.py --profile {profile} --write-artifacts\"\n        )\n    return deduped[-1]\n\n\ndef _load_dual_factor_shadow_snapshot(\n    date_tag: str,\n    profile: str,\n    *,\n    config: dict[str, Any] | None = None,\n    report_dir: Path = REPORT_DIR,\n) -> dict[str, Any]:\n    summary_path = _resolve_dual_factor_shadow_summary_path(date_tag, profile, config=config, report_dir=report_dir)\n    summary = load_json(summary_path)\n    profiles = summary.get(\"profiles\") or {}\n    selected = profiles.get(profile) or {}\n    overlay_block = summary.get(\"dual_factor_overlay\") or {}\n    runtime_inputs = (\n        selected.get(\"runtime_shadow_inputs\")\n        or summary.get(\"selected_runtime_shadow_inputs\")\n        or overlay_block.get(\"runtime_shadow_inputs\")\n        or {}\n    )\n    if not runtime_inputs:\n        raise ValueError(f\"dual factor shadow summary 缺少 runtime_shadow_inputs: {summary_path}\")\n    metrics = selected.get(\"metrics\") or overlay_block.get(\"selected_metrics\") or {}\n    latest_state = selected.get(\"latest_state\") or overlay_block.get(\"latest_state\") or {}\n    return {\n        \"profile\": profile,\n        \"summary_path\": summary_path,\n        \"summary\": summary,\n        \"metrics\": metrics,\n        \"latest_state\": latest_state,\n        \"runtime_shadow_inputs\": runtime_inputs,\n    }\n\n\ndef _apply_dual_factor_shadow_live_payload(\n    live_payload: dict[str, Any],\n    *,\n    profile: str,\n    snapshot: dict[str, Any],\n) -> dict[str, Any]:\n    payload = copy.deepcopy(live_payload)\n    combo = dict(payload.get(\"combo_v1\") or {})\n    runtime_inputs = snapshot.get(\"runtime_shadow_inputs\") or {}\n    metrics = snapshot.get(\"metrics\") or {}\n    field_map = {\n        \"strategy_max_dd_pct\": \"max_drawdown_pct\",\n        \"strategy_sharpe\": \"sharpe\",\n        \"annual_return_pct\": \"annual_return_pct\",\n        \"annual_vol_pct\": \"annual_vol_pct\",\n    }\n    for source_field, combo_field in field_map.items():\n        if runtime_inputs.get(source_field) is not None:\n            combo[combo_field] = runtime_inputs.get(source_field)\n    if metrics.get(\"final_equity\") is not None:\n        combo[\"final_equity\"] = metrics.get(\"final_equity\")\n    if metrics.get(\"n\") is not None:\n        combo[\"trading_days\"] = metrics.get(\"n\")\n    payload[\"combo_v1\"] = combo\n\n    overlay_block = dict(payload.get(\"dual_factor_overlay\") or {})\n    overlay_block.update(\n        {\n            \"mode\": \"feature_flag_runtime\",\n            \"status\": \"feature_flag_applied\",\n            \"feature_flag_profile\": profile,\n            \"runtime_shadow_inputs\": runtime_inputs,\n            \"selected_metrics\": metrics,\n            \"latest_state\": snapshot.get(\"latest_state\") or {},\n            \"shadow_summary\": str(snapshot.get(\"summary_path\") or \"\"),\n        }\n    )\n    payload[\"dual_factor_overlay\"] = overlay_block\n    return payload\n\n\n_INTRADAY_BREADTH_CACHE: dict[str, float | None] = {}\n_INTRADAY_INDEX_RETURN_CACHE: dict[str, float | None] = {}\n_INTRADAY_INDEX_MAP: dict[str, dict[str, str]] = {\n    \"ZZ2000\": {\"fetch_code\": \"000852.SH\", \"symbol\": \"sh000852\"},\n    \"HS300\": {\"fetch_code\": \"000300.SH\", \"symbol\": \"sh000300\"},\n    \"ZZ500\": {\"fetch_code\": \"000905.SH\", \"symbol\": \"sh000905\"},\n    \"CYB\": {\"fetch_code\": \"399006.SZ\", \"symbol\": \"sz399006\"},\n}\n_TENCENT_FIRST_INDEX_CODES = {\"HS300\"}\n\n\ndef _fetch_realtime_index_return_pct(benchmark_code: str) -> float | None:\n    normalized_code = str(benchmark_code or \"ZZ2000\").strip().upper() or \"ZZ2000\"\n    mapping = _INTRADAY_INDEX_MAP.get(normalized_code)\n    if mapping is None:\n        return None\n\n    if normalized_code in _INTRADAY_INDEX_RETURN_CACHE:\n        return _INTRADAY_INDEX_RETURN_CACHE[normalized_code]\n\n    if normalized_code in _TENCENT_FIRST_INDEX_CODES:\n        try:\n            from intraday_market_gate import fetch_tencent_quote\n\n            payload = fetch_tencent_quote(mapping[\"symbol\"])\n            if payload and payload.get(\"valid\"):\n                change_pct = parse_optional_float(payload.get(\"change_pct\"))\n                if change_pct is not None:\n                    resolved = round(float(change_pct), 4)\n                    logging.info(\n                        \"[load_index_return_pct_for_date] 使用腾讯直连实时源 %s=%+.4f%%\",\n                        normalized_code,\n                        resolved,\n                    )\n                    _INTRADAY_INDEX_RETURN_CACHE[normalized_code] = resolved\n                    return resolved\n        except Exception as exc:\n            logging.info(\"[load_index_return_pct_for_date] 腾讯直连指数获取异常: %s\", exc)\n\n    resolved: float | None = None\n    try:\n        from intraday_market_gate import _get_unified_fetcher\n\n[379 more lines in file. Use offset=260 to continue.]"}],"isError":false,"timestamp":1775173297312}}
