{"type":"message","id":"f8319c86","parentId":"948ce47a","timestamp":"2026-04-03T01:37:38.466Z","message":{"role":"toolResult","toolCallId":"call_hEmw8SEfR0F6wqC3efd6RJvJ|fc_00990316fdaeab850169cf19e1d2d0819896c9031a926845b8","toolName":"exec","content":[{"type":"text","text":"for profile_slug in TRACKED_ACCOUNT_PROFILES:\n        account_payload = load_json(REPORT_DIR / f\"paper_{profile_slug}_account_v1_latest.json\")\n        account_date_tag = str(account_payload.get(\"date_tag\") or \"\").strip()\n        if len(account_date_tag) == 8 and account_date_tag.isdigit() and account_date_tag <= normalized:\n            candidates.append((f\"paper_account:{profile_slug}\", account_date_tag))\n\n    if not candidates:\n        return {\"date_tag\": normalized, \"source\": \"wall_clock\"}\n\n    source, date_tag = max(candidates, key=lambda item: item[1])\n    return {\"date_tag\": date_tag, \"source\": source}\n\n\ndef governance_gate_state() -> dict[str, Any]:\n    path = REPORT_DIR / \"strategy_governance_gate_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"RED\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_governance_gate_report\",\n            \"report_status\": \"MISSING\",\n            \"blocking_issues\": [\"missing_governance_gate_report\"],\n            \"registry_rows\": [],\n        }\n\n    try:\n        payload = json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {\n            \"status\": \"RED\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"invalid_governance_gate_report\",\n            \"report_status\": \"INVALID\",\n            \"blocking_issues\": [\"invalid_governance_gate_report\"],\n            \"registry_rows\": [],\n        }\n\n    mtime = datetime.fromtimestamp(path.stat().st_mtime)\n    age_hours = (datetime.now() - mtime).total_seconds() / 3600.0\n    report_status = str(payload.get(\"overall_status\") or \"UNKNOWN\").upper()\n    blocking_issues = [str(x).strip() for x in (payload.get(\"blocking_issues\") or []) if str(x).strip()]\n    stale = age_hours > 72\n    if stale:\n        blocking_issues.append(\"stale_governance_gate_report\")\n    status = \"GREEN\" if report_status == \"PASS\" and not blocking_issues else \"RED\"\n    if blocking_issues:\n        reason = f\"blocking:{blocking_issues[0]}\"\n    elif report_status == \"PASS\":\n        reason = \"ok\"\n    else:\n        reason = f\"report_status={report_status.lower()}\"\n    return {\n        \"status\": status,\n        \"path\": str(path),\n        \"mtime\": mtime.strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"reason\": reason,\n        \"report_status\": report_status,\n        \"blocking_issues\": blocking_issues,\n        \"registry_rows\": payload.get(\"registry_rows\") or [],"}],"details":{"status":"completed","exitCode":0,"durationMs":60,"aggregated":"for profile_slug in TRACKED_ACCOUNT_PROFILES:\n        account_payload = load_json(REPORT_DIR / f\"paper_{profile_slug}_account_v1_latest.json\")\n        account_date_tag = str(account_payload.get(\"date_tag\") or \"\").strip()\n        if len(account_date_tag) == 8 and account_date_tag.isdigit() and account_date_tag <= normalized:\n            candidates.append((f\"paper_account:{profile_slug}\", account_date_tag))\n\n    if not candidates:\n        return {\"date_tag\": normalized, \"source\": \"wall_clock\"}\n\n    source, date_tag = max(candidates, key=lambda item: item[1])\n    return {\"date_tag\": date_tag, \"source\": source}\n\n\ndef governance_gate_state() -> dict[str, Any]:\n    path = REPORT_DIR / \"strategy_governance_gate_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"RED\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_governance_gate_report\",\n            \"report_status\": \"MISSING\",\n            \"blocking_issues\": [\"missing_governance_gate_report\"],\n            \"registry_rows\": [],\n        }\n\n    try:\n        payload = json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {\n            \"status\": \"RED\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"invalid_governance_gate_report\",\n            \"report_status\": \"INVALID\",\n            \"blocking_issues\": [\"invalid_governance_gate_report\"],\n            \"registry_rows\": [],\n        }\n\n    mtime = datetime.fromtimestamp(path.stat().st_mtime)\n    age_hours = (datetime.now() - mtime).total_seconds() / 3600.0\n    report_status = str(payload.get(\"overall_status\") or \"UNKNOWN\").upper()\n    blocking_issues = [str(x).strip() for x in (payload.get(\"blocking_issues\") or []) if str(x).strip()]\n    stale = age_hours > 72\n    if stale:\n        blocking_issues.append(\"stale_governance_gate_report\")\n    status = \"GREEN\" if report_status == \"PASS\" and not blocking_issues else \"RED\"\n    if blocking_issues:\n        reason = f\"blocking:{blocking_issues[0]}\"\n    elif report_status == \"PASS\":\n        reason = \"ok\"\n    else:\n        reason = f\"report_status={report_status.lower()}\"\n    return {\n        \"status\": status,\n        \"path\": str(path),\n        \"mtime\": mtime.strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"reason\": reason,\n        \"report_status\": report_status,\n        \"blocking_issues\": blocking_issues,\n        \"registry_rows\": payload.get(\"registry_rows\") or [],","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1775180258454}}
{"type":"message","id":"bd34ccd2","parentId":"f8319c86","timestamp":"2026-04-03T01:37:38.479Z","message":{"role":"toolResult","toolCallId":"call_2I5wakEeYmeOG9iW3ZY66y5v|fc_00990316fdaeab850169cf19e1d2dc819890071d27b69ec21c","toolName":"exec","content":[{"type":"text","text":"def latest_or_exact(pattern_prefix: str, date_tag: str, suffix: str) -> Path | None:\n    exact = REPORT_DIR / f\"{pattern_prefix}_{date_tag}.{suffix}\"\n    if exact.exists():\n        return exact\n    candidates = sorted(REPORT_DIR.glob(f\"{pattern_prefix}_*.{suffix}\"))\n    if not candidates:\n        return None\n    eligible = [path for path in candidates if path.stem.rsplit(\"_\", 1)[-1] <= date_tag]\n    return eligible[-1] if eligible else candidates[-1]\n\n\ndef governance_gate_status(date_tag: str) -> dict[str, Any]:\n    path = latest_or_exact(\"strategy_governance_gate\", date_tag, \"json\") or (REPORT_DIR / \"strategy_governance_gate_latest.json\")\n    payload = load_json(path if path and path.exists() else None)\n    if not payload:\n        return {\n            \"report_status\": \"MISSING\",\n            \"blocking\": True,\n            \"issues\": [\"missing_governance_gate_report\"],\n            \"path\": str(path) if path else \"\",\n            \"generated_at\": \"\",\n        }\n    report_status = str(payload.get(\"overall_status\") or \"UNKNOWN\").upper()\n    issues = [str(item).strip() for item in (payload.get(\"blocking_issues\") or []) if str(item).strip()]\n    return {\n        \"report_status\": report_status,\n        \"blocking\": report_status != \"PASS\" or bool(issues),\n        \"issues\": issues,\n        \"path\": str(path) if path else \"\",\n        \"generated_at\": str(payload.get(\"generated_at\") or \"\"),\n    }\n\n\ndef to_float(value: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(value).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef to_bool(value: Any) -> bool:"}],"details":{"status":"completed","exitCode":0,"durationMs":72,"aggregated":"def latest_or_exact(pattern_prefix: str, date_tag: str, suffix: str) -> Path | None:\n    exact = REPORT_DIR / f\"{pattern_prefix}_{date_tag}.{suffix}\"\n    if exact.exists():\n        return exact\n    candidates = sorted(REPORT_DIR.glob(f\"{pattern_prefix}_*.{suffix}\"))\n    if not candidates:\n        return None\n    eligible = [path for path in candidates if path.stem.rsplit(\"_\", 1)[-1] <= date_tag]\n    return eligible[-1] if eligible else candidates[-1]\n\n\ndef governance_gate_status(date_tag: str) -> dict[str, Any]:\n    path = latest_or_exact(\"strategy_governance_gate\", date_tag, \"json\") or (REPORT_DIR / \"strategy_governance_gate_latest.json\")\n    payload = load_json(path if path and path.exists() else None)\n    if not payload:\n        return {\n            \"report_status\": \"MISSING\",\n            \"blocking\": True,\n            \"issues\": [\"missing_governance_gate_report\"],\n            \"path\": str(path) if path else \"\",\n            \"generated_at\": \"\",\n        }\n    report_status = str(payload.get(\"overall_status\") or \"UNKNOWN\").upper()\n    issues = [str(item).strip() for item in (payload.get(\"blocking_issues\") or []) if str(item).strip()]\n    return {\n        \"report_status\": report_status,\n        \"blocking\": report_status != \"PASS\" or bool(issues),\n        \"issues\": issues,\n        \"path\": str(path) if path else \"\",\n        \"generated_at\": str(payload.get(\"generated_at\") or \"\"),\n    }\n\n\ndef to_float(value: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(value).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef to_bool(value: Any) -> bool:","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1775180258466}}
