r_orders_dual_shadow.py","offset":320,"limit":120},"partialJson":"{\"file\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/prepare_paper_orders_dual_shadow.py\",\"offset\":320,\"limit\":120}"},{"type":"toolCall","id":"call_T5wqaybfArQbyqF7PfI0uVGo|fc_0593218ebc10f81b0169cefe950af4819889fb9b15e15b35be","name":"read","arguments":{"file":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/prepare_paper_orders_dual_shadow.py","offset":470,"limit":110},"partialJson":"{\"file\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/prepare_paper_orders_dual_shadow.py\",\"offset\":470,\"limit\":110}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":489,"output":209,"cacheRead":69120,"cacheWrite":0,"totalTokens":69818,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775173262956,"responseId":"resp_0593218ebc10f81b0169cefe8fdb40819891a5f41dcfe09ad7"}}
{"type":"message","id":"5331ca55","parentId":"d0b1d9c1","timestamp":"2026-04-02T23:41:09.899Z","message":{"role":"toolResult","toolCallId":"call_adpoyLFl1rHaLVdX0CyARWwG|fc_0593218ebc10f81b0169cefe950ad88198bc8ef5956dbdfe76","toolName":"read","content":[{"type":"text","text":"    combo = live_payload.get(\"combo_v1\") or {}\n    if not path.exists():\n        return {\n            \"source\": \"live_system_v1\",\n            \"path\": str(path),\n            \"strategy_max_dd_pct\": combo.get(\"max_drawdown_pct\"),\n            \"strategy_sharpe\": combo.get(\"sharpe\"),\n            \"annual_return_pct\": combo.get(\"annual_return_pct\"),\n            \"annual_vol_pct\": combo.get(\"annual_vol_pct\"),\n            \"risk_off\": None,\n            \"halt_new_buy\": None,\n            \"gate_reasons\": [],\n        }\n    payload = load_json(path)\n    if str(payload.get(\"date_tag\") or \"\") != str(date_tag):\n        return {\"source\": \"\", \"path\": str(path), \"date_mismatch\": True}\n    runtime_metrics = payload.get(\"runtime_metrics\") or {}\n    latest = payload.get(\"latest_runtime\") or {}\n    return {\n        \"source\": f\"runtime_risk_state_latest{suffix}\",\n        \"path\": str(path),\n        \"strategy_max_dd_pct\": runtime_metrics.get(\"strategy_max_dd_pct\", combo.get(\"max_drawdown_pct\")),\n        \"strategy_sharpe\": runtime_metrics.get(\"strategy_sharpe\", combo.get(\"sharpe\")),\n        \"annual_return_pct\": runtime_metrics.get(\"annual_return_pct\", combo.get(\"annual_return_pct\")),\n        \"annual_vol_pct\": runtime_metrics.get(\"annual_vol_pct\", combo.get(\"annual_vol_pct\")),\n        \"risk_off\": latest.get(\"risk_off\", False),\n        \"halt_new_buy\": latest.get(\"halt_new_buy\", False),\n        \"gate_reasons\": latest.get(\"gate_reasons\", []),\n    }\n\n\ndef resolve_shadow_runtime_metrics(summary: dict[str, Any], profile: str) -> dict[str, Any]:\n    selected = ((summary.get(\"profiles\") or {}).get(profile) or {})\n    overlay_block = summary.get(\"dual_factor_overlay\") or {}\n    runtime_inputs = (\n        selected.get(\"runtime_shadow_inputs\")\n        or summary.get(\"selected_runtime_shadow_inputs\")\n        or overlay_block.get(\"runtime_shadow_inputs\")\n        or {}\n    )\n    metrics = selected.get(\"metrics\") or overlay_block.get(\"selected_metrics\") or {}\n    latest_state = selected.get(\"latest_state\") or overlay_block.get(\"latest_state\") or {}\n    return {\n        \"strategy_max_dd_pct\": runtime_inputs.get(\"strategy_max_dd_pct\"),\n        \"strategy_sharpe\": runtime_inputs.get(\"strategy_sharpe\"),\n        \"annual_return_pct\": runtime_inputs.get(\"annual_return_pct\"),\n        \"annual_vol_pct\": runtime_inputs.get(\"annual_vol_pct\"),\n        \"risk_off\": None,\n        \"halt_new_buy\": None,\n        \"gate_reasons\": [],\n        \"latest_state\": latest_state,\n        \"metrics\": metrics,\n    }\n\n\ndef build_runtime_comparison(baseline_metrics: dict[str, Any], dual_metrics: dict[str, Any]) -> dict[str, Any]:\n    rows = []\n    metric_rows = [\n        (\"strategy_max_dd_pct\", \"策略最大回撤(%)\"),\n        (\"strategy_sharpe\", \"策略夏普\"),\n        (\"annual_return_pct\", \"策略年化收益(%)\"),\n        (\"annual_vol_pct\", \"策略年化波动(%)\"),\n    ]\n    for field, label in metric_rows:\n        baseline = baseline_metrics.get(field)\n        dual = dual_metrics.get(field)\n        try:\n            diff = round(float(dual) - float(baseline), 4)\n        except Exception:\n            diff = None\n        rows.append({\n            \"field\": field,\n            \"label\": label,\n            \"baseline\": baseline,\n            \"dual_factor\": dual,\n            \"diff\": diff,\n        })\n    for field, label in [(\"risk_off\", \"risk_off\"), (\"halt_new_buy\", \"halt_new_buy\")]:\n        rows.append({\n            \"field\": field,\n            \"label\": label,\n            \"baseline\": baseline_metrics.get(field),\n            \"dual_factor\": dual_metrics.get(field),\n            \"diff\": \"变化\" if baseline_metrics.get(field) != dual_metrics.get(field) else \"不变\",\n        })\n    return {\n        \"rows\": rows,\n        \"note\": \"diff = dual_factor - baseline；回撤/波动为负数更优，收益/夏普为正数更优\",\n    }\n\n\n[351 more lines in file. Use offset=230 to continue.]"}],"isError":false,"timestamp":1775173269889}}
{"type":"message","id":"0447f673","parentId":"5331ca55","timestamp":"2026-04-02T23:41:09.909Z","message":{"role":"toolResult","toolCallId":"call_9PHm5Hco6cIA312c1NNmy4bf|fc_0593218ebc10f81b0169cefe950ae881988c0cba5e54bbcd62","toolName":"read","content":[{"type":"text","text":"        \"baseline_order_diagnostics\": nested_get(baseline_plan, \"files\", \"order_diagnostics_json\"),\n        \"dual_order_diagnostics\": nested_get(dual_plan, \"files\", \"order_diagnostics_json\"),\n    }\n\n\ndef summarize_findings(runtime_comparison: dict[str, Any], paper_diff: dict[str, Any]) -> list[str]:\n    findings: list[str] = []\n    diff_map = {row[\"field\"]: row for row in runtime_comparison.get(\"rows\", [])}\n    dd_diff = diff_map.get(\"strategy_max_dd_pct\", {}).get(\"diff\")\n    sharpe_diff = diff_map.get(\"strategy_sharpe\", {}).get(\"diff\")\n    ann_diff = diff_map.get(\"annual_return_pct\", {}).get(\"diff\")\n    if isinstance(dd_diff, (int, float)):\n        findings.append(\n            f\"{'✅' if dd_diff < 0 else '⚠️'} 双因子 runtime 回撤{'改善' if dd_diff < 0 else '恶化'} {abs(dd_diff):.2f}pp\"\n        )\n    if isinstance(sharpe_diff, (int, float)) and sharpe_diff != 0:\n        findings.append(\n            f\"{'✅' if sharpe_diff > 0 else '⚠️'} 双因子 runtime 夏普{'提升' if sharpe_diff > 0 else '下降'} {abs(sharpe_diff):.3f}\"\n        )\n    if isinstance(ann_diff, (int, float)) and ann_diff != 0:\n        findings.append(\n            f\"{'✅' if ann_diff > 0 else '⚠️'} 双因子 runtime 年化{'提升' if ann_diff > 0 else '下降'} {abs(ann_diff):.2f}pp\"\n        )\n\n    plan_rows = {row[\"path\"]: row for row in paper_diff.get(\"rows\", [])}\n    blocked = plan_rows.get(\"stats.blocked_buy_halt\")\n    if blocked:\n        try:\n            delta = int(blocked.get(\"dual_factor\") or 0) - int(blocked.get(\"baseline\") or 0)\n        except Exception:\n            delta = None\n        if delta is not None and delta > 0:\n            findings.append(f\"⚠️ 双因子纸盘计划多拦截 {delta} 个买入（blocked_buy_halt）\")\n        elif delta is not None and delta < 0:\n            findings.append(f\"✅ 双因子纸盘计划少拦截 {abs(delta)} 个买入（blocked_buy_halt）\")\n\n    buy_count = plan_rows.get(\"stats.buy_count\")\n    if buy_count:\n        try:\n            delta = int(buy_count.get(\"dual_factor\") or 0) - int(buy_count.get(\"baseline\") or 0)\n        except Exception:\n            delta = None\n        if delta is not None and delta != 0:\n            findings.append(f\"ℹ️ 实际 buy_count 差异：dual-baseline = {delta}\")\n\n    if not findings:\n        findings.append(\"ℹ️ 本次 baseline 与 dual factor 实际纸盘计划差异有限，需继续多日观察\")\n    return findings\n\n\ndef build_result(\n    *,\n    profile: str,\n    date_tag: str,\n    live_json_path: Path,\n    shadow_summary_path: Path,\n    baseline_runtime: dict[str, Any],\n    dual_runtime: dict[str, Any],\n    baseline_plan: dict[str, Any],\n    dual_plan: dict[str, Any],\n    runtime_comparison: dict[str, Any],\n    paper_diff: dict[str, Any],\n    output_files: dict[str, str],\n) -> dict[str, Any]:\n    findings = summarize_findings(runtime_comparison, paper_diff)\n    return {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"status\": \"paper_shadow_parallel_ready\",\n        \"date_tag\": date_tag,\n        \"feature_flag\": {\n            \"field\": \"dual_factor_profile\",\n            \"baseline\": \"off\",\n            \"dual_factor\": profile,\n            \"valid_values\": [\"off\", \"default\", \"conservative\"],\n        },\n        \"baseline_live_json\": str(live_json_path),\n        \"shadow_summary\": str(shadow_summary_path),\n        \"baseline_runtime\": baseline_runtime,\n        \"dual_runtime\": dual_runtime,\n        \"runtime_comparison\": runtime_comparison,\n        \"paper_order_diff\": paper_diff,\n        \"baseline_plan_ref\": {\n            \"config\": baseline_plan.get(\"config\"),\n            \"files\": baseline_plan.get(\"files\") or {},\n            \"feature_flags\": baseline_plan.get(\"feature_flags\") or {},\n        },\n        \"dual_plan_ref\": {\n            \"config\": dual_plan.get(\"config\"),\n            \"files\": dual_plan.get(\"files\") or {},\n            \"feature_flags\": dual_plan.get(\"feature_flags\") or {},\n        },\n        \"key_findings\": findings,\n        \"guardrails\": [\n            \"dual factor 仍保持 feature flag 灰度，不替换 baseline 主链路\",\n            \"先看多日 shadow diff，再决定是否在单纸盘打开 dual_factor_profile=default\",\n            \"一旦出现 runtime 指标新鲜度异常或误停，立即回退 dual_factor_profile=off\",\n        ],\n        \"can_start_single_paper_gray\": True,\n        \"single_paper_gray_conditions\": [\n            \"默认保持 dual_factor_profile=off\",\n            \"仅在单纸盘/单 profile 上切到 dual_factor_profile=default 或 conservative\",\n            \"继续保留 baseline 与 dual 两套日志/plan_json/order_diagnostics 并行对照\",\n        ],\n        \"next_steps\": [\n            \"1. 先用 conservative/default 在单纸盘做多日 shadow 对照\",\n            \"2. 重点复核 blocked_buy_halt / buy_count / order_diagnostics 根因变化\",\n            \"3. 若连续验证稳定，再把 feature flag 提升到固定 profile 灰度\",\n        ],\n        \"output_files\": output_files,\n    }\n\n\ndef write_md(path: Path, result: dict[str, Any]) -> None:\n    lines = [\n        f\"# 纸盘 Dual Factor Shadow 并行验证（{result.get('date_tag')} / {result.get('feature_flag', {}).get('dual_factor')}）\",\n        \"\",\n        \"## 关键结论\",\n        *(f\"- {item}\" for item in result.get(\"key_findings\", [])),\n        \"\",\n        \"## Runtime 对照\",\n\n[141 more lines in file. Use offset=440 to continue.]"}],"isError":false,"timestamp":1775173269900}}
{"type":"message","id":"c6388d77","parentId":"0447f673","timestamp":"2026-04-02T23:41:09.919Z","message":{"role":"toolResult","toolCallId":"call_T5wqaybfArQbyqF7PfI0uVGo|fc_0593218ebc10f81b0169cefe950af4819889fb9b15e15b35be","toolName":"read","content":[{"type":"text","text":"    if profile not in VALID_PROFILES:\n        raise ValueError(f\"无效 profile={profile}\")\n    if profile == \"off\":\n        raise ValueError(\"paper shadow wrapper 需要 dual profile=default/conservative；baseline 固定为 off\")\n\n    live_json_path = Path(args.live_json).expanduser().resolve() if args.live_json else discover_latest_live_json()\n    live_payload = load_json(live_json_path)\n    date_tag = parse_date_tag(args.date) if args.date else parse_date_tag(str(live_payload.get(\"date\") or datetime.now().strftime(\"%Y%m%d\")))\n\n    shadow_summary_path = ensure_shadow_summary(\n        date_tag=date_tag,\n        profile=profile,\n        live_json_path=live_json_path,\n        supplied_path=args.shadow_summary,\n    )\n    shadow_summary = load_json(shadow_summary_path)\n\n    paper_cfg = load_json(Path(args.config).expanduser().resolve())\n    profile_slug = str(paper_cfg.get(\"profile_slug\") or \"\").strip().lower()\n    baseline_runtime = resolve_baseline_runtime_metrics(date_tag, profile_slug=profile_slug)\n    dual_runtime = resolve_shadow_runtime_metrics(shadow_summary, profile)\n    runtime_comparison = build_runtime_comparison(baseline_runtime, dual_runtime)\n\n    config_path = str(Path(args.config).expanduser().resolve())\n    baseline_plan = run_paper_orders(\n        config_path=config_path,\n        date_tag=date_tag,\n        dual_factor_profile=\"off\",\n        merged_signals=args.merged_signals,\n        tickets=args.tickets,\n    )\n    if int(baseline_plan.get(\"_returncode\", 1)) != 0:\n        raise RuntimeError(\n            f\"baseline paper run 失败: stderr={baseline_plan.get('_stderr', '')} stdout={baseline_plan.get('_stdout', '')}\"\n        )\n    baseline_snapshots = snapshot_plan_artifacts(\n        baseline_plan,\n        label=\"baseline\",\n        profile=profile,\n        date_tag=date_tag,\n    ) if args.write_artifacts and not args.dry_run else {}\n\n    dual_plan = run_paper_orders(\n        config_path=config_path,\n        date_tag=date_tag,\n        dual_factor_profile=profile,\n        merged_signals=args.merged_signals,\n        tickets=args.tickets,\n    )\n    if int(dual_plan.get(\"_returncode\", 1)) != 0:\n        raise RuntimeError(\n            f\"dual paper run 失败: stderr={dual_plan.get('_stderr', '')} stdout={dual_plan.get('_stdout', '')}\"\n        )\n    dual_snapshots = snapshot_plan_artifacts(\n        dual_plan,\n        label=\"dual\",\n        profile=profile,\n        date_tag=date_tag,\n    ) if args.write_artifacts and not args.dry_run else {}\n\n    paper_diff = build_paper_shadow_diff(baseline_plan, dual_plan)\n    if baseline_snapshots.get(\"plan_json\"):\n        paper_diff[\"baseline_plan_json\"] = baseline_snapshots.get(\"plan_json\")\n    if dual_snapshots.get(\"plan_json\"):\n        paper_diff[\"dual_plan_json\"] = dual_snapshots.get(\"plan_json\")\n    if baseline_snapshots.get(\"order_diagnostics_json\"):\n        paper_diff[\"baseline_order_diagnostics\"] = baseline_snapshots.get(\"order_diagnostics_json\")\n    if dual_snapshots.get(\"order_diagnostics_json\"):\n        paper_diff[\"dual_order_diagnostics\"] = dual_snapshots.get(\"order_diagnostics_json\")\n    output_files: dict[str, str] = {\n        \"baseline_plan_json\": str(baseline_snapshots.get(\"plan_json\") or (baseline_plan.get(\"files\") or {}).get(\"plan_json\") or \"\"),\n        \"dual_plan_json\": str(dual_snapshots.get(\"plan_json\") or (dual_plan.get(\"files\") or {}).get(\"plan_json\") or \"\"),\n        \"baseline_order_diagnostics\": str(baseline_snapshots.get(\"order_diagnostics_json\") or (baseline_plan.get(\"files\") or {}).get(\"order_diagnostics_json\") or \"\"),\n        \"dual_order_diagnostics\": str(dual_snapshots.get(\"order_diagnostics_json\") or (dual_plan.get(\"files\") or {}).get(\"order_diagnostics_json\") or \"\"),\n    }\n    for key, value in baseline_snapshots.items():\n        output_files[f\"baseline_{key}\"] = value\n    for key, value in dual_snapshots.items():\n        output_files[f\"dual_{key}\"] = value\n\n    result = build_result(\n        profile=profile,\n        date_tag=date_tag,\n        live_json_path=live_json_path,\n        shadow_summary_path=shadow_summary_path,\n        baseline_runtime=baseline_runtime,\n        dual_runtime=dual_runtime,\n        baseline_plan=baseline_plan,\n        dual_plan=dual_plan,\n        runtime_comparison=runtime_comparison,\n        paper_diff=paper_diff,\n        output_files=output_files,\n    )\n\n    if args.write_artifacts and not args.dry_run:\n        json_path = REPORT_DIR / f\"paper_shadow_diff_{profile}_{date_tag}.json\"\n        md_path = REPORT_DIR / f\"paper_shadow_diff_{profile}_{date_tag}.md\"\n        json_path.write_text(json.dumps(result, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n        write_md(md_path, result)\n        result[\"output_files\"] = dict(result.get(\"output_files\") or {})\n        result[\"output_files\"].update({\n            \"shadow_diff\": str(json_path),\n            \"shadow_diff_md\": str(md_path),\n        })\n\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()\n\n[1 more lines in file. Use offset=580 to continue.]"}],"isError":false,"timestamp":1775173269909}}
