rd\": {\n          \"test_annual_return_pct_mean\": 20.99,\n          \"test_sharpe_mean\": 1.617,\n          \"test_max_drawdown_pct_mean\": 6.48,\n          \"test_total_return_pct_mean\": 8.74,\n          \"test_folds\": 8\n        },\n        \"full_backtest\": {\n          \"annual_return_pct\": 15.21,\n          \"sharpe\": 1.148,\n          \"max_drawdown_pct\": 37.85,\n          \"total_return_pct\": 360.19\n        }\n      }\n    },\n    {\n      \"strategy_id\": \"smallcap_chip_v4_2_alpha_recover\",\n      \"current_state\": \"candidate\",\n      \"current_role\": \"当前主候选 / 参与率修复主方向\",\n      \"suggested_action\": \"降级\",\n      \"review_conclusion\": \"downgrade_to_watch_candidate\",\n      \"owner_role\": \"research_owner\",\n      \"signoff_roles\": [\"research_owner\", \"risk_owner\"],\n      \"reason_summary\": [\n        \"实验表现仍强，是 smallcap 候选组里更优的一支\",\n        \"但已连续 3/3 触发 drawdown review required\",\n        \"继续保留主候选定位会与当前治理门禁冲突\"\n      ],\n      \"execution_actions\": [\n        \"从当前主候选降级为观察候选\",\n        \"暂停其作为近期晋升 approved 的优先路径\",\n        \"待连续观察期与治理复核闭环后再决定是否恢复主候选角色\"\n      ],\n      \"evidence\": {\n        \"decision_record\": \"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports/smallcap_chip_v4_2_alpha_recover_decision_20260325.md\",\n        \"latest_experiment_id\": \"smallcap_chip_v4_2_alpha_recover:walk_forward:20260314:44136fa355b3678a\",\n        \"walk_forward\": {\n          \"test_annual_return_pct_mean\": 22.0,\n          \"test_sharpe_mean\": 1.687,\n          \"test_max_drawdown_pct_mean\": 6.37,\n          \"test_total_return_pct_mean\": 9.17,\n          \"test_folds\": 8\n        },\n        \"full_backtest\": {\n          \"annual_return_pct\": 33.25,\n          \"sharpe\": 1.89,\n          \"max_drawdown_pct\": 18.1,\n          \"total_return_pct\": 451.02\n        }\n      }\n    },\n    {\n      \"strategy_id\": \"rd_agent_top2_gray_v1\",\n      \"current_state\": \"ca