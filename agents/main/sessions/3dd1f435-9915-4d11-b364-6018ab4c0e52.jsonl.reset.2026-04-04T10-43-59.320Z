{"type":"message","id":"6b1fdcf7","parentId":"d99a506c","timestamp":"2026-04-03T01:37:59.967Z","message":{"role":"toolResult","toolCallId":"call_1ryd31ASjeeI1vifR28l0BEX|fc_00990316fdaeab850169cf19f760d48198aa269383b14dc442","toolName":"exec","content":[{"type":"text","text":"lines: list[str] = []\n    lines.append(f\"# 今日选股/策略报告（{trade_date}）\")\n    lines.append(\"\")\n    lines.append(\"> 说明：基于三套模拟盘最新订单、风险门控、每日策略审计与候选池汇总生成，仅供研究参考。\")\n    lines.append(\"\")\n    lines.append(\"## 一、当前风控状态\")\n    lines.append(f\"- 模拟盘最新完整交易日：`{date_tag}`\")\n    lines.append(f\"- 今日盘前强检状态：`{precheck_status}` / passed=`{bool(precheck_passed)}`\")\n    lines.append(\n        f\"- 治理闸门：`{governance_status.get('report_status', 'UNKNOWN')}` / blocking=`{governance_status.get('blocking')}` / \"\n        f\"issues=`{len(governance_status.get('issues') or [])}`\"\n    )\n    lines.append(f\"- 风险模式：`{risk_mode}` / risk_off=`{risk_off}` / hard_stop=`{hard_stop}`\")\n    lines.append(\n        f\"- 今日执行摘要：`{execution_status_label_cn}` / runtime_truth=`{runtime_truth_state or '-'}` / can_execute_today=`{can_execute_today}` / buy_authorized=`{runtime_buy_authorized}` / blocking_reason=`{blocking_reason or '-'}`\"\n    )\n    if runtime_snapshot.get(\"runtime_truth_state\") is not None:\n        lines.append(\n            f\"- 统一执行状态：`{runtime_snapshot.get('runtime_truth_state')}` / ready=`{runtime_snapshot.get('runtime_truth_ready')}` / buy_authorized=`{runtime_snapshot.get('buy_authorized')}`\"\n        )\n    if missing_order_plan_profiles:\n        lines.append(f\"- 当天未生成 order_plan 的模拟盘：`{'、'.join(missing_order_plan_profiles)}`\")\n    lines.append(\n        f\"- 宽度门禁：当前 `{fmt_ratio_pct(market_breadth, 2)}%` / cautious<=`{fmt_ratio_pct(breadth_riskoff, 2)}%` / \"\n        f\"halt<=`{fmt_ratio_pct(breadth_hard_stop, 2)}%`\"\n    )\n    lines.append(\n        f\"- 基准指数：`{benchmark_code}` 当前 `{fmt_pct(index_ret_pct, 4)}%` / 指数硬停阈值 \"\n        f\"`{fmt_pct(index_halt_threshold_pct, 4)}%`\"\n    )\n    lines.append(\n        f\"- 盘中指数门禁：`{intraday_gate_action}` / `{intraday_gate_reason}` / \"\n        f\"指数快照：`{'；'.join(intraday_index_snapshot) if intraday_index_snapshot else '无'}`\"\n    )\n    lines.append(\n        f\"- 盘中宽度来源：`{intraday_breadth_source}` / 捕获时间：`{intraday_breadth_at}` / \"\n        f\"risk_off 允许新开仓：`{bool(allow_new_buy_when_riskoff)}`\"\n    )\n    lines.append(f\"- 当前触发原因：`{trigger_reason}`\")\n    lines.append(f\"- 当前门控摘要：`{gate_reason_text}`\")\n    lines.append(\n        f\"- 实时源分布：`{realtime_source_breakdown_total if realtime_source_breakdown_total else {}}` / \"\n        f\"分时MA来源：`{intraday_ma_source_breakdown_total if intraday_ma_source_breakdown_total else {}}`\"\n    )\n    lines.append(\"\")\n    lines.append(\"## 二、历史健康度（仅审计，不直接决定当下开平仓）\")\n    lines.append(f\"- 每日策略审计：`{audit.get('overall_status', '-')}`\")\n    lines.append(f\"- 年化：`{fmt_pct(audit.get('annual_return_pct'))}%`\")\n    lines.append(f\"- 最大回撤：`{fmt_pct(audit.get('max_drawdown_pct'))}%`\")\n    lines.append(f\"- 夏普：`{fmt_pct(audit.get('sharpe'), 3)}`\")\n    lines.append(\"- 说明：这一层用于评估策略长期健康度，不直接替代今日实时风控。\")\n    lines.append(\"\")\n    lines.append(\"## 三、今日核心结论\")\n    if recommendation_status[\"blocked\"] and governance_status.get(\"blocking\"):\n        lines.append(\"- **结论：今天不允许把研究候选继续包装成可执行买入建议，治理闸门处于 BLOCK。**\")\n        lines.append(\"- 即使候选池有分数，治理缺口未补完之前，这些标的也只能停留在研究观察层，不能进入执行建议层。\")\n        lines.append(\n            f\"- 当前研究层仍识别出 `{raw_buy_count}` 个去重 BUY 候选、`{sell_count}` 个去重 SELL 候选，但可执行 BUY 候选被压到 `0`。\"\n        )\n        lines.append(\n            f\"- 治理阻断项：`{'；'.join(governance_status.get('issues') or ['governance_block'])}`\"\n        )\n    elif halt_new_buy:\n        lines.append(\"- **结论：今天不建议新开仓，三套模拟盘执行层处于统一风险阻断态。**\")\n        lines.append(\"- 原因不是候选池为空，而是 `risk_off/hard_stop` 已经联动触发，新增买单被风险闸门整体拦截。\")\n        lines.append(f\"- 当前共形成 `{raw_buy_count}` 个去重 BUY 候选、`{sell_count}` 个去重 SELL 候选，但三盘合计被阻断买单 `{blocked_buy_total}` 笔。\")\n        lines.append(\"- 今日更适合保留候选优先级与风险边界，不把候选直接翻译成执行买单。\")\n    else:\n        lines.append(\"- **结论：今天允许条件化推进，但仍需先过风控门控与用户确认。**\")\n        lines.append(\"- 当前候选池可用于排序与跟踪，但不应越级跳过盘前强检与预算约束。\")\n        lines.append(f\"- 当前共形成 `{raw_buy_count}` 个去重 BUY 候选、`{sell_count}` 个去重 SELL 候选。\")\n        lines.append(\"- 今日应以‘候选池 + 触发条件 + 风控边界’作为执行前提。\")\n    lines.append(\"\")\n    lines.append(\"## 四、组合层补充指标\")\n    if comparison_trade_count <= 0:"}],"details":{"status":"completed","exitCode":0,"durationMs":44,"aggregated":"lines: list[str] = []\n    lines.append(f\"# 今日选股/策略报告（{trade_date}）\")\n    lines.append(\"\")\n    lines.append(\"> 说明：基于三套模拟盘最新订单、风险门控、每日策略审计与候选池汇总生成，仅供研究参考。\")\n    lines.append(\"\")\n    lines.append(\"## 一、当前风控状态\")\n    lines.append(f\"- 模拟盘最新完整交易日：`{date_tag}`\")\n    lines.append(f\"- 今日盘前强检状态：`{precheck_status}` / passed=`{bool(precheck_passed)}`\")\n    lines.append(\n        f\"- 治理闸门：`{governance_status.get('report_status', 'UNKNOWN')}` / blocking=`{governance_status.get('blocking')}` / \"\n        f\"issues=`{len(governance_status.get('issues') or [])}`\"\n    )\n    lines.append(f\"- 风险模式：`{risk_mode}` / risk_off=`{risk_off}` / hard_stop=`{hard_stop}`\")\n    lines.append(\n        f\"- 今日执行摘要：`{execution_status_label_cn}` / runtime_truth=`{runtime_truth_state or '-'}` / can_execute_today=`{can_execute_today}` / buy_authorized=`{runtime_buy_authorized}` / blocking_reason=`{blocking_reason or '-'}`\"\n    )\n    if runtime_snapshot.get(\"runtime_truth_state\") is not None:\n        lines.append(\n            f\"- 统一执行状态：`{runtime_snapshot.get('runtime_truth_state')}` / ready=`{runtime_snapshot.get('runtime_truth_ready')}` / buy_authorized=`{runtime_snapshot.get('buy_authorized')}`\"\n        )\n    if missing_order_plan_profiles:\n        lines.append(f\"- 当天未生成 order_plan 的模拟盘：`{'、'.join(missing_order_plan_profiles)}`\")\n    lines.append(\n        f\"- 宽度门禁：当前 `{fmt_ratio_pct(market_breadth, 2)}%` / cautious<=`{fmt_ratio_pct(breadth_riskoff, 2)}%` / \"\n        f\"halt<=`{fmt_ratio_pct(breadth_hard_stop, 2)}%`\"\n    )\n    lines.append(\n        f\"- 基准指数：`{benchmark_code}` 当前 `{fmt_pct(index_ret_pct, 4)}%` / 指数硬停阈值 \"\n        f\"`{fmt_pct(index_halt_threshold_pct, 4)}%`\"\n    )\n    lines.append(\n        f\"- 盘中指数门禁：`{intraday_gate_action}` / `{intraday_gate_reason}` / \"\n        f\"指数快照：`{'；'.join(intraday_index_snapshot) if intraday_index_snapshot else '无'}`\"\n    )\n    lines.append(\n        f\"- 盘中宽度来源：`{intraday_breadth_source}` / 捕获时间：`{intraday_breadth_at}` / \"\n        f\"risk_off 允许新开仓：`{bool(allow_new_buy_when_riskoff)}`\"\n    )\n    lines.append(f\"- 当前触发原因：`{trigger_reason}`\")\n    lines.append(f\"- 当前门控摘要：`{gate_reason_text}`\")\n    lines.append(\n        f\"- 实时源分布：`{realtime_source_breakdown_total if realtime_source_breakdown_total else {}}` / \"\n        f\"分时MA来源：`{intraday_ma_source_breakdown_total if intraday_ma_source_breakdown_total else {}}`\"\n    )\n    lines.append(\"\")\n    lines.append(\"## 二、历史健康度（仅审计，不直接决定当下开平仓）\")\n    lines.append(f\"- 每日策略审计：`{audit.get('overall_status', '-')}`\")\n    lines.append(f\"- 年化：`{fmt_pct(audit.get('annual_return_pct'))}%`\")\n    lines.append(f\"- 最大回撤：`{fmt_pct(audit.get('max_drawdown_pct'))}%`\")\n    lines.append(f\"- 夏普：`{fmt_pct(audit.get('sharpe'), 3)}`\")\n    lines.append(\"- 说明：这一层用于评估策略长期健康度，不直接替代今日实时风控。\")\n    lines.append(\"\")\n    lines.append(\"## 三、今日核心结论\")\n    if recommendation_status[\"blocked\"] and governance_status.get(\"blocking\"):\n        lines.append(\"- **结论：今天不允许把研究候选继续包装成可执行买入建议，治理闸门处于 BLOCK。**\")\n        lines.append(\"- 即使候选池有分数，治理缺口未补完之前，这些标的也只能停留在研究观察层，不能进入执行建议层。\")\n        lines.append(\n            f\"- 当前研究层仍识别出 `{raw_buy_count}` 个去重 BUY 候选、`{sell_count}` 个去重 SELL 候选，但可执行 BUY 候选被压到 `0`。\"\n        )\n        lines.append(\n            f\"- 治理阻断项：`{'；'.join(governance_status.get('issues') or ['governance_block'])}`\"\n        )\n    elif halt_new_buy:\n        lines.append(\"- **结论：今天不建议