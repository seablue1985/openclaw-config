{"type":"message","id":"6f3aa514","parentId":"9f401a2a","timestamp":"2026-04-03T00:52:30.480Z","message":{"role":"toolResult","toolCallId":"call_6Et5jgGbzkBEeXyiB8S03b5Z|fc_00990316fdaeab850169cf0f4d8f188198b9d6aa0a9c2aa545","toolName":"read","content":[{"type":"text","text":"Status: done\nPriority: P1\nStarted: 2026-04-03 08:49\nUpdated: 2026-04-03 08:51\nWorkspace: /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system\nOwner: main-session\nUser Trigger: 张玲要求继续，把 3 个 drawdown_review_required 做成治理评审清单/结论草案\nResume Entry: 先读取 strategy_governance_gate_latest.json、strategy_registry_v2.json、experiment_registry_v1.json，提炼 3 个 review_required 的建议动作，再生成治理评审草案报告\n\n## Goal\n- 为 3 个 drawdown_review_required 策略生成可签字的治理评审草案，明确每个策略建议：继续观察 / 降级 / 下线候选\n\n## Acceptance\n- 新增一份治理评审草案报告（md）\n- 报告覆盖 3 个策略，并给出建议结论与理由\n- 完成后提交 git commit\n\n## Current\n- None\n\n## Next\n- None\n\n## Completed\n- [2026-04-03 08:48] dual factor conservative 决策极简版已落地，明确当前维持 HOLD、不进 default，下一步先做 governance review 草案 + 3~5 日 conservative shadow\n- 读取 governance gate 与策略/实验注册信息，整理 3 个策略的治理评审建议\n- [2026-04-03 08:52] 3 个 drawdown_review_required 的治理评审草案已落地：alpha_guard=继续观察，alpha_recover=降级，rd_agent_top2_gray_v1=下线候选\n\n## Evidence\n- /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports/strategy_governance_gate_latest.json\n- /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/config/strategy_registry_v2.json\n- /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/config/experiment_registry_v1.json\n- /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports/dual_factor_conservative_decision_brief_20260403.md\n- /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports/strategy_drawdown_governance_review_draft_20260403.md\n\n## Blockers\n- None\n"}],"isError":false,"timestamp":1775177550472}}
{"type":"message","id":"9dbb623e","parentId":"6f3aa514","timestamp":"2026-04-03T00:52:30.488Z","message":{"role":"toolResult","toolCallId":"call_XYF1ektJC8dqWTYH0m7V8MBE|fc_00990316fdaeab850169cf0f4d8f2c819881497c7c1350ef59","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport experiment_registry as experiment_registry_mod\n\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nREGISTRY_PATH = PROJECT_ROOT / \"config\" / \"strategy_registry_v2.json\"\nOWNERS_PATH = PROJECT_ROOT / \"config\" / \"strategy_governance_owners_v1.json\"\nINCIDENT_TEMPLATE_PATH = PROJECT_ROOT / \"docs\" / \"INCIDENT_TEMPLATE_V1.md\"\nEXPERIMENT_REGISTRY_PATH = PROJECT_ROOT / \"config\" / \"experiment_registry_v1.json\"\nRUNTIME_RISK_PATH = REPORT_DIR / \"runtime_risk_state_latest.json\"\nDRAWDOWN_WATCH_STATE_PATH = REPORT_DIR / \"strategy_drawdown_watch_state.json\"\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef path_exists(value: str) -> bool:\n    text = str(value or \"\").strip()\n    return bool(text) and Path(text).exists()\n\n\ndef parse_float(value: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(value).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef validate_registry(\n    registry: dict[str, Any],\n    owners: dict[str, Any],\n    experiment_registry: dict[str, Any],\n) -> tuple[list[dict[str, Any]], list[str]]:\n    role_map = (owners.get(\"roles\") or {}) if isinstance(owners, dict) else {}\n    required_signoffs = ((registry.get(\"policy\") or {}).get(\"required_signoff_roles\") or {}) if isinstance(registry, dict) else {}\n    strategies = registry.get(\"strategies\") or []\n    experiment_summaries = {\n        str(item.get(\"strategy_id\") or \"\"): item\n        for item in (experiment_registry.get(\"strategy_summaries\") or [])\n        if str(item.get(\"strategy_id\") or \"\").strip()\n    }\n\n    rows: list[dict[str, Any]] = []\n    blocking_issues: list[str] = []\n    for item in strategies:\n        strategy_id = str(item.get(\"strategy_id\") or \"\").strip()\n        state = str(item.get(\"state\") or \"\").strip().lower()\n        owner_role = str(item.get(\"owner_role\") or \"\").strip()\n        signoffs = [str(x).strip() for x in (item.get(\"signoffs\") or []) if str(x).strip()]\n        evidence = item.get(\"promotion_evidence\") or {}\n        experiment_summary = experiment_summaries.get(strategy_id) or {}\n\n        issues: list[str] = []\n        if not strategy_id:\n            issues.append(\"missing_strategy_id\")\n        if owner_role not in role_map:\n            issues.append(\"unknown_owner_role\")\n        if not str(item.get(\"location\") or \"\").strip():\n            issues.append(\"missing_location\")\n\n        if state in {\"candidate\", \"approved\"}:\n            if not bool(item.get(\"signal_schema_ready\")):\n                issues.append(\"signal_schema_not_ready\")\n            if not bool(item.get(\"risk_engine_ready\")):\n                issues.append(\"risk_engine_not_ready\")\n            if not path_exists(str(evidence.get(\"decision_record\") or \"\")):\n                issues.append(\"missing_decision_record\")\n            if not experiment_summary:\n                issues.append(\"missing_experiment_registry_summary\")\n            else:\n                missing_experiments = experiment_summary.get(\"missing_required_experiment_types\") or []\n                if missing_experiments:\n                    issues.append(f\"missing_experiments:{'|'.join(str(x) for x in missing_experiments)}\")\n                latest_promotion_state = str(experiment_summary.get(\"latest_promotion_state\") or \"\")\n                if latest_promotion_state and latest_promotion_state != \"none\" and not experiment_registry_mod.state_ge(\n                    latest_promotion_state,\n                    state,\n                ):\n                    issues.append(f\"experiment_state_below_registry:{latest_promotion_state}\")\n                if not bool(experiment_summary.get(\"registry_ready\")):\n                    issues.append(\"experiment_registry_not_ready\")\n\n        if state == \"approved\":\n            if not bool(item.get(\"live_chain_ready\")):\n                issues.append(\"approved_without_live_chain\")\n            if not path_exists(str(evidence.get(\"paper_trade_report\") or \"\")):\n                issues.append(\"approved_without_paper_trade_report\")\n\n        needed_roles = [str(x).strip() for x in (required_signoffs.get(state) or []) if str(x).strip()]\n        missing_signoffs = [role for role in needed_roles if role not in signoffs]\n        if missing_signoffs:\n            issues.append(f\"missing_signoffs:{'|'.join(missing_signoffs)}\")\n\n        status = \"PASS\" if not issues else \"BLOCK\"\n        if issues:\n            blocking_issues.append(f\"{strategy_id}:{','.join(issues)}\")\n\n        rows.append(\n            {\n                \"strategy_id\": strategy_id,\n                \"state\": state,\n                \"owner_role\": owner_role,\n                \"status\": status,\n                \"issues\": issues,\n            }\n        )\n\n    return rows, blocking_issues\n\n\ndef validate_ownership(owners: dict[str, Any]) -> list[str]:\n    issues: list[str] = []\n    roles = owners.get(\"roles\") or {}\n    ownership = owners.get(\"ownership\") or []\n\n    for row in ownership:\n        area = str(row.get(\"area\") or \"\").strip()\n        owner_role = str(row.get(\"owner_role\") or \"\").strip()\n        review_role = str(row.get(\"review_role\") or \"\").strip()\n        paths = row.get(\"paths\") or []\n        if owner_role not in roles:\n            issues.append(f\"{area}:unknown_owner_role\")\n        if review_role not in roles:\n            issues.append(f\"{area}:unknown_review_role\")\n        missing_paths = [p for p in paths if not (PROJECT_ROOT / p).exists()]\n        if missing_paths:\n            issues.append(f\"{area}:missing_paths:{'|'.join(missing_paths)}\")\n    return issues\n\n\ndef evaluate_drawdown_review(\n    registry: dict[str, Any],\n    *,\n    runtime_payload: dict[str, Any],\n    previous_state: dict[str, Any],\n) -> tuple[dict[str, Any], dict[str, Any], list[str]]:\n    policy = (registry.get(\"policy\") or {}) if isinstance(registry, dict) else {}\n    drawdown_policy = (policy.get(\"drawdown_review\") or {}) if isinstance(policy, dict) else {}\n    threshold = parse_float(drawdown_policy.get(\"max_drawdown_threshold_pct\"), 10.0)\n    required_days = max(1, int(parse_float(drawdown_policy.get(\"consecutive_days\"), 3)))\n    runtime_date_tag = str(runtime_payload.get(\"date_tag\") or datetime.now().strftime(\"%Y%m%d\"))\n    runtime_metrics = runtime_payload.get(\"runtime_metrics\") or {}\n    strategy_max_dd_pct = parse_float(runtime_metrics.get(\"strategy_max_dd_pct\"), 0.0)\n    trigger_hit = strategy_max_dd_pct >= threshold\n\n    previous_rows = previous_state.get(\"strategies\") or {}\n    strategies = registry.get(\"strategies\") or []\n    rows: list[dict[str, Any]] = []\n    next_rows: dict[str, Any] = {}\n    blocking: list[str] = []\n\n    for item in strategies:\n        strategy_id = str(item.get(\"strategy_id\") or \"\").strip()\n        state = str(item.get(\"state\") or \"\").strip().lower()\n        owner_role = str(item.get(\"owner_role\") or \"\").strip() or \"unassigned_owner\"\n        if not strategy_id:\n            continue\n        prev = previous_rows.get(strategy_id) or {}\n        prev_count = int(prev.get(\"consecutive_trigger_days\") or 0)\n        prev_date = str(prev.get(\"last_evaluated_date_tag\") or \"\")\n        if trigger_hit:\n            if prev_date == runtime_date_tag:\n                consecutive = prev_count\n            else:\n                consecutive = prev_count + 1\n        else:\n            consecutive = 0\n        review_required = state in {\"candidate\", \"approved\"} and trigger_hit and consecutive >= required_days\n        conclusion = \"pending_manual_decision\" if review_required else \"monitoring\"\n        owner_signature = f\"{owner_role}:AUTO_SIGNATURE_PENDING\"\n        row = {\n            \"strategy_id\": strategy_id,\n            \"registry_state\": state,\n            \"owner_role\": owner_role,\n            \"trigger_hit\": trigger_hit,\n            \"strategy_max_drawdown_pct\": round(strategy_max_dd_pct, 4),\n            \"threshold_pct\": threshold,\n            \"consecutive_trigger_days\": consecutive,\n            \"required_consecutive_days\": required_days,\n            \"review_required\": review_required,\n            \"owner_signature\": owner_signature,\n            \"review_conclusion\": conclusion,\n            \"evaluated_date_tag\": runtime_date_tag,\n        }\n        rows.append(row)\n        next_rows[strategy_id] = {\n            \"last_evaluated_date_tag\": runtime_date_tag,\n            \"consecutive_trigger_days\": consecutive,\n            \"trigger_hit\": trigger_hit,\n            \"review_required\": review_required,\n            \"owner_signature\": owner_signature,\n            \"review_conclusion\": conclusion,\n        }\n        if review_required:\n            blocking.append(\n                f\"drawdown_review_required:{strategy_id}:consecutive_days={consecutive}:owner={owner_role}\"\n            )\n\n    summary = {\n        \"runtime_date_tag\": runtime_date_tag,\n        \"strategy_max_drawdown_pct\": round(strategy_max_dd_pct, 4),\n        \"threshold_pct\": threshold,\n        \"trigger_hit\": trigger_hit,\n        \"required_consecutive_days\": required_days,\n        \"rows\": rows,\n    }\n    next_state = {\n        \"updated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"runtime_date_tag\": runtime_date_tag,\n        \"strategies\": next_rows,\n    }\n    return summary, next_state, blocking\n\n\ndef build_payload() -> dict[str, Any]:\n    registry = load_json(REGISTRY_PATH)\n    owners = load_json(OWNERS_PATH)\n    experiment_sync_error = \"\"\n    try:\n        experiment_registry = experiment_registry_mod.sync_registry(write=True)\n    except Exception as exc:  # pragma: no cover - defensive guard for production chain\n        experiment_registry = load_json(EXPERIMENT_REGISTRY_PATH)\n        experiment_sync_error = str(exc)\n    registry_rows, registry_issues = validate_registry(registry, owners, experiment_registry)\n    ownership_issues = validate_ownership(owners)\n    incident_template_exists = INCIDENT_TEMPLATE_PATH.exists()\n    runtime_payload = load_json(RUNTIME_RISK_PATH)\n    drawdown_prev_state = load_json(DRAWDOWN_WATCH_STATE_PATH)\n    drawdown_review, drawdown_next_state, drawdown_issues = evaluate_drawdown_review(\n        registry,\n        runtime_payload=runtime_payload,\n        previous_state=drawdown_prev_state,\n    )\n    DRAWDOWN_WATCH_STATE_PATH.write_text(\n        json.dumps(drawdown_next_state, ensure_ascii=False, indent=2),\n        encoding=\"utf-8\",\n    )\n\n    blocking_issues = registry_issues + ownership_issues + drawdown_issues\n    if experiment_sync_error:\n        blocking_issues.append(f\"experiment_registry_sync_failed:{experiment_sync_error}\")\n    if not incident_template_exists:\n        blocking_issues.append(\"incident_template_missing\")\n\n    overall_status = \"PASS\" if not blocking_issues else \"BLOCK\"\n    return {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"overall_status\": overall_status,\n        \"files\": {"}],"details":{"status":"completed","exitCode":0,"durationMs":41,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport experiment_registry as experiment_registry_mod\n\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nREGISTRY_PATH = PROJECT_ROOT / \"config\" / \"strategy_registry_v2.json\"\nOWNERS_PATH = PROJECT_ROOT / \"config\" / \"strategy_governance_owners_v1.json\"\nINCIDENT_TEMPLATE_PATH = PROJECT_ROOT / \"docs\" / \"INCIDENT_TEMPLATE_V1.md\"\nEXPERIMENT_REGISTRY_PATH = PROJECT_ROOT / \"config\" / \"experiment_registry_v1.json\"\nRUNTIME_RISK_PATH = REPORT_DIR / \"runtime_risk_state_latest.json\"\nDRAWDOWN_WATCH_STATE_PATH = REPORT_DIR / \"strategy_drawdown_watch_state.json\"\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef path_exists(value: str) -> bool:\n    text = str(value or \"\").strip()\n    return bool(text) and Path(text).exists()\n\n\ndef parse_float(value: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(value).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef validate_registry(\n    registry: dict[str, Any],\n    owners: dict[str, Any],\n    experiment_registry: dict[str, Any],\n) -> tuple[list[dict[str, Any]], list[str]]:\n    role_map = (owners.get(\"roles\") or {}) if isinstance(owners, dict) else {}\n    required_signoffs = ((registry.get(\"policy\") or {}).get(\"required_signoff_roles\") or {}) if isinstance(registry, dict) else {}\n    strategies = registry.get(\"strategies\") or []\n    experiment_summaries = {\n        str(item.get(\"strategy_id\") or \"\"): item\n        for item in (experiment_registry.get(\"strategy_summaries\") or [])\n        if str(item.get(\"strategy_id\") or \"\").strip()\n    }\n\n    rows: list[dict[str, Any]] = []\n    blocking_issues: list[str] = []\n    for item in strategies:\n        strategy_id = str(item.get(\"strategy_id\") or \"\").strip()\n        state = str(item.get(\"state\") or \"\").strip().lower()\n        owner_role = str(item.get(\"owner_role\") or \"\").strip()\n        signoffs = [str(x).strip() for x in (item.get(\"signoffs\") or []) if str(x).strip()]\n        evidence = item.get(\"promotion_evidence\") or {}\n        experiment_summary = experiment_summaries.get(strategy_id) or {}\n\n        issues: list[str] = []\n        if not strategy_id:\n            issues.append(\"missing_strategy_id\")\n        if owner_role not in role_map:\n            issues.append(\"unknown_owner_role\")\n        if not str(item.get(\"location\") or \"\").strip():\n            issues.append(\"missing_location\")\n\n        if state in {\"candidate\", \"approved\"}:\n            if not bool(item.get(\"signal_schema_ready\")):\n                issues.append(\"signal_schema_not_ready\")\n            if not bool(item.get(\"risk_engine_ready\")):\n                issues.append(\"risk_engine_not_ready\")\n            if not path_exists(str(evidence.get(\"decision_record\") or \"\")):\n                issues.append(\"missing_decision_record\")\n            if not experiment_summary:\n                issues.append(\"missing_experiment_registry_summary\")\n            else:\n                missing_experiments = experiment_summary.get(\"missing_required_experiment_types\") or []\n                if missing_experiments:\n                    issues.append(f\"missing_experiments:{'|'.join(str(x) for x in missing_experiments)}\")\n                latest_promotion_state = str(experiment_summary.get(\"latest_promotion_state\") or \"\")\n                if latest_promotion_state and latest_promotion_state != \"none\" and not experiment_registry_mod.state_ge(\n                    latest_promotion_state,\n                    state,\n                ):\n                    issues.append(f\"experiment_state_below_registry:{latest_promotion_state}\")\n                if not bool(experiment_summary.get(\"registry_ready\")):\n                    issues.append(\"experiment_registry_not_ready\")\n\n        if state == \"approved\":\n            if not bool(item.get(\"live_chain_ready\")):\n                issues.append(\"approved_without_live_chain\")\n            if not path_exists(str(evidence.get(\"paper_trade_report\") or \"\")):\n                issues.append(\"approved_without_paper_trade_report\")\n\n        needed_roles = [str(x).strip() for x in (required_signoffs.get(state) or []) if str(x).strip()]\n        missing_signoffs = [role for role in needed_roles if role not in signoffs]\n        if missing_signoffs:\n            issues.append(f\"missing_signoffs:{'|'.join(missing_signoffs)}\")\n\n        status = \"PASS\" if not issues else \"BLOCK\"\n        if issues:\n            blocking_issues.append(f\"{strategy_id}:{','.join(issues)}\")\n\n        rows.append(\n            {\n                \"strategy_id\": strategy_id,\n                \"state\": state,\n                \"owner_role\": owner_role,\n                \"status\": status,\n                \"issues\": issues,\n            }\n        )\n\n    return rows, blocking_issues\n\n\ndef validate_ownership(owners: dict[str, Any]) -> list[str]:\n    issues: list[str] = []\n    roles = owners.get(\"roles\") or {}\n    ownership = owners.get(\"ownership\") or []\n\n    for row in ownership:\n        area = str(row.get(\"area\") or \"\").strip()\n        owner_role = str(row.get(\"owner_role\") or \"\").strip()\n        review_role = str(row.get(\"review_role\") or \"\").strip()\n        paths = row.get(\"paths\") or []\n        if owner_role not in roles:\n            issues.append(f\"{area}:unknown_owner_role\")\n        if review_role not in roles:\n            issues.append(f\"{area}:unknown_review_role\")\n        missing_paths = [p for p in paths if not (PROJECT_ROOT / p).exists()]\n        if missing_paths:\n            issues.append(f\"{area}:missing_paths:{'|'.join(missing_paths)}\")\n    return issues\n\n\ndef evaluate_drawdown_review(\n    registry: dict[str, Any],\n    *,\n    runtime_payload: dict[str, Any],\n    previous_state: dict[str, Any],\n) -> tuple[dict[str, Any], dict[str, Any], list[str]]:\n    policy = (registry.get(\"policy\") or {}) if isinstance(registry, dict) else {}\n    drawdown_policy = (policy.get(\"drawdown_review\") or {}) if isinstance(policy, dict) else {}\n    threshold = parse_float(drawdown_policy.get(\"max_drawdown_threshold_pct\"), 10.0)\n    required_days = max(1, int(parse_float(drawdown_policy.get(\"consecutive_days\"), 3)))\n    runtime_date_tag = str(runtime_payload.get(\"date_tag\") or datetime.now().strftime(\"%Y%m%d\"))\n    runtime_metrics = runtime_payload.get(\"runtime_metrics\") or {}\n    strategy_max_dd_pct = parse_float(runtime_metrics.get(\"strategy_max_dd_pct\"), 0.0)\n    trigger_hit = strategy_max_dd_pct >= threshold\n\n    previous_rows = previous_state.get(\"strategies\") or {}\n    strategies = registry.get(\"strategies\") or []\n    rows: list[dict[str, Any]] = []\n    next_rows: dict[str, Any] = {}\n    blocking: list[str] = []\n\n    for item in strategies:\n        strategy_id = str(item.get(\"strategy_id\") or \"\").strip()\n        state = str(item.get(\"state\") or \"\").strip().lower()\n        owner_role = str(item.get(\"owner_role\") or \"\").strip() or \"unassigned_owner\"\n        if not strategy_id:\n            continue\n        prev = previous_rows.get(strategy_id) or {}\n        prev_count = int(prev.get(\"consecutive_trigger_days\") or 0)\n        prev_date = str(prev.get(\"last_evaluated_date_tag\") or \"\")\n        if trigger_hit:\n            if prev_date == runtime_date_tag:\n                consecutive = prev_count\n            else:\n                consecutive = prev_count + 1\n        else:\n            consecutive = 0\n        review_required = state in {\"candidate\", \"approved\"} and trigger_hit and consecutive >= required_days\n        conclusion = \"pending_manual_decision\" if review_required else \"monitoring\"\n        owner_signature = f\"{owner_role}:AUTO_SIGNATURE_PENDING\"\n        row = {\n            \"strategy_id\": strategy_id,\n            \"registry_state\": state,\n            \"owner_role\": owner_role,\n            \"trigger_hit\": trigger_hit,\n            \"strategy_max_drawdown_pct\": round(strategy_max_dd_pct, 4),\n            \"threshold_pct\": threshold,\n            \"consecutive_trigger_days\": consecutive,\n            \"required_consecutive_days\": required_days,\n            \"review_required\": review_required,\n            \"owner_signature\": owner_signature,\n            \"review_conclusion\": conclusion,\n            \"evaluated_date_tag\": runtime_date_tag,\n        }\n        rows.append(row)\n        next_rows[strategy_id] = {\n            \"last_evaluated_date_tag\": runtime_date_tag,\n            \"consecutive_trigger_days\": consecutive,\n            \"trigger_hit\": trigger_hit,\n            \"review_required\": review_required,\n            \"owner_signature\": owner_signature,\n            \"review_conclusion\": conclusion,\n        }\n        if review_required:\n            blocking.append(\n                f\"drawdown_review_required:{strategy_id}:consecutive_days={consecutive}:owner={owner_role}\"\n            )\n\n    summary = {\n        \"runtime_date_tag\": runtime_date_tag,\n        \"strategy_max_drawdown_pct\": round(strategy_max_dd_pct, 4),\n        \"threshold_pct\": threshold,\n        \"trigger_hit\": trigger_hit,\n        \"required_consecutive_days\": required_days,\n        \"rows\": rows,\n    }\n    next_state = {\n        \"updated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"runtime_date_tag\": runtime_date_tag,\n        \"strategies\": next_rows,\n    }\n    return summary, next_state, blocking\n\n\ndef build_payload() -> dict[str, Any]:\n    registry = load_json(REGISTRY_PATH)\n    owners = load_json(OWNERS_PATH)\n    experiment_sync_error = \"\"\n    try:\n        experiment_registry = experiment_registry_mod.sync_registry(write=True)\n    except Exception as exc:  # pragma: no cover - defensive guard for production chain\n        experiment_registry = load_json(EXPERIMENT_REGISTRY_PATH)\n        experiment_sync_error = str(exc)\n    registry_rows, registry_issues = validate_registry(registry, owners, experiment_registry)\n    ownership_issues = validate_ownership(owners)\n    incident_template_exists = INCIDENT_TEMPLATE_PATH.exists()\n    runtime_payload = load_json(RUNTIME_RISK_PATH)\n    drawdown_prev_state = load_json(DRAWDOWN_WATCH_STATE_PATH)\n    drawdown_review, drawdown_next_state, drawdown_issues = evaluate_drawdown_review(\n        registry,\n        runtime_payload=runtime_payload,\n        previous_state=drawdown_prev_state,\n    )\n    DRAWDOWN_WATCH_STATE_PATH.write_text(\n        json.dumps(drawdown_next_state, ensure_ascii=False, indent=2),\n        encoding=\"utf-8\",\n    )\n\n    blocking_issues = registry_issues + ownership_issues + drawdown_issues\n    if experiment_sync_error:\n        blocking_issues.append(f\"experiment_registry_sync_failed:{experiment_sync_error}\")\n    if not incident_template_exists:\n        blocking_issues.append(\"incident_template_missing\")\n\n    overall_status = \"PASS\" if not blocking_issues else \"BLOCK\"\n    return {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"overall_status\": overall_status,\n        \"files\": {","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1775177550480}}
