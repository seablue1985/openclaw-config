ge\": 0.23\n      }\n    },\n    \"run_live_system_v1_dual_shadow__write_artifacts\": {\n      \"status\": \"pass\",\n      \"artifacts_written\": true,\n      \"files\": [\n        \"dual_factor_shadow_*_default_YYYYMMDD_summary.json\",\n        \"dual_factor_shadow_*_default_YYYYMMDD_curve.csv\",\n        \"dual_factor_shadow_*_default_YYYYMMDD_live_payload.json\"\n      ]\n    },\n    \"prepare_paper_orders_dual_shadow__dry_run\": {\n      \"status\": \"pass\",\n      \"runtime_comparison_available\": true,\n      \"key_findings\": [\n        \"双因子回撤改善 1.79pp\",\n        \"双因子夏普提升 +0.153\",\n        \"⚠️ 变化: risk_off baseline=True → dual=False\",\n        \"⚠️ 变化: halt_new_buy baseline=True → dual=False\"\n      ]\n    },\n    \"syntax_check\": {\n      \"run_live_system_v1_dual_shadow.py\": \"pass\",\n      \"prepare_paper_orders_dual_shadow.py\": \"pass\"\n    }\n  },\n  \"risk_guardrails\": [\n    \"不直接替换主链路 combo_v1\",\n    \"纸盘阶段先做 shadow diff 对照，不作为真实下单真相源\",\n    \"baseline 与 dual factor 必须并行保留日志\",\n    \"若指数缓存/市场均价/combo_curve 任一缺失或不新鲜，dual shadow 判定无效\",\n    \"risk_off / halt_new_buy 字段从 True 变为 False 时，必须人工确认后才可以灰度\",\n    \"conservative 档位为首选灰度档位（±5%~±10% 放大/收缩，变化幅度更小）\"\n  ],\n  \"next_steps\": [\n    {\n      \"step\": 1,\n      \"name\": \"生成 dual factor shadow 产物\",\n      \"command\": \"python3 scripts/run_live_system_v1_dual_shadow.py --profile conservative --write-artifacts\",\n      \"pass_criteria\": \"成功输出 shadow summary / curve / live payload，baseline 文件未被改写\"\n    },\n    {\n      \"step\": 2,\n      \"name\": \"纸盘 shadow diff 对照\",\n      \"command\": \"python3 scripts/prepare_paper_orders_dual_shadow.py --profile conservative --date YYYYMMDD --write-artifacts\",\n      \"pass_criteria\": \"生成 paper_shadow_diff JSON/MD，关键差异有人工复核结论\"\n    },\n    {\n      \"step\": 3,\n      \"name\": \"panel runtime risk shadow 扩展（如需三盘灰度）\",\n      \"command\": \"在 generate_per_panel_runtime_risk_t05.py 中增加 dual_factor_profile 接线\",\n      \"pass_criteria\": \"aggressive/balanced/defensive 三盘均可并行生成 dual shadow\"\n    },\n    {\n      \"step\": 4,\n      \"name\": \"灰度门禁评审\",\n      \"command\": \"人工复核 shadow diff，conservative 档连续 3~5 个交易日稳定后，可切换 --profile default\",\n      \"pass_criteria\": \"无异常 halt 误触发，无 blocked_buy 异常增加\"\n    }\n  ],\n  \"minimal_rollout_order\": [\n    \"1. 运行 run_live_system_v1_dual_shadow.py --profile conservative --write-artifacts 生成 shadow 产物\",\n    \"2. 运行 prepare_paper_orders_dual_shadow.py --profile conservative --write-artifacts 做纸盘 diff 对照\",\n    \"3. 人工确认 risk_off/halt_new_buy 差异方向正确后，切换 --profile default 进行单纸盘灰度\"\n  ],\n  \"final_decision\": {\n    \"can_start_code_integration\": true,\n    \"can_start_paper_shadow\": true,\n    \"can_replace_mainline_now\": false,\n    \"gray_recommended_profile\": \"conservative\",\n    \"gray_recommended_panel\": \"aggressive\",\n    \"notes\": \"当前 dual factor shadow 在 runtime risk 层面显著改善了 halt/risk_off 状态（22.49%→20.7% 回撤），建议优先验证 conservative 档\"\n  }\n}\n"}],"isError":false,"timestamp":1775173123706}}
