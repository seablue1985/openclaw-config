,"arguments":{"file":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/regime_overlay_utils.py","offset":300,"limit":120},"partialJson":"{\"file\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/regime_overlay_utils.py\",\"offset\":300,\"limit\":120}"},{"type":"toolCall","id":"call_BwlObOQujQ2Hljd35dQ1dUlv|fc_0593218ebc10f81b0169cefe874db08198a8be96785be8090a","name":"read","arguments":{"file":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_per_panel_runtime_risk_t05.py","offset":1,"limit":180},"partialJson":"{\"file\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_per_panel_runtime_risk_t05.py\",\"offset\":1,\"limit\":180}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":13928,"output":321,"cacheRead":47872,"cacheWrite":0,"totalTokens":62121,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775173216144,"responseId":"resp_0593218ebc10f81b0169cefe7f83ac8198881d8b97c08271f0"}}
{"type":"message","id":"bed2abf1","parentId":"7be816df","timestamp":"2026-04-02T23:40:55.766Z","message":{"role":"toolResult","toolCallId":"call_u4otdYTHeS8AZ03Wo7BZp25m|fc_0593218ebc10f81b0169cefe874d988198ae2e81ab0dee3513","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nPaper Shadow Wrapper: baseline vs dual factor 实盘接线验证器。\n\n作用：\n1. 确保 dual factor shadow summary 已存在（必要时自动生成）\n2. 用同一份 config / date / merged_signals / tickets 各跑一次 prepare_paper_orders_v1.py\n   - baseline:     --dual-factor-profile off\n   - dual factor:  --dual-factor-profile {default|conservative}\n3. 输出 runtime 指标差异 + 实际纸盘计划差异（plan/stats/diagnostics）\n\n这不是主链路替换器；只用于灰度验证。\n\"\"\"\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport re\nimport shutil\nimport subprocess\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nSCRIPTS_DIR = PROJECT_ROOT / \"scripts\"\nfor candidate in [PROJECT_ROOT, SCRIPTS_DIR]:\n    if str(candidate) not in sys.path:\n        sys.path.insert(0, str(candidate))\n\nVALID_PROFILES = {\"off\", \"default\", \"conservative\"}\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef parse_date_tag(value: str) -> str:\n    text = str(value or \"\").strip()\n    if re.fullmatch(r\"\\d{8}\", text):\n        return text\n    if re.fullmatch(r\"\\d{4}-\\d{2}-\\d{2}\", text):\n        return text.replace(\"-\", \"\")\n    raise ValueError(f\"无效日期 tag: {value}\")\n\n\ndef discover_latest_live_json() -> Path:\n    candidates = sorted(REPORT_DIR.glob(\"live_system_v1_????????.json\"))\n    if not candidates:\n        candidates = sorted(REPORT_DIR.glob(\"live_system_v1_*.json\"))\n    if not candidates:\n        raise FileNotFoundError(f\"未找到 live_system_v1_*.json: {REPORT_DIR}\")\n    return candidates[-1]\n\n\ndef discover_shadow_summary(date_tag: str, profile: str) -> Path | None:\n    patterns = [\n        f\"dual_factor_shadow*_{profile}_{date_tag}_summary.json\",\n        f\"dual_factor_shadow*{profile}*{date_tag}_summary.json\",\n    ]\n    candidates: list[Path] = []\n    for pattern in patterns:\n        candidates.extend(sorted(REPORT_DIR.glob(pattern)))\n    if not candidates:\n        return None\n    return candidates[-1]\n\n\ndef run_json_command(cmd: list[str]) -> dict[str, Any]:\n    proc = subprocess.run(cmd, cwd=str(PROJECT_ROOT), capture_output=True, text=True)\n    stdout = (proc.stdout or \"\").strip()\n    stderr = (proc.stderr or \"\").strip()\n    payload: dict[str, Any]\n    try:\n        payload = json.loads(stdout) if stdout else {}\n    except Exception:\n        payload = {\n            \"parse_error\": True,\n            \"stdout\": stdout[-3000:],\n            \"stderr\": stderr[-3000:],\n        }\n    payload.setdefault(\"_cmd\", cmd)\n    payload.setdefault(\"_returncode\", proc.returncode)\n    payload.setdefault(\"_stderr\", stderr[-3000:])\n    payload.setdefault(\"_stdout\", stdout[-3000:])\n    return payload\n\n\ndef ensure_shadow_summary(\n    *,\n    date_tag: str,\n    profile: str,\n    live_json_path: Path,\n    supplied_path: str = \"\",\n) -> Path:\n    if supplied_path:\n        path = Path(supplied_path).expanduser().resolve()\n        if not path.exists():\n            raise FileNotFoundError(f\"指定 shadow summary 不存在: {path}\")\n        return path\n\n    found = discover_shadow_summary(date_tag, profile)\n    if found is not None:\n        return found\n\n    cmd = [\n        \"python3\",\n        str(SCRIPTS_DIR / \"run_live_system_v1_dual_shadow.py\"),\n        \"--profile\",\n        profile,\n        \"--live-json\",\n        str(live_json_path),\n        \"--write-artifacts\",\n    ]\n    result = run_json_command(cmd)\n    if int(result.get(\"_returncode\", 1)) != 0:\n        raise RuntimeError(\n            \"自动生成 dual factor shadow 失败: \"\n            f\"returncode={result.get('_returncode')} stderr={result.get('_stderr', '')}\"\n        )\n    found = discover_shadow_summary(date_tag, profile)\n    if found is None:\n        shadow_summary = result.get(\"shadow_summary\") or {}\n        artifact_files = shadow_summary.get(\"artifact_files\") or {}\n        candidate = str(artifact_files.get(\"shadow_summary\") or \"\").strip()\n        if candidate:\n            found = Path(candidate).expanduser().resolve()\n    if found is None or not found.exists():\n        raise FileNotFoundError(f\"自动生成后仍未找到 shadow summary: date={date_tag} profile={profile}\")\n    return found\n\n\ndef resolve_baseline_runtime_metrics(date_tag: str, profile_slug: str = \"\") -> dict[str, Any]:\n    suffix = f\"_{profile_slug}\" if profile_slug else \"\"\n    path = REPORT_DIR / f\"runtime_risk_state_latest{suffix}.json\"\n    live_json_path = REPORT_DIR / f\"live_system_v1_{date_tag}.json\"\n    live_payload = load_json(live_json_path) if live_json_path.exists() else {}\n    combo = live_payload.get(\"combo_v1\") or {}\n    if not path.exists():\n        return {\n            \"source\": \"live_system_v1\",\n            \"path\": str(path),\n            \"strategy_max_dd_pct\": combo.get(\"max_drawdown_pct\"),\n            \"strategy_sharpe\": combo.get(\"sharpe\"),\n            \"annual_return_pct\": combo.get(\"annual_return_pct\"),\n            \"annual_vol_pct\": combo.get(\"annual_vol_pct\"),\n            \"risk_off\": None,\n            \"halt_new_buy\": None,\n            \"gate_reasons\": [],\n        }\n    payload = load_json(path)\n    if str(payload.get(\"date_tag\") or \"\") != str(date_tag):\n        return {\"source\": \"\", \"path\": str(path), \"date_mismatch\": True}\n    runtime_metrics = payload.get(\"runtime_metrics\") or {}\n    latest = payload.get(\"latest_runtime\") or {}\n    return {\n        \"source\": f\"runtime_risk_state_latest{suffix}\",\n        \"path\": str(path),\n        \"strategy_max_dd_pct\": runtime_metrics.get(\"strategy_max_dd_pct\", combo.get(\"max_drawdown_pct\")),\n        \"strategy_sharpe\": runtime_metrics.get(\"strategy_sharpe\", combo.get(\"sharpe\")),\n        \"annual_return_pct\": runtime_metrics.get(\"annual_return_pct\", combo.get(\"annual_return_pct\")),\n        \"annual_vol_pct\": runtime_metrics.get(\"annual_vol_pct\", combo.get(\"annual_vol_pct\")),\n        \"risk_off\": latest.get(\"risk_off\", False),\n        \"halt_new_buy\": latest.get(\"halt_new_buy\", False),\n        \"gate_reasons\": latest.get(\"gate_reasons\", []),\n    }\n\n\ndef resolve_shadow_runtime_metrics(summary: dict[str, Any], profile: str) -> dict[str, Any]:\n    selected = ((summary.get(\"profiles\") or {}).get(profile) or {})\n    overlay_block = summary.get(\"dual_factor_overlay\") or {}\n    runtime_inputs = (\n        selected.get(\"runtime_shadow_inputs\")\n        or summary.get(\"selected_runtime_shadow_inputs\")\n        or overlay_block.get(\"runtime_shadow_inputs\")\n        or {}\n    )\n    metrics = selected.get(\"metrics\") or overlay_block.get(\"selected_metrics\") or {}\n    latest_state = selected.get(\"latest_state\") or overlay_block.get(\"latest_state\") or {}\n    return {\n        \"strategy_max_dd_pct\": runtime_inputs.get(\"strategy_max_dd_pct\"),\n        \"strategy_sharpe\": runtime_inputs.get(\"strategy_sharpe\"),\n        \"annual_return_pct\": runtime_inputs.get(\"annual_return_pct\"),\n        \"annual_vol_pct\": runtime_inputs.get(\"annual_vol_pct\"),\n        \"risk_off\": None,\n        \"halt_new_buy\": None,\n        \"gate_reasons\": [],\n        \"latest_state\": latest_state,\n        \"metrics\": metrics,\n    }\n\n\ndef build_runtime_comparison(baseline_metrics: dict[str, Any], dual_metrics: dict[str, Any]) -> dict[str, Any]:\n    rows = []\n    metric_rows = [\n        (\"strategy_max_dd_pct\", \"策略最大回撤(%)\"),\n        (\"strategy_sharpe\", \"策略夏普\"),\n        (\"annual_return_pct\", \"策略年化收益(%)\"),\n        (\"annual_vol_pct\", \"策略年化波动(%)\"),\n    ]\n    for field, label in metric_rows:\n        baseline = baseline_metrics.get(field)\n        dual = dual_metrics.get(field)\n        try:\n            diff = round(float(dual) - float(baseline), 4)\n        except Exception:\n            diff = None\n        rows.append({\n            \"field\": field,\n            \"label\": label,\n            \"baseline\": baseline,\n            \"dual_factor\": dual,\n            \"diff\": diff,\n        })\n    for field, label in [(\"risk_off\", \"risk_off\"), (\"halt_new_buy\", \"halt_new_buy\")]:\n        rows.append({\n            \"field\": field,\n            \"label\": label,\n            \"baseline\": baseline_metrics.get(field),\n            \"dual_factor\": dual_metrics.get(field),\n            \"diff\": \"变化\" if baseline_metrics.get(field) != dual_metrics.get(field) else \"不变\",\n        })\n    return {\n        \"rows\": rows,\n        \"note\": \"diff = dual_factor - baseline；回撤/波动为负数更优，收益/夏普为正数更优\",\n    }\n\n\ndef run_paper_orders(\n    *,\n    config_path: str,\n    date_tag: str,\n    dual_factor_profile: str,\n    merged_signals: str = \"\",\n    tickets: str = \"\",\n) -> dict[str, Any]:\n    cmd = [\n        \"python3\",\n        str(SCRIPTS_DIR / \"prepare_paper_orders_v1.py\"),\n        \"--config\",\n        config_path,\n        \"--date\",\n        date_tag,\n        \"--dual-factor-profile\",\n        dual_factor_profile,\n    ]\n    if merged_signals:\n        cmd.extend([\"--merged-signals\", merged_signals])\n    if tickets:\n        cmd.extend([\"--tickets\", tickets])\n    return run_json_command(cmd)\n\n\ndef nested_get(payload: dict[str, Any], *keys: str) -> Any:\n    cur: Any = payload\n    for key in keys:\n        if not isinstance(cur, dict):\n            return None\n\n[320 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1775173255758}}
{"type":"message","id":"f47bfd01","parentId":"bed2abf1","timestamp":"2026-04-02T23:40:55.776Z","message":{"role":"toolResult","toolCallId":"call_nbMhbEcNRyFbpmzmAsYtH9hR|fc_0593218ebc10f81b0169cefe874da4819892072cec196f7d05","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nDual Factor Feature Flag Wrapper for Live System v1.\n\n支持三种模式：\n  off          → 纯 baseline，不做任何 dual factor 叠加（主链路默认值）\n  conservative → 使用 conservative profile（放大/收缩幅度更小）\n  default      → 使用 default profile（正式候选参数）\n\n与 run_live_system_v1.py 完全独立，不修改主链路产出。\n仅在已存在 baseline live_system_v1_*.json 的前提下，生成 shadow overlay 产物。\n\n用法：\n  python3 scripts/run_live_system_v1_dual_shadow.py --profile default --write-artifacts\n  python3 scripts/run_live_system_v1_dual_shadow.py --profile off --dry-run\n\"\"\"\nfrom __future__ import annotations\n\nimport argparse\nimport copy\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nfor candidate in [PROJECT_ROOT, PROJECT_ROOT / \"scripts\"]:\n    if str(candidate) not in sys.path:\n        sys.path.insert(0, str(candidate))\n\nimport subprocess\n\n# Feature flag 合法值\nVALID_PROFILES = {\"off\", \"default\", \"conservative\"}\n\n# Feature flag 字段元数据（用于 readiness JSON）\nFEATURE_FLAG_FIELDS = {\n    \"field\": \"dual_factor_profile\",\n    \"type\": \"string\",\n    \"enum\": [\"off\", \"default\", \"conservative\"],\n    \"default\": \"off\",\n    \"description\": \"控制 dual factor overlay 的接入档位；off=关闭，conservative=保守档，default=正式候选档\",\n    \"storage\": \"环境变量 DUAL_FACTOR_PROFILE 或命令行 --profile\",\n    \"non_invasive\": True,\n    \"main_line_behavior\": {\n        \"off\": \"完全不修改 combo_v1，保持 baseline live_system_v1.json 原样输出\",\n        \"conservative\": \"生成 shadow overlay 产物（曲线/摘要/payload），但不替换 combo_v1\",\n        \"default\": \"生成 shadow overlay 产物（曲线/摘要/payload），但不替换 combo_v1\",\n    },\n}\n\n\ndef discover_latest_live_json() -> Path:\n    # 优先标准版本 live_system_v1_YYYYMMDD.json，排除 enhanced / backup 等变体\n    candidates = sorted(REPORT_DIR.glob(\"live_system_v1_????????.json\"))\n    if not candidates:\n        # 降级：允许其他后缀\n        all_candidates = sorted(REPORT_DIR.glob(\"live_system_v1_*.json\"))\n        if not all_candidates:\n            raise FileNotFoundError(f\"未找到 live_system_v1_*.json，请先运行 run_live_system_v1.py: {REPORT_DIR}\")\n        candidates = all_candidates\n    return candidates[-1]\n\n\ndef run_dual_shadow(\n    *,\n    live_json_path: Path,\n    profile: str,\n    write_artifacts: bool = False,\n    output_prefix: str = \"dual_factor_shadow\",\n) -> dict[str, Any]:\n    \"\"\"通过 subprocess 调用 integrate_dual_factor_overlay，避免 stdout 捕获冲突。\"\"\"\n    argv = [\n        \"python3\",\n        str(PROJECT_ROOT / \"scripts\" / \"integrate_dual_factor_overlay.py\"),\n        \"--live-json\", str(live_json_path),\n        \"--profile\", profile,\n    ]\n    if write_artifacts:\n        argv.append(\"--write-artifacts\")\n    argv.extend([\"--output-prefix\", output_prefix])\n\n    proc = subprocess.run(\n        argv,\n        cwd=str(PROJECT_ROOT),\n        capture_output=True,\n        text=True,\n    )\n    combined = (proc.stdout or \"\") + (proc.stderr or \"\")\n    try:\n        return json.loads(proc.stdout or combined)\n    except Exception:\n        return {\n            \"returncode\": proc.returncode,\n            \"stdout\": (proc.stdout or \"\")[:500],\n            \"stderr\": (proc.stderr or \"\")[:500],\n            \"combined\": combined[:500],\n        }\n\n\ndef build_shadow_diff_summary(\n    *,\n    baseline_payload: dict[str, Any],\n    shadow_summary: dict[str, Any],\n    profile: str,\n) -> dict[str, Any]:\n    \"\"\"在 baseline vs dual shadow 之间构建 diff 结构，用于快速对照。\"\"\"\n    baseline_combo = baseline_payload.get(\"combo_v1\", {})\n    baseline_metrics = {\n        \"ann_ret\": baseline_combo.get(\"annual_return_pct\", 0.0),\n        \"max_dd\": baseline_combo.get(\"max_drawdown_pct\", 0.0),\n        \"sharpe\": baseline_combo.get(\"sharpe\", 0.0),\n    }\n\n    selected = shadow_summary.get(\"profiles\", {}).get(profile, {})\n    dual_metrics = selected.get(\"metrics\", {})\n    dual_diff = selected.get(\"diff_vs_baseline\", {})\n\n    # guardrails 位于 live_payload JSON 中，不在 summary JSON 里\n    guardrails: list[str] = []\n    if isinstance(shadow_summary.get(\"dual_factor_overlay\"), dict):\n        guardrails = shadow_summary[\"dual_factor_overlay\"].get(\"guardrails\", [])\n    else:\n        # artifact_files 在 --write-artifacts 时写入 summary；live_payload 里有完整 guardrails\n        live_payload_path = (\n            shadow_summary.get(\"artifact_files\", {}).get(\"shadow_live_payload\")\n            or shadow_summary.get(\"files\", {}).get(\"shadow_live_payload\")\n        )\n        if live_payload_path and Path(live_payload_path).exists():\n            try:\n                live_payload = json.loads(Path(live_payload_path).read_text(encoding=\"utf-8\"))\n                guardrails = (live_payload.get(\"dual_factor_overlay\") or {}).get(\"guardrails\", [])\n            except Exception:\n                pass\n\n    return {\n        \"comparison\": {\n            \"baseline\": baseline_metrics,\n            \"dual_factor\": dual_metrics,\n            \"diff\": dual_diff,\n        },\n        \"key_signals\": {\n            \"ann_ret_change_pp\": dual_diff.get(\"ann_ret_pp\", 0.0),\n            \"max_dd_change_pp\": dual_diff.get(\"max_dd_pp\", 0.0),\n            \"sharpe_change\": dual_diff.get(\"sharpe\", 0.0),\n        },\n        \"runtime_shadow_inputs\": selected.get(\"runtime_shadow_inputs\", {}),\n        \"latest_state\": selected.get(\"latest_state\", {}),\n        \"guardrails\": guardrails,\n    }\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(\n        description=\"Dual Factor Feature Flag Wrapper — 读取 live_system_v1 结果并叠加 dual factor shadow\",\n    )\n    parser.add_argument(\n        \"--profile\",\n        choices=[\"off\", \"default\", \"conservative\"],\n        default=\"off\",\n        help=(\n            \"off=不叠加（纯 baseline），\"\n            \"conservative=保守档 dual factor（放大/收缩幅度 ±5%~±10%），\"\n            \"default=正式候选档 dual factor（放大/收缩幅度 ±10%~±15%）。\"\n            \"off 为主链路默认值。\"\n        ),\n    )\n    parser.add_argument(\n        \"--live-json\",\n        default=\"\",\n        help=\"指定 live_system_v1_YYYYMMDD.json；默认自动取最新\",\n    )\n    parser.add_argument(\n        \"--write-artifacts\",\n        action=\"store_true\",\n        help=\"写出 shadow 曲线/摘要/live payload（默认只打印摘要，不写文件）\",\n    )\n    parser.add_argument(\n        \"--dry-run\",\n        action=\"store_true\",\n        help=\"仅打印 diff 对照，不写任何文件\",\n    )\n    parser.add_argument(\n        \"--output-prefix\",\n        default=\"dual_factor_shadow\",\n        help=\"输出前缀（仅 --write-artifacts 时生效）\",\n    )\n    args = parser.parse_args()\n\n    # ---- 解析 profile ----\n    profile = args.profile.lower().strip()\n    if profile not in VALID_PROFILES:\n        raise ValueError(f\"无效 profile={profile}，合法值：{VALID_PROFILES}\")\n\n    # ---- 发现 baseline live_system_v1 ----\n    if args.live_json:\n        live_json_path = Path(args.live_json).expanduser().resolve()\n    else:\n        live_json_path = discover_latest_live_json()\n\n    if not live_json_path.exists():\n        raise FileNotFoundError(f\"live_system_v1 JSON 不存在：{live_json_path}，请先运行 run_live_system_v1.py\")\n\n    baseline_payload = json.loads(live_json_path.read_text(encoding=\"utf-8\"))\n    date_tag = str(baseline_payload.get(\"date\") or datetime.now().strftime(\"%Y%m%d\"))\n    output_prefix = f\"{args.output_prefix}_{date_tag}\"\n\n    # ---- 处理三种模式 ----\n    result: dict[str, Any] = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"feature_flag\": {\n            \"field\": \"dual_factor_profile\",\n            \"profile\": profile,\n            \"valid_values\": list(VALID_PROFILES),\n            \"main_line_unchanged\": profile == \"off\",\n        },\n        \"live_system_v1\": str(live_json_path),\n        \"date_tag\": date_tag,\n    }\n\n    if profile == \"off\":\n        # off 模式：不做任何 dual factor 叠加\n        result[\"status\"] = \"off\"\n        result[\"message\"] = \"dual_factor_profile=off，未做任何 dual factor 叠加，baseline combo_v1 保持不变\"\n        result[\"baseline_metrics\"] = baseline_payload.get(\"combo_v1\", {})\n        result[\"shadow\"] = None\n        print(json.dumps(result, ensure_ascii=False, indent=2))\n        return\n\n    # ---- default / conservative：调用 integrate_dual_factor_overlay ----\n    shadow_summary = run_dual_shadow(\n        live_json_path=live_json_path,\n        profile=profile,\n        write_artifacts=(args.write_artifacts and not args.dry_run),\n        output_prefix=output_prefix,\n    )\n\n    diff = build_shadow_diff_summary(\n        baseline_payload=baseline_payload,\n        shadow_summary=shadow_summary,\n        profile=profile,\n    )\n\n    result[\"status\"] = \"shadow_generated\"\n    result[\"profile\"] = profile\n    result[\"feature_flag_note\"] = (\n        \"shadow 产物已生成，但 baseline combo_v1 仍未被替换；\"\n        \"需在完成 shadow 对照验证后，通过 feature flag 切换才可正式接入主链路\"\n    )\n    result[\"shadow\"] = diff\n    result[\"shadow_summary\"] = shadow_summary\n\n    if args.dry_run:\n        result[\"artifacts_written\"] = False\n        result[\"message\"] = \"dry-run 模式，仅打印 shadow diff，不写文件\"\n    else:\n        result[\"artifacts_written\"] = args.write_artifacts\n        result[\"message\"] = (\n\n[10 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1775173255766}}
{"type":"message","id":"d92387ea","parentId":"f47bfd01","timestamp":"2026-04-02T23:40:55.785Z","message":{"role":"toolResult","toolCallId":"call_9l2iG4V0JhnHbRnc5JKehOoj|fc_0593218ebc10f81b0169cefe874dac8198a5f8e6992e88e437","toolName":"read","content":[{"type":"text","text":"\ndef compute_regime_snapshots(\n    config: dict[str, Any],\n    *,\n    date_tag: str | None = None,\n    benchmark_code: str | None = None,\n    market_breadth: float | None = None,\n) -> dict[str, Any]:\n    return {\n        \"volatility\": compute_volatility_regime_snapshot(\n            config,\n            date_tag=date_tag,\n            benchmark_code=benchmark_code,\n            market_breadth=market_breadth,\n        ),\n        \"liquidity\": compute_liquidity_regime_snapshot(config, date_tag=date_tag, benchmark_code=benchmark_code),\n    }\n\n\ndef apply_regime_overlays(\n    *,\n    mode: str,\n    risk_off: bool,\n    hard_stop: bool,\n    halt_new_buy: bool,\n    gate_reasons: list[str] | None,\n    volatility_snapshot: dict[str, Any] | None = None,\n    liquidity_snapshot: dict[str, Any] | None = None,\n) -> dict[str, Any]:\n    mode_text = str(mode or \"normal\").strip().lower() or \"normal\"\n    reasons = [str(item).strip() for item in (gate_reasons or []) if str(item).strip()]\n    risk_off_flag = bool(risk_off)\n    hard_stop_flag = bool(hard_stop)\n    halt_new_buy_flag = bool(halt_new_buy)\n\n    vol_state = str((volatility_snapshot or {}).get(\"state\") or \"\").strip().lower()\n    vol_reasons = [str(item).strip() for item in ((volatility_snapshot or {}).get(\"gate_reasons\") or []) if str(item).strip()]\n    if vol_state == \"halt\":\n        hard_stop_flag = True\n        risk_off_flag = True\n        halt_new_buy_flag = True\n        mode_text = \"halt\"\n        reasons.extend(vol_reasons)\n    elif vol_state == \"risk_off\" and not hard_stop_flag:\n        risk_off_flag = True\n        halt_new_buy_flag = True\n        if mode_text == \"normal\":\n            mode_text = \"cautious\"\n        reasons.extend(vol_reasons)\n\n    liq_state = str((liquidity_snapshot or {}).get(\"state\") or \"\").strip().lower()\n    liq_reasons = [str(item).strip() for item in ((liquidity_snapshot or {}).get(\"gate_reasons\") or []) if str(item).strip()]\n    if liq_state == \"halt\" and not hard_stop_flag:\n        risk_off_flag = True\n        halt_new_buy_flag = True\n        if mode_text == \"normal\":\n            mode_text = \"cautious\"\n        reasons.extend(liq_reasons)\n    elif liq_state == \"risk_off\" and not hard_stop_flag:\n        risk_off_flag = True\n        halt_new_buy_flag = True\n        if mode_text == \"normal\":\n            mode_text = \"cautious\"\n        reasons.extend(liq_reasons)\n\n    deduped_reasons = list(dict.fromkeys(reasons))\n    return {\n        \"mode\": mode_text,\n        \"risk_off\": risk_off_flag,\n        \"hard_stop\": hard_stop_flag,\n        \"halt_new_buy\": halt_new_buy_flag,\n        \"gate_reasons\": deduped_reasons,\n        \"halt_reason\": deduped_reasons[0] if deduped_reasons else \"\",\n    }\n"}],"isError":false,"timestamp":1775173255776}}
{"type":"message","id":"e887120d","parentId":"d92387ea","timestamp":"2026-04-02T23:40:55.795Z","message":{"role":"toolResult","toolCallId":"call_BwlObOQujQ2Hljd35dQ1dUlv|fc_0593218ebc10f81b0169cefe874db08198a8be96785be8090a","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nT05 Step 1: Generate per-panel runtime risk state files.\nReads the global runtime_risk_state_latest.json as base,\nthen applies per-panel thresholds from panel_profile_registry,\nwriting aggressive/balanced/defensive variants.\n\"\"\"\nimport json, sys\nfrom pathlib import Path\nfrom typing import Optional\n\nPROJECT_ROOT = Path(__file__).parent.parent\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nsys.path.insert(0, str(PROJECT_ROOT))\n\nfrom scripts.panel_profile_registry import PROFILE_RUNTIME_RISK_CONFIG\n\ndef load_global_risk():\n    path = REPORT_DIR / \"runtime_risk_state_latest.json\"\n    if not path.exists():\n        raise FileNotFoundError(f\"Global runtime risk state not found: {path}\")\n    with open(path) as f:\n        return json.load(f)\n\ndef load_paper_latest_metrics(profile_slug: str) -> Optional[dict]:\n    \"\"\"Load the latest paper trading metrics for a given profile slug.\n    Returns None if no metrics file exists yet.\n    \"\"\"\n    files = sorted((REPORT_DIR).glob(f\"paper_{profile_slug}_trading_metrics_*.json\"))\n    if not files:\n        return None\n    with open(files[-1]) as f:\n        return json.load(f)\n\ndef get_paper_real_drawdown(profile_slug: str) -> Optional[float]:\n    \"\"\"Get paper account's real max_drawdown_pct from its latest metrics.\n    Returns None if no metrics file is available (fallback to live_system data).\n    \"\"\"\n    metrics = load_paper_latest_metrics(profile_slug)\n    if metrics is None:\n        return None\n    dd = metrics.get(\"metrics\", {}).get(\"max_drawdown_pct\")\n    if dd is not None:\n        return float(dd)\n    return None\n\ndef compute_panel_risk(global_risk: dict, profile_slug: str) -> dict:\n    \"\"\"Build a per-panel runtime risk state with panel-level halt logic.\n    \n    进取方案核心修复：使用纸盘自己的真实最大回撤，\n    而不是 live_system_v1 的11年回测回撤（24.51%），\n    避免纸盘被历史回测数据错误地halt。\n    \"\"\"\n    cfg = PROFILE_RUNTIME_RISK_CONFIG.get(profile_slug, {})\n    halt_pct = cfg.get(\"strategy_max_drawdown_halt_pct\", 15.0)\n    riskoff_pct = cfg.get(\"strategy_max_drawdown_riskoff_pct\", 10.0)\n    \n    global_metrics = global_risk.get(\"runtime_metrics\", {})\n    # 进取方案：优先用纸盘自己的真实回撤；没有则降级用全局live_system数据\n    current_dd = get_paper_real_drawdown(profile_slug)\n    if current_dd is None:\n        current_dd = global_metrics.get(\"strategy_max_dd_pct\", 0.0)\n    \n    # Panel-level halt decision\n    halt_new_buy = current_dd >= halt_pct\n    risk_off = current_dd >= riskoff_pct\n    \n    # Gate reasons\n    gate_reasons = []\n    if risk_off:\n        gate_reasons.append(f\"strategy_max_drawdown_pct({current_dd:.4f}) >= {riskoff_pct:.4f}\")\n    if halt_new_buy:\n        gate_reasons.append(f\"strategy_max_drawdown_pct({current_dd:.4f}) >= HALT_THRESHOLD({halt_pct:.4f})\")\n    \n    # Build the panel runtime risk state\n    # NOTE: The base_runtime section contains a nested runtime_truth (pre-computed\n    # from global thresholds) which overrides our panel-level fields when read\n    # by runtime_state_schema.get_runtime_truth(). We must also override that\n    # nested runtime_truth with the correct per-panel halt decision.\n    per_panel_rt = {\n        \"state\": \"risk_off\" if risk_off else (\"normal\" if not halt_new_buy else \"halted\"),\n        \"state_reason\": f\"strategy_max_drawdown_pct({current_dd:.4f}) >= {riskoff_pct:.4f}\" if risk_off else \"\",\n        \"trading_status\": \"BUY_HALT\" if halt_new_buy else \"TRADING\",\n        \"trading_status_reason\": f\"strategy_max_drawdown_pct({current_dd:.4f}) >= {halt_pct:.4f}\" if halt_new_buy else \"per_panel_ok\",\n        \"trading_status_label_cn\": \"禁止买入\" if halt_new_buy else \"正常交易\",\n        \"mode\": \"cautious\" if risk_off else (\"normal\" if not halt_new_buy else \"halted\"),\n        \"risk_off\": risk_off,\n        \"hard_stop\": False,\n        \"halt_new_buy\": halt_new_buy,\n        \"gate_reasons\": gate_reasons,\n        \"buy_authorized\": not halt_new_buy,\n        \"trading_ready\": not halt_new_buy,\n        \"severity\": \"RED\" if halt_new_buy else (\"YELLOW\" if risk_off else \"GREEN\"),\n        \"source\": f\"per_panel_t05_{profile_slug}\",\n        \"pipeline_ok\": True,\n        \"precheck_passed\": None,\n        \"advice_only\": True,\n    }\n\n    panel_risk = {\n        **global_risk,\n        \"generated_at\": global_risk.get(\"generated_at\", \"\"),\n        \"panel\": profile_slug,\n        \"panel_halt_threshold_pct\": halt_pct,\n        \"panel_riskoff_threshold_pct\": riskoff_pct,\n        \"runtime_metrics\": {\n            **global_metrics,\n            \"panel_strategy_max_dd_pct\": current_dd,\n        },\n        # Override top-level runtime_truth so get_runtime_truth() picks up per-panel values\n        \"runtime_truth\": per_panel_rt,\n        # Override latest_runtime too (fallback path in get_runtime_truth)\n        \"latest_runtime\": {\n            **(global_risk.get(\"latest_runtime\") or {}),\n            \"mode\": per_panel_rt[\"mode\"],\n            \"risk_off\": risk_off,\n            \"hard_stop\": False,\n            \"halt_new_buy\": halt_new_buy,\n            \"halt_reason\": f\"strategy_max_drawdown_pct({current_dd:.4f}) >= {halt_pct:.4f}\" if halt_new_buy else \"\",\n            \"gate_reasons\": gate_reasons,\n            \"runtime_truth\": per_panel_rt,\n        },\n        \"base_runtime\": {\n            **(global_risk.get(\"base_runtime\") or {}),\n            \"mode\": per_panel_rt[\"mode\"],\n            \"halt_new_buy\": halt_new_buy,\n            \"risk_off\": risk_off,\n            \"halt_reason\": f\"strategy_max_drawdown_pct({current_dd:.4f}) >= {halt_pct:.4f}\" if halt_new_buy else \"\",\n            \"gate_reasons\": gate_reasons,\n            \"runtime_truth\": per_panel_rt,\n        },\n        \"note\": f\"Per-panel runtime risk truth for {profile_slug}: halt>@{halt_pct}%(dd={current_dd}%), riskoff>@{riskoff_pct}%\",\n    }\n    return panel_risk\n\ndef main():\n    global_risk = load_global_risk()\n    \n    for profile_slug in [\"aggressive\", \"balanced\", \"defensive\"]:\n        panel_risk = compute_panel_risk(global_risk, profile_slug)\n        out_path = REPORT_DIR / f\"runtime_risk_state_latest_{profile_slug}.json\"\n        with open(out_path, \"w\") as f:\n            json.dump(panel_risk, f, indent=2, ensure_ascii=False)\n        # 进取方案：同时打印paper真实DD（已注入到panel_risk[\"runtime_metrics\"]）\n        br = panel_risk[\"base_runtime\"]\n        paper_dd = panel_risk[\"runtime_metrics\"].get(\"panel_strategy_max_dd_pct\")\n        live_dd = global_risk[\"runtime_metrics\"][\"strategy_max_dd_pct\"]\n        print(f\"  {profile_slug}: halt={br['halt_new_buy']}, risk_off={br['risk_off']}, \"\n              f\"halt_pct={panel_risk['panel_halt_threshold_pct']}%, \"\n              f\"paper_dd={paper_dd:.4f}% (live_sys={live_dd}%)\")\n    \n    print(f\"\\nGenerated 3 per-panel runtime risk files in {REPORT_DIR}\")\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1775173255785}}
