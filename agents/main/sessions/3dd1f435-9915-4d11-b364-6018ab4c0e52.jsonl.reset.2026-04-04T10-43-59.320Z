{"type":"message","id":"35a72812","parentId":"96ef3c2b","timestamp":"2026-04-02T23:41:21.455Z","message":{"role":"toolResult","toolCallId":"call_1hlwuMeoaccj4NyM3CCcq6TQ|fc_0593218ebc10f81b0169cefea088a48198a5f04274e2b5ea68","toolName":"read","content":[{"type":"text","text":"    alignment[(roc_multiplier < 1.0) & (rsv_multiplier < 1.0)] = \"双空\"\n    alignment[(roc_multiplier > 1.0) & (rsv_multiplier < 1.0)] = \"ROC强+RSV弱\"\n    alignment[(roc_multiplier < 1.0) & (rsv_multiplier > 1.0)] = \"ROC弱+RSV强\"\n    alignment[(roc_multiplier == 1.0) & (rsv_multiplier < 1.0)] = \"ROC中性+RSV弱\"\n    alignment[(roc_multiplier == 1.0) & (rsv_multiplier > 1.0)] = \"ROC中性+RSV强\"\n    alignment = alignment.fillna(\"中性\")\n\n    snapshot = {\n        \"profile\": profile_name,\n        \"params\": profile,\n        \"metrics\": dual_metrics,\n        \"diff_vs_baseline\": diff_metrics(dual_metrics, baseline_metrics),\n        \"signal_stats\": {\n            \"roc10\": {\n                \"bull_days\": int((roc_multiplier > 1.0).sum()),\n                \"bear_days\": int((roc_multiplier < 1.0).sum()),\n                \"neutral_days\": int((roc_multiplier == 1.0).sum()),\n            },\n            \"rsv5\": {\n                \"bull_days\": int((rsv_multiplier > 1.0).sum()),\n                \"bear_days\": int((rsv_multiplier < 1.0).sum()),\n            },\n            \"dual_multiplier\": {\n                \"min\": round(float(dual_multiplier.min()), 4),\n                \"max\": round(float(dual_multiplier.max()), 4),\n                \"mean\": round(float(dual_multiplier.mean()), 4),\n            },\n            \"alignment_counts\": {str(k): int(v) for k, v in alignment.value_counts().to_dict().items()},\n        },\n        \"latest_state\": {\n            \"date\": str(pd.Timestamp(latest[\"date\"]).date()),\n            \"roc10_signal\": round(float(latest[\"roc10_signal\"]), 6) if pd.notna(latest[\"roc10_signal\"]) else None,\n            \"roc10_multiplier\": round(float(latest[\"roc10_multiplier\"]), 4),\n            \"rsv5_signal\": round(float(latest[\"rsv5_signal\"]), 6) if pd.notna(latest[\"rsv5_signal\"]) else None,\n            \"rsv5_rolling_median\": round(float(latest[\"rsv5_rolling_median\"]), 6) if pd.notna(latest[\"rsv5_rolling_median\"]) else None,\n            \"rsv5_multiplier\": round(float(latest[\"rsv5_multiplier\"]), 4),\n            \"dual_multiplier\": round(float(latest[\"dual_multiplier\"]), 4),\n        },\n        \"runtime_shadow_inputs\": {\n            \"strategy_max_dd_pct\": dual_metrics[\"max_dd\"],\n            \"strategy_sharpe\": dual_metrics[\"sharpe\"],\n            \"annual_return_pct\": dual_metrics[\"ann_ret\"],\n            \"annual_vol_pct\": dual_metrics[\"annual_vol\"],\n        },\n    }\n    return snapshot, curve_df\n\n\ndef build_shadow_live_payload(\n    *,\n    baseline_payload: dict[str, Any],\n    baseline_curve_path: Path,\n    baseline_metrics: dict[str, Any],\n    selected_snapshot: dict[str, Any],\n    shadow_curve_path: Path,\n    summary_path: Path,\n) -> dict[str, Any]:\n    payload = copy.deepcopy(baseline_payload)\n    payload[\"dual_factor_overlay\"] = {\n        \"mode\": \"shadow_only\",\n        \"status\": \"candidate_for_paper_shadow\",\n        \"baseline_combo_v1\": baseline_payload.get(\"combo_v1\", {}),\n        \"baseline_metrics_normalized\": baseline_metrics,\n        \"selected_profile\": selected_snapshot[\"profile\"],\n        \"selected_metrics\": selected_snapshot[\"metrics\"],\n        \"selected_diff_vs_baseline\": selected_snapshot[\"diff_vs_baseline\"],\n        \"selected_params\": selected_snapshot[\"params\"],\n        \"latest_state\": selected_snapshot[\"latest_state\"],\n        \"runtime_shadow_inputs\": selected_snapshot[\"runtime_shadow_inputs\"],\n        \"guardrails\": [\n            \"不直接覆盖 combo_v1，先作为 shadow overlay 并行落地。\",\n            \"纸盘阶段先比对 runtime gate 与 orders diff，未完成对照前不替换主链路。\",\n            \"出现 dual 指标异常或数据不新鲜时，立即回退到 baseline combo_v1。\",\n        ],\n        \"files\": {\n            \"baseline_curve\": str(baseline_curve_path),\n            \"shadow_curve\": str(shadow_curve_path),\n            \"shadow_summary\": str(summary_path),\n        },\n    }\n    return payload\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"构建 live_system_v1 的双因子正式集成 shadow 产物\")\n    parser.add_argument(\"--live-json\", default=\"\", help=\"指定 live_system_v1_YYYYMMDD.json；默认自动取最新\")\n    parser.add_argument(\"--formal-params\", default=str(FORMAL_PARAMS_PATH), help=\"formal params json\")\n    parser.add_argument(\"--robustness\", default=str(ROBUSTNESS_PATH), help=\"robustness json\")\n    parser.add_argument(\"--sse-index-file\", default=str(DEFAULT_SSE_INDEX_FILE), help=\"上证综指缓存 csv\")\n    parser.add_argument(\"--profile\", choices=[\"default\", \"conservative\"], default=\"default\", help=\"选定输出 profile\")\n    parser.add_argument(\"--write-artifacts\", action=\"store_true\", help=\"写出 shadow 曲线/摘要/live payload\")\n    parser.add_argument(\"--output-prefix\", default=\"dual_factor_shadow\", help=\"输出前缀，仅在 --write-artifacts 时生效\")\n    args = parser.parse_args()\n\n    live_json_path = Path(args.live_json).expanduser().resolve() if args.live_json else discover_latest_live_json()\n    formal_params_path = Path(args.formal_params).expanduser().resolve()\n    robustness_path = Path(args.robustness).expanduser().resolve()\n    sse_index_file = Path(args.sse_index_file).expanduser().resolve()\n\n    formal_params = load_json(formal_params_path) if formal_params_path.exists() else None\n    robustness = load_json(robustness_path) if robustness_path.exists() else None\n    profiles = build_profiles(formal_params)\n\n    live_payload, baseline_curve_path, baseline_curve = load_live_payload(live_json_path)\n    baseline_metrics = normalize_metrics(baseline_curve)\n    market_close = load_market_close(baseline_curve.index)\n    sse_index = load_sse_index(baseline_curve.index, sse_index_file)\n\n    snapshots: dict[str, dict[str, Any]] = {}\n    curve_frames: dict[str, pd.DataFrame] = {}\n    for profile_name, profile in profiles.items():\n        snapshot, curve_df = build_profile_snapshot(\n            profile_name=profile_name,\n            profile=profile,\n            baseline_curve=baseline_curve,\n            market_close=market_close,\n            sse_index=sse_index,\n        )\n        snapshots[profile_name] = snapshot\n        curve_frames[profile_name] = curve_df\n\n    selected_snapshot = snapshots[args.profile]\n    date_tag = str(live_payload.get(\"date\") or datetime.now().strftime(\"%Y%m%d\"))\n    prefix = f\"{args.output_prefix}_{args.profile}_{date_tag}\"\n    shadow_curve_path = REPORT_DIR / f\"{prefix}_curve.csv\"\n    shadow_summary_path = REPORT_DIR / f\"{prefix}_summary.json\"\n    shadow_live_json_path = REPORT_DIR / f\"{prefix}_live_payload.json\"\n\n    summary = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"integration_mode\": \"shadow_only\",\n        \"formal_version\": str((formal_params or {}).get(\"formal_version\") or \"dual_factor_rsv5_roc10_v1\"),\n        \"live_system_path\": str(live_json_path),\n        \"baseline_curve_path\": str(baseline_curve_path),\n        \"selected_profile\": args.profile,\n        \"baseline_metrics\": baseline_metrics,\n        \"profiles\": snapshots,\n        \"selected_runtime_shadow_inputs\": selected_snapshot[\"runtime_shadow_inputs\"],\n        \"validated_reference_metrics\": (formal_params or {}).get(\"validated_metrics\") if isinstance(formal_params, dict) else None,\n        \"shadow_metrics_note\": \"profiles.*.metrics 为当前集成脚本按 live_system combo_curve 实时重算的 shadow 指标；正式立项口径仍以 dual_factor_formal_params.json / dual_factor_robustness_report.json 为准。\",\n        \"integration_entrypoints\": {\n            \"live_system_source\": \"research/reports/live_system_v1_*.json\",\n            \"combo_curve\": str(baseline_curve_path),\n            \"paper_runtime_reader\": \"scripts/prepare_paper_orders_v1.py -> runtime_date_utils.load_runtime_metrics_for_date()\",\n            \"panel_risk_generator\": \"scripts/generate_per_panel_runtime_risk_t05.py\",\n        },\n        \"recommended_actions\": [\n            \"保持 baseline live_system_v1 不变，先生成 dual_factor shadow 产物。\",\n            \"用 selected_runtime_shadow_inputs 对照 runtime risk / paper orders diff，不直接改主链路。\",\n            \"若 shadow 连续验证通过，再做 feature flag 级别的灰度接入。\",\n        ],\n        \"robustness_reference\": robustness.get(\"summary\") if isinstance(robustness, dict) else None,\n    }\n\n    if args.write_artifacts:\n        REPORT_DIR.mkdir(parents=True, exist_ok=True)\n        curve_frames[args.profile].to_csv(shadow_curve_path, index=False)\n        shadow_summary_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n        shadow_payload = build_shadow_live_payload(\n            baseline_payload=live_payload,\n            baseline_curve_path=baseline_curve_path,\n            baseline_metrics=baseline_metrics,\n            selected_snapshot=selected_snapshot,\n            shadow_curve_path=shadow_curve_path,\n            summary_path=shadow_summary_path,\n        )\n        shadow_live_json_path.write_text(json.dumps(shadow_payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n        summary[\"artifact_files\"] = {\n            \"shadow_curve\": str(shadow_curve_path),\n            \"shadow_summary\": str(shadow_summary_path),\n\n[9 more lines in file. Use offset=390 to continue.]"}],"isError":false,"timestamp":1775173281446}}
{"type":"message","id":"0276c2cf","parentId":"35a72812","timestamp":"2026-04-02T23:41:31.354Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Inspecting order logic**\n\nThis confirms that the latest state only includes multipliers and not risk_off/halt. It leads me to believe that the report stating risk_off to be false originated from another source, possibly paper orders outputs or a validation script that miscalculated. I need to take a closer look at the logic in prepare_paper_orders_v1, especially regarding dual-factor profiles. This feels crucial, so I'll search through the related parts concerning patching runtime truth.","thinkingSignature":"{\"id\":\"rs_0593218ebc10f81b0169cefea746a0819891cb5899aefed28f\",\"type\":\"reasoning\",\"encrypted_content\":\"gAAAAABpzv6qiMj4rtRYDgSF7bspFDUKVgfjua0evdxNcgF9qyfjC8MjRWTUK1BM6G5MvlG56eTKMKQnIQ6IeI3hP9lHvBDDTFN5fpEO6ARU0yaQaelhv_so7Jk2OLV7jy0oJKt9x_Jb17Yk-NXIdrtnoX51LmnPPOwjQsRXeIR8gHbT8quySlpHo_AmRBdaasJB9oAXxETEJoFtnt5hzAEFi_D-Nr2VzazXYsyYGFznGsikscDv83VPB_P7JSsheXMx_s4E4lGHZc1Jlqssxqx6v4Y9VdYUMiwDtO1isGJvHtk2Vlo2VpVNs_c_BOEhcbXSoULL0WFKQ_kBn0R7b0C7w6hkQA58vpyPEwrv4yrbEe7cmFLoR7Tq5XiZA8JDeyJNDVCRaK2ENb2rLeysCUuMlLCd67xghINDwO1ztCN4sG-_imqnG6qnc8HM0YNK199BGTqcXXaVxKiyZLlvFbpS0kRGAjYSqaXDc3ecrBr6I-zChPmzigOYX9zQWv453rhF-iYkxHvV7wmQyQ5Gxm8j5P2YNUfNitp4g-KTvIi5wqRdRZSKhDHgkvGsLsJRboCFz6Nchg1mQdoNoP4eohfu5QCdS1mbhupjtHrebn-dYL4p1s0sS1nR8SHTjyMYBU25Kj_ZB_OgbNaE3zTPX_vzFzp_7X8MjuQntHYQWLXlsTmoFjvXCXHD2LFsinE2KNxegs846I-2aaR7Mq1I5SoPi3NW4lNxcSz7ZncumG2puWM0SeFFrkCQp7VSbOxShQQOs6Shc9L6ZiDXcQVd1H8e04v0qBw-BqMb8EfTKjs8Qtt13drkfngDH4bDtaSG3OsOUEbSHCZYvVkehsvgmeFnHPcO16QLArVN10BYdwzsBWiPzMXmZGGL3-gQRTzJiTP5bJiiw8GyufUkFIyfZxblfbTO2WUu4AHCIyiGnOqwTW-7ynLAjiGR06RcNybZzGRPt4h6CnLgQsLdFWp2esG3wR-RDru0b0Bfavzx8XW8sSOjb6DoBoqEnkezenwuDNBnbwBd7sKy5N7X97DXsO0L2qeO6N-94m9b26DMERPcwEgUAWS30-EuMBxLWZwUxpgzHIeSEYxZQMTIZEZDYEhS28FsgjvbWrDJILCPSzXj4AY-whj5LJV6CY8v4nmvcLtb90AAB09uJbdMAfRxZklsJovK5qcYSNT6V0LBhIUUKlZzPUzd1RUCadNOTSlYsn6-XpKtXnJV3720RE1FmMJdRUmHCNlTVTg03cMqmupeQo0wJzHf-bJHS9ORORDv2EK3_13aaNco\",\"summary\":[{\"type\":\"summary_text\",\"text\":\"**Inspecting order logic**\\n\\nThis confirms that the latest state only includes multipliers and not risk_off/halt. It leads me to believe that the report stating risk_off to be false originated from another source, possibly paper orders outputs or a validation script that miscalculated. I need to take a closer look at the logic in prepare_paper_orders_v1, especially regarding dual-factor profiles. This feels crucial, so I'll search through the related parts concerning patching runtime truth.\"}]}"},{"type":"toolCall","id":"call_FM11j0dmsUZSuz35A9JXdaqy|fc_0593218ebc10f81b0169cefeaaf3508198a21cb1f4ada99b75","name":"read","arguments":{"file":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/prepare_paper_orders_v1.py","offset":250,"limit":180},"partialJson":"{\"file\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/prepare_paper_orders_v1.py\",\"offset\":250,\"limit\":180}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":2308,"output":122,"cacheRead":80256,"cacheWrite":0,"totalTokens":82686,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775173281456,"responseId":"resp_0593218ebc10f81b0169cefea3e13481989734ce8bd096f58f"}}
{"type":"message","id":"19650625","parentId":"0276c2cf","timestamp":"2026-04-02T23:41:31.455Z","message":{"role":"toolResult","toolCallId":"call_FM11j0dmsUZSuz35A9JXdaqy|fc_0593218ebc10f81b0169cefeaaf3508198a21cb1f4ada99b75","toolName":"read","content":[{"type":"text","text":"        return None\n\n    cached_market_breadth = latest_runtime.get(\"market_breadth\", runtime_metrics.get(\"market_breadth\"))\n\n    result: dict[str, Any] = {\n        \"market_breadth\": sanitize_cached_market_breadth(payload, cached_market_breadth),\n        \"index_ret_pct\": latest_runtime.get(\"index_ret_pct\", runtime_metrics.get(\"index_ret_pct\")),\n        \"strategy_max_dd_pct\": runtime_metrics.get(\"strategy_max_dd_pct\"),\n        \"strategy_sharpe\": runtime_metrics.get(\"strategy_sharpe\"),\n        \"benchmark_code\": snapshot_benchmark or expected_benchmark,\n        \"live_system_path\": str(live_system_path),\n        \"live_payload\": live_payload,\n        \"runtime_latest\": latest_runtime,\n        \"runtime_truth\": (latest_runtime.get(\"runtime_truth\") or {}),\n        \"source\": f\"runtime_risk_state_latest{('_' + profile_slug) if use_panel_level else ''}\",\n        \"profile_slug\": profile_slug,\n        \"panel_level_risk\": use_panel_level,\n    }\n\n    # Apply panel-level threshold override: replace the global strategy_max_dd_pct\n    # with the panel-specific risk-off threshold so that the halt gate is evaluated\n    # against this panel's tolerance instead of the shared global truth.\n    if use_panel_level:\n        panel_risk_cfg = profile_runtime_risk_config(profile_slug)\n        panel_dd_riskoff = panel_risk_cfg.get(\"strategy_max_drawdown_riskoff_pct\")\n        panel_dd_halt = panel_risk_cfg.get(\"strategy_max_drawdown_halt_pct\")\n        result[\"panel_strategy_max_dd_riskoff_pct\"] = panel_dd_riskoff\n        result[\"panel_strategy_max_dd_halt_pct\"] = panel_dd_halt\n        # Patch runtime_truth halt_new_buy logic: use panel threshold\n        # 进取方案核心：优先用纸盘自己的真实回撤，没有才降级用live_system数据\n        patched_truth = dict(result[\"runtime_truth\"])\n        global_dd = result[\"strategy_max_dd_pct\"]\n        paper_dd = _get_paper_real_drawdown(profile_slug)\n        if paper_dd is not None:\n            # 用纸盘真实回撤参与halt/riskoff评估，同时记录原始live_system值供审计\n            result[\"_paper_real_drawdown_pct\"] = paper_dd\n            current_dd = paper_dd\n        else:\n            current_dd = global_dd\n        if current_dd is not None and panel_dd_halt is not None:\n            if float(current_dd) >= float(panel_dd_halt):\n                patched_truth[\"halt_new_buy\"] = True\n                patched_truth[\"hard_stop\"] = True\n                patched_truth[\"risk_off\"] = True\n                patched_truth[\"halt_reason\"] = (\n                    f\"panel_halt:{profile_slug}_max_drawdown_pct({current_dd:.4f}) >= {panel_dd_halt}\"\n                    + (f\" (paper_real, live_sys={global_dd})\" if paper_dd is not None else \"\")\n                )\n                patched_truth[\"state_reason\"] = patched_truth[\"halt_reason\"]\n                patched_truth[\"trading_status\"] = \"BUY_HALT\"\n                patched_truth[\"trading_status_reason\"] = patched_truth[\"halt_reason\"]\n                patched_truth[\"trading_status_label_cn\"] = \"禁止买入\"\n                patched_truth[\"buy_authorized\"] = False\n                patched_truth[\"gate_reasons\"] = [\n                    f\"panel_halt:{profile_slug}_max_drawdown_pct({current_dd:.4f}) >= {panel_dd_halt}\"\n                    + (f\" (paper_real)\" if paper_dd is not None else \"\")\n                ]\n            elif float(current_dd) >= float(panel_dd_riskoff):\n                patched_truth[\"halt_new_buy\"] = False\n                patched_truth[\"hard_stop\"] = False\n                patched_truth[\"risk_off\"] = True\n                patched_truth[\"halt_reason\"] = (\n                    f\"panel_riskoff:{profile_slug}_max_drawdown_pct({current_dd:.4f}) >= {panel_dd_riskoff}\"\n                    + (f\" (paper_real, live_sys={global_dd})\" if paper_dd is not None else \"\")\n                )\n                patched_truth[\"state_reason\"] = patched_truth[\"halt_reason\"]\n                patched_truth[\"trading_status\"] = \"RISK_OFF\"\n                patched_truth[\"trading_status_reason\"] = patched_truth[\"halt_reason\"]\n                patched_truth[\"trading_status_label_cn\"] = \"降低风险\"\n                patched_truth[\"buy_authorized\"] = False\n                patched_truth[\"gate_reasons\"] = [\n                    f\"panel_riskoff:{profile_slug}_max_drawdown_pct({current_dd:.4f}) >= {panel_dd_riskoff}\"\n                    + (f\" (paper_real)\" if paper_dd is not None else \"\")\n                ]\n            else:\n                patched_truth[\"halt_new_buy\"] = False\n                patched_truth[\"hard_stop\"] = False\n                patched_truth[\"risk_off\"] = False\n                patched_truth[\"halt_reason\"] = \"\"\n                patched_truth[\"state_reason\"] = \"panel_normal\"\n                patched_truth[\"trading_status\"] = \"NORMAL\"\n                patched_truth[\"trading_status_reason\"] = \"panel_normal\"\n                patched_truth[\"trading_status_label_cn\"] = \"正常\"\n                patched_truth[\"buy_authorized\"] = True\n                patched_truth[\"gate_reasons\"] = []\n        result[\"runtime_truth\"] = patched_truth\n\n    return result\n\n\ndef _get_paper_real_drawdown(profile_slug: str) -> float | None:\n    \"\"\"Get paper account's real max_drawdown_pct from its latest trading metrics.\n    Returns None if no metrics file exists yet (legacy paper accounts).\n    进取方案核心：用纸盘自己的真实数据，而非live_system回测数据。\n    \"\"\"\n    files = sorted((REPORT_DIR).glob(f\"paper_{profile_slug}_trading_metrics_*.json\"))\n    if not files:\n        return None\n    try:\n        d = load_json(files[-1])\n        dd = d.get(\"metrics\", {}).get(\"max_drawdown_pct\")\n        if dd is not None:\n            return float(dd)\n    except Exception:\n        pass\n    return None\n\n\ndef resolve_runtime_metrics(date_tag: str, config: dict[str, Any], *, profile_slug: str = \"\") -> dict[str, Any]:\n    if resolve_dual_factor_profile(config) != \"off\":\n        return load_runtime_metrics_for_date(date_tag, config, report_dir=REPORT_DIR)\n    cached = load_cached_runtime_metrics(date_tag, config, profile_slug=profile_slug)\n    if cached is not None:\n        return cached\n    return load_runtime_metrics_for_date(date_tag, config, report_dir=REPORT_DIR)\n\n\ndef apply_cached_runtime_truth(runtime: Any, runtime_metrics: dict[str, Any], *, date_tag: str) -> Any:\n    if str(getattr(runtime, \"date_tag\", \"\") or \"\") != str(date_tag):\n        return runtime\n\n    runtime_truth = runtime_metrics.get(\"runtime_truth\") or {}\n    runtime_latest = runtime_metrics.get(\"runtime_latest\") or {}\n    source = runtime_metrics.get(\"source\", \"\")\n    # Accept both the global source and panel-level sources (runtime_risk_state_latest_aggressive, etc.)\n    is_cached = source == \"runtime_risk_state_latest\" or source.startswith(\"runtime_risk_state_latest_\")\n    if not is_cached:\n        return runtime\n\n    authoritative = runtime_truth if isinstance(runtime_truth, dict) and runtime_truth else runtime_latest\n    if not isinstance(authoritative, dict) or not authoritative:\n        return runtime\n\n    runtime.mode = str(authoritative.get(\"mode\") or getattr(runtime, \"mode\", \"\") or \"\")\n    runtime.risk_off = bool(authoritative.get(\"risk_off\", getattr(runtime, \"risk_off\", False)))\n    runtime.hard_stop = bool(authoritative.get(\"hard_stop\", getattr(runtime, \"hard_stop\", False)))\n    runtime.halt_new_buy = bool(authoritative.get(\"halt_new_buy\", getattr(runtime, \"halt_new_buy\", False)))\n    runtime.halt_reason = str(\n        authoritative.get(\"trading_status_reason\")\n        or authoritative.get(\"state_reason\")\n        or authoritative.get(\"halt_reason\")\n        or getattr(runtime, \"halt_reason\", \"\")\n        or \"\"\n    )\n    gate_reasons = authoritative.get(\"gate_reasons\")\n    if isinstance(gate_reasons, list):\n        runtime.gate_reasons = [str(item).strip() for item in gate_reasons if str(item).strip()]\n    market_breadth = authoritative.get(\"market_breadth\", runtime_metrics.get(\"market_breadth\"))\n    if market_breadth is not None:\n        try:\n            runtime.market_breadth = float(market_breadth)\n        except Exception:\n            pass\n    return runtime\n\n\ndef build_profile_artifact_paths(profile_slug: str, date_tag: str) -> dict[str, Path]:\n    prefix = f\"paper_{profile_slug}\" if profile_slug else \"paper\"\n    return {\n        \"holdings_input\": REPORT_DIR / f\"{prefix}_exit_holdings_{date_tag}.csv\",\n        \"trade_history\": REPORT_DIR / f\"{prefix}_trade_history_{date_tag}.csv\",\n        \"approved\": REPORT_DIR / f\"{prefix}_merged_approved_signals_{date_tag}.csv\",\n        \"candidate_orders\": REPORT_DIR / f\"{prefix}_merged_proposed_orders_{date_tag}.csv\",\n        \"tickets\": REPORT_DIR / f\"{prefix}_signal_tickets_{date_tag}.csv\",\n        \"candidate_main\": REPORT_DIR / f\"{prefix}_manual_smallcap_candidates_{date_tag}.csv\",\n        \"candidate_guard\": REPORT_DIR / f\"{prefix}_manual_smallcap_candidates_v4_2b_{date_tag}.csv\",\n        \"candidate_summary\": REPORT_DIR / f\"{prefix}_smallcap_candidate_generation_{date_tag}.json\",\n        \"signal_raw_main\": REPORT_DIR / f\"{prefix}_smallcap_signal_v4_2_{date_tag}.csv\",\n        \"signal_raw_guard\": REPORT_DIR / f\"{prefix}_smallcap_signal_v4_2b_{date_tag}.csv\",\n        \"merged_profile_buys\": REPORT_DIR / f\"{prefix}_merged_profile_buy_signals_{date_tag}.csv\",\n        \"merged_signals_profiled\": REPORT_DIR / f\"{prefix}_merged_signals_profiled_{date_tag}.csv\",\n    }\n\n\ndef csv_row_count(path_like: Any) -> int:\n    if not path_like:\n        return 0\n    path = Path(str(path_like))\n    if not path.exists():\n        return 0\n\n[1027 more lines in file. Use offset=430 to continue.]"}],"isError":false,"timestamp":1775173291446}}
