{"type":"message","id":"ec80569a","parentId":"116cf3db","timestamp":"2026-04-02T23:42:28.364Z","message":{"role":"toolResult","toolCallId":"call_S7Tw6LFbwVfAWO9yGtqx8ItE|fc_0593218ebc10f81b0169cefee324e08198ab9845b3921a62a6","toolName":"read","content":[{"type":"text","text":"        halt_reason=halt_reason,\n        gate_reasons=gate_reasons,\n        source=source,\n        precheck_passed=precheck_passed,\n        pipeline_ok=pipeline_ok,\n        force_state=force_state,\n        force_reason=force_reason,\n    )\n\n\ndef build_close_review_runtime_truth(\n    *,\n    tomorrow_mode: str,\n    risk_level: str,\n    journal_exists: bool,\n    journal_records: int,\n    orders_total: int,\n    execution_attempted_orders: int = 0,\n    source: str = \"run_close_review_v2\",\n) -> dict[str, Any]:\n    mode = str(tomorrow_mode or \"\").strip()\n    risk = str(risk_level or \"\").strip().upper()\n    attempted = int(execution_attempted_orders or 0)\n    if not journal_exists:\n        if orders_total > 0 and attempted <= 0:\n            return build_runtime_truth(\n                mode=\"review_required\",\n                risk_off=False,\n                hard_stop=False,\n                halt_new_buy=True,\n                source=source,\n                pipeline_ok=False,\n                force_state=\"blocked\",\n                force_reason=\"orders_pending_without_execution\",\n            )\n        return build_runtime_truth(\n            mode=\"review_required\",\n            risk_off=False,\n            hard_stop=False,\n            halt_new_buy=True,\n            source=source,\n            pipeline_ok=False,\n            force_state=\"blocked\",\n            force_reason=\"journal_missing\",\n        )\n    if attempted > 0 and journal_records <= 0:\n        return build_runtime_truth(\n            mode=\"review_required\",\n            risk_off=False,\n            hard_stop=False,\n            halt_new_buy=True,\n            source=source,\n            pipeline_ok=False,\n            force_state=\"blocked\",\n            force_reason=\"orders_without_journal_records\",\n        )\n    if mode == \"halt\" or risk == \"RED\":\n        return build_runtime_truth(\n            mode=\"halt\",\n            risk_off=True,\n            hard_stop=True,\n            halt_new_buy=True,\n            source=source,\n            force_state=\"risk_halt\",\n            force_reason=\"close_review_halt\",\n        )\n    if mode == \"cautious\" or risk == \"YELLOW\":\n        return build_runtime_truth(\n            mode=\"cautious\",\n            risk_off=True,\n            hard_stop=False,\n            halt_new_buy=True,\n            source=source,\n            force_state=\"risk_off\",\n            force_reason=\"close_review_cautious\",\n        )\n    if mode == \"review_required\" or risk == \"NO_DATA\":\n        return build_runtime_truth(\n            mode=\"review_required\",\n            risk_off=False,\n            hard_stop=False,\n            halt_new_buy=True,\n            source=source,\n            pipeline_ok=False,\n            force_state=\"blocked\",\n            force_reason=\"review_required\",\n        )\n    return build_runtime_truth(\n        mode=\"normal\",\n        risk_off=False,\n        hard_stop=False,\n        halt_new_buy=False,\n        source=source,\n        force_state=\"ok\",\n    )\n\n\ndef get_runtime_truth(payload: dict[str, Any] | None) -> dict[str, Any]:\n    if not isinstance(payload, dict):\n        return {}\n    truth = payload.get(\"runtime_truth\")\n    if isinstance(truth, dict) and truth.get(\"state\"):\n        return enrich_runtime_truth(truth)\n    latest_runtime = payload.get(\"latest_runtime\")\n    if isinstance(latest_runtime, dict):\n        nested = latest_runtime.get(\"runtime_truth\")\n        if isinstance(nested, dict) and nested.get(\"state\"):\n            return enrich_runtime_truth(nested)\n        return build_runtime_truth(\n            mode=str(latest_runtime.get(\"mode\") or \"\"),\n\n[9 more lines in file. Use offset=440 to continue.]"}],"isError":false,"timestamp":1775173348353}}
