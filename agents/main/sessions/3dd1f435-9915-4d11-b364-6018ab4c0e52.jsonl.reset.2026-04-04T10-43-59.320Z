{"type":"message","id":"2cbf42fc","parentId":"d471f462","timestamp":"2026-04-03T01:38:39.806Z","message":{"role":"toolResult","toolCallId":"call_hg5Vm77DjVnPfResLTtL7uo3|fc_00990316fdaeab850169cf1a1f46988198a28d409e94bb3b19","toolName":"exec","content":[{"type":"text","text":"\"registry_rows\": payload.get(\"registry_rows\") or [],\n        \"generated_at\": str(payload.get(\"generated_at\") or \"\"),\n    }\n\n\ndef incident_registry_state() -> dict[str, Any]:\n    path = REPORT_DIR / \"incident_registry_latest.json\"\n    weekly_path = REPORT_DIR / \"incident_weekly_review_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_incident_registry\",\n        }\n    payload = load_json(path)\n    mtime = datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\")\n    open_count = int(payload.get(\"open_incident_count_30d\") or 0)\n    if not weekly_path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": mtime,\n            \"reason\": \"missing_incident_weekly_review\",\n        }\n    status = \"GREEN\" if str(payload.get(\"overall_status\") or \"\").upper() == \"PASS\" and open_count == 0 else \"YELLOW\"\n    return {\n        \"status\": status,\n        \"path\": str(path),\n        \"mtime\": mtime,\n        \"reason\": \"ok\" if status == \"GREEN\" else f\"incident_open_count={open_count}\",\n    }\n\n\ndef event_watch_refresh_state(expected_date_tag: str) -> dict[str, Any]:\n    path = REPORT_DIR / \"runtime_risk_state_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_runtime_risk_state\",\n        }\n    payload = load_json(path)\n    report_date = str(payload.get(\"date_tag\") or \"\").strip()\n    event_watch = payload.get(\"event_watch_refresh\") or {}\n    if report_date and report_date != expected_date_tag:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": f\"stale_event_watch_state:{report_date}\",\n        }\n    if not isinstance(event_watch, dict) or not event_watch:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"missing_event_watch_refresh\",\n        }\n    if bool(event_watch.get(\"ok\")):\n        return {\n            \"status\": \"GREEN\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"ok\",\n        }\n    return {\n        \"status\": \"RED\",\n        \"path\": str(path),\n        \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"reason\": f\"event_watch_refresh_failed:returncode={event_watch.get('returncode')}\",\n    }\n\n\ndef live_chain_failure_state(expected_date_tag: str) -> dict[str, Any]:\n    path = REPORT_DIR / \"live_chain_failure_summary_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),"}],"details":{"status":"completed","exitCode":0,"durationMs":41,"aggregated":"\"registry_rows\": payload.get(\"registry_rows\") or [],\n        \"generated_at\": str(payload.get(\"generated_at\") or \"\"),\n    }\n\n\ndef incident_registry_state() -> dict[str, Any]:\n    path = REPORT_DIR / \"incident_registry_latest.json\"\n    weekly_path = REPORT_DIR / \"incident_weekly_review_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_incident_registry\",\n        }\n    payload = load_json(path)\n    mtime = datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\")\n    open_count = int(payload.get(\"open_incident_count_30d\") or 0)\n    if not weekly_path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": mtime,\n            \"reason\": \"missing_incident_weekly_review\",\n        }\n    status = \"GREEN\" if str(payload.get(\"overall_status\") or \"\").upper() == \"PASS\" and open_count == 0 else \"YELLOW\"\n    return {\n        \"status\": status,\n        \"path\": str(path),\n        \"mtime\": mtime,\n        \"reason\": \"ok\" if status == \"GREEN\" else f\"incident_open_count={open_count}\",\n    }\n\n\ndef event_watch_refresh_state(expected_date_tag: str) -> dict[str, Any]:\n    path = REPORT_DIR / \"runtime_risk_state_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_runtime_risk_state\",\n        }\n    payload = load_json(path)\n    report_date = str(payload.get(\"date_tag\") or \"\").strip()\n    event_watch = payload.get(\"event_watch_refresh\") or {}\n    if report_date and report_date != expected_date_tag:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": f\"stale_event_watch_state:{report_date}\",\n        }\n    if not isinstance(event_watch, dict) or not event_watch:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"missing_event_watch_refresh\",\n        }\n    if bool(event_watch.get(\"ok\")):\n        return {\n            \"status\": \"GREEN\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"ok\",\n        }\n    return {\n        \"status\": \"RED\",\n        \"path\": str(path),\n        \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"reason\": f\"event_watch_refresh_failed:returncode={event_watch.get('returncode')}\",\n    }\n\n\ndef live_chain_failure_state(expected_date_tag: str) -> dict[str, Any]:\n    path = REPORT_DIR / \"live_chain_failure_summary_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1775180319797}}
{"type":"message","id":"5348e20d","parentId":"2cbf42fc","timestamp":"2026-04-03T01:38:39.815Z","message":{"role":"toolResult","toolCallId":"call_OlArSQtQvQV1JP8MtIIJD5vR|fc_00990316fdaeab850169cf1a1f46a88198a2db3da121afe613","toolName":"exec","content":[{"type":"text","text":"\"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_live_chain_failure_summary\",\n        }\n    try:\n        payload = json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {\n            \"status\": \"RED\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"invalid_live_chain_failure_summary\",\n        }\n    summary_date = str(payload.get(\"date_tag\") or \"\")\n    if summary_date and summary_date != expected_date_tag:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": f\"stale_live_chain_failure_summary:{summary_date}\",\n        }\n    return {\n        \"status\": str(payload.get(\"overall_status\") or \"YELLOW\"),\n        \"path\": str(path),\n        \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"reason\": str(payload.get(\"reason\") or \"ok\"),\n    }\n\n\ndef manual_review_closure_alert_state(expected_date_tag: str) -> dict[str, Any]:\n    path = REPORT_DIR / \"manual_review_closure_alert_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_manual_review_closure_alert\",\n        }\n    payload = load_json(path)\n    report_date = str(payload.get(\"date_tag\") or \"\")\n    if report_date and report_date != expected_date_tag:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": f\"stale_manual_review_closure_alert:{report_date}\",\n        }\n    return {\n        \"status\": str(payload.get(\"overall_status\") or \"YELLOW\"),\n        \"path\": str(path),\n        \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),"}],"details":{"status":"completed","exitCode":0,"durationMs":50,"aggregated":"\"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_live_chain_failure_summary\",\n        }\n    try:\n        payload = json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {\n            \"status\": \"RED\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"invalid_live_chain_failure_summary\",\n        }\n    summary_date = str(payload.get(\"date_tag\") or \"\")\n    if summary_date and summary_date != expected_date_tag:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": f\"stale_live_chain_failure_summary:{summary_date}\",\n        }\n    return {\n        \"status\": str(payload.get(\"overall_status\") or \"YELLOW\"),\n        \"path\": str(path),\n        \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"reason\": str(payload.get(\"reason\") or \"ok\"),\n    }\n\n\ndef manual_review_closure_alert_state(expected_date_tag: str) -> dict[str, Any]:\n    path = REPORT_DIR / \"manual_review_closure_alert_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_manual_review_closure_alert\",\n        }\n    payload = load_json(path)\n    report_date = str(payload.get(\"date_tag\") or \"\")\n    if report_date and report_date != expected_date_tag:\n        return {\n            \"status\": \"YELLOW\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": f\"stale_manual_review_closure_alert:{report_date}\",\n        }\n    return {\n        \"status\": str(payload.get(\"overall_status\") or \"YELLOW\"),\n        \"path\": str(path),\n        \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1775180319806}}
