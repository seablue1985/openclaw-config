: 18.1,\n          \"total_return_pct\": 451.02\n        }\n      }\n    },\n    {\n      \"strategy_id\": \"rd_agent_top2_gray_v1\",\n      \"current_state\": \"candidate\",\n      \"current_role\": \"overlay enhancement / 灰度增强路径\",\n      \"suggested_action\": \"下线候选\",\n      \"review_conclusion\": \"retire_from_active_candidate_queue\",\n      \"owner_role\": \"research_owner\",\n      \"signoff_roles\": [\"research_owner\", \"risk_owner\"],\n      \"reason_summary\": [\n        \"属于增强层，不是基础主链\",\n        \"缺 paper signoff 与 incident 约束闭环\",\n        \"当前又连续 3/3 触发 drawdown review，不适合继续留在近期推进队列\"\n      ],\n      \"execution_actions\": [\n        \"暂停近期灰度推进\",\n        \"移出当前增强层优先候选队列\",\n        \"待补齐 paper signoff、incident 约束和新一轮 review 后再重新申请进入候选池\"\n      ],\n      \"evidence\": {\n        \"decision_record\": \"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/config/live_rd_agent_top2_gray_v1.json\",\n        \"robustness_report\": \"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports/rd_agent_top2_robustness_20260308.md\",\n        \"latest_experiment_id\": \"rd_agent_top2_gray_v1:robustness_review:20260308:44136fa355b3678a\",\n        \"robustness_metrics\": {\n          \"annual_return_pct\": 48.18,\n          \"sharpe\": 1.976,\n          \"max_drawdown_pct\": 19.46,\n          \"rolling_sharpe_win_rate\": 0.8,\n          \"rolling_annual_win_rate\": 0.8,\n          \"worst_sharpe_delta\": 0.285,\n          \"worst_annual_delta\": 5.71,\n          \"decision_label\": \"GO_LIVE_CANDIDATE\"\n        }\n      }\n    }\n  ],\n  \"signoff_template\": {\n    \"research_owner\": \"PENDING\",\n    \"risk_owner\": \"PENDING\",\n    \"decision_date\": \"PENDING\"\n  },\n  \"execution_gate\": {\n    \"keep_governance_block_before_signoff\": true,\n    \"allow_promotion_before_signoff\": false,\n    \"allow_gray_scale_before_signoff\": false\n  }\n}\n"},"partialJson":"{\"file\":\"/Users/lin