{"type":"message","id":"c236b59e","parentId":"8d5a591c","timestamp":"2026-03-20T02:04:02.244Z","message":{"role":"toolResult","toolCallId":"call_function_3bd5pspoytwh_1","toolName":"exec","content":[{"type":"text","text":"\"style_snapshot\": runtime.style_snapshot or {},\n    }\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"盘中风险复检\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--config\", default=str(LIVE_CONFIG_PATH), help=\"live trading config\")\n    args = parser.parse_args()\n\n    date_tag = parse_date_tag(args.date) if args.date else datetime.now().strftime(\"%Y%m%d\")\n    config_path = Path(args.config).expanduser().resolve()\n    config = load_json(config_path)\n\n    runtime_metrics = load_runtime_metrics_for_date(date_tag, config, report_dir=REPORT_DIR)\n    runtime = evaluate_runtime_state_for_date(\n        config=config,\n        live_payload=runtime_metrics[\"live_payload\"],\n        date_tag=date_tag,\n        index_ret_pct=float(runtime_metrics.get(\"index_ret_pct\", 0.0) or 0.0),\n        market_breadth=runtime_metrics.get(\"market_breadth\"),\n    )\n    base_runtime = runtime_to_dict(runtime)\n\n    intraday_gate = get_intraday_market_state(date_tag)\n    intraday_breadth = fetch_intraday_breadth() if intraday_gate.get(\"enabled\") else {\"available\": False, \"reason\": \"gate_disabled\"}\n    intraday_runtime = dict(base_runtime)\n    intraday_runtime[\"intraday_gate_applied\"] = False\n\n    risk_cfg = config.get(\"risk\") or {}\n    breadth_hard_stop = float(risk_cfg.get(\"market_breadth_hard_stop_threshold\", 0.25) or 0.25)\n    breadth_riskoff = float(risk_cfg.get(\"market_breadth_riskoff_threshold\", 0.35) or 0.35)\n    breadth_available = bool(intraday_breadth.get(\"available\"))\n    breadth_ratio = intraday_breadth.get(\"up_ratio\")\n\n    if intraday_gate.get(\"enabled\"):\n        gate_action = intraday_gate.get(\"gate_action\", \"none\")\n\n        if gate_action == \"halt\":\n            intraday_runtime.update(\n                {\n                    \"mode\": \"halt\",\n                    \"risk_off\": True,\n                    \"hard_stop\": True,\n                    \"halt_new_buy\": True,\n                    \"halt_reason\": f\"盘中门禁触发 halt: {intraday_gate.get('reason', '')}\",\n                    \"intraday_gate_applied\": True,\n                    \"market_breadth\": breadth_ratio if breadth_available else None,\n                }\n            )\n            intraday_runtime[\"gate_reasons\"] = list(dict.fromkeys((intraday_runtime.get(\"gate_reasons\") or []) + [\"intraday_market_halt\"]))\n        else:\n            # 非 halt 时，若盘中宽度不可用，则禁止自动恢复\n            if not breadth_available:\n                intraday_runtime.update(\n                    {\n                        \"mode\": \"halt\",\n                        \"risk_off\": True,\n                        \"hard_stop\": True,\n                        \"halt_new_buy\": True,\n                        \"halt_reason\": \"盘中宽度不可用，禁止自动恢复买入\","}],"details":{"status":"completed","exitCode":0,"durationMs":8,"aggregated":"\"style_snapshot\": runtime.style_snapshot or {},\n    }\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"盘中风险复检\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--config\", default=str(LIVE_CONFIG_PATH), help=\"live trading config\")\n    args = parser.parse_args()\n\n    date_tag = parse_date_tag(args.date) if args.date else datetime.now().strftime(\"%Y%m%d\")\n    config_path = Path(args.config).expanduser().resolve()\n    config = load_json(config_path)\n\n    runtime_metrics = load_runtime_metrics_for_date(date_tag, config, report_dir=REPORT_DIR)\n    runtime = evaluate_runtime_state_for_date(\n        config=config,\n        live_payload=runtime_metrics[\"live_payload\"],\n        date_tag=date_tag,\n        index_ret_pct=float(runtime_metrics