{"type":"message","id":"4279ddec","parentId":"fda46f2a","timestamp":"2026-03-20T03:44:35.814Z","message":{"role":"toolResult","toolCallId":"call_function_9wo2g8swrsg8_1","toolName":"exec","content":[{"type":"text","text":"\"cycle\": cycle,\n            \"generated_at\": payload.get(\"generated_at\"),\n            \"status\": payload.get(\"data_source_runtime\", {}).get(\"status\"),\n            \"md\": str(path.with_suffix('.md')),\n            \"json\": str(path),\n        })\n\n    health_scope, health_probe, health_path = latest_health_probe_for_date(REPORT_DIR, today_tag())\n    health_snapshot = build_health_snapshot(health_scope, health_probe, health_path)\n    morning_news, morning_news_path = morning_news_state()\n    morning_news_norm = normalize_morning_news_state(morning_news)\n    strategy_audit, strategy_audit_path = latest_strategy_audit()\n    auto_premarket_precheck, auto_premarket_precheck_path = latest_auto_premarket_precheck()\n    paper_execution = build_paper_execution_snapshot()\n    execution_status = {\n        \"path\": str((paper_execution.get(\"files\") or {}).get(\"summary_json\") or \"\"),\n        \"date\": paper_execution.get(\"date_tag\"),\n        \"time\": paper_execution.get(\"generated_at\"),\n        \"status\": \"paper_only\",\n        \"status_reason\": \"execution_status 已切换为三套模拟盘口径\",\n        \"strict_precheck_passed\": paper_execution.get(\"execution_status\", {}).get(\"allowed_to_open_new_positions\"),\n        \"strict_precheck\": \"paper_profiles_only\",\n        **(paper_execution.get(\"execution_status\") or {}),\n    }\n    backtest_queue, backtest_queue_path = snapshot_backtest_queue_status()\n    event_watch_path = REPORT_DIR / f\"investment_research_event_watch_{today_tag()}.json\"\n    event_watch = maybe_json(event_watch_path)\n    temp_meeting_path = REPORT_DIR / f\"investment_research_temporary_meeting_broadcast_{today_tag()}.json\"\n    temp_meeting = maybe_json(temp_meeting_path)\n\n    latest_dashboard = lat