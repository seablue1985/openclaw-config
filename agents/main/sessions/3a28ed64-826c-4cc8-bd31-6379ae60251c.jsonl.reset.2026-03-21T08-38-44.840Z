 else \\\"❌\\\"}')\nprint()\n\n# 3. index_ret_pct 修复验证\nprint('【3】runtime_risk_state index_ret_pct')\nrt = json.load(open('/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports/runtime_risk_state_latest.json'))\nret = rt.get('runtime_metrics', {}).get('index_ret_pct', 'N/A')\nprint(f'  index_ret_pct={ret}  {\\\"✅ 已修复（陈旧数据返回0）\\\" if abs(float(ret or 0)) < 0.01 else \\\"⚠️ 仍为昨日数据\\\"}')\nprint()\n\n# 4. 小红书登录\nprint('【4】小红书扫码登录')\nlogin_f = Path('/Users/ling/.openclaw/workspace/skills/xiaohongshu-skills/scripts/xhs/login.py')\ncli_f = Path('/Users/ling/.openclaw/workspace/skills/xiaohongshu-skills/scripts/cli.py')\nupdate_sh = Path('/Users/ling/.openclaw/workspace/scripts/update_xhs_web_session.sh')\nfor f, name in [(login_f, 'login.py'), (cli_f, 'cli.py'), (update_sh, 'update_xhs_web_session.sh')]:\n    content = f.read_text() if f.exists() else ''\n    ok = 'qr_refreshed' in content or 'new_qr_url' in content or '阻塞等待扫码' in content\n    print(f'  {name}: {\\\"✅ 已修复\\\" if ok else \\\"⚠️ 需检查\\\"}')\nprint()\n\n# 5. Tester 自检\nprint('【5】Tester 自检结果')\ntester = json.load(open('/Users/ling/.openclaw/workspace/research/reports/tester_scheduled_guard_latest.json'))\nprint(f'  status: {tester[\\\"status\\\"]}  ({\\\"✅\\\" if tester[\\\"status\\\"]==\\\"PASS\\\" else \\\"⚠️ 有问题\\\"})')\nprint(f'  issues: {tester[\\\"issue_count\\\"]}')\nprint()\n\nprint('=== 自检完成 ===')\n\" 2>&1","timeout":15}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":89229,"output":985,"cacheRead":24877,"cacheWrite":0,"totalTokens":115091,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773981460292}}
