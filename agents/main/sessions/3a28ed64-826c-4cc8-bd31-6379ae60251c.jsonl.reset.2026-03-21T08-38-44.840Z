# 数据陈旧：昨日收盘数据在今早被误用。\n+162         # 盘前（09:25 前）应返回 0.0；盘中若有实时数据源应优先使用。\n+163         logging.warning(\n+164             f\"[load_index_return_pct_for_date] {normalized_code} 数据陈旧（最后日期={latest_date_key}，\"\n+165             f\"今日={today_key}），返回 0.0 而非昨日涨跌。\"\n+166             f\"如需盘中实时涨跌，需在 morning_scan 中更新实时指数数据。\"\n+167         )\n+168         return 0.0\n+169 \n+170     # latest_date_key == today_key：正常，当日日线已就绪\n 137     latest_close = parse_float(frame.iloc[-1][\"close\"], 0.0)\n 138     prev_close = parse_float(frame.iloc[-2][\"close\"], 0.0)\n 139     if latest_close <= 0 or prev_close <= 0:\n 140         return 0.0\n     ...","firstChangedLine":124},"isError":false,"timestamp":1773972314294}}
