{"type":"message","id":"558010d0","parentId":"a1971beb","timestamp":"2026-03-20T03:44:46.086Z","message":{"role":"toolResult","toolCallId":"call_function_dw3lv3voqyio_1","toolName":"exec","content":[{"type":"text","text":"def build_paper_execution_snapshot() -> dict[str, Any]:\n    date_tag = latest_paper_date_tag()\n    freshness = build_execution_freshness(date_tag)\n    profiles = [_profile_snapshot(slot_label, profile_slug, date_tag) for slot_label, profile_slug in PAPER_PROFILES]\n\n    holdings_rows = [row for profile in profiles for row in profile.get(\"positions_rows\", [])]\n    trades_rows = [row for profile in profiles for row in profile.get(\"trades_rows\", [])]\n    orders_rows = [row for profile in profiles for row in profile.get(\"orders_rows\", [])]\n    tickets_rows = [row for profile in profiles for row in profile.get(\"tickets_rows\", [])]\n\n    holdings_csv = WORKSPACE_REPORT_DIR / f\"investment_research_paper_holdings_{date_tag}.csv\"\n    trades_csv = WORKSPACE_REPORT_DIR / f\"investment_research_paper_trades_{date_tag}.csv\"\n    orders_csv = WORKSPACE_REPORT_DIR / f\"investment_research_paper_orders_{date_tag}.csv\"\n    tickets_csv = WORKSPACE_REPORT_DIR / f\"investment_research_paper_tickets_{date_tag}.csv\"\n    summary_json = WORKSPACE_REPORT_DIR / f\"investment_research_paper_execution_summary_{date_tag}.json\"\n    summary_md = WORKSPACE_REPORT_DIR / f\"investment_research_paper_execution_summary_{date_tag}.md\"\n\n    _write_csv(\n        holdings_csv,\n        holdings_rows,\n        [\"slot_label\", \"profile_slug\", \"profile_name\", \"symbol\", \"ts_code\", \"name\", \"display\", \"quantity\", \"cost_price\", \"market_value\", \"weight_pct\"],\n    )\n    _write_csv(\n        trades_csv,\n        trades_rows,\n        [\"slot_label\", \"profile_slug\", \"profile_name\", \"date\", \"action\", \"ts_code\", \"symbol_name\", \"shares\", \"price\", \"amount\", \"signal_reason\", \"notes\"],\n    )\n    _write_csv(\n        orders_csv,\n        orders_rows,\n        [\"slot_label\", \"profile_slug\", \"profile_name\", \"ts_code\", \"side\", \"suggest_qty\", \"risk_gate\", \"gate_reason\", \"source_reason\", \"notes\"],\n    )\n    _write_csv(\n        tickets_csv,\n        tickets_rows,\n        [\"slot_label\", \"profile_slug\", \"profile_name\", \"ts_code\", \"side\", \"source_qty\", \"confirm_status\", \"execute_status\", \"notes\"],\n    )\n\n    unique_halt_reasons = [\n        reason\n        for reason in dict.fromkeys(\n            str((profile.get(\"stats\") or {}).get(\"halt_reason\") or \"\").strip()\n            for profile in profiles\n        )\n        if reason\n    ]\n    unique_gate_reasons = [\n        reason\n        for reason in dict.fromkeys(\n            reason\n            for profile in profiles\n            for reason in _split_gate_reasons((profile.get(\"stats\") or {}).get(\"gate_reasons\"))\n        )\n        if reason\n    ]\n\n    allowed_to_open_new_positions = any(\n        (_coerce_int((profile.get(\"stats\") or {}).get(\"buy_budget_slots\")) > 0)\n        and (not bool((profile.get(\"stats\") or {}).get(\"halt_new_buy\")))\n        for profile in profiles\n    )\n    status_mode = \"halt\" if profiles and all(str((profile.get(\"stats\") or {}).get(\"mode\") or \"\") == \"halt\" for profile in profiles) else \"mixed\"\n\n    payload = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"date_tag\": date_tag,\n        \"freshness\": freshness,\n        \"profiles\": [\n            {\n                \"slot_label\": profile.get(\"slot_label\"),\n                \"profile_slug\": profile.get(\"profile_slug\"),\n                \"profile_name\": profile.get(\"profile_name\"),\n                \"account\": {\n                    \"nav\": _coerce_float((profile.get(\"account\") or {}).get(\"nav\")),\n                    \"cash\": _coerce_float((profile.get(\"account\") or {}).get(\"cash\")),\n                    \"position_count\": _coerce_int((profile.get(\"account\") or {}).get(\"position_count\")),\n                    \"today_trade_count\": _coerce_int((profile.get(\"account\") or {}).get(\"today_trade_count\")),\n                },\n                \"stats\": profile.get(\"stats\", {}),\n                \"files\": profile.get(\"files\", {}),\n            }\n            for profile in profiles\n        ],\n        \"totals\": {\n            \"nav\": round(sum(_coerce_float((profile.get(\"account\") or {}).get(\"nav\")) for profile in profiles), 2),\n            \"cash\": round(sum(_coerce_float((profile.get(\"account\") or {}).get(\"cash\")) for profile in profiles), 2),\n            \"position_count\": sum(_coerce_int((profile.get(\"account\") or {}).get(\"position_count\")) for profile in profiles),\n            \"trade_count\": sum(_coerce_int((profile.get(\"account\") or {}).get(\"today_trade_count\")) for profile in profiles),\n            \"pass_buy_count\": sum(\n                sum(1 for row in profile.get(\"orders_rows\", []) if str(row.get(\"side\") or row.get(\"action\") or \"\").upper() == \"BUY\" and str(row.get(\"risk_gate\") or \"\").lower() == \"pass\")\n                for profile in profiles\n            ),\n            \"blocked_buy_count\": sum(\n                sum(1 for row in profile.get(\"orders_rows\", []) if str(row.get(\"side\") or row.get(\"action\") or \"\").upper() == \"BUY\" and str(row.get(\"risk_gate\") or \"\").lower() != \"pass\")\n                for profile in profiles\n            ),\n        },\n        \"execution_status\": {\n            \"source\": \"paper_profiles\",\n            \"source_date_tag\": date_tag,\n            \"freshness_status\": freshness.get(\"status\"),\n            \"freshness_summary\": freshness.get(\"summary\"),\n            \"mode\": status_mode,\n            \"risk_off\": all(bool((profile.get(\"stats\") or {}).get(\"risk_off\")) for profile in profiles) if profiles else False,\n            \"hard_stop\": all(bool((profile.get(\"stats\") or {}).get(\"hard_stop\")) for profile in profiles) if profiles else False,\n            \"halt_new_buy\": all(bool((profile.get(\"stats\") or {}).get(\"halt_new_buy\")) for profile in profiles) if profiles else False,\n            \"halt_reason\": \"；\".join(unique_halt_reasons),\n            \"market_breadth\": next((_coerce_float((profile.get(\"stats\") or {}).get(\"market_breadth\")) for profile in profiles if (profile.get(\"stats\") or {}).get(\"market_breadth\") is not None), 0.0),\n            \"gate_reasons\": unique_gate_reasons,\n            \"buy_count\": sum(_coerce_int((profile.get(\"stats\") or {}).get(\"buy_count\")) for profile in profiles),\n            \"sell_count\": sum(_coerce_int((profile.get(\"stats\") or {}).get(\"sell_count\")) for profile in profiles),\n            \"blocked_buy_halt\": sum(_coerce_int((profile.get(\"stats\") or {}).get(\"blocked_buy_halt\")) for profile in profiles),\n            \"blocked_sell_no_holding\": sum(_coerce_int((profile.get(\"stats\") or {}).get(\"blocked_sell_no_holding\")) for profile in profiles),\n            \"decision_eligible_buy_count\": sum(_coerce_int((profile.get(\"stats\") or {}).get(\"decision_eligible_buy_count\")) for profile in profiles),\n            \"buy_budget_slots\": sum(_coerce_int((profile.get(\"stats\") or {}).get(\"buy_budget_slots\")) for profile in profiles),\n            \"daily_add_budget\": round(sum(_coerce_float((profile.get(\"stats\") or {}).get(\"daily_add_budget\")) for profile in profiles), 2),\n            \"per_buy_budget\": _format_profile_budget(profiles, \"per_buy_budget\"),\n            \"configured_single_ticket_budget\": _format_profile_budget(profiles, \"configured_single_ticket_budget\"),\n            \"max_single_amount\": _format_profile_budget(profiles, \"max_single_amount\"),\n            \"buy_window\": \"-\",\n            \"risk_only_after\": \"-\",\n            \"precheck_path\": str(summary_md),\n            \"orders_path\": str(orders_csv),\n            \"brief_path\": str(summary_md),\n            \"journal_path\": str(trades_csv),\n            \"ticket_path\": str(tickets_csv),\n            \"holdings_path\": str(holdings_csv),\n            \"allowed_to_open_new_positions\": allowed_to_open_new_positions,\n        },\n        \"files\": {\n            \"holdings_csv\": str(holdings_csv),\n            \"trades_csv\": str(trades_csv),"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"def build_paper_execution_snapshot() -> dict[str, Any]:\n    date_tag = latest_paper_date_tag()\n    freshness = build_execution_freshness(date_tag)\n    profiles = [_profile_snapshot(slot_label, profile_slug, date_tag) for slot_label, profile_slug in PAPER_PROFILES]\n\n    holdings_rows = [row for profile in profiles for row in profile.get(\"positions_rows\", [])]\n    trades_rows = [row for profile in profiles for row in profile.get(\"trades_rows\", [])]\n    orders_rows = [row for profile in profiles for row in profile.get(\"orders_rows\", [])]\n    tickets_rows = [row for profile in profiles for row in profile.get(\"tickets_rows\", [])]\n\n    holdings_csv = WORKSPACE_REPORT_DIR / f\"investment_research_paper_holdings_{date_tag}.csv\"\n    trades_csv = WORKSPACE_REPORT_DIR / f\"investment_research_paper_trades_{date_tag}.csv\"\n    orders_csv = WORKSPACE_REPORT_DIR / f\"investment_research_paper_orders_{date_tag}.csv\"\n    tickets_csv = WORKSPACE_REPORT_DIR / f\"investment_research_paper_tickets_{date_tag}.csv\"\n    summary_json = WORKSPACE_REPORT_DIR / f\"investment_research_paper_execution_summary_{date_tag}.json\"\n    summary_md = WORKSPACE_REPORT_DIR / f\"investment_research_paper_execution_summary_{date_tag}.md\"\n\n    _write_csv(\n        holdings_csv,\n        holdings_rows,\n        [\"slot_label\", \"profile_slug\", \"profile_name\", \"symbol\", \"ts_code\", \"name\", \"display\", \"quantity\", \"cost_price\", \"market_value\", \"weight_pct\"],\n    )\n    _write_csv(\n        trades_csv,\n        trades_rows,\n        [\"slot_label\", \"profile_slug\", \"profile_name\", \"date\", \"action\", \"ts_code\", \"symbol_name\", \"shares\", \"price\", \"amount\", \"signal_reason\", \"notes\"],\n    )\n    _write_csv(\n        orders_csv,\n        orders_rows,\n        [\"slot_label\", \"profile_slug\", \"profile_name\", \"ts_code\", \"side\", \"suggest_qty\", \"risk_gate\", \"gate_reason\", \"source_reason\", \"notes\"],\n    )\n    _write_csv(\n        tickets_csv,\n        tickets_rows,\n        [\"slot_label\", \"profile_slug\", \"profile_name\", \"ts_code\", \"side\", \"source_qty\", \"confirm_status\", \"execute_status\", \"notes\"],\n    )\n\n    unique_halt_reasons = [\n        reason\n        for reason in dict.fromkeys(\n            str((profile.get(\"stats\") or {}).get(\"halt_reason\") or \"\").strip()\n            for profile in profiles\n        )\n        if reason\n    ]\n    unique_gate_reasons = [\n        reason\n        for reason in dict.fromkeys(\n            reason\n            for profile in profiles\n            for reason in _split_gate_reasons((profile.get(\"stats\") or {}).get(\"gate_reasons\"))\n        )\n        if reason\n    ]\n\n    allowed_to_open_new_positions = any(\n        (_coerce_int((profile.get(\"stats\") or {}).get(\"buy_budget_slots\")) > 0)\n        and (not bool((profile.get(\"stats\") or {}).get(\"halt_new_buy\")))\n        for profile in profiles\n    )\n    status_mode = \"halt\" if profiles and all(str((profile.get(\"stats\") or {}).get(\"mode\") or \"\") == \"halt\" for profile in profiles) else \"mixed\"\n\n    payload = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"date_tag\": date_tag,\n        \"freshness\": freshness,\n        \"profiles\": [\n            {\n                \"slot_label\": profile.get(\"slot_label\"),\n                \"profile_slug\": profile.get(\"profile_slug\"),\n                \"profile_name\": profile.get(\"profile_name\"),\n  