{"type":"message","id":"8bc25375","parentId":"97673ef6","timestamp":"2026-03-20T02:06:39.904Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to add a function to `morning_scan.py` that:\n1. Fetches today's real-time index data (current price)\n2. Compares with yesterday's close to compute today's intraday return\n3. Writes this to a JSON file that can be read by the gate check functions\n\nLet me add this function before `main()` and call it from main. I'll add it as step 2b (after get_market_index):","thinkingSignature":"857358eb3ee69ae85ae6dae8aca0fc5438becb97131e30659ffb312caddcac02"},{"type":"toolCall","id":"call_function_3l22zocbdhxp_1","name":"edit","arguments":{"path":"/Users/ling/.openclaw/workspace/scripts/morning_scan.py","oldText":"    log(\"📄 日报已保存\")\n\ndef main():\n    print(\"=\"*50)\n    print(\"🚀 早盘准备脚本启动\")\n    print(\"=\"*50)\n    \n    log(\"=\"*50)\n    log(\"开始早盘准备\")\n    \n    # 1. 获取实时数据\n    df = get_realtime_data()\n    \n    # 2. 获取指数\n    index_data = get_market_index()","newText":"    log(\"📄 日报已保存\")\n\n\ndef update_realtime_index_returns():\n    \"\"\"获取今日实时指数涨跌，写入 JSON 供盘前门控使用。\n\n    使用 akshare stock_zh_index_spot_em（实时快照）获取当前指数价格，\n    与昨日收盘价对比计算今日收益率。\n    结果写入 ~/.qlib_data/cn_data/realtime_index_returns.json，\n    由 runtime_date_utils.load_index_return_pct_for_date 的盘中 fallback 读取。\n    \"\"\"\n    log(\"📊 更新实时指数收益率...\")\n\n    # 指数代码映射（通达信格式: sh000852）\n    REALTIME_INDEX_MAP = {\n        \"ZZ2000\": \"sh000852\",   # 中证2000\n        \"HS300\":  \"sh000300\",   # 沪深300\n        \"ZZ500\":  \"sh000905\",   # 中证500\n        \"SH0001\": \"sh000001\",   # 上证指数\n        \"SZ3991\": \"sz399001\",   # 深证成指\n        \"CYBZ\":   \"sz399006\",   # 创业板指\n    }\n\n    import json\n    from datetime import date\n\n    output_path = os.path.join(DATA_DIR, \"realtime_index_returns.json\")\n    today_str = date.today().strftime(\"%Y%m%d\")\n\n    # 读取昨日收盘价（从已有 CSV）\n    import pandas as pd\n    prev_closes = {}\n    for code_key, ts_code in REALTIME_INDEX_MAP.items():\n        csv_path = os.path.join(DATA_DIR, f\"index_{ts_code.replace('sh','000').replace('sz','399')}_SH.csv\")\n        # 尝试找到对应的 CSV\n        csv_pattern = ts_code.replace(\"sh\", \"000\").replace(\"sz\", \"399\") + \"_SH.csv\"\n        csv_path2 = os.path.join(DATA_DIR, csv_pattern)\n        for p in [csv_path, csv_path2]:\n            if os.path.exists(p):\n                try:\n                    df_idx = pd.read_csv(p)\n                    if not df_idx.empty and \"close\" in df_idx.columns:\n                        prev_closes[code_key] = float(df_idx.iloc[-1][\"close\"])\n                        break\n                except Exception:\n                    pass\n\n    result = {\n        \"date\": today_str,\n        \"updated_at\": datetime.now().isoformat(),\n        \"returns\": {},\n        \"note\": \"实时涨跌（当前价 vs 昨日收盘），盘中有效；盘前（09:25 前）全为 None\",\n    }\n\n    # 尝试获取实时价格\n    try:\n        spot_df = ak.stock_zh_index_spot_em()\n        for code_key, name in [\n            (\"ZZ2000\", \"中证2000\"),\n            (\"HS300\",  \"沪深300\"),\n            (\"ZZ500\",  \"中证500\"),\n        ]:\n            row = spot_df[spot_df[\"代码\"] == REALTIME_INDEX_MAP[code_key].replace(\"sh\", \"\").replace(\"sz\", \"\")]\n            if not row.empty:\n                current = float(row.iloc[0][\"最新价\"])\n                prev = prev_closes.get(code_key)\n                ret = (current / prev - 1) * 100 if prev and prev > 0 else None\n                result[\"returns\"][code_key] = ret\n                log(f\"   {name}: {current:.2f} ({ret:.2f}%)\" if ret is not None else f\"   {name}: {current:.2f} (无昨日收盘)\")\n            else:\n                result[\"returns\"][code_key] = None\n                log(f\"   {name}: 未找到实时数据\")\n    except Exception as e:\n        log(f\"   实时指数获取失败: {e}\")\n        # 网络异常时，写入空结果（避免错误数据被门控使用）\n        result[\"error\"] = str(e)\n\n    with open(output_path, \"w\") as f:\n        json.dump(result, f, ensure_ascii=False, indent=2)\n    log(f\"   实时指数收益已写入: {output_path}\")\n\n\ndef main():\n    print(\"=\"*50)\n    print(\"🚀 早盘准备脚本启动\")\n    print(\"=\"*50)\n\n    log(\"=\"*50)\n    log(\"开始早盘准备\")\n\n    # 1. 获取实时数据\n    df = get_realtime_data()\n\n    # 2. 获取指数（日线历史，用于历史参考）\n    index_data = get_market_index()\n\n    # 2b. 更新实时指数涨跌（供盘前门控使用）\n    update_realtime_index_returns()"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":74064,"output":1214,"cacheRead":24877,"cacheWrite":0,"totalTokens":100155,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773972366178}}
