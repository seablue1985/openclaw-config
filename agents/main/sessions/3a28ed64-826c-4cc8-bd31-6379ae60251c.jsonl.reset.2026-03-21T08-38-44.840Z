f reason == \"manual_risk_off\":\n        return \"人工风险收缩触发\"\n\n    return reason\n\n\ndef evaluate_risk(\n    config: dict[str, Any],\n    live_payload: dict[str, Any],\n    index_ret: dict[str, float],\n    market_breadth: float | None,\n) -> dict[str, Any]:\n    combo = live_payload.get(\"combo_v1\", {})\n    target_cfg = config.get(\"targets\", {})\n    constraints_cfg = config.get(\"constraints\", {})\n\n    combo_dd = parse_float(combo.get(\"max_drawdown_pct\"), 0.0)\n    combo_sharpe = parse_float(combo.get(\"sharpe\"), 0.0)\n    dd_target = parse_float(target_cfg.get(\"max_drawdown_max_pct\"), 25.0)"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"if breadth_riskoff_threshold is not None and market_breadth is not None:\n            return f\"市场宽度{market_breadth:.3f} <= {breadth_riskoff_threshold:.3f}（风险收缩）\"\n        return \"市场宽度触发风险门控\"\n\n    if reason.startswith(\"strategy_max_drawdown_pct\"):\n        if max_dd_threshold is not None:\n            return f\"组合历史回撤{combo_dd:.2f}% >= {max_dd_threshold:.2f}%（风险收缩）\"\n        return f\"组合历史回撤{combo_dd:.2f}%触发风险收缩\"\n\n    if reason.startswith(\"strategy_sharpe\"):\n        if sharpe_threshold is not None:\n            return f\"组合Sharpe {combo_sharpe:.3f} < {sharpe_threshold:.3f}（谨慎模式）\"\n        return f\"组合Sharpe {combo_sharpe:.3f}偏低（谨慎模式）\"\n\n    if reason == \"style_rotation_hard_stop\":\n        return (\n            f\"风格切换硬停：{style_snapshot.get('smallcap_index', 'ZZ2000')}相对\"\n            f\"{style_snapshot.get('broad_index', 'HS300')}\"\n            f\"{int(style_snapshot.get('short_window', 5))}日超额=\"\n            f\"{parse_float(style_snapshot.get('short_excess_pct'), 0.0):.2f}% / \"\n            f\"{int(style_snapshot.get('medium_window', 20))}日超额=\"\n            f\"{parse_float(style_snapshot.get('medium_excess_pct'), 0.0):.2f}%\"\n        )\n\n    if reason == \"style_rotation_riskoff\":\n        return (\n            f\"风格切换收缩：{style_snapshot.get('smallcap_index',