 \n+400         # 每 10 秒检查一次 QR 是否已刷新（小红书 QR 约 60 秒过期，\n+401         # 用 10 秒间隔在过期前有充足缓冲，且不会过度查询 DOM）\n+402         if last_qr_url is not None and int(time.monotonic() * 10) % 10 == 0:\n+403             current_qr = get_current_qr_data_url()\n+404             if current_qr and current_qr != last_qr_url:\n+405                 logger.info(\"检测到 QR 码已刷新，需要用户重新扫码\")\n+406                 return False, current_qr\n+407 \n 376         time.sleep(0.3)\n-377     return False\n+409 \n+410     # 超时：最后一次检查 QR 是否刷新了\n+411     if last_qr_url is not None:\n+412         final_qr = get_current_qr_data_url()\n+413         if final_qr and final_qr != last_qr_url:\n+414             return False, final_qr\n+415 \n+416     return False, None","firstChangedLine":361},"isError":false,"timestamp":1773971519991}}
{"type":"message","id":"f213b9ca","parentId":"685faea4","timestamp":"2026-03-20T01:52:17.980Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me update `cmd_wait_login` in `cli.py` to handle the new return type and surface QR refresh notifications to the user.","thinkingSignature":"99ea8d8b9b0a1a1b0cf13fd3650cc883cf18b95265866a3b27806640981b6f4b"},{"type":"text","text":"现在修改 `cli.py` 的 `cmd_wait_login`，让它能输出 QR 刷新提示：\n"},{"type":"toolCall","id":"call_function_z54f76wtpuaf_1","name":"edit","arguments":{"path":"/Users/ling/.openclaw/workspace/skills/xiaohongshu-skills/scripts/cli.py","oldText":"def cmd_wait_login(args: argparse.Namespace) -> None:\n    \"\"\"等待扫码登录完成（配合 get-qrcode 使用）。\n\n    连接已有 Chrome tab，内部轮询直到登录成功或超时，替代 Skill 层的多次 check-login 轮询。\n    \"\"\"\n    from xhs.login import wait_for_login\n\n    browser, page = _connect_saved_tab(args)\n    try:\n        success = wait_for_login(page, timeout=args.timeout)\n        if success:\n            _clear_login_tab(args.port)\n            _update_account_nickname(args, page)\n        _output(\n            {\n                \"logged_in\": success,\n                \"message\": \"登录成功\" if success else \"等待超时，请重新运行 get-qrcode 获取新二维码\",\n            },\n            exit_code=0 if success else 2,\n        )\n    finally:\n        browser.close()","newText":"def cmd_wait_login(args: argparse.Namespace) -> None:\n    \"\"\"等待扫码登录完成（配合 get-qrcode 使用）。\n\n    连接已有 Chrome tab，内部轮询直到登录成功或超时，替代 Skill 层的多次 check-login 轮询。\n    检测 QR 刷新并实时通知用户。\n    \"\"\"\n    from xhs.login import fetch_qrcode, make_qrcode_url, wait_for_login\n\n    browser, page = _connect_saved_tab(args)\n    try:\n        # 获取进入等待时的初始 QR，用于检测刷新\n        initial_qr = None\n        try:\n            png_bytes, _, _ = fetch_qrcode(page)\n            if png_bytes:\n                from xhs.login import save_qrcode_to_file\n                save_qrcode_to_file(png_bytes)\n                initial_qr, _ = make_qrcode_url(png_bytes)\n        except Exception:\n            pass  # 非 QR 页面（如已登录）不影响主流程\n\n        success, new_qr_url = wait_for_login(\n            page,\n            timeout=args.timeout,\n            initial_qr_data_url=initial_qr,\n        )\n\n        if success:\n            _clear_login_tab(args.port)\n            _update_account_nickname(args, page)\n            _output(\n                {\"logged_in\": True, \"message\": \"登录成功\"},\n                exit_code=0,\n            )\n        elif new_qr_url:\n            # QR 刷新了，通知用户并告知如何刷新\n            _output(\n                {\n                    \"logged_in\": False,\n                    \"qr_refreshed\": True,\n                    \"qrcode_image_url\": new_qr_url,\n                    \"message\": (\n                        \"二维码已过期并刷新，请重新扫码。\"\n                        \"新二维码已更新，请刷新页面或重新运行 get-qrcode 获取。\"\n                    ),\n                },\n                exit_code=2,\n            )\n        else:\n            _output(\n                {\n                    \"logged_in\": False,\n                    \"message\": \"等待超时，请重新运行 get-qrcode 获取新二维码\",\n                },\n                exit_code=2,\n            )\n    finally:\n        browser.close()"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":45475,"output":718,"cacheRead":24877,"cacheWrite":0,"totalTokens":71070,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773971520001}}
