{"type":"message","id":"0522557a","parentId":"fbd8fc86","timestamp":"2026-03-20T02:03:33.428Z","message":{"role":"toolResult","toolCallId":"call_function_11kbxpv8rhfq_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\nCONFIG_PATH = WORKSPACE / \"config\" / \"investment_research_event_triggers_v1.json\"\nINPUTS_CONFIG = WORKSPACE / \"config\" / \"investment_research_org_inputs_v1.json\"\nDATA_SOURCE_POLICY = WORKSPACE / \"config\" / \"investment_research_data_source_policy_v1.json\"\nSCRIPTS_DIR = WORKSPACE / \"scripts\"\nQUANT_REPORT_DIR = WORKSPACE / \"quant_projects\" / \"personal-a-share-research-system\" / \"research\" / \"reports\"\nRUNTIME_STATE_LATEST = QUANT_REPORT_DIR / \"runtime_risk_state_latest.json\"\n\nsys.path.insert(0, str(SCRIPTS_DIR))\nimport run_investment_research_org_orchestrator as org  # noqa: E402\nfrom investment_research_data_source_runtime import build_runtime_status, load_policy  # noqa: E402\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef write_json(path: Path, payload: dict[str, Any]) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef compare_lists(a: list[str], b: list[str]) -> bool:\n    return a != b\n\n\ndef parse_dt(value: Any) -> datetime:\n    text = str(value or \"\").strip()\n    if not text:\n        return datetime.min\n    for fmt in (\"%Y-%m-%d %H:%M:%S\", \"%Y-%m-%dT%H:%M:%S.%f\", \"%Y-%m-%dT%H:%M:%S\"):\n        try:\n            return datetime.strptime(text, fmt)\n        except ValueError:\n            continue\n    return datetime.min\n\n\ndef load_runtime_overlay(date_tag: str) -> tuple[dict[str, Any], dict[str, Any]]:\n    runtime_obj: dict[str, Any] = {}\n    report_obj: dict[str, Any] = {}\n    if RUNTIME_STATE_LATEST.exists():\n        try:\n            runtime_obj = load_json(RUNTIME_STATE_LATEST)\n        except Exception:\n            runtime_obj = {}\n    report_path = QUANT_REPORT_DIR / f\"today_stock_strategy_report_{date_tag}.json\"\n    if not report_path.exists():\n        report_path = QUANT_REPORT_DIR / \"today_stock_strategy_report_latest.json\"\n    if report_path.exists():\n        try:\n            report_obj = load_json(report_path)\n        except Exception:\n            report_obj = {}\n    return runtime_obj, report_obj\n\n\ndef apply_runtime_overlay(summary: dict[str, Any]) -> dict[str, Any]:\n    date_tag = str(summary.get(\"strategy_report_date_tag\") or summary.get(\"paper_date_tag\") or datetime.now().strftime(\"%Y%m%d\"))\n    runtime_obj, report_obj = load_runtime_overlay(date_tag)\n    latest_runtime = runtime_obj.get(\"latest_runtime\") or {}\n\n    if str(runtime_obj.get(\"date_tag\") or \"\") == date_tag and latest_runtime:\n        summary[\"risk_off\"] = bool(latest_runtime.get(\"risk_off\"))\n        pe = dict(summary.get(\"paper_execution_status\") or {})\n        pe.update(\n            {\n                \"source\": \"runtime_risk_state_latest\",\n                \"mode\": latest_runtime.get(\"mode\"),"}],"details":{"status":"completed","exitCode":0,"durationMs":3,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\nCONFIG_PATH = WORKSPACE / \"config\" / \"investment_research_event_triggers_v1.json\"\nINPUTS_CONFIG = WORKSPACE / \"config\" / \"investment_research_org_inputs_v1.json\"\nDATA_SOURCE_POLICY = WORKSPACE / \"config\" / \"investment_research_data_source_policy_v1.json\"\nSCRIPTS_DIR = WORKSPACE / \"scripts\"\nQUANT_REPORT_DIR = WORKSPACE / \"quant_projects\" / \"personal-a-share-research-system\" / \"research\" / \"reports\"\nRUNTIME_STATE_LATEST = QUANT_REPORT_DIR / \"runtime_risk_state_latest.json\"\n\nsys.path.insert(0, str(SCRIPTS_DIR))\nimport run_investment_research_org_orchestrator as org  # noqa: E402\nfrom investment_research_data_source_runtime import build_runtime_status, load_policy  # noqa: E402\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef write_json(path: Path, payload: dict[str, Any]) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef compare_lists(a: list[str], b: list[str]) -> bool:\n    return a != b\n\n\ndef parse_dt(value: Any) -> datetime:\n    text = str(value or \"\").strip()\n    if not text:\n        return datetime.min\n    for fmt in (\"%Y-%m-%d %H:%M:%S\", \"%Y-%m-%dT%H:%M:%S.%f\", \"%Y-%m-%dT%H:%M:%S\"):\n        try:\n            return datetime.strptime(text, fmt)\n        except ValueError:\n            continue\n    return datetime.min\n\n\ndef load_runtime_overlay(date_tag: str) -> tuple[dict[str, Any], dict[str, Any]]:\n    runtime_obj: dict[str, Any] = {}\n    report_obj: dict[str, Any] = {}\n    if RUNTIME_STATE_LATEST.exists():\n        try:\n            runtime_obj = load_json(RUNTIME_STATE_LATEST)\n        except Exception:\n            runtime_obj = {}\n    report_path = QUANT_REPORT_DIR / f\"today_stock_strategy_report_{date_tag}.json\"\n    if not report_path.exists():\n        report_path = QUANT_REPORT_DIR / \"today_stock_strategy_report_latest.json\"\n    if report_path.exists():\n        try:\n            report_obj = load_json(report_path)\n        except Exception:\n            report_obj = {}\n    return runtime_obj, report_obj\n\n\ndef apply_runtime_overlay(summary: dict[str, Any]) -> dict[str, Any]:\n    date_tag = str(summary.get(\"strategy_report_date_tag\") or summary.get(\"paper_date_tag\") or datetime.now().strftime(\"%Y%m%d\"))\n    runtime_obj, report_obj = load_runtime_overlay(date_tag)\n    latest_runtime = runtime_obj.get(\"latest_runtime\") or {}\n\n    if str(runtime_obj.get(\"date_tag\") or \"\") == date_tag and latest_runtime:\n        summary[\"risk_off\"] = bool(latest_runtime.get(\"risk_off\"))\n        pe = dict(summary.get(\"paper_execution_status\") or {})\n        pe.update(\n            {\n                \"source\": \"runtime_risk_state_latest\",\n                \"mode\": latest_runtime.get(\"mode\"),","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1773972213422}}
