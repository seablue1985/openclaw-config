_date=today)\n    print(f\"  当日沪深港通持股记录数: {len(hb)}\")\nexcept:\n    pass\n\n# 获取今日模拟持仓个股行情\nprint(\"\\n=== 模拟持仓个股今日行情 ===\")\npositions = [\n    ('688228.SH', '开普云'),\n    ('603103.SH', '横店影视'),\n    ('688221.SH', '前沿生物'),\n    ('688622.SH', '禾信仪器'),\n    ('001330.SZ', '博纳影业'),\n    ('600977.SH', '中国电影'),\n    ('603533.SH', '掌阅科技'),\n    ('688435.SH', '英方软件'),\n    ('600481.SH', '双良节能'),\n    ('688699.SH', '明微电子'),\n]\n\ncodes = [p[0] for p in positions]\ndf = pro.daily(ts_code=','.join(codes), trade_date=today)\nif not df.empty:\n    df = df.set_index('ts_code')\n    total_pl = 0\n    for code, name in positions:\n        if code in df.index:\n            row = df.loc[code]\n            pct = row['pct_chg']\n            total_pl += pct\n            print(f\"  {name}({code}): {pct:+.2f}%\")\n        else:\n            print(f\"  {name}({code}): 无数据\")\n    print(f\"\\n  持仓组合加权涨跌: {total_pl/len(positions):+.2f}%\")\nelse:\n    print(\"  无数据\")\n\n# 获取昨日收盘对照\nprint(\"\\n=== 持仓个股近5日行情 ===\")\ntry:\n    df5 = pro.daily(ts_code=','.join(codes), start_date='20260318', end_date=today)\n    if not df5.empty:\n        df5 = df5.sort_values(['ts_code','trade_date'])\n        for code, name in positions[:5]:\n            sub = df5[df5['ts_code']==code][['trade_date','close','pct_chg','vol']]\n            print(f\"  {name}:\")\n            for _, r in sub.iterrows():\n                print(f\"    {r['trade_date']}: 收盘{r['close']} 涨跌{r['pct_chg']:+.2f}%\")\n    else:\n        print(\"  无数据\")\nexcept Exception as e:\n    print(f\"  Error: {e}\")\n\nEOF\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":112538,"output":1047,"cacheRead":38484,"cacheWrite":0,"totalTokens":152069,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774256498113}}
