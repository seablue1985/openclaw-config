05ddb16df2\",\"name\":\"exec\",\"arguments\":{\"command\":\"python3 - <<'PY'\\nimport akshare as ak\\nimport pandas as pd\\nfrom pathlib import Path\\n\\nnames = [\\n'风华高科','兴森科技','胜宏科技','沪电股份','景旺电子','东山精密','生益科技','南亚新材',\\n'铜冠铜箔','德福科技','诺德股份','宏和科技','菲利华','中国巨石','东方钽业','兆易创新',\\n'南大光电','沪硅产业','云南锗业','博杰股份'\\n]\\nspot = ak.stock_zh_a_spot_em()\\nspot = spot[spot['名称'].isin(names)].copy()\\n# append missing if any from北交/科创? still same data source\\nfound = set(spot['名称'])\\nmissing = [x for x in names if x not in found]\\nprint('missing', missing)\\n\\nrows=[]\\nfor name in names:\\n    srow = spot[spot['名称']==name]\\n    if srow.empty:\\n        rows.append({'名称':name, '代码':'MISSING'})\\n        continue\\n    s=srow.iloc[0]\\n    code=str(s['代码']).zfill(6)\\n    rec={\\n        '名称':name,'代码':code,'最新价':s['最新价'],'涨跌幅':s['涨跌幅'],'换手率':s['换手率'],\\n        'PE':s['市盈率-动态'],'PB':s['市净率'],'总市值亿':round(float(s['总市值'])/1e8,2),\\n        '年初至今涨跌幅':s['年初至今涨跌幅'],'60日涨跌幅':s['60日涨跌幅']\\n    }\\n    try:\\n        hist = ak.stock_zh_a_hist(symbol=code, period='daily', start_date='20250101', end_date='20260328', adjust='qfq')\\n        if len(hist)>=60:\\n            close=hist['收盘'].astype(float)\\n            rec['ma20']=round(close.tail(20).mean(),2)\\n            rec['ma60']=round(close.tail(60).mean(),2)\\n            rec['距ma20%']=round((close.iloc[-1]/close.tail(20).mean()-1)*100,2)\\n            rec['距ma60%']=round((close.iloc[-1]/close.tail(60).mean()-1)*100,2)\\n            rec['20日涨跌%']=round((close.iloc[-1]/close.iloc[-21]-1)*100,2) if len(close)>=21 else None\\n    except Exception as e:\\n        rec['hist_err']=type(e).__name__\\n    try:\\n        info = ak.stock_zyjs_ths(symbol=code)\\n        if not info.empty:\\n            rec['主营业务']=info.iloc[0]['主营业务']\\n            rec['产品类型']=info.iloc[0]['产品类型']\\n    except Exception as e:\\n        rec['biz_err']=type(e).__name__\\n    try:\\n        fa = ak.stock_financial_abstract_ths(symbol=code, indicator='按报告期') if 'indicator' in ak.stock_financial_abstract_ths.__code__.co_varnames else ak.stock_financial_abstract_ths(symbol=code)\\n    except TypeError:\\n        fa = ak.stock_financial_abstract_ths(symbol=code)\\n    except Exception as e:\\n        fa = pd.DataFrame()\\n        rec['fa_err']=type(e).__name__\\n    if not fa.empty:\\n        latest = fa.iloc[-1]\\n        for col,new in [('报告期','报告期'),('营业总收入','营业总收入'),('营业总收入同比增长率','营收同比'),('净利润','净利润'),('净利润同比增长率','净利同比'),('销售净利率','销售净利率'),('净资产收益率-摊薄','ROE摊薄'),('资产负债率','资产负债率')]:\\n            rec[new]=latest.get(col)\\n    rows.append(rec)\\n\\ndf=pd.DataFrame(rows)\\nout=Path('/tmp/xhs_ai_bottleneck_stock_snapshot.csv')\\ndf.to_csv(out, index=False)\\nprint(df.to_markdown(index=False))\\nprint('\\\\nCSV', out)\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace-coding-agent\",\"timeout\":1800,\"yieldMs\":20000,\"background\":true},\"partialJson\":\"{\\\"command\\\":\\\"python3 - <<'PY'\\\\nimport akshare as ak\\\\nimport pandas as pd\\\\nfrom pathlib import Path\\\\n\\\\nnames = [\\\\n'风华高科','兴森科技','胜宏科技','沪电股份','景旺电子','东山精密','生益科技','南亚新材',\\\\n'铜冠铜箔','德福科技','诺德股份','宏和科技','菲利华','中国巨石','东方钽业','兆易创新',\\\\n'南大光电','沪硅产业','云南锗业','博杰股份'\\\\n]\\\\nspot = ak.stock_zh_a_spot_em()\\\\nspot = spot[spot['名称'].isin(names)].copy()\\\\n# append missing if any from北交/科创? still same data source\\\\nfound = set(spot['名称'])\\\\nmissing = [x for x in names if x not in found]\\\\nprint('missing', missing)\\\\n\\\\nrows=[]\\\\nfor name in names:\\\\n    srow = spot[spot['名称']==name]\\\\n    if srow.empty:\\\\n        rows.append({'名称':name, '代码':'MISSING'})\\\\n        continue\\\\n    s=srow.iloc[0]\\\\n    code=str(s['代码']).zfill(6)\\\\n    rec={\\\\n        '名称':name,'代码':code,'最新价':s['最新价'],'涨跌幅':s['涨跌幅'],'换手率':s['换手率'],\\\\n        'PE':s['市盈率-动态'],'PB':s['市净率'],'总市值亿':round(float(s['总市值'])/1e8,2),\\\\n        '年初至今涨跌幅':s['年初至今涨跌幅'],'60日涨跌幅':s['60日涨跌幅']\\\\n    }\\\\n    try:\\\\n        hist = ak.stock_zh_a_hist(symbol=code, period='daily', start_date='20250101', end_date='20260328', adjust='qfq')\\\\n        if len(hist)>=60:\\\\n            close=hist['收盘'].astype(float)\\\\n            rec['ma20']=round(close.tail(20).mean(),2)\\\\n            rec['ma60']=round(close.tail(60).mean(),2)\\\\n            rec['距ma20%']=round((close.iloc[-1]/close.tail(20).mean()-1)*100,2)\\\\n            rec['距ma60%']=round((close.iloc[-1]/close.tail(60).mean()-1)*100,2)\\\\n            rec['20日涨跌%']=round((close.iloc[-1]/close.iloc[-21]-1)*100,2) if len(close)>=21 else None\\\\n    except Exception as e:\\\\n        rec['hist_err']=type(e).__name__\\\\n    try:\\\\n        info = ak.stock_zyjs_ths(symbol=code)\\\\n        if not info.empty:\\\\n            rec['主营业务']=info.iloc[0]['主营业务']\\\\n            rec['产品类型']=info.iloc[0]['产品类型']\\\\n    except Exception as e:\\\\n        rec['biz_err']=type(e).__name__\\\\n    try:\\\\n        fa = ak.stock_financial_abstract_ths(symbol=code, indicator='按报告期') if 'indicator' in ak.stock_financial_abstract_ths.__code__.co_varnames else ak.stock_financial_abstract_ths(symbol=code)\\\\n    except TypeError:\\\\n        fa = ak.stock_financial_abstract_ths(symbol=code)\\\\n    except Exception as e:\\\\n        fa = pd.DataFrame()\\\\n        rec['fa_err']=type(e).__name__\\\\n    if not fa.empty:\\\\n        latest = fa.iloc[-1]\\\\n        for col,new in [('报告期','报告期'),('营业总收入','营业总收入'),('营业总收入同比增长率','营收同比'),('净利润','净利润'),('净利润同比增长率','净利同比'),('销售净利率','销售净利率'),('净资产收益率-摊薄','ROE摊薄'),('资产负债率','资产负债率')]:\\\\n            rec[new]=latest.get(col)\\\\n    rows.append(rec)\\\\n\\\\ndf=pd.DataFrame(rows)\\\\nout=Path('/tmp/xhs_ai_bottleneck_stock_snapshot.csv')\\\\ndf.to_csv(out, index=False)\\\\nprint(df.to_markdown(index=False))\\\\nprint('\\\\\\\\nCSV', out)\\\\nPY\\\",\\\"workdir\\\":\\\"/Users/ling/.openclaw/workspace-coding-agent\\\",\\\"timeout\\\":1800,\\\"yieldMs\\\":20000,\\\"background\\\":true}\"}],\"api\":\"openai-responses\",\"provider\":\"codex\",\"model\":\"gpt