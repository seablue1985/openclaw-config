ecklists/_tmp/video_lyric_extract_20260328/ocr_frames.swift","content":"import Foundation\nimport Vision\nimport AppKit\n\nlet framesDir = URL(fileURLWithPath: \"/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328/frames\")\nlet outPath = URL(fileURLWithPath: \"/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328/frame_ocr.txt\")\n\nlet fm = FileManager.default\nlet files = (try fm.contentsOfDirectory(at: framesDir, includingPropertiesForKeys: nil))\n    .filter { $0.pathExtension.lowercased() == \"jpg\" }\n    .sorted { $0.lastPathComponent < $1.lastPathComponent }\n\nvar lines: [String] = []\nfor file in files {\n    guard let image = NSImage(contentsOf: file) else { continue }\n    var rect = NSRect(origin: .zero, size: image.size)\n    guard let cgImage = image.cgImage(forProposedRect: &rect, context: nil, hints: nil) else { continue }\n\n    let request = VNRecognizeTextRequest()\n    request.recognitionLevel = .accurate\n    request.recognitionLanguages = [\"zh-Hans\", \"zh-Hant\"]\n    request.usesLanguageCorrection = true\n    request.minimumTextHeight = 0.02\n\n    let handler = VNImageRequestHandler(cgImage: cgImage, options: [:])\n    do {\n        try handler.perform([request])\n    } catch {\n        lines.append(\"## \\(file.lastPathComponent)\\nOCR_ERROR: \\(error)\\n\")\n        continue\n    }\n\n    let observations = (request.results ?? [])\n        .compactMap { $0.topCandidates(1).first?.string }\n    lines.append(\"## \\(file.lastPathComponent)\")\n    if observations.isEmpty {\n        lines.append(\"(no text)\")\n    } else {\n        lines.append(contentsOf: observations)\n    }\n    lines.append(\"\")\n}\n\ntry lines.joined(separator: \"\\n\").write(to: outPath, atomically: true, encoding: .utf8)\nprint(outPath.path)\n"},"partialJson":"{\"path\":\"checklists/_tmp/video_lyric_extract_20260328/ocr_frames.swift\",\"content\":\"import Foundation\\nimport Vision\\nimport AppKit\\n\\nlet framesDir = URL(fileURLWithPath: \\\"/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328/frames\\\")\\nlet outPath = URL(fileURLWithPath: \\\"/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328/frame_ocr.txt\\\")\\n\\nlet fm = FileManager.default\\nlet files = (try fm.contentsOfDirectory(at: framesDir, includingPropertiesForKeys: nil))\\n    .filter { $0.pathExtension.lowercased() == \\\"jpg\\\" }\\n    .sorted { $0.lastPathComponent < $1.lastPathComponent }\\n\\nvar lines: [String] = []\\nfor file in files {\\n    guard let image = NSImage(contentsOf: file) else { continue }\\n    var rect = NSRect(origin: .zero, size: image.size)\\n    guard let cgImage = image.cgImage(forProposedRect: &rect, context: nil, hints: nil) else { continue }\\n\\n    let request = VNRecognizeTextRequest()\\n    request.recognitionLevel = .accurate\\n    request.recognitionLanguages = [\\\"zh-Hans\\\", \\\"zh-Hant\\\"]\\n    request.usesLanguageCorrection = true\\n    request.minimumTextHeight = 0.02\\n\\n    let handler = VNImageRequestHandler(cgImage: cgImage, options: [:])\\n    do {\\n        try handler.perform([request])\\n    } catch {\\n        lines.append(\\\"## \\\\(file.lastPathComponent)\\\\nOCR_ERROR: \\\\(error)\\\\n\\\")\\n        continue\\n    }\\n\\n    let observations = (request.results ?? [])\\n        .compactMap { $0.topCandidates(1).first?.string }\\n    lines.append(\\\"## \\\\(file.lastPathComponent)\\\")\\n    if observations.isEmpty {\\n        lines.append(\\\"(no text)\\\")\\n    } else {\\n        lines.append(contentsOf: observations)\\n    }\\n    lines.append(\\\"\\\")\\n}\\n\\ntry lines.joined(separator: \\\"\\\\n\\\").write(to: outPath, atomically: true, encoding: .utf8)\\nprint(outPath.path)\\n\"}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":158,"output":639,"cacheRead":94208,"cacheWrite":0,"totalTokens":95005,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total"