d make it more efficient. By focusing on extracting text directly from video frames, I can streamline the workflow. I'm considering utilizing AVAssetImageGenerator for frame extraction and Vision for OCR processing. This way, I can capture subtitles or text more accurately. Let's dive into coding this and see how effective it is!\"}]}"},{"type":"text","text":"初步 OCR 已经把多句歌词抓出来了，但识别质量一般。我继续做更细的“逐秒抽帧 + 下半屏定向 OCR”，把歌词完整度提上来。","textSignature":"{\"v\":1,\"id\":\"msg_075abb85efaf918e0169c7c80abfe8819aa41a47a74165ba42\",\"phase\":\"commentary\"}"},{"type":"toolCall","id":"call_e3q4pOrQpqJJjr5xv6TsJ9oG|fc_075abb85efaf918e0169c7c80ad210819ab12a7db60435259c","name":"write","arguments":{"path":"checklists/_tmp/video_lyric_extract_20260328/ocr_video_subtitles.swift","content":"import Foundation\nimport AVFoundation\nimport Vision\nimport AppKit\nimport CoreMedia\n\nlet inputURL = URL(fileURLWithPath: \"/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328/zghd_school_song.mp4\")\nlet outPath = URL(fileURLWithPath: \"/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328/subtitle_ocr_detailed.txt\")\n\nlet asset = AVURLAsset(url: inputURL)\nlet generator = AVAssetImageGenerator(asset: asset)\ngenerator.appliesPreferredTrackTransform = true\ngenerator.maximumSize = CGSize(width: 1280, height: 720)\n\nlet durationSeconds = CMTimeGetSeconds(asset.duration)\nlet step: Double = 2.0\nvar t: Double = 0\nvar out: [String] = []\n\nwhile t < durationSeconds {\n    let time = CMTime(seconds: t, preferredTimescale: 600)\n    do {\n        let cgImage = try generator.copyCGImage(at: time, actualTime: nil)\n        let width = cgImage.width\n        let height = cgImage.height\n        let cropRect = CGRect(x: 0, y: 0, width: width, height: Int(Double(height) * 0.38))\n        guard let cropped = cgImage.cropping(to: cropRect) else {\n            t += step\n            continue\n        }\n\n        let request = VNRecognizeTextRequest()\n        request.recognitionLevel = .accurate\n        request.recognitionLanguages = [\"zh-Hans\", \"zh-Hant\"]\n        request.usesLanguageCorrection = true\n        request.minimumTextHeight = 0.025\n\n        let handler = VNImageRequestHandler(cgImage: cropped, options: [:])\n        try handler.perform([request])\n        let texts = (request.results ?? [])\n            .sorted { $0.boundingBox.minY > $1.boundingBox.minY }\n            .compactMap { $0.topCandidates(1).first?.string.trimmingCharacters(in: .whitespacesAndNewlines) }\n            .filter { !$0.isEmpty }\n\n        out.append(String(format: \"[%.0fs] %@\", t, texts.joined(separator: \" | \")))\n    } catch {\n        out.append(String(format: \"[%.0fs] OCR_ERROR: %@\", t, String(describing: error)))\n    }\n    t += step\n}\n\ntry out.joined(separator: \"\\n\").write(to: outPath, atomically: true, encoding: .utf8)\nprint(outPath.path)\n"},"partialJson":"{\"path\":\"checklists/_tmp/video_lyric_extract_20260328/ocr_video_subtitles.swift\",\"content\":\"import Foundation\\nimport AVFoundation\\nimport Vision\\nimport AppKit\\nimport CoreMedia\\n\\nlet inputURL = URL(fileURLWithPath: \\\"/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328/zghd_school_song.mp4\\\")\\nlet outPath = URL(fileURLWithPath: \\\"/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328/subtitle_ocr_detailed.txt\\\")\\n\\nlet asset = AVURLAsset(url: inputURL)\\nlet generator = AVAssetImageGenerator(asset: asset)\\ngenerator.appliesPreferredTrackTransform = true\\ngenerator.maximumSize = CGSize(width: 1280, height: 720)\\n\\nlet durationSeconds = CMTimeGetSeconds(asset.duration)\\nlet step: Double = 2.0\\nvar t: Double = 0\\nvar out: [String] = []\\n\\nwhile t < durationSeconds {\\n    let time = CMTime(seconds: t, preferredTimescale: 600)\\n    do {\\n        let cgImage = try generator.copyCGImage(at: time, actualTime: nil)\\n        let width = cgImage.width\\n        let height = cgImage.height\\n        let cropRect = CGRect(x: 0, y: 0, width: width, height: Int(Double(height) * 0.38))\\n        guard let cropped = cgImage.cropping(to: cropRect) else {\\n            t += step\\n            continue\\n        }\\n\\n        let request = VNRecognizeTextRequest()\\n        request.recognitionLevel = .accurate\\n        request.recognitionLanguages = [\\\"zh-Hans\\\", \\\"zh-Hant\\\"]\\n        request.usesLanguageCorrection = true\\n        request.minimumTextHeight = 0.025\\n\\n        let handler = VNImageRequestHandler(cgImage: cropped, options: [:])\\n        try handler.perform([request])\\n        let texts = (request.results ?? [])\\n            .sorted { $0.boundingBox.minY > $1.boundingBox.minY }\\n            .compactMap { $0.topCandidates(1).first?.string.trimmingCharacters(in: .whitespacesAndNewlines) }\\n            .filter { !$0.isEmpty }\\n\\n        out.append(String(format: \\\"[%.0fs] %@\\\", t, texts.joined(separator: \\\" | \\\")))\\n    } catch {\\n        out.append(String(format: \\\"[%.0fs] OCR_ERROR: %@\\\", t, String(describing: error)))\\n    }\\n    t += step\\n}\\n\\ntry out.joined(separator: \\\"\\\\n\\\").write(to: outPath, atomically: true, encoding: .utf8)\\nprint(outPath.path)\\n\"}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":496,"output":894,"cacheRead":94976,"cacheWrite":0,"totalTokens":96366,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774700542041,"responseId":"resp_075abb85efaf918e0169c7c7ffe0fc819aba709a26b26b8762"}}
