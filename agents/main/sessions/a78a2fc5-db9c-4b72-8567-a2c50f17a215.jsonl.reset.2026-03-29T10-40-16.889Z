app_id=acc.get('appId') or cfg['channels']['feishu'].get('appId')\napp_secret=acc.get('appSecret') or cfg['channels']['feishu'].get('appSecret')\nif isinstance(app_secret, str) and app_secret.startswith('${') and app_secret.endswith('}'):\n    app_secret=os.environ.get(app_secret[2:-1])\nif not app_secret:\n    secret_file=cfg.get('secrets',{}).get('providers',{}).get('feishu_app_secret_file',{}).get('path')\n    if secret_file and Path(secret_file).exists():\n        app_secret=Path(secret_file).read_text().strip()\nr=requests.post('https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal', json={'app_id': app_id, 'app_secret': app_secret}, timeout=30)\nr.raise_for_status(); j=r.json(); token=j['tenant_access_token']\nheaders={'Authorization': f'Bearer {token}'}\nurl=f'https://open.feishu.cn/open-apis/im/v1/files/{file_key}'\nwith requests.get(url, headers=headers, stream=True, timeout=120) as resp:\n    print('HTTP', resp.status_code)\n    print('CONTENT_TYPE', resp.headers.get('content-type'))\n    if resp.status_code!=200:\n        print(resp.text[:1000]); sys.exit(1)\n    with open(out_file, 'wb') as f:\n        for chunk in resp.iter_content(1024*1024):\n            if chunk:\n                f.write(chunk)\nprint('DOWNLOADED', out_file)\nprint('SIZE', out_file.stat().st_size)\nPY","workdir":"/Users/ling/.openclaw/workspace","timeout":180,"yieldMs":4000},"partialJson":"{\"command\":\"python3 - <<'PY'\\nimport json, os, sys\\nfrom pathlib import Path\\nimport requests\\nfile_key='file_v3_00107_cfc2da4c-263e-4baf-ac3a-0771d704faeg'\\nout_dir=Path('/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328')\\nout_dir.mkdir(parents=True, exist_ok=True)\\nout_file=out_dir/'Video_1774699100058_366.mp4'\\n\\ncfg=json.loads((Path.home()/'.openclaw'/'openclaw.json').read_text())\\nacc=cfg['channels']['feishu']['accounts']['feishu-assistant']\\napp_id=acc.get('appId') or cfg['channels']['feishu'].get('appId')\\napp_secret=acc.get('appSecret') or cfg['channels']['feishu'].get('appSecret')\\nif isinstance(app_secret, str) and app_secret.startswith('${') and app_secret.endswith('}'):\\n    app_secret=os.environ.get(app_secret[2:-1])\\nif not app_secret:\\n    secret_file=cfg.get('secrets',{}).get('providers',{}).get('feishu_app_secret_file',{}).get('path')\\n    if secret_file and Path(secret_file).exists():\\n        app_secret=Path(secret_file).read_text().strip()\\nr=requests.post('https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal', json={'app_id': app_id, 'app_secret': app_secret}, timeout=30)\\nr.raise_for_status(); j=r.json(); token=j['tenant_access_token']\\nheaders={'Authorization': f'Bearer {token}'}\\nurl=f'https://open.feishu.cn/open-apis/im/v1/files/{file_key}'\\nwith requests.get(url, headers=headers, stream=True, timeout=120) as resp:\\n    print('HTTP', resp.status_code)\\n    print('CONTENT_TYPE', resp.headers.get('content-type'))\\n    if resp.status_code!=200:\\n        print(resp.text[:1000]); sys.exit(1)\\n    with open(out_file, 'wb') as f:\\n        for chunk in resp.iter_content(1024*1024):\\n            if chunk:\\n                f.write(chunk)\\nprint('DOWNLOADED', out_file)\\nprint('SIZE', out_file.stat().st_size)\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":180,\"yieldMs\":4000}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":763,"output":615,"cacheRead":47616,"cacheWrite":0,"totalTokens":48994,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774699473050,"responseId":"resp_075abb85efaf918e0169c7c3d32870819a86f9acb7afd2328b"}}
