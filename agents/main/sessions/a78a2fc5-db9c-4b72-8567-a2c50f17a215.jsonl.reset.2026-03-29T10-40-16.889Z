TION',key)\\n        if isinstance(obj[key], dict):\\n            print(list(obj[key].keys())[:50])\\n        elif isinstance(obj[key], list):\\n            print('list', len(obj[key]))\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace\",\"timeout\":30,\"yieldMs\":3000}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":2571,"output":476,"cacheRead":110592,"cacheWrite":0,"totalTokens":113639,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774704282531,"responseId":"resp_075abb85efaf918e0169c7d69bfae0819aae543766e144bccf"}}
