rator = AVAssetImageGenerator(asset: asset)\ngenerator.appliesPreferredTrackTransform = true\ngenerator.maximumSize = CGSize(width: 1280, height: 720)\n\nlet durationSeconds = CMTimeGetSeconds(asset.duration)\nlet step: Double = 2.0\nvar t: Double = 0\nvar out: [String] = []\n\nwhile t < durationSeconds {\n    let time = CMTime(seconds: t, preferredTimescale: 600)\n    do {\n        let cgImage = try generator.copyCGImage(at: time, actualTime: nil)\n\n        let request = VNRecognizeTextRequest()\n        request.recognitionLevel = .accurate\n        request.recognitionLanguages = [\"zh-Hans\", \"zh-Hant\"]\n        request.usesLanguageCorrection = true\n        request.minimumTextHeight = 0.015\n\n        let handler = VNImageRequestHandler(cgImage: cgImage, options: [:])\n        try handler.perform([request])\n        let texts = (request.results ?? [])\n            .sorted { $0.boundingBox.minY > $1.boundingBox.minY }\n            .compactMap { obs -> String? in\n                guard let s = obs.topCandidates(1).first?.string.trimmingCharacters(in: .whitespacesAndNewlines) else { return nil }\n                if s.isEmpty { return nil }\n                return s\n            }\n            .filter { !$0.contains(\"腾讯视频\") && !$0.contains(\"謄讯视频\") && !$0.contains(\"跨讯视频\") && !$0.contains(\"皆讯视频\") && !$0.contains(\"揩讯\") && !$0.contains(\"眷讯\") && !$0.contains(\"膳讯\") }\n\n        out.append(String(format: \"[%.0fs] %@\", t, texts.joined(separator: \" | \")))\n    } catch {\n        out.append(String(format: \"[%.0fs] OCR_ERROR: %@\", t, String(describing: error)))\n    }\n    t += step\n}\n\ntry out.joined(separator: \"\\n\").write(to: outPath, atomically: true, encoding: .utf8)\nprint(outPath.path)\n"},"partialJson":"{\"path\":\"checklists/_tmp/video_lyric_extract_20260328/ocr_video_full.swift\",\"content\":\"import Foundation\\nimport AVFoundation\\nimport Vision\\nimport CoreMedia\\n\\nlet inputURL = URL(fileURLWithPath: \\\"/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328/zghd_school_song.mp4\\\")\\nlet outPath = URL(fileURLWithPath: \\\"/Users/ling/.openclaw/workspace/checklists/_tmp/video_lyric_extract_20260328/subtitle_ocr_full_2s.txt\\\")\\n\\nlet asset = AVURLAsset(url: inputURL)\\nlet generator = AVAssetImageGenerator(asset: asset)\\ngenerator.appliesPreferredTrackTransform = true\\ngenerator.maximumSize = CGSize(width: 1280, height: 720)\\n\\nlet durationSeconds = CMTimeGetSeconds(asset.duration)\\nlet step: Double = 2.0\\nvar t: Double = 0\\nvar out: [String] = []\\n\\nwhile t < durationSeconds {\\n    let time = CMTime(seconds: t, preferredTimescale: 600)\\n    do {\\n        let cgImage = try generator.copyCGImage(at: time, actualTime: nil)\\n\\n        let request = VNRecognizeTextRequest()\\n        request.recognitionLevel = .accurate\\n        request.recognitionLanguages = [\\\"zh-Hans\\\", \\\"zh-Hant\\\"]\\n        request.usesLanguageCorrection = true\\n        request.minimumTextHeight = 0.015\\n\\n        let handler = VNImageRequestHandler(cgImage: cgImage, options: [:])\\n        try handler.perform([request])\\n        let texts = (request.results ?? [])\\n            .sorted { $0.boundingBox.minY > $1.boundingBox.minY }\\n            .compactMap { obs -> String? in\\n                guard let s = obs.topCandidates(1).first?.string.trimmingCharacters(in: .whitespacesAndNewlines) else { return nil }\\n                if s.isEmpty { return nil }\\n                return s\\n            }\\n            .filter { !$0.contains(\\\"腾讯视频\\\") && !$0.contains(\\\"謄讯视频\\\") && !$0.contains(\\\"跨讯视频\\\") && !$0.contains(\\\"皆讯视频\\\") && !$0.contains(\\\"揩讯\\\") && !$0.contains(\\\"眷讯\\\") && !$0.contains(\\\"膳讯\\\") }\\n\\n        out.append(String(format: \\\"[%.0fs] %@\\\", t, texts.joined(separator: \\\" | \\\")))\\n    } catch {\\n        out.append(String(format: \\\"[%.0fs] OCR_ERROR: %@\\\", t, String(describing: error)))\\n    }\\n    t += step\\n}\\n\\ntry out.joined(separator: \\\"\\\\n\\\").write(to: outPath, atomically: true, encoding: .utf8)\\nprint(outPath.path)\\n\"}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":684,"output":816,"cacheRead":96768,"cacheWrite":0,"totalTokens":98268,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774700577686,"responseId":"resp_075abb85efaf918e0169c7c822aed8819a8b3efe4a6a3831b1"}}
