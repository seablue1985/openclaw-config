{"type":"message","id":"7be79941","parentId":"4faf5870","timestamp":"2026-03-27T10:08:11.511Z","message":{"role":"toolResult","toolCallId":"call_wyFPSIZQfYfHGSERvhu1S8Ud|fc_0a18d76e314b89270169c6570a75488198aa906ea4966892f7","toolName":"read","content":[{"type":"text","text":"            f\"- 当前默认 profile 样本外多数跑赢基线：`{conclusion.get('default_profile_beats_baseline_majority', False)}`\",\n            f\"- 当前默认 profile 平均样本外 alpha 为正：`{conclusion.get('default_profile_positive_mean_test_alpha', False)}`\",\n            f\"- 逐窗训练选型样本外多数跑赢基线：`{conclusion.get('selection_beats_baseline_majority', False)}`\",\n            f\"- 是否达到最低窗口门槛 `{MIN_WINDOWS_FOR_LIVE_SWITCH}`：`{conclusion.get('enough_windows', False)}`\",\n            f\"- robust_pass：`{conclusion.get('robust_pass', False)}`\",\n            f\"- 建议动作：`{conclusion.get('recommended_action', '')}`\",\n            \"\",\n        ]\n    )\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(\"\\n\".join(lines), encoding=\"utf-8\")\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"股票分析 overlay 样本外稳健性验证\")\n    parser.add_argument(\"--input-detail-csv\", default=\"\", help=\"可选：已有 chain replay detail CSV；不传则自动跑一次链路回放\")\n    parser.add_argument(\"--start-date\", default=\"20250101\")\n    parser.add_argument(\"--end-date\", default=datetime.now().strftime(\"%Y%m%d\"))\n    parser.add_argument(\"--eval-window-days\", type=int, default=5)\n    parser.add_argument(\"--price-csv\", default=str(chain_mod.DEFAULT_PRICE_CSV))\n    parser.add_argument(\"--basic-csv\", default=str(chain_mod.DEFAULT_BASIC_CSV))\n    parser.add_argument(\"--strategy-config\", default=str(chain_mod.DEFAULT_CONFIG))\n    parser.add_argument(\"--live-config\", default=str(chain_mod.DEFAULT_LIVE_CONFIG))\n    parser.add_argument(\"--stock-basic-csv\", default=str(chain_mod.DEFAULT_STOCK_BASIC_CSV))\n    parser.add_argument(\"--chunk-size\", type=int, default=chain_mod.DEFAULT_CHUNK_SIZE)\n    parser.add_argument(\"--profiles\", nargs=\"+\", default=list(DEFAULT_PROFILE_NAMES))\n    parser.add_argument(\"--baseline-profile\", default=DEFAULT_BASELINE_PROFILE)\n    parser.add_argument(\"--holdout-train-ratio\", type=float, default=DEFAULT_HOLDOUT_TRAIN_RATIO)\n    parser.add_argument(\"--holdout-min-test-days\", type=int, default=DEFAULT_HOLDOUT_MIN_TEST_DAYS)\n    parser.add_argument(\"--train-days\", type=int, default=DEFAULT_TRAIN_DAYS)\n    parser.add_argument(\"--test-days\", type=int, default=DEFAULT_TEST_DAYS)\n    parser.add_argument(\"--step-days\", type=int, default=DEFAULT_STEP_DAYS)\n    parser.add_argument(\"--date-tag\", default=datetime.now().strftime(\"%Y%m%d\"))\n    parser.add_argument(\"--output-profile-summary-csv\", default=\"\")\n    parser.add_argument(\"--output-window-selection-csv\", default=\"\")\n    parser.add_argument(\"--output-window-metric-csv\", default=\"\")\n    parser.add_argument(\"--output-holdout-csv\", default=\"\")\n    parser.add_argument(\"--output-json\", default=\"\")\n    parser.add_argument(\"--output-md\", default=\"\")\n    args = parser.parse_args()\n\n    profile_names = unique_keep_order(\n        [bridge_mod.normalize_overlay_profile_name(name) for name in list(args.profiles or [])]\n    )\n    baseline_profile = bridge_mod.normalize_overlay_profile_name(args.baseline_profile)\n    if baseline_profile not in profile_names:\n        profile_names.insert(0, baseline_profile)\n\n    if args.input_detail_csv:\n        detail_source = Path(args.input_detail_csv).expanduser().resolve()\n        if not detail_source.exists():\n            raise FileNotFoundError(detail_source)\n        detail_frame = normalize_detail_frame(pd.read_csv(detail_source))\n        source_payload: dict[str, Any] | None = None\n    else:\n        source_payload = chain_mod.run_backtest(\n            start_date=chain_mod.parse_date_key(args.start_date),\n            end_date=chain_mod.parse_date_key(args.end_date),\n            eval_window_days=int(args.eval_window_days),\n            price_csv=Path(args.price_csv),\n            basic_csv=Path(args.basic_csv),\n            strategy_config_path=Path(args.strategy_config),\n            live_config_path=Path(args.live_config),\n            stock_basic_csv=Path(args.stock_basic_csv),\n            chunk_size=int(args.chunk_size),\n        )\n        detail_source = REPORT_DIR / f\"stock_analysis_overlay_walkforward_source_detail_{args.date_tag}.csv\"\n        detail_frame = normalize_detail_frame(pd.DataFrame(source_payload[\"detail_rows\"]))\n        detail_source.parent.mkdir(parents=True, exist_ok=True)\n        detail_frame.to_csv(detail_source, index=False, encoding=\"utf-8-sig\")\n\n    trade_dates = sorted(int(x) for x in detail_frame[\"date_key\"].dropna().unique().tolist() if int(x) > 0)\n    if not trade_dates:\n        raise ValueError(\"detail frame 不包含有效交易日\")\n\n    holdout_split = build_holdout_split(\n        trade_dates,\n        train_ratio=float(args.holdout_train_ratio),\n        min_test_days=int(args.holdout_min_test_days),\n    )\n    windows = wf_mod.build_walkforward_windows(\n        trade_dates,\n        train_days=int(args.train_days),\n        test_days=int(args.test_days),\n        step_days=int(args.step_days),\n    )\n\n    profile_frames: dict[str, pd.DataFrame] = {}\n    overlay_count_map: dict[str, dict[str, int]] = {}\n    for profile_name in profile_names:\n        profile_frame, overlay_counts = recompute_profile_frame(detail_frame, profile_name=profile_name)\n        profile_frames[profile_name] = profile_frame\n        overlay_count_map[profile_name] = overlay_counts\n\n    full_sample_df = evaluate_full_sample(profile_frames)\n    holdout_df, holdout_summary = evaluate_holdout_profiles(\n        profile_frames,\n        split=holdout_split,\n        baseline_profile=baseline_profile,\n    )\n    rolling_metric_df, selection_df = evaluate_rolling_windows(\n        profile_frames,\n        windows=windows,\n        baseline_profile=baseline_profile,\n    )\n    rolling_summary_df = aggregate_profile_results(rolling_metric_df, selection_df)\n    robust_candidate = select_robust_profile(rolling_summary_df, window_count=len(windows))\n    selection_summary = summarize_window_selection(selection_df)\n\n    default_profile_summary = (\n        rolling_summary_df[rolling_summary_df[\"profile_name\"] == bridge_mod.DEFAULT_OVERLAY_PROFILE].iloc[0].to_dict()\n        if not rolling_summary_df.empty and bridge_mod.DEFAULT_OVERLAY_PROFILE in rolling_summary_df[\"profile_name\"].tolist()\n        else {}\n    )\n    majority = math.ceil(max(len(windows), 1) / 2)\n    enough_windows = len(windows) >= MIN_WINDOWS_FOR_LIVE_SWITCH\n    default_beats_majority = int(default_profile_summary.get(\"outperform_baseline_windows\", 0) or 0) >= majority\n    default_positive_mean = bridge_mod.parse_float(default_profile_summary.get(\"mean_test_overlay_alpha_pct\"), 0.0) > 0\n    selection_beats_majority = int(selection_summary.get(\"beats_baseline_windows\", 0) or 0) >= majority\n    robust_pass = bool(enough_windows and default_beats_majority and default_positive_mean and selection_beats_majority)\n    recommended_action = \"keep_current_default_profile\"\n    if robust_candidate and robust_candidate.get(\"profile_name\") != bridge_mod.DEFAULT_OVERLAY_PROFILE and robust_pass:\n        recommended_action = f\"consider_switch_to_{robust_candidate.get('profile_name')}\"\n    elif not robust_pass:\n        recommended_action = \"keep_current_default_but_do_not_expand_weight\"\n\n    outputs = default_output_paths(args.date_tag)\n    if args.output_profile_summary_csv:\n        outputs[\"profile_summary_csv\"] = Path(args.output_profile_summary_csv)\n    if args.output_window_selection_csv:\n        outputs[\"window_selection_csv\"] = Path(args.output_window_selection_csv)\n    if args.output_window_metric_csv:\n        outputs[\"window_metric_csv\"] = Path(args.output_window_metric_csv)\n    if args.output_holdout_csv:\n        outputs[\"holdout_csv\"] = Path(args.output_holdout_csv)\n    if args.output_json:\n        outputs[\"json\"] = Path(args.output_json)\n    if args.output_md:\n        outputs[\"md\"] = Path(args.output_md)\n\n    for path in outputs.values():\n        path.parent.mkdir(parents=True, exist_ok=True)\n\n    full_sample_records = full_sample_df.where(pd.notna(full_sample_df), None).to_dict(orient=\"records\")\n    holdout_records = holdout_df.where(pd.notna(holdout_df), None).to_dict(orient=\"records\")\n    rolling_summary_records = rolling_summary_df.where(pd.notna(rolling_summary_df), None).to_dict(orient=\"records\")\n    selection_records = selection_df.where(pd.notna(selection_df), None).to_dict(orient=\"records\")\n\n    rolling_summary_df.to_csv(outputs[\"profile_summary_csv\"], index=False, encoding=\"utf-8-sig\")\n    selection_df.to_csv(outputs[\"window_selection_csv\"], index=False, encoding=\"utf-8-sig\")\n    rolling_metric_df.to_csv(outputs[\"window_metric_csv\"], index=False, encoding=\"utf-8-sig\")\n    holdout_df.to_csv(outputs[\"holdout_csv\"], index=False, encoding=\"utf-8-sig\")\n\n    payload = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"date_tag\": args.date_tag,\n        \"detail_source\": str(detail_source),\n        \"start_date\": int(trade_dates[0]),\n        \"effective_end_date\": int(trade_dates[-1]),\n        \"trade_day_count\": int(len(trade_dates)),\n        \"profiles\": profile_names,\n        \"baseline_profile\": baseline_profile,\n        \"default_profile\": bridge_mod.DEFAULT_OVERLAY_PROFILE,\n        \"overlay_counts\": overlay_count_map,\n        \"holdout_split\": asdict(holdout_split),\n        \"window_config\": {\n            \"train_days\": int(args.train_days),\n            \"test_days\": int(args.test_days),\n            \"step_days\": int(args.step_days),\n        },\n        \"window_count\": int(len(windows)),\n        \"windows\": [asdict(window) for window in windows],\n        \"holdout_summary\": holdout_summary,\n        \"rolling_selection_summary\": selection_summary,\n        \"robust_candidate\": robust_candidate,\n        \"full_sample_summary\": full_sample_records,\n        \"holdout_rows\": holdout_records,\n        \"rolling_profile_summary\": rolling_summary_records,\n        \"window_selection_preview\": selection_records[:20],\n        \"conclusion\": {\n            \"default_profile_beats_baseline_majority\": bool(default_beats_majority),\n            \"default_profile_positive_mean_test_alpha\": bool(default_positive_mean),\n            \"selection_beats_baseline_majority\": bool(selection_beats_majority),\n            \"enough_windows\": bool(enough_windows),\n            \"robust_pass\": bool(robust_pass),\n            \"recommended_action\": recommended_action,\n        },\n        \"files\": {key: str(path) for key, path in outputs.items()},\n    }\n    if source_payload is not None:\n        payload[\"source_backtest_summary\"] = {\n            \"risk_stage\": source_payload.get(\"risk_stage\"),\n            \"final_stage\": source_payload.get(\"final_stage\"),\n            \"overlay_counts\": source_payload.get(\"overlay_counts\"),\n        }\n\n    outputs[\"json\"].write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    render_markdown(outputs[\"md\"], payload)\n    print(json.dumps(payload, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774606091501}}
