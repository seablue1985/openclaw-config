rsS8wag1NTe2nCFKtumiOU7aVfoplhpHd5z_wb9wilpcI0YnHZk-EqQb1gDMOTRDPVmeSh8oOqr6Rg3-sQJxcG-wChxLfolo3MLepNMNB27twcFBSafTUzjiu8Hlzxdeua-FtIv6tp9TG-OBkjHV34IxjYWMtOggDMxmskAgBYrukNrAGkfVE-PfRkaWk0hiNTYZf2hFQb5OUYh7TXARjUvArWbet1Al1pnZ4rhWnKbWzEJ4sjZOExYisMkI0ZJ6u4ZucjHUTG6_WPQTKmewsIzekfakwVTESxRiMXoQNn-23boXBerqFJWuhmK2ZpgLgk9LXqyejG85FGo16_2r5j9-iDyheQNtb94FbO0mpf5EueF57QOZNs1yzoLuXCoSZbd3e23LB_mtDpeWGWJtTsnVFS-vmGvnWqrsPxxUmxEg1pEZBornkparoAUG6PQ2YDI8ILM_k_sR-AxdAI0hdwns1doG_SxjzYZKTy3Pi8nAEKXnG2mTvaabF7OgIZxxMjPiiqDxax2vD_TlN6UsOJ074PABJ3KOocM9j\",\"summary\":[{\"type\":\"summary_text\",\"text\":\"**Crafting a script for analysis**\\n\\nI need to carefully write a script, possibly using the existing run_exit_rule_walkforward_validation for building walkforward windows. I should consider implementing my own dataclass for speed, along with a helper function. I'll look into using panel z cols and inspect header constants. It seems I can borrow FAST_Z_COLS, and utilize libraries like pandas, argparse, json, and dataclasses to create a self-contained script. I also want to ensure the calculation of rolling percentiles is identical.\"},{\"type\":\"summary_text\",\"text\":\"**Organizing candidate evaluation**\\n\\nI’m planning to build a function to create windows based on unique trade date indices. For evaluating candidates, I’ll set metrics for A and B, aiming to choose the preferred candidate by maximizing edge avoidance and using a tiebreaker based on count. I’ll implement rolling windows with train/test subsets, aggregating summaries by candidate over test windows for metrics like mean edge, median, and sample count. Finally, I’ll prepare outputs in CSV and JSON formats, ensuring acceptance is based on validation and a robust report.\"}]}"},{"type":"text","text":"脚本我直接按“固定切分 + 滚动前推 + 候选 A/B 对比”写，不再走泛化大框架。","textSignature":"{\"v\":1,\"id\":\"msg_0a18d76e314b89270169c65dea804881988cdfd9882add704a\",\"phase\":\"commentary\"}"},{"type":"toolCall","id":"call_8xsqwksJrCRPPEPxVbawRc5o|fc_0a18d76e314b89270169c65deae1c08198ac21ad2571c0a4d0","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_sentiment_rule2_walkforward_validation.py","content":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport math\nfrom dataclasses import asdict, dataclass\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nWORKSPACE = Path('/Users/ling/.openclaw/workspace')\nREPORT_DIR = WORKSPACE / 'research' / 'reports'\nDEFAULT_DETAIL_CSV = REPORT_DIR / 'sentiment_gate_shadow_validation_detail_20260327_window_ext.csv'\nDEFAULT_PANEL_CSV = REPORT_DIR / 'docx14_sentiment_factor_panel_20260327_window_ext.csv'\n\nFAST_Z_COLS = [\n    'ashare_trading_volume_z60',\n    'ashare_turnover_rate_z60',\n    'limit_up_stock_count_z60',\n    'northbound_trading_total_z60',\n    'rsi_index_z60',\n]\n\n\n@dataclass\nclass HoldoutSplit:\n    train_start: int\n    train_end: int\n    validation_start: int\n    validation_end: int\n    train_days: int\n    validation_days: int\n\n\n@dataclass\nclass WalkforwardWindow:\n    window_id: int\n    train_start: int\n    train_end: int\n    test_start: int\n    test_end: int\n    train_days: int\n    test_days: int\n\n\ndef rolling_percentile(series: pd.Series, window: int = 60) -> pd.Series:\n    values = pd.to_numeric(series, errors='coerce')\n    out: list[float | None] = []\n    for idx in range(len(values)):\n        start = max(0, idx - window + 1)\n        hist = values.iloc[start : idx + 1].dropna()\n        cur = values.iloc[idx]\n        if hist.empty or pd.isna(cur):\n            out.append(None)\n            continue\n        out.append(round(float((hist <= cur).mean() * 100.0), 4))\n    return pd.Series(out, index=series.index, dtype='float64')\n\n\ndef build_holdout_split(trade_dates: list[int], train_ratio: float, min_test_days: int) -> HoldoutSplit:\n    total = len(trade_dates)\n    if total < 2:\n        raise ValueError('交易日不足，无法做样本外切分')\n    validation_days = max(int(round(total * (1.0 - train_ratio))), int(min_test_days))\n    validation_days = min(validation_days, total - 1)\n    train_days = total - validation_days\n    if train_days <= 0:\n        raise ValueError('训练窗口为空，无法做样本外切分')\n    return HoldoutSplit(\n        train_start=int(trade_dates[0]),\n        train_end=int(trade_dates[train_days - 1]),\n        validation_start=int(trade_dates[train_days]),\n        validation_end=int(trade_dates[-1]),\n        train_days=int(train_days),\n        validation_days=int(validation_days),\n    )\n\n\ndef build_walkforward_windows(trade_dates: list[int], train_days: int, test_days: int, step_days: int) -> list[WalkforwardWindow]:\n    windows: list[WalkforwardWindow] = []\n    if len(trade_dates) < train_days + test_days:\n        return windows\n    idx = 0\n    window_id = 1\n    while idx + train_days + test_days <= len(trade_dates):\n        train_slice = trade_dates[idx : idx + train_days]\n        test_slice = trade_dates[idx + train_days : idx + train_days + test_days]\n        windows.append(\n            WalkforwardWindow(\n                window_id=window_id,\n                train_start=int(train_slice[0]),\n                train_end=int(train_slice[-1]),\n                test_start=int(test_slice[0]),\n                test_end=int(test_slice[-1]),\n                train_days=int(len(train_slice)),\n                test_days=int(len(test_slice)),\n            )\n        )\n        window_id += 1\n        idx += step_days\n    return windows\n\n\ndef summarize(frame: pd.DataFrame) -> dict[str, Any]:\n    completed = frame.dropna(subset=['future_return_pct']).copy()\n    count = int(len(frame))\n    completed_count = int(len(completed))\n    avg_ret = round(float(completed['future_return_pct'].mean()), 4) if completed_count else None\n    med_ret = round(float(completed['future_return_pct'].median()), 4) if completed_count else None\n    win_rate = round(float((completed['future_return_pct'] > 0).mean() * 100.0), 2) if completed_count else None\n    return {\n        'count': count,\n        'completed_count': completed_count,\n        'avg_future_return_pct': avg_ret,\n        'median_future_return_pct': med_ret,\n        'win_rate_pct': win_rate,\n    }\n\n\ndef normalize_detail(detail: pd.DataFrame) -> pd.DataFrame:\n    detail = detail.copy()\n    detail.columns = [str(c).lstrip('\\ufeff') for c in detail.columns]\n    detail['date_key'] = pd.to_numeric(detail['date_key'], errors='coerce').fillna(0).astype(int)\n    detail['future_return_pct'] = pd.to_numeric(detail['future_return_pct'], errors='coerce')\n    detail['sentiment_score'] = pd.to_numeric(detail['sentiment_score'], errors='coerce')\n    detail['risk_approved'] = detail['risk_approved'].astype(str).str.lower().eq('true')\n    detail['ai_decision_norm'] = detail['ai_decision'].astype(str).str.lower().str.strip()\n    detail['trend_prediction_norm'] = detail['trend_prediction'].astype(str).str.strip()\n    detail['price_action_state_code_norm'] = detail['price_action_state_code'].astype(str).str.strip().str.upper()\n    return detail\n\n\ndef enrich_fast_percentile(detail: pd.DataFrame, panel: pd.DataFrame) -> pd.DataFrame:\n    panel = panel.copy()\n    panel.columns = [str(c).lstrip('\\ufeff') for c in panel.columns]\n    panel['trade_date'] = pd.to_numeric(panel['trade_date'], errors='coerce').fillna(0).astype(int)\n    panel = panel.sort_values('trade_date').reset_index(drop=True)\n    panel['fast_raw_score'] = panel[FAST_Z_COLS].apply(pd.to_numeric, errors='coerce').mean(axis=1, skipna=True)\n    panel['fast_pct_60'] = rolling_percentile(panel['fast_raw_score'], 60)\n    merged = detail.merge(panel[['trade_date', 'fast_pct_60']], left_on='date_key', right_on='trade_date', how='left')\n    if 'trade_date_y' in merged.columns:\n        merged = merged.drop(columns=['trade_date_y'])\n    return merged\n\n\ndef candidate_mask(frame: pd.DataFrame, hot_cut: float, score_max: float) -> pd.Series:\n    return (\n        frame['risk_approved']\n        & (pd.to_numeric(frame['fast_pct_60'], errors='coerce') >= float(hot_cut))\n        & (pd.to_numeric(frame['sentiment_score'], errors='coerce') <= float(score_max))\n        & frame['price_action_state_code_norm'].eq('S5')\n        & frame['ai_decision_norm'].isin(['reduce', 'block'])\n        & frame['trend_prediction_norm'].isin(['看空', '强烈看空'])\n    )\n\n\ndef evaluate_candidate(frame: pd.DataFrame, name: str, hot_cut: float, score_max: float) -> dict[str, Any]:\n    mask = candidate_mask(frame, hot_cut=hot_cut, score_max=score_max)\n    sample = frame[mask].copy()\n    baseline_pool = frame[frame['risk_approved']].copy()\n    days = sorted(int(x) for x in sample['date_key'].dropna().unique().tolist() if int(x) > 0)\n    same_day = baseline_pool[baseline_pool['date_key'].isin(days)].copy() if days else baseline_pool.iloc[0:0].copy()\n    s = summarize(sample)\n    b = summarize(same_day)\n    avoid_edge = None\n    if s['avg_future_return_pct'] is not None and b['avg_future_return_pct'] is not None:\n        avoid_edge = round(float(b['avg_future_return_pct']) - float(s['avg_future_return_pct']), 4)\n    out = {\n        'candidate': name,\n        'hot_cut': hot_cut,\n        'score_max': score_max,\n        'trade_day_count': int(len(days)),\n        **s,\n        'same_day_baseline_count': int(b['count']),\n        'same_day_baseline_avg_future_return_pct': b['avg_future_return_pct'],\n        'avoid_loss_edge_vs_same_day_baseline_pct': avoid_edge,\n    }\n    return out\n\n\ndef pick_preferred(metrics: list[dict[str, Any]]) -> dict[str, Any]:\n    ranked = sorted(\n        metrics,\n        key=lambda x: (\n            -9999.0 if x.get('avoid_loss_edge_vs_same_day_baseline_pct') is None else -float(x['avoid_loss_edge_vs_same_day_baseline_pct']),\n            -int(x.get('count', 0)),\n            int(x.get('hot_cut', 0)),\n        ),\n    )\n    return ranked[0]\n\n\ndef evaluate_frame(frame: pd.DataFrame) -> dict[str, Any]:\n    metrics = [\n        evaluate_candidate(frame, name='candidate_A', hot_cut=85, score_max=50),\n        evaluate_candidate(frame, name='candidate_B', hot_cut=90, score_max=40),\n    ]\n    preferred = pick_preferred(metrics)\n    return {\n        'metrics': metrics,\n        'preferred_candidate': preferred.get('candidate'),\n        'preferred_hot_cut': preferred.get('hot_cut'),\n        'preferred_score_max': preferred.get('score_max'),\n        'preferred_avoid_loss_edge_vs_same_day_baseline_pct': preferred.get('avoid_loss_edge_vs_same_day_baseline_pct'),\n        'preferred_count': preferred.get('count'),\n    }\n\n\ndef evaluate_holdout(detail: pd.DataFrame, split: HoldoutSplit) -> tuple[pd.DataFrame, dict[str, Any]]:\n    train_mask = (detail['date_key'] >= split.train_start) & (detail['date_key'] <= split.train_end)\n    validation_mask = (detail['date_key'] >= split.validation_start) & (detail['date_key'] <= split.validation_end)\n    train_eval = evaluate_frame(detail[train_mask].copy())\n    val_metrics = evaluate_frame(detail[validation_mask].copy())['metrics']\n    rows: list[dict[str, Any]] = []\n    preferred_candidate = train_eval['preferred_candidate']\n    validation_preferred: dict[str, Any] | None = None\n    for row in val_metrics:\n        item = dict(row)\n        item['is_preferred_from_train'] = bool(row['candidate'] == preferred_candidate)\n        rows.append(item)\n        if item['is_preferred_from_train']:\n            validation_preferred = item\n    if validation_preferred is None:\n        validation_preferred = rows[0] if rows else None\n    summary = {\n        'train_preferred_candidate': preferred_candidate,\n        'train_preferred_edge_pct': train_eval.get('preferred_avoid_loss_edge_vs_same_day_baseline_pct'),\n        'validation_preferred_candidate': validation_preferred.get('candidate') if validation_preferred else None,\n        'validation_preferred_edge_pct': validation_preferred.get('avoid_loss_edge_vs_same_day_baseline_pct') if validation_preferred else None,\n        'validation_preferred_count': validation_preferred.get('count') if validation_preferred else None,\n        'validation_preferred_avg_future_return_pct': validation_preferred.get('avg_future_return_pct') if validation_preferred else None,\n    }\n    return pd.DataFrame(rows), summary\n\n\ndef evaluate_windows(detail: pd.DataFrame, windows: list[WalkforwardWindow]) -> tuple[pd.DataFrame, pd.DataFrame, dict[str, Any]]:\n    rows: list[dict[str, Any]] = []\n    selected_rows: list[dict[str, Any]] = []\n    for window in windows:\n        train_mask = (detail['date_key'] >= window.train_start) & (detail['date_key'] <= window.train_end)\n        test_mask = (detail['date_key'] >= window.test_start) & (detail['date_key'] <= window.test_end)\n        train_eval = evaluate_frame(detail[train_mask].copy())\n        test_eval = evaluate_frame(detail[test_mask].copy())\n        preferred_candidate = train_eval['preferred_candidate']\n        for row in test_eval['metrics']:\n            item = dict(row)\n            item.update(asdict(window))\n            item['train_selected_candidate'] = preferred_candidate\n            item['is_train_selected'] = bool(item['candidate'] == preferred_candidate)\n            rows.append(item)\n            if item['is_train_selected']:\n                selected_rows.append(item)\n\n    metrics_df = pd.DataFrame(rows)\n    selected_df = pd.DataFrame(selected_rows)\n    if metrics_df.empty:\n        summary_df = pd.DataFrame(columns=['candidate'])\n        summary = {\n            'window_count': 0,\n            'selected_positive_edge_windows': 0,\n            'selected_negative_edge_windows': 0,\n            'selected_mean_edge_pct': None,\n            'selected_worst_edge_pct': None,\n            'selected_beats_baseline_majority': False,\n        }\n        return metrics_df, summary_df, summary\n\n    summary_df = (\n        metrics_df.groupby('candidate', as_index=False)\n        .agg(\n            window_count=('window_id', 'count'),\n            total_count=('count', 'sum'),\n            mean_count=('count', 'mean'),\n            mean_test_edge_pct=('avoid_loss_edge_vs_same_day_baseline_pct', 'mean'),\n            median_test_edge_pct=('avoid_loss_edge_vs_same_day_baseline_pct', 'median'),\n            worst_test_edge_pct=('avoid_loss_edge_vs_same_day_baseline_pct', 'min'),\n            positive_edge_windows=('avoid_loss_edge_vs_same_day_baseline_pct', lambda s: int((pd.to_numeric(s, errors='coerce') > 0).sum())),\n        )\n        .sort_values(['mean_test_edge_pct', 'total_count'], ascending=[False, False])\n        .reset_index(drop=True)\n    )\n\n    positive_selected = int((pd.to_numeric(selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce') > 0).sum()) if not selected_df.empty else 0\n    negative_selected = int((pd.to_numeric(selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce') <= 0).sum()) if not selected_df.empty else 0\n    selected_mean_edge = round(float(pd.to_numeric(selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce').mean()), 4) if not selected_df.empty else None\n    selected_worst_edge = round(float(pd.to_numeric(selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce').min()), 4) if not selected_df.empty else None\n    majority_threshold = math.ceil(max(len(windows), 1) / 2)\n    summary = {\n        'window_count': int(len(windows)),\n        'selected_positive_edge_windows': positive_selected,\n        'selected_negative_edge_windows': negative_selected,\n        'selected_mean_edge_pct': selected_mean_edge,\n        'selected_worst_edge_pct': selected_worst_edge,\n        'selected_beats_baseline_majority': bool(positive_selected >= majority_threshold),\n        'majority_threshold': int(majority_threshold),\n    }\n    return metrics_df, summary_df, summary\n\n\ndef render_markdown(path: Path, payload: dict[str, Any]) -> None:\n    holdout = payload.get('holdout_summary', {}) or {}\n    rolling = payload.get('rolling_summary', {}) or {}\n    candidate_summary = payload.get('rolling_candidate_summary', []) or []\n    lines = [\n        '# A股情绪验证链第八轮：规则二样本外验证',\n        '',\n        f\"生成时间：{payload.get('generated_at')}（Asia/Shanghai）\",\n        '',\n        '## 一、本轮验证对象',\n        '',\n        '- 候选 A：`hot>=85 & score<=50 & S5 & reduce/block & 看空/强烈看空`',\n        '- 候选 B：`hot>=90 & score<=40 & S5 & reduce/block & 看空/强烈看空`',\n        '',\n        '## 二、输入口径',\n        '',\n        f\"- 明细：`{payload.get('detail_csv')}`\",\n        f\"- 面板：`{payload.get('panel_csv')}`\",\n        f\"- 交易日数：`{payload.get('trade_day_count')}`\",\n        f\"- 固定切分：训练 `70%` / 验证 `30%`（实际 `{payload.get('holdout_split', {}).get('train_days', 0)}` / `{payload.get('holdout_split', {}).get('validation_days', 0)}` 交易日）\",\n        f\"- 滚动窗口：train=`{payload.get('window_config', {}).get('train_days')}` / test=`{payload.get('window_config', {}).get('test_days')}` / step=`{payload.get('window_config', {}).get('step_days')}`\",\n        '',\n        '## 三、固定切分结果',\n        '',\n        f\"- 训练期优选候选：`{holdout.get('train_preferred_candidate', 'N/A')}`\",\n        f\"- 训练期优选 edge：`{holdout.get('train_preferred_edge_pct', 'N/A')}`\",\n        f\"- 验证期优选候选：`{holdout.get('validation_preferred_candidate', 'N/A')}`\",\n        f\"- 验证期优选 edge：`{holdout.get('validation_preferred_edge_pct', 'N/A')}`\",\n        f\"- 验证期优选样本数：`{holdout.get('validation_preferred_count', 'N/A')}`\",\n        f\"- 验证期优选平均未来收益：`{holdout.get('validation_preferred_avg_future_return_pct', 'N/A')}`\",\n        '',\n        '## 四、滚动前推结果',\n        '',\n        f\"- 窗口数：`{rolling.get('window_count', 0)}`\",\n        f\"- 训练优选在测试期跑赢基线窗口数：`{rolling.get('selected_positive_edge_windows', 0)}` / `{rolling.get('window_count', 0)}`\",\n        f\"- 训练优选在测试期平均 edge：`{rolling.get('selected_mean_edge_pct', 'N/A')}`\",\n        f\"- 训练优选在测试期最差 edge：`{rolling.get('selected_worst_edge_pct', 'N/A')}`\",\n        f\"- 是否多数窗口跑赢基线：`{rolling.get('selected_beats_baseline_majority', False)}`\",\n        '',\n        '## 五、候选汇总',\n        '',\n        '| 候选 | 窗口数 | 总样本数 | 平均每窗样本 | 平均测试 edge | 最差测试 edge | 正 edge 窗口数 |',\n        '| --- | ---: | ---: | ---: | ---: | ---: | ---: |',\n    ]\n    for row in candidate_summary:\n        lines.append(\n            '| {candidate} | {window_count} | {total_count} | {mean_count:.2f} | {mean_test_edge_pct} | {worst_test_edge_pct} | {positive_edge_windows} |'.format(\n                candidate=row.get('candidate'),\n                window_count=int(row.get('window_count', 0) or 0),\n                total_count=int(row.get('total_count', 0) or 0),\n                mean_count=float(row.get('mean_count', 0.0) or 0.0),\n                mean_test_edge_pct=row.get('mean_test_edge_pct'),\n                worst_test_edge_pct=row.get('worst_test_edge_pct'),\n                positive_edge_windows=int(row.get('positive_edge_windows', 0) or 0),\n            )\n        )\n    lines.extend([\n        '',\n        '## 六、本轮结论',\n        '',\n        f\"- 推荐动作：`{payload.get('conclusion', {}).get('recommended_action', '')}`\",\n        f\"- 样本外是否通过：`{payload.get('conclusion', {}).get('oos_pass', False)}`\",\n        f\"- 是否进入正式门禁候选：`{payload.get('conclusion', {}).get('ready_for_formal_gate_candidate', False)}`\",\n        '',\n        '## 一句话结论',\n        '',\n        payload.get('conclusion', {}).get('summary_cn', ''),\n    ])\n    path.write_text('\\n'.join(lines), encoding='utf-8')\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description='规则二样本外验证：固定切分 + 滚动前推')\n    parser.add_argument('--detail-csv', default=str(DEFAULT_DETAIL_CSV))\n    parser.add_argument('--panel-csv', default=str(DEFAULT_PANEL_CSV))\n    parser.add_argument('--holdout-train-ratio', type=float, default=0.7)\n    parser.add_argument('--holdout-min-test-days', type=int, default=42)\n    parser.add_argument('--train-days', type=int, default=168)\n    parser.add_argument('--test-days', type=int, default=42)\n    parser.add_argument('--step-days', type=int, default=21)\n    parser.add_argument('--date-tag', default=datetime.now().strftime('%Y%m%d'))\n    parser.add_argument('--output-window-csv', default='')\n    parser.add_argument('--output-holdout-csv', default='')\n    parser.add_argument('--output-json', default='')\n    parser.add_argument('--output-md', default='')\n    args = parser.parse_args()\n\n    detail = normalize_detail(pd.read_csv(Path(args.detail_csv).expanduser().resolve()))\n    panel = pd.read_csv(Path(args.panel_csv).expanduser().resolve())\n    detail = enrich_fast_percentile(detail, panel)\n\n    trade_dates = sorted(int(x) for x in detail['date_key'].dropna().unique().tolist() if int(x) > 0)\n    if not trade_dates:\n        raise ValueError('detail frame 不包含有效交易日')\n\n    holdout_split = build_holdout_split(\n        trade_dates,\n        train_ratio=float(args.holdout_train_ratio),\n        min_test_days=int(args.holdout_min_test_days),\n    )\n    windows = build_walkforward_windows(\n        trade_dates,\n        train_days=int(args.train_days),\n        test_days=int(args.test_days),\n        step_days=int(args.step_days),\n    )\n\n    holdout_df, holdout_summary = evaluate_holdout(detail, holdout_split)\n    window_df, candidate_summary_df, rolling_summary = evaluate_windows(detail, windows)\n\n    candidate_summary_records = candidate_summary_df.where(pd.notna(candidate_summary_df), None).to_dict(orient='records')\n    window_records = window_df.where(pd.notna(window_df), None).to_dict(orient='records')\n    holdout_records = holdout_df.where(pd.notna(holdout_df), None).to_dict(orient='records')\n\n    oos_pass = bool(\n        (holdout_summary.get('validation_preferred_edge_pct') is not None)\n        and float(holdout_summary.get('validation_preferred_edge_pct')) > 0\n        and bool(rolling_summary.get('selected_beats_baseline_majority'))\n        and (rolling_summary.get('selected_mean_edge_pct') is not None)\n        and float(rolling_summary.get('selected_mean_edge_pct')) > 0\n    )\n    ready_for_formal_gate_candidate = bool(\n        oos_pass\n        and (rolling_summary.get('selected_worst_edge_pct') is not None)\n        and float(rolling_summary.get('selected_worst_edge_pct')) > -1.5\n    )\n    if ready_for_formal_gate_candidate:\n        recommended_action = 'continue_shadow_run_then_prepare_formal_gate_candidate'\n        summary_cn = '规则二首轮样本外验证为正，当前更适合进入影子运行并准备正式门禁候选。'\n    elif oos_pass:\n        recommended_action = 'keep_as_shadow_candidate_and_expand_observation'\n        summary_cn = '规则二首轮样本外验证基本为正，但最差窗口仍需继续观察，暂保留为影子候选。'\n    else:\n        recommended_action = 'stay_in_research_only_and_do_not_formalize_yet'\n        summary_cn = '规则二首轮样本外验证未形成足够稳健优势，当前仍应停留在研究/影子层，不进入正式门禁。'\n\n    outputs = {\n        'window_csv': Path(args.output_window_csv) if args.output_window_csv else REPORT_DIR / f'sentiment_rule2_walkforward_window_metrics_{args.date_tag}.csv',\n        'holdout_csv': Path(args.output_holdout_csv) if args.output_holdout_csv else REPORT_DIR / f'sentiment_rule2_walkforward_holdout_{args.date_tag}.csv',\n        'json': Path(args.output_json) if args.output_json else REPORT_DIR / f'sentiment_rule2_walkforward_{args.date_tag}.json',\n        'md': Path(args.output_md) if args.output_md else REPORT_DIR / f'A股情绪验证链第八轮_规则二样本外验证_{args.date_tag}.md',\n    }\n    for path in outputs.values():\n        path.parent.mkdir(parents=True, exist_ok=True)\n\n    window_df.to_csv(outputs['window_csv'], index=False, encoding='utf-8-sig')\n    holdout_df.to_csv(outputs['holdout_csv'], index=False, encoding='utf-8-sig')\n\n    payload = {\n        'generated_at': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n        'detail_csv': str(Path(args.detail_csv).expanduser().resolve()),\n        'panel_csv': str(Path(args.panel_csv).expanduser().resolve()),\n        'trade_day_count': int(len(trade_dates)),\n        'holdout_split': asdict(holdout_split),\n        'window_config': {\n            'train_days': int(args.train_days),\n            'test_days': int(args.test_days),\n            'step_days': int(args.step_days),\n        },\n        'window_count': int(len(windows)),\n        'holdout_summary': holdout_summary,\n        'holdout_rows': holdout_records,\n        'rolling_summary': rolling_summary,\n        'rolling_candidate_summary': candidate_summary_records,\n        'window_selection_preview': window_records[:20],\n        'files': {key: str(path) for key, path in outputs.items()},\n        'conclusion': {\n            'oos_pass': bool(oos_pass),\n            'ready_for_formal_gate_candidate': bool(ready_for_formal_gate_candidate),\n            'recommended_action': recommended_action,\n            'summary_cn': summary_cn,\n        },\n    }\n    outputs['json'].write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding='utf-8')\n    render_markdown(outputs['md'], payload)\n    print(json.dumps(payload, ensure_ascii=False, indent=2))\n\n\nif __name__ == '__main__':\n    main()\n"},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_sentiment_rule2_walkforward_validation.py\",\"content\":\"#!/usr/bin/env python3\\nfrom __future__ import annotations\\n\\nimport argparse\\nimport json\\nimport math\\nfrom dataclasses import asdict, dataclass\\nfrom datetime import datetime\\nfrom pathlib import Path\\nfrom typing import Any\\n\\nimport pandas as pd\\n\\nWORKSPACE = Path('/Users/ling/.openclaw/workspace')\\nREPORT_DIR = WORKSPACE / 'research' / 'reports'\\nDEFAULT_DETAIL_CSV = REPORT_DIR / 'sentiment_gate_shadow_validation_detail_20260327_window_ext.csv'\\nDEFAULT_PANEL_CSV = REPORT_DIR / 'docx14_sentiment_factor_panel_20260327_window_ext.csv'\\n\\nFAST_Z_COLS = [\\n    'ashare_trading_volume_z60',\\n    'ashare_turnover_rate_z60',\\n    'limit_up_stock_count_z60',\\n    'northbound_trading_total_z60',\\n    'rsi_index_z60',\\n]\\n\\n\\n@dataclass\\nclass HoldoutSplit:\\n    train_start: int\\n    train_end: int\\n    validation_start: int\\n    validation_end: int\\n    train_days: int\\n    validation_days: int\\n\\n\\n@dataclass\\nclass WalkforwardWindow:\\n    window_id: int\\n    train_start: int\\n    train_end: int\\n    test_start: int\\n    test_end: int\\n    train_days: int\\n    test_days: int\\n\\n\\ndef rolling_percentile(series: pd.Series, window: int = 60) -> pd.Series:\\n    values = pd.to_numeric(series, errors='coerce')\\n    out: list[float | None] = []\\n    for idx in range(len(values)):\\n        start = max(0, idx - window + 1)\\n        hist = values.iloc[start : idx + 1].dropna()\\n        cur = values.iloc[idx]\\n        if hist.empty or pd.isna(cur):\\n            out.append(None)\\n            continue\\n        out.append(round(float((hist <= cur).mean() * 100.0), 4))\\n    return pd.Series(out, index=series.index, dtype='float64')\\n\\n\\ndef build_holdout_split(trade_dates: list[int], train_ratio: float, min_test_days: int) -> HoldoutSplit:\\n    total = len(trade_dates)\\n    if total < 2:\\n        raise ValueError('交易日不足，无法做样本外切分')\\n    validation_days = max(int(round(total * (1.0 - train_ratio))), int(min_test_days))\\n    validation_days = min(validation_days, total - 1)\\n    train_days = total - validation_days\\n    if train_days <= 0:\\n        raise ValueError('训练窗口为空，无法做样本外切分')\\n    return HoldoutSplit(\\n        train_start=int(trade_dates[0]),\\n        train_end=int(trade_dates[train_days - 1]),\\n        validation_start=int(trade_dates[train_days]),\\n        validation_end=int(trade_dates[-1]),\\n        train_days=int(train_days),\\n        validation_days=int(validation_days),\\n    )\\n\\n\\ndef build_walkforward_windows(trade_dates: list[int], train_days: int, test_days: int, step_days: int) -> list[WalkforwardWindow]:\\n    windows: list[WalkforwardWindow] = []\\n    if len(trade_dates) < train_days + test_days:\\n        return windows\\n    idx = 0\\n    window_id = 1\\n    while idx + train_days + test_days <= len(trade_dates):\\n        train_slice = trade_dates[idx : idx + train_days]\\n        test_slice = trade_dates[idx + train_days : idx + train_days + test_days]\\n        windows.append(\\n            WalkforwardWindow(\\n                window_id=window_id,\\n                train_start=int(train_slice[0]),\\n                train_end=int(train_slice[-1]),\\n                test_start=int(test_slice[0]),\\n                test_end=int(test_slice[-1]),\\n                train_days=int(len(train_slice)),\\n                test_days=int(len(test_slice)),\\n            )\\n        )\\n        window_id += 1\\n        idx += step_days\\n    return windows\\n\\n\\ndef summarize(frame: pd.DataFrame) -> dict[str, Any]:\\n    completed = frame.dropna(subset=['future_return_pct']).copy()\\n    count = int(len(frame))\\n    completed_count = int(len(completed))\\n    avg_ret = round(float(completed['future_return_pct'].mean()), 4) if completed_count else None\\n    med_ret = round(float(completed['future_return_pct'].median()), 4) if completed_count else None\\n    win_rate = round(float((completed['future_return_pct'] > 0).mean() * 100.0), 2) if completed_count else None\\n    return {\\n        'count': count,\\n        'completed_count': completed_count,\\n        'avg_future_return_pct': avg_ret,\\n        'median_future_return_pct': med_ret,\\n        'win_rate_pct': win_rate,\\n    }\\n\\n\\ndef normalize_detail(detail: pd.DataFrame) -> pd.DataFrame:\\n    detail = detail.copy()\\n    detail.columns = [str(c).lstrip('\\\\ufeff') for c in detail.columns]\\n    detail['date_key'] = pd.to_numeric(detail['date_key'], errors='coerce').fillna(0).astype(int)\\n    detail['future_return_pct'] = pd.to_numeric(detail['future_return_pct'], errors='coerce')\\n    detail['sentiment_score'] = pd.to_numeric(detail['sentiment_score'], errors='coerce')\\n    detail['risk_approved'] = detail['risk_approved'].astype(str).str.lower().eq('true')\\n    detail['ai_decision_norm'] = detail['ai_decision'].astype(str).str.lower().str.strip()\\n    detail['trend_prediction_norm'] = detail['trend_prediction'].astype(str).str.strip()\\n    detail['price_action_state_code_norm'] = detail['price_action_state_code'].astype(str).str.strip().str.upper()\\n    return detail\\n\\n\\ndef enrich_fast_percentile(detail: pd.DataFrame, panel: pd.DataFrame) -> pd.DataFrame:\\n    panel = panel.copy()\\n    panel.columns = [str(c).lstrip('\\\\ufeff') for c in panel.columns]\\n    panel['trade_date'] = pd.to_numeric(panel['trade_date'], errors='coerce').fillna(0).astype(int)\\n    panel = panel.sort_values('trade_date').reset_index(drop=True)\\n    panel['fast_raw_score'] = panel[FAST_Z_COLS].apply(pd.to_numeric, errors='coerce').mean(axis=1, skipna=True)\\n    panel['fast_pct_60'] = rolling_percentile(panel['fast_raw_score'], 60)\\n    merged = detail.merge(panel[['trade_date', 'fast_pct_60']], left_on='date_key', right_on='trade_date', how='left')\\n    if 'trade_date_y' in merged.columns:\\n        merged = merged.drop(columns=['trade_date_y'])\\n    return merged\\n\\n\\ndef candidate_mask(frame: pd.DataFrame, hot_cut: float, score_max: float) -> pd.Series:\\n    return (\\n        frame['risk_approved']\\n        & (pd.to_numeric(frame['fast_pct_60'], errors='coerce') >= float(hot_cut))\\n        & (pd.to_numeric(frame['sentiment_score'], errors='coerce') <= float(score_max))\\n        & frame['price_action_state_code_norm'].eq('S5')\\n        & frame['ai_decision_norm'].isin(['reduce', 'block'])\\n        & frame['trend_prediction_norm'].isin(['看空', '强烈看空'])\\n    )\\n\\n\\ndef evaluate_candidate(frame: pd.DataFrame, name: str, hot_cut: float, score_max: float) -> dict[str, Any]:\\n    mask = candidate_mask(frame, hot_cut=hot_cut, score_max=score_max)\\n    sample = frame[mask].copy()\\n    baseline_pool = frame[frame['risk_approved']].copy()\\n    days = sorted(int(x) for x in sample['date_key'].dropna().unique().tolist() if int(x) > 0)\\n    same_day = baseline_pool[baseline_pool['date_key'].isin(days)].copy() if days else baseline_pool.iloc[0:0].copy()\\n    s = summarize(sample)\\n    b = summarize(same_day)\\n    avoid_edge = None\\n    if s['avg_future_return_pct'] is not None and b['avg_future_return_pct'] is not None:\\n        avoid_edge = round(float(b['avg_future_return_pct']) - float(s['avg_future_return_pct']), 4)\\n    out = {\\n        'candidate': name,\\n        'hot_cut': hot_cut,\\n        'score_max': score_max,\\n        'trade_day_count': int(len(days)),\\n        **s,\\n        'same_day_baseline_count': int(b['count']),\\n        'same_day_baseline_avg_future_return_pct': b['avg_future_return_pct'],\\n        'avoid_loss_edge_vs_same_day_baseline_pct': avoid_edge,\\n    }\\n    return out\\n\\n\\ndef pick_preferred(metrics: list[dict[str, Any]]) -> dict[str, Any]:\\n    ranked = sorted(\\n        metrics,\\n        key=lambda x: (\\n            -9999.0 if x.get('avoid_loss_edge_vs_same_day_baseline_pct') is None else -float(x['avoid_loss_edge_vs_same_day_baseline_pct']),\\n            -int(x.get('count', 0)),\\n            int(x.get('hot_cut', 0)),\\n        ),\\n    )\\n    return ranked[0]\\n\\n\\ndef evaluate_frame(frame: pd.DataFrame) -> dict[str, Any]:\\n    metrics = [\\n        evaluate_candidate(frame, name='candidate_A', hot_cut=85, score_max=50),\\n        evaluate_candidate(frame, name='candidate_B', hot_cut=90, score_max=40),\\n    ]\\n    preferred = pick_preferred(metrics)\\n    return {\\n        'metrics': metrics,\\n        'preferred_candidate': preferred.get('candidate'),\\n        'preferred_hot_cut': preferred.get('hot_cut'),\\n        'preferred_score_max': preferred.get('score_max'),\\n        'preferred_avoid_loss_edge_vs_same_day_baseline_pct': preferred.get('avoid_loss_edge_vs_same_day_baseline_pct'),\\n        'preferred_count': preferred.get('count'),\\n    }\\n\\n\\ndef evaluate_holdout(detail: pd.DataFrame, split: HoldoutSplit) -> tuple[pd.DataFrame, dict[str, Any]]:\\n    train_mask = (detail['date_key'] >= split.train_start) & (detail['date_key'] <= split.train_end)\\n    validation_mask = (detail['date_key'] >= split.validation_start) & (detail['date_key'] <= split.validation_end)\\n    train_eval = evaluate_frame(detail[train_mask].copy())\\n    val_metrics = evaluate_frame(detail[validation_mask].copy())['metrics']\\n    rows: list[dict[str, Any]] = []\\n    preferred_candidate = train_eval['preferred_candidate']\\n    validation_preferred: dict[str, Any] | None = None\\n    for row in val_metrics:\\n        item = dict(row)\\n        item['is_preferred_from_train'] = bool(row['candidate'] == preferred_candidate)\\n        rows.append(item)\\n        if item['is_preferred_from_train']:\\n            validation_preferred = item\\n    if validation_preferred is None:\\n        validation_preferred = rows[0] if rows else None\\n    summary = {\\n        'train_preferred_candidate': preferred_candidate,\\n        'train_preferred_edge_pct': train_eval.get('preferred_avoid_loss_edge_vs_same_day_baseline_pct'),\\n        'validation_preferred_candidate': validation_preferred.get('candidate') if validation_preferred else None,\\n        'validation_preferred_edge_pct': validation_preferred.get('avoid_loss_edge_vs_same_day_baseline_pct') if validation_preferred else None,\\n        'validation_preferred_count': validation_preferred.get('count') if validation_preferred else None,\\n        'validation_preferred_avg_future_return_pct': validation_preferred.get('avg_future_return_pct') if validation_preferred else None,\\n    }\\n    return pd.DataFrame(rows), summary\\n\\n\\ndef evaluate_windows(detail: pd.DataFrame, windows: list[WalkforwardWindow]) -> tuple[pd.DataFrame, pd.DataFrame, dict[str, Any]]:\\n    rows: list[dict[str, Any]] = []\\n    selected_rows: list[dict[str, Any]] = []\\n    for window in windows:\\n        train_mask = (detail['date_key'] >= window.train_start) & (detail['date_key'] <= window.train_end)\\n        test_mask = (detail['date_key'] >= window.test_start) & (detail['date_key'] <= window.test_end)\\n        train_eval = evaluate_frame(detail[train_mask].copy())\\n        test_eval = evaluate_frame(detail[test_mask].copy())\\n        preferred_candidate = train_eval['preferred_candidate']\\n        for row in test_eval['metrics']:\\n            item = dict(row)\\n            item.update(asdict(window))\\n            item['train_selected_candidate'] = preferred_candidate\\n            item['is_train_selected'] = bool(item['candidate'] == preferred_candidate)\\n            rows.append(item)\\n            if item['is_train_selected']:\\n                selected_rows.append(item)\\n\\n    metrics_df = pd.DataFrame(rows)\\n    selected_df = pd.DataFrame(selected_rows)\\n    if metrics_df.empty:\\n        summary_df = pd.DataFrame(columns=['candidate'])\\n        summary = {\\n            'window_count': 0,\\n            'selected_positive_edge_windows': 0,\\n            'selected_negative_edge_windows': 0,\\n            'selected_mean_edge_pct': None,\\n            'selected_worst_edge_pct': None,\\n            'selected_beats_baseline_majority': False,\\n        }\\n        return metrics_df, summary_df, summary\\n\\n    summary_df = (\\n        metrics_df.groupby('candidate', as_index=False)\\n        .agg(\\n            window_count=('window_id', 'count'),\\n            total_count=('count', 'sum'),\\n            mean_count=('count', 'mean'),\\n            mean_test_edge_pct=('avoid_loss_edge_vs_same_day_baseline_pct', 'mean'),\\n            median_test_edge_pct=('avoid_loss_edge_vs_same_day_baseline_pct', 'median'),\\n            worst_test_edge_pct=('avoid_loss_edge_vs_same_day_baseline_pct', 'min'),\\n            positive_edge_windows=('avoid_loss_edge_vs_same_day_baseline_pct', lambda s: int((pd.to_numeric(s, errors='coerce') > 0).sum())),\\n        )\\n        .sort_values(['mean_test_edge_pct', 'total_count'], ascending=[False, False])\\n        .reset_index(drop=True)\\n    )\\n\\n    positive_selected = int((pd.to_numeric(selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce') > 0).sum()) if not selected_df.empty else 0\\n    negative_selected = int((pd.to_numeric(selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce') <= 0).sum()) if not selected_df.empty else 0\\n    selected_mean_edge = round(float(pd.to_numeric(selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce').mean()), 4) if not selected_df.empty else None\\n    selected_worst_edge = round(float(pd.to_numeric(selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce').min()), 4) if not selected_df.empty else None\\n    majority_threshold = math.ceil(max(len(windows), 1) / 2)\\n    summary = {\\n        'window_count': int(len(windows)),\\n        'selected_positive_edge_windows': positive_selected,\\n        'selected_negative_edge_windows': negative_selected,\\n        'selected_mean_edge_pct': selected_mean_edge,\\n        'selected_worst_edge_pct': selected_worst_edge,\\n        'selected_beats_baseline_majority': bool(positive_selected >= majority_threshold),\\n        'majority_threshold': int(majority_threshold),\\n    }\\n    return metrics_df, summary_df, summary\\n\\n\\ndef render_markdown(path: Path, payload: dict[str, Any]) -> None:\\n    holdout = payload.get('holdout_summary', {}) or {}\\n    rolling = payload.get('rolling_summary', {}) or {}\\n    candidate_summary = payload.get('rolling_candidate_summary', []) or []\\n    lines = [\\n        '# A股情绪验证链第八轮：规则二样本外验证',\\n        '',\\n        f\\\"生成时间：{payload.get('generated_at')}（Asia/Shanghai）\\\",\\n        '',\\n        '## 一、本轮验证对象',\\n        '',\\n        '- 候选 A：`hot>=85 & score<=50 & S5 & reduce/block & 看空/强烈看空`',\\n        '- 候选 B：`hot>=90 & score<=40 & S5 & reduce/block & 看空/强烈看空`',\\n        '',\\n        '## 二、输入口径',\\n        '',\\n        f\\\"- 明细：`{payload.get('detail_csv')}`\\\",\\n        f\\\"- 面板：`{payload.get('panel_csv')}`\\\",\\n        f\\\"- 交易日数：`{payload.get('trade_day_count')}`\\\",\\n        f\\\"- 固定切分：训练 `70%` / 验证 `30%`（实际 `{payload.get('holdout_split', {}).get('train_days', 0)}` / `{payload.get('holdout_split', {}).get('validation_days', 0)}` 交易日）\\\",\\n        f\\\"- 滚动窗口：train=`{payload.get('window_config', {}).get('train_days')}` / test=`{payload.get('window_config', {}).get('test_days')}` / step=`{payload.get('window_config', {}).get('step_days')}`\\\",\\n        '',\\n        '## 三、固定切分结果',\\n        '',\\n        f\\\"- 训练期优选候选：`{holdout.get('train_preferred_candidate', 'N/A')}`\\\",\\n        f\\\"- 训练期优选 edge：`{holdout.get('train_preferred_edge_pct', 'N/A')}`\\\",\\n        f\\\"- 验证期优选候选：`{holdout.get('validation_preferred_candidate', 'N/A')}`\\\",\\n        f\\\"- 验证期优选 edge：`{holdout.get('validation_preferred_edge_pct', 'N/A')}`\\\",\\n        f\\\"- 验证期优选样本数：`{holdout.get('validation_preferred_count', 'N/A')}`\\\",\\n        f\\\"- 验证期优选平均未来收益：`{holdout.get('validation_preferred_avg_future_return_pct', 'N/A')}`\\\",\\n        '',\\n        '## 四、滚动前推结果',\\n        '',\\n        f\\\"- 窗口数：`{rolling.get('window_count', 0)}`\\\",\\n        f\\\"- 训练优选在测试期跑赢基线窗口数：`{rolling.get('selected_positive_edge_windows', 0)}` / `{rolling.get('window_count', 0)}`\\\",\\n        f\\\"- 训练优选在测试期平均 edge：`{rolling.get('selected_mean_edge_pct', 'N/A')}`\\\",\\n        f\\\"- 训练优选在测试期最差 edge：`{rolling.get('selected_worst_edge_pct', 'N/A')}`\\\",\\n        f\\\"- 是否多数窗口跑赢基线：`{rolling.get('selected_beats_baseline_majority', False)}`\\\",\\n        '',\\n        '## 五、候选汇总',\\n        '',\\n        '| 候选 | 窗口数 | 总样本数 | 平均每窗样本 | 平均测试 edge | 最差测试 edge | 正 edge 窗口数 |',\\n        '| --- | ---: | ---: | ---: | ---: | ---: | ---: |',\\n    ]\\n    for row in candidate_summary:\\n        lines.append(\\n            '| {candidate} | {window_count} | {total_count} | {mean_count:.2f} | {mean_test_edge_pct} | {worst_test_edge_pct} | {positive_edge_windows} |'.format(\\n                candidate=row.get('candidate'),\\n                window_count=int(row.get('window_count', 0) or 0),\\n                total_count=int(row.get('total_count', 0) or 0),\\n                mean_count=float(row.get('mean_count', 0.0) or 0.0),\\n                mean_test_edge_pct=row.get('mean_test_edge_pct'),\\n                worst_test_edge_pct=row.get('worst_test_edge_pct'),\\n                positive_edge_windows=int(row.get('positive_edge_windows', 0) or 0),\\n            )\\n        )\\n    lines.extend([\\n        '',\\n        '## 六、本轮结论',\\n        '',\\n        f\\\"- 推荐动作：`{payload.get('conclusion', {}).get('recommended_action', '')}`\\\",\\n        f\\\"- 样本外是否通过：`{payload.get('conclusion', {}).get('oos_pass', False)}`\\\",\\n        f\\\"- 是否进入正式门禁候选：`{payload.get('conclusion', {}).get('ready_for_formal_gate_candidate', False)}`\\\",\\n        '',\\n        '## 一句话结论',\\n        '',\\n        payload.get('conclusion', {}).get('summary_cn', ''),\\n    ])\\n    path.write_text('\\\\n'.join(lines), encoding='utf-8')\\n\\n\\ndef main() -> None:\\n    parser = argparse.ArgumentParser(description='规则二样本外验证：固定切分 + 滚动前推')\\n    parser.add_argument('--detail-csv', default=str(DEFAULT_DETAIL_CSV))\\n    parser.add_argument('--panel-csv', default=str(DEFAULT_PANEL_CSV))\\n    parser.add_argument('--holdout-train-ratio', type=float, default=0.7)\\n    parser.add_argument('--holdout-min-test-days', type=int, default=42)\\n    parser.add_argument('--train-days', type=int, default=168)\\n    parser.add_argument('--test-days', type=int, default=42)\\n    parser.add_argument('--step-days', type=int, default=21)\\n    parser.add_argument('--date-tag', default=datetime.now().strftime('%Y%m%d'))\\n    parser.add_argument('--output-window-csv', default='')\\n    parser.add_argument('--output-holdout-csv', default='')\\n    parser.add_argument('--output-json', default='')\\n    parser.add_argument('--output-md', default='')\\n    args = parser.parse_args()\\n\\n    detail = normalize_detail(pd.read_csv(Path(args.detail_csv).expanduser().resolve()))\\n    panel = pd.read_csv(Path(args.panel_csv).expanduser().resolve())\\n    detail = enrich_fast_percentile(detail, panel)\\n\\n    trade_dates = sorted(int(x) for x in detail['date_key'].dropna().unique().tolist() if int(x) > 0)\\n    if not trade_dates:\\n        raise ValueError('detail frame 不包含有效交易日')\\n\\n    holdout_split = build_holdout_split(\\n        trade_dates,\\n        train_ratio=float(args.holdout_train_ratio),\\n        min_test_days=int(args.holdout_min_test_days),\\n    )\\n    windows = build_walkforward_windows(\\n        trade_dates,\\n        train_days=int(args.train_days),\\n        test_days=int(args.test_days),\\n        step_days=int(args.step_days),\\n    )\\n\\n    holdout_df, holdout_summary = evaluate_holdout(detail, holdout_split)\\n    window_df, candidate_summary_df, rolling_summary = evaluate_windows(detail, windows)\\n\\n    candidate_summary_records = candidate_summary_df.where(pd.notna(candidate_summary_df), None).to_dict(orient='records')\\n    window_records = window_df.where(pd.notna(window_df), None).to_dict(orient='records')\\n    holdout_records = holdout_df.where(pd.notna(holdout_df), None).to_dict(orient='records')\\n\\n    oos_pass = bool(\\n        (holdout_summary.get('validation_preferred_edge_pct') is not None)\\n        and float(holdout_summary.get('validation_preferred_edge_pct')) > 0\\n        and bool(rolling_summary.get('selected_beats_baseline_majority'))\\n        and (rolling_summary.get('selected_mean_edge_pct') is not None)\\n        and float(rolling_summary.get('selected_mean_edge_pct')) > 0\\n    )\\n    ready_for_formal_gate_candidate = bool(\\n        oos_pass\\n        and (rolling_summary.get('selected_worst_edge_pct') is not None)\\n        and float(rolling_summary.get('selected_worst_edge_pct')) > -1.5\\n    )\\n    if ready_for_formal_gate_candidate:\\n        recommended_action = 'continue_shadow_run_then_prepare_formal_gate_candidate'\\n        summary_cn = '规则二首轮样本外验证为正，当前更适合进入影子运行并准备正式门禁候选。'\\n    elif oos_pass:\\n        recommended_action = 'keep_as_shadow_candidate_and_expand_observation'\\n        summary_cn = '规则二首轮样本外验证基本为正，但最差窗口仍需继续观察，暂保留为影子候选。'\\n    else:\\n        recommended_action = 'stay_in_research_only_and_do_not_formalize_yet'\\n        summary_cn = '规则二首轮样本外验证未形成足够稳健优势，当前仍应停留在研究/影子层，不进入正式门禁。'\\n\\n    outputs = {\\n        'window_csv': Path(args.output_window_csv) if args.output_window_csv else REPORT_DIR / f'sentiment_rule2_walkforward_window_metrics_{args.date_tag}.csv',\\n        'holdout_csv': Path(args.output_holdout_csv) if args.output_holdout_csv else REPORT_DIR / f'sentiment_rule2_walkforward_holdout_{args.date_tag}.csv',\\n        'json': Path(args.output_json) if args.output_json else REPORT_DIR / f'sentiment_rule2_walkforward_{args.date_tag}.json',\\n        'md': Path(args.output_md) if args.output_md else REPORT_DIR / f'A股情绪验证链第八轮_规则二样本外验证_{args.date_tag}.md',\\n    }\\n    for path in outputs.values():\\n        path.parent.mkdir(parents=True, exist_ok=True)\\n\\n    window_df.to_csv(outputs['window_csv'], index=False, encoding='utf-8-sig')\\n    holdout_df.to_csv(outputs['holdout_csv'], index=False, encoding='utf-8-sig')\\n\\n    payload = {\\n        'generated_at': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\\n        'detail_csv': str(Path(args.detail_csv).expanduser().resolve()),\\n        'panel_csv': str(Path(args.panel_csv).expanduser().resolve()),\\n        'trade_day_count': int(len(trade_dates)),\\n        'holdout_split': asdict(holdout_split),\\n        'window_config': {\\n            'train_days': int(args.train_days),\\n            'test_days': int(args.test_days),\\n            'step_days': int(args.step_days),\\n  