5ctxRDrHtWYViaLDfObf0Pxf6PYa1WzbbkUW60JQT3u7S7oJ7WjLO1IMu2lb_26k2BX0rXJefIpXafqobb1xZPwjA2hUlT92PEUVRPZN2hqybBstwfOyIv8llzxTLuPbX22R28NguR4seuzDWzQK52csawTlGpowsuqmPp-kH70UQp7djGOKhR89BU5F4AcW815Y_Azp8w8YGsNR20VZntCKfjtLzFLDhOjAkLmQzUlgbSbPBDI9eC7HO6GnW1FAPFSZA7sT8eQ-X6pe8PUADnEMh_ZgDRV6OBFR7yVYM9bFYuzymhFMXtUtNsYXRqhTwDwQcLJZTJ4c0-B9cePz_08PFZ_ZNHWexOlfHSwfAYp8N8csMio_4LD-RYKsds1hSNw3854bSf7ZlqPXX6W2zdIQYVl9KM5er5p1acWWadlLTJv7WPldtvZjcd9pp-zOAfu0YEtcDeAJImReCYSuKi56QBKA9HTYIpFAeGYov2H0te9pJ7Vkn6BTOF-XUtJE96Nv12kGL_pWqmOZgo-QFMRUlvGYO50Z3uVcV4oBYP5f-OTU0O-rLt6wbH36WpoH6p-_PLhGGtc6mcI3GSoXKshrH5E7h4PWk8vjDNuLCssSjLL2DLCo2Xe57LfWg3jGfNN0PDJ74x507cn5oXGHFao4-4PVak44PH9dKy8osVdYOa-FbLRMFnjoLpDMl6_BGyXJrw6IwyaoYG6sHcYjXeQWqSuwgP3mvW8Hmw==\",\"summary\":[{\"type\":\"summary_text\",\"text\":\"**Evaluating validation criteria**\\n\\nI’m looking at different components independently, like train edge, validation edge, counts, and rolling windows. I think I need to choose a recommended candidate based on certain criteria, such as validation edge being greater than zero and ensuring a sampled majority is true. I might also consider total counts and worst edges to find a good compromise. I’ll script this up to output in JSON, CSV, or Markdown format while also using imported functions.\"},{\"type\":\"summary_text\",\"text\":\"**Structuring evaluation script**\\n\\nI’m planning to write an elegant script that will assess different combinations effectively. I’ll evaluate candidates on both train and validation subsets, and for each window, I’ll check the test subset. It’s crucial to count the sampled windows where counts are above zero and note the positive counts, as well as the mean and worst across these windows. I’m considering ranking them based on criteria like positive validation edges and a minimum count of sampled windows to guide my decisions.\"},{\"type\":\"summary_text\",\"text\":\"**Running validation checks**\\n\\nI’m considering validation and using sampled_majority to help with decisions. If that doesn't yield results, I'll look for the best compromise, possibly going with something like A 83/50. I'm curious to see how it turns out after running the process. I might also compute strict viability flags to ensure thoroughness. It sounds like a solid plan to script and run the tests! Let's see what the results bring!\"}]}"},{"type":"text","text":"我不再泛化扩参，只做 A 周边 3×3 的局部扫描：`hot=83/85/87`，`score=45/50/55`。脚本直接复用现有样本外验证骨架。","textSignature":"{\"v\":1,\"id\":\"msg_0a18d76e314b89270169c66041f3b48198ada0eba19b4fba99\",\"phase\":\"commentary\"}"},{"type":"toolCall","id":"call_4VFXTLAsWn0N2d8euO344As3|fc_0a18d76e314b89270169c6604206d081988a1aba0bc833aa23","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_sentiment_rule2_candidate_a_local_scan.py","content":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nimport run_sentiment_rule2_walkforward_validation as base_mod\n\nWORKSPACE = Path('/Users/ling/.openclaw/workspace')\nREPORT_DIR = WORKSPACE / 'research' / 'reports'\n\n\ndef evaluate_single_combo(\n    detail: pd.DataFrame,\n    *,\n    hot_cut: float,\n    score_max: float,\n    holdout_split: base_mod.HoldoutSplit,\n    windows: list[base_mod.WalkforwardWindow],\n) -> dict[str, Any]:\n    train_mask = (detail['date_key'] >= holdout_split.train_start) & (detail['date_key'] <= holdout_split.train_end)\n    validation_mask = (detail['date_key'] >= holdout_split.validation_start) & (detail['date_key'] <= holdout_split.validation_end)\n\n    full_metrics = base_mod.evaluate_candidate(detail, name='candidate', hot_cut=hot_cut, score_max=score_max)\n    train_metrics = base_mod.evaluate_candidate(detail[train_mask].copy(), name='candidate', hot_cut=hot_cut, score_max=score_max)\n    validation_metrics = base_mod.evaluate_candidate(detail[validation_mask].copy(), name='candidate', hot_cut=hot_cut, score_max=score_max)\n\n    window_rows: list[dict[str, Any]] = []\n    for window in windows:\n        test_mask = (detail['date_key'] >= window.test_start) & (detail['date_key'] <= window.test_end)\n        test_metrics = base_mod.evaluate_candidate(detail[test_mask].copy(), name='candidate', hot_cut=hot_cut, score_max=score_max)\n        item = dict(test_metrics)\n        item.update({\n            'window_id': window.window_id,\n            'train_start': window.train_start,\n            'train_end': window.train_end,\n            'test_start': window.test_start,\n            'test_end': window.test_end,\n            'train_days': window.train_days,\n            'test_days': window.test_days,\n        })\n        window_rows.append(item)\n\n    window_df = pd.DataFrame(window_rows)\n    sampled_df = window_df[pd.to_numeric(window_df['count'], errors='coerce').fillna(0) > 0].copy() if not window_df.empty else window_df.copy()\n    positive_sampled = int((pd.to_numeric(sampled_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce') > 0).sum()) if not sampled_df.empty else 0\n    sampled_windows = int(len(sampled_df))\n    sampled_majority_threshold = max((sampled_windows + 1) // 2, 1)\n    mean_sampled_edge = round(float(pd.to_numeric(sampled_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce').mean()), 4) if not sampled_df.empty else None\n    worst_sampled_edge = round(float(pd.to_numeric(sampled_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce').min()), 4) if not sampled_df.empty else None\n\n    result = {\n        'hot_cut': float(hot_cut),\n        'score_max': float(score_max),\n        'full_count': int(full_metrics.get('count', 0) or 0),\n        'full_trade_day_count': int(full_metrics.get('trade_day_count', 0) or 0),\n        'full_avg_future_return_pct': full_metrics.get('avg_future_return_pct'),\n        'full_avoid_loss_edge_pct': full_metrics.get('avoid_loss_edge_vs_same_day_baseline_pct'),\n        'train_count': int(train_metrics.get('count', 0) or 0),\n        'train_edge_pct': train_metrics.get('avoid_loss_edge_vs_same_day_baseline_pct'),\n        'validation_count': int(validation_metrics.get('count', 0) or 0),\n        'validation_avg_future_return_pct': validation_metrics.get('avg_future_return_pct'),\n        'validation_edge_pct': validation_metrics.get('avoid_loss_edge_vs_same_day_baseline_pct'),\n        'sampled_window_count': sampled_windows,\n        'empty_window_count': int(len(window_df) - sampled_windows),\n        'positive_sampled_window_count': positive_sampled,\n        'sampled_majority_threshold': int(sampled_majority_threshold),\n        'sampled_majority_positive': bool(sampled_windows > 0 and positive_sampled >= sampled_majority_threshold),\n        'mean_sampled_edge_pct': mean_sampled_edge,\n        'worst_sampled_edge_pct': worst_sampled_edge,\n        'window_rows': window_df.where(pd.notna(window_df), None).to_dict(orient='records'),\n    }\n    result['shadow_ready'] = bool(\n        result['validation_edge_pct'] is not None\n        and float(result['validation_edge_pct']) > 0\n        and result['sampled_window_count'] >= 5\n        and result['sampled_majority_positive']\n        and result['mean_sampled_edge_pct'] is not None\n        and float(result['mean_sampled_edge_pct']) > 0\n    )\n    return result\n\n\ndef pick_recommended(rows: list[dict[str, Any]]) -> dict[str, Any]:\n    if not rows:\n        return {}\n\n    def sort_key(row: dict[str, Any]) -> tuple:\n        return (\n            int(bool(row.get('shadow_ready'))),\n            int(bool(row.get('sampled_majority_positive'))),\n            -9999.0 if row.get('validation_edge_pct') is None else float(row['validation_edge_pct']),\n            -9999.0 if row.get('mean_sampled_edge_pct') is None else float(row['mean_sampled_edge_pct']),\n            -9999.0 if row.get('worst_sampled_edge_pct') is None else float(row['worst_sampled_edge_pct']),\n            int(row.get('sampled_window_count', 0) or 0),\n            int(row.get('full_count', 0) or 0),\n        )\n\n    return sorted(rows, key=sort_key, reverse=True)[0]\n\n\ndef render_markdown(path: Path, payload: dict[str, Any]) -> None:\n    recommendation = payload.get('recommended_combo', {}) or {}\n    lines = [\n        '# A股情绪验证链第九轮：候选 A 邻域局部稳健性扫描',\n        '',\n        f\"生成时间：{payload.get('generated_at')}（Asia/Shanghai）\",\n        '',\n        '## 一、本轮扫描范围',\n        '',\n        f\"- hot_cut：`{', '.join(str(x) for x in payload.get('hot_list', []))}`\",\n        f\"- score_max：`{', '.join(str(x) for x in payload.get('score_list', []))}`\",\n        '- 固定条件：`S5 & reduce/block & 看空/强烈看空`',\n        '',\n        '## 二、推荐组合',\n        '',\n        f\"- 推荐 hot_cut：`{recommendation.get('hot_cut', 'N/A')}`\",\n        f\"- 推荐 score_max：`{recommendation.get('score_max', 'N/A')}`\",\n        f\"- 验证集 edge：`{recommendation.get('validation_edge_pct', 'N/A')}`\",\n        f\"- 有样本滚动窗口：`{recommendation.get('sampled_window_count', 'N/A')}`\",\n        f\"- 正 edge 窗口：`{recommendation.get('positive_sampled_window_count', 'N/A')}` / `{recommendation.get('sampled_window_count', 'N/A')}`\",\n        f\"- 平均滚动 edge：`{recommendation.get('mean_sampled_edge_pct', 'N/A')}`\",\n        f\"- 最差滚动 edge：`{recommendation.get('worst_sampled_edge_pct', 'N/A')}`\",\n        f\"- 是否达到影子候选门槛：`{recommendation.get('shadow_ready', False)}`\",\n        '',\n        '## 三、组合汇总',\n        '',\n        '| hot_cut | score_max | 验证集样本 | 验证集 edge | 有样本窗口 | 正 edge 窗口 | 平均滚动 edge | 最差滚动 edge | 影子候选 |',\n        '| ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: | --- |',\n    ]\n    for row in payload.get('summary_rows', []) or []:\n        lines.append(\n            '| {hot_cut} | {score_max} | {validation_count} | {validation_edge_pct} | {sampled_window_count} | {positive_sampled_window_count} | {mean_sampled_edge_pct} | {worst_sampled_edge_pct} | {shadow_ready} |'.format(\n                hot_cut=row.get('hot_cut'),\n                score_max=row.get('score_max'),\n                validation_count=row.get('validation_count'),\n                validation_edge_pct=row.get('validation_edge_pct'),\n                sampled_window_count=row.get('sampled_window_count'),\n                positive_sampled_window_count=row.get('positive_sampled_window_count'),\n                mean_sampled_edge_pct=row.get('mean_sampled_edge_pct'),\n                worst_sampled_edge_pct=row.get('worst_sampled_edge_pct'),\n                shadow_ready=row.get('shadow_ready'),\n            )\n        )\n    lines.extend([\n        '',\n        '## 四、影子运行建议',\n        '',\n        payload.get('conclusion', {}).get('shadow_plan_cn', ''),\n        '',\n        '## 一句话结论',\n        '',\n        payload.get('conclusion', {}).get('summary_cn', ''),\n    ])\n    path.write_text('\\n'.join(lines), encoding='utf-8')\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description='规则二候选A邻域局部稳健性扫描')\n    parser.add_argument('--detail-csv', default=str(base_mod.DEFAULT_DETAIL_CSV))\n    parser.add_argument('--panel-csv', default=str(base_mod.DEFAULT_PANEL_CSV))\n    parser.add_argument('--hot-list', default='83,85,87')\n    parser.add_argument('--score-list', default='45,50,55')\n    parser.add_argument('--holdout-train-ratio', type=float, default=0.7)\n    parser.add_argument('--holdout-min-test-days', type=int, default=42)\n    parser.add_argument('--train-days', type=int, default=168)\n    parser.add_argument('--test-days', type=int, default=42)\n    parser.add_argument('--step-days', type=int, default=21)\n    parser.add_argument('--date-tag', default=datetime.now().strftime('%Y%m%d'))\n    args = parser.parse_args()\n\n    hot_list = [float(x.strip()) for x in str(args.hot_list).split(',') if x.strip()]\n    score_list = [float(x.strip()) for x in str(args.score_list).split(',') if x.strip()]\n\n    detail = base_mod.normalize_detail(pd.read_csv(Path(args.detail_csv).expanduser().resolve()))\n    panel = pd.read_csv(Path(args.panel_csv).expanduser().resolve())\n    detail = base_mod.enrich_fast_percentile(detail, panel)\n\n    trade_dates = sorted(int(x) for x in detail['date_key'].dropna().unique().tolist() if int(x) > 0)\n    holdout_split = base_mod.build_holdout_split(\n        trade_dates,\n        train_ratio=float(args.holdout_train_ratio),\n        min_test_days=int(args.holdout_min_test_days),\n    )\n    windows = base_mod.build_walkforward_windows(\n        trade_dates,\n        train_days=int(args.train_days),\n        test_days=int(args.test_days),\n        step_days=int(args.step_days),\n    )\n\n    rows: list[dict[str, Any]] = []\n    window_rows: list[dict[str, Any]] = []\n    for hot_cut in hot_list:\n        for score_max in score_list:\n            item = evaluate_single_combo(\n                detail,\n                hot_cut=hot_cut,\n                score_max=score_max,\n                holdout_split=holdout_split,\n                windows=windows,\n            )\n            rows.append({k: v for k, v in item.items() if k != 'window_rows'})\n            for w in item['window_rows']:\n                ww = dict(w)\n                ww['hot_cut'] = hot_cut\n                ww['score_max'] = score_max\n                window_rows.append(ww)\n\n    summary_df = pd.DataFrame(rows).sort_values(\n        ['shadow_ready', 'sampled_majority_positive', 'validation_edge_pct', 'mean_sampled_edge_pct', 'sampled_window_count', 'full_count'],\n        ascending=[False, False, False, False, False, False],\n    ).reset_index(drop=True)\n    window_df = pd.DataFrame(window_rows)\n    recommended = pick_recommended(rows)\n\n    if recommended.get('shadow_ready'):\n        shadow_plan_cn = (\n            f\"建议以 hot>={int(recommended.get('hot_cut'))} / score<={int(recommended.get('score_max'))} 作为主影子候选，\"\n            '连续观察至少 20 个交易日或 20 次有效触发，再决定是否升格。'\n        )\n        summary_cn = '候选 A 邻域里已出现更适合影子运行的稳健组合，下一步应进入连续影子验证。'\n    else:\n        shadow_plan_cn = (\n            '当前扫描范围内仍未出现同时满足“验证集为正 + 有样本窗口多数为正 + 覆盖不太稀”的组合。'\n            '建议先以验证集更优的组合作为轻量影子参考，不进入硬门禁。'\n        )\n        summary_cn = '候选 A 邻域扫描后仍未出现足够稳健的正式候选，下一步应保持轻量影子观察而非正式接入。'\n\n    outputs = {\n        'summary_csv': REPORT_DIR / f'sentiment_rule2_candidate_a_local_scan_{args.date_tag}.csv',\n        'window_csv': REPORT_DIR / f'sentiment_rule2_candidate_a_local_scan_windows_{args.date_tag}.csv',\n        'json': REPORT_DIR / f'sentiment_rule2_candidate_a_local_scan_{args.date_tag}.json',\n        'md': REPORT_DIR / f'A股情绪验证链第九轮_候选A局部稳健性扫描_{args.date_tag}.md',\n    }\n    for path in outputs.values():\n        path.parent.mkdir(parents=True, exist_ok=True)\n\n    summary_df.to_csv(outputs['summary_csv'], index=False, encoding='utf-8-sig')\n    window_df.to_csv(outputs['window_csv'], index=False, encoding='utf-8-sig')\n\n    payload = {\n        'generated_at': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n        'detail_csv': str(Path(args.detail_csv).expanduser().resolve()),\n        'panel_csv': str(Path(args.panel_csv).expanduser().resolve()),\n        'trade_day_count': int(len(trade_dates)),\n        'holdout_split': base_mod.asdict(holdout_split),\n        'window_config': {\n            'train_days': int(args.train_days),\n            'test_days': int(args.test_days),\n            'step_days': int(args.step_days),\n            'window_count': int(len(windows)),\n        },\n        'hot_list': hot_list,\n        'score_list': score_list,\n        'recommended_combo': recommended,\n        'summary_rows': summary_df.where(pd.notna(summary_df), None).to_dict(orient='records'),\n        'files': {k: str(v) for k, v in outputs.items()},\n        'conclusion': {\n            'summary_cn': summary_cn,\n            'shadow_plan_cn': shadow_plan_cn,\n        },\n    }\n    outputs['json'].write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding='utf-8')\n    render_markdown(outputs['md'], payload)\n    print(json.dumps(payload, ensure_ascii=False, indent=2))\n\n\nif __name__ == '__main__':\n    main()\n"},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_sentiment_rule2_candidate_a_local_scan.py\",\"content\":\"#!/usr/bin/env python3\\nfrom __future__ import annotations\\n\\nimport argparse\\nimport json\\nfrom datetime import datetime\\nfrom pathlib import Path\\nfrom typing import Any\\n\\nimport pandas as pd\\n\\nimport run_sentiment_rule2_walkforward_validation as base_mod\\n\\nWORKSPACE = Path('/Users/ling/.openclaw/workspace')\\nREPORT_DIR = WORKSPACE / 'research' / 'reports'\\n\\n\\ndef evaluate_single_combo(\\n    detail: pd.DataFrame,\\n    *,\\n    hot_cut: float,\\n    score_max: float,\\n    holdout_split: base_mod.HoldoutSplit,\\n    windows: list[base_mod.WalkforwardWindow],\\n) -> dict[str, Any]:\\n    train_mask = (detail['date_key'] >= holdout_split.train_start) & (detail['date_key'] <= holdout_split.train_end)\\n    validation_mask = (detail['date_key'] >= holdout_split.validation_start) & (detail['date_key'] <= holdout_split.validation_end)\\n\\n    full_metrics = base_mod.evaluate_candidate(detail, name='candidate', hot_cut=hot_cut, score_max=score_max)\\n    train_metrics = base_mod.evaluate_candidate(detail[train_mask].copy(), name='candidate', hot_cut=hot_cut, score_max=score_max)\\n    validation_metrics = base_mod.evaluate_candidate(detail[validation_mask].copy(), name='candidate', hot_cut=hot_cut, score_max=score_max)\\n\\n    window_rows: list[dict[str, Any]] = []\\n    for window in windows:\\n        test_mask = (detail['date_key'] >= window.test_start) & (detail['date_key'] <= window.test_end)\\n        test_metrics = base_mod.evaluate_candidate(detail[test_mask].copy(), name='candidate', hot_cut=hot_cut, score_max=score_max)\\n        item = dict(test_metrics)\\n        item.update({\\n            'window_id': window.window_id,\\n            'train_start': window.train_start,\\n            'train_end': window.train_end,\\n            'test_start': window.test_start,\\n            'test_end': window.test_end,\\n            'train_days': window.train_days,\\n            'test_days': window.test_days,\\n        })\\n        window_rows.append(item)\\n\\n    window_df = pd.DataFrame(window_rows)\\n    sampled_df = window_df[pd.to_numeric(window_df['count'], errors='coerce').fillna(0) > 0].copy() if not window_df.empty else window_df.copy()\\n    positive_sampled = int((pd.to_numeric(sampled_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce') > 0).sum()) if not sampled_df.empty else 0\\n    sampled_windows = int(len(sampled_df))\\n    sampled_majority_threshold = max((sampled_windows + 1) // 2, 1)\\n    mean_sampled_edge = round(float(pd.to_numeric(sampled_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce').mean()), 4) if not sampled_df.empty else None\\n    worst_sampled_edge = round(float(pd.to_numeric(sampled_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce').min()), 4) if not sampled_df.empty else None\\n\\n    result = {\\n        'hot_cut': float(hot_cut),\\n        'score_max': float(score_max),\\n        'full_count': int(full_metrics.get('count', 0) or 0),\\n        'full_trade_day_count': int(full_metrics.get('trade_day_count', 0) or 0),\\n        'full_avg_future_return_pct': full_metrics.get('avg_future_return_pct'),\\n        'full_avoid_loss_edge_pct': full_metrics.get('avoid_loss_edge_vs_same_day_baseline_pct'),\\n        'train_count': int(train_metrics.get('count', 0) or 0),\\n        'train_edge_pct': train_metrics.get('avoid_loss_edge_vs_same_day_baseline_pct'),\\n        'validation_count': int(validation_metrics.get('count', 0) or 0),\\n        'validation_avg_future_return_pct': validation_metrics.get('avg_future_return_pct'),\\n        'validation_edge_pct': validation_metrics.get('avoid_loss_edge_vs_same_day_baseline_pct'),\\n        'sampled_window_count': sampled_windows,\\n        'empty_window_count': int(len(window_df) - sampled_windows),\\n        'positive_sampled_window_count': positive_sampled,\\n        'sampled_majority_threshold': int(sampled_majority_threshold),\\n        'sampled_majority_positive': bool(sampled_windows > 0 and positive_sampled >= sampled_majority_threshold),\\n        'mean_sampled_edge_pct': mean_sampled_edge,\\n        'worst_sampled_edge_pct': worst_sampled_edge,\\n        'window_rows': window_df.where(pd.notna(window_df), None).to_dict(orient='records'),\\n    }\\n    result['shadow_ready'] = bool(\\n        result['validation_edge_pct'] is not None\\n        and float(result['validation_edge_pct']) > 0\\n        and result['sampled_window_count'] >= 5\\n        and result['sampled_majority_positive']\\n        and result['mean_sampled_edge_pct'] is not None\\n        and float(result['mean_sampled_edge_pct']) > 0\\n    )\\n    return result\\n\\n\\ndef pick_recommended(rows: list[dict[str, Any]]) -> dict[str, Any]:\\n    if not rows:\\n        return {}\\n\\n    def sort_key(row: dict[str, Any]) -> tuple:\\n        return (\\n            int(bool(row.get('shadow_ready'))),\\n            int(bool(row.get('sampled_majority_positive'))),\\n            -9999.0 if row.get('validation_edge_pct') is None else float(row['validation_edge_pct']),\\n            -9999.0 if row.get('mean_sampled_edge_pct') is None else float(row['mean_sampled_edge_pct']),\\n            -9999.0 if row.get('worst_sampled_edge_pct') is None else float(row['worst_sampled_edge_pct']),\\n            int(row.get('sampled_window_count', 0) or 0),\\n            int(row.get('full_count', 0) or 0),\\n        )\\n\\n    return sorted(rows, key=sort_key, reverse=True)[0]\\n\\n\\ndef render_markdown(path: Path, payload: dict[str, Any]) -> None:\\n    recommendation = payload.get('recommended_combo', {}) or {}\\n    lines = [\\n        '# A股情绪验证链第九轮：候选 A 邻域局部稳健性扫描',\\n        '',\\n        f\\\"生成时间：{payload.get('generated_at')}（Asia/Shanghai）\\\",\\n        '',\\n        '## 一、本轮扫描范围',\\n        '',\\n        f\\\"- hot_cut：`{', '.join(str(x) for x in payload.get('hot_list', []))}`\\\",\\n        f\\\"- score_max：`{', '.join(str(x) for x in payload.get('score_list', []))}`\\\",\\n        '- 固定条件：`S5 & reduce/block & 看空/强烈看空`',\\n        '',\\n        '## 二、推荐组合',\\n        '',\\n        f\\\"- 推荐 hot_cut：`{recommendation.get('hot_cut', 'N/A')}`\\\",\\n        f\\\"- 推荐 score_max：`{recommendation.get('score_max', 'N/A')}`\\\",\\n        f\\\"- 验证集 edge：`{recommendation.get('validation_edge_pct', 'N/A')}`\\\",\\n        f\\\"- 有样本滚动窗口：`{recommendation.get('sampled_window_count', 'N/A')}`\\\",\\n        f\\\"- 正 edge 窗口：`{recommendation.get('positive_sampled_window_count', 'N/A')}` / `{recommendation.get('sampled_window_count', 'N/A')}`\\\",\\n        f\\\"- 平均滚动 edge：`{recommendation.get('mean_sampled_edge_pct', 'N/A')}`\\\",\\n        f\\\"- 最差滚动 edge：`{recommendation.get('worst_sampled_edge_pct', 'N/A')}`\\\",\\n        f\\\"- 是否达到影子候选门槛：`{recommendation.get('shadow_ready', False)}`\\\",\\n        '',\\n        '## 三、组合汇总',\\n        '',\\n        '| hot_cut | score_max | 验证集样本 | 验证集 edge | 有样本窗口 | 正 edge 窗口 | 平均滚动 edge | 最差滚动 edge | 影子候选 |',\\n        '| ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: | --- |',\\n    ]\\n    for row in payload.get('summary_rows', []) or []:\\n        lines.append(\\n            '| {hot_cut} | {score_max} | {validation_count} | {validation_edge_pct} | {sampled_window_count} | {positive_sampled_window_count} | {mean_sampled_edge_pct} | {worst_sampled_edge_pct} | {shadow_ready} |'.format(\\n                hot_cut=row.get('hot_cut'),\\n                score_max=row.get('score_max'),\\n                validation_count=row.get('validation_count'),\\n                validation_edge_pct=row.get('validation_edge_pct'),\\n                sampled_window_count=row.get('sampled_window_count'),\\n                positive_sampled_window_count=row.get('positive_sampled_window_count'),\\n                mean_sampled_edge_pct=row.get('mean_sampled_edge_pct'),\\n                worst_sampled_edge_pct=row.get('worst_sampled_edge_pct'),\\n                shadow_ready=row.get('shadow_ready'),\\n            )\\n        )\\n    lines.extend([\\n        '',\\n        '## 四、影子运行建议',\\n        '',\\n        payload.get('conclusion', {}).get('shadow_plan_cn', ''),\\n        '',\\n        '## 一句话结论',\\n        '',\\n        payload.get('conclusion', {}).get('summary_cn', ''),\\n    ])\\n    path.write_text('\\\\n'.join(lines), encoding='utf-8')\\n\\n\\ndef main() -> None:\\n    parser = argparse.ArgumentParser(description='规则二候选A邻域局部稳健性扫描')\\n    parser.add_argument('--detail-csv', default=str(base_mod.DEFAULT_DETAIL_CSV))\\n    parser.add_argument('--panel-csv', default=str(base_mod.DEFAULT_PANEL_CSV))\\n    parser.add_argument('--hot-list', default='83,85,87')\\n    parser.add_argument('--score-list', default='45,50,55')\\n    parser.add_argument('--holdout-train-ratio', type=float, default=0.7)\\n    parser.add_argument('--holdout-min-test-days', type=int, default=42)\\n    parser.add_argument('--train-days', type=int, default=168)\\n    parser.add_argument('--test-days', type=int, default=42)\\n    parser.add_argument('--step-days', type=int, default=21)\\n    parser.add_argument('--date-tag', default=datetime.now().strftime('%Y%m%d'))\\n    args = parser.parse_args()\\n\\n    hot_list = [float(x.strip()) for x in str(args.hot_list).split(',') if x.strip()]\\n    score_list = [float(x.strip()) for x in str(args.score_list).split(',') if x.strip()]\\n\\n    detail = base_mod.normalize_detail(pd.read_csv(Path(args.detail_csv).expanduser().resolve()))\\n    panel = pd.read_csv(Path(args.panel_csv).expanduser().resolve())\\n    detail = base_mod.enrich_fast_percentile(detail, panel)\\n\\n    trade_dates = sorted(int(x) for x in detail['date_key'].dropna().unique().tolist() if int(x) > 0)\\n    holdout_split = base_mod.build_holdout_split(\\n        trade_dates,\\n        train_ratio=float(args.holdout_train_ratio),\\n        min_test_days=int(args.holdout_min_test_days),\\n    )\\n    windows = base_mod.build_walkforward_windows(\\n        trade_dates,\\n        train_days=int(args.train_days),\\n        test_days=int(args.test_days),\\n        step_days=int(args.step_days),\\n    )\\n\\n    rows: list[dict[str, Any]] = []\\n    window_rows: list[dict[str, Any]] = []\\n    for hot_cut in hot_list:\\n        for score_max in score_list:\\n            item = evaluate_single_combo(\\n                detail,\\n                hot_cut=hot_cut,\\n                score_max=score_max,\\n                holdout_split=holdout_split,\\n                windows=windows,\\n            )\\n            rows.append({k: v for k, v in item.items() if k != 'window_rows'})\\n            for w in item['window_rows']:\\n                ww = dict(w)\\n                ww['hot_cut'] = hot_cut\\n                ww['score_max'] = score_max\\n                window_rows.append(ww)\\n\\n    summary_df = pd.DataFrame(rows).sort_values(\\n        ['shadow_ready', 'sampled_majority_positive', 'validation_edge_pct', 'mean_sampled_edge_pct', 'sampled_window_count', 'full_count'],\\n        ascending=[False, False, False, False, False, False],\\n    ).reset_index(drop=True)\\n    window_df = pd.DataFrame(window_rows)\\n    recommended = pick_recommended(rows)\\n\\n    if recommended.get('shadow_ready'):\\n        shadow_plan_cn = (\\n            f\\\"建议以 hot>={int(recommended.get('hot_cut'))} / score<={int(recommended.get('score_max'))} 作为主影子候选，\\\"\\n            '连续观察至少 20 个交易日或 20 次有效触发，再决定是否升格。'\\n        )\\n        summary_cn = '候选 A 邻域里已出现更适合影子运行的稳健组合，下一步应进入连续影子验证。'\\n    else:\\n        shadow_plan_cn = (\\n            '当前扫描范围内仍未出现同时满足“验证集为正 + 有样本窗口多数为正 + 覆盖不太稀”的组合。'\\n            '建议先以验证集更优的组合作为轻量影子参考，不进入硬门禁。'\\n        )\\n        summary_cn = '候选 A 邻域扫描后仍未出现足够稳健的正式候选，下一步应保持轻量影子观察而非正式接入。'\\n\\n    outputs = {\\n        'summary_csv': REPORT_DIR / f'sentiment_rule2_candidate_a_local_scan_{args.date_tag}.csv',\\n        'window_csv': REPORT_DIR / f'sentiment_rule2_candidate_a_local_scan_windows_{args.date_tag}.csv',\\n        'json': REPORT_DIR / f'sentiment_rule2_candidate_a_local_scan_{args.date_tag}.json',\\n        'md': REPORT_DIR / f'A股情绪验证链第九轮_候选A局部稳健性扫描_{args.date_tag}.md',\\n    }\\n    for path in outputs.values():\\n        path.parent.mkdir(parents=True, exist_ok=True)\\n\\n    summary_df.to_csv(outputs['summary_csv'], index=False, encoding='utf-8-sig')\\n    window_df.to_csv(outputs['window_csv'], index=False, encoding='utf-8-sig')\\n\\n    payload = {\\n        'generated_at': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\\n        'detail_csv': str(Path(args.detail_csv).expanduser().resolve()),\\n        'panel_csv': str(Path(args.panel_csv).expanduser().resolve()),\\n        'trade_day_count': int(len(trade_dates)),\\n        'holdout_split': base_mod.asdict(holdout_split),\\n        'window_config': {\\n            'train_days': int(args.train_days),\\n            'test_days': int(args.test_days),\\n            'step_days': int(args.step_days),\\n            'window_count': int(len(windows)),\\n        },\\n        'hot_list': hot_list,\\n        'score_list': score_list,\\n        'recommended_combo': recommended,\\n        'summary_rows': summary_df.where(pd.notna(summary_df), None).to_dict(orient='records'),\\n        'files': {k: str(v) for k, v in outputs.items()},\\n        'conclusion': {\\n            'summary_cn': summary_cn,\\n            'shadow_plan_cn': shadow_plan_cn,\\n        },\\n    }\\n    outputs['json'].write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding='utf-8')\\n    render_markdown(outputs['md'], payload)\\n    print(json.dumps(payload, ensure_ascii=False, indent=2))\\n\\n\\nif __name__ == '__main__':\\n    main()\\n\"}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage