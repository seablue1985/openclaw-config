{"type":"message","id":"0ab4db0b","parentId":"feadd298","timestamp":"2026-03-27T12:15:24.779Z","message":{"role":"toolResult","toolCallId":"call_2J2curUR3wYjNtVI9Lu8CWzx|fc_0a18d76e314b89270169c674db3bc08198a07bc99674bbebfb","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nimport shutil\nimport subprocess\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nWORKSPACE = Path('/Users/ling/.openclaw/workspace')\nQUANT_REPORT_DIR = WORKSPACE / 'quant_projects' / 'personal-a-share-research-system' / 'research' / 'reports'\nREPORT_DIR = WORKSPACE / 'research' / 'reports'\nSTRATEGY_REPORT_SCRIPT = WORKSPACE / 'quant_projects' / 'personal-a-share-research-system' / 'scripts' / 'generate_today_stock_strategy_report.py'\nEVENT_WATCH_SCRIPT = WORKSPACE / 'scripts' / 'run_investment_research_event_watch.py'\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding='utf-8'))\n\n\ndef parse_dt(value: Any) -> datetime:\n    text = str(value or '').strip()\n    if not text:\n        return datetime.min\n    for fmt in ('%Y-%m-%d %H:%M:%S', '%Y-%m-%dT%H:%M:%S.%f', '%Y-%m-%dT%H:%M:%S'):\n        try:\n            return datetime.strptime(text, fmt)\n        except ValueError:\n            continue\n    return datetime.min\n\n\ndef same_float(a: Any, b: Any) -> bool:\n    try:\n        return abs(float(a) - float(b)) < 1e-12\n    except Exception:\n        return a == b\n\n\ndef ensure_strategy_report(runtime: dict[str, Any], date_tag: str) -> tuple[dict[str, Any], list[str]]:\n    actions: list[str] = []\n    latest_runtime = runtime.get('latest_runtime') or {}\n    runtime_dt = parse_dt(runtime.get('generated_at'))\n    runtime_mode = latest_runtime.get('mode')\n    runtime_halt = latest_runtime.get('halt_new_buy')\n    runtime_breadth = latest_runtime.get('market_breadth')\n\n    dated_json = QUANT_REPORT_DIR / f'today_stock_strategy_report_{date_tag}.json'\n    dated_md = QUANT_REPORT_DIR / f'today_stock_strategy_report_{date_tag}.md'\n    latest_json = QUANT_REPORT_DIR / 'today_stock_strategy_report_latest.json'\n    latest_md = QUANT_REPORT_DIR / 'today_stock_strategy_report_latest.md'\n\n    report = load_json(dated_json)\n    report_dt = parse_dt(report.get('generated_at'))\n    report_trade_date = str(report.get('trade_date') or '').replace('-', '')\n    report_mode = report.get('risk_mode')\n    report_halt = report.get('halt_new_buy')\n    report_breadth = report.get('market_breadth')\n\n    needs_refresh = False\n    reasons: list[str] = []\n    if not report:\n        needs_refresh = True\n        reasons.append('dated_report_missing')\n    if report_trade_date != date_tag:\n        needs_refresh = True\n        reasons.append(f'trade_date={report_trade_date or \"<empty>\"}')\n    if runtime_dt != datetime.min and report_dt != datetime.min and report_dt < runtime_dt:\n        needs_refresh = True\n        reasons.append(f'report_older_than_runtime:{report.get(\"generated_at\")}<{runtime.get(\"generated_at\")}')\n    if report_mode != runtime_mode:\n        needs_refresh = True\n        reasons.append(f'mode_mismatch:{report_mode}!={runtime_mode}')\n    if report_halt != runtime_halt:\n        needs_refresh = True\n        reasons.append(f'halt_mismatch:{report_halt}!={runtime_halt}')\n    if not same_float(report_breadth, runtime_breadth):\n        needs_refresh = True\n        reasons.append(f'breadth_mismatch:{report_breadth}!={runtime_breadth}')\n\n    if needs_refresh and STRATEGY_REPORT_SCRIPT.exists():\n        proc = subprocess.run(\n            [sys.executable, str(STRATEGY_REPORT_SCRIPT), '--date', date_tag],\n            cwd=str(WORKSPACE),\n            capture_output=True,\n            text=True,\n        )\n        actions.append(f'refresh_strategy_report({\";\".join(reasons)}) => rc={proc.returncode}')\n        report = load_json(dated_json)\n        if dated_json.exists():\n            shutil.copyfile(dated_json, latest_json)\n        if dated_md.exists():\n            shutil.copyfile(dated_md, latest_md)\n        actions.append(f'sync_latest_from_dated => {latest_json.name}')\n    else:\n        actions.append('refresh_strategy_report(skip)')\n\n    return load_json(dated_json) or load_json(latest_json), actions\n\n\ndef ensure_event_watch(runtime: dict[str, Any], date_tag: str) -> tuple[dict[str, Any], list[str]]:\n    actions: list[str] = []\n    latest_runtime = runtime.get('latest_runtime') or {}\n    runtime_dt = parse_dt(runtime.get('generated_at'))\n    runtime_mode = latest_runtime.get('mode')\n    runtime_halt = latest_runtime.get('halt_new_buy')\n\n    dated_json = REPORT_DIR / f'investment_research_event_watch_{date_tag}.json'\n    dated_md = REPORT_DIR / f'investment_research_event_watch_{date_tag}.md'\n    latest_json = REPORT_DIR / 'investment_research_event_watch_latest.json'\n    latest_md = REPORT_DIR / 'investment_research_event_watch_latest.md'\n\n    event_watch = load_json(dated_json)\n    ew_dt = parse_dt(event_watch.get('generated_at'))\n    cur = event_watch.get('current') or {}\n    pe = cur.get('paper_execution_status') or {}\n    ew_source = pe.get('source')\n    ew_mode = pe.get('mode')\n    ew_halt = pe.get('halt_new_buy')\n    ew_tag = str(cur.get('strategy_report_date_tag') or '').replace('-', '')\n\n    needs_refresh = False\n    reasons: list[str] = []\n    if not event_watch:\n        needs_refresh = True\n        reasons.append('event_watch_missing')\n    if ew_tag not in {'', date_tag}:\n        needs_refresh = True\n        reasons.append(f'strategy_report_date_tag={ew_tag}')\n    if runtime_dt != datetime.min and ew_dt != datetime.min and ew_dt < runtime_dt:\n        needs_refresh = True\n        reasons.append(f'event_watch_older_than_runtime:{event_watch.get(\"generated_at\")}<{runtime.get(\"generated_at\")}')\n    if ew_source != 'runtime_risk_state_latest':\n        needs_refresh = True\n        reasons.append(f'source={ew_source}')\n    if ew_mode != runtime_mode:\n        needs_refresh = True\n        reasons.append(f'mode_mismatch:{ew_mode}!={runtime_mode}')\n    if ew_halt != runtime_halt:\n        needs_refresh = True\n        reasons.append(f'halt_mismatch:{ew_halt}!={runtime_halt}')\n\n    if needs_refresh and EVENT_WATCH_SCRIPT.exists():\n        proc = subprocess.run(\n            [sys.executable, str(EVENT_WATCH_SCRIPT)],\n            cwd=str(WORKSPACE),\n            capture_output=True,\n            text=True,\n        )\n        actions.append(f'refresh_event_watch({\";\".join(reasons)}) => rc={proc.returncode}')\n        event_watch = load_json(dated_json)\n        if dated_json.exists():\n            shutil.copyfile(dated_json, latest_json)\n        if dated_md.exists():\n            shutil.copyfile(dated_md, latest_md)\n        actions.append(f'sync_event_watch_latest_from_dated => {latest_json.name}')\n    else:\n        actions.append('refresh_event_watch(skip)')\n\n    return load_json(dated_json) or load_json(latest_json), actions\n\n\ndef main() -> None:\n    runtime = load_json(QUANT_REPORT_DIR / 'runtime_risk_state_latest.json')\n    date_tag = str(runtime.get('date_tag') or datetime.now().strftime('%Y%m%d'))\n    report, report_actions = ensure_strategy_report(runtime, date_tag)\n    event_watch, event_actions = ensure_event_watch(runtime, date_tag)\n\n    payload = {\n        'generated_at': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n        'date_tag': date_tag,\n        'runtime_path': str(QUANT_REPORT_DIR / 'runtime_risk_state_latest.json'),\n        'dated_report_path': str(QUANT_REPORT_DIR / f'today_stock_strategy_report_{date_tag}.json'),\n        'dated_event_watch_path': str(REPORT_DIR / f'investment_research_event_watch_{date_tag}.json'),\n        'report_actions': report_actions,\n        'event_watch_actions': event_actions,\n        'report_snapshot': {\n            'generated_at': report.get('generated_at'),\n            'trade_date': report.get('trade_date'),\n            'risk_mode': report.get('risk_mode'),\n            'halt_new_buy': report.get('halt_new_buy'),\n            'market_breadth': report.get('market_breadth'),\n        },\n        'event_watch_snapshot': {\n            'generated_at': event_watch.get('generated_at'),\n            'strategy_report_date_tag': (event_watch.get('current') or {}).get('strategy_report_date_tag'),\n            'source': ((event_watch.get('current') or {}).get('paper_execution_status') or {}).get('source'),\n            'mode': ((event_watch.get('current') or {}).get('paper_execution_status') or {}).get('mode'),\n            'halt_new_buy': ((event_watch.get('current') or {}).get('paper_execution_status') or {}).get('halt_new_buy'),\n            'market_breadth': ((event_watch.get('current') or {}).get('paper_execution_status') or {}).get('market_breadth'),\n        },\n    }\n\n    latest_json = REPORT_DIR / 'p1_001_consistency_refresh_latest.json'\n    latest_md = REPORT_DIR / 'p1_001_consistency_refresh_latest.md'\n    latest_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding='utf-8')\n    md = [\n        '# P1-001 一致性刷新',\n        '',\n        f\"- 生成时间：{payload['generated_at']}\",\n        f\"- date_tag：`{date_tag}`\",\n        '',\n        '## 策略报告刷新动作',\n    ]\n    for item in report_actions:\n        md.append(f'- {item}')\n    md.extend(['', '## 事件监控刷新动作'])\n    for item in event_actions:\n        md.append(f'- {item}')\n    md.extend([\n        '',\n        '## 当前快照',\n        f\"- report: mode={payload['report_snapshot']['risk_mode']} halt={payload['report_snapshot']['halt_new_buy']} breadth={payload['report_snapshot']['market_breadth']} generated_at={payload['report_snapshot']['generated_at']}\",\n        f\"- event_watch: source={payload['event_watch_snapshot']['source']} mode={payload['event_watch_snapshot']['mode']} halt={payload['event_watch_snapshot']['halt_new_buy']} breadth={payload['event_watch_snapshot']['market_breadth']} generated_at={payload['event_watch_snapshot']['generated_at']}\",\n        '',\n    ])\n    latest_md.write_text('\\n'.join(md), encoding='utf-8')\n    print(json.dumps(payload, ensure_ascii=False, indent=2))\n\n\nif __name__ == '__main__':\n    main()\n"}],"isError":false,"timestamp":1774613724768}}
