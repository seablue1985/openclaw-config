{"type":"message","id":"61e0dc6d","parentId":"83febc87","timestamp":"2026-03-27T10:40:45.160Z","message":{"role":"toolResult","toolCallId":"call_diBIbv6peEy89w46G7XaSzN5|fc_0a18d76e314b89270169c65eac64508198b021f0113f423443","toolName":"read","content":[{"type":"text","text":"            mean_test_edge_pct=('avoid_loss_edge_vs_same_day_baseline_pct', 'mean'),\n            median_test_edge_pct=('avoid_loss_edge_vs_same_day_baseline_pct', 'median'),\n            worst_test_edge_pct=('avoid_loss_edge_vs_same_day_baseline_pct', 'min'),\n            positive_edge_windows=('avoid_loss_edge_vs_same_day_baseline_pct', lambda s: int((pd.to_numeric(s, errors='coerce') > 0).sum())),\n        )\n        .sort_values(['mean_test_edge_pct', 'total_count'], ascending=[False, False])\n        .reset_index(drop=True)\n    )\n\n    sampled_selected_df = selected_df[pd.to_numeric(selected_df['count'], errors='coerce').fillna(0) > 0].copy() if not selected_df.empty else selected_df.copy()\n    positive_selected = int((pd.to_numeric(sampled_selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce') > 0).sum()) if not sampled_selected_df.empty else 0\n    negative_selected = int((pd.to_numeric(sampled_selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce') <= 0).sum()) if not sampled_selected_df.empty else 0\n    selected_mean_edge = round(float(pd.to_numeric(sampled_selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce').mean()), 4) if not sampled_selected_df.empty else None\n    selected_worst_edge = round(float(pd.to_numeric(sampled_selected_df['avoid_loss_edge_vs_same_day_baseline_pct'], errors='coerce').min()), 4) if not sampled_selected_df.empty else None\n    majority_threshold = math.ceil(max(len(windows), 1) / 2)\n    sampled_threshold = math.ceil(max(len(sampled_selected_df), 1) / 2) if len(sampled_selected_df) else 1\n    summary = {\n        'window_count': int(len(windows)),\n        'selected_sampled_windows': int(len(sampled_selected_df)),\n        'selected_empty_windows': int(len(selected_df) - len(sampled_selected_df)),\n        'selected_positive_edge_windows': positive_selected,\n        'selected_negative_edge_windows': negative_selected,\n        'selected_mean_edge_pct': selected_mean_edge,\n        'selected_worst_edge_pct': selected_worst_edge,\n        'selected_beats_baseline_majority': bool(positive_selected >= majority_threshold),\n        'selected_beats_baseline_majority_on_sampled_windows': bool(positive_selected >= sampled_threshold) if len(sampled_selected_df) else False,\n        'majority_threshold': int(majority_threshold),\n        'sampled_majority_threshold': int(sampled_threshold),\n    }\n    return metrics_df, summary_df, summary\n\n\ndef render_markdown(path: Path, payload: dict[str, Any]) -> None:\n    holdout = payload.get('holdout_summary', {}) or {}\n    rolling = payload.get('rolling_summary', {}) or {}\n    candidate_summary = payload.get('rolling_candidate_summary', []) or []\n    lines = [\n        '# A股情绪验证链第八轮：规则二样本外验证',\n        '',\n        f\"生成时间：{payload.get('generated_at')}（Asia/Shanghai）\",\n        '',\n        '## 一、本轮验证对象',\n        '',\n        '- 候选 A：`hot>=85 & score<=50 & S5 & reduce/block & 看空/强烈看空`',\n        '- 候选 B：`hot>=90 & score<=40 & S5 & reduce/block & 看空/强烈看空`',\n        '',\n        '## 二、输入口径',\n        '',\n        f\"- 明细：`{payload.get('detail_csv')}`\",\n        f\"- 面板：`{payload.get('panel_csv')}`\",\n        f\"- 交易日数：`{payload.get('trade_day_count')}`\",\n        f\"- 固定切分：训练 `70%` / 验证 `30%`（实际 `{payload.get('holdout_split', {}).get('train_days', 0)}` / `{payload.get('holdout_split', {}).get('validation_days', 0)}` 交易日）\",\n        f\"- 滚动窗口：train=`{payload.get('window_config', {}).get('train_days')}` / test=`{payload.get('window_config', {}).get('test_days')}` / step=`{payload.get('window_config', {}).get('step_days')}`\",\n        '',\n        '## 三、固定切分结果',\n        '',\n        f\"- 训练期优选候选：`{holdout.get('train_preferred_candidate', 'N/A')}`\",\n        f\"- 训练期优选 edge：`{holdout.get('train_preferred_edge_pct', 'N/A')}`\",\n        f\"- 验证期优选候选：`{holdout.get('validation_preferred_candidate', 'N/A')}`\",\n        f\"- 验证期优选 edge：`{holdout.get('validation_preferred_edge_pct', 'N/A')}`\",\n        f\"- 验证期优选样本数：`{holdout.get('validation_preferred_count', 'N/A')}`\",\n        f\"- 验证期优选平均未来收益：`{holdout.get('validation_preferred_avg_future_return_pct', 'N/A')}`\",\n        '',\n        '## 四、滚动前推结果',\n        '',\n        f\"- 窗口数：`{rolling.get('window_count', 0)}`\",\n        f\"- 有样本的训练优选测试窗口数：`{rolling.get('selected_sampled_windows', 0)}`（空窗口 `{'{'}rolling.get('selected_empty_windows', 0){'}'}`）\",\n        f\"- 训练优选在测试期跑赢基线窗口数：`{rolling.get('selected_positive_edge_windows', 0)}` / `{rolling.get('selected_sampled_windows', 0)}`（按全窗口口径：`{rolling.get('selected_positive_edge_windows', 0)}` / `{rolling.get('window_count', 0)}`）\",\n        f\"- 训练优选在测试期平均 edge：`{rolling.get('selected_mean_edge_pct', 'N/A')}`\",\n        f\"- 训练优选在测试期最差 edge：`{rolling.get('selected_worst_edge_pct', 'N/A')}`\",\n        f\"- 是否多数有样本窗口跑赢基线：`{rolling.get('selected_beats_baseline_majority_on_sampled_windows', False)}`\",\n        f\"- 是否多数全窗口跑赢基线：`{rolling.get('selected_beats_baseline_majority', False)}`\",\n        '',\n        '## 五、候选汇总',\n        '',\n        '| 候选 | 窗口数 | 总样本数 | 平均每窗样本 | 平均测试 edge | 最差测试 edge | 正 edge 窗口数 |',\n        '| --- | ---: | ---: | ---: | ---: | ---: | ---: |',\n    ]\n    for row in candidate_summary:\n        lines.append(\n\n[135 more lines in file. Use offset=360 to continue.]"}],"isError":false,"timestamp":1774608045149}}
