n\n=== RED ===\n\nslug)\n\n    journal_df = read_csv(journal_path)\n    orders_df = read_csv(orders_path)\n    positions_df = read_csv(positions_path)\n    account_payload = load_json(account_path)\n    metrics_payload = load_json(metrics_path)\n    metrics = metrics_payload.get(\"metrics\", {}) or {}\n\n    issues: list[dict[str, Any]] = []\n\n    drawdown_pct = parse_float(metrics.get(\"max_drawdown_pct\"), 0.0)\n    if drawdown_pct > parse_float(thresholds.get(\"paper_max_drawdown_pct\"), 8.0):\n        issues.append({\"level\": \"RED\", \"code\": \"MAX_DRAWDOWN_BREACH\", \"value\": drawdown_pct, \"limit\": thresholds.get(\"paper_max_drawdown_pct\")})\n\n    daily_ret = pd.to_numeric(journal_df.get(\"pnl_day\"), errors=\"coerce\").fillna(0.0)\n    nav = parse_float(account_payload.get(\"nav\"), 0.0)\n    if nav > 0 and not daily_ret.empty:\n        ret_series = daily_ret.tail(20) / nav\n    else:\n        ret_series = pd.Series(dtype=float)\n\n    trailing_20d_ret = trailing_return_pct(ret_series)\n    if trailing_20d_ret < parse_float(thresholds.get(\"paper_20d_return_floor_pct\"), -5.0):\n        issues.append({\"level\": \"RED\", \"code\": \"RET_20D_BREACH\", \"value\": trailing_20d_ret, \"limit\": thresholds.get(\"paper_20d_return_floor_pct\")})\n\n    trailing_20d_sharpe = round(annualized_sharpe(ret_series.tail(20)), 3) if not ret_series.empty else 0.0\n    if trailing_20d_sharpe < parse_float(thresholds.get(\"paper_20d_sharpe_floor\"), 0.0):\n        issue\n\n=== halt ===\n\n  if error_trade_count > int(parse_float(thresholds.get(\"paper_error_trade_count_cap\"), 0.0)):\n        issues.append({\"level\": \"RED\", \"code\": \"ERROR_TRADE_COUNT_BREACH\", \"value\": error_trade_count, \"limit\": thresholds.get(\"paper_error_trade_count_cap\")})\n\n    observation_days = int(cfg.get(\"admission\", {}).get(\"paper_observation_min_days\", 20))\n    status = \"GREEN\"\n    tomorrow_mode = \"normal\"\n    if any(item[\"level\"] == \"RED\" for item in issues):\n        status = \"RED\"\n        tomorrow_mode = \"halt\"\n    elif issues:\n        status = \"YELLOW\"\n        tomorrow_mode = \"cautious\"\n    elif journal_records < observation_days:\n        status = \"YELLOW\"\n        tomorrow_mode = \"observe\"\n\n    payload = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"config\": str(cfg_path),\n        \"date_tag\": date_tag,\n        \"profile_slug\": profile_slug,\n        \"status\": status,\n        \"tomorrow_mode\": tomorrow_mode,\n        \"issues\": issues,\n        \"inputs\": {\n            \"journal\": str(journal_path),\n            \"orders\": str(orders_path),\n            \"account\": str(account_path),\n            \"metrics\": str(metrics_path),\n            \"positions\": str(positions_path),\n        },\n        \"stats\": {\n            \"nav\": round(nav, 2),\n            \"planned_orders\": int(len(orders_df)),\n            \"journal_records\": journal_records,\n            \"position_count\": int(ac\n\n=== cautious ===\n\n_count_cap\"), 0.0)):\n        issues.append({\"level\": \"RED\", \"code\": \"ERROR_TRADE_COUNT_BREACH\", \"value\": error_trade_count, \"limit\": thresholds.get(\"paper_error_trade_count_cap\")})\n\n    observation_days = int(cfg.get(\"admission\", {}).get(\"paper_observation_min_days\", 20))\n    status = \"GREEN\"\n    tomorrow_mode = \"normal\"\n    if any(item[\"level\"] == \"RED\" for item in issues):\n        status = \"RED\"\n        tomorrow_mode = \"halt\"\n    elif issues:\n        status = \"YELLOW\"\n        tomorrow_mode = \"cautious\"\n    elif journal_records < observation_days:\n        status = \"YELLOW\"\n        tomorrow_mode = \"observe\"\n\n    payload = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"config\": str(cfg_path),\n        \"date_tag\": date_tag,\n        \"profile_slug\": profile_slug,\n        \"status\": status,\n        \"tomorrow_mode\": tomorrow_mode,\n        