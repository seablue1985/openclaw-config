        \"--market-breadth\",\n        str(runtime_metrics.get(\"market_breadth\")),\n        \"--index-ret-pct\",\n        str(runtime_metrics.get(\"index_ret_pct\")),\n        \"--strategy-max-dd-pct\",\n        str(runtime_metrics.get(\"strategy_max_dd_pct\")),\n        \"--strategy-sharpe\",\n        str(runtime_metrics.get(\"strategy_sharpe\")),\n        \"--live-config\",\n        str(live_config_path),\n        \"--holdings\",\n        str(artifacts[\"holdings_input\"]),\n        \"--trade-history\",\n        str(artifacts[\"trade_history\"]),\n        \"--approved-output\",\n        str(artifacts[\"approved\"]),\n        \"--orders-output\",\n        str(artifacts[\"candidate_orders\"]),\n    ]\n    if risk_config_path is not None:\n        apply_cmd.extend([\"--risk-config\", str(risk_config_path)])\n    apply_out = run_cmd(apply_cmd)\n\n    stock_analysis_overlay = apply_stock_analysis_overlay(\n        candidate_orders_path=artifacts[\"candidate_orders\"],\n        report_dir=REPORT_DIR,\n        date_tag=date_tag,\n        profile_slug=profile_slug,\n        scope=\"paper\",\n        overlay_rule_profile=EXECUTION_OVERLAY_PROFILE,\n    )\n    ticket_rows, ticket_stats = build_ticket_rows(\n        source_kind=\"merged_proposed_orders\",\n        source_path=artifacts[\"candidate_orders\"],\n        date_tag=date_tag,\n        account_nav=account_nav,\n        lot_size=max(1, lot_size),\n    )\n    ticket_rows = inject_ticket_pipeline_notes(\n        ticket_rows,\n        pipeline_kind=\"paper\",\n        generated_by=\"prepare_paper_orders_v1.py\",\n        date_tag=date_tag,\n    )\n    write_ticket_rows(artifacts[\"tickets\"], ticket_rows)\n\n    return {\n        \"source\": \"profile_signal_chain\",\n        \"date_tag\": date_tag,\n        \"live_config\": str(live_config_path),\n        \"risk_config\": str(risk_config_path) if risk_config_path is not None else \"\",\n        \"merged_signals\": str(merged_signals_path),\n        \"candidate_approved\": str(artifacts[\"approved\"]),\n        \"candidate_orders\": str(artifacts[\"candidate_orders\"]),\n        \"candidate_tickets\": str(artifacts[\"tickets\"]),\n        \"holdings_input\": str(artifacts[\"holdings_input\"]),\n        \"trade_history_input\": str(artifacts[\"trade_history\"]),\n        \"available_cash\": available_cash,\n        \"account_nav\": account_nav,\n        \"ticket_rows\": int(len(ticket_rows)),\n        \"ticket_stats\": ticket_stats,\n        \"apply_risk_cmd\": apply_out.get(\"cmd\", []),\n        \"stock_analysis_overlay\": stock_analysis_overlay,\n    }\n\n\ndef write_brief(\n    *,\n    path: Path,\n    date_tag: str,\n    state: dict[str, Any],\n    config_path: Path,\n    tickets_path: Path,\n    holdings_path: Path,\n    orders_path: Path,\n    stats: dict[str, Any],\n    gray_context: dict[str, Any],\n    market_breadth: float | None,\n    index_ret_pct: float,\n    signal_materialization: dict[str, Any] | None = None,\n    intraday_gate: dict[str, Any] | None = None,\n) -> None:\n    signal_materialization = signal_materialization or {}\n    intraday_gate = intraday_gate or {}\n    lines = [\n        f\"# 模拟盘下单计划 v1（{date_tag}）\",\n        \"\",\n        \"## 纸面账户前置状态\",\n        f\"- state_source：`{state.get('source', '-')}`\",\n        f\"- source_date_tag：`{state.get('source_date_tag', '-') or '-'}`\",\n        f\"- available_cash：`{round(parse_float(state.get('available_cash'), 0.0), 2)}`\",\n        f\"- account_nav：`{round(parse_float(state.get('account_nav'), 0.0), 2)}`\",\n        f\"- holdings_count：`{len(state.get('positions_df', pd.DataFrame()))}`\",\n        \"\",\n        \"## 风控执行状态\",\n        f\"- config：`{config_path}`\",\n---\n    path.write_text(\"\\n\".join(lines) + \"\\n\", encoding=\"utf-8\")\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"纸面账户下单计划生成 v1\")\n    parser.add_argument(\n        \"--config\",\n        default=str(DEFAULT_CONFIG_PATH),\n        help=\"纸面交易配置文件；默认使用 aggressive profile\",\n    )\n    parser.add_argument(\"--date\", default=\"\", help=\"可选：YYYYMMDD 或 YYYY-MM-DD\")\n    parser.add_argument(\"--tickets\", default=\"\", help=\"可选：指定信号票据 csv\")\n    parser.add_argument(\"--merged-signals\", default=\"\", help=\"可选：指定 merged_signals csv；未传 tickets 时用于自动生成 profile 专属票据\")\n    parser.add_argument(\"--risk-config\", default=\"\", help=\"可选：显式指定 risk config；未传则直接使用 live_config 内的 risk\")\n    args = parser.parse_args()\n\n    paper_cfg = load_json(resolve_path(args.config))\n    execution_config_path = resolve_path(str(paper_cfg.get(\"execution_config\", \"config/paper_live_trading_v1.json\")))\n    execution_cfg = load_json(execution_config_path)\n    profile_slug = profile_slug_from_config(paper_cfg)\n    profile_name = profile_name_from_config(paper_cfg)\n\n    date_tag = parse_date_tag(args.date) if args.date else datetime.now().strftime(\"%Y%m%d\")\n    state = resolve_pretrade_state(paper_cfg, date_tag)\n    signal_materialization: dict[str, Any]\n    if args.tickets:\n        tickets_path = resolve_tickets_path(date_tag, args.tickets)\n        signal_materialization = {\n            \"source\": \"explicit_tickets\",\n            \"candidate_tickets\": str(tickets_path),\n        }\n    else:\n        signal_materialization = materialize_profile_signal_chain(\n            paper_cfg=paper_cfg,\n            state=state,\n            date_tag=date_tag,\n            merged_signals_path=resolve_merged_signals_path(date_tag, args.merged_signals),\n            risk_config_path=resolve_path(args.risk_config) if str(args.risk_config or \"\").strip() else None,\n        )\n        tickets_path = Path(str(signal_materialization[\"candidate_tickets\"])).resolve()\n\n    holdings_dated = report_path(REPORT_DIR, \"execution_holdings_dated\", profile_slug=profile_slug, date_tag=date_tag)\n    holdings_latest = report_path(REPORT_DIR, \"execution_holdings_latest\", profile_slug=profile_slug)\n    write_holdings_snapshot(holdings_dated, state[\"positions_df\"])\n    write_holdings_snapshot(holdings_latest, state[\"positions_df\"])\n\n    holdings_map = load_holdings_map(holdings_dated)\n    adv20_map = load_adv20_map(A_STOCK_CSV, min_trade_date=\"2020-01-01\")\n    runtime_metrics = resolve_runtime_metrics(date_tag, execution_cfg)\n\n    # ===== CSV 数据新鲜度校验（防控 T-1 数据被误用）====\n    csv_index_file = INDEX_DATA_ROOT / \"index_000852_SH.csv\"\n    csv_data_stale_warning = \"\"\n    csv_index_is_stale = False\n    last_csv_date: int | None = None\n    if csv_index_file.exists():\n        import pandas as pd\n        df_idx = pd.read_csv(csv_index_file)\n        last_csv_date = int(df_idx.iloc[-1][\"trade_date\"])\n        today_int = int(datetime.now().strftime(\"%Y%m%d\"))\n        if last_csv_date < today_int:\n            csv_index_is_stale = True\n\n    live_payload = runtime_metrics[\"live_payload\"]\n    index_ret_pct = float(runtime_metrics.get(\"index_ret_pct\", 0.0) or 0.0)\n    market_breadth = runtime_metrics.get(\"market_breadth\")\n    if csv_index_is_stale and abs(index_ret_pct) <= 1e-9:\n        csv_data_stale_warning = (\n            f\"[WARN] CSV 指数数据陈旧（最后日期={last_csv_date}，今日={today_int}），\"\n            \"实时指数口径也不可用，风控判断存在失真风险。\"\n        )\n        print(csv_data_stale_warning, file=sys.stderr)\n    elif csv_index_is_stale:\n        csv_data_stale_warning = (\n            f\"[INFO] CSV 指数日线陈旧（最后日期={last_csv_date}，今日={today_int}），\"\n            f\"本次已切换实时指数口径 index_ret_pct={index_ret_pct:.4f}%\"\n        )\n    runtime = evaluate_runtime_state_for_date(\n        config=execution_cfg,\n        live_payload=live_payload,\n        date_tag=date_tag,\n        index_ret_pct=index_ret_pct,\n        market_breadth=market_breadth,\n    )\n    gray_context = apply_gray_policy(\n        config=execution_cfg,\n        available_cash=float(state[\"available_cash\"]),\n        runtime=runtime,\n    )\n\n    # ===== 盘中实时大盘门禁 =====","cwd":"/Users/ling/.openclaw/workspace"},"isError":false,"timestamp":1774412810041}}
