itable, search, drive, wiki, sheets, im)\\n[plugins] feishu_oauth: Registered feishu_oauth tool\\n[plugins] feishu_oauth_batch_auth: Registered feishu_oauth_batch_auth tool\\n{\\n  \\\"action\\\": \\\"send\\\",\\n  \\\"channel\\\": \\\"feishu\\\",\\n  \\\"dryRun\\\": true,\\n  \\\"handledBy\\\": \\\"core\\\",\\n  \\\"payload\\\": {\\n    \\\"channel\\\": \\\"feishu\\\",\\n    \\\"to\\\": \\\"ou_968a615509dc191f04220e18cda67080\\\",\\n    \\\"via\\\": \\\"direct\\\",\\n    \\\"mediaUrl\\\": null,\\n    \\\"dryRun\\\": true\\n  }\\n}\",\n      \"dry_run\": true\n    },\n    {\n      \"target_name\": \"group\",\n      \"channel\": \"feishu\",\n      \"account\": \"main\",\n      \"target\": \"chat:oc_8a819be3a90d35b8d0a2d5c1f4642b22\",\n      \"status\": \"OK\",\n      \"dedupe_key\": \"4b91fbe5f1ecbb37c74cd144b43b229d87335ed4177fec052515a5604aaf6464\",\n      \"info\": \"[plugins] feishu_chat: Registered feishu_chat, feishu_chat_members\\n[plugins] feishu_im: Registered feishu_im_user_message, feishu_im_user_fetch_resource, feishu_im_user_get_messages, feishu_im_user_get_thread_messages, feishu_im_user_search_messages\\n[plugins] feishu_drive: Registered feishu_drive_file, feishu_doc_comments, feishu_doc_media\\n[plugins] feishu_wiki: Registered feishu_wiki_space, feishu_wiki_space_node\\n[plugins] feishu_sheets: Registered feishu_sheet tool\\n[plugins] feishu_im_bot_image: Registered feishu_im_bot_image tool\\n[plugins] feishu_im: Registered feishu_im_bot_image\\n[plugins] Registered all OAPI tools (calendar, task, bitable, search, drive, wiki, sheets, im)\\n[plugins] feishu_oauth: Registered feishu_oauth tool\\n[plugins] feishu_oauth_batch_auth: Registered feishu_oauth_batch_auth tool\\n{\\n  \\\"action\\\": \\\"send\\\",\\n  \\\"channel\\\": \\\"feishu\\\",\\n  \\\"dryRun\\\": true,\\n  \\\"handledBy\\\": \\\"core\\\",\\n  \\\"payload\\\": {\\n    \\\"channel\\\": \\\"feishu\\\",\\n    \\\"to\\\": \\\"oc_8a819be3a90d35b8d0a2d5c1f4642b22\\\",\\n    \\\"via\\\": \\\"direct\\\",\\n    \\\"mediaUrl\\\": null,\\n    \\\"dryRun\\\": true\\n  }\\n}\",\n      \"dry_run\": true\n    }\n  ]\n}\n"}],"isError":false,"timestamp":1774446449357}}
{"type":"message","id":"05cd95c8","parentId":"d805a8bc","timestamp":"2026-03-25T13:47:29.380Z","message":{"role":"toolResult","toolCallId":"call_ThcV0EVRlKJytToeAgmqXrwy|fc_03f66048c5db434b0169c3e7704da88195ba0009379ff03704","toolName":"read","content":[{"type":"text","text":"\n\ndef compact_watchlist(items: list[Any], limit: int = 5) -> list[str]:\n    result: list[str] = []\n    for item in items[:limit]:\n        if isinstance(item, dict):\n            display = item.get(\"display\") or item.get(\"ticker\") or item.get(\"name\")\n            if display:\n                result.append(str(display))\n        elif item:\n            result.append(str(item))\n    return result\n\n\ndef compact_sell_review(items: list[Any], limit: int = 5) -> list[str]:\n    result: list[str] = []\n    for item in items[:limit]:\n        if isinstance(item, dict):\n            display = item.get(\"display\") or item.get(\"ticker\") or item.get(\"name\")\n            reason = item.get(\"reason\") or item.get(\"action\")\n            if display and reason:\n                result.append(f\"{display} | {reason}\")\n            elif display:\n                result.append(str(display))\n        elif item:\n            result.append(str(item))\n    return result\n\n\ndef resolve_health_snapshot(date_tag: str, bundle: dict[str, Any], control_tower: dict[str, Any]) -> dict[str, Any]:\n    health_scope, health_probe, health_path = latest_health_probe_for_date(REPORT_DIR, date_tag)\n    if health_probe:\n        return build_health_snapshot(health_scope, health_probe, health_path)\n    health_snapshot = control_tower.get(\"health_probe\", {}) if isinstance(control_tower.get(\"health_probe\"), dict) else {}\n    if health_snapshot:\n        return health_snapshot\n    bundle_probe = bundle.get(\"data_source_health\", {}) if isinstance(bundle.get(\"data_source_health\"), dict) else {}\n    if bundle_probe:\n        return build_health_snapshot(bundle_probe.get(\"scope\"), bundle_probe, None)\n    return {}\n\n\ndef should_include_execution_review_summary(meeting_type: str, trade_card: dict[str, Any]) -> bool:\n    if meeting_type not in {\"close\", \"night\"}:\n        return False\n    entries = trade_card.get(\"execution_review_entries\", [])\n    if not entries or not isinstance(entries[0], dict):\n        return False\n    review_item = entries[0]\n    if review_item.get(\"reason\") == \"holding_outside_trade_loop\":\n        return False\n    if review_item.get(\"primary_attribution_label\") == \"holding_without_strategy_exit\":\n        return False\n    if review_item.get(\"stage\") == \"sell_review\" and not trade_card.get(\"sell_review_list\"):\n        return False\n    return True\n\n\ndef build_message(\n    meeting_type: str,\n    date_tag: str,\n    trade_card: dict[str, Any],\n    bundle: dict[str, Any],\n    health_snapshot: dict[str, Any],\n) -> str:\n    watchlist = compact_watchlist(trade_card.get(\"watchlist\", []))\n    sell_review = compact_sell_review(trade_card.get(\"sell_review_list\", []))\n    event_watch = bundle.get(\"event_watch\", {}) if isinstance(bundle.get(\"event_watch\"), dict) else {}\n    ths = health_snapshot.get(\"ths_market\", {}) if isinstance(health_snapshot.get(\"ths_market\"), dict) else {}\n    paper_freshness = trade_card.get(\"paper_execution_freshness\", {}) if isinstance(trade_card.get(\"paper_execution_freshness\"), dict) else {}\n    risk_text = \"偏防守\" if trade_card.get(\"risk_off\") else \"条件化推进\"\n    watchlist_text = \"、\".join(watchlist) if watchlist else str(trade_card.get(\"watchlist_reason\") or \"暂无\")\n    sell_review_text = \"、\".join(sell_review) if sell_review else str(trade_card.get(\"sell_review_reason\") or \"暂无\")\n    alert_line = build_ths_alert_line(health_snapshot)\n\n    lines: list[str] = []\n    if alert_line:\n        lines.append(f\"[THS告警] {alert_line}\")\n\n    lines.extend([\n        f\"{MEETING_EMOJIS.get(meeting_type, '📊')} 模拟交易提示｜{MEETING_LABELS.get(meeting_type, meeting_type)}｜{date_tag}\",\n        f\"- 风险状态：{risk_text}\",\n        f\"- 模拟买入观察：{watchlist_text}\",\n        f\"- 模拟卖出复核：{sell_review_text}\",\n        f\"- 执行门槛：{'需要人工确认' if trade_card.get('user_confirmation_required') else '系统可直接推进'}\",\n    ])\n    loop_entries = trade_card.get(\"trade_loop_buy_entries\", [])[:2]\n    for item in loop_entries:\n        lines.append(\n            f\"- {item.get('display') or item.get('ticker') or '-'}：{item.get('stage_label') or item.get('stage') or '-'}\"\n            f\" | 触发={item.get('trigger_hint') or '-'} | 止损/止盈={item.get('stop_loss') or '-'} / {item.get('take_profit') or '-'}\"\n        )\n    if should_include_execution_review_summary(meeting_type, trade_card):\n        review_item = trade_card[\"execution_review_entries\"][0]\n        lines.append(\n            f\"- 执行归因：{review_item.get('display') or review_item.get('ticker') or '-'} | \"\n            f\"{review_item.get('primary_attribution_label_cn') or '-'} | 下一步={review_item.get('primary_next_action') or '-'}\"\n        )\n\n    if trade_card.get(\"risk_off\"):\n        lines.append(\"- 当前结论：只保留观察名单和触发条件，不自动转成买单。\")\n    if not trade_card.get(\"trading_time\", False):\n        lines.append(\"- 当前非交易时段/非交易日，不提供可执行买价。\")\n    if event_watch.get(\"should_temporary_meet\"):\n        lines.append(\"- 事件监控：已触发临时会商建议。\")\n    if trade_card.get(\"paper_date_tag\") or paper_freshness:\n        lines.append(\n            f\"- 模拟盘快照：{trade_card.get('paper_date_tag') or '-'}\"\n            f\" | 新鲜度={cn_status(paper_freshness.get('status'))}\"\n        )\n        if paper_freshness.get(\"summary\"):\n            lines.append(f\"- 模拟盘说明：{paper_freshness.get('summary')}\")\n    if health_snapshot.get(\"status\"):\n        lines.append(\n            f\"- 数据源健康：{cn_status(health_snapshot.get('status'))}\"\n            f\" | 推荐模式={cn_status(health_snapshot.get('recommended_mode'))}\"\n        )\n    if ths:\n        lines.append(\n            f\"- THS本地行情：{cn_status(ths.get('status'))}\"\n\n[188 more lines in file. Use offset=270 to continue.]"}],"isError":false,"timestamp":1774446449369}}
