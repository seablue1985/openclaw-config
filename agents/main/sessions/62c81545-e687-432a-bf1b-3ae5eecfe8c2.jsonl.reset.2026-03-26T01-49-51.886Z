ts/personal-a-share-research-system","timeout":30},"partialJson":"{\"command\":\"cd /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system && python3 scripts/generate_single_stock_lens.py --help\",\"workdir\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system\",\"timeout\":30}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":144182,"output":150,"cacheRead":0,"cacheWrite":0,"totalTokens":144332,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774447416026}}
{"type":"message","id":"f2234ff3","parentId":"b3471096","timestamp":"2026-03-25T14:03:58.543Z","message":{"role":"toolResult","toolCallId":"call_REjEUgLy5Fw6nVXss9FSgVlx|fc_03f66048c5db434b0169c3eb4c83a481959f71d273ec82bce0","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport html\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\nimport akshare as ak\nimport baostock as bs\n\n\ndef get_stock_news(ts_code: str, limit: int = 5) -> dict:\n    \"\"\"获取个股新闻舆情\"\"\"\n    try:\n        import akshare as ak\n        # Extract code without exchange suffix\n        code = ts_code.split('.')[0]\n        df = ak.stock_news_em(symbol=code)\n        if df is not None and len(df) > 0:\n            news_list = []\n            for _, row in df.head(limit).iterrows():\n                news_list.append({\n                    \"title\": str(row.get(\"新闻标题\", \"\"))[:50],\n                    \"source\": str(row.get(\"文章来源\", \"\")),\n                    \"time\": str(row.get(\"发布时间\", \"\"))[:16],\n                })\n            return {\"news\": news_list, \"error\": None}\n    except Exception as e:\n        return {\"news\": [], \"error\": str(e)}\n    return {\"news\": [], \"error\": None}\n\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nPROFILES = [\"defensive\", \"balanced\", \"aggressive\"]\nDAILY_ANALYSIS_ROOT = Path('/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis')\nif str(DAILY_ANALYSIS_ROOT) not in sys.path:\n    sys.path.insert(0, str(DAILY_ANALYSIS_ROOT))\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef load_csv_rows(path: Path) -> list[dict[str, str]]:\n    if not path.exists():\n        return []\n    lines = path.read_text(encoding=\"utf-8-sig\").splitlines()\n    if not lines:\n        return []\n    header = [x.strip() for x in lines[0].split(\",\")]\n    rows: list[dict[str, str]] = []\n    for line in lines[1:]:\n        parts = line.split(\",\")\n        if len(parts) < len(header):\n            parts += [\"\"] * (len(header) - len(parts))\n        rows.append({header[i]: parts[i].strip() for i in range(len(header))})\n    return rows\n\n\ndef normalize_code(code: str) -> str:\n    text = str(code or \"\").strip().upper()\n    if not text:\n        return text\n    if text.endswith((\".SZ\", \".SH\", \".BJ\")):\n        return text\n    if text.endswith(\".XSHE\"):\n        return text[:6] + \".SZ\"\n    if text.endswith(\".XSHG\"):\n        return text[:6] + \".SH\"\n    digits = text.zfill(6)\n    if digits.startswith((\"6\", \"9\")):\n        return f\"{digits}.SH\"\n    if digits.startswith((\"4\", \"8\")):\n        return f\"{digits}.BJ\"\n    return f\"{digits}.SZ\"\n\n\ndef normalize_jq(code: str) -> str:\n    text = str(code or \"\").strip().upper()\n    if text.endswith(\".SZ\"):\n        return text[:6] + \".XSHE\"\n    if text.endswith(\".SH\"):\n        return text[:6] + \".XSHG\"\n    return text\n\n\ndef latest_path(pattern: str) -> Path | None:\n    matches = sorted(REPORT_DIR.glob(pattern))\n    return matches[-1] if matches else None\n\n\ndef run_instant_analysis(code: str) -> dict[str, Any]:\n    \"\"\"带超时的即时分析\"\"\"\n    import threading\n    \n    result_container = [None]\n    exception_container = [None]\n    \n    def target():\n        try:\n            from src.services.analysis_service import AnalysisService  # type: ignore\n            service = AnalysisService()\n            result_container[0] = service.analyze_stock(stock_code=code[:6], report_type=\"detailed\", force_refresh=False, send_notification=False)\n        except Exception as e:\n            exception_container[0] = e\n    \n    thread = threading.Thread(target=target)\n    thread.daemon = True\n    thread.start()\n    thread.join(timeout=8)  # 8秒超时\n    \n    if thread.is_alive():\n        return {\"error\": \"分析超时(8s)\", \"fallback\": True}\n    if exception_container[0]:\n        return {\"error\": str(exception_container[0]), \"fallback\": True}\n    return result_container[0] or {}\n\n\ndef calc_technical_indicators(code: str) -> dict[str, Any]:\n    \"\"\"计算技术指标，支持 akshare 和 baostock 双源\"\"\"\n    symbol = code[:6]\n    df = None\n    data_source = None\n    \n    # 尝试 akshare\n    try:\n        df = ak.stock_zh_a_hist(symbol=symbol, period='daily', adjust='qfq')\n        if df is not None and not df.empty and len(df) >= 35:\n            data_source = 'akshare'\n    except Exception:\n        pass\n    \n    # 回退到 baostock\n    if df is None or len(df) < 35:\n        try:\n            lg = bs.login()\n            if lg.error_code == '0':\n                bs_code = 'sz.' + symbol if symbol.startswith(('0', '3')) else 'sh.' + symbol\n                rs = bs.query_history_k_data_plus(bs_code,\n                    'date,open,high,low,close,volume',\n                    start_date='2025-01-01', end_date='2025-03-18',\n                    frequency='d', adjustflag='2')\n                data_list = []\n                while (rs.error_code == '0') & rs.next():\n                    data_list.append(rs.get_row_data())\n                bs.logout()\n                if data_list:\n                    df = pd.DataFrame(data_list, columns=rs.fields)\n                    df.columns = ['日期', '开盘', '最高', '最低', '收盘', '成交量']\n                    data_source = 'baostock'\n        except Exception:\n            pass\n    \n    if df is None or df.empty or len(df) < 35:\n        return {\"error\": \"历史行情不足\", \"fallback\": True}\n    \n    close = pd.to_numeric(df['收盘'], errors='coerce')\n    high = pd.to_numeric(df['最高'], errors='coerce')\n    low = pd.to_numeric(df['最低'], errors='coerce')\n    \n    ma10 = close.rolling(10).mean()\n    ma20 = close.rolling(20).mean()\n    \n    ema12 = close.ewm(span=12, adjust=False).mean()\n    ema26 = close.ewm(span=26, adjust=False).mean()\n    dif = ema12 - ema26\n    dea = dif.ewm(span=9, adjust=False).mean()\n    macd = (dif - dea) * 2\n    \n    delta = close.diff()\n    gain = delta.clip(lower=0)\n    loss = -delta.clip(upper=0)\n    avg_gain = gain.rolling(14).mean()\n    avg_loss = loss.rolling(14).mean()\n    rs_val = avg_gain / avg_loss.replace(0, pd.NA)\n    rsi14 = 100 - (100 / (1 + rs_val))\n    \n    low9 = low.rolling(9).min()\n    high9 = high.rolling(9).max()\n    rsv = (close - low9) / (high9 - low9).replace(0, pd.NA) * 100\n    k = rsv.ewm(com=2, adjust=False).mean()\n    d = k.ewm(com=2, adjust=False).mean()\n    j = 3 * k - 2 * d\n    \n    last_idx = close.last_valid_index()\n    if last_idx is None:\n        return {\"error\": \"无有效收盘价\", \"fallback\": True}\n    \n    latest = {\n        \"close\": round(float(close.loc[last_idx]), 2),\n        \"ma10\": round(float(ma10.loc[last_idx]), 2) if pd.notna(ma10.loc[last_idx]) else None,\n        \"ma20\": round(float(ma20.loc[last_idx]), 2) if pd.notna(ma20.loc[last_idx]) else None,\n        \"macd_dif\": round(float(dif.loc[last_idx]), 4) if pd.notna(dif.loc[last_idx]) else None,\n        \"macd_dea\": round(float(dea.loc[last_idx]), 4) if pd.notna(dea.loc[last_idx]) else None,\n        \"macd_hist\": round(float(macd.loc[last_idx]), 4) if pd.notna(macd.loc[last_idx]) else None,\n        \"rsi14\": round(float(rsi14.loc[last_idx]), 2) if pd.notna(rsi14.loc[last_idx]) else None,\n        \"kdj_k\": round(float(k.loc[last_idx]), 2) if pd.notna(k.loc[last_idx]) else None,\n        \"kdj_d\": round(float(d.loc[last_idx]), 2) if pd.notna(d.loc[last_idx]) else None,\n        \"kdj_j\": round(float(j.loc[last_idx]), 2) if pd.notna(j.loc[last_idx]) else None,\n        \"data_source\": data_source,\n    }\n    \n    latest['ma_signal'] = (\n        '偏强' if latest['ma10'] and latest['ma20'] and latest['close'] > latest['ma10'] > latest['ma20'] else\n        '走弱' if latest['ma10'] and latest['ma20'] and latest['close'] < latest['ma10'] < latest['ma20'] else\n        '震荡'\n    )\n    latest['macd_signal'] = (\n        '金叉区' if latest['macd_dif'] is not None and latest['macd_dea'] is not None and latest['macd_dif'] > latest['macd_dea'] else\n        '死叉区' if latest['macd_dif'] is not None and latest['macd_dea'] is not None and latest['macd_dif'] < latest['macd_dea'] else\n        '未知'\n    )\n    latest['rsi_signal'] = (\n        '超买' if latest['rsi14'] is not None and latest['rsi14'] >= 70 else\n        '超卖' if latest['rsi14'] is not None and latest['rsi14'] <= 30 else\n        '中性'\n    )\n    latest['kdj_signal'] = (\n        '高位' if latest['kdj_j'] is not None and latest['kdj_j'] >= 100 else\n        '低位' if latest['kdj_j'] is not None and latest['kdj_j'] <= 0 else\n        '中性'\n    )\n    \n    # BIAS 乖离率\n    ma5 = close.rolling(5).mean()\n    bias5 = (close - ma5) / ma5 * 100\n    latest['bias5'] = round(float(bias5.loc[last_idx]), 2) if pd.notna(bias5.loc[last_idx]) else None\n    latest['bias_signal'] = (\n        '超买' if latest['bias5'] is not None and latest['bias5'] > 10 else\n        '超卖' if latest['bias5'] is not None and latest['bias5'] < -10 else\n        '正常'\n    )\n    \n    return latest\n\n\ndef calc_volume_structure(code: str) -> dict[str, Any]:\n    \"\"\"量价结构分析\"\"\"\n    import baostock as bs\n    import pandas as pd\n    \n    symbol = code[:6]\n    bs_code = 'sz.' + symbol if symbol.startswith(('0', '3')) else 'sh.' + symbol\n    \n    try:\n        lg = bs.login()\n        rs = bs.query_history_k_data_plus(bs_code,\n            'date,open,high,low,close,volume,amount',\n            start_date='2025-02-01', end_date='2025-03-18',\n            frequency='d', adjustflag='2')\n        \n        data_list = []\n\n[902 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1774447438531}}
