’m thinking about creating a helper function called `should_include_execution_review_summary(meeting_type, trade_card)`. That could make it easier to edit the precise lines when needed. I'll take a moment to review the top functions and see how they are structured! Let's ensure I’m looking at the right functions for guidance.\"}]}"},{"type":"toolCall","id":"call_ixolPzNUm89L6rSXwmIj0cIw|fc_03f66048c5db434b0169c3e713e6208195b9bb80faff7263d8","name":"read","arguments":{"path":"scripts/push_investment_research_delivery.py","offset":1,"limit":220},"partialJson":"{\"path\":\"scripts/push_investment_research_delivery.py\",\"offset\":1,\"limit\":220}"}],"api":"openai-responses","provider":"codex","model":"gpt-5.4","usage":{"input":34165,"output":78,"cacheRead":96384,"cacheWrite":0,"totalTokens":130627,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774446341486}}
{"type":"message","id":"d72043ce","parentId":"61ea327f","timestamp":"2026-03-25T13:45:57.679Z","message":{"role":"toolResult","toolCallId":"call_ixolPzNUm89L6rSXwmIj0cIw|fc_03f66048c5db434b0169c3e713e6208195b9bb80faff7263d8","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom investment_research_health_snapshot import build_health_snapshot, build_ths_alert_line, latest_health_probe_for_date\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\nCONFIG_FILE = WORKSPACE / \"config\" / \"investment_research_delivery_v1.json\"\nSTATE_FILE = WORKSPACE / \"memory\" / \"investment_research_delivery_state.json\"\nOPENCLAW_BIN_CANDIDATES = [\n    str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"aliases\" / \"default\" / \"bin\" / \"openclaw\"),\n    shutil.which(\"openclaw\") or \"\",\n    \"openclaw\",\n]\n\nMEETING_LABELS = {\n    \"morning\": \"盘前会\",\n    \"midday\": \"午盘巡检\",\n    \"close\": \"收盘复盘\",\n    \"night\": \"夜间研究会\",\n}\n\nMEETING_EMOJIS = {\n    \"morning\": \"🌅\",\n    \"midday\": \"☀️\",\n    \"close\": \"📘\",\n    \"night\": \"🌙\",\n}\n\nSTATUS_LABELS = {\n    \"healthy\": \"健康\",\n    \"offhours_guarded\": \"非交易时段观察\",\n    \"watch_guarded\": \"警戒观察\",\n    \"degraded\": \"降级\",\n    \"normal\": \"正常\",\n    \"cautious\": \"谨慎\",\n    \"observe_defensive\": \"防守观察\",\n    \"halt\": \"暂停\",\n    \"ok\": \"正常\",\n    \"fallback\": \"已回退\",\n    \"failed\": \"部分失败\",\n    \"unavailable\": \"不可用\",\n    \"unknown\": \"未知\",\n    \"fresh\": \"今日已刷新\",\n    \"pending_today_refresh\": \"待今日刷新\",\n    \"stale\": \"已过期\",\n    \"missing\": \"缺失\",\n}\n\n\ndef now_str() -> str:\n    return datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n\ndef default_date_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    try:\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef write_json(path: Path, payload: dict[str, Any]) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n\n\ndef read_text(path: Path) -> str:\n    if not path.exists():\n        return \"\"\n    return path.read_text(encoding=\"utf-8\")\n\n\ndef cn_status(value: Any) -> str:\n    if value is None or value == \"\":\n        return \"-\"\n    return STATUS_LABELS.get(str(value), str(value))\n\n\ndef cn_text(value: Any) -> str:\n    if value is None or value == \"\":\n        return \"-\"\n    text = str(value)\n    replacements = {\n        \"public_source_divergence>\": \"公开网页源存在价差分歧 > \",\n        \"normal模式\": \"正常模式\",\n    }\n    for old, new in replacements.items():\n        text = text.replace(old, new)\n    return text\n\n\ndef resolve_openclaw_bin() -> str:\n    for candidate in OPENCLAW_BIN_CANDIDATES:\n        if candidate and Path(candidate).exists():\n            return candidate\n    for candidate in OPENCLAW_BIN_CANDIDATES:\n        if candidate:\n            return candidate\n    return \"openclaw\"\n\n\ndef run_cmd(cmd: list[str], timeout: int = 120) -> tuple[int, str, str]:\n    try:\n        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)\n        return proc.returncode, proc.stdout or \"\", proc.stderr or \"\"\n    except FileNotFoundError as exc:\n        return 127, \"\", str(exc)\n    except subprocess.TimeoutExpired as exc:\n        return 124, exc.stdout or \"\", exc.stderr or f\"timeout after {timeout}s\"\n\n\ndef selected_targets(config: dict[str, Any]) -> list[tuple[str, dict[str, Any]]]:\n    targets = config.get(\"targets\", {})\n    mode = str(config.get(\"deliveryMode\") or \"dm_and_group\")\n    ordered_names: list[str]\n    if mode == \"dm\":\n        ordered_names = [\"dm\"]\n    elif mode == \"group\":\n        ordered_names = [\"group\"]\n    else:\n        ordered_names = [\"dm\", \"group\"]\n\n    result: list[tuple[str, dict[str, Any]]] = []\n    for name in ordered_names:\n        payload = targets.get(name)\n        if isinstance(payload, dict) and payload.get(\"enabled\", True):\n            result.append((name, payload))\n    if result:\n        return result\n\n    for name, payload in targets.items():\n        if isinstance(payload, dict) and payload.get(\"enabled\", True):\n            result.append((str(name), payload))\n    return result\n\n\ndef compact_watchlist(items: list[Any], limit: int = 5) -> list[str]:\n    result: list[str] = []\n    for item in items[:limit]:\n        if isinstance(item, dict):\n            display = item.get(\"display\") or item.get(\"ticker\") or item.get(\"name\")\n            if display:\n                result.append(str(display))\n        elif item:\n            result.append(str(item))\n    return result\n\n\ndef compact_sell_review(items: list[Any], limit: int = 5) -> list[str]:\n    result: list[str] = []\n    for item in items[:limit]:\n        if isinstance(item, dict):\n            display = item.get(\"display\") or item.get(\"ticker\") or item.get(\"name\")\n            reason = item.get(\"reason\") or item.get(\"action\")\n            if display and reason:\n                result.append(f\"{display} | {reason}\")\n            elif display:\n                result.append(str(display))\n        elif item:\n            result.append(str(item))\n    return result\n\n\ndef resolve_health_snapshot(date_tag: str, bundle: dict[str, Any], control_tower: dict[str, Any]) -> dict[str, Any]:\n    health_scope, health_probe, health_path = latest_health_probe_for_date(REPORT_DIR, date_tag)\n    if health_probe:\n        return build_health_snapshot(health_scope, health_probe, health_path)\n    health_snapshot = control_tower.get(\"health_probe\", {}) if isinstance(control_tower.get(\"health_probe\"), dict) else {}\n    if health_snapshot:\n        return health_snapshot\n    bundle_probe = bundle.get(\"data_source_health\", {}) if isinstance(bundle.get(\"data_source_health\"), dict) else {}\n    if bundle_probe:\n        return build_health_snapshot(bundle_probe.get(\"scope\"), bundle_probe, None)\n    return {}\n\n\ndef build_message(\n    meeting_type: str,\n    date_tag: str,\n    trade_card: dict[str, Any],\n    bundle: dict[str, Any],\n    health_snapshot: dict[str, Any],\n) -> str:\n    watchlist = compact_watchlist(trade_card.get(\"watchlist\", []))\n    sell_review = compact_sell_review(trade_card.get(\"sell_review_list\", []))\n    event_watch = bundle.get(\"event_watch\", {}) if isinstance(bundle.get(\"event_watch\"), dict) else {}\n    ths = health_snapshot.get(\"ths_market\", {}) if isinstance(health_snapshot.get(\"ths_market\"), dict) else {}\n    paper_freshness = trade_card.get(\"paper_execution_freshness\", {}) if isinstance(trade_card.get(\"paper_execution_freshness\"), dict) else {}\n    risk_text = \"偏防守\" if trade_card.get(\"risk_off\") else \"条件化推进\"\n    watchlist_text = \"、\".join(watchlist) if watchlist else str(trade_card.get(\"watchlist_reason\") or \"暂无\")\n    sell_review_text = \"、\".join(sell_review) if sell_review else str(trade_card.get(\"sell_review_reason\") or \"暂无\")\n    alert_line = build_ths_alert_line(health_snapshot)\n\n    lines: list[str] = []\n    if alert_line:\n        lines.append(f\"[THS告警] {alert_line}\")\n\n    lines.extend([\n        f\"{MEETING_EMOJIS.get(meeting_type, '📊')} 模拟交易提示｜{MEETING_LABELS.get(meeting_type, meeting_type)}｜{date_tag}\",\n        f\"- 风险状态：{risk_text}\",\n        f\"- 模拟买入观察：{watchlist_text}\",\n        f\"- 模拟卖出复核：{sell_review_text}\",\n        f\"- 执行门槛：{'需要人工确认' if trade_card.get('user_confirmation_required') else '系统可直接推进'}\",\n    ])\n    loop