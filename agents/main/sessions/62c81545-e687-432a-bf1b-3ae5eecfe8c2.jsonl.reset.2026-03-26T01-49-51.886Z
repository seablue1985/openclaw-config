{"type":"message","id":"8ab01c1f","parentId":"61f097a3","timestamp":"2026-03-25T13:44:41.924Z","message":{"role":"toolResult","toolCallId":"call_vKMWBEE1fzalM2ncDIs6gKYJ|fc_03f66048c5db434b0169c3e6c903ec81958fd66b25857f01c8","toolName":"read","content":[{"type":"text","text":"    health_scope, health_probe, health_path = latest_health_probe_for_date(REPORT_DIR, date_tag)\n    if health_probe:\n        return build_health_snapshot(health_scope, health_probe, health_path)\n    health_snapshot = control_tower.get(\"health_probe\", {}) if isinstance(control_tower.get(\"health_probe\"), dict) else {}\n    if health_snapshot:\n        return health_snapshot\n    bundle_probe = bundle.get(\"data_source_health\", {}) if isinstance(bundle.get(\"data_source_health\"), dict) else {}\n    if bundle_probe:\n        return build_health_snapshot(bundle_probe.get(\"scope\"), bundle_probe, None)\n    return {}\n\n\ndef build_message(\n    meeting_type: str,\n    date_tag: str,\n    trade_card: dict[str, Any],\n    bundle: dict[str, Any],\n    health_snapshot: dict[str, Any],\n) -> str:\n    watchlist = compact_watchlist(trade_card.get(\"watchlist\", []))\n    sell_review = compact_sell_review(trade_card.get(\"sell_review_list\", []))\n    event_watch = bundle.get(\"event_watch\", {}) if isinstance(bundle.get(\"event_watch\"), dict) else {}\n    ths = health_snapshot.get(\"ths_market\", {}) if isinstance(health_snapshot.get(\"ths_market\"), dict) else {}\n    paper_freshness = trade_card.get(\"paper_execution_freshness\", {}) if isinstance(trade_card.get(\"paper_execution_freshness\"), dict) else {}\n    risk_text = \"偏防守\" if trade_card.get(\"risk_off\") else \"条件化推进\"\n    watchlist_text = \"、\".join(watchlist) if watchlist else str(trade_card.get(\"watchlist_reason\") or \"暂无\")\n    sell_review_text = \"、\".join(sell_review) if sell_review else str(trade_card.get(\"sell_review_reason\") or \"暂无\")\n    alert_line = build_ths_alert_line(health_snapshot)\n\n    lines: list[str] = []\n    if alert_line:\n        lines.append(f\"[THS告警] {alert_line}\")\n\n    lines.extend([\n        f\"{MEETING_EMOJIS.get(meeting_type, '📊')} 模拟交易提示｜{MEETING_LABELS.get(meeting_type, meeting_type)}｜{date_tag}\",\n        f\"- 风险状态：{risk_text}\",\n        f\"- 模拟买入观察：{watchlist_text}\",\n        f\"- 模拟卖出复核：{sell_review_text}\",\n        f\"- 执行门槛：{'需要人工确认' if trade_card.get('user_confirmation_required') else '系统可直接推进'}\",\n    ])\n    loop_entries = trade_card.get(\"trade_loop_buy_entries\", [])[:2]\n    for item in loop_entries:\n        lines.append(\n            f\"- {item.get('display') or item.get('ticker') or '-'}：{item.get('stage_label') or item.get('stage') or '-'}\"\n            f\" | 触发={item.get('trigger_hint') or '-'} | 止损/止盈={item.get('stop_loss') or '-'} / {item.get('take_profit') or '-'}\"\n        )\n    if meeting_type in {\"close\", \"night\"} and trade_card.get(\"execution_review_entries\"):\n        review_item = trade_card[\"execution_review_entries\"][0]\n        lines.append(\n            f\"- 执行归因：{review_item.get('display') or review_item.get('ticker') or '-'} | \"\n            f\"{review_item.get('primary_attribution_label_cn') or '-'} | 下一步={review_item.get('primary_next_action') or '-'}\"\n        )\n\n    if trade_card.get(\"risk_off\"):\n        lines.append(\"- 当前结论：只保留观察名单和触发条件，不自动转成买单。\")\n    if not trade_card.get(\"trading_time\", False):\n        lines.append(\"- 当前非交易时段/非交易日，不提供可执行买价。\")\n    if event_watch.get(\"should_temporary_meet\"):\n        lines.append(\"- 事件监控：已触发临时会商建议。\")\n    if trade_card.get(\"paper_date_tag\") or paper_freshness:\n        lines.append(\n            f\"- 模拟盘快照：{trade_card.get('paper_date_tag') or '-'}\"\n            f\" | 新鲜度={cn_status(paper_freshness.get('status'))}\"\n        )\n        if paper_freshness.get(\"summary\"):\n            lines.append(f\"- 模拟盘说明：{paper_freshness.get('summary')}\")\n    if health_snapshot.get(\"status\"):\n        lines.append(\n            f\"- 数据源健康：{cn_status(health_snapshot.get('status'))}\"\n            f\" | 推荐模式={cn_status(health_snapshot.get('recommended_mode'))}\"\n        )\n    if ths:\n        lines.append(\n            f\"- THS本地行情：{cn_status(ths.get('status'))}\"\n            f\" | THS命中/回退/失败={ths.get('ok_count', 0)}/{ths.get('fallback_count', 0)}/{ths.get('failed_count', 0)}\"\n        )\n        lines.append(f\"- THS摘要：{ths.get('summary') or '-'}\")\n    if health_snapshot.get(\"observations\"):\n        lines.append(f\"- 观察项：{'、'.join(cn_text(item) for item in health_snapshot.get('observations', [])[:2])}\")\n    return \"\\n\".join(lines)\n\n\ndef dedupe_key(\n    meeting_type: str,\n    date_tag: str,\n    target_name: str,\n    target_value: str,\n    message: str,\n    card_payload: dict[str, Any] | None,\n) -> str:\n    base = {\n        \"meeting_type\": meeting_type,\n        \"date_tag\": date_tag,\n        \"target_name\": target_name,\n        \"target_value\": target_value,\n        \"message\": message,\n        \"card\": card_payload or {},\n    }\n    raw = json.dumps(base, ensure_ascii=False, sort_keys=True)\n    return hashlib.sha256(raw.encode(\"utf-8\")).hexdigest()\n\n\ndef send_payload(\n    *,\n    channel: str,\n    account: str,\n    target: str,\n    message: str,\n    card_payload: dict[str, Any] | None,\n    dry_run: bool,\n) -> tuple[bool, str]:\n    cmd = [\n        resolve_openclaw_bin(),\n        \"message\",\n        \"send\",\n        \"--channel\",\n        channel,\n        \"--account\",\n        account,\n        \"--target\",\n\n[142 more lines in file. Use offset=300 to continue.]"}],"isError":false,"timestamp":1774446281909}}
