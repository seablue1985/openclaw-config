ased on app assets. If model files are present in the assets folder, the app could auto-seed them on first launch, which would benefit both current users and future updates.\"}]}"},{"type":"toolCall","id":"call_7pQLEVDqyZZ5Gmeb52PgczsV|fc_04b76fdf640436710169b75c01382081a0862bdb57b617f85f","name":"read","arguments":{"file_path":"/Users/ling/.openclaw/workspace/apps/kids-box-tv-app/app/src/main/java/com/openclaw/kidsboxtv/audio/SpeechPracticeEngineFactory.kt","offset":1,"limit":220},"partialJson":"{\"file_path\":\"/Users/ling/.openclaw/workspace/apps/kids-box-tv-app/app/src/main/java/com/openclaw/kidsboxtv/audio/SpeechPracticeEngineFactory.kt\",\"offset\":1,\"limit\":220}"},{"type":"toolCall","id":"call_3f6qEzfIfDfsjpLnRhahpIDT|fc_04b76fdf640436710169b75c01383081a086f5719b916d0c1f","name":"read","arguments":{"file_path":"/Users/ling/.openclaw/workspace/apps/kids-box-tv-app/app/src/main/java/com/openclaw/kidsboxtv/data/AppSettingsRepository.kt","offset":1,"limit":220},"partialJson":"{\"file_path\":\"/Users/ling/.openclaw/workspace/apps/kids-box-tv-app/app/src/main/java/com/openclaw/kidsboxtv/data/AppSettingsRepository.kt\",\"offset\":1,\"limit\":220}"},{"type":"toolCall","id":"call_VEUr0kWhdDUF8mQVUDGoyXPW|fc_04b76fdf640436710169b75c01383c81a09ae34c1b72c1a82e","name":"read","arguments":{"file_path":"/Users/ling/.openclaw/workspace/apps/kids-box-tv-app/app/src/main/java/com/openclaw/kidsboxtv/data/AsrEngineMode.kt","offset":1,"limit":120},"partialJson":"{\"file_path\":\"/Users/ling/.openclaw/workspace/apps/kids-box-tv-app/app/src/main/java/com/openclaw/kidsboxtv/data/AsrEngineMode.kt\",\"offset\":1,\"limit\":120}"},{"type":"toolCall","id":"call_C5EO3kNDnJoXTTihLGYFXO5H|fc_04b76fdf640436710169b75c01384481a0a53c9a63996a7f67","name":"read","arguments":{"file_path":"/Users/ling/.openclaw/workspace/apps/kids-box-tv-app/app/src/main/java/com/openclaw/kidsboxtv/audio/SpeechPracticeRecognizer.kt","offset":1,"limit":260},"partialJson":"{\"file_path\":\"/Users/ling/.openclaw/workspace/apps/kids-box-tv-app/app/src/main/java/com/openclaw/kidsboxtv/audio/SpeechPracticeRecognizer.kt\",\"offset\":1,\"limit\":260}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":13252,"output":762,"cacheRead":90368,"cacheWrite":0,"totalTokens":104382,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773624294738}}
{"type":"message","id":"68386cf2","parentId":"a63cdf1b","timestamp":"2026-03-16T01:25:22.182Z","message":{"role":"toolResult","toolCallId":"call_7pQLEVDqyZZ5Gmeb52PgczsV|fc_04b76fdf640436710169b75c01382081a0862bdb57b617f85f","toolName":"read","content":[{"type":"text","text":"package com.openclaw.englishworkbook.audio\n\nimport android.content.Context\nimport com.openclaw.englishworkbook.data.AppSettingsRepository\nimport com.openclaw.englishworkbook.data.AsrEngineMode\n\nobject SpeechPracticeEngineFactory {\n    fun create(\n        context: Context,\n        settingsRepository: AppSettingsRepository,\n    ): SpeechPracticeEngine {\n        return when (settingsRepository.asrEngineMode()) {\n            AsrEngineMode.SYSTEM -> SpeechPracticeRecognizer(context)\n            AsrEngineMode.SHERPA_ONNX -> SherpaOnnxSpeechPracticeEngine(context, settingsRepository)\n        }\n    }\n}\n"}],"isError":false,"timestamp":1773624322177}}
{"type":"message","id":"7f9ba89a","parentId":"68386cf2","timestamp":"2026-03-16T01:25:22.193Z","message":{"role":"toolResult","toolCallId":"call_3f6qEzfIfDfsjpLnRhahpIDT|fc_04b76fdf640436710169b75c01383081a086f5719b916d0c1f","toolName":"read","content":[{"type":"text","text":"package com.openclaw.englishworkbook.data\n\nimport android.content.Context\n\nclass AppSettingsRepository(context: Context) {\n    private val prefs = context.getSharedPreferences(\"kids_box_settings\", Context.MODE_PRIVATE)\n\n    fun autoSpeakEnglish(): Boolean = prefs.getBoolean(\"auto_speak_english\", false)\n\n    fun setAutoSpeakEnglish(enabled: Boolean) {\n        prefs.edit().putBoolean(\"auto_speak_english\", enabled).apply()\n    }\n\n    fun asrEngineMode(): AsrEngineMode {\n        val raw = prefs.getString(\"asr_engine_mode\", AsrEngineMode.SYSTEM.name) ?: AsrEngineMode.SYSTEM.name\n        return AsrEngineMode.entries.firstOrNull { it.name == raw } ?: AsrEngineMode.SYSTEM\n    }\n\n    fun setAsrEngineMode(mode: AsrEngineMode) {\n        prefs.edit().putString(\"asr_engine_mode\", mode.name).apply()\n    }\n\n    fun sherpaOnnxSettings(): SherpaOnnxSettings {\n        return SherpaOnnxSettings(\n            enabled = prefs.getBoolean(\"sherpa_onnx_enabled\", false),\n            modelId = prefs.getString(\"sherpa_onnx_model_id\", \"english-zipformer-small\") ?: \"english-zipformer-small\",\n        )\n    }\n\n    fun setSherpaOnnxEnabled(enabled: Boolean) {\n        prefs.edit().putBoolean(\"sherpa_onnx_enabled\", enabled).apply()\n    }\n\n    fun setSherpaOnnxModelId(modelId: String) {\n        prefs.edit().putString(\"sherpa_onnx_model_id\", modelId).apply()\n    }\n}\n"}],"isError":false,"timestamp":1773624322188}}
{"type":"message","id":"aca56119","parentId":"7f9ba89a","timestamp":"2026-03-16T01:25:22.204Z","message":{"role":"toolResult","toolCallId":"call_VEUr0kWhdDUF8mQVUDGoyXPW|fc_04b76fdf640436710169b75c01383c81a09ae34c1b72c1a82e","toolName":"read","content":[{"type":"text","text":"package com.openclaw.englishworkbook.data\n\nenum class AsrEngineMode {\n    SYSTEM,\n    SHERPA_ONNX,\n}\n"}],"isError":false,"timestamp":1773624322199}}
{"type":"message","id":"311e2780","parentId":"aca56119","timestamp":"2026-03-16T01:25:22.219Z","message":{"role":"toolResult","toolCallId":"call_C5EO3kNDnJoXTTihLGYFXO5H|fc_04b76fdf640436710169b75c01384481a0a53c9a63996a7f67","toolName":"read","content":[{"type":"text","text":"package com.openclaw.englishworkbook.audio\n\nimport android.Manifest\nimport android.content.Context\nimport android.content.Intent\nimport android.content.pm.PackageManager\nimport android.os.Build\nimport android.os.Bundle\nimport android.speech.RecognitionListener\nimport android.speech.RecognitionService\nimport android.speech.RecognizerIntent\nimport android.speech.SpeechRecognizer\nimport androidx.compose.runtime.getValue\nimport androidx.compose.runtime.mutableStateOf\nimport androidx.compose.runtime.setValue\nimport androidx.core.content.ContextCompat\nimport java.util.Locale\n\ndata class SpeechPracticeResult(\n    val attemptId: Int,\n    val targetLabel: String,\n    val targetRewardId: String,\n    val score: ReadAlongScore,\n)\n\nclass SpeechPracticeRecognizer(private val context: Context) : SpeechPracticeEngine {\n    private var recognizer: SpeechRecognizer? = null\n\n    override var isListening by mutableStateOf(false)\n        private set\n    override var statusMessage by mutableStateOf(initialStatus())\n        private set\n    override var lastResult by mutableStateOf<SpeechPracticeResult?>(null)\n        private set\n    override var lastErrorCode by mutableStateOf(0)\n        private set\n    override var lastErrorAttemptId by mutableStateOf(0)\n        private set\n\n    private var currentTargetText: String = \"\"\n    private var currentTargetLabel: String = \"\"\n    private var currentTargetRewardId: String = \"\"\n    private var nextAttemptId: Int = 1\n    private var currentAttemptId: Int = 0\n\n    override fun isAvailable(): Boolean = SpeechRecognizer.isRecognitionAvailable(context)\n\n    private fun hasMicPermission(): Boolean {\n        return ContextCompat.checkSelfPermission(context, Manifest.permission.RECORD_AUDIO) == PackageManager.PERMISSION_GRANTED\n    }\n\n    private fun recognitionServicePackages(): List<String> {\n        val intent = Intent(RecognitionService.SERVICE_INTERFACE)\n        val services = if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {\n            context.packageManager.queryIntentServices(intent, PackageManager.ResolveInfoFlags.of(0))\n        } else {\n            @Suppress(\"DEPRECATION\")\n            context.packageManager.queryIntentServices(intent, 0)\n        }\n        return services.mapNotNull { it.serviceInfo?.packageName }.distinct().sorted()\n    }\n\n    private fun debugSummary(): String {\n        val mic = if (hasMicPermission()) \"mic=granted\" else \"mic=missing\"\n        val available = if (isAvailable()) \"recognizer=available\" else \"recognizer=missing\"\n        val services = recognitionServicePackages().joinToString(\", \").ifBlank { \"none\" }\n        return \"$mic, $available, services=$services\"\n    }\n\n    private fun preparePracticeTarget(targetText: String, targetLabel: String, targetRewardId: String): Boolean {\n        if (!hasMicPermission()) {\n            statusMessage = \"App 还没有麦克风权限，请在系统设置里允许麦克风访问（${debugSummary()}）\"\n            return false\n        }\n        val normalizedTarget = targetText.trim()\n        if (normalizedTarget.isBlank()) {\n            statusMessage = \"当前题目没有可跟读的英文内容\"\n            return false\n        }\n        currentTargetText = normalizedTarget\n        currentTargetLabel = targetLabel\n        currentTargetRewardId = targetRewardId.trim()\n        currentAttemptId = nextAttemptId++\n        lastResult = null\n        lastErrorCode = 0\n        lastErrorAttemptId = 0\n        return true\n    }\n\n    override fun startPractice(targetText: String, targetLabel: String, targetRewardId: String): Boolean {\n        if (!preparePracticeTarget(targetText, targetLabel, targetRewardId)) {\n            return false\n        }\n        if (!isAvailable()) {\n            statusMessage = \"未检测到系统语音识别服务，请检查系统语音输入/Google 语音识别是否可用（${debugSummary()}）\"\n            return false\n        }\n        ensureRecognizer()\n        statusMessage = \"准备开始，请对着麦克风读出来\"\n        recognizer?.cancel()\n        recognizer?.startListening(buildIntent(forceEnglish = true, includePrompt = true))\n        return true\n    }\n\n    override fun buildFallbackIntent(targetText: String, targetLabel: String, targetRewardId: String): Intent? {\n        if (!preparePracticeTarget(targetText, targetLabel, targetRewardId)) {\n            return null\n        }\n        return buildFallbackIntentForCurrentTarget()\n    }\n\n    override fun buildFallbackIntentForCurrentTarget(): Intent? {\n        if (!hasMicPermission()) {\n            statusMessage = \"App 还没有麦克风权限，请在系统设置里允许麦克风访问（${debugSummary()}）\"\n            return null\n        }\n        if (currentTargetText.isBlank()) {\n            statusMessage = \"当前题目没有可跟读的英文内容\"\n            return null\n        }\n        val intent = buildIntent(\n            action = RecognizerIntent.ACTION_RECOGNIZE_SPEECH,\n            forceEnglish = false,\n            includePrompt = false,\n        )\n        return if (intent.resolveActivity(context.packageManager) != null) {\n            statusMessage = \"正在打开系统语音识别（兼容模式）…\"\n            intent\n        } else {\n            statusMessage = \"系统里没有可用的语音识别界面（${debugSummary()}）\"\n            null\n        }\n    }\n\n    override fun shouldAutoFallback(error: Int): Boolean {\n        return error == SpeechRecognizer.ERROR_INSUFFICIENT_PERMISSIONS ||\n            error == SpeechRecognizer.ERROR_CLIENT ||\n            error == SpeechRecognizer.ERROR_SERVER\n    }\n\n    override fun reset() {\n        if (isListening) {\n            recognizer?.cancel()\n        }\n        isListening = false\n        lastResult = null\n        lastErrorCode = 0\n        lastErrorAttemptId = 0\n        statusMessage = initialStatus()\n        currentTargetText = \"\"\n        currentTargetLabel = \"\"\n        currentTargetRewardId = \"\"\n        currentAttemptId = 0\n    }\n\n    override fun shutdown() {\n        recognizer?.cancel()\n        recognizer?.destroy()\n        recognizer = null\n    }\n\n    private fun ensureRecognizer() {\n        if (recognizer != null) return\n        recognizer = SpeechRecognizer.createSpeechRecognizer(context).apply {\n            setRecognitionListener(object : RecognitionListener {\n                override fun onReadyForSpeech(params: Bundle?) {\n                    isListening = true\n                    statusMessage = \"开始跟读吧…\"\n                }\n\n                override fun onBeginningOfSpeech() {\n                    isListening = true\n                    statusMessage = \"正在听…\"\n                }\n\n                override fun onRmsChanged(rmsdB: Float) = Unit\n\n                override fun onBufferReceived(buffer: ByteArray?) = Unit\n\n                override fun onEndOfSpeech() {\n                    isListening = false\n                    statusMessage = \"识别中…\"\n                }\n\n                override fun onError(error: Int) {\n                    isListening = false\n                    lastErrorCode = error\n                    lastErrorAttemptId = currentAttemptId\n                    statusMessage = mapError(error)\n                }\n\n                override fun onResults(results: Bundle?) {\n                    isListening = false\n                    val matches = results?.getStringArrayList(SpeechRecognizer.RESULTS_RECOGNITION).orEmpty()\n                    applyRecognitionMatches(matches)\n                }\n\n                override fun onPartialResults(partialResults: Bundle?) = Unit\n\n                override fun onEvent(eventType: Int, params: Bundle?) = Unit\n            })\n        }\n    }\n\n    override fun handleFallbackResult(data: Intent?): Boolean {\n        isListening = false\n        val matches = data?.getStringArrayListExtra(RecognizerIntent.EXTRA_RESULTS).orEmpty()\n        return applyRecognitionMatches(matches)\n    }\n\n    override fun handleFallbackCancelled() {\n        isListening = false\n        statusMessage = \"已取消跟读\"\n    }\n\n    private fun applyRecognitionMatches(matches: List<String>): Boolean {\n        val recognized = matches.firstOrNull().orEmpty().trim()\n        if (recognized.isBlank()) {\n            statusMessage = \"没听清，再试一次\"\n            lastResult = null\n            return false\n        }\n        val score = ReadAlongScorer.score(currentTargetText, recognized)\n        lastResult = SpeechPracticeResult(\n            attemptId = currentAttemptId,\n            targetLabel = currentTargetLabel,\n            targetRewardId = currentTargetRewardId,\n            score = score,\n        )\n        statusMessage = \"${score.encouragementTitle}，${score.encouragementDetail}\"\n        return true\n    }\n\n    private fun buildIntent(\n        action: String = RecognizerIntent.ACTION_RECOGNIZE_SPEECH,\n        forceEnglish: Boolean,\n        includePrompt: Boolean,\n    ): Intent {\n        return Intent(action).apply {\n            putExtra(RecognizerIntent.EXTRA_LANGUAGE_MODEL, RecognizerIntent.LANGUAGE_MODEL_FREE_FORM)\n            if (forceEnglish) {\n                putExtra(RecognizerIntent.EXTRA_LANGUAGE, Locale.US.toLanguageTag())\n                putExtra(RecognizerIntent.EXTRA_LANGUAGE_PREFERENCE, Locale.US.toLanguageTag())\n            }\n            putExtra(RecognizerIntent.EXTRA_MAX_RESULTS, 3)\n            putExtra(RecognizerIntent.EXTRA_PARTIAL_RESULTS, false)\n            if (includePrompt) {\n                putExtra(RecognizerIntent.EXTRA_PROMPT, \"请跟读英文\")\n            }\n        }\n    }\n\n    private fun initialStatus(): String {\n        return if (isAvailable()) {\n            \"点击按钮开始跟读打分\"\n        } else {\n            \"未检测到系统语音识别服务\"\n        }\n    }\n\n\n[21 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1773624322211}}
