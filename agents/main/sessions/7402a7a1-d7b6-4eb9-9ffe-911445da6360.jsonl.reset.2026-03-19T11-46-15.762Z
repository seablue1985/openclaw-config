{"type":"message","id":"58b0f4cf","parentId":"7f6a7c56","timestamp":"2026-03-16T08:43:33.097Z","message":{"role":"toolResult","toolCallId":"call_FCKhv3Y5i04ANhD6ZuvOqAm2","toolName":"read","content":[{"type":"text","text":"package com.openclaw.englishworkbook.audio\n\nimport android.content.Context\nimport android.util.Base64\nimport androidx.compose.runtime.getValue\nimport androidx.compose.runtime.mutableStateOf\nimport androidx.compose.runtime.setValue\nimport kotlinx.coroutines.*\nimport okhttp3.*\nimport com.google.gson.Gson\nimport com.google.gson.annotations.SerializedName\nimport com.openclaw.englishworkbook.data.ReadAlongScore\nimport com.openclaw.englishworkbook.data.WordFeedback\nimport okhttp3.HttpUrl.Companion.toHttpUrl\nimport org.json.JSONException\nimport org.json.JSONObject\nimport java.net.URLEncoder\nimport java.nio.charset.Charset\nimport java.text.SimpleDateFormat\nimport java.util.*\nimport javax.crypto.Mac\nimport javax.crypto.spec.SecretKeySpec\n\nclass IFlytekSpeechPracticeEngine(\n    private val context: Context\n) : SpeechPracticeEngine {\n\n    // 讯飞星火认证信息 (硬编码集成)\n    private val APPID = \"f9a02e2c\"\n    private val APISecret = \"ODMwYzcyMGMxYjljZWZhZWYxYWY2MjNj\"\n    private val APIKey = \"26daf21b1361ea9ab74089e3bb212b01\"\n    private val HOST_URL = \"wss://spark-openapi.cn-huabei-1.xf-yun.com/api/v1/voice-insight\"\n\n    private val scope = CoroutineScope(Dispatchers.Main + SupervisorJob())\n    private val client = OkHttpClient()\n    private var webSocket: WebSocket? = null\n\n    override var isListening by mutableStateOf(false)\n        private set\n    override var statusMessage by mutableStateOf(\"点击开始跟读 (讯飞星火)\")\n        private set\n    override var lastResult by mutableStateOf<SpeechPracticeResult?>(null)\n        private set\n    override var lastErrorCode by mutableStateOf(0)\n        private set\n    override var lastErrorAttemptId by mutableStateOf(0)\n        private set\n\n    private var currentTargetText: String = \"\"\n    private var currentTargetLabel: String = \"\"\n    private var currentTargetRewardId: String = \"\"\n    private var nextAttemptId: Int = 1\n    private var currentAttemptId: Int = 0\n\n    private val recorder = PcmAudioRecorder()\n\n    override fun isAvailable(): Boolean = true\n\n    override fun startPractice(targetText: String, targetLabel: String, targetRewardId: String): Boolean {\n        currentTargetText = targetText.trim()\n        currentTargetLabel = targetLabel\n        currentTargetRewardId = targetRewardId.trim()\n        currentAttemptId = nextAttemptId++\n        \n        lastResult = null\n        lastErrorCode = 0\n        lastErrorAttemptId = 0\n\n        isListening = true\n        statusMessage = \"正在连接讯飞星火...\"\n\n        scope.launch {\n            try {\n                connectWebSocket()\n            } catch (e: Exception) {\n                statusMessage = \"连接失败: ${e.message}\"\n                isListening = false\n                e.printStackTrace()\n            }\n        }\n\n        return true\n    }\n\n    private fun connectWebSocket() {\n        val authUrl = getAuthUrl(HOST_URL, APIKey, APISecret)\n        val request = Request.Builder().url(authUrl).build()\n\n        webSocket = client.newWebSocket(request, object : WebSocketListener() {\n            override fun onOpen(webSocket: WebSocket, response: Response) {\n                statusMessage = \"连接成功，请开始朗读...\"\n                sendStartFrame(webSocket)\n                startRecording(webSocket)\n            }\n\n            override fun onMessage(webSocket: WebSocket, text: String) {\n                handleMessage(text)\n            }\n\n            override fun onFailure(webSocket: WebSocket, t: Throwable, response: Response?) {\n                scope.launch {\n                    statusMessage = \"连接断开: ${t.message}\"\n                    isListening = false\n                }\n                t.printStackTrace()\n            }\n\n            override fun onClosed(webSocket: WebSocket, code: Int, reason: String) {\n                scope.launch {\n                    if (isListening) {\n                        statusMessage = \"连接关闭\"\n                        isListening = false\n                    }\n                }\n            }\n        })\n    }\n\n    private fun sendStartFrame(ws: WebSocket) {\n        val frame = JSONObject().apply {\n            put(\"header\", JSONObject().apply {\n                put(\"app_id\", APPID)\n                put(\"status\", 0) // 0: 首帧\n            })\n            put(\"parameter\", JSONObject().apply {\n                put(\"oral\", JSONObject().apply {\n                    put(\"oral_level\", \"mid\") // 中学水平，适合通用\n                    put(\"scflg\", 0)\n                    put(\"audio_rate\", 16000)\n                    put(\"audio_format\", \"raw\")\n                    put(\"channel\", 1)\n                })\n                put(\"tts\", JSONObject().apply {\n                    put(\"text\", currentTargetText) // 评测文本\n                    put(\"mode\", \"word\") // 单词模式，如果是句子可以用 \"sentence\"\n                })\n            })\n            put(\"payload\", JSONObject().apply {\n                put(\"audio\", JSONObject().apply {\n                    put(\"encoding\", \"raw\")\n                    put(\"sample_rate\", 16000)\n                    put(\"status\", 0)\n                })\n            })\n        }\n        ws.send(frame.toString())\n    }\n\n    private fun startRecording(ws: WebSocket) {\n        scope.launch(Dispatchers.IO) {\n            if (!recorder.prepare() || !recorder.start()) {\n                withContext(Dispatchers.Main) {\n                    statusMessage = \"录音启动失败\"\n                    isListening = false\n                    ws.close(1000, \"Recorder failed\")\n                }\n                return@launch\n            }\n\n            val buffer = ByteArray(1280) // 40ms for 16k sample rate\n            var readSize: Int\n            val startTime = System.currentTimeMillis()\n\n            // 录音 5 秒\n            while (isListening && System.currentTimeMillis() - startTime < 5000) {\n                val shorts = recorder.readChunk()\n                if (shorts.isNotEmpty()) {\n                    // Convert ShortArray to ByteArray\n                    val bytes = ByteArray(shorts.size * 2)\n                    java.nio.ByteBuffer.wrap(bytes).order(java.nio.ByteOrder.LITTLE_ENDIAN).asShortBuffer().put(shorts)\n                    \n                    val audioData = Base64.encodeToString(bytes, Base64.NO_WRAP)\n                    val frame = JSONObject().apply {\n                        put(\"header\", JSONObject().apply {\n                            put(\"app_id\", APPID)\n                            put(\"status\", 1) // 1: 中间帧\n                        })\n                        put(\"payload\", JSONObject().apply {\n                            put(\"audio\", JSONObject().apply {\n                                put(\"encoding\", \"raw\")\n                                put(\"sample_rate\", 16000)\n                                put(\"status\", 1)\n                                put(\"audio\", audioData)\n                            })\n                        })\n                    }\n                    ws.send(frame.toString())\n                }\n                delay(40)\n            }\n\n            recorder.stop()\n            recorder.release()\n\n            // 发送结束帧\n            val endFrame = JSONObject().apply {\n                put(\"header\", JSONObject().apply {\n                    put(\"app_id\", APPID)\n                    put(\"status\", 2) // 2: 尾帧\n                })\n                put(\"payload\", JSONObject().apply {\n                    put(\"audio\", JSONObject().apply {\n                        put(\"encoding\", \"raw\")\n                        put(\"sample_rate\", 16000)\n                        put(\"status\", 2)\n                        put(\"audio\", \"\")\n                    })\n                })\n            }\n            ws.send(endFrame.toString())\n        }\n    }\n\n    // Data models for parsing iFlytek's response JSON more safely\n    private data class IFlytekWord(\n        val content: String,\n        @SerializedName(\"total_score\") val totalScore: Double\n    )\n\n    private data class IFlytekScoreResult(\n\n[169 more lines in file. Use offset=221 to continue.]"}],"isError":false,"timestamp":1773650613089}}
