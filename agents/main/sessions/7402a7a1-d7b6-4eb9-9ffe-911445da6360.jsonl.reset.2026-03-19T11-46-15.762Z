003e镜像\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eSpeech recognition\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/automatic-speech-recognition\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://hf.qhduan.com/spaces/k2-fsa/automatic-speech-recognition\\\" rel=\\\"nofollow\\\"\\u003e镜像\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eSpeech recognition with \\u003ca href=\\\"https://github.com/openai/whisper\\\"\\u003eWhisper\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/automatic-speech-recognition-with-whisper\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://hf.qhduan.com/spaces/k2-fsa/automatic-speech-recognition-with-whisper\\\" rel=\\\"nofollow\\\"\\u003e镜像\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eSpeech synthesis\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/text-to-speech\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://hf.qhduan.com/spaces/k2-fsa/text-to-speech\\\" rel=\\\"nofollow\\\"\\u003e镜像\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eGenerate subtitles\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/generate-subtitles-for-videos\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://hf.qhduan.com/spaces/k2-fsa/generate-subtitles-for-videos\\\" rel=\\\"nofollow\\\"\\u003e镜像\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eAudio tagging\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/audio-tagging\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://hf.qhduan.com/spaces/k2-fsa/audio-tagging\\\" rel=\\\"nofollow\\\"\\u003e镜像\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eSource separation\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/source-separation\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://hf.qhduan.com/spaces/k2-fsa/source-separation\\\" rel=\\\"nofollow\\\"\\u003e镜像\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eSpoken language identification with \\u003ca href=\\\"https://github.com/openai/whisper\\\"\\u003eWhisper\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/spoken-language-identification\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://hf.qhduan.com/spaces/k2-fsa/spoken-language-identification\\\" rel=\\\"nofollow\\\"\\u003e镜像\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003c/tbody\\u003e\\n\\u003c/table\\u003e\\u003c/markdown-accessiblity-table\\u003e\\n\\u003cp dir=\\\"auto\\\"\\u003eWe also have spaces built using WebAssembly. They are listed below:\\u003c/p\\u003e\\n\\u003cmarkdown-accessiblity-table\\u003e\\u003ctable\\u003e\\n\\u003cthead\\u003e\\n\\u003ctr\\u003e\\n\\u003cth\\u003eDescription\\u003c/th\\u003e\\n\\u003cth\\u003eHuggingface space\\u003c/th\\u003e\\n\\u003cth\\u003eModelScope space\\u003c/th\\u003e\\n\\u003c/tr\\u003e\\n\\u003c/thead\\u003e\\n\\u003ctbody\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eVoice activity detection with \\u003ca href=\\\"https://github.com/snakers4/silero-vad\\\"\\u003esilero-vad\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/web-assembly-vad-sherpa-onnx\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://modelscope.cn/studios/csukuangfj/web-assembly-vad-sherpa-onnx\\\" rel=\\\"nofollow\\\"\\u003e地址\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eReal-time speech recognition (Chinese + English) with Zipformer\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/web-assembly-asr-sherpa-onnx-zh-en\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/web-assembly-asr-sherpa-onnx-zh-en\\\" rel=\\\"nofollow\\\"\\u003e地址\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eReal-time speech recognition (Chinese + English) with Paraformer\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/web-assembly-asr-sherpa-onnx-zh-en-paraformer\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://modelscope.cn/studios/k2-fsa/web-assembly-asr-sherpa-onnx-zh-en-paraformer\\\" rel=\\\"nofollow\\\"\\u003e地址\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003c/tr\\u003e\\n\\u003ctr\\u003e\\n\\u003ctd\\u003eReal-time speech recognition (Chinese + English + Cantonese) with \\u003ca href=\\\"https://www.modelscope.cn/models/damo/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-pytorch/summary\\\" rel=\\\"nofollow\\\"\\u003eParaformer-large\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://huggingface.co/spaces/k2-fsa/web-assembly-asr-sherpa-onnx-zh-cantonese-en-paraformer\\\" rel=\\\"nofollow\\\"\\u003eClick me\\u003c/a\\u003e\\u003c/td\\u003e\\n\\u003ctd\\u003e\\u003ca href=\\\"https://modelscope.cn/studios/k2-fsa/web-assembly-asr-sherpa-onnx-zh-cantonese-en-paraformer\\\" rel=\\\"nofollow