sers/ling/.openclaw/workspace/apps/kids-box-tv-app/app/src/main/java/com/openclaw/kidsboxtv/audio/PcmAudioRecorder.kt\",\"offset\":1,\"limit\":220}"}],"api":"openai-responses","provider":"gmn","model":"gpt-5.4","usage":{"input":4960,"output":423,"cacheRead":51200,"cacheWrite":0,"totalTokens":56583,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773623023463}}
{"type":"message","id":"ecf48ae9","parentId":"7b2ad934","timestamp":"2026-03-16T01:04:02.564Z","message":{"role":"toolResult","toolCallId":"call_UiwJQim8R2N47nNbb1pMkj45|fc_04b76fdf640436710169b7570255e881a0a8f099ffee1aae0f","toolName":"read","content":[{"type":"text","text":"package com.openclaw.englishworkbook.audio\n\nimport android.content.Context\nimport com.k2fsa.sherpa.onnx.FeatureConfig\nimport com.k2fsa.sherpa.onnx.OfflineModelConfig\nimport com.k2fsa.sherpa.onnx.OfflineRecognizer\nimport com.k2fsa.sherpa.onnx.OfflineRecognizerConfig\nimport com.k2fsa.sherpa.onnx.OfflineTransducerModelConfig\nimport com.openclaw.englishworkbook.data.SherpaOnnxModelStatus\nimport java.io.File\n\nclass SherpaOnnxRuntime(\n    context: Context,\n    private val modelStatus: SherpaOnnxModelStatus,\n    private val sampleRate: Int = 16_000,\n    private val featureDim: Int = 80,\n    private val numThreads: Int = 2,\n) {\n    private val appContext = context.applicationContext\n\n    var recognizer: OfflineRecognizer? = null\n        private set\n\n    fun isModelReady(): Boolean = modelStatus.isReady\n\n    fun recognizerClassName(): String = OfflineRecognizer::class.java.name\n\n    fun initialize(): Boolean {\n        if (!modelStatus.isReady) {\n            shutdown()\n            return false\n        }\n        if (recognizer != null) return true\n\n        val modelDir = File(modelStatus.modelDirPath)\n        val encoder = File(modelDir, \"encoder.onnx\")\n        val decoder = File(modelDir, \"decoder.onnx\")\n        val joiner = File(modelDir, \"joiner.onnx\")\n        val tokens = File(modelDir, \"tokens.txt\")\n        if (!encoder.isFile || !decoder.isFile || !joiner.isFile || !tokens.isFile) {\n            shutdown()\n            return false\n        }\n\n        val transducer = OfflineTransducerModelConfig().apply {\n            this.encoder = encoder.absolutePath\n            this.decoder = decoder.absolutePath\n            this.joiner = joiner.absolutePath\n        }\n        val modelConfig = OfflineModelConfig().apply {\n            this.transducer = transducer\n            this.tokens = tokens.absolutePath\n            this.numThreads = numThreads\n            this.provider = \"cpu\"\n            this.debug = false\n        }\n        val featureConfig = FeatureConfig().apply {\n            this.sampleRate = sampleRate\n            this.featureDim = featureDim\n            this.dither = 0f\n        }\n        val recognizerConfig = OfflineRecognizerConfig().apply {\n            this.featConfig = featureConfig\n            this.modelConfig = modelConfig\n            this.decodingMethod = \"greedy_search\"\n            this.maxActivePaths = 4\n            this.blankPenalty = 0f\n        }\n\n        recognizer = OfflineRecognizer(appContext.assets, recognizerConfig)\n        return true\n    }\n\n    fun recognize(samples: ShortArray): String {\n        if (samples.isEmpty()) return \"\"\n        check(initialize()) { \"sherpa-onnx 模型未就绪\" }\n        val offlineRecognizer = recognizer ?: error(\"sherpa-onnx recognizer 初始化失败\")\n        val stream = offlineRecognizer.createStream()\n        return try {\n            stream.acceptWaveform(samples.toFloatPcm(), sampleRate)\n            offlineRecognizer.decode(stream)\n            offlineRecognizer.getResult(stream).text.orEmpty().trim()\n        } finally {\n            stream.release()\n        }\n    }\n\n    fun shutdown() {\n        runCatching { recognizer?.release() }\n        recognizer = null\n    }\n\n    private fun ShortArray.toFloatPcm(): FloatArray {\n        return FloatArray(size) { index ->\n            (this[index] / 32768.0f).coerceIn(-1f, 1f)\n        }\n    }\n}\n"}],"isError":false,"timestamp":1773623042554}}
{"type":"message","id":"2cb7a690","parentId":"ecf48ae9","timestamp":"2026-03-16T01:04:02.584Z","message":{"role":"toolResult","toolCallId":"call_mm7TjCdl9iy5TlSDzV0kJj4d|fc_04b76fdf640436710169b7570255f881a0a97dc70d6973a05f","toolName":"read","content":[{"type":"text","text":"package com.openclaw.englishworkbook.audio\n\nimport android.content.Context\nimport android.content.Intent\nimport android.os.Handler\nimport android.os.Looper\nimport androidx.compose.runtime.getValue\nimport androidx.compose.runtime.mutableIntStateOf\nimport androidx.compose.runtime.mutableStateOf\nimport androidx.compose.runtime.setValue\nimport com.openclaw.englishworkbook.data.AppSettingsRepository\nimport com.openclaw.englishworkbook.data.SherpaOnnxModelManager\n\nclass SherpaOnnxSpeechPracticeEngine(\n    context: Context,\n    private val settingsRepository: AppSettingsRepository,\n) : SpeechPracticeEngine {\n    private val appContext = context.applicationContext\n    private val modelManager = SherpaOnnxModelManager(appContext)\n    private val mainHandler = Handler(Looper.getMainLooper())\n    private val pcmRecorder = PcmAudioRecorder()\n\n    override var isListening by mutableStateOf(false)\n        private set\n    override var statusMessage by mutableStateOf(initialStatus())\n        private set\n    override var lastResult by mutableStateOf<SpeechPracticeResult?>(null)\n        private set\n    override var lastErrorCode by mutableIntStateOf(0)\n        private set\n    override var lastErrorAttemptId by mutableIntStateOf(0)\n        private set\n\n    private var runtime: SherpaOnnxRuntime? = null\n    private var workerThread: Thread? = null\n    @Volatile\n    private var stopRequested: Boolean = false\n\n    private var currentTargetText: String = \"\"\n    private var currentTargetLabel: String = \"\"\n    private var currentTargetRewardId: String = \"\"\n    private var nextAttemptId: Int = 1\n    private var currentAttemptId: Int = 0\n\n    override fun isAvailable(): Boolean {\n        val settings = settingsRepository.sherpaOnnxSettings()\n        return settings.enabled && modelManager.inspect(settings.modelId).isReady\n    }\n\n    override fun startPractice(targetText: String, targetLabel: String, targetRewardId: String): Boolean {\n        val settings = settingsRepository.sherpaOnnxSettings()\n        val status = modelManager.inspect(settings.modelId)\n        lastResult = null\n        lastErrorCode = 0\n        lastErrorAttemptId = 0\n\n        if (!settings.enabled) {\n            statusMessage = \"sherpa-onnx 尚未启用，请先在设置里打开离线跟读\"\n            return false\n        }\n        if (!status.isReady) {\n            statusMessage = \"sherpa-onnx 模型未就绪：缺少 ${status.missingFiles.joinToString(\", \")}（目录：${status.modelDirPath}）\"\n            return false\n        }\n        if (workerThread?.isAlive == true || isListening) {\n            statusMessage = \"上一轮跟读还没结束，请稍等一下\"\n            return false\n        }\n\n        val normalizedTarget = targetText.trim()\n        if (normalizedTarget.isBlank()) {\n            statusMessage = \"当前题目没有可跟读的英文内容\"\n            return false\n        }\n\n        val currentRuntime = SherpaOnnxRuntime(appContext, status)\n        if (!runCatching { currentRuntime.initialize() }.getOrDefault(false)) {\n            currentRuntime.shutdown()\n            statusMessage = \"离线识别模型初始化失败，请检查模型文件后重试\"\n            return false\n        }\n        if (!pcmRecorder.prepare()) {\n            currentRuntime.shutdown()\n            statusMessage = \"麦克风初始化失败，请稍后再试\"\n            return false\n        }\n        if (!pcmRecorder.start()) {\n            pcmRecorder.release()\n            currentRuntime.shutdown()\n            statusMessage = \"无法开始录音，请检查麦克风权限后重试\"\n            return false\n        }\n\n        runtime?.shutdown()\n        runtime = currentRuntime\n        currentTargetText = normalizedTarget\n        currentTargetLabel = targetLabel\n        currentTargetRewardId = targetRewardId.trim()\n        currentAttemptId = nextAttemptId++\n        stopRequested = false\n        isListening = true\n        statusMessage = \"开始跟读吧…\"\n\n        workerThread = Thread {\n            runRecognitionLoop(currentRuntime, currentAttemptId)\n        }.apply {\n            name = \"SherpaOnnxPractice-$currentAttemptId\"\n            start()\n        }\n        return true\n    }\n\n    override fun buildFallbackIntent(targetText: String, targetLabel: String, targetRewardId: String): Intent? = null\n\n    override fun buildFallbackIntentForCurrentTarget(): Intent? = null\n\n    override fun shouldAutoFallback(error: Int): Boolean = false\n\n    override fun handleFallbackResult(data: Intent?): Boolean = false\n\n    override fun handleFallbackCancelled() {\n        stopRecognition(resetStatus = true)\n        statusMessage = \"已取消跟读\"\n    }\n\n    override fun reset() {\n        stopRecognition(resetStatus = false)\n        isListening = false\n        lastResult = null\n        lastErrorCode = 0\n        lastErrorAttemptId = 0\n        statusMessage = initialStatus()\n        currentTargetText = \"\"\n        currentTargetLabel = \"\"\n        currentTargetRewardId = \"\"\n        currentAttemptId = 0\n    }\n\n    override fun shutdown() {\n        stopRecognition(resetStatus = false)\n        runtime?.shutdown()\n        runtime = null\n    }\n\n    private fun runRecognitionLoop(currentRuntime: SherpaOnnxRuntime, attemptId: Int) {\n        val chunks = mutableListOf<ShortArray>()\n        var totalSamples = 0\n        val startedAt = System.currentTimeMillis()\n        val maxRecordDurationMs = 4_500L\n\n        try {\n            while (!stopRequested && System.currentTimeMillis() - startedAt < maxRecordDurationMs) {\n                val chunk = pcmRecorder.readChunk()\n                if (chunk.isNotEmpty()) {\n                    chunks += chunk\n                    totalSamples += chunk.size\n                }\n            }\n            pcmRecorder.stop()\n            pcmRecorder.release()\n\n            if (stopRequested || attemptId != currentAttemptId) {\n                postToMain {\n                    isListening = false\n                }\n                return\n            }\n\n            postToMain {\n                isListening = false\n                statusMessage = \"识别中…\"\n            }\n\n            val merged = mergeChunks(chunks, totalSamples)\n            if (merged.isEmpty()) {\n                postNoMatch(attemptId)\n                return\n            }\n\n            val recognized = currentRuntime.recognize(merged)\n            if (recognized.isBlank()) {\n                postNoMatch(attemptId)\n                return\n            }\n\n            val score = ReadAlongScorer.score(currentTargetText, recognized)\n            postToMain {\n                if (attemptId != currentAttemptId) return@postToMain\n                lastResult = SpeechPracticeResult(\n                    attemptId = attemptId,\n                    targetLabel = currentTargetLabel,\n                    targetRewardId = currentTargetRewardId,\n                    score = score,\n                )\n                statusMessage = \"${score.encouragementTitle}，${score.encouragementDetail}\"\n            }\n        } catch (t: Throwable) {\n            postToMain {\n                if (attemptId != currentAttemptId) return@postToMain\n                isListening = false\n                lastErrorCode = 1\n                lastErrorAttemptId = attemptId\n                statusMessage = \"离线识别暂时不可用：${t.message ?: \"请稍后再试\"}\"\n            }\n        } finally {\n            runCatching { pcmRecorder.stop() }\n            runCatching { pcmRecorder.release() }\n        }\n    }\n\n    private fun stopRecognition(resetStatus: Boolean) {\n        stopRequested = true\n        runCatching { pcmRecorder.stop() }\n        runCatching { pcmRecorder.release() }\n        workerThread = null\n        if (resetStatus) {\n            isListening = false\n        }\n    }\n\n    private fun mergeChunks(chunks: List<ShortArray>, totalSamples: Int): ShortArray {\n        if (chunks.isEmpty() || totalSamples <= 0) return shortArrayOf()\n        val merged = ShortArray(totalSamples)\n        var offset = 0\n        chunks.forEach { chunk ->\n            chunk.copyInto(merged, destinationOffset = offset)\n            offset += chunk.size\n        }\n        return merged\n    }\n\n    private fun postNoMatch(attemptId: Int) {\n        postToMain {\n            if (attemptId != currentAttemptId) return@postToMain\n            isListening = false\n            lastResult = null\n            statusMessage = \"没听清，再试一次\"\n        }\n    }\n\n    private fun postToMain(block: () -> Unit) {\n        mainHandler.post(block)\n    }\n\n    private fun initialStatus(): String {\n        val mode = settingsRepository.asrEngineMode()\n        val settings = settingsRepository.sherpaOnnxSettings()\n        val status = modelManager.inspect(settings.modelId)\n        return when {\n            mode.name != \"SHERPA_ONNX\" -> \"当前未启用 sherpa-onnx\"\n            !settings.enabled -> \"sherpa-onnx 尚未启用，请先完成模型接入\"\n            !status.isReady -> \"sherpa-onnx 模型未就绪：${status.modelDirPath}\"\n            else -> \"点击按钮开始离线跟读\"\n        }\n    }\n}\n"}],"isError":false,"timestamp":1773623042577}}
{"type":"message","id":"bc3f70a6","parentId":"2cb7a690","timestamp":"2026-03-16T01:04:02.598Z","message":{"role":"toolResult","toolCallId":"call_3CrP0KvwMWLoVmVHPjbsz4yF|fc_04b76fdf640436710169b75702560081a080ed2ea008b5da71","toolName":"read","content":[{"type":"text","text":"package com.openclaw.englishworkbook.audio\n\nimport android.media.AudioFormat\nimport android.media.AudioRecord\nimport android.media.MediaRecorder\nimport kotlin.math.max\n\nclass PcmAudioRecorder(\n    private val config: Config = Config(),\n) {\n    data class Config(\n        val sampleRate: Int = 16000,\n        val channelConfig: Int = AudioFormat.CHANNEL_IN_MONO,\n        val audioFormat: Int = AudioFormat.ENCODING_PCM_16BIT,\n        val readMultiplier: Int = 2,\n    )\n\n    private var audioRecord: AudioRecord? = null\n    private var bufferSizeInBytes: Int = 0\n\n    fun prepare(): Boolean {\n        release()\n        val minBuffer = AudioRecord.getMinBufferSize(config.sampleRate, config.channelConfig, config.audioFormat)\n        if (minBuffer <= 0) return false\n        bufferSizeInBytes = max(minBuffer, minBuffer * config.readMultiplier)\n        audioRecord = AudioRecord(\n            MediaRecorder.AudioSource.MIC,\n            config.sampleRate,\n            config.channelConfig,\n            config.audioFormat,\n            bufferSizeInBytes,\n        )\n        return audioRecord?.state == AudioRecord.STATE_INITIALIZED\n    }\n\n    fun start(): Boolean {\n        val recorder = audioRecord ?: return false\n        if (recorder.state != AudioRecord.STATE_INITIALIZED) return false\n        recorder.startRecording()\n        return recorder.recordingState == AudioRecord.RECORDSTATE_RECORDING\n    }\n\n    fun readChunk(): ShortArray {\n        val recorder = audioRecord ?: return shortArrayOf()\n        if (bufferSizeInBytes <= 0) return shortArrayOf()\n        val shortBuffer = ShortArray(bufferSizeInBytes / 2)\n        val read = recorder.read(shortBuffer, 0, shortBuffer.size)\n        return if (read > 0) shortBuffer.copyOf(read) else shortArrayOf()\n    }\n\n    fun stop() {\n        runCatching { audioRecord?.stop() }\n    }\n\n    fun release() {\n        runCatching { audioRecord?.release() }\n        audioRecord = null\n        bufferSizeInBytes = 0\n    }\n}\n"}],"isError":false,"timestamp":1773623042591}}
