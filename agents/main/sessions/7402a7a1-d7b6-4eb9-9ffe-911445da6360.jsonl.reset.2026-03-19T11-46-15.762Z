ned ASR models (Non-Streaming)\"},{\"level\":3,\"text\":\"Useful links\",\"anchor\":\"useful-links\",\"htmlText\":\"Useful links\"},{\"level\":3,\"text\":\"How to reach us\",\"anchor\":\"how-to-reach-us\",\"htmlText\":\"How to reach us\"},{\"level\":2,\"text\":\"Projects using sherpa-onnx\",\"anchor\":\"projects-using-sherpa-onnx\",\"htmlText\":\"Projects using sherpa-onnx\"},{\"level\":3,\"text\":\"BreezeApp from MediaTek Research\",\"anchor\":\"breezeapp-from-mediatek-research\",\"htmlText\":\"BreezeApp from MediaTek Research\"},{\"level\":3,\"text\":\"Open-LLM-VTuber\",\"anchor\":\"open-llm-vtuber\",\"htmlText\":\"Open-LLM-VTuber\"},{\"level\":3,\"text\":\"voiceapi\",\"anchor\":\"voiceapi\",\"htmlText\":\"voiceapi\"},{\"level\":3,\"text\":\"腾讯会议摸鱼工具 TMSpeech\",\"anchor\":\"腾讯会议摸鱼工具-tmspeech\",\"htmlText\":\"腾讯会议摸鱼工具 TMSpeech\"},{\"level\":3,\"text\":\"lol互动助手\",\"anchor\":\"lol互动助手\",\"htmlText\":\"lol互动助手\"},{\"level\":3,\"text\":\"Sherpa-ONNX 语音识别服务器\",\"anchor\":\"sherpa-onnx-语音识别服务器\",\"htmlText\":\"Sherpa-ONNX 语音识别服务器\"},{\"level\":3,\"text\":\"QSmartAssistant\",\"anchor\":\"qsmartassistant\",\"htmlText\":\"QSmartAssistant\"},{\"level\":3,\"text\":\"Flutter-EasySpeechRecognition\",\"anchor\":\"flutter-easyspeechrecognition\",\"htmlText\":\"Flutter-EasySpeechRecognition\"},{\"level\":3,\"text\":\"sherpa-onnx-unity\",\"anchor\":\"sherpa-onnx-unity\",\"htmlText\":\"sherpa-onnx-unity\"},{\"level\":3,\"text\":\"xiaozhi-esp32-server\",\"anchor\":\"xiaozhi-esp32-server\",\"htmlText\":\"xiaozhi-esp32-server\"},{\"level\":3,\"text\":\"KaithemAutomation\",\"anchor\":\"kaithemautomation\",\"htmlText\":\"KaithemAutomation\"},{\"level\":3,\"text\":\"Open-XiaoAI KWS\",\"anchor\":\"open-xiaoai-kws\",\"htmlText\":\"Open-XiaoAI KWS\"},{\"level\":3,\"text\":\"C++ WebSocket ASR Server\",\"anchor\":\"c-websocket-asr-server\",\"htmlText\":\"C++ WebSocket ASR Server\"},{\"level\":3,\"text\":\"Go WebSocket Server\",\"anchor\":\"go-websocket-server\",\"htmlText\":\"Go WebSocket Server\"},{\"level\":3,\"text\":\"Making robot Paimon, Ep10 \\\"The AI Part 1\\\"\",\"anchor\":\"making-robot-paimon-ep10-the-ai-part-1\",\"htmlText\":\"Making robot Paimon, Ep10 \\\"The AI Part 1\\\"\"},{\"level\":3,\"text\":\"TtsReader - Desktop application\",\"anchor\":\"ttsreader---desktop-application\",\"htmlText\":\"TtsReader - Desktop application\"},{\"level\":3,\"text\":\"MentraOS\",\"anchor\":\"mentraos\",\"htmlText\":\"MentraOS\"},{\"level\":3,\"text\":\"flet_sherpa_onnx\",\"anchor\":\"flet_sherpa_onnx\",\"htmlText\":\"flet_sherpa_onnx\"},{\"level\":3,\"text\":\"achatbot-go\",\"anchor\":\"achatbot-go\",\"htmlText\":\"achatbot-go\"}],\"siteNavLoginPath\":\"/login?return_to=https%3A%2F%2Fgithub.com%2Fk2-fsa%2Fsherpa-onnx\"}},{\"displayName\":\"LICENSE\",\"repoName\":\"sherpa-onnx\",\"refName\":\"master\",\"path\":\"LICENSE\",\"preferredFileType\":\"license\",\"tabName\":\"Apache-2.0\",\"richText\":null,\"loaded\":false,\"timedOut\":false,\"errorMessage\":null,\"headerInfo\":{\"toc\":null,\"siteNavLoginPath\":\"/login?return_to=https%3A%2F%2Fgithub.com%2Fk2-fsa%2Fsherpa-onnx\"}}],\"overviewFilesProcessingTime\":0,\"copilotSWEAgentEnabled\":false}},\"codeViewLayoutRoute\":{\"repo\":{\"id\":531380835,\"defaultBranch\":\"master\",\"name\":\"sherpa-onnx\",\"ownerLogin\":\"k2-fsa\",\"currentUserCanPush\":false,\"isFork\":false,\"isEmpty\":false,\"createdAt\":\"2022-09-01T05:47:33.000Z\",\"ownerAvatar\":\"https://avatars.githubusercontent.com/u/71431748?v=4\",\"public\":true,\"private\":false,\"isOrgOwned\":true},\"currentUser\":null,\"uploadToken\":\"EBXCfYJ7qlEHAKE2fBYn5Q2VeCyDKFgf6zWE5djxYBUjDmHx3k6H7xOPhXZW94WJKTf5Wyw_putdMvG9LIRF6w\",\"allShortcutsEnabled\":false,\"treeExpanded\":true,\"path\":\"/\",\"symbolsExpanded\":false,\"refInfo\":{\"name\":\"master\",\"listCacheKey\":\"v0:1773281666.0\",\"canEdit\":false,\"currentOid\":\"55189b07f0f3445b5c81148e0793cb2d22238580\"},\"helpUrl\":\"https://docs.github.com\",\"findFileWorkerPath\":\"/assets-cdn/worker/find-file-worker-4e5d7136862a2a48.js\",\"findInFileWorkerPath\":\"/assets-cdn/worker/find-in-file-worker-4c35b25d88167fef.js\",\"githubDevUrl\":null},\"csrf_tokens\":{\"/k2-fsa/sherpa-onnx/branches\":{\"post\":\"gniSYyFGuICFqgg3hhasOkdbxe_vVVWRduUHyVbwXBsKrxM2ovEshujDCURQW37YkrrKpgwH9pzR-4_Cf6vHXg\"}}},\"title\":\"GitHub - k2-fsa/sherpa-onnx: Speech-to-text, text-to-speech, speaker diarization, speech enhancement, source separation, and VAD using next-gen Kaldi with onnxruntime without Internet connection. Support embedded systems, Android, iOS, HarmonyOS, Raspberry Pi, RISC-V, RK NPU, Axera NPU, Ascend NPU, x86_64 servers, websocket server/client, support 12 programming languages\",\"appPayload\":{},\"meta\":{\"title\":\"GitHub - k2-fsa/sherpa-onnx: Speech-to-text, text-to-speech, speaker diarization, speech enhancement, source separation, and VAD using next-gen Kaldi with onnxruntime without Internet connection. Support embedded systems, Android, iOS, HarmonyOS, Raspberry Pi, RISC-V, RK NPU, Axera NPU, Ascend NPU, x86_64 servers, websocket server/client, support 12 programming languages\"}}</script>\n<td>Real-time speech recognition (Chinese + English) with Zipformer</td>\n<td>Real-time speech recognition (Chinese + English) with Paraformer</td>\n<td>Real-time speech recognition (Chinese + English + Cantonese) with <a href=\"https://www.modelscope.cn/models/damo/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-pytorch/summary\" rel=\"nofollow\">Paraformer-large</a></td>\n<td>Real-time speech recognition (English)</td>\n<td>VAD + speech recognition (Chinese) with <a href=\"https://k2-fsa.github.io/sherpa/onnx/pretrained_models/offline-ctc/icefall/zipformer.html#sherpa-onnx-zipformer-ctc-zh-int8-2025-07-03-chinese\" rel=\"nofollow\">Zipformer CTC</a></td>\n<td><a href=\"https://huggingface.co/spaces/k2-fsa/web-assembly-vad-asr-sherpa-onnx-zh-zipformer-ctc\" rel=\"nofollow\">Click me</a></td>\n<td><a href=\"https://modelscope.cn/studios/csukuangfj/web-assembly-vad-asr-sherpa-onnx-zh-zipformer-ctc/summary\" rel=\"nofollow\">地址</a></td>\n<td>VAD + speech recognition (Chinese + English + Korean + Japanese + Cantonese) with <a href=\"https://github.com/FunAudioLLM/SenseVoice\">SenseVoice</a></td>\n<td>VAD + speech recognition (English) with <a href=\"https://github.com/openai/whisper\">Whisper</a> tiny.en</td>\n<td>VAD + speech recognition (English) with <a href=\"https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models/sherpa-onnx-moonshine-tiny-en-int8.tar.bz2\">Moonshine tiny</a></td>\n<td>VAD + speech recognition (English) with Zipformer trained with <a href=\"https://github.com/SpeechColab/GigaSpeech\">GigaSpeech</a></td>\n<td><a href=\"https://huggingface.co/spaces/k2-fsa/web-assembly-vad-asr-sherpa-onnx-en-zipformer-gigaspeech\" rel=\"nofollow\">Click me</a></td>\n<td><a href=\"https://www.modelscope.cn/studios/k2-fsa/web-assembly-vad-asr-sherpa-onnx-en-zipformer-gigaspeech\" rel=\"nofollow\">地址</a></td>\n<td>VAD + speech recognition (Chinese) with Zipformer trained with <a href=\"https://github.com/wenet-e2e/WenetSpeech\">WenetSpeech</a></td>\n<td><a href=\"https://huggingface.co/spaces/k2-fsa/web-assembly-vad-asr-sherpa-onnx-zh-zipformer-wenetspeech\" rel=\"nofollow\">Click me</a></td>\n<td><a href=\"https://www.modelscope.cn/studios/k2-fsa/web-assembly-vad-asr-sherpa-onnx-zh-zipformer-wenetspeech\" rel=\"nofollow\">地址</a></td>\n<td>VAD + speech recognition (Japanese) with Zipformer trained with <a href=\"https://research.reazon.jp/_static/reazonspeech_nlp2023.pdf\" rel=\"nofollow\">ReazonSpeech</a></td>\n<td><a href=\"https://huggingface.co/spaces/k2-fsa/web-assembly-vad-asr-sherpa-onnx-ja-zipformer\" rel=\"nofollow\">Click me</a></td>\n<td><a href=\"https://www.modelscope.cn/studios/csukuangfj/web-assembly-vad-asr-sherpa-onnx-ja-zipformer\" rel=\"nofollow\">地址</a></td>\n\n--- https://huggingface.co/csukuangfj ---\n\t\t<div class=\"flex min-h-dvh flex-col\"><div class=\"SVELTE_HYDRATER contents\" data-target=\"