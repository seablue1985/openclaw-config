{"type":"message","id":"5a32cf2f","parentId":"dae45c38","timestamp":"2026-03-16T09:07:20.667Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_mzbaeedE8mfGhlgUajBNre5h","name":"edit","arguments":{"file_path":"/Users/ling/.openclaw/workspace/apps/kids-box-tv-app/app/src/main/java/com/openclaw/kidsboxtv/audio/IFlytekSpeechPracticeEngine.kt","oldText":"    // 鉴权 URL 生成\n    private fun getAuthUrl(hostUrl: String, apiKey: String, apiSecret: String): String {\n        val url = java.net.URL(hostUrl)\n        val date = SimpleDateFormat(\"EEE, dd MMM yyyy HH:mm:ss z\", Locale.US).apply {\n            timeZone = TimeZone.getTimeZone(\"GMT\")\n        }.format(Date())\n\n        val builder = StringBuilder(\"host: \").append(url.host).append(\"\\n\")\n            .append(\"date: \").append(date).append(\"\\n\")\n            .append(\"GET \").append(url.path).append(\" HTTP/1.1\")\n\n        val mac = Mac.getInstance(\"hmacsha256\")\n        val spec = SecretKeySpec(apiSecret.toByteArray(Charset.forName(\"UTF-8\")), \"hmacsha256\")\n        mac.init(spec)\n        val hexDigits = mac.doFinal(builder.toString().toByteArray(Charset.forName(\"UTF-8\")))\n        val sha = Base64.encodeToString(hexDigits, Base64.NO_WRAP)\n\n        val authorization = String.format(\n            \"api_key=\\\"%s\\\", algorithm=\\\"%s\\\", headers=\\\"%s\\\", signature=\\\"%s\\\"\",\n            apiKey, \"hmac-sha256\", \"host date request-line\", sha\n        )\n\n        val httpUrl = hostUrl.toHttpUrl().newBuilder()\n            .addQueryParameter(\"authorization\", Base64.encodeToString(authorization.toByteArray(Charset.forName(\"UTF-8\")), Base64.NO_WRAP))\n            .addQueryParameter(\"date\", date)\n            .addQueryParameter(\"host\", url.host)\n            .build()\n\n        return httpUrl.toString()\n    }\n","newText":"    // 鉴权 URL 生成（保留 wss:// 协议，不再按 httpUrl 解析，避免 unknown protocol:wss）\n    private fun getAuthUrl(hostUrl: String, apiKey: String, apiSecret: String): String {\n        val uri = java.net.URI(hostUrl)\n        val host = uri.host\n        val path = if (uri.rawPath.isNullOrBlank()) \"/\" else uri.rawPath\n        val date = SimpleDateFormat(\"EEE, dd MMM yyyy HH:mm:ss z\", Locale.US).apply {\n            timeZone = TimeZone.getTimeZone(\"GMT\")\n        }.format(Date())\n\n        val builder = StringBuilder(\"host: \").append(host).append(\"\\n\")\n            .append(\"date: \").append(date).append(\"\\n\")\n            .append(\"GET \").append(path).append(\" HTTP/1.1\")\n\n        val mac = Mac.getInstance(\"hmacsha256\")\n        val spec = SecretKeySpec(apiSecret.toByteArray(Charset.forName(\"UTF-8\")), \"hmacsha256\")\n        mac.init(spec)\n        val hexDigits = mac.doFinal(builder.toString().toByteArray(Charset.forName(\"UTF-8\")))\n        val sha = Base64.encodeToString(hexDigits, Base64.NO_WRAP)\n\n        val authorization = String.format(\n            \"api_key=\\\"%s\\\", algorithm=\\\"%s\\\", headers=\\\"%s\\\", signature=\\\"%s\\\"\",\n            apiKey, \"hmac-sha256\", \"host date request-line\", sha\n        )\n\n        val encodedAuthorization = URLEncoder.encode(\n            Base64.encodeToString(authorization.toByteArray(Charset.forName(\"UTF-8\")), Base64.NO_WRAP),\n            \"UTF-8\"\n        )\n        val encodedDate = URLEncoder.encode(date, \"UTF-8\")\n        val encodedHost = URLEncoder.encode(host, \"UTF-8\")\n\n        return \"$hostUrl?authorization=$encodedAuthorization&date=$encodedDate&host=$encodedHost\"\n    }\n"}}],"api":"openai-completions","provider":"gmn","model":"gpt-5.4","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773652016398}}
