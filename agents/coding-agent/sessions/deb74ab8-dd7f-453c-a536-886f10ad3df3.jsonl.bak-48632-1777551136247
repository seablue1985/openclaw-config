{"type":"message","id":"715776e2","parentId":"bfd35f8b","timestamp":"2026-04-30T02:23:04.815Z","message":{"role":"toolResult","toolCallId":"call_rwdOB0PDI4wkJyNMo0Xw4iTW|fc_0f4ac913ff6b71190169f2bd09b7e0819bbefbe0b688ff9c91","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nTHS Level2 实时行情封装 — 接入盘中研究链路\n支持: tick_super_level1, big_order_flow, order_book, min_snapshot\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport ssl\nimport time\nimport urllib.request\nfrom dataclasses import dataclass\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any, Optional\n\n# =============================================================================\n# 凭证加载\n# =============================================================================\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nCREDS_PATH = WORKSPACE / \"config\" / \"thsdata_credentials.json\"\n\n\ndef load_credentials() -> dict[str, str]:\n    if not CREDS_PATH.exists():\n        raise FileNotFoundError(f\"THS credentials not found: {CREDS_PATH}\")\n    return json.loads(CREDS_PATH.read_text(encoding=\"utf-8\"))\n\n\n# =============================================================================\n# THS 实时行情核心（基于 thsdata SDK）\n# =============================================================================\nfrom thsdata import Quote\n\n\n@dataclass\nclass THSRealtimeQuote:\n    ts_code: str          # 标准格式: 000001.SZ\n    ths_code: str         # THS格式: USZA000001\n    source: str = \"ths_level2\"\n    price: float = 0.0\n    change_pct: float = 0.0\n    volume: int = 0\n    amount: float = 0.0\n    bid1: float = 0.0\n    ask1: float = 0.0\n    bid_vol1: int = 0\n    ask_vol1: int = 0\n    turnover: float = 0.0\n    change: float = 0.0\n    open: float = 0.0\n    high: float = 0.0\n    low: float = 0.0\n    status: str = \"ok\"\n    error: str = \"\"\n\n\ndef ts_code_to_ths(ts_code: str) -> str:\n    \"\"\"标准 ts_code → THS 格式\"\"\"\n    code = (ts_code or \"\").strip().upper()\n    if not code or \".\" not in code:\n        return code\n    symbol, market = code.split(\".\", 1)\n    market = market.lower()\n    if market in {\"sh\", \"sz\", \"bj\"}:\n        prefix = {\"sh\": \"USHA\", \"sz\": \"USZA\", \"bj\": \"USBA\"}.get(market, \"USZA\")\n        return f\"{prefix}{symbol}\"\n    return f\"USZA{symbol}\"\n\n\ndef ths_to_ts_code(ths_code: str) -> str:\n    \"\"\"THS 格式 → 标准 ts_code\"\"\"\n    code = (ths_code or \"\").strip().upper()\n    if len(code) != 10:\n        return code\n    prefix = code[:4]\n    symbol = code[4:]\n    market_map = {\"USHA\": \"SH\", \"USZA\": \"SZ\", \"USBA\": \"BJ\"}\n    market = market_map.get(prefix, \"SZ\")\n    return f\"{symbol}.{market}\"\n\n\ndef _connect() -> Quote:\n    creds = load_credentials()\n    q = Quote(ops={\n        \"username\": creds[\"username\"],\n        \"password\": creds[\"password\"],\n        \"mac\":      creds[\"mac\"],\n    })\n    q.connect()\n    return q\n\n\n# =============================================================================\n# Level2 逐笔行情\n# =============================================================================\ndef get_level2_tick(ts_code: str, buffer_size_mb: int = 10) -> dict[str, Any]:\n    \"\"\"\n    获取Level2超级盘口（逐笔 + 10档委买卖盘）\n    返回 dict，含 'success', 'error', 'df' (DataFrame)\n    \"\"\"\n    try:\n        ths_code = ts_code_to_ths(ts_code)\n        q = _connect()\n        r = q.ths.tick_super_level1(ths_code, buffer_size=buffer_size_mb * 1024 * 1024)\n        if not r.success:\n            return {\"success\": False, \"error\": r.error, \"df\": None}\n        import pandas as pd\n        df = r.df.copy()\n        # 转换时间戳\n        if \"时间\" in df.columns:\n            df[\"时间\"] = pd.to_datetime(df[\"时间\"], unit=\"s\").dt.tz_localize(\"UTC\").dt.tz_convert(\"Asia/Shanghai\")\n        return {\"success\": True, \"error\": \"\", \"df\": df}\n    except Exception as e:\n        return {\"success\": False, \"error\": str(e), \"df\": None}\n\n\n# =============================================================================\n# 大单流向\n# =============================================================================\ndef get_big_order_flow(ts_code: str) -> dict[str, Any]:\n    \"\"\"获取大单流向数据\"\"\"\n    try:\n        ths_code = ts_code_to_ths(ts_code)\n        q = _connect()\n        r = q.ths.big_order_flow(ths_code)\n        if not r.success:\n            return {\"success\": False, \"error\": r.error, \"df\": None}\n        import pandas as pd\n        df = r.df.copy()\n        if \"时间\" in df.columns:\n            df[\"时间\"] = pd.to_datetime(df[\"时间\"], unit=\"s\").dt.tz_localize(\"UTC\").dt.tz_convert(\"Asia/Shanghai\")\n        return {\"success\": True, \"error\": \"\", \"df\": df}\n    except Exception as e:\n        return {\"success\": False, \"error\": str(e), \"df\": None}\n\n\n# =============================================================================\n# 委托订单簿（买/卖）\n# =============================================================================\ndef get_order_book(ts_code: str) -> dict[str, Any]:\n    \"\"\"获取委托订单簿（买盘/卖盘各10档）\"\"\"\n    try:\n        ths_code = ts_code_to_ths(ts_code)\n        q = _connect()\n        r_bid = q.ths.order_book_bid(ths_code)\n        r_ask = q.ths.order_book_ask(ths_code)\n        import pandas as pd\n        bid_df = r_bid.df.copy() if r_bid.success else pd.DataFrame()\n        ask_df = r_ask.df.copy() if r_ask.success else pd.DataFrame()\n        return {\n            \"success\": True,\n            \"error\": \"\",\n            \"bid\": bid_df,\n            \"ask\": ask_df,\n        }\n    except Exception as e:\n        return {\"success\": False, \"error\": str(e), \"bid\": None, \"ask\": None}\n\n\n# =============================================================================\n# 统一报价接口（用于 probe_ths_market_quotes 链路）\n# =============================================================================\ndef get_realtime_quote(ts_code: str) -> THSRealtimeQuote:\n    \"\"\"\n    统一实时报价，返回 THSRealtimeQuote\n    与 dual_source_quote.QuoteResult 保持兼容\n    \"\"\"\n    try:\n        ths_code = ts_code_to_ths(ts_code)\n        q = _connect()\n\n        # 用 Level2 tick 获取最新价格\n        r = q.ths.tick_super_level1(ths_code, buffer_size=10 * 1024 * 1024)\n        if not r.success:\n            return THSRealtimeQuote(\n                ts_code=ts_code, ths_code=ths_code,\n                status=\"failed\", error=r.error\n            )\n\n        df = r.df\n        if df is None or df.empty:\n            return THSRealtimeQuote(\n                ts_code=ts_code, ths_code=ths_code,\n                status=\"failed\", error=\"empty_df\"\n            )\n\n        import math\n        # 取最后一个有效价格行\n        # 过滤条件：时间是 unix timestamp（>1e9），价格非 NaN\n        import pandas as pd\n        def _is_unix_ts(x):\n            if pd.isna(x):\n                return False\n            try:\n                v = float(x)\n                return v > 1e9  # unix timestamp > 2001\n            except (ValueError, TypeError):\n                return False\n\n        valid = df[\n            df[\"时间\"].apply(_is_unix_ts) &\n            df[\"价格\"].notna() &\n            (df[\"价格\"] != 0)\n        ]\n        if valid.empty:\n            return THSRealtimeQuote(ts_code=ts_code, ths_code=ths_code, status=\"failed\", error=\"no_valid_price\")\n        latest = valid.iloc[-1]\n\n        def _safe_float(val, default=0.0):\n            if val is None or (isinstance(val, float) and math.isnan(val)):\n                return default\n            try:\n                return float(val)\n            except (ValueError, TypeError):\n                return default\n\n        def _safe_int(val, default=0):\n            if val is None or (isinstance(val, float) and math.isnan(val)):\n                return default\n            try:\n                return int(float(val))\n            except (ValueError, TypeError):\n                return default\n\n        price = _safe_float(latest.get(\"价格\"))\n        # 昨结字段有时全为NaN，此时用前一行的收盘价作为参考\n        prev_close = _safe_float(latest.get(\"昨结\"))\n        if prev_close == 0 and len(valid) > 1:\n            prev_close = _safe_float(valid.iloc[-2].get(\"价格\"))\n        change_pct = ((price - prev_close) / prev_close * 100) if prev_close > 0 else 0.0\n        volume = _safe_int(latest.get(\"成交量\"))\n        amount = _safe_float(latest.get(\"总金额\"))\n\n        return THSRealtimeQuote(\n            ts_code=ts_code,\n            ths_code=ths_code,\n            source=\"ths_level2\",\n            price=price,\n            change_pct=round(change_pct, 2),\n            volume=volume,\n            amount=amount,\n            bid1=_safe_float(latest.get(\"买1价\")),\n            ask1=_safe_float(latest.get(\"卖1价\")),\n            bid_vol1=_safe_int(latest.get(\"买1量\")),\n            ask_vol1=_safe_int(latest.get(\"卖1量\")),\n            turnover=_safe_float(latest.get(\"总金额\")),\n            status=\"ok\",\n        )\n    except Exception as e:\n        return THSRealtimeQuote(\n            ts_code=ts_code, ths_code=ths_code,\n            status=\"failed\", error=str(e)\n        )\n\n\n# =============================================================================\n# 健康探针（用于 investment_research_data_source_health）\n# =============================================================================\n\n[59 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1777515784814}}
