{"type":"message","id":"e21673d8","parentId":"53e23ac2","timestamp":"2026-04-30T02:23:36.364Z","message":{"role":"toolResult","toolCallId":"call_dy4xmEYHCurJpu3HsarKKkE1|fc_0f4ac913ff6b71190169f2bd28d724819ba3a8966abd275819","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n盘中实时大盘门禁 - 用于在买入推荐生成前检查当日实时大盘状态\n避免用昨日/前一日收盘口径支撑当日买入决策\n\n数据源：统一 DataFetcherManager（THS → Pytdx → Efinance → 腾讯直连）\n\"\"\"\nfrom __future__ import annotations\n\nimport json\nimport re\nimport ssl\nimport urllib.request\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any, Optional\n\n# 主要监控的指数代码（腾讯格式）\nINDEX_CODES = {\n    \"sh000001\": \"上证指数\",\n    \"sz399001\": \"深证成指\",\n    \"sz399006\": \"创业板指\",\n    \"sh000852\": \"中证1000\",\n}\n\n# THS/TDX/Efinance 格式\nINDEX_THX_CODES = {\n    \"上证指数\": \"000001.SH\",\n    \"深证成指\": \"399001.SZ\",\n    \"创业板指\": \"399006.SZ\",\n    \"中证1000\": \"000852.SH\",\n}\n\nINDEX_CODE_LIST = list(INDEX_CODES.keys())\n\n\ndef _get_unified_fetcher():\n    \"\"\"构建统一路由 fetcher（THS 最高优先级）。\"\"\"\n    import sys\n    from pathlib import Path\n    DSA = Path('/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis')\n    if str(DSA) not in sys.path:\n        sys.path.insert(0, str(DSA))\n    from data_provider.base import DataFetcherManager\n    from data_provider.efinance_fetcher import EfinanceFetcher\n    from data_provider.ths_market_fetcher import ThsMarketFetcher\n    from data_provider.pytdx_fetcher import PytdxFetcher\n\n    # 这些 fetcher 构造函数并不统一支持 priority 参数，统一用实例属性设置优先级。\n    ths = ThsMarketFetcher()\n    ths.priority = 0\n    pytdx = PytdxFetcher()\n    pytdx.priority = 1\n    efinance = EfinanceFetcher()\n    efinance.priority = 2\n\n    fetchers = [\n        ths,       # 优先级 0：同花顺\n        pytdx,     # 优先级 1：通达信\n        efinance,  # 优先级 2：efinance\n    ]\n    return DataFetcherManager(fetchers=fetchers)\n\n\ndef fetch_tencent_quote(symbol: str, timeout: float = 8.0) -> Optional[dict]:\n    \"\"\"从腾讯获取单只股票/指数的实时行情（降级兜底）\"\"\"\n    url = f\"http://qt.gtimg.cn/q={symbol}\"\n    try:\n        with urllib.request.urlopen(url, timeout=timeout) as resp:\n            text = resp.read().decode(\"gbk\")\n        m = re.match(r'v_\\w+=\"(.*)\";', text.strip())\n        if not m:\n            return None\n        f = m.group(1).split(\"~\")\n        if len(f) < 48:\n            return None\n        price = float(f[3] or 0)\n        change_pct = float(f[32] or 0)\n        return {\n            \"symbol\": symbol,\n            \"name\": f[1] or \"\",\n            \"price\": price,\n            \"change_pct\": change_pct,\n            \"valid\": price > 0,\n            \"source\": \"tencent_direct\",\n        }\n    except Exception:\n        return None\n\n\ndef fetch_unified_quote(symbol: str) -> Optional[dict]:\n    \"\"\"通过统一路由获取指数数据（THS → Pytdx → Efinance）。\"\"\"\n    try:\n        mgr = _get_unified_fetcher()\n        # 转换腾讯格式 → THX 格式\n        thx_code = INDEX_THX_CODES.get(INDEX_CODES.get(symbol, \"\"), \"\")\n        if not thx_code:\n            # 已经是 THX 格式\n            thx_code = symbol\n        quote = mgr.get_realtime_quote(thx_code)\n        if quote is not None and quote.price is not None and quote.price > 0:\n            return {\n                \"symbol\": symbol,\n                \"name\": getattr(quote, 'name', '') or \"\",\n                \"price\": quote.price,\n                \"change_pct\": quote.change_pct or 0.0,\n                \"valid\": True,\n                \"source\": \"unified_fetcher\",\n            }\n    except Exception:\n        pass\n    return None\n\n\ndef fetch_multi_quote(symbols: list[str]) -> dict[str, dict]:\n    \"\"\"批量获取实时行情（统一路由优先，降级腾讯直连）。\"\"\"\n    results = {}\n    for sym in symbols:\n        # 优先统一路由\n        quote = fetch_unified_quote(sym)\n        if quote:\n            results[sym] = quote\n        else:\n            # 降级到腾讯直连\n            q = fetch_tencent_quote(sym)\n            if q:\n                results[sym] = q\n    return results\n\n\ndef is_trading_hours() -> bool:\n    \"\"\"判断当前是否在交易时段（A股）\"\"\"\n    now = datetime.now()\n    hour = now.hour\n    minute = now.minute\n    # 上午: 09:30-11:30, 下午: 13:00-15:00\n    if hour == 9 and minute < 30:\n        return False\n    if hour == 11 and minute > 30:\n        return False\n    if hour == 12:\n        return False\n    return (hour == 9 and minute >= 30) or (10 <= hour < 11) or (hour == 11 and minute <= 30) or (hour == 13) or (hour == 14) or (hour == 15 and minute == 0)\n\n\ndef evaluate_intraday_market_gate(quotes: dict[str, dict]) -> dict[str, Any]:\n    \"\"\"\n    基于实时指数涨跌幅评估盘中市场门禁状态\n    \n    返回:\n    {\n        \"enabled\": bool,  # 是否启用（交易时段且有数据）\n        \"indices\": dict,  # 各指数实时数据\n        \"negative_count\": int,  # 下跌指数数量\n        \"total_count\": int,  # 有效指数总数\n        \"weakness_score\": float,  # 弱势分数 (下跌数/总数)\n        \"gate_action\": str,  # \"none\" | \"cautious\" | \"halt\"\n        \"reason\": str,\n    }\n    \"\"\"\n    if not quotes:\n        return {\n            \"enabled\": False,\n            \"reason\": \"无可用实时指数数据\",\n            \"indices\": {},\n            \"negative_count\": 0,\n            \"total_count\": 0,\n            \"weakness_score\": 0.0,\n            \"gate_action\": \"none\",\n        }\n    \n    valid_quotes = {k: v for k, v in quotes.items() if v.get(\"valid\", False)}\n    if not valid_quotes:\n        return {\n            \"enabled\": False,\n            \"reason\": \"所有指数数据无效\",\n            \"indices\": quotes,\n            \"negative_count\": 0,\n            \"total_count\": 0,\n            \"weakness_score\": 0.0,\n            \"gate_action\": \"none\",\n        }\n    \n    negative_count = sum(1 for v in valid_quotes.values() if v.get(\"change_pct\", 0) < 0)\n    total_count = len(valid_quotes)\n    weakness_score = negative_count / total_count if total_count > 0 else 0.0\n    \n    # 规则：>=3/4 指数下跌 → halt; 2/4 下跌 → cautious\n    if negative_count >= 3:\n        gate_action = \"halt\"\n        reason = f\"{negative_count}/{total_count} 指数下跌，盘中的门禁触发 halt\"\n    elif negative_count >= 2:\n        gate_action = \"cautious\"\n        reason = f\"{negative_count}/{total_count} 指数下跌，盘中进入谨慎模式\"\n    else:\n        gate_action = \"none\"\n        reason = f\"仅 {negative_count}/{total_count} 指数下跌，暂不触发门禁\"\n    \n    return {\n        \"enabled\": True,\n        \"indices\": valid_quotes,\n        \"negative_count\": negative_count,\n        \"total_count\": total_count,\n        \"weakness_score\": weakness_score,\n        \"gate_action\": gate_action,\n        \"reason\": reason,\n    }\n\n\ndef get_intraday_market_state(date_tag: str) -> dict[str, Any]:\n    \"\"\"\n    获取指定日期的盘中市场状态\n    \n    如果日期是今天且在交易时段，返回实时指数门禁评估结果\n    否则返回 {\"enabled\": False}\n    \"\"\"\n    today = datetime.now().strftime(\"%Y%m%d\")\n    \n    # 只有今天是交易日且在交易时段才获取实时数据\n    if date_tag != today:\n        return {\"enabled\": False, \"reason\": f\"非今日({date_tag})\"}\n    \n    if not is_trading_hours():\n        return {\"enabled\": False, \"reason\": \"非交易时段\"}\n    \n    quotes = fetch_multi_quote(INDEX_CODE_LIST)\n    gate_result = evaluate_intraday_market_gate(quotes)\n    \n    return gate_result\n\n\nif __name__ == \"__main__\":\n    import sys\n    date_arg = sys.argv[1] if len(sys.argv) > 1 else datetime.now().strftime(\"%Y%m%d\")\n    result = get_intraday_market_state(date_arg)\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n"}],"isError":false,"timestamp":1777515816364}}
