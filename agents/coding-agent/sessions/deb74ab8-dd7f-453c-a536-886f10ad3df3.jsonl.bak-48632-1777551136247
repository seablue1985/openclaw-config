ates:\n        try:\n            return ImageFont.truetype(p, size=size)\n        except Exception:\n            continue\n    return ImageFont.load_default()\n\nW = H = 1200\ncenter = (W//2, H//2)\n\n# palette\nGREEN_DARK = (33, 92, 68)\nGREEN_MAIN = (63, 143, 102)\nGREEN_LIGHT = (176, 224, 196)\nMINT = (220, 244, 231)\nGOLD = (208, 173, 92)\nGOLD_LIGHT = (235, 214, 155)\nWHITE = (250, 252, 249)\nTEXT_DARK = (30, 64, 50)\n\n\ndef radial_bg(base1, base2):\n    img = Image.new('RGB', (W, H), base1)\n    px = img.load()\n    cx, cy = center\n    maxd = math.hypot(cx, cy)\n    for y in range(H):\n        for x in range(W):\n            d = math.hypot(x-cx, y-cy)/maxd\n            t = min(1, max(0, d))\n            r = int(base2[0]*t + base1[0]*(1-t))\n            g = int(base2[1]*t + base1[1]*(1-t))\n            b = int(base2[2]*t + base1[2]*(1-t))\n            px[x,y]=(r,g,b)\n    return img\n\n\ndef draw_book_leaf(draw, scale=1.0, offset=(0,0), color=GREEN_MAIN):\n    cx, cy = center[0]+offset[0], center[1]+offset[1]\n    # open book\n    draw.rounded_rectangle((cx-180*scale, cy+40*scale, cx-10*scale, cy+165*scale), radius=18, fill=WHITE, outline=color, width=6)\n    draw.rounded_rectangle((cx+10*scale, cy+40*scale, cx+180*scale, cy+165*scale), radius=18, fill=WHITE, outline=color, width=6)\n    draw.line((cx, cy+38*scale, cx, cy+168*scale), fill=color, width=int(6*scale))\n    # leaf stem\n    draw.line((cx, cy+45*scale, cx, cy-100*scale), fill=color, width=int(10*scale))\n    # leaves\n    draw.ellipse((cx-120*scale, cy-120*scale, cx-15*scale, cy-20*scale), fill=GREEN_LIGHT, outline=color, width=6)\n    draw.ellipse((cx+15*scale, cy-145*scale, cx+135*scale, cy-30*scale), fill=MINT, outline=color, width=6)\n\n\ndef draw_stars(draw, y=235, n=5, r=12, color=GOLD):\n    spacing = 60\n    total = spacing*(n-1)\n    start = center[0]-total//2\n    for i in range(n):\n        x = start + i*spacing\n        draw.regular_polygon((x, y, r), n_sides=5, rotation=0, fill=color)\n\n\ndef text_center(draw, xy, text, font, fill):\n    bbox = draw.textbbox((0,0), text, font=font)\n    w = bbox[2]-bbox[0]\n    h = bbox[3]-bbox[1]\n    draw.text((xy[0]-w/2, xy[1]-h/2), text, font=font, fill=fill)\n\n# 方案1 圆形校徽\nimg1 = radial_bg((245,250,246),(213,235,220))\nd = ImageDraw.Draw(img1)\nd.ellipse((90,90,W-90,H-90), fill=WHITE, outline=GREEN_DARK, width=22)\nd.ellipse((140,140,W-140,H-140), fill=(244,250,245), outline=GOLD, width=8)\nd.ellipse((210,210,W-210,H-210), fill=(236,247,239), outline=GREEN_MAIN, width=10)\ndraw_stars(d, y=265, n=5, r=14)\ntext_center(d,(600,180),'汇东实验学校', get_font(74), GREEN_DARK)\ntext_center(d,(600,300),'一年级6班', get_font(58), GREEN_MAIN)\ndraw_book_leaf(d, scale=1.0, offset=(0,20), color=GREEN_MAIN)\ntext_center(d,(600,935),'向阳生长  ·  自信闪亮', get_font(48), TEXT_DARK)\nimg1 = img1.filter(ImageFilter.SMOOTH_MORE)\nimg1.save(OUT_DIR/'badge_green_round.png')\n\n# 方案2 盾形高级感\nimg2 = radial_bg((241,249,244),(196,230,206))\nd = ImageDraw.Draw(img2)\nshield = [(600,95),(950,220),(890,760),(600,1060),(310,760),(250,220)]\nd.polygon(shield, fill=WHITE, outline=GREEN_DARK)\n# inner shield\nshield2 = [(600,145),(890,250),(840,730),(600,980),(360,730),(310,250)]\nd.polygon(shield2, fill=(237,247,241), outline=GOLD, width=8)\ntext_center(d,(600,235),'汇东实验学校', get_font(60), GREEN_DARK)\ntext_center(d,(600,320),'GRADE 1 · CLASS 6', get_font(34), GOLD)\n# center circle\n# use big 6 with leaf\nfor r, fill, outline, w in [(180,(255,255,255),GREEN_MAIN,8),(160,(229,244,235),GOLD,4)]:\n    d.ellipse((600-r,520-r,600+r,520+r), fill=fill, outline=outline, width=w)\ntext_center(d,(600,470),'6', get_font(230), GREEN_DARK)\ntext_center(d,(600,595),'一年级六班', get_font(58), GREEN_MAIN)\n# laurel-ish leaves\nfor side in [-1,1]:\n    for i in range(6):\n        x = 600 + side*(240 + i*15)\n        y = 650 - i*58\n        box = (x-26, y-14, x+26, y+14)\n        d.ellipse(box, fill=GREEN_LIGHT, outline=GREEN_MAIN, width=3)\ntext_center(d,(600,860),'成长 · 阅读 · 友爱', get_font(48), TEXT_DARK)\nimg2.save(OUT_DIR/'badge_green_shield.png')\n\n# 方案3 清新自然艺术感\nimg3 = radial_bg((248,252,248),(221,241,228))\nd = ImageDraw.Draw(img3)\nd.rounded_rectangle((120,120,W-120,H-120), radius=200, fill=WHITE, outline=GREEN_MAIN, width=16)\nd.rounded_rectangle((170,170,W-170,H-170), radius=180, fill=(241,249,243), outline=GOLD_LIGHT, width=6)\n# soft arch\nfor r, col, w in [(260,GREEN_LIGHT,18),(230,MINT,18),(200,GOLD_LIGHT,8)]:\n    d.arc((600-r,310-r,600+r,310+r), 200, 340, fill=col, width=w)\ntext_center(d,(600,255),'汇东实验学校', get_font(70), GREEN_DARK)\ntext_center(d,(600,340),'一年级6班', get_font(60), GREEN_MAIN)\n# sprout in medallion\nfor r, fill, outline, w in [(195,(255,255,255),GREEN_MAIN,8),(170,(233,246,238),None,1)]:\n    d.ellipse((600-r,650-r,600+r,650+r), fill=fill, outline=outline, width=w)\n# stem and leaves\ncx, cy = 600, 680\nd.line((cx, cy+90, cx, cy-35), fill=GREEN_DARK, width=12)\nd.ellipse((cx-130, cy-60, cx-20, cy+30), fill=GREEN_LIGHT, outline=GREEN_MAIN, width=6)\nd.ellipse((cx+20, cy-100, cx+145, cy+10), fill=MINT, outline=GREEN_MAIN, width=6)\n# book base\nfor x1,x2 in [(cx-155,cx-10),(cx+10,cx+155)]:\n    d.rounded_rectangle((x1, cy+80, x2, cy+180), radius=18, fill=WHITE, outline=GREEN_MAIN, width=5)\nd.line((cx, cy+78, cx, cy+182), fill=GREEN_MAIN, width=5)\ntext_center(d,(600,965),'绿意童年  向上而生', get_font(50), TEXT_DARK)\nimg3.save(OUT_DIR/'badge_green_nature.png')\n\n# contact sheet\nsheet = Image.new('RGB',(1800,700),(247,250,247))\nfor i,name in enumerate(['badge_green_round.png','badge_green_shield.png','badge_green_nature.png']):\n    im = Image.open(OUT_DIR/name).resize((600,600))\n    sheet.paste(im,(i*600,50))\n    dd = ImageDraw.Draw(sheet)\n    labels=['方案A 圆形校徽','方案B 盾形高级','方案C 清新自然']\n    text_center(dd,(i*600+300,665),labels[i],get_font(34),TEXT_DARK)\nsheet.save(OUT_DIR/'badge_green_contact_sheet.png')\nprint(OUT_DIR)\nfor p in OUT_DIR.iterdir():\n    print(p.name)\nPY","timeout":60}}],"api":"openai-res