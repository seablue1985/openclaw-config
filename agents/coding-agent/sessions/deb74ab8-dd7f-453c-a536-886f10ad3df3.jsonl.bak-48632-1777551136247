def _market_breadth_estimate():\n    \"\"\"根据主要指数表现估算市场宽度情绪\"\"\"\n    try:\n        req = urllib.request.Request(\"http://qt.gtimg.cn/q=sh000001,sz399001\", headers={\"User-Agent\": \"Mozilla/5.0\"})\n        with urllib.request.urlopen(req, timeout=4) as r:\n            bd = r.read().decode(\"gbk\", errors=\"replace\")\n        parts = next((l.split(\"~\") for l in bd.strip().split(\"\\n\") if \"sh000001\" in l and \"none_match\" not in l), [])\n        if len(parts) > 4 and parts[3] and parts[4]:\n            idx_pct = float(parts[3]) / float(parts[4]) * 100 - 100 if float(parts[4]) else 0\n            if idx_pct > 1.0:   return {\"up\": 2500, \"down\": 1500, \"total\": 4000}\n            elif idx_pct > 0.3: return {\"up\": 2100, \"down\": 1800, \"total\": 3900}\n            elif idx_pct > -0.3:return {\"up\": 1900, \"down\": 1900, \"total\": 3800}\n            elif idx_pct > -1.0:return {\"up\": 1600, \"down\": 2300, \"total\": 3900}\n            else:               return {\"up\": 1200, \"down\": 2800, \"total\": 4000}\n    except: pass\n    return {\"up\": 0, \"down\": 0, \"total\": 0}\n\ndef fetch_market_overview() -> dict:\n    \"\"\"六大指数快照 + 市场宽度 + 温度计\"\"\"\n    indices_labels = [\n        (\"sh000001\", \"上证指数\"),\n        (\"sz399001\", \"深证成指\"),\n        (\"sh000300\", \"沪深300\"),\n        (\"sz399006\", \"创业板指\"),\n        (\"sh000688\", \"科创50\"),\n        (\"bj899050\", \"北证50\"),\n    ]\n    codes_str = \",\".join(c for c, _ in indices_labels)\n    indices = _fetch_index_data(codes_str, indices_labels)\n    breadth = _market_breadth_estimate()\n    valid_pcts = [r[\"pct\"] for r in indices if r.get(\"pct\") is not None]\n    avg_pct = round(sum(valid_pcts) / max(len(valid_pcts), 1), 2)\n    if breadth.get(\"total\", 0) > 0:\n        breadth[\"temp\"] = round(breadth[\"up\"] / breadth[\"total\"] * 100, 1)\n    if   avg_pct >= 1.5: temp_label = \"🔥 极热\"\n    elif avg_pct >= 0.5: temp_label = \"☀️ 较热\"\n    elif avg_pct >= -0.3:temp_label = \"🌤️ 中性\"\n    elif avg_pct >= -1.5:temp_label = \"🌧️ 偏冷\"\n    else:                temp_label = \"❄️ 极冷\"\n    return {\n        \"indices\": indices,\n        \"breadth\": breadth,\n        \"avg_pct\": avg_pct,\n        \"temp_label\": temp_label,\n        \"ts\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n    }\n\n[232 more lines in file. Use offset=1668 to continue.]"}],"isError":false,"timestamp":1777513557842}}
