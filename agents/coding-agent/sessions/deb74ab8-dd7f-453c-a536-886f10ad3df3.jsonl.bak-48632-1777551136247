{"type":"message","id":"d383006e","parentId":"f6727eec","timestamp":"2026-04-30T02:23:36.365Z","message":{"role":"toolResult","toolCallId":"call_SupTAsJkXWaCGL6C7P0LyHSV|fc_0f4ac913ff6b71190169f2bd28d79c819b89b961b6b0b48d7c","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport csv\nimport json\nimport re\nimport signal\nimport sys\nimport urllib.request\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nANALYZER_TIMEOUT_SEC = 15  # 单只股票分析超时秒数，超时则视为 unavailable\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / 'research' / 'reports'\nDSA_ROOT = Path('/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis_upgrade_preview')\n\n# ── thresholds for analyzer_service veto ────────────────────────────────────\nSENTIMENT_SCORE_MIN = 40          # below this → block\nNEGATIVE_ADVICES = {\"减仓\", \"卖出\"}\n\n# ── normalise helpers ───────────────────────────────────────────────────────\nCODE_FIELDS = ['ts_code', 'ticker', 'symbol', 'code', 'stock_code']\nSIDE_FIELDS = ['side', 'action', 'order_side', 'trade_side', 'signal_side']\nBUY_VALUES = {'buy', 'open_buy', 'long', 'b'}\n\n\ndef normalize_symbol(symbol: str) -> str:\n    s = str(symbol or '').strip().upper()\n    if not s:\n        return s\n    s = s.replace('.', '')\n    if re.fullmatch(r'\\d{6}SH', s):\n        return 'sh' + s[:6]\n    if re.fullmatch(r'\\d{6}SZ', s):\n        return 'sz' + s[:6]\n    if re.fullmatch(r'SH\\d{6}', s):\n        return 'sh' + s[2:]\n    if re.fullmatch(r'SZ\\d{6}', s):\n        return 'sz' + s[2:]\n    if re.fullmatch(r'\\d{6}', s):\n        return ('sh' if s.startswith('6') else 'sz') + s\n    return s.lower()\n\n\ndef _ths_ts_code(symbol: str) -> str:\n    \"\"\"Convert symbol to THS/TDX format (e.g. 002920.SZ).\"\"\"\n    s = str(symbol or '').strip().upper()\n    s = s.replace('.', '').replace('SH', '').replace('SZ', '')\n    if len(s) == 6:\n        return ('SZ' if s.startswith(('0', '3')) else 'SH') + s\n    # already in format\n    return symbol.upper()\n\n\n# ── unified fetcher (THS/TDX priority) ─────────────────────────────────────\ndef _get_unified_fetcher():\n    \"\"\"Return a configured DataFetcherManager with THS/TDX at highest priority.\"\"\"\n    if str(DSA_ROOT) not in sys.path:\n        sys.path.insert(0, str(DSA_ROOT))\n    from data_provider.base import DataFetcherManager\n    from data_provider.efinance_fetcher import EfinanceFetcher\n    from data_provider.akshare_fetcher import AkshareFetcher\n    from data_provider.ths_market_fetcher import ThsMarketFetcher\n    from data_provider.pytdx_fetcher import PytdxFetcher\n    from data_provider.tushare_fetcher import TushareFetcher\n    from data_provider.baostock_fetcher import BaostockFetcher\n\n    fetchers = [\n        ThsMarketFetcher(),    # 同花顺最高优先级（priority=0类属性）\n        PytdxFetcher(),\n        EfinanceFetcher(),\n        AkshareFetcher(),\n        TushareFetcher(),\n        BaostockFetcher(),\n    ]\n    return DataFetcherManager(fetchers=fetchers)\n\n\n# ── quote (unified fetcher with THS/TDX priority, fallback to tencent) ──────\ndef fetch_quote(symbol: str) -> dict[str, Any]:\n    # 方法1：尝试统一路由（THS → Pytdx → Efinance → AkShare）\n    try:\n        manager = _get_unified_fetcher()\n        ts_code = _ths_ts_code(symbol)\n        quote = manager.get_realtime_quote(ts_code)\n        if quote is not None and quote.price is not None and quote.price > 0:\n            return {\n                'valid': True,\n                'input_symbol': symbol,\n                'market_symbol': ts_code,\n                'name': getattr(quote, 'name', '') or '',\n                'price': quote.price,\n                'change_pct': quote.change_pct or 0.0,\n                'source': 'unified_fetcher',\n            }\n    except Exception:\n        pass\n\n    # 方法2：降级到腾讯直连\n    market_symbol = normalize_symbol(symbol)\n    url = f'http://qt.gtimg.cn/q={market_symbol}'\n    try:\n        with urllib.request.urlopen(url, timeout=8) as resp:\n            text = resp.read().decode('gbk', errors='ignore')\n        m = re.match(r'v_\\w+=\"(.*)\";', text.strip())\n        if not m:\n            return {'valid': False, 'symbol': symbol, 'reason': 'parse_failed'}\n        f = m.group(1).split('~')\n        if len(f) < 48:\n            return {'valid': False, 'symbol': symbol, 'reason': 'field_short'}\n        return {\n            'valid': True,\n            'input_symbol': symbol,\n            'market_symbol': market_symbol,\n            'name': f[1] or '',\n            'price': float(f[3] or 0),\n            'change_pct': float(f[32] or 0),\n            'source': 'tencent_fallback',\n        }\n    except Exception as e:\n        return {'valid': False, 'symbol': symbol, 'reason': repr(e)}\n\n\n# ── analyzer_service ────────────────────────────────────────────────────────\ndef _load_analyzer_service():\n    \"\"\"Lazy-import analyzer_service; return (module, error).\"\"\"\n    if not (DSA_ROOT / 'analyzer_service.py').exists():\n        return None, 'dsa_root_not_found'\n    if str(DSA_ROOT) not in sys.path:\n        sys.path.insert(0, str(DSA_ROOT))\n    try:\n        import importlib\n        mod = importlib.import_module('analyzer_service')\n        return mod, None\n    except Exception as e:\n        return None, repr(e)\n\n\ndef _timeout_handler(signum, frame):\n    raise TimeoutError('analyzer_service timed out')\n\n\ndef fetch_analyzer_analysis(symbol: str) -> dict[str, Any]:\n    \"\"\"\n    Call analyzer_service.analyze_stock with a per-stock timeout.\n    Returns a dict with:\n      - available: bool\n      - sentiment_score: int | None\n      - operation_advice: str | None\n      - core_conclusion: str | None\n      - error: str | None\n    \"\"\"\n    mod, err = _load_analyzer_service()\n    if err:\n        return {'available': False, 'symbol': symbol, 'error': err}\n    old_handler = signal.signal(signal.SIGALRM, _timeout_handler)\n    signal.alarm(ANALYZER_TIMEOUT_SEC)\n    try:\n        result = mod.analyze_stock(symbol)\n        signal.alarm(0)\n        if result is None:\n            return {'available': False, 'symbol': symbol, 'error': 'analyze_stock returned None'}\n        return {\n            'available': True,\n            'symbol': symbol,\n            'sentiment_score': getattr(result, 'sentiment_score', None),\n            'operation_advice': getattr(result, 'operation_advice', None),\n            'core_conclusion': getattr(result, 'core_conclusion', None) or '',\n        }\n    except TimeoutError:\n        signal.alarm(0)\n        return {'available': False, 'symbol': symbol, 'error': f'timeout_after_{ANALYZER_TIMEOUT_SEC}s'}\n    except Exception as e:\n        signal.alarm(0)\n        return {'available': False, 'symbol': symbol, 'error': repr(e)}\n    finally:\n        signal.signal(signal.SIGALRM, old_handler)\n\n\ndef analyzer_veto(analysis: dict[str, Any]) -> tuple[bool, str]:\n    \"\"\"\n    Returns (should_block, reason).\n    \"\"\"\n    if not analysis.get('available'):\n        return False, ''   # no data → don't block on analyzer basis\n    score = analysis.get('sentiment_score')\n    advice = analysis.get('operation_advice') or ''\n    reasons = []\n    if score is not None and int(score) < SENTIMENT_SCORE_MIN:\n        reasons.append(f\"sentiment_score {score} < {SENTIMENT_SCORE_MIN}\")\n    if advice in NEGATIVE_ADVICES:\n        reasons.append(f\"operation_advice '{advice}' in {NEGATIVE_ADVICES}\")\n    if reasons:\n        return True, '; '.join(reasons)\n    return False, ''\n\n\n# ── csv reader ───────────────────────────────────────────────────────────────\ndef load_candidates_from_csv(path: Path) -> list[dict[str, Any]]:\n    rows: list[dict[str, Any]] = []\n    if not path.exists():\n        return rows\n    with path.open('r', encoding='utf-8', newline='') as f:\n        reader = csv.DictReader(f)\n        for row in read