{"type":"message","id":"8e90fb1a","parentId":"741a9673","timestamp":"2026-04-30T01:35:46.551Z","message":{"role":"toolResult","toolCallId":"call_00_hr6RIJMIzCUuPcp6Tlqrf1Zp","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport re\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom runtime_state_schema import build_precheck_runtime_truth, get_runtime_truth\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\nWORKSPACE_ROOT = ROOT.parents[1] if len(ROOT.parents) >= 2 else ROOT\nSTATE_PATH = Path(\n    str(\n        os.environ.get(\"PREMARKET_PRECHECK_STATE_PATH\")\n        or (WORKSPACE_ROOT / \"memory\" / \"premarket_precheck_state.json\")\n    )\n)\n\n\ndef now_shanghai() -> datetime:\n    return datetime.now()\n\n\ndef load_state() -> dict:\n    if not STATE_PATH.exists():\n        return {}\n    try:\n        return json.loads(STATE_PATH.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef save_state(payload: dict) -> None:\n    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)\n    STATE_PATH.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef is_trading_day(date_str: str) -> bool:\n    \"\"\"\n    交易日判断：优先用腾讯行情 API，API 异常时降级为工作日（周一~五）判断。\n    \"\"\"\n    try:\n        date_obj = datetime.strptime(date_str, \"%Y-%m-%d\")\n        weekday_fallback = date_obj.weekday() < 5\n    except Exception:\n        weekday_fallback = False\n\n    if date_obj.weekday() >= 5:  # 周末直接返回 False\n        return False\n\n    try:\n        import urllib.request\n        req = urllib.request.Request(\n            \"https://qt.gtimg.cn/q=sh000001\",\n            headers={\"User-Agent\": \"Mozilla/5.0\"},\n        )\n        with urllib.request.urlopen(req, timeout=5) as resp:\n            content = resp.read().decode(\"gbk\", errors=\"replace\")\n        for line in content.split(\";\"):\n            if \"sh000001\" in line:\n                parts = line.split(\"~\")\n                if len(parts) > 30:\n                    mkt_str = parts[30].strip()[:8]\n                    market_date = f\"{mkt_str[:4]}-{mkt_str[4:6]}-{mkt_str[6:8]}\"\n                    return market_date == date_str\n                break\n        return weekday_fallback\n    except Exception:\n        return weekday_fallback\n\n\ndef in_window(hhmm: str, start: str, end: str) -> bool:\n    return start <= hhmm <= end\n\n\ndef _extract_yyyymmdd(name: str) -> str:\n    m = re.search(r\"(20\\d{6})\", name)\n    return m.group(1) if m else \"\"\n\n\ndef latest_by_patterns(\n    patterns: list[str],\n    *,\n    required_date_tag: str = \"\",\n    allow_stale: bool = True,\n) -> Path | None:\n    if required_date_tag:\n        for pat in patterns:\n            dated = sorted(\n                [p for p in REPORT_DIR.glob(pat) if _extract_yyyymmdd(p.name) == required_date_tag],\n                key=*** p: p.stat().st_mtime,\n                reverse=True,\n            )\n            if dated:\n                return dated[0]\n        if not allow_stale:\n            return None\n\n    for pat in patterns:\n        files = sorted(REPORT_DIR.glob(pat), key=*** p: p.stat().st_mtime, reverse=True)\n        if files:\n            return files[0]\n    return None\n\n\ndef build_empty_today_ticket(date_tag: str) -> tuple[Path, dict]:\n    \"\"\"构造当日空票据，避免因“无当日票据文件”导致流程中断。\"\"\"\n    fallback = latest_by_patterns(\n        [\n            \"stock_signal_tickets_live_*.csv\",\n            \"stock_signal_tickets_*.csv\",\n            \"live_stock_signal_*.csv\",\n            \"stock_orders_signal_*.csv\",\n            \"joinquant_order_tickets_*.csv\",\n        ],\n        allow_stale=True,\n    )\n\n    default_header = \"ticket_time,ts_code,side,source_time,source_qty,source_price,source_amount,reason,confirm_status,execute_status,notes\"\n    header = default_header\n    if fallback and fallback.exists():\n        try:\n            first_line = fallback.read_text(encoding=\"utf-8\").splitlines()[0].strip()\n            if first_line:\n                header = first_line\n        except Exception:\n            pass\n\n    out = REPORT_DIR / f\"joinquant_order_tickets_{date_tag}_autogen.csv\"\n    out.write_text(header + \"\\n\", encoding=\"utf-8\")\n    return out, {\n        \"autogen\": True,\n        \"autogen_reason\": \"no_today_tickets_use_empty_template\",\n        \"autogen_from\": str(fallback) if fallback else \"\",\n    }\n\n\ndef prepare_today_ticket(date_tag: str, available_cash: float, account_nav: float) -> tuple[Path | None, dict]:\n    cmd = [\n        \"python3\",\n        \"scripts/prepare_live_signal_tickets.py\",\n        \"--date\",\n        date_tag,\n        \"--available-cash\",\n        str(available_cash),\n        \"--account-nav\",\n        str(account_nav),\n    ]\n    proc = subprocess.run(cmd, cwd=str(ROOT), capture_output=True, text=True)\n\n    meta: dict = {\n        \"prepared\": proc.returncode == 0,\n        \"cmd\": \" \".join(cmd),\n        \"returncode\": proc.returncode,\n        \"stdout\": proc.stdout,\n        \"stderr\": proc.stderr,\n    }\n    stdout = (proc.stdout or \"\").strip()\n    if stdout:\n        try:\n            parsed = json.loads(stdout)\n            if isinstance(parsed, dict):\n                meta.update(parsed)\n        except Exception:\n            pass\n\n    ticket_file = str(meta.get(\"ticket_file\") or \"\").strip()\n    ticket_path = Path(ticket_file).resolve() if ticket_file else None\n    if ticket_path is not None and ticket_path.exists():\n        meta[\"autogen\"] = bool(meta.get(\"status\") == \"EMPTY\")\n        meta[\"autogen_reason\"] = str(meta.get(\"reason\") or \"\")\n        return ticket_path, meta\n    return None, meta\n\n\ndef run_precheck(available_cash: float, account_nav: float, tickets: Path, holdings: Path | None) -> dict:\n    cmd