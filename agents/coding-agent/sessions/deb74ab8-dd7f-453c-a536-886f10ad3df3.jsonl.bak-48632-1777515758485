ode or \".\" not in code:\n        return code\n    symbol, market = code.split(\".\", 1)\n    market = market.lower()\n    if market in {\"sh\", \"sz\", \"bj\"}:\n        prefix = {\"sh\": \"USHA\", \"sz\": \"USZA\", \"bj\": \"USBA\"}.get(market, \"USZA\")\n        return f\"{prefix}{symbol}\"\n    return f\"USZA{symbol}\"\n\n\ndef ths_to_ts_code(ths_code: str) -> str:\n    \"\"\"THS 格式 → 标准 ts_code\"\"\"\n    code = (ths_code or \"\").strip().upper()\n    if len(code) != 10:\n        return code\n    prefix = code[:4]\n    symbol = code[4:]\n    market_map = {\"USHA\": \"SH\", \"USZA\": \"SZ\", \"USBA\": \"BJ\"}\n    market = market_map.get(prefix, \"SZ\")\n\n[239 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1777513168706}}
