l_reason:\n                embedded_truth[\"trading_status_reason\"] = empty_signal_reason\n                embedded_truth[\"state_reason\"] = empty_signal_reason\n        return embedded_truth\n\n    precheck = parsed.get(\"precheck\") or {}\n    reasons = [str(x).strip() for x in (precheck.get(\"reasons\") or []) if str(x).strip()]\n    halt_reason = str(parsed.get(\"halt_reason\") or \"\").strip()\n    hard_stop = bool(parsed.get(\"hard_stop\"))\n    risk_off = bool(parsed.get(\"risk_off\"))\n    halt_new_buy = bool(parsed.get(\"halt_new_buy\"))\n    mode = str(parsed.get(\"mode\") or \"\").strip()\n    precheck_passed = bool(precheck.get(\"passed\"))\n\n    no_order_reasons = {\n        \"预处理后无有效信号（pending_after_gate=0）\",\n        \"净额合并后无有效订单（pending_netted=0）\",\n    }\n    only_no_order_reasons = bool(reasons) and all(reason in no_order_reasons for reason in reasons)\n\n    empty_signal_reason = \"\"\n    if only_no_order_reasons and isinstance(ticket_meta, dict):\n        empty_signal_reason = str(ticket_meta.get(\"reason\") or ticket_meta.get(\"autogen_reason\") or \"\").strip()\n\n    return build_precheck_runtime_truth(\n        mode=mode,\n        risk_off=risk_off,\n        hard_stop=hard_stop,\n        halt_new_buy=halt_new_buy,\n        halt_reason=halt_reason,\n        gate_reasons=parsed.get(\"gate_reasons\") or [],\n        precheck_passed=precheck_passed,\n        pipeline_ok=raw_returncode == 0,\n        precheck_reasons=reasons,\n        source=\"auto_run_premarket_precheck\",\n        empty_signal_reason=empty_signal_reason,\n    )\n\n\ndef classify_precheck_status(result: dict, ticket_meta: dict | None = None) -> tuple[str, str]:\n    truth = build_execution_truth(result, ticket_meta=ticket_meta)\n    return str(truth.get(\"trading_status\") or \"FULL_HALT\"), str(truth.get(\"trading_status_reason\") or \"\")\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"自动盘前强制检查执行器\")\n    parser.add_argument(\"--available-cash