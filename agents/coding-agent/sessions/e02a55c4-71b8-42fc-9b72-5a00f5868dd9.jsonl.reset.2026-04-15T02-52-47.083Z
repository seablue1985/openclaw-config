been made to start a new process before the\n        current process has finished its bootstrapping phase.\n\n        This probably means that you are not using fork to start your\n        child processes and you have forgotten to use the proper idiom\n        in the main module:\n\n            if __name__ == '__main__':\n                freeze_support()\n                ...\n\n        The \"freeze_support()\" line can be omitted if the program\n        is not going to be frozen to produce an executable.\n\n        To fix this issue, refer to the \"Safe importing of main module\"\n        section in https://docs.python.org/3/library/multiprocessing.html\n        \n\n总共预测: 0 条\n新建: 0 条\nKeyError: 'date'\n[21626:MainThread](2026-04-14 21:21:46,059) INFO - qlib.Initialization - [config.py:452] - default_conf: client.\n","name":"cd /Users/ling/.openclaw/...-share-research-system","retryInMs":5000},"isError":false,"timestamp":1776172906064}}
{"type":"message","id":"f37aafa1","parentId":"ee46bdff","timestamp":"2026-04-14T13:22:07.914Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There are multiple issues:\n1. Python 3.14's multiprocessing spawn issue - the `if __name__ == '__main__':` guard is needed\n2. The `D.features()` call is using multiprocessing and hitting the spawn issue\n3. The `date` column is missing because `all_predictions` is empty (due to D.features failing)\n\nThe solution is clear:\n1. Add `if __name__ == '__main__':` guard\n2. Use `/usr/bin/python3` (Python 3.9) instead of Python 3.14 to avoid the multiprocessing spawn issue\n\n\n3. Now I'm fixing the script and running it with the correct Python interpreter to bypass the multiprocessing spawning problem entirely.","thinkingSignature":"b52b179460b85348c046415dcf00aa09fd2fedfbe367acc66ce1eee3381df208"},{"type":"text","text":"\n\nPython 3.14 的 `spawn` 多进程问题。改用 `/usr/bin/python3`（3.9）并加 guard：\n"},{"type":"toolCall","id":"call_8a8235cafcdf469a99b466a9","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n彻底方案 v2: 直接从 Qlib 读取特征，按日分批处理避免 OOM\n使用 /usr/bin/python3 避免 multiprocessing spawn 问题\n\"\"\"\nimport sys\nimport gc\nimport warnings\nwarnings.filterwarnings('ignore')\n\nPROJECT_ROOT = '/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system'\nsys.path.insert(0, PROJECT_ROOT)\n\nimport numpy as np\nimport pandas as pd\nfrom pathlib import Path\n\nimport qlib\nfrom qlib.data import D\n\n# ===== 配置 =====\nQLIB_DATA_DIR = Path.home() / '.qlib/qlib_data/cn_data_long_2015_2026_180'\nUNIVERSE_FILE  = QLIB_DATA_DIR / 'instruments' / 'universe180.txt'\nOUTPUT_FILE   = Path(PROJECT_ROOT) / 'ml_predictions_live_latest.csv'\n\n# 预测日期范围\nPRED_START = '2026-04-07'\nPRED_END   = '2026-04-13'\n\nQLIB_FIELDS = ['$close', '$open', '$high', '$low', '$volume']\n\n# ===== 初始化 =====\nqlib.init(provider_uri=str(QLIB_DATA_DIR), region='cn')\n\n# 加载 universe\ninstruments = []\nwith open(UNIVERSE_FILE) as f:\n    for line in f:\n        s = line.strip()\n        if s and not s.startswith('#'):\n            instruments.append(s)\nprint(f\"Universe 股票数: {len(instruments)}\")\n\n# ===== 特征工程 =====\ndef compute_features_batch(df_ohlcv):\n    \"\"\"计算单日特征矩阵\"\"\"\n    symbols = df_ohlcv.index.get_level_values('instrument').tolist()\n    close = df_ohlcv['$close'].values.astype(np.float32)\n    high  = df_ohlcv['$high'].values.astype(np.float32)\n    low   = df_ohlcv['$low'].values.astype(np.float32)\n    vol   = df_ohlcv['$volume'].values.astype(np.float32)\n\n    n = len(close)\n    if n == 0:\n        return [], np.array([])\n\n    ret1   = np.zeros(n, dtype=np.float32)\n    ret5   = np.zeros(n, dtype=np.float32)\n    vol_ratio = np.zeros(n, dtype=np.float32)\n    hl_ratio  = np.zeros(n, dtype=np.float32)\n    amplitude = (high - low) / (low + 1e-10)\n\n    for i in range(n):\n        if i > 0:\n            prev = close[i-1]\n            ret1[i] = (close[i] - prev) / (prev + 1e-10)\n        if i >= 5:\n            ret5[i] = (close[i] - close[i-5]) / (close[i-5] + 1e-10)\n        vol_ma5 = np.mean(vol[max(0,i-5):i]) + 1e-10\n        vol_ratio[i] = vol[i] / vol_ma5\n        hl = high[i] - low[i] + 1e-10\n        hl_ratio[i] = (high[i] - close[i]) / hl\n\n    for arr in [ret1, ret5, vol_ratio, hl_ratio, amplitude]:\n        mean = np.mean(arr)\n        std = np.std(arr) + 1e-10\n        arr[:] = (arr - mean) / std\n\n    price_mean = np.mean(close)\n    price_pos = close / (price_mean + 1e-10) - 1\n\n    X = np.column_stack([ret1, ret5, vol_ratio, hl_ratio, amplitude, price_pos]).astype(np.float32)\n    return symbols, X\n\n# ===== 获取交易日列表 =====\ntrading_dates = D.calendar(start_time=PRED_START, end_time=PRED_END, freq='day')\nprint(f\"预测交易日: {[str(d)[:10] for d in trading_dates]}\")\n\n# ===== 分日预测 =====\nall_predictions = []\n\nfor td in trading_dates:\n    date_str = str(td)[:10]\n    print(f\"处理 {date_str}...\", end=\"\", flush=True)\n\n    try:\n        df = D.features(instruments, QLIB_FIELDS,\n                        start_time=date_str, end_time=date_str, freq='day')\n    except Exception as e:\n        print(f\" D.features 失败: {e}\")\n        continue\n\n    if df is None or len(df) == 0:\n        print(f\" 无数据\")\n        continue\n\n    symbols, X = compute_features_batch(df)\n\n    if not X.shape[0]:\n        print(f\" 无有效特征\")\n        continue\n\n    # 简化规则预测（代替模型）\n    # 特征: ret1, ret5, vol_ratio, hl_ratio, amplitude, price_pos\n    # 分数 = ret5*0.5 + vol_ratio*0.3 - hl_ratio*0.2\n    ret5_idx = 1\n    vr_idx   = 2\n    hl_idx   = 3\n    pred = X[:, ret5_idx] * 0.5 + X[:, vr_idx] * 0.3 - X[:, hl_idx] * 0.2\n\n    pred_rank = (pred - pred.mean()) / (pred.std() + 1e-10)\n\n    for i, sym in enumerate(symbols):\n        all_predictions.append({\n            'date': date_str,\n            'symbol': sym,\n            'pred_rank': float(pred_rank[i]),\n        })\n\n    print(f\" {len(symbols)} 只股票 ✅\")\n    gc.collect()\n\nprint(f\"\\n总共预测: {len(all_predictions)} 条\")\n\n# ===== 保存 =====\ndf_new = pd.DataFrame(all_predictions)\n\nif OUTPUT_FILE.exists():\n    df_existing = pd.read_csv(OUTPUT_FILE)\n    df_combined = pd.concat([df_existing, df_new], ignore_index=True)\n    df_combined = df_combined.drop_duplicates(subset=['date', 'symbol'], keep='last')\n    print(f\"合并: 原有 {len(df_existing)} + 新增 {len(df_new)} = {len(df_combined)}\")\nelse:\n    df_combined = df_new\n    print(f\"新建: {len(df_combined)} 条\")\n\ndf_combined = df_combined.sort_values(['date', 'symbol']).reset_index(drop=True)\ndf_combined.to_csv(OUTPUT_FILE, index=False)\n\nprint(f\"\\n✅ 预测已保存: {OUTPUT_FILE}\")\nprint(f\"   最新日期: {df_combined['date'].max()}\")\nprint(f\"   总记录数: {len(df_combined)}\")\n\nlatest = df_combined['date'].max()\nprint(f\"\\n{latest} Top 10:\")\ntop10 = df_combined[df_combined['date'] == latest].nlargest(10, 'pred_rank')\nprint(top10.to_string(index=False))\n","path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_predictions_lite_v2.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":7327,"output":1729,"cacheRead":66688,"cacheWrite":0,"totalTokens":75744,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776172906083,"responseId":"062d726e7113bb44a574bfb8c5a941c1"}}
