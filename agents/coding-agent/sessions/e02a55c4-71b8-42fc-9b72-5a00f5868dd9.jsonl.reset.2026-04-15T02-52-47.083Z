tx) as r:\n        c = r.read().decode('gbk', errors='replace')'''\n\nif old_check in content:\n    content = content.replace(old_check, new_check)\n    open(script_path, 'w').write(content)\n    print('✅ SSL check fixed in cron_paper_trading_profiles_v1.sh')\nelse:\n    print('⚠️ Pattern not found, checking current content...')\n    # Find the actual pattern\n    idx = content.find('MKT_OK=')\n    if idx >= 0:\n        print('Found MKT_OK at index', idx)\n        print(repr(content[idx:idx+300]))\nEOF\npython3 /tmp/fix_ssl_check.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":112199,"output":598,"cacheRead":1088,"cacheWrite":0,"totalTokens":113885,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776154415458,"responseId":"062d2a3235b36d417eb7428b820c90d1"}}
