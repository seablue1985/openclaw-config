{"type":"message","id":"08b9ca10","parentId":"a531b1c8","timestamp":"2026-04-14T08:45:08.735Z","message":{"role":"toolResult","toolCallId":"call_function_85ld2diycvzh_1","toolName":"exec","content":[{"type":"text","text":"return payload\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"构建 live_system_v1 的双因子正式集成 shadow 产物\")\n    parser.add_argument(\"--live-json\", default=\"\", help=\"指定 live_system_v1_YYYYMMDD.json；默认自动取最新\")\n    parser.add_argument(\"--formal-params\", default=str(FORMAL_PARAMS_PATH), help=\"formal params json\")\n    parser.add_argument(\"--robustness\", default=str(ROBUSTNESS_PATH), help=\"robustness json\")\n    parser.add_argument(\"--sse-index-file\", default=str(DEFAULT_SSE_INDEX_FILE), help=\"上证综指缓存 csv\")\n    parser.add_argument(\"--profile\", choices=[\"default\", \"conservative\"], default=\"default\", help=\"选定输出 profile\")\n    parser.add_argument(\"--write-artifacts\", action=\"store_true\", help=\"写出 shadow 曲线/摘要/live payload\")\n    parser.add_argument(\"--output-prefix\", default=\"dual_factor_shadow\", help=\"输出前缀，仅在 --write-artifacts 时生效\")\n    args = parser.parse_args()\n\n    live_json_path = Path(args.live_json).expanduser().resolve() if args.live_json else discover_latest_live_json()\n    formal_params_path = Path(args.formal_params).expanduser().resolve()\n    robustness_path = Path(args.robustness).expanduser().resolve()\n    sse_index_file = Path(args.sse_index_file).expanduser().resolve()\n\n    formal_params = load_json(formal_params_path) if formal_params_path.exists() else None\n    robustness = load_json(robustness_path) if robustness_path.exists() else None\n    profiles = build_profiles(formal_params)\n\n    live_payload, baseline_curve_path, baseline_curve = load_live_payload(live_json_path)\n    baseline_metrics = normalize_metrics(baseline_curve)\n    market_close = load_market_close(baseline_curve.index)\n    sse_index = load_sse_index(baseline_curve.index, sse_index_file)\n\n    snapshots: dict[str, dict[str, Any]] = {}\n    curve_frames: dict[str, pd.DataFrame] = {}\n    for profile_name, profile in profiles.items():\n        snapshot, curve_df = build_profile_snapshot(\n            profile_name=profile_name,\n            profile=profile,\n            baseline_curve=baseline_curve,\n            market_close=market_close,\n            sse_index=sse_index,\n        )\n        snapshots[profile_name] = snapshot\n        curve_frames[profile_name] = curve_df\n\n    selected_snapshot = snapshots[args.profile]\n    date_tag = str(live_payload.get(\"date\") or datetime.now().strftime(\"%Y%m%d\"))\n    prefix = f\"{args.output_prefix}_{args.profile}_{date_tag}\"\n    shadow_curve_path = REPORT_DIR / f\"{prefix}_curve.csv\"\n    shadow_summary_path = REPORT_DIR / f\"{prefix}_summary.json\"\n    shadow_live_json_path = REPORT_DIR / f\"{prefix}_live_payload.json\"\n\n    summary = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"integration_mode\": \"shadow_only\",\n        \"formal_version\": str((formal_params or {}).get(\"formal_version\") or \"dual_factor_rsv5_roc10_v1\"),\n        \"live_system_path\": str(live_json_path),\n        \"baseline_curve_path\": str(baseline_curve_path),\n        \"selected_profile\": args.profile,\n        \"baseline_metrics\": baseline_metrics,\n        \"profiles\": snapshots,\n        \"selected_runtime_shadow_inputs\": selected_snapshot[\"runtime_shadow_inputs\"],\n        \"validated_reference_metrics\": (formal_params or {}).get(\"validated_metrics\") if isinstance(formal_params, dict) else None,\n        \"shadow_metrics_note\": \"profiles.*.metrics 为当前集成脚本按 live_system combo_curve 实时重算的 shadow 指标；正式立项口径仍以 dual_factor_formal_params.json / dual_factor_robustness_report.json 为准。\",\n        \"integration_entrypoints\": {\n            \"live_system_source\": \"research/reports/live_system_v1_*.json\",\n            \"combo_curve\": str(baseline_curve_path),\n            \"paper_runtime_reader\": \"scripts/prepare_paper_orders_v1.py -> runtime_date_utils.load_runtime_metrics_for_date()\",\n            \"panel_risk_generator\": \"scripts/generate_per_panel_runtime_risk_t05.py\",\n        },\n        \"recommended_actions\": [\n            \"保持 baseline live_system_v1 不变，先生成 dual_factor shadow 产物。\",\n            \"用 selected_runtime_shadow_inputs 对照 runtime risk / paper orders diff，不直接改主链路。\",\n            \"若 shadow 连续验证通过，再做 feature flag 级别的灰度接入。\",\n        ],\n        \"robustness_reference\": robustness.get(\"summary\") if isinstance(robustness, dict) else None,\n    }\n\n    if args.write_artifacts:\n        REPORT_DIR.mkdir(parents=True, exist_ok=True)\n        curve_frames[args.profile].to_csv(shadow_curve_path, index=False)\n        shadow_summary_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n        shadow_payload = build_shadow_live_payload(\n            baseline_payload=live_payload,\n            baseline_curve_path=baseline_curve_path,"}],"details":{"status":"completed","exitCode":0,"durationMs":5,"aggregated":"return payload\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"构建 live_system_v1 的双因子正式集成 shadow 产物\")\n    parser.add_argument(\"--live-json\", default=\"\", help=\"指定 live_system_v1_YYYYMMDD.json；默认自动取最新\")\n    parser.add_argument(\"--formal-params\", default=str(FORMAL_PARAMS_PATH), help=\"formal params json\")\n    parser.add_argument(\"--robustness\", default=str(ROBUSTNESS_PATH), help=\"robustness json\")\n    parser.add_argument(\"--sse-index-file\", default=str(DEFAULT_SSE_INDEX_FILE), help=\"上证综指缓存 csv\")\n    parser.add_argument(\"--profile\", choices=[\"default\", \"conservative\"], default=\"default\", help=\"选定输出 profile\")\n    parser.add_argument(\"--write-artifacts\", action=\"store_true\", help=\"写出 shadow 曲线/摘要/live payload\")\n    parser.add_argument(\"--output-prefix\", default=\"dual_factor_shadow\", help=\"输出前缀，仅在 --write-artifacts 时生效\")\n    args = parser.parse_args()\n\n    live_json_path = Path(args.live_json).expanduser().resolve() if args.live_json else discover_latest_live_json()\n    formal_params_path = Path(args.formal_params).expanduser().resolve()\n    robustness_path = Path(args.robustness).expanduser().resolve()\n    sse_index_file = Path(args.sse_index_file).expanduser().resolve()\n\n    formal_params = load_json(formal_params_path) if formal_params_path.exists() else None\n    robustness = load_json(robustness_path) if robustness_path.exists() else None\n    profiles = build_profiles(formal_params)\n\n    live_payload, baseline_curve_path, baseline_curve = load_live_payload(live_json_path)\n    baseline_metrics = normalize_metrics(baseline_curve)\n    market_close = load_market_close(baseline_curve.index)\n    sse_index = load_sse_index(baseline_curve.index, sse_index_file)\n\n    snapshots: dict[str, dict[str, Any]] = {}\n    curve_frames: dict[str, pd.DataFrame] = {}\n    for profile_name, profile in profiles.items():\n        snapshot, curve_df = build_profile_snapshot(\n            profile_name=profile_name,\n            profile=profile,\n            baseline_curve=baseline_curve,\n            market_close=market_close,\n            sse_index=sse_index,\n        )\n        snapshots[profile_name] = snapshot\n        curve_frames[profile_name] = curve_df\n\n    selected_snapshot = snapshots[args.profile]\n    date_tag = str(live_payload.get(\"date\") or datetime.now().strftime(\"%Y%m%d\"))\n    prefix = f\"{args.output_prefix}_{args.profile}_{date_tag}\"\n    shadow_curve_path = REPORT_DIR / f\"{prefix}_curve.csv\"\n    shadow_summary_path = REPORT_DIR / f\"{prefix}_summary.json\"\n    shadow_live_json_path = REPORT_DIR / f\"{prefix}_live_payload.json\"\n\n    summary = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"integration_mode\": \"shadow_only\",\n        \"formal_version\": str((formal_params or {}).get(\"formal_version\") or \"dual_factor_rsv5_roc10_v1\"),\n        \"live_system_path\": str(live_json_path),\n        \"baseline_curve_path\": str(baseline_curve_path),\n        \"selected_profile\": args.profile,\n        \"baseline_metrics\": baseline_metrics,\n        \"profiles\": snapshots,\n        \"selected_runtime_shadow_inputs\": selected_snapshot[\"runtime_shadow_inputs\"],\n        \"validated_reference_metrics\": (formal_params or {}).get(\"validated_metrics\") if isinstance(formal_params, dict) else None,\n        \"shadow_metrics_note\": \"profiles.*.metrics 为当前集成脚本按 live_system combo_curve 实时重算的 shadow 指标；正式立项口径仍以 dual_factor_formal_params.json / dual_factor_robustness_report.json 为准。\",\n        \"integration_entrypoints\": {\n            \"live_system_source\": \"research/reports/live_system_v1_*.json\",\n            \"combo_curve\": str(baseline_curve_path),\n            \"paper_runtime_reader\": \"scripts/prepare_paper_orders_v1.py -> runtime_date_utils.load_runtime_metrics_for_date()\",\n            \"panel_risk_generator\": \"scripts/generate_per_panel_runtime_risk_t05.py\",\n        },\n        \"recommended_actions\": [\n            \"保持 baseline live_system_v1 不变，先生成 dual_factor shadow 产物。\",\n            \"用 selected_runtime_shadow_inputs 对照 runtime risk / paper orders diff，不直接改主链路。\",\n            \"若 shadow 连续验证通过，再做 feature flag 级别的灰度接入。\",\n        ],\n        \"robustness_reference\": robustness.get(\"summary\") if isinstance(robustness, dict) else None,\n    }\n\n    if args.write_artifacts:\n        REPORT_DIR.mkdir(parents=True, exist_ok=True)\n        curve_frames[args.profile].to_csv(shadow_curve_path, index=False)\n        shadow_summary_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n        shadow_payload = build_shadow_live_payload(\n            baseline_payload=live_payload,\n            baseline_curve_path=baseline_curve_path,","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timesta