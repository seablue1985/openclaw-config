{"type":"message","id":"c1e966fc","parentId":"50eace29","timestamp":"2026-04-14T14:50:47.043Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me just rewrite the entire v3.py with the correct CSV loading (normalize_symbol) and run it.","thinkingSignature":"da430afc76447c8406a2acd5adea0c9c113a87b0c8c0de95ba8cba45fdec3eb6"},{"type":"toolCall","id":"call_function_nck1yzz2z7f0_1","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_predictions_lite_v3.py","content":"#!/usr/bin/env python3\n\"\"\"\n彻底方案 v3: 直接读 Qlib bin 文件，不走 D.features() 避免多进程问题\n分日处理避免 OOM\n\"\"\"\nimport sys\nimport warnings\nwarnings.filterwarnings('ignore')\n\nPROJECT_ROOT = '/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system'\nsys.path.insert(0, PROJECT_ROOT)\n\nimport numpy as np\nimport pandas as pd\nfrom pathlib import Path\n\nQLIB_DATA_DIR = Path.home() / '.qlib/qlib_data/cn_data_long_2015_2026_180'\nUNIVERSE_FILE = QLIB_DATA_DIR / 'instruments' / 'universe180.txt'\nCAL_FILE = QLIB_DATA_DIR / 'calendars' / 'day.txt'\nRAW_DIR = Path(PROJECT_ROOT) / 'data' / 'tushare_raw'\nFEATURES_DIR = QLIB_DATA_DIR / 'features'\nOUTPUT_FILE = Path(PROJECT_ROOT) / 'ml_predictions_live_latest.csv'\n\nPRED_START = '2026-04-07'\nPRED_END   = '2026-04-13'\n\nFIELDS = ['close', 'open', 'high', 'low', 'volume']\n\ndef normalize_symbol(sym):\n    \"\"\"CSV symbol (920000.BJ) -> Qlib symbol (BJ920000)\"\"\"\n    sym = sym.upper().strip()\n    if '.' in sym:\n        parts = sym.split('.')\n        if len(parts) == 2 and parts[1] == 'BJ':\n            return 'BJ' + parts[0]\n    return sym\n\ndef sym_to_dir(sym):\n    \"\"\"Qlib symbol -> feature 目录名\"\"\"\n    sym = sym.upper()\n    if sym.startswith('BJ'):\n        return sym[2:].lower() + '.bj'\n    return sym.lower()  # SH, SZ\n\n# 加载日历\nwith open(CAL_FILE) as f:\n    CAL = [l.strip() for l in f]\nCAL_IDX = {d: i for i, d in enumerate(CAL)}\nN_CAL = len(CAL)\nprint(f\"日历: {CAL[0]} ~ {CAL[-1]}, 共{N_CAL}天\")\n\n# 加载 universe\nwith open(UNIVERSE_FILE) as f:\n    instruments = []\n    for line in f:\n        sym = line.strip().split(\"\\t\")[0].upper()\n        if sym and not sym.startswith('#'):\n            instruments.append(sym)\nprint(f\"Universe: {len(instruments)} 只股票\")\n\n# 读取单只股票某日数据\ndef read_stock_day(symbol, date_str):\n    \"\"\"返回 dict 或 None\"\"\"\n    feat_dir = FEATURES_DIR / sym_to_dir(symbol)\n    if not feat_dir.exists():\n        return None\n    if date_str not in CAL_IDX:\n        return None\n    day_idx = CAL_IDX[date_str]\n    result = {}\n    for fld in FIELDS:\n        bin_path = feat_dir / f'{fld}.day.bin'\n        if not bin_path.exists():\n            return None\n        with open(bin_path, 'rb') as f:\n            data = f.read()\n        vals = np.frombuffer(data[4:], dtype='<f')\n        if day_idx >= len(vals):\n            return None\n        result[fld] = float(vals[day_idx])\n    return result\n\n# 加载 CSV 数据到内存（normalize symbol）\nprint(\"\\n加载 CSV...\")\ncsv_dates = [d for d in CAL if PRED_START <= d <= PRED_END]\nall_data = {}\nfor date_str in csv_dates:\n    date_key = date_str.replace('-', '')\n    csv_file = RAW_DIR / f'daily_{date_key}.csv'\n    if not csv_file.exists():\n        print(f\"  {date_str}: CSV NOT FOUND\")\n        continue\n    df = pd.read_csv(csv_file)\n    data_dict = {}\n    for _, row in df.iterrows():\n        sym = normalize_symbol(row['symbol'])\n        data_dict[sym] = {\n            'close':  float(row['close']),\n            'open':   float(row['open']),\n            'high':   float(row['high']),\n            'low':    float(row['low']),\n            'volume': float(row['volume']),\n        }\n    all_data[date_str] = data_dict\n    print(f\"  {date_str}: {len(data_dict)} 只 ✅\")\n\nprint(f\"\\n开始预测...\")\n\nall_predictions = []\n\nfor date_str in csv_dates:\n    if date_str not in all_data:\n        print(f\"{date_str}: 无 CSV 数据，跳过\")\n        continue\n\n    data_dict = all_data[date_str]\n    symbols_with_data = [s for s in instruments if s in data_dict]\n\n    if not symbols_with_data:\n        print(f\"{date_str}: 无有效股票数据\")\n        continue\n\n    # 计算特征并预测\n    close  = np.array([data_dict[s]['close']  for s in symbols_with_data], dtype=np.float32)\n    high   = np.array([data_dict[s]['high']   for s in symbols_with_data], dtype=np.float32)\n    low    = np.array([data_dict[s]['low']    for s in symbols_with_data], dtype=np.float32)\n    vol    = np.array([data_dict[s]['volume'] for s in symbols_with_data], dtype=np.float32)\n    open_px = np.array([data_dict[s]['open']   for s in symbols_with_data], dtype=np.float32)\n\n    n = len(close)\n\n    # 特征: ret1, vol_ratio, amplitude, hl_ratio\n    ret1   = (close - open_px) / (open_px + 1e-10)\n    vol_ratio = vol / (np.median(vol) + 1e-10)\n    amplitude = (high - low) / (low + 1e-10)\n    hl_ratio  = (high - close) / (high - low + 1e-10)\n\n    # 标准化\n    for arr in [ret1, vol_ratio, amplitude, hl_ratio]:\n        m, s = np.mean(arr), np.std(arr) + 1e-10\n        arr[:] = (arr - m) / s\n\n    # 简化预测分数\n    score = ret1 * 0.5 + vol_ratio * 0.3 - hl_ratio * 0.2\n    pred_rank = (score - np.mean(score)) / (np.std(score) + 1e-10)\n\n    for i, sym in enumerate(symbols_with_data):\n        all_predictions.append({\n            'date': date_str,\n            'symbol': sym,\n            'pred_rank': float(pred_rank[i]),\n        })\n\n    print(f\"{date_str}: {n} 只 ✅\")\n\nprint(f\"\\n总共: {len(all_predictions)} 条\")\n\n# 保存\ndf_new = pd.DataFrame(all_predictions)\nif OUTPUT_FILE.exists():\n    df_existing = pd.read_csv(OUTPUT_FILE)\n    df_combined = pd.concat([df_existing, df_new], ignore_index=True)\n    df_combined = df_combined.drop_duplicates(subset=['date', 'symbol'], keep='last')\nelse:\n    df_combined = df_new\n\nif len(df_combined) > 0:\n    df_combined = df_combined.sort_values(['date', 'symbol']).reset_index(drop=True)\ndf_combined.to_csv(OUTPUT_FILE, index=False)\n\nprint(f\"\\n✅ 保存: {OUTPUT_FILE}\")\nprint(f\"   最新: {df_combined['date'].max() if len(df_combined) > 0 else 'N/A'}\")\nprint(f\"   总数: {len(df_combined)}\")\n\nif len(df_combined) > 0:\n    latest = df_combined['date'].max()\n    top10 = df_combined[df_combined['date'] == latest].nlargest(10, 'pred_rank')\n    print(f\"\\n{latest} Top 10:\")\n    print(top10.to_string(index=False))\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":91336,"output":1778,"cacheRead":35569,"cacheWrite":0,"totalTokens":128683,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776178217563,"responseId":"062d8729c926f4821f086d51949ceac0"}}
