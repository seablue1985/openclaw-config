ate'].max()}\")\n147:    test_data['pred'] = model.predict(X_test)\n151:    X_live = live_data[feature_cols].fillna(0)\n152:    live_data['pred'] = model.predict(X_live)\n153:    live_data['pred_rank'] = live_data.groupby('date')['pred'].rank(pct=True)\n155:    return model, test_data, live_data, feature_cols\n157:def backtest(test_data):\n222:def save_results(full_df, test_data, live_data, results, equity_curve, feature_cols):\n230:    test_data.to_csv(OUTPUT_DIR / \"ml_predictions.csv\", index=False)\n231:    live_data.to_csv(OUTPUT_DIR / \"ml_predictions_live_latest.csv\", index=False)\n242:    latest_live_date = None if live_data.empty else pd.to_datetime(live_data['date'], errors='coerce').max()\n245:    results['live_prediction_period'] = f\"{TEST_START} ~ {latest_live_str}\"\n247:    results['live_predictions_file'] = str(OUTPUT_DIR / 'ml_predictions_live_latest.csv')\n254:    print(f\"预测结果: {OUTPUT_DIR / 'ml_predictions.csv'}\")\n255:    print(f\"LIVE预测结果: {OUTPUT_DIR / 'ml_predictions_live_latest.csv'}\")","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1776165529361}}
