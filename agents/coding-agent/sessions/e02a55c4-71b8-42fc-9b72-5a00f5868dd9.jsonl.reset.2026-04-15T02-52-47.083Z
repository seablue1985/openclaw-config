{"type":"message","id":"ab614017","parentId":"63d598d6","timestamp":"2026-04-14T08:30:22.491Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me look at the run_live_system_v1_dual_shadow.py to understand the shadow logic and where to add the upgrade gate.\n","thinkingSignature":"3138d509bb30410d900e0333e49acf47483e8a35c6d9730a3c71a7b58b9a73a9"},{"type":"toolCall","id":"call_function_0ue5eussz2z3_1","name":"exec","arguments":{"command":"head -150 /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_live_system_v1_dual_shadow.py"}},{"type":"toolCall","id":"call_function_0ue5eussz2z3_2","name":"exec","arguments":{"command":"grep -n \"upgrade\\|gray\\|feature_flag\\|shadow_live\\|live_candidate\\|conservative.*run\\|min.*day\" /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_live_system_v1_dual_shadow.py 2>/dev/null | head -30"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":591,"output":173,"cacheRead":139136,"cacheWrite":0,"totalTokens":139900,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776155405035,"responseId":"062d2e1710a09019b0707ad3719a0dd7"}}
{"type":"message","id":"81e517c8","parentId":"ab614017","timestamp":"2026-04-14T08:30:22.541Z","message":{"role":"toolResult","toolCallId":"call_function_0ue5eussz2z3_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nDual Factor Feature Flag Wrapper for Live System v1.\n\n支持三种模式：\n  off          → 纯 baseline，不做任何 dual factor 叠加（主链路默认值）\n  conservative → 使用 conservative profile（放大/收缩幅度更小）\n  default      → 使用 default profile（正式候选参数）\n\n与 run_live_system_v1.py 完全独立，不修改主链路产出。\n仅在已存在 baseline live_system_v1_*.json 的前提下，生成 shadow overlay 产物。\n\n用法：\n  python3 scripts/run_live_system_v1_dual_shadow.py --profile default --write-artifacts\n  python3 scripts/run_live_system_v1_dual_shadow.py --profile off --dry-run\n\"\"\"\nfrom __future__ import annotations\n\nimport argparse\nimport copy\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nfor candidate in [PROJECT_ROOT, PROJECT_ROOT / \"scripts\"]:\n    if str(candidate) not in sys.path:\n        sys.path.insert(0, str(candidate))\n\nimport subprocess\n\n# Feature flag 合法值\nVALID_PROFILES = {\"off\", \"default\", \"conservative\"}\n\n# Feature flag 字段元数据（用于 readiness JSON）\nFEATURE_FLAG_FIELDS = {\n    \"field\": \"dual_factor_profile\",\n    \"type\": \"string\",\n    \"enum\": [\"off\", \"default\", \"conservative\"],\n    \"default\": \"off\",\n    \"description\": \"控制 dual factor overlay 的接入档位；off=关闭，conservative=保守档，default=正式候选档\",\n    \"storage\": \"环境变量 DUAL_FACTOR_PROFILE 或命令行 --profile\",\n    \"non_invasive\": True,\n    \"main_line_behavior\": {\n        \"off\": \"完全不修改 combo_v1，保持 baseline live_system_v1.json 原样输出\",\n        \"conservative\": \"生成 shadow overlay 产物（曲线/摘要/payload），但不替换 combo_v1\",\n        \"default\": \"生成 shadow overlay 产物（曲线/摘要/payload），但不替换 combo_v1\",\n    },\n}\n\n\ndef discover_latest_live_json() -> Path:\n    # 优先标准版本 live_system_v1_YYYYMMDD.json，排除 enhanced / backup 等变体\n    candidates = sorted(REPORT_DIR.glob(\"live_system_v1_????????.json\"))\n    if not candidates:\n        # 降级：允许其他后缀\n        all_candidates = sorted(REPORT_DIR.glob(\"live_system_v1_*.json\"))\n        if not all_candidates:\n            raise FileNotFoundError(f\"未找到 live_system_v1_*.json，请先运行 run_live_system_v1.py: {REPORT_DIR}\")\n        candidates = all_candidates\n    return candidates[-1]\n\n\ndef run_dual_shadow(\n    *,\n    live_json_path: Path,\n    profile: str,\n    write_artifacts: bool = False,\n    output_prefix: str = \"dual_factor_shadow\",\n) -> dict[str, Any]:\n    \"\"\"通过 subprocess 调用 integrate_dual_factor_overlay，避免 stdout 捕获冲突。\"\"\"\n    argv = [\n        \"python3\",\n        str(PROJECT_ROOT / \"scripts\" / \"integrate_dual_factor_overlay.py\"),\n        \"--live-json\", str(live_json_path),\n        \"--profile\", profile,\n    ]\n    if write_artifacts:\n        argv.append(\"--write-artifacts\")\n    argv.extend([\"--output-prefix\", output_prefix])\n\n    proc = subprocess.run(\n        argv,\n        cwd=str(PROJECT_ROOT),\n        capture_output=True,\n        text=True,\n    )\n    combined = (proc.stdout or \"\") + (proc.stderr or \"\")\n    try:\n        return json.loads(proc.stdout or combined)\n    except Exception:\n        return {\n            \"returncode\": proc.returncode,\n            \"stdout\": (proc.stdout or \"\")[:500],\n            \"stderr\": (proc.stderr or \"\")[:500],\n            \"combined\": combined[:500],\n        }\n\n\ndef build_shadow_diff_summary(\n    *,\n    baseline_payload: dict[str, Any],\n    shadow_summary: dict[str, Any],\n    profile: str,\n) -> dict[str, Any]:\n    \"\"\"在 baseline vs dual shadow 之间构建 diff 结构，用于快速对照。\"\"\"\n    baseline_combo = baseline_payload.get(\"combo_v1\", {})\n    baseline_metrics = {\n        \"ann_ret\": baseline_combo.get(\"annual_return_pct\", 0.0),\n        \"max_dd\": baseline_combo.get(\"max_drawdown_pct\", 0.0),\n        \"sharpe\": baseline_combo.get(\"sharpe\", 0.0),\n    }\n\n    selected = shadow_summary.get(\"profiles\", {}).get(profile, {})\n    dual_metrics = selected.get(\"metrics\", {})\n    dual_diff = selected.get(\"diff_vs_baseline\", {})\n\n    # guardrails 位于 live_payload JSON 中，不在 summary JSON 里\n    guardrails: list[str] = []\n    if isinstance(shadow_summary.get(\"dual_factor_overlay\"), dict):\n        guardrails = shadow_summary[\"dual_factor_overlay\"].get(\"guardrails\", [])\n    else:\n        # artifact_files 在 --write-artifacts 时写入 summary；live_payload 里有完整 guardrails\n        live_payload_path = (\n            shadow_summary.get(\"artifact_files\", {}).get(\"shadow_live_payload\")\n            or shadow_summary.get(\"files\", {}).get(\"shadow_live_payload\")\n        )\n        if live_payload_path and Path(live_payload_path).exists():\n            try:\n                live_payload = json.loads(Path(live_payload_path).read_text(encoding=\"utf-8\"))\n                guardrails = (live_payload.get(\"dual_factor_overlay\") or {}).get(\"guardrails\", [])\n            except Exception:\n                pass\n\n    return {\n        \"comparison\": {\n            \"baseline\": baseline_metrics,\n            \"dual_factor\": dual_metrics,\n            \"diff\": dual_diff,\n        },\n        \"key_signals\": {\n            \"ann_ret_change_pp\": dual_diff.get(\"ann_ret_pp\", 0.0),\n            \"max_dd_change_pp\": dual_diff.get(\"max_dd_pp\", 0.0),\n            \"sharpe_change\": dual_diff.get(\"sharpe\", 0.0),\n        },\n        \"runtime_shadow_inputs\": selected.get(\"runtime_shadow_inputs\", {}),\n        \"latest_state\": selected.get(\"latest_state\", {}),"}],"details":{"status":"completed","exitCode":0,"durationMs":5,"aggregated":"#!/usr/bin/env python3\n\"\"\"\nDual Factor Feature Flag Wrapper for Live System v1.\n\n支持三种模式：\n  off          → 纯 baseline，不做任何 dual factor 叠加（主链路默认值）\n  conservative → 使用 conservative profile（放大/收缩幅度更小）\n  default      → 使用 default profile（正式候选参数）\n\n与 run_live_system_v1.py 完全独立，不修改主链路产出。\n仅在已存在 baseline live_system_v1_*.json 的前提下，生成 shadow overlay 产物。\n\n用法：\n  python3 scripts/run_live_system_v1_dual_shadow.py --profile default --write-artifacts\n  python3 scripts/run_live_system_v1_dual_shadow.py --profile off --dry-run\n\"\"\"\nfrom __future__ import annotations\n\nimport argparse\nimport copy\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nfor candidate in [PROJECT_ROOT, PROJECT_ROOT / \"scripts\"]:\n    if str(candidate) not in sys.path:\n        sys.path.insert(0, str(candidate))\n\nimport subprocess\n\n# Feature flag 合法值\nVALID_PROFILES = {\"off\", \"default\", \"conservative\"}\n\n# Feature flag 字段元数据（用于 readiness JSON）\nFEATURE_FLAG_FIELDS = {\n    \"field\": \"dual_factor_profile\",\n    \"type\": \"string\",\n    \"enum\": [\"off\", \"default\", \"conservative\"],\n    \"default\": \"off\",\n    \"description\": \"控制 dual factor overlay 的接入档位；off=关闭，conservative=保守档，default=正式候选档\",\n    \"storage\": \"环境变量 DUAL_FACTOR_PROFILE 或命令行 --profile\",\n    \"non_invasive\": True,\n    \"main_line_behavior\": {\n        \"off\": \"完全不修改 combo_v1，保持 baseline live_system_v1.json 原样输出\",\n        \"conservative\": \"生成 shadow overlay 产物（曲线/摘要/payload），但不替换 combo_v1\",\n        \"default\": \"生成 shadow overlay 产物（曲线/摘要/payload），但不替换 combo_v1\",\n    },\n}\n\n\ndef discover_latest_live_json() -> Path:\n    # 优先标准版本 live_system_v1_YYYYMMDD.json，排除 enhanced / backup 等变体\n    candidates = sorted(REPORT_DIR.glob(\"live_system_v1_????????.json\"))\n    if not candidates:\n        # 降级：允许其他后缀\n        all_candidates = sorted(REPORT_DIR.glob(\"live_system_v1_*.json\"))\n        if not all_candidates:\n            raise FileNotFoundError(f\"未找到 live_system_v1_*.json，请先运行 run_live_system_v1.py: {REPORT_DIR}\")\n        candidates = all_candidates\n    return candidates[-1]\n\n\ndef run_dual_shadow(\n    *,\n    live_json_path: Path,\n    profile: str,\n    write_artifacts: bool = False,\n    output_prefix: str = \"dual_factor_shadow\",\n) -> dict[str, Any]:\n    \"\"\"通过 subprocess 调用 integrate_dual_factor_overlay，避免 stdout 捕获冲突。\"\"\"\n    argv = [\n        \"python3\",\n        str(PROJECT_ROOT / \"scripts\" / \"integrate_dual_factor_overlay.py\"),\n        \"--live-json\", str(live_json_path),\n        \"--profile\", profile,\n    ]\n    if write_artifacts:\n        argv.append(\"--write-artifacts\")\n    argv.extend([\"--output-prefix\", output_prefix])\n\n    proc = subprocess.run(\n        argv,\n        cwd=str(PROJECT_ROOT),\n        capture_output=True,\n        text=True,\n    )\n    combined = (proc.stdout or \"\") + (proc.stderr or \"\")\n    try:\n        return json.loads(proc.stdout or combined)\n    except Exception:\n        return {\n            \"returncode\": proc.returncode,\n            \"stdout\": (proc.stdout or \"\")[:500],\n            \"stderr\": (proc.stderr or \"\")[:500],\n            \"combined\": combined[:500],\n        }\n\n\ndef build_shadow_diff_summary(\n    *,\n    baseline_payload: dict[str, Any],\n    shadow_summary: dict[str, Any],\n    profile: str,\n) -> dict[str, Any]:\n    \"\"\"在 baseline vs dual shadow 之间构建 diff 结构，用于快速对照。\"\"\"\n    baseline_combo = baseline_payload.get(\"combo_v1\", {})\n    baseline_metrics = {\n        \"ann_ret\": baseline_combo.get(\"annual_return_pct\", 0.0),\n        \"max_dd\": baseline_combo.get(\"max_drawdown_pct\", 0.0),\n        \"sharpe\": baseline_combo.get(\"sharpe\", 0.0),\n    }\n\n    selected = shadow_summary.get(\"profiles\", {}).get(profile, {})\n    dual_metrics = selected.get(\"metrics\", {})\n    dual_diff = selected.get(\"diff_vs_baseline\", {})\n\n    # guardrails 位于 live_payload JSON 中，不在 summary JSON 里\n    guardrails: list[str] = []\n    if isinstance(shadow_summary.get(\"dual_factor_overlay\"), dict):\n        guardrails = shadow_summary[\"dual_factor_overlay\"].get(\"guardrails\", [])\n    else:\n        # artifact_files 在 --write-artifacts 时写入 summary；live_payload 里有完整 guardrails\n        live_payload_path = (\n            shadow_summary.get(\"artifact_files\", {}).get(\"shadow_live_payload\")\n            or shadow_summary.get(\"files\", {}).get(\"shadow_live_payload\")\n        )\n        if live_payload_path and Path(live_payload_path).exists():\n            try:\n                live_payload = json.loads(Path(live_payload_path).read_text(encoding=\"utf-8\"))\n                guardrails = (live_payload.get(\"dual_factor_overlay\") or {}).get(\"guardrails\", [])\n            except Exception:\n                pass\n\n    return {\n        \"comparison\": {\n            \"baseline\": baseline_metrics,\n            \"dual_factor\": dual_metrics,\n            \"diff\": dual_diff,\n        },\n        \"key_signals\": {\n            \"ann_ret_change_pp\": dual_diff.get(\"ann_ret_pp\", 0.0),\n            \"max_dd_change_pp\": dual_diff.get(\"max_dd_pp\", 0.0),\n            \"sharpe_change\": dual_diff.get(\"sharpe\", 0.0),\n        },\n        \"runtime_shadow_inputs\": selected.get(\"runtime_shadow_inputs\", {}),\n        \"latest_state\": selected.get(\"latest_state\", {}),","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1776155422532}}
