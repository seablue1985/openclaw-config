{"type":"message","id":"b3dee371","parentId":"c4fd5ef6","timestamp":"2026-04-14T08:38:25.321Z","message":{"role":"toolResult","toolCallId":"call_function_nei4qdcrvch9_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom pathlib import Path\n\nimport numpy as np\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nDEFAULT_CURVE_FILE = REPORT_DIR / \"live_system_v1_combo_curve_20260402.csv\"\nDEFAULT_OUTPUT_FILE = REPORT_DIR / \"dual_factor_overlay_backtest.json\"\nDEFAULT_SSE_INDEX_FILE = Path(\"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis/index_000001_SH.csv\")\nDEFAULT_RSV5_REPORT = REPORT_DIR / \"rsv5_regime_backtest.json\"\nDEFAULT_ROC10_REPORT = REPORT_DIR / \"roc10_regime_backtest.json\"\n\nsys.path.insert(0, str(PROJECT_ROOT / \"scripts\"))\nimport run_strategy_695_batch as batch  # noqa: E402\n\nROC10_WINDOW = 10\nROC10_BULL = 1.15\nROC10_BEAR = 0.85\nRSV5_WINDOW = 5\nRSV5_MEDIAN_WINDOW = 60\nRSV5_MEDIAN_MIN_PERIODS = 20\nRSV5_BULL = 1.10\nRSV5_BEAR = 0.90\n\n\ndef load_curve(curve_file: Path, start: str | None = None) -> pd.Series:\n    df = pd.read_csv(curve_file)\n    if \"date\" not in df.columns or \"daily_return\" not in df.columns:\n        raise ValueError(f\"curve file missing required columns: {curve_file}\")\n    df = df.copy()\n    df[\"date\"] = pd.to_datetime(df[\"date\"], errors=\"coerce\")\n    df[\"daily_return\"] = pd.to_numeric(df[\"daily_return\"], errors=\"coerce\")\n    df = df.dropna(subset=[\"date\", \"daily_return\"]).sort_values(\"date\")\n    series = df.set_index(\"date\")[\"daily_return\"]\n    if start:\n        series = series[series.index >= pd.Timestamp(start)]\n    if series.empty:\n        raise ValueError(f\"curve series empty after start filter: {start}\")\n    return series.astype(float)\n\n\ndef infer_start_date(explicit_start: str | None) -> str | None:\n    if explicit_start:\n        return explicit_start\n    if DEFAULT_RSV5_REPORT.exists():\n        try:\n            payload = json.loads(DEFAULT_RSV5_REPORT.read_text(encoding=\"utf-8\"))\n            start = payload.get(\"start\")\n            if start:\n                return str(start)\n        except Exception:\n            pass\n    return None"}],"details":{"status":"completed","exitCode":0,"durationMs":671,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom pathlib import Path\n\nimport numpy as np\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nDEFAULT_CURVE_FILE = REPORT_DIR / \"live_system_v1_combo_curve_20260402.csv\"\nDEFAULT_OUTPUT_FILE = REPORT_DIR / \"dual_factor_overlay_backtest.json\"\nDEFAULT_SSE_INDEX_FILE = Path(\"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis/index_000001_SH.csv\")\nDEFAULT_RSV5_REPORT = REPORT_DIR / \"rsv5_regime_backtest.json\"\nDEFAULT_ROC10_REPORT = REPORT_DIR / \"roc10_regime_backtest.json\"\n\nsys.path.insert(0, str(PROJECT_ROOT / \"scripts\"))\nimport run_strategy_695_batch as batch  # noqa: E402\n\nROC10_WINDOW = 10\nROC10_BULL = 1.15\nROC10_BEAR = 0.85\nRSV5_WINDOW = 5\nRSV5_MEDIAN_WINDOW = 60\nRSV5_MEDIAN_MIN_PERIODS = 20\nRSV5_BULL = 1.10\nRSV5_BEAR = 0.90\n\n\ndef load_curve(curve_file: Path, start: str | None = None) -> pd.Series:\n    df = pd.read_csv(curve_file)\n    if \"date\" not in df.columns or \"daily_return\" not in df.columns:\n        raise ValueError(f\"curve file missing required columns: {curve_file}\")\n    df = df.copy()\n    df[\"date\"] = pd.to_datetime(df[\"date\"], errors=\"coerce\")\n    df[\"daily_return\"] = pd.to_numeric(df[\"daily_return\"], errors=\"coerce\")\n    df = df.dropna(subset=[\"date\", \"daily_return\"]).sort_values(\"date\")\n    series = df.set_index(\"date\")[\"daily_return\"]\n    if start:\n        series = series[series.index >= pd.Timestamp(start)]\n    if series.empty:\n        raise ValueError(f\"curve series empty after start filter: {start}\")\n    return series.astype(float)\n\n\ndef infer_start_date(explicit_start: str | None) -> str | None:\n    if explicit_start:\n        return explicit_start\n    if DEFAULT_RSV5_REPORT.exists():\n        try:\n            payload = json.loads(DEFAULT_RSV5_REPORT.read_text(encoding=\"utf-8\"))\n            start = payload.get(\"start\")\n            if start:\n                return str(start)\n        except Exception:\n            pass\n    return None","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1776155904630}}
