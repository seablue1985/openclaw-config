{"type":"message","id":"08fec666","parentId":"905a6d9d","timestamp":"2026-04-14T15:30:24.264Z","message":{"role":"toolResult","toolCallId":"call_function_j69hx9ziwx51_1","toolName":"exec","content":[{"type":"text","text":"---\ndef compose_profile_merged_signals(\n    *,\n    base_merged_signals_path: Path,\n    profile_buy_signals_path: Path,\n    output_path: Path,\n    score_floor: float | None,\n) -> dict[str, Any]:\n    base_df = init_signal_frame(pd.read_csv(base_merged_signals_path)) if base_merged_signals_path.exists() else init_signal_frame()\n    profile_buy_df = init_signal_frame(pd.read_csv(profile_buy_signals_path)) if profile_buy_signals_path.exists() else init_signal_frame()\n\n    base_non_buy_df = base_df[base_df[\"signal_type\"].astype(str).str.upper() != \"BUY\"].copy()\n    profile_buy_df = profile_buy_df[profile_buy_df[\"signal_type\"].astype(str).str.upper() == \"BUY\"].copy()\n    raw_profile_buy_rows = int(len(profile_buy_df.index))\n    applied_score_floor = parse_optional_float(score_floor)\n    if applied_score_floor is not None and not profile_buy_df.empty:\n        score_series = pd.to_numeric(profile_buy_df[\"score\"], errors=\"coerce\").fillna(0.0)\n        profile_buy_df = profile_buy_df.loc[score_series >= applied_score_floor].copy()\n\n    out_df = init_signal_frame(pd.concat([base_non_buy_df, profile_buy_df], ignore_index=True))\n    if not out_df.empty:\n        out_df = out_df.sort_values([\"signal_type\", \"ts_code\", \"strategy_id\"], kind=\"stable\").reset_index(drop=True)\n\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n    out_df.to_csv(output_path, index=False, encoding=\"utf-8\")\n    return {\n        \"base_non_buy_rows\": int(len(base_non_buy_df.index)),\n        \"raw_profile_buy_rows\": raw_profile_buy_rows,\n        \"filtered_profile_buy_rows\": int(len(profile_buy_df.index)),\n        \"score_floor\": applied_score_floor,\n        \"score_floor_dropped_rows\": int(raw_profile_buy_rows - len(profile_buy_df.index)),\n        \"merged_rows\": int(len(out_df.index)),\n        \"output\": str(output_path),\n    }\n\n\ndef materialize_profile_candidate_source(\n    *,\n    live_cfg: dict[str, Any],\n    profile_slug: str,\n    date_tag: str,\n    base_merged_signals_path: Path,\n    artifacts: dict[str, Path],\n) -> dict[str, Any]:\n    settings = load_profile_live_candidate_settings(live_cfg)\n    if not settings:\n        return {\n            \"enabled\": False,\n            \"merged_signals\": str(base_merged_signals_path),\n            \"base_merged_signals\": str(base_merged_signals_path),\n            \"reason\": \"smallcap_live_candidates_missing\",\n        }\n\n    trade_date = tag_to_iso(date_tag)\n    commands: list[dict[str, Any]] = []\n    candidate_cmd = [\n        \"python3\",\n        \"scripts/generate_live_smallcap_candidates.py\",\n        \"--date\",\n        date_tag,\n        \"--config\",\n        str(settings[\"config\"]),\n        \"--main-count\",\n        str(settings[\"main_count\"]),\n        \"--guard-count\",\n        str(settings[\"guard_count\"]),\n        \"--main-target-weight\",\n        str(settings[\"main_target_weight\"]),\n        \"--guard-target-weight\",\n        str(settings[\"guard_target_weight\"]),\n        \"--main-output\",\n        str(artifacts[\"candidate_main\"]),\n        \"--guard-output\",\n        str(artifacts[\"candidate_guard\"]),\n        \"--summary-output\",\n        str(artifacts[\"candidate_summary\"]),\n        \"--overwrite\",\n    ]\n    candidate_out = run_cmd(candidate_cmd)\n    commands.append({\"step\": \"generate_live_candidates\", **candidate_out})\n\n    raw_specs = [\n        (artifacts[\"candidate_main\"], artifacts[\"signal_raw_main\"], \"scripts/export_smallcap_v4_2_signal.py\"),\n        (artifacts[\"candidate_guard\"], artifacts[\"signal_raw_guard\"], \"scripts/export_smallcap_v4_2b_signal.py\"),\n    ]\n    raw_paths: list[Path] = []\n    for candidate_path, output_path, script_rel in raw_specs:\n        if csv_row_count(candidate_path) <= 0:\n            continue\n        export_cmd = [\n            \"python3\","}],"details":{"status":"completed","exitCode":0,"durationMs":85,"aggregated":"---\ndef compose_profile_merged_signals(\n    *,\n    base_merged_signals_path: Path,\n    profile_buy_signals_path: Path,\n    output_path: Path,\n    score_floor: float | None,\n) -> dict[str, Any]:\n    base_df = init_signal_frame(pd.read_csv(base_merged_signals_path)) if base_merged_signals_path.exists() else init_signal_frame()\n    profile_buy_df = init_signal_frame(pd.read_csv(profile_buy_signals_path)) if profile_buy_signals_path.exists() else init_signal_frame()\n\n    base_non_buy_df = base_df[base_df[\"signal_type\"].astype(str).str.upper() != \"BUY\"].copy()\n    profile_buy_df = profile_buy_df[profile_buy_df[\"signal_type\"].astype(str).str.upper() == \"BUY\"].copy()\n    raw_profile_buy_rows = int(len(profile_buy_df.index))\n    applied_score_floor = parse_optional_float(score_floor)\n    if applied_score_floor is not None and not profile_buy_df.empty:\n        score_series = pd.to_numeric(profile_buy_df[\"score\"], errors=\"coerce\").fillna(0.0)\n        profile_buy_df = profile_buy_df.loc[score_series >= applied_score_floor].copy()\n\n    out_df = init_signal_frame(pd.concat([base_non_buy_df, profile_buy_df], ignore_index=True))\n    if not out_df.empty:\n        out_df = out_df.sort_values([\"signal_type\", \"ts_code\", \"strategy_id\"], kind=\"stable\").reset_index(drop=True)\n\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n    out_df.to_csv(output_path, index=False, encoding=\"utf-8\")\n    return {\n        \"base_non_buy_rows\": int(len(base_non_buy_df.index)),\n        \"raw_profile_buy_rows\": raw_profile_buy_rows,\n        \"filtered_profile_buy_rows\": int(len(profile_buy_df.index)),\n        \"score_floor\": applied_score_floor,\n        \"score_floor_dropped_rows\": int(raw_profile_buy_rows - len(profile_buy_df.index)),\n        \"merged_rows\": int(len(out_df.index)),\n        \"output\": str(output_path),\n    }\n\n\ndef materialize_profile_candidate_source(\n    *,\n    live_cfg: dict[str, Any],\n    profile_slug: str,\n    date_tag: str,\n    base_merged_signals_path: Path,\n    artifacts: dict[str, Path],\n) -> dict[str, Any]:\n    settings = load_profile_live_candidate_settings(live_cfg)\n    if not settings:\n        return {\n            \"enabled\": False,\n            \"merged_signals\": str(base_merged_signals_path),\n            \"base_merged_signals\": str(base_merged_signals_path),\n            \"reason\": \"smallcap_live_candidates_missing\",\n        }\n\n    trade_date = tag_to_iso(date_tag)\n    commands: list[dict[str, Any]] = []\n    candidate_cmd = [\n        \"python3\",\n        \"scripts/generate_live_smallcap_candidates.py\",\n        \"--date\",\n        date_tag,\n        \"--config\",\n        str(settings[\"config\"]),\n        \"--main-count\",\n        str(settings[\"main_count\"]),\n        \"--guard-count\",\n        str(settings[\"guard_count\"]),\n        \"--main-target-weight\",\n        str(settings[\"main_target_weight\"]),\n        \"--guard-target-weight\",\n        str(settings[\"guard_target_weight\"]),\n        \"--main-output\",\n        str(artifacts[\"candidate_main\"]),\n        \"--guard-output\",\n        str(artifacts[\"candidate_guard\"]),\n        \"--summary-output\",\n        str(artifacts[\"candidate_summary\"]),\n        \"--overwrite\",\n    ]\n    candidate_out = run_cmd(candidate_cmd)\n    commands.append({\"step\": \"generate_live_candidates\", **candidate_out})\n\n    raw_specs = [\n        (artifacts[\"candidate_main\"], artifacts[\"signal_raw_main\"], \"scripts/export_smallcap_v4_2_signal.py\"),\n        (artifacts[\"candidate_guard\"], artifacts[\"signal_raw_guard\"], \"scripts/export_smallcap_v4_2b_signal.py\"),\n    ]\n    raw_paths: list[Path] = []\n    for candidate_path, output_path, script_rel in raw_specs:\n       