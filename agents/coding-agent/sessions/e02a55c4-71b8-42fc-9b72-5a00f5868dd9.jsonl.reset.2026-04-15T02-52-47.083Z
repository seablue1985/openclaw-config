{"type":"message","id":"728a28c8","parentId":"938c5316","timestamp":"2026-04-14T02:05:24.378Z","message":{"role":"toolResult","toolCallId":"call_function_k82o2j5jb31t_1","toolName":"exec","content":[{"type":"text","text":"#!/bin/bash\n# run_daily_overlays.sh\n# 每日定时执行: 候选池解释 + 持仓风险观察\n# 使用 MiniMax-M2.5-HighSpeed 模型\n#\n# 用法: ./run_daily_overlays.sh [YYYYMMDD]\n#   不带参数则自动取前一交易日\n\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nPROJECT_DIR=\"$(dirname \"$SCRIPT_DIR\")\"\nREPORTS_DIR=\"$PROJECT_DIR/research/reports\"\nOVERLAY_DIR=\"$REPORTS_DIR/ai_overlay\"\nLOG_FILE=\"$PROJECT_DIR/logs/daily_overlays_$(date +%Y%m%d).log\"\n\nmkdir -p \"$(dirname \"$LOG_FILE\")\"\nexec > >(tee -a \"$LOG_FILE\") 2>&1\n\n# ---------- 日期确定 ----------\nif [ -n \"${1:-}\" ]; then\n  DATE_TAG=\"$1\"\nelse\n  # 取前一交易日（跳过周末）\n  DATE_TAG=$(python3 -c \"\nimport datetime\ntoday = datetime.date.today()\n# 往前找最近的交易日\nfor i in range(1, 8):\n    d = today - datetime.timedelta(days=i)\n    if d.weekday() < 5:  # Mon-Fri\n        print(d.strftime('%Y%m%d'))\n        break\n\")\nfi\n\necho \"========================================\"\necho \"日期: $DATE_TAG\"\necho \"时间: $(date '+%Y-%m-%d %H:%M:%S')\"\necho \"========================================\"\n\n# ---------- 持仓价格补全 ----------\nENRICHED=\"$REPORTS_DIR/selected_real_positions_${DATE_TAG}_enriched.csv\"\nHOLDINGS=\"$REPORTS_DIR/selected_real_positions_${DATE_TAG}.csv\"\nBREADTH=\"$REPORTS_DIR/breadth_aggressive_paper_${DATE_TAG}.json\"\nBREADTH_FALLBACK=\"$REPORTS_DIR/breadth_aggressive_paper_latest.json\"\n\necho \"\"\necho \"[1/5] 补全持仓价格 ...\"\nif [ -f \"$HOLDINGS\" ]; then\n    python3 \"$SCRIPT_DIR/enrich_holdings_with_prices.py\" \\\n        --input \"$HOLDINGS\" \\\n        --output \"$ENRICHED\"\n    echo \"价格已写入: $ENRICHED\"\nelse\n    echo \"WARNING: 找不到持仓文件 $HOLDINGS，跳过价格补全\"\nfi\n\n# ---------- 候选池解释 ----------\necho \"\"\necho \"[2/5] 运行候选池解释 (candidate_explainer) ...\"\nCANDIDATE_POOL=\"$REPORTS_DIR/candidate_pool_${DATE_TAG}.json\"\nCANDIDATE_POOL_FALLBACK=\"$REPORTS_DIR/candidate_pool_latest.json\"\n\nCANDIDATE_INPUT=\"\"\nif [ -f \"$CANDIDATE_POOL\" ]; then\n    CANDIDATE_INPUT=\"$CANDIDATE_POOL\"\nelif [ -f \"$CANDIDATE_POOL_FALLBACK\" ]; then\n    CANDIDATE_INPUT=\"$CANDIDATE_POOL_FALLBACK\"\n    echo \"WARNING: 使用 fallback 候选池 $CANDIDATE_POOL_FALLBACK\"\nelse\n    echo \"WARNING: 找不到候选池文件，跳过候选池解释\"\nfi\n\nif [ -n \"$CANDIDATE_INPUT\" ]; then\n    cd \"$PROJECT_DIR\"\n    python3 -m ai_overlay.candidate_explainer.main \\\n        --date \"$DATE_TAG\" \\\n        --model minimax-m2.5-highspeed \\\n        --max-candidates 18 \\\n        --candidate-pool \"$CANDIDATE_INPUT\" \\\n        2>&1 | grep -v \"^\\[position_explainer\\]\"\n    echo \"候选池解释完成\"\nfi\n\n# ---------- 持仓风险观察 ----------\necho \"\"\necho \"[3/5] 运行持仓风险观察 (position_explainer) ...\"\n\nMC_PATH=\"$BREADTH\"\nif [ ! -f \"$MC_PATH\" ]; then\n    MC_PATH=\"$BREADTH_FALLBACK\"\n    echo \"WARNING: 使用 fallback 市场数据 $MC_PATH\"\nfi\n\nif [ -f \"$ENRICHED\" ]; then\n    cd \"$PROJECT_DIR\"\n    python3 -m ai_overlay.position_explainer.main \\\n        --date \"$DATE_TAG\" \\\n        --holdings \"$ENRICHED\" \\\n        --market-context \"$MC_PATH\" \\\n        --model minimax-m2.5-highspeed \\\n        2>&1 | grep -v \"^\\[position_explainer\\]\" || true\n    echo \"持仓风险观察完成\"\nelse\n    echo \"WARNING: 找不到 enriched 持仓文件，跳过持仓风险观察\"\nfi\n\n# ---------- 输出摘要 ----------\necho \"\"\necho \"[5/5] 生成多视角综合研判 ...\"\ncd \"$PROJECT_DIR\"\nif python3 -m ai_overlay.multi_perspective_merger \\\n    --date \"$DATE_TAG\" \\\n    2>&1; then\n    echo \"✅ 综合研判已生成: $OVERLAY_DIR/daily_digest_${DATE_TAG}.md\"\nelse\n    echo \"❌ 综合研判生成失败\"\nfi\n\necho \"\"\necho \"========================================\"\necho \"✅ 每日 Overlay 执行完成\"\necho \"日期: $DATE_TAG\"\necho \"日志: $LOG_FILE\"\necho \"候选池:   $OVERLAY_DIR/candidate_explainer_${DATE_TAG}.md\"\necho \"持仓:     $OVERLAY_DIR/position_explainer_${DATE_TAG}.md\"\necho \"综合研判: $OVERLAY_DIR/daily_digest_${DATE_TAG}.md\"\necho \"========================================\""}],"details":{"status":"completed","exitCode":0,"durationMs":34,"aggregated":"#!/bin/bash\n# run_daily_overlays.sh\n# 每日定时执行: 候选池解释 + 持仓风险观察\n# 使用 MiniMax-M2.5-HighSpeed 模型\n#\n# 用法: ./run_daily_overlays.sh [YYYYMMDD]\n#   不带参数则自动取前一交易日\n\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nPROJECT_DIR=\"$(dirname \"$SCRIPT_DIR\")\"\nREPORTS_DIR=\"$PROJECT_DIR/research/reports\"\nOVERLAY_DIR=\"$REPORTS_DIR/ai_overlay\"\nLOG_FILE=\"$PROJECT_DIR/logs/daily_overlays_$(date +%Y%m%d).log\"\n\nmkdir -p \"$(dirname \"$LOG_FILE\")\"\nexec > >(tee -a \"$LOG_FILE\") 2>&1\n\n# ---------- 日期确定 ----------\nif [ -n \"${1:-}\" ]; then\n  DATE_TAG=\"$1\"\nelse\n  # 取前一交易日（跳过周末）\n  DATE_TAG=$(python3 -c \"\nimport datetime\ntoday = datetime.date.today()\n# 往前找最近的交易日\nfor i in range(1, 8):\n    d = today - datetime.timedelta(days=i)\n    if d.weekday() < 5:  # Mon-Fri\n        print(d.strftime('%Y%m%d'))\n        break\n\")\nfi\n\necho \"========================================\"\necho \"日期: $DATE_TAG\"\necho \"时间: $(date '+%Y-%m-%d %H:%M:%S')\"\necho \"========================================\"\n\n# ---------- 持仓价格补全 ----------\nENRICHED=\"$REPORTS_DIR/selected_real_positions_${DATE_TAG}_enriched.csv\"\nHOLDINGS=\"$REPORTS_DIR/selected_real_positions_${DATE_TAG}.csv\"\nBREADTH=\"$REPORTS_DIR/breadth_aggressive_paper_${DATE_TAG}.json\"\nBREADTH_FALLBACK=\"$REPORTS_DIR/breadth_aggressive_paper_latest.json\"\n\necho \"\"\necho \"[1/5] 补全持仓价格 ...\"\nif [ -f \"$HOLDINGS\" ]; then\n    python3 \"$SCRIPT_DIR/enrich_holdings_with_prices.py\" \\\n        --input \"$HOLDINGS\" \\\n        --output \"$ENRICHED\"\n    echo \"价格已写入: $ENRICHED\"\nelse\n    echo \"WARNING: 找不到持仓文件 $HOLDINGS，跳过价格补全\"\nfi\n\n# ---------- 候选池解释 ----------\necho \"\"\necho \"[2/5] 运行候选池解释 (candidate_explainer) ...\"\nCANDIDATE_POOL=\"$REPORTS_DIR/candidate_pool_${DATE_TAG}.json\"\nCANDIDATE_POOL_FALLBACK=\"$REPORTS_DIR/candidate_pool_latest.json\"\n\nCANDIDATE_INPUT=\"\"\nif [ -f \"$CANDIDATE_POOL\" ]; then\n    CANDIDATE_INPUT=\"$CANDIDATE_POOL\"\nelif [ -f \"$CANDIDATE_POOL_FALLBACK\" ]; then\n    CANDIDATE_INPUT=\"$CANDIDATE_POOL_FALLBACK\"\n    echo \"WARNING: 使用 fallback 候选池 $CANDIDATE_POOL_FALLBACK\"\nelse\n    echo \"WARNING: 找不到候选池文件，跳过候选池解释\"\nfi\n\nif [ -n \"$CANDIDATE_INPUT\" ]; then\n    cd \"$PROJECT_DIR\"\n    python3 -m ai_overlay.candidate_explainer.main \\\n        --date \"$DATE_TAG\" \\\n        --model minimax-m2.5-highspeed \\\n        --max-candidates 18 \\\n        --candidate-pool \"$CANDIDATE_INPUT\" \\\n        2>&1 | grep -v \"^\\[position_explainer\\]\"\n    echo \"候选池解释完成\"\nfi\n\n# ---------- 持仓风险观察 ----------\necho \"\"\necho \"[3/5] 运行持仓风险观察 (position_explainer) ...\"\n\nMC_PATH=\"$BREADTH\"\nif [ ! -f \"$MC_PATH\" ]; then\n    MC_PATH=\"$BREADTH_FALLBACK\"\n    echo \"WARNING: 使用 fallback 市场数据 $MC_PATH\"\nfi\n\nif [ -f \"$ENRICHED\" ]; then\n    cd \"$PROJECT_DIR\"\n    python3 -m ai_overlay.position_explainer.main \\\n        --date \"$DATE_TAG\" \\\n        --holdings \"$ENRICHED\" \\\n        --market-context \"$MC_PATH\" \\\n        --model minimax-m2.5-highspeed \\\n        2>&1 | grep -v \"^\\[position_explainer\\]\" || true\n    echo \"持仓风险观察完成\"\nelse\n    echo \"WARNING: 找不到 enriched 持仓文件，跳过持仓风险观察\"\nfi\n\n# ---------- 输出摘要 ----------\necho \"\"\necho \"[5/5] 生成多视角综合研判 ...\"\ncd \"$PROJECT_DIR\"\nif python3 -m ai_overlay.multi_perspective_merger \\\n    --date \"$DATE_TAG\" \\\n    2>&1; then\n    echo \"✅ 综合研判已生成: $OVERLAY_DIR/daily_digest_${DATE_TAG}.md\"\nelse\n    echo \"❌ 综合研判生成失败\"\nfi\n\necho \"\"\necho \"========================================\"\necho \"✅ 每日 Overlay 执行完成\"\necho \"日期: $DATE_TAG\"\necho \"日志: $LOG_FILE\"\necho \"候选池:   $OVERLAY_DIR/candidate_explainer_${DATE_TAG}.md\"\necho \"持仓:     $OVERLAY_DIR/position_explainer_${DATE_TAG}.md\"\necho \"综合研判: $OVERLAY_DIR/daily_digest_${DATE