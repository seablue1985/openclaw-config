ode(code)\n                adv20 = parse_float(adv20_map.get(ts_code_for_adv), 0.0)\n                if adv20 > 0 and max_order_to_adv20_ratio > 0:\n                    max_liquidity_amount = adv20 * max_order_to_adv20_ratio\n                    ratio = est_amount / adv20\n                    if ratio > max_order_to_adv20_ratio:\n                        liquidity_qty = int(max_liquidity_amount / ref_price)\n                        liquidity_qty = (liquidity_qty // lot_size) * lot_size\n                        if liquidity_qty <= 0:\n                            blocked_buy_liquidity += 1\n                            risk_gate = \"blocked\"\n                            gate_reason = merge_gate_reason(\n                                f\"流动性拦截: order/adv20={ratio:.4f} > {max_order_to_adv20_ratio:.4f}\",\n                                decision,\n                            )\n                        else:\n                            capped_buy_liquidity += 1\n                            suggest_qty = min(suggest_qty, liquidity_qty)\n                            est_amount = suggest_qty * ref_price\n                            gate_reason = merge_gate_reason(\n                                f\"流动性限额截断: order/adv20={ratio:.4f} > {max_order_to_adv20_ratio:.4f}, \"\n                                f\"cap_qty={suggest_qty}\",\n                                decision,"}],"details":{"status":"completed","exitCode":0,"durationMs":10,"aggregated":"ref_price = realtime_price if realtime_price > 0 else fallback_price\n\n        risk_gate = \"pass\"\n        gate_reason = \"\"\n\n        if runtime.halt_new_buy:\n            blocked_buy_halt += 1\n            risk_gate = \"blocked\"\n            gate_reason = runtime.halt_reason or \"mode=halt\"\n            suggest_qty = 0\n            est_amount = 0.0\n        elif ref_price <= 0:\n            blocked_buy_no_price += 1\n            risk_gate = \"blocked\"\n            gate_reason = \"无有效参考价格\"\n            suggest_qty = 0\n  