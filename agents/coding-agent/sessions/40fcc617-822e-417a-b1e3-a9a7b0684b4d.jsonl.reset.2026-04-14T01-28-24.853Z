{"type":"message","id":"fda789fd","parentId":"2eade79f","timestamp":"2026-04-13T07:45:37.131Z","message":{"role":"toolResult","toolCallId":"call_function_wv6ah73mapf0_1","toolName":"exec","content":[{"type":"text","text":"def manual_review_status(profile_slug: str, now: datetime) -> dict[str, Any]:\n    recon_path = latest_file(f\"paper_{profile_slug}_daily_reconciliation_*.csv\")\n    if recon_path is None:\n        return {\n            \"profile_slug\": profile_slug,\n            \"completed\": False,\n            \"issues\": [\"missing_reconciliation\"],\n            \"path\": None,\n        }\n    if not is_recent_mtime(recon_path, now):\n        return {\n            \"profile_slug\": profile_slug,\n            \"completed\": False,\n            \"issues\": [\"stale_reconciliation\"],\n            \"path\": str(recon_path),\n        }\n\n    rows = load_csv_rows(recon_path)\n    if not rows:\n        return {\n            \"profile_slug\": profile_slug,\n            \"completed\": False,\n            \"issues\": [\"empty_reconciliation\"],\n            \"path\": str(recon_path),\n        }\n\n    pending_items: list[str] = []\n    reviewer = \"\"\n    for row in rows:\n        section = str(row.get(\"section\") or \"\").strip()\n        item = str(row.get(\"item\") or \"\").strip()\n        if section not in {\"人工复核\", \"结论\"}:\n            continue\n        value = str(row.get(\"value\") or \"\").strip()\n        status = str(row.get(\"status\") or \"\").strip().upper()\n        if item == \"复核人\" and (not _is_blank(value)):\n            reviewer = value\n        if status in {\"\", \"TODO\", \"AUTO\"} or _is_blank(value):\n            pending_items.append(item or \"unknown\")\n\n    issues = [f\"pending_manual_review:{item}\" for item in pending_items]\n    if not reviewer:\n        issues.append(\"missing_reviewer\")\n    return {\n        \"profile_slug\": profile_slug,\n        \"completed\": len(pending_items) == 0 and bool(reviewer),\n        \"issues\": issues,\n        \"path\": str(recon_path),\n        \"reviewer\": reviewer,\n    }\n\n\ndef profile_runtime_status(profile_slug: str, now: datetime) -> dict[str, Any]:\n    prefix = f\"paper_{profile_slug}\"\n    account_latest = REPORT_DIR / f\"{prefix}_account_v1_latest.json\"\n    positions_latest = REPORT_DIR / f\"{prefix}_portfolio_positions_latest.csv\"\n    orders_path = latest_file(f\"{prefix}_orders_v1_*.csv\")\n    tickets_path = latest_file(f\"{prefix}_signal_tickets_*.csv\")\n    journal_path = latest_file(f\"{prefix}_trading_journal_*.csv\")\n    order_plan_path = latest_file(f\"{prefix}_order_plan_v1_*.json\")\n\n    dated_tags = {\n        \"orders\": extract_date_tag(orders_path),\n        \"tickets\": extract_date_tag(tickets_path),\n        \"journal\": extract_date_tag(journal_path),\n        \"order_plan\": extract_date_tag(order_plan_path),\n    }\n    unique_tags = sorted({value for value in dated_tags.values() if value})\n    profile_date_tag = unique_tags[0] if len(unique_tags) == 1 else \"\"\n\n    issues: list[str] = []\n    if not account_latest.exists():\n        issues.append(\"missing_account_latest\")\n    elif not is_recent_mtime(account_latest, now):\n        issues.append(\"stale_account_latest\")\n    if not positions_latest.exists():\n        issues.append(\"missing_positions_latest\")\n    elif not is_recent_mtime(positions_latest, now):\n        issues.append(\"stale_positions_latest\")\n    for kind, path in {\n        \"orders\": orders_path,\n        \"tickets\": tickets_path,\n        \"journal\": journal_path,\n        \"order_plan\": order_plan_path,\n    }.items():\n        if path is None:\n            issues.append(f\"missing_{kind}\")\n    if len(unique_tags) > 1:\n        issues.append(\"dated_artifact_tag_mismatch\")\n    elif not profile_date_tag:\n        issues.append(\"missing_profile_date_tag\")\n    elif not is_recent_date_tag(profile_date_tag, now):\n        issues.append(\"stale_profile_date_tag\")\n\n    return {\n        \"profile_slug\": profile_slug,\n        \"date_tag\": profile_date_tag,\n        \"runtime_ready\": not issues,\n        \"issues\": issues,\n        \"artifacts\": {\n            \"account_latest\": str(account_latest) if account_latest.exists() else None,\n            \"positions_latest\": str(positions_latest) if positions_latest.exists() else None,\n            \"orders\": str(orders_path) if orders_path else None,\n            \"tickets\": str(tickets_path) if tickets_path else None,\n            \"journal\": str(journal_path) if journal_path else None,\n            \"order_plan\": str(order_plan_path) if order_plan_path else None,\n        },\n        \"dated_tags\": dated_tags,\n    }"}],"details":{"status":"completed","exitCode":0,"durationMs":42,"aggregated":"def manual_review_status(profile_slug: str, now: datetime) -> dict[str, Any]:\n    recon_path = latest_file(f\"paper_{profile_slug}_daily_reconciliation_*.csv\")\n    if recon_path is None:\n        return {\n            \"profile_slug\": profile_slug,\n            \"completed\": False,\n            \"issues\": [\"missing_reconciliation\"],\n            \"path\": None,\n        }\n    if not is_recent_mtime(recon_path, now):\n        return {\n            \"profile_slug\": profile_slug,\n            \"completed\": False,\n            \"issues\": [\"stale_reconciliation\"],\n            \"path\": str(recon_path),\n        }\n\n    rows = load_csv_rows(recon_path)\n    if not rows:\n        return {\n            \"profile_slug\": profile_slug,\n            \"completed\": False,\n            \"issues\": [\"empty_reconciliation\"],\n            \"path\": str(recon_path),\n        }\n\n    pending_items: list[str] = []\n    reviewer = \"\"\n    for row in rows:\n        section = str(row.get(\"section\") or \"\").strip()\n        item = str(row.get(\"item\") or \"\").strip()\n        if section not in {\"人工复核\", \"结论\"}:\n            continue\n        value = str(row.get(\"value\") or \"\").strip()\n        status = str(row.get(\"status\") or \"\").strip().upper()\n        if item == \"复核人\" and (not _is_blank(value)):\n            reviewer = value\n        if status in {\"\", \"TODO\", \"AUTO\"} or _is_blank(value):\n            pending_items.append(item or \"unknown\")\n\n    issues = [f\"pending_manual_review:{item}\" for item in pending_items]\n    if not reviewer:\n        issues.append(\"missing_reviewer\")\n    return {\n        \"profile_slug\": profile_slug,\n        \"completed\": len(pending_items) == 0 and bool(reviewer),\n        \"issues\": issues,\n        \"path\": str(recon_path),\n        \"reviewer\": reviewer,\n    }\n\n\ndef profile_runtime_status(profile_slug: str, now: datetime) -> dict[str, Any]:\n    prefix = f\"paper_{profile_slug}\"\n    account_latest = REPORT_DIR / f\"{prefix}_account_v1_latest.json\"\n    positions_latest = REPORT_DIR / f\"{prefix}_portfolio_positions_latest.csv\"\n    orders_path = latest_file(f\"{prefix}_orders_v1_*.csv\")\n    tickets_path = latest_file(f\"{prefix}_signal_tickets_*.csv\")\n    journal_path = latest_file(f\"{prefix}_trading_journal_*.csv\")\n    order_plan_path = latest_file(f\"{prefix}_order_plan_v1_*.json\")\n\n    dated_tags = {\n        \"orders\": extract_date_tag(orders_path),\n        \"tickets\": extract_date_tag(tickets_path),\n        \"journal\": extract_date_tag(journal_path),\n        \"order_plan\": extract_date_tag(order_plan_path),\n    }\n    unique_tags = sorted({value for value in dated_tags.values() if value})\n    profile_date_tag = unique_tags[0] if len(unique_tags) == 1 else \"\"\n\n    issues: list[str] = []\n    if not account_latest.exists():\n        issues.append(\"missing_account_latest\")\n    elif not is_recent_mtime(account_latest, now):\n        issues.append(\"stale_account_latest\")\n    if not positions_latest.exists():\n        issues.append(\"missing_positions_latest\")\n    elif not is_recent_mtime(positions_latest, now):\n        issues.append(\"stale_positions_latest\")\n    for kind, path in {\n        \"orders\": orders_path,\n        \"tickets\": tickets_path,\n        \"journal\": journal_path,\n        \"order_plan\": order_plan_path,\n    }.items():\n        if path is None:\n            issues.append(f\"missing_{kind}\")\n    if len(unique_tags) > 1:\n        issues.append(\"dated_artifact_tag_mismatch\")\n    elif not profile_date_tag:\n        issues.append(\"missing_profile_date_tag\")\n    elif not is_recent_date_tag(profile_date_tag, now):\n        issues.append(\"stale_profile_date_tag\")\n\n    return {\n        \"profile_slug\": profile_slug,\n        \"date_tag\": profile_date_tag,\n        \"runtime_ready\": not issues,\n        \"issues\": issues,\n        \"artifacts\": {\n            \"account_latest\": str(account_latest) if account_latest.exists() else None,\n            \"positions_latest\": str(positions_latest) if positions_latest.exists() else None,\n            \"orders\": str(orders_path) if orders_path else None,\n            \"tickets\": str(tickets_path) if tickets_path else None,\n            \"journal\": str(journal_path) if journal_path else None,\n            \"order_plan\": str(order_plan_path) if order_plan_path else None,\n        },\n        \"dated_tags\": dated_tags,\n    }","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1776066337115}}
