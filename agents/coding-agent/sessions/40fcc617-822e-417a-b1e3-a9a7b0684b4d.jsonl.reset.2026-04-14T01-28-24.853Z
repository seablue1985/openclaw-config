{"type":"message","id":"ecf56c55","parentId":"97f03813","timestamp":"2026-04-13T03:06:31.589Z","message":{"role":"toolResult","toolCallId":"call_function_0h2hhp9gpz4g_1","toolName":"read","content":[{"type":"text","text":"            from gotdx_client import get_gotdx_client\n            self.gotdx_client = get_gotdx_client()\n            if self.gotdx_client:\n                print(f\"✅ gotdx实时行情已就绪\")\n        except Exception as e:\n            print(f\"⚠️ gotdx初始化失败: {e}\")\n\n        # 初始化tushare（历史数据备用）\n        if self.tushare_token:\n            try:\n                import tushare as ts\n\n                ts.set_token(self.tushare_token)\n                self.tushare_api = ts.pro_api()\n                self.tushare_available = True\n                print(\"✅ Tushare数据源初始化成功\")\n            except Exception as e:\n                print(f\"⚠️ Tushare数据源初始化失败: {e}\")\n                self.tushare_available = False\n        else:\n            print(\"ℹ️ 未配置Tushare Token\")\n\n    def get_stock_hist_data(self, symbol, start_date=None, end_date=None, adjust=\"qfq\"):\n        \"\"\"\n        获取股票历史数据（优先gotdx，iFinD失败时使用tushare）\n\n        Args:\n            symbol: 股票代码（6位数字）\n            start_date: 开始日期（格式：'20240101'或'2024-01-01'）\n            end_date: 结束日期\n\n[366 more lines in file. Use offset=56 to continue.]"}],"isError":false,"timestamp":1776049591582}}
{"type":"message","id":"e1b07454","parentId":"ecf56c55","timestamp":"2026-04-13T03:06:54.533Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I need to add health check to the DataSourceManager. Let me add a `_health_status` dict and a `health_check()` method, and also add automatic switching based on health status.","thinkingSignature":"ead3fa85f7f4c8555498eae9287848e207562d7868df7fb790ea534ae6ce8c6d"},{"type":"toolCall","id":"call_function_ro75l8ces5sd_1","name":"edit","arguments":{"path":"/Users/ling/AI-RXC/data_source_manager.py","edits":[{"oldText":"import os\nimport pandas as pd\nfrom datetime import datetime\nfrom dotenv import load_dotenv","newText":"import os\nimport threading\nimport time\nimport pandas as pd\nfrom datetime import datetime\nfrom dotenv import load_dotenv"},{"oldText":"class DataSourceManager:\n    \"\"\"数据源管理器 - 实现gotdx/Tushare/iFinD自动切换\"\"\"\n\n    def __init__(self):\n        self.tushare_token = os.getenv(\"TUSHARE_TOKEN\", \"\")\n        self.tushare_available = False\n        self.tushare_api = None\n        self.gotdx_client = None\n\n        # 初始化gotdx（实时行情，优先级最高）\n        try:\n            from gotdx_client import get_gotdx_client\n            self.gotdx_client = get_gotdx_client()\n            if self.gotdx_client:\n                print(f\"✅ gotdx实时行情已就绪\")\n        except Exception as e:\n            print(f\"⚠️ gotdx初始化失败: {e}\")\n\n        # 初始化tushare（历史数据备用）\n        if self.tushare_token:\n            try:\n                import tushare as ts\n\n                ts.set_token(self.tushare_token)\n                self.tushare_api = ts.pro_api()\n                self.tushare_available = True\n                print(\"✅ Tushare数据源初始化成功\")\n            except Exception as e:\n                print(f\"⚠️ Tushare数据源初始化失败: {e}\")\n                self.tushare_available = False\n        else:\n            print(\"ℹ️ 未配置Tushare Token\")","newText":"class DataSourceManager:\n    \"\"\"数据源管理器 - 实现gotdx/Tushare/iFinD自动切换 + 健康检查\"\"\"\n\n    def __init__(self):\n        self.tushare_token = os.getenv(\"TUSHARE_TOKEN\", \"\")\n        self.tushare_available = False\n        self.tushare_api = None\n        self.gotdx_client = None\n        self._health_status: dict[str, bool] = {}\n        self._health_lock = threading.Lock()\n        self._last_health_check: float = 0\n        self._health_check_interval: float = 60  # 每60秒检查一次\n\n        # 初始化gotdx（实时行情，优先级最高）\n        try:\n            from gotdx_client import get_gotdx_client\n            self.gotdx_client = get_gotdx_client()\n            if self.gotdx_client:\n                print(f\"✅ gotdx实时行情已就绪\")\n        except Exception as e:\n            print(f\"⚠️ gotdx初始化失败: {e}\")\n\n        # 初始化tushare（历史数据备用）\n        if self.tushare_token:\n            try:\n                import tushare as ts\n\n                ts.set_token(self.tushare_token)\n                self.tushare_api = ts.pro_api()\n                self.tushare_available = True\n                print(\"✅ Tushare数据源初始化成功\")\n            except Exception as e:\n                print(f\"⚠️ Tushare数据源初始化失败: {e}\")\n                self.tushare_available = False\n        else:\n            print(\"ℹ️ 未配置Tushare Token\")\n\n        # 启动时做一次健康检查\n        self._run_health_checks()\n\n    def _run_health_checks(self) -> dict:\n        \"\"\"并行检查所有行情源健康状态\"\"\"\n        import httpx\n        results: dict[str, bool] = {}\n\n        # gotdx 健康检查\n        if self.gotdx_client:\n            try:\n                df = self.gotdx_client.get_realtime_quotes([\"000001\"])\n                results[\"gotdx\"] = df is not None and not df.empty\n            except Exception:\n                results[\"gotdx\"] = False\n        else:\n            results[\"gotdx\"] = False\n\n        # tushare 健康检查（轻量调用）\n        if self.tushare_available and self.tushare_api:\n            try:\n                today = datetime.now().strftime(\"%Y%m%d\")\n                df = self.tushare_api.daily(ts_code=\"000001.SZ\", start_date=today, end_date=today)\n                results[\"tushare\"] = df is not None and not df.empty\n            except Exception:\n                results[\"tushare\"] = False\n        else:\n            results[\"tushare\"] = False\n\n        with self._health_lock:\n            self._health_status = results\n            self._last_health_check = time.time()\n\n        return results\n\n    def get_health_status(self) -> dict:\n        \"\"\"返回各数据源健康状态，必要时刷新\"\"\"\n        with self._health_lock:\n            stale = (time.time() - self._last_health_check) > self._health_check_interval\n        if stale:\n            return self._run_health_checks()\n        return dict(self._health_status)\n\n    def is_healthy(self, source: str) -> bool:\n        \"\"\"检查指定数据源是否健康\"\"\"\n        status = self.get_health_status()\n        return status.get(source, False)"}]}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":68886,"output":1331,"cacheRead":35206,"cacheWrite":0,"totalTokens":105423,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776049591591,"responseId":"062b90b829869639ade29391fcd04071"}}
