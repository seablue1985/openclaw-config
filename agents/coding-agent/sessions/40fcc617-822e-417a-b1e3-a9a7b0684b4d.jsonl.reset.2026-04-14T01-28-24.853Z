{"type":"message","id":"dc653a77","parentId":"9e6f050f","timestamp":"2026-04-13T03:05:19.945Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the omlx_provider.py.","thinkingSignature":"ef14eac362cc999f0b48a15a7b4febaaf301459193ea122954815e83db53ab08"},{"type":"toolCall","id":"call_function_cbb8m2rw6fyl_1","name":"write","arguments":{"path":"/Users/ling/AI-RXC/services/llm_providers/omlx_provider.py","content":"\"\"\"\noMLX 本地推理 Provider\n支持 temperature, max_tokens, cache\n\"\"\"\n\nimport os\nimport time\nfrom typing import Any\n\nimport httpx\n\n\ndef _bool_env(name: str, default: bool) -> bool:\n    raw = os.getenv(name)\n    if raw in {None, \"\"}:\n        return bool(default)\n    return str(raw).strip().lower() in {\"1\", \"true\", \"yes\", \"on\"}\n\n\ndef generate_text(\n    *,\n    api_key: str,\n    base_url: str,\n    model: str,\n    messages: list[dict],\n    temperature: float,\n    max_tokens: int,\n    include_reasoning: bool = True,\n    timeout_config: dict[str, float] | None = None,\n    extra_body: dict[str, Any] | None = None,\n) -> dict[str, Any]:\n    \"\"\"\n    调用本地 oMLX server（OpenAI-compatible /v1/chat/completions）\n    支持的 extra_body 键:\n        - repetition_penalty: float\n        - top_p: float\n    \"\"\"\n    config = timeout_config or {}\n    connect_timeout = float(config.get(\"connect\", 5))\n    read_timeout = float(config.get(\"read\", 30))\n    write_timeout = float(config.get(\"write\", 10))\n    total_timeout = float(config.get(\"total\", 35))\n    timeout = httpx.Timeout(timeout=total_timeout, connect=connect_timeout, read=read_timeout, write=write_timeout, pool=5.0)\n\n    # 标准化 base_url\n    base = str(base_url or \"http://127.0.0.1:8000\").rstrip(\"/\")\n    if base.endswith(\"/v1\"):\n        base = base[:-3]\n\n    url = f\"{base}/v1/chat/completions\"\n    headers = {\"Authorization\": f\"Bearer {api_key}\", \"Content-Type\": \"application/json\"}\n\n    # 转换 messages 为 prompt（oMLX 对话格式）\n    # oMLX server 支持 messages 格式\n    payload: dict[str, Any] = {\n        \"model\": model,\n        \"messages\": messages,\n        \"temperature\": max(temperature, 0.05),  # 最低0.05，防止输出不稳定\n        \"max_tokens\": min(max_tokens, 2048),     # 限制输出长度，防止过长延迟\n    }\n\n    if isinstance(extra_body, dict):\n        if \"repetition_penalty\" in extra_body:\n            payload[\"repetition_penalty\"] = float(extra_body[\"repetition_penalty\"])\n        if \"top_p\" in extra_body:\n            payload[\"top_p\"] = float(extra_body[\"top_p\"])\n        if extra_body.get(\"stream\") is True:\n            payload[\"stream\"] = True\n\n    started = time.perf_counter()\n    http_status: int | None = None\n    error_type = \"\"\n    error_message = \"\"\n    raw_body: str = \"\"\n\n    try:\n        with httpx.Client(timeout=timeout) as client:\n            resp = client.post(url, headers=headers, json=payload)\n            http_status = resp.status_code\n            raw_body = resp.text\n            resp.raise_for_status()\n            body = resp.json()\n\n    except httpx.TimeoutException:\n        error_type = \"timeout\"\n        error_message = f\"oMLX 请求超时({total_timeout}s)\"\n        body = {}\n    except httpx.HTTPStatusError as e:\n        error_type = \"http_error\"\n        error_message = f\"oMLX HTTP {e.response.status_code}: {e.response.text[:200]}\"\n        body = {}\n    except Exception as e:\n        error_type = \"unknown\"\n        error_message = f\"oMLX 调用异常: {e}\"\n        body = {}\n\n    elapsed = time.perf_counter() - started\n\n    if error_type:\n        return {\n            \"ok\": False,\n            \"provider\": \"omlx\",\n            \"model\": model,\n            \"text\": \"\",\n            \"duration_s\": elapsed,\n            \"error_type\": error_type,\n            \"error_message\": error_message,\n            \"usage\": {\"prompt_tokens\": 0, \"completion_tokens\": 0, \"total_tokens\": 0},\n            \"usage_estimated\": False,\n            \"finish_reason\": \"error\",\n            \"http_status\": http_status,\n            \"raw_head\": raw_body[:200],\n        }\n\n    # 解析响应\n    choices = body.get(\"choices\", [])\n    message = (choices[0].get(\"message\") if choices else {}) or {}\n    content = str(message.get(\"content\", \"\")).strip()\n    finish_reason = str(choices[0].get(\"finish_reason\", \"stop\") if choices else \"stop\")\n    usage = body.get(\"usage\", {})\n\n    prompt_tokens = int(usage.get(\"prompt_tokens\", 0))\n    completion_tokens = int(usage.get(\"completion_tokens\", 0))\n    total_tokens = int(usage.get(\"total_tokens\", 0))\n\n    # 估算token数\n    if total_tokens == 0:\n        prompt_tokens = max(1, sum(len(str(m)) for m in messages) // 4)\n        completion_tokens = max(1, len(content) // 4)\n        total_tokens = prompt_tokens + completion_tokens\n\n    return {\n        \"ok\": True,\n        \"provider\": \"omlx\",\n        \"model\": model,\n        \"text\": content,\n        \"duration_s\": elapsed,\n        \"error_type\": \"\",\n        \"error_message\": \"\",\n        \"usage\": {\n            \"prompt_tokens\": prompt_tokens,\n            \"completion_tokens\": completion_tokens,\n            \"total_tokens\": total_tokens,\n        },\n        \"usage_estimated\": total_tokens == 0,\n        \"finish_reason\": finish_reason,\n        \"http_status\": http_status,\n        \"raw_head\": raw_body[:200],\n    }\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":64248,"output":1283,"cacheRead":35206,"cacheWrite":0,"totalTokens":100737,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776049492474,"responseId":"062b9054a3f70edb55b370c32fc65f7a"}}
