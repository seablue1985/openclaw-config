: \"自动\", \"settings.resource.off\": \"关闭\", \"settings.resource.memory_limit_total_disabled\": \"设为0则禁用。\", \"settings.resource.memory_limit_models\": \"内存限制（仅模型）\", \"settings.resource.memory_limit_models_description\": \"已加载模型的最大内存限制。设为0则禁用。\", \"settings.resource.hot_cache_limit\": \"热缓存限制（内存缓存）\", \"settings.resource.hot_cache_description\": \"用于频繁访问的 KV Cache 块的内存缓存。\", \"settings.resource.hot_cache_zero_note\": \"减少重复提示词的 SSD I/O 延迟。\", \"settings.resource.hot_cache_disabled\": \"0\", \"settings.resource.hot_cache_disabled_label\": \"= 已禁用。\", \"settings.resource.cold_cache_limit\": \"冷缓存限制（SSD 缓存）\", \"settings.resource.cold_cache_description\": \"被驱逐的 KV Cache 块的持久 SSD 存储。\", \"settings.resource.prefill_memory_guard\": \"内存守卫\", \"settings.resource.prefill_memory_guard_description\": \"在预填充前估算内存，内存压力时延迟调度以防止Metal分配失败。\", \"settings.resource.max_concurrent_requests\": \"最大并发请求\", \"settings.resource.max_concurrent_requests_hint\": \"同时处理的最大请求数。值越大吞吐量越高，但内存使用也越多。\", \"settings.resource.restart_badge\": \"需要重启\", \"settings.cache.section_label\": \"缓存\", \"settings.cache.enabled\": \"启用缓存\", \"settings.cache.ssd_directory\": \"SSD 缓存目录\", \"settings.generation.section_label\": \"生成默认值\", \"settings.generation.max_context_window\": \"最大上下文窗口\", \"settings.generation.max_context_window_hint\": \"拒绝超过此 Token 限制的提示词\", \"settings.generation.max_tokens\": \"最大 Token 数\", \"settings.generation.temperature\": \"温度\", \"settings.generation.temperature_hint\": \"0.0 = 确定性，2.0 = 最大随机性\", \"settings.generation.top_p\": \"Top P\", \"settings.generation.top_p_hint\": \"核采样阈值\", \"settings.generation.top_k\": \"Top K\", \"settings.generation.top_k_hint\": \"0 = 禁用\", \"settings.generation.repetition_penalty\": \"重复惩罚\", \"settings.generation.repetition_penalty_hint\": \"1.0 = 禁用\", \"settings.mcp.section_label\": \"MCP\", \"settings.mcp.restart_badge\": \"需要重启\", \"settings.mcp.config_path\": \"配置路径\", \"settings.mcp.config_placeholder\": \"MCP 配置文件路径\", \"settings.huggingface.endpoint\": \"镜像端点\", \"settings.huggingface.endpoint_hint\": \"HuggingFace API 自定义端点 URL（例如 https://hf-mirror.com）\", \"settings.huggingface.endpoint_clear_hint\": \"要使用默认端点，请清空输入框并保存。\", \"settings.advanced.section_label\": \"高级\", \"settings.advanced.restart_badge\": \"需要重启\", \"settings.advanced.cache\": \"缓存\", \"settings.advanced.initial_cache_blocks\": \"初始缓存块数\", \"settings.advanced.initial_cache_blocks_hint\": \"启动时预分配的块数。值越大，动态分配开销越小。\", \"settings.language.section_label\": \"语言\", \"settings.language.label\": \"界面语言\", \"settings.language.en\": \"English\", \"settings.language.zh\": \"中文（简体）\", \"settings.language.zh-TW\": \"中文（繁體）\", \"settings.language.ko\": \"한국어\", \"settings.language.ja\": \"日本語\", \"settings.save.button\": \"保存设置\", \"settings.save.saving\": \"保存中...\", \"settings.models.section_label\": \"模型设置\", \"settings.models.heading\": \"可用模型\", \"settings.models.description\": \"配置每个模型的设置，包括采样参数。\", \"settings.models.loading\": \"正在加载模型...\", \"settings.models.no_models_heading\": \"未找到任何模型\", \"settings.models.no_models_description\": \"请将模型添加到模型目录以开始使用。\", \"settings.models.table.model\": \"模型\", \"settings.models.table.type\": \"类型\", \"settings.models.table.size\": \"大小\", \"settings.models.table.status\": \"状态\", \"settings.models.table.pin\": \"固定\", \"settings.models.table.default\": \"默认\", \"settings.models.table.status_loading\": \"加载中\", \"settings.models.table.status_loaded\": \"已加载\", \"settings.models.table.status_unload\": \"卸载\", \"settings.models.table.status_load\": \"加载\", \"settings.models.table.status_ready\": \"就绪\", \"settings.models.table.copy_model_name_tooltip\": \"复制模型名称\", \"settings.models.table.sampling_settings_tooltip\": \"采样设置\", \"settings.models.badge.ctx_window\": \"ctx_window:\", \"settings.models.badge.max_tokens\": \"max_tokens:\", \"settings.models.badge.temp\": \"temp:\", \"settings.models.badge.top_p\": \"top_p:\", \"settings.models.badge.top_k\": \"top_k:\", \"settings.models.badge.min_p\": \"min_p:\", \"settings.models.badge.rep_penalty\": \"rep_penalty:\", \"settings.models.badge.presence_penalty\": \"presence_penalty:\", \"settings.models.badge.tool_result_tokens\": \"tool_result_tokens:\", \"settings.models.badge.force_sampling\": \"force_sampling\", \"modal.model_settings.section_label\": \"模型设置\", \"modal.model_settings.model_alias\": \"模型别名\", \"modal.model_settings.model_type\": \"模型类型\", \"modal.model_settings.model_type_auto\": \"自动检测\", \"modal.model_settings.max_context_window\": \"Ctx Window\", \"modal.model_settings.max_tokens\": \"最大 Token 数\", \"modal.model_settings.temperature\": \"温度\", \"modal.model_settings.repetition_penalty\": \"重复惩罚\", \"modal.model_settings.repetition_penalty_short\": \"Rep. Penalty\", \"modal.model_settings.min_p\": \"Min P\", \"modal.model_settings.presence_penalty\": \"Presence Penalty\", \"modal.model_settings.top_p\": \"Top P\", \"modal.model_settings.top_k\": \"Top K\", \"modal.model_settings.ttl_seconds\": \"TTL（秒）\", \"modal.model_settings.ttl_pinned\": \"已固定\", \"modal.model_settings.ttl_no_ttl\": \"无 TTL\", \"modal.model_settings.load_defaults\": \"加载默认值\", \"modal.model_settings.loading_defaults\": \"加载中...\", \"modal.model_settings.placeholder_default\": \"默认\", \"modal.model_settings.thinking_budget\": \"思考 Token 限制\", \"modal.model_settings.thinking_budget_hint\": \"限制推理模型的思考 Token 数量，超出时强制结束思考\", \"modal.model_settings.thinking_budget_placeholder\": \"例如 4096\", \"modal.model_settings.limit_tool_result\": \"限制工具结果 Token\", \"modal.model_settings.limit_tool_result_hint\": \"截断过长的工具结果（如文件读取）到 Token 限制\", \"modal.model_settings.limit_tool_placeholder\": \"例如 2000\", \"modal.model_settings.turboquant_kv\": \"TurboQuant KV Cache\", \"modal.model_settings.turboquant_kv_hint\": \"Compress KV cache using vector quantization. Reduces memory ~60-75% with near-lossless quality for long context.\", \"modal.model_settings.turboquant_kv_bits_label\": \"Bits per channel\", \"modal.model_settings.index_cache\": \"索引缓存\", \"modal.model_settings.index_cache_hint\": \"跳过DSA层中的冗余索引器计算（DeepSeek V3/GLM-5）。\", \"modal.model_settings.index_cache_freq\": \"频率（每N层保留索引器）\", \"modal.model_settings.force_sampling\": \"强制采样\", \"modal.model_settings.force_sampling_hint\": \"用配置值覆盖请求中的采样参数\", \"modal.model_settings.chat_template_kwargs\": \"聊天模板参数\", \"modal.model_settings.chat_template_kwargs_hint\": \"传递给聊天模板的参数\", \"modal.model_settings.add_kwarg\": \"+ 添加\", \"modal.model_settings.kwarg_enable_thinking\": \"enable_thinking\", \"modal.model_settings.kwarg_reasoning_effort\": \"reasoning_effort\", \"modal.model_settings.kwarg_custom\": \"自定义\", \"modal.model_settings.kwarg_custom_key_placeholder\": \"键\", \"modal.model_settings.kwarg_custom_value_placeholder\": \"值\", \"modal.model_settings.kwarg_force\": \"强制\", \"modal.model_settings.kwarg_force_tooltip\": \"强制：API 请求无法覆盖此值\", \"modal.model_settings.kwarg_effort_low\": \"low\", \"modal.model_settings.kwarg_effort_medium\": \"medium\", \"modal.model_settings.kwarg_effort_high\": \"high\", \"modal.model_settings.no_kwargs\": \"暂无配置的参数\", \"modal.model_settings.empty_hint\": \"留空则使用全局默认值\", \"modal.model_settings.basic_label\": \"基本设置\", \"modal.model_settings.advanced_label\": \"高级设置\", \"modal.model_settings.experimental_label\": \"实验性功能\", \"modal.model_settings.cancel\": \"取消\", \"modal.model_settings.save\": \"保存\", \"modal.model_settings.saving\": \"保存中...\", \"logs.section_label\": \"日志\", \"logs.heading\": \"服务器日志\", \"logs.description\": \"查看实时服务器日志，支持自动刷新。\", \"logs.viewer_label\": \"日志查看器\", \"logs.auto_refresh\": \"自动刷新\", \"logs.lines_label\": \"行数：\", \"logs.refresh_label\": \"刷新间隔：\", \"logs.refresh_unit\": \"秒（0=关闭）\", \"logs.file_label\": \"文件：\", \"logs.refresh_button\": \"刷新\", \"logs.loading\": \"加载中...\", \"logs.auto_scroll\": \"自动滚动\", \"logs.showing_lines\": \"显示 {lines} / {total} 行\", \"logs.placeholder\": \"暂无日志。启动服务器后将产生日志。\", \"logs.last_updated\": \"最后更新：{time}\", \"bench.section_label\": \"基准测试\", \"bench.heading\": \"性能基准测试\", \"bench.description\": \"测量单请求和连续批处理的推理速度。基准测试前将卸载所有其他模型。\", \"bench.config.section_label\": \"配置\", \"bench.config.model\": \"模型\", \"bench.config.model_placeholder\": \"选择模型...\", \"bench.config.single_request\": \"单请求测试\", \"bench.config.generation_hint\": \"生成长度：128 tokens（固定）\", \"bench.config.batch_tests\": \"连续批处理测试\", \"bench.config.batch_hint\": \"批处理测试使用 pp1024 / tg128\", \"bench.config.run_button\": \"运行基准测试\", \"bench.progress.preparing\": \"准备中...\", \"bench.progress.cancel\": \"取消\", \"bench.progress.starting\": \"正在启动基准测试...\", \"bench.results.single.section_label\": \"单请求结果\", \"bench.results.single.test\": \"测试\", \"bench.results.single.ttft\": \"TTFT (ms)\", \"bench.results.single.tpot\": \"TPOT (ms/tok)\", \"bench.results.single.pp_tps\": \"pp TPS\", \"bench.results.single.tg_tps\": \"tg TPS\", \"bench.results.single.e2e_latency\": \"端到端延迟\", \"bench.results.single.throughput\": \"吞吐量\", \"bench.results.single.peak_mem\": \"峰值内存\", \"bench.results.batch.section_label\": \"Continuous Batching\", \"bench.results.batch.subtitle\": \"pp1024 / tg128\", \"bench.results.batch.batch_size\": \"批大小\", \"bench.results.batch.tg_tps\": \"tg TPS\", \"bench.results.batch.speedup\": \"加速比\", \"bench.results.batch.pp_tps\": \"pp TPS\", \"bench.results.batch.pp_tps_req\": \"pp TPS/请求\", \"bench.results.batch.avg_ttft\": \"平均 TTFT (ms)\", \"bench.results.batch.e2e_latency\": \"端到端延迟\", \"bench.results.batch.baseline\": \"1x（基准线）\", \"bench.results.text_export.section_label\": \"基准结果（文本 — 复制粘贴）\", \"bench.results.text_export.copy\": \"复制\", \"bench.results.text_export.copied\": \"已复制！\", \"bench.metrics.section_label\": \"指标参考\", \"bench.metrics.ttft.name\": \"TTFT\", \"bench.metrics.ttft.full_name\": \"（首 Token 时间）\", \"bench.metrics.test.tooltip\": \"测试用例标签，格式为 ppN/tgM。'pp' = 提示词处理（输入 token 数），'tg' = token 生成（输出 token 数）。例如 pp1024/tg256 表示 1024 个输入 token 和 256 个输出 token。\", \"bench.metrics.ttft.tooltip\": \"Time to First Token — 用户看到第一个输出前的等待时间。模型必须在生成第一个 token 之前读取并处理整个提示词（预填充阶段）。提示词越长，TTFT 越高。以毫秒为单位。越低越好。\", \"bench.metrics.tpot.tooltip\": \"Time Per Output Token — 生成（解码）阶段连续输出 token 之间的平均间隔。直接影响文本在屏幕上显示的速度。例如 20ms/tok 意味着每秒约 50 个 token。越低越好。\", \"bench.metrics.tg_tps.tooltip\": \"Token Generation TPS — 解码阶段每秒生成的输出 token 数。是 TPOT 的倒数（例如 TPOT 20ms = 50 tg TPS）。衡量模型生成回复速度的核心指标。越高越好。\", \"bench.metrics.pp_tps.tooltip\": \"Prompt Processing TPS — 预填充阶段模型每秒处理的输入 token 数。数值越高意味着模型读取提示词越快，直接降低 TTFT。对长上下文任务尤为重要。越高越好。\", \"bench.metrics.e2e.tooltip\": \"End-to-End Latency — 从发送请求到收到完整回复的总耗时。等于 TTFT +（TPOT × 输出 token 数）。这是用户等待完整答案的总时间。\", \"bench.metrics.throughput.tooltip\": \"Total Throughput — 每秒处理的输入和输出 token 总和。展示包括预填充和生成在内的整体系统利用率。适合比较不同提示词长度下的总计算效率。\", \"bench.metrics.peak_mem.tooltip\": \"Peak GPU Memory — 该测试中推理时使用的最大 GPU（统一）内存。包括模型权重、KV 缓存和中间激活。有助于估算你的硬件能运行多大的模型。\", \"bench.metrics.batch_size.tooltip\": \"Batch Size — 同时处理的请求数。批处理让 GPU 同时处理多个请求，提高总吞吐量但增加单个请求的延迟。由于内存带宽限制，2x 批量并不等于 2 倍速度。\", \"bench.metrics.speedup.tooltip\": \"Speedup — 相对于单请求（1x 基准）的 token 生成速度提升倍数。例如 1.8x 表示批处理整体产生 token 的速度是单请求的 1.8 倍。超过 1x 说明批处理提升了 GPU 利用效率。\", \"bench.metrics.pp_tps_req.tooltip\": \"Per-Request Prompt Processing TPS — pp TPS 除以批量大小。展示与其他请求共享 GPU 时，每个请求的提示词处理速度。由于计算资源共享，预期低于单请求的 pp TPS。\", \"bench.metrics.avg_ttft.tooltip\": \"批次内所有请求的平均 Time to First Token。由于 GPU 需要处理多个提示词，因此高于单请求 TTFT。展示批处理负载下每个用户的典型等待时间。\", \"bench.metrics.ttft.description\": \"模型开始响应前的延迟。衡量提示词处理（预填充）速度。越低越好。\", \"bench.metrics.tpot.name\": \"TPOT\", \"bench.metrics.tpot.full_name\": \"（每输出 Token 时间）\", \"bench.metrics.tpot.description\": \"每个生成 Token 之间的平均时间。衡量解码速度。越低越好。\", \"bench.metrics.tg_tps.name\": \"tg TPS\", \"bench.metrics.tg_tps.full_name\": \"（Token 生成 TPS）\", \"bench.metrics.tg_tps.description\": \"每秒生成的输出 Token 数。TPOT 的倒数。越高越好。\", \"bench.metrics.pp_tps.name\": \"pp TPS\", \"bench.metrics.pp_tps.full_name\": \"（提示词处理 TPS）\", \"bench.metrics.pp_tps.description\": \"预填充阶段每秒处理的输入/提示词 Token 数。越高越好。\", \"bench.metrics.e2e.name\": \"端到端延迟\", \"bench.metrics.e2e.full_name\": \"（End-to-End）\", \"bench.metrics.e2e.description\": \"从提交请求到完整响应的总时间。包含预填充 + 生成。\", \"bench.metrics.throughput.name\": \"总吞吐量\", \"bench.metrics.throughput.description\": \"每秒处理的总 Token 数（输入 + 输出）。衡量系统整体利用率。\", \"bench.metrics.batch_size.name\": \"批量大小\", \"bench.metrics.batch_size.description\": \"同时处理的并发请求数。批量越大总吞吐量越高，但每个请求的延迟会增加。\", \"bench.metrics.speedup.name\": \"加速比\", \"bench.metrics.speedup.description\": \"相对于单请求基准（1x）的 Token 生成吞吐量倍数。越高越好。\", \"bench.metrics.pp_tps_req.name\": \"pp TPS/req\", \"bench.metrics.pp_tps_req.full_name\": \"（每请求提示词处理 TPS）\", \"bench.metrics.pp_tps_req.description\": \"提示词处理吞吐量除以批量大小。显示批量负载下每个请求的预填充速度。\", \"navbar.dropdown.performance\": \"Performance\", \"navbar.dropdown.accuracy\": \"Intelligence\", \"acc_bench.section_label\": \"Intelligence\", \"acc_bench.heading\": \"智能基准测试\", \"acc_bench.description\": \"通过知识、推理、数学和编程基准评估模型智能。基准测试前将卸载所有其他模型。\", \"acc_bench.config.section_label\": \"配置\", \"acc_bench.config.model\": \"模型\", \"acc_bench.config.model_placeholder\": \"选择模型...\", \"acc_bench.config.benchmarks\": \"基准测试\", \"acc_bench.config.benchmarks_hint\": \"固定种子采样确保不同模型使用相同问题进行公平比较。选择Full使用完整数据集。\", \"acc_bench.config.livecodebench_warning\": \"LiveCodeBench 会在你的机器上执行模型生成的代码（带超时和内存限制的沙箱环境）。\", \"acc_bench.config.code_exec\": \"代码执行\", \"acc_bench.config.batch_size\": \"批量大小\", \"acc_bench.config.batch_size_hint\": \"同时处理多个问题。批量越大速度越快，但占用更多内存。\", \"acc_bench.config.add_run\": \"添加并运行\", \"acc_bench.config.cancel_button\": \"取消\", \"acc_bench.config.queue_label\": \"队列\", \"acc_bench.results.section_label\": \"结果\", \"acc_bench.results.clear\": \"清除结果\", \"acc_bench.results.download\": \"Download\", \"acc_bench.results.show_categories\": \"显示分类详情\", \"acc_bench.results.hide_categories\": \"隐藏分类详情\", \"acc_bench.results.category\": \"分类\", \"acc_bench.results.score\": \"得分\", \"acc_bench.results.show_text\": \"显示文本导出\", \"acc_bench.results.hide_text\": \"隐藏文本导出\", \"chat.title\": \"聊天 - oMLX 管理后台\