rt_status') or 'UNKNOWN').lower()}\"]\n\n\ndef manual_review_closure_alert_status(now: datetime) -> dict[str, Any]:"}],"details":{"status":"completed","exitCode":0,"durationMs":10,"aggregated":"def load_scheduler_config() -> dict[str, Any]:\n    return load_json(SCHEDULER_CONFIG_PATH) if SCHEDULER_CONFIG_PATH.exists() else {}\n\n\ndef load_governance_gate_status(now: datetime) -> dict[str, Any]:\n    path = REPORT_DIR / \"strategy_governance_gate_latest.json\"\n    if not path.exists():\n        return {\n            \"report_status\": \"MISSING\",\n            \"blocking\": True,\n            \"issues\": [\"missing_governance_gate_report\"],\n            \"path\": None,\n            \"generated_at\": \"\",\n        }\n\n    payload = load_json(path)\n    if not payload:\n        return {\n            \"report_status\": \"INVALID\",\n            \"blocking\": True,\n            \"issues\": [\"invalid_governance_gate_report\"],\n            \"path\": str(path),\n            \"generated_at\": \"\",\n        }\n\n    report_status = str(payload.get(\"overall_status\") or \"UNKNOWN\").upper()\n    issues = [str(x).strip() for x in (payload.get(\"blocking_issues\") or []) if str(x).strip()]\n    if not is_recent_mtime(path, now):\n        issues.append(\"stale_governance_gate_report\")\n    blocking = report_status != \"PASS\" or bool(issues)\n    return {\n        \"report_status\": report_status,\n        \"blocking\": blocking,\n        \"issues\": issues,\n        \"path\": str(path),\n        \"generated_at\": str(payload.get(\"generated_at\") or \"\"),\n    }\n\n\ndef governance_blocking_entries(governance_status: dict[str, Any]) -> list[str]:\n    if not governance_status.get(\"blocking\"):\n        return []\n    governance_issues = governance_status.get(\"issues\") or []\n    if governance_issues:\n        return [f\"governance:{issue}\" for issue in governance_issues]\n    return [f\"governance:status_{str(governance_status.get('report_status') or 'UNKNOWN').lower()}\"]\n\n\ndef manual_review_closure_alert_status(now: datetime) -> dict[str, Any]:","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1776077605673}}
