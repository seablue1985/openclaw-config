{"type":"message","id":"5c2ac99e","parentId":"e5ecfa05","timestamp":"2026-04-13T03:06:10.228Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the `inference_router.py` that ties everything together. This will be the main entry point for inference with routing, caching, and health check.","thinkingSignature":"3ac90cee1207ef4e118b329f857e2bd9ff561f646b5f364d54dceef4d898688a"},{"type":"toolCall","id":"call_function_mw4sp7a1upbf_1","name":"write","arguments":{"path":"/Users/ling/AI-RXC/services/inference_router.py","content":"\"\"\"\n推理路由层 - 统一入口\n1. 读取 inference_routing.json 路由配置\n2. 根据 task_type 选择 provider（oMLX 本地 / DeepSeek 云端）\n3. 查询 InferenceCache 缓存\n4. 缓存未命中 → 调用对应 provider → 写入缓存\n5. 支持健康检查自动切源\n\"\"\"\n\nimport json\nimport os\nimport time\nfrom threading import Lock\nfrom typing import Any\n\nfrom services.inference_cache import get_cache, InferenceCache\nfrom services.llm_router import call_llm\n\n\n_ROUTING_CONFIG_PATH = os.path.join(os.path.dirname(__file__), \"..\", \"inference_routing.json\")\n_health_status: dict[str, bool] = {}\n_health_lock = Lock()\n\n\ndef _load_routing_config() -> dict:\n    path = os.environ.get(\"INFERENCE_ROUTING_CONFIG\", _ROUTING_CONFIG_PATH)\n    if os.path.exists(path):\n        with open(path) as f:\n            return json.load(f)\n    return {}\n\n\ndef check_provider_health(provider: str, config: dict) -> bool:\n    \"\"\"检查 provider 是否健康\"\"\"\n    try:\n        if provider == \"gotdx\":\n            import httpx\n            base_url = config.get(\"gotdx\", {}).get(\"base_url\", \"http://host.docker.internal:8089\")\n            method = config.get(\"gotdx\", {}).get(\"health_check_method\", \"stock_quotes\")\n            resp = httpx.get(f\"{base_url}/api/query\", timeout=3, json={\n                \"method\": method,\n                \"params\": {\"markets\": \"0,1\", \"codes\": \"000001\"}\n            })\n            return resp.status_code == 200\n        elif provider == \"omlx\":\n            import httpx\n            omlx_cfg = config.get(\"omlx\", {})\n            base_url = omlx_cfg.get(\"base_url\", \"http://host.docker.internal:8000\")\n            api_key = omlx_cfg.get(\"api_key\", \"0923\")\n            base = base_url.rstrip(\"/\")\n            if base.endswith(\"/v1\"):\n                base = base[:-3]\n            resp = httpx.get(\n                f\"{base}/v1/models\",\n                timeout=5,\n                headers={\"Authorization\": f\"Bearer {api_key}\"}\n            )\n            return resp.status_code == 200\n    except Exception:\n        pass\n    return False\n\n\ndef run_health_checks() -> dict[str, bool]:\n    \"\"\"并行检查所有 provider 健康状态\"\"\"\n    config = _load_routing_config()\n    providers = config.get(\"health_check\", {}).get(\"providers\", [])\n    results = {}\n    for p in providers:\n        results[p] = check_provider_health(p, config)\n    with _health_lock:\n        _health_status.update(results)\n    return results\n\n\ndef get_health_status(provider: str | None = None) -> dict[str, bool] | bool:\n    with _health_lock:\n        if provider:\n            return _health_status.get(provider, False)\n        return dict(_health_status)\n\n\ndef inference(\n    *,\n    task_type: str,\n    stock_code: str | None = None,\n    date: str | None = None,\n    prompt: str | None = None,\n    messages: list[dict] | None = None,\n    system_prompt: str | None = None,\n    override_provider: str | None = None,\n    skip_cache: bool = False,\n    llm_cfg: dict | None = None,\n) -> dict[str, Any]:\n    \"\"\"\n    推理统一入口\n\n    Args:\n        task_type: 任务类型（如 \"stock_screen\", \"fund_flow_analysis\"）\n        stock_code: 股票代码（用于缓存key）\n        date: 日期（用于缓存key）\n        prompt: prompt 文本（与 messages 二选一）\n        messages: 对话消息列表\n        system_prompt: 系统提示词\n        override_provider: 强制指定 provider（跳过路由）\n        skip_cache: 跳过缓存\n        llm_cfg: 额外 LLM 配置（会与路由配置合并）\n\n    Returns:\n        dict: 包含 ok, text, provider, cache_hit 等字段\n    \"\"\"\n    config = _load_routing_config()\n    routes = config.get(\"task_routes\", {})\n    task_cfg = routes.get(task_type, {}) if task_type else {}\n    cache = get_cache()\n\n    # 确定 provider\n    if override_provider:\n        provider = override_provider\n        model = llm_cfg.get(\"model\") if llm_cfg else None\n        temperature = llm_cfg.get(\"temperature\", 0.3) if llm_cfg else 0.3\n        max_tokens = llm_cfg.get(\"max_tokens\", 2000) if llm_cfg else 2000\n    elif task_cfg:\n        provider = task_cfg.get(\"provider\", config.get(\"default_provider\", \"deepseek\"))\n        model = task_cfg.get(\"model\")\n        temperature = task_cfg.get(\"temperature\", 0.3)\n        max_tokens = task_cfg.get(\"max_tokens\", 2000)\n    else:\n        provider = config.get(\"default_provider\", \"deepseek\")\n        model = None\n        temperature = 0.3\n        max_tokens = 2000\n\n    # 检查健康状态，不健康的 provider 自动降级\n    if provider in [\"gotdx\", \"omlx\"]:\n        status = get_health_status(provider)\n        if status is False or (isinstance(status, dict) and not any(status.values())):\n            fallback = config.get(provider, {}).get(f\"fallback_{provider}_provider\") or config.get(\"default_provider\", \"deepseek\")\n            print(f\"[inference_router] {provider} 不健康，自动降级到 {fallback}\")\n            provider = fallback\n\n    # 构建缓存 key（只有指定了 stock_code + date + task_type 才缓存）\n    cache_hit = False\n    if stock_code and date and not skip_cache and provider in (\"omlx\", \"deepseek\"):\n        cached = cache.get(stock_code, date, task_type, prompt or str(messages))\n        if cached:\n            cached[\"cache_hit\"] = True\n            return cached\n\n    # 构建 messages\n    if messages is None:\n        messages = []\n        if system_prompt:\n            messages.append({\"role\": \"system\", \"content\": system_prompt})\n        if prompt:\n            messages.append({\"role\": \"user\", \"content\": prompt})\n\n    # 调用 LLM\n    extra_cfg = llm_cfg or {}\n    if model:\n        extra_cfg[\"model\"] = model\n\n    result = call_llm(\n        provider=provider,\n        model=model or (llm_cfg.get(\"model\") if llm_cfg else \"deepseek-chat\"),\n        messages=messages,\n        temperature=temperature,\n        max_tokens=max_tokens,\n        **(extra_cfg or {}),\n    )\n    result[\"cache_hit\"] = False\n\n    # 写入缓存\n    if stock_code and date and result.get(\"ok\") and provider in (\"omlx\", \"deepseek\"):\n        cache.set(stock_code, date, task_type, prompt or str(messages), result)\n\n    return result\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":66232,"output":1575,"cacheRead":35206,"cacheWrite":0,"totalTokens":103013,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776049533775,"responseId":"062b907ed7dfa4b58d8eaebcaf1c9538"}}
