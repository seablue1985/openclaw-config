{"type":"message","id":"23e0bc70","parentId":"8697db0f","timestamp":"2026-04-13T02:14:47.316Z","message":{"role":"toolResult","toolCallId":"call_function_fdze4xol1n9w_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env bash\nset -euo pipefail\n\nTHSDK_VERSION=\"1.7.15\"\nTHSDATA_REPO=\"https://github.com/jsczsyx969/thsdata.git\"\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nPATCH1=\"$SCRIPT_DIR/patches/0001-thsdata-compat-with-new-thsdk.patch\"\nPATCH2=\"$SCRIPT_DIR/patches/0002-thsdk-fix-darwin-arm64-arch-check.patch\"\n\nWORKDIR=\"$PWD/thsdata-realtime-fix-work\"\nSKIP_SMOKE=0\nDRY_RUN=0\n\nusage() {\n  cat <<'EOF'\n用法:\n  bash apply_thsdata_realtime_fix.sh [--workdir DIR] [--skip-smoke] [--dry-run]\n\n参数:\n  --workdir DIR   工作目录（默认: ./thsdata-realtime-fix-work）\n  --skip-smoke    跳过安装后的连通性冒烟测试\n  --dry-run       只打印将执行的步骤，不实际执行\n  -h, --help      显示帮助\nEOF\n}\n\nwhile [[ $# -gt 0 ]]; do\n  case \"$1\" in\n    --workdir)\n      WORKDIR=\"$2\"\n      shift 2\n      ;;\n    --skip-smoke)\n      SKIP_SMOKE=1\n      shift\n      ;;\n    --dry-run)\n      DRY_RUN=1\n      shift\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      echo \"未知参数: $1\" >&2\n      usage\n      exit 1\n      ;;\n  esac\ndone\n\nrun() {\n  echo \"+ $*\"\n  if [[ \"$DRY_RUN\" -eq 0 ]]; then\n    eval \"$*\"\n  fi\n}\n\nfor cmd in python3 git patch; do\n  command -v \"$cmd\" >/dev/null || { echo \"缺少命令: $cmd\" >&2; exit 1; }\ndone\n\n[[ -f \"$PATCH1\" ]] || { echo \"缺少补丁: $PATCH1\" >&2; exit 1; }\n[[ -f \"$PATCH2\" ]] || { echo \"缺少补丁: $PATCH2\" >&2; exit 1; }\n\nrun \"mkdir -p '$WORKDIR'\"\nrun \"mkdir -p '$WORKDIR/src'\"\n\nTHSDK_SRC_TAR=\"$WORKDIR/src/thsdk-${THSDK_VERSION}.tar.gz\"\nTHSDK_SRC_DIR=\"$WORKDIR/src/thsdk-${THSDK_VERSION}\"\nTHSDATA_DIR=\"$WORKDIR/src/thsdata\"\nVENV_DIR=\"$WORKDIR/venv\"\nSMOKE_LOG=\"$WORKDIR/smoke-test.log\"\n\nrun \"python3 -m pip download --no-binary :all: --no-deps thsdk==${THSDK_VERSION} -d '$WORKDIR/src'\"\nrun \"rm -rf '$THSDK_SRC_DIR'\"\nrun \"tar -xzf '$THSDK_SRC_TAR' -C '$WORKDIR/src'\"\n\nrun \"cd '$THSDK_SRC_DIR' && patch -p1 < '$PATCH2'\"\n\nrun \"rm -rf '$THSDATA_DIR'\"\nrun \"git clone --depth 1 '$THSDATA_REPO' '$THSDATA_DIR'\"\nrun \"cd '$THSDATA_DIR' && git apply '$PATCH1'\"\n\nrun \"python3 -m venv '$VENV_DIR'\"\nrun \"source '$VENV_DIR/bin/activate' && pip -q install --upgrade pip\"\nrun \"source '$VENV_DIR/bin/activate' && pip -q install pandas requests pytz setuptools\"\nrun \"source '$VENV_DIR/bin/activate' && pip -q install '$THSDK_SRC_DIR'\"\nrun \"source '$VENV_DIR/bin/activate' && pip -q install '$THSDATA_DIR'\"\n\nif [[ \"$SKIP_SMOKE\" -eq 0 ]]; then\n  run \"source '$VENV_DIR/bin/activate' && python - <<'PY' > '$SMOKE_LOG' 2>&1\nfrom thsdata import Quote, FuquanNo, KlineDay\nimport datetime\n\nq = Quote()\nmd = q.ths.market_data_cn('USZA300033')\nprint('market_data_cn ok=', bool(md), 'err=', md.error)\nif md.data:\n    print('market sample=', {k: md.data[0].get(k) for k in ['代码','名称','价格','开盘价','最高价','最低价','成交量']})\n\nnow = datetime.datetime.now()\nbars = q.security_bars('USZA300033', now - datetime.timedelta(days=5), now, FuquanNo, KlineDay)\nprint('bars rows=', len(bars), 'cols=', list(bars.columns)[:8])\n\nca = q.call_auction('USZA300033')\nprint('call_auction rows=', len(ca), 'cols=', list(ca.columns)[:8])\n\nq.disconnect()\nPY\"\nfi\n\necho\nif [[ \"$DRY_RUN\" -eq 1 ]]; then\n  echo \"[DRY RUN] 已输出全部步骤。\"\nelse\n  echo \"✅ 修复完成\"\n  echo \"工作目录: $WORKDIR\"\n  echo \"虚拟环境: $VENV_DIR\"\n  if [[ \"$SKIP_SMOKE\" -eq 0 ]]; then\n    echo \"冒烟日志: $SMOKE_LOG\"\n  fi\nfi"}],"details":{"status":"completed","exitCode":0,"durationMs":30,"aggregated":"#!/usr/bin/env bash\nset -euo pipefail\n\nTHSDK_VERSION=\"1.7.15\"\nTHSDATA_REPO=\"https://github.com/jsczsyx969/thsdata.git\"\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nPATCH1=\"$SCRIPT_DIR/patches/0001-thsdata-compat-with-new-thsdk.patch\"\nPATCH2=\"$SCRIPT_DIR/patches/0002-thsdk-fix-darwin-arm64-arch-check.patch\"\n\nWORKDIR=\"$PWD/thsdata-realtime-fix-work\"\nSKIP_SMOKE=0\nDRY_RUN=0\n\nusage() {\n  cat <<'EOF'\n用法:\n  bash apply_thsdata_realtime_fix.sh [--workdir DIR] [--skip-smoke] [--dry-run]\n\n参数:\n  --workdir DIR   工作目录（默认: ./thsdata-realtime-fix-work）\n  --skip-smoke    跳过安装后的连通性冒烟测试\n  --dry-run       只打印将执行的步骤，不实际执行\n  -h, --help      显示帮助\nEOF\n}\n\nwhile [[ $# -gt 0 ]]; do\n  case \"$1\" in\n    --workdir)\n      WORKDIR=\"$2\"\n      shift 2\n      ;;\n    --skip-smoke)\n      SKIP_SMOKE=1\n      shift\n      ;;\n    --dry-run)\n      DRY_RUN=1\n      shift\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      echo \"未知参数: $1\" >&2\n      usage\n      exit 1\n      ;;\n  esac\ndone\n\nrun() {\n  echo \"+ $*\"\n  if [[ \"$DRY_RUN\" -eq 0 ]]; then\n    eval \"$*\"\n  fi\n}\n\nfor cmd in python3 git patch; do\n  command -v \"$cmd\" >/dev/null || { echo \"缺少命令: $cmd\" >&2; exit 1; }\ndone\n\n[[ -f \"$PATCH1\" ]] || { echo \"缺少补丁: $PATCH1\" >&2; exit 1; }\n[[ -f \"$PATCH2\" ]] || { echo \"缺少补丁: $PATCH2\" >&2; exit 1; }\n\nrun \"mkdir -p '$WORKDIR'\"\nrun \"mkdir -p '$WORKDIR/src'\"\n\nTHSDK_SRC_TAR=\"$WORKDIR/src/thsdk-${THSDK_VERSION}.tar.gz\"\nTHSDK_SRC_DIR=\"$WORKDIR/src/thsdk-${THSDK_VERSION}\"\nTHSDATA_DIR=\"$WORKDIR/src/thsdata\"\nVENV_DIR=\"$WORKDIR/venv\"\nSMOKE_LOG=\"$WORKDIR/smoke-test.log\"\n\nrun \"python3 -m pip download --no-binary :all: --no-deps thsdk==${THSDK_VERSION} -d '$WORKDIR/src'\"\nrun \"rm -rf '$THSDK_SRC_DIR'\"\nrun \"tar -xzf '$THSDK_SRC_TAR' -C '$WORKDIR/src'\"\n\nrun \"cd '$THSDK_SRC_DIR' && patch -p1 < '$PATCH2'\"\n\nrun \"rm -rf '$THSDATA_DIR'\"\nrun \"git clone --depth 1 '$THSDATA_REPO' '$THSDATA_DIR'\"\nrun \"cd '$THSDATA_DIR' && git apply '$PATCH1'\"\n\nrun \"python3 -m venv '$VENV_DIR'\"\nrun \"source '$VENV_DIR/bin/activate' && pip -q install --upgrade pip\"\nrun \"source '$VENV_DIR/bin/activate' && pip -q install pandas requests pytz setuptools\"\nrun \"source '$VENV_DIR/bin/activate' && pip -q install '$THSDK_SRC_DIR'\"\nrun \"source '$VENV_DIR/bin/activate' && pip -q install '$THSDATA_DIR'\"\n\nif [[ \"$SKIP_SMOKE\" -eq 0 ]]; then\n  run \"source '$VENV_DIR/bin/activate' && python - <<'PY' > '$SMOKE_LOG' 2>&1\nfrom thsdata import Quote, FuquanNo, KlineDay\nimport datetime\n\nq = Quote()\nmd = q.ths.market_data_cn('USZA300033')\nprint('market_data_cn ok=', bool(md), 'err=', md.error)\nif md.data:\n    print('market sample=', {k: md.data[0].get(k) for k in ['代码','名称','价格','开盘价','最高价','最低价','成交量']})\n\nnow = datetime.datetime.now()\nbars = q.security_bars('USZA300033', now - datetime.timedelta(days=5), now, FuquanNo, KlineDay)\nprint('bars rows=', len(bars), 'cols=', list(bars.columns)[:8])\n\nca = q.call_auction('USZA300033')\nprint('call_auction rows=', len(ca), 'cols=', list(ca.columns)[:8])\n\nq.disconnect()\nPY\"\nfi\n\necho\nif [[ \"$DRY_RUN\" -eq 1 ]]; then\n  echo \"[DRY RUN] 已输出全部步骤。\"\nelse\n  echo \"✅ 修复完成\"\n  echo \"工作目录: $WORKDIR\"\n  echo \"虚拟环境: $VENV_DIR\"\n  if [[ \"$SKIP_SMOKE\" -eq 0 ]]; then\n    echo \"冒烟日志: $SMOKE_LOG\"\n  fi\nfi","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1776046487308}}
