{"type":"message","id":"4563a0f8","parentId":"f2541244","timestamp":"2026-04-13T07:44:20.249Z","message":{"role":"toolResult","toolCallId":"call_function_ssy6yjx1ttze_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nWORKSPACE = Path('/Users/ling/.openclaw/workspace')\nQUANT_REPORT_DIR = WORKSPACE / 'quant_projects' / 'personal-a-share-research-system' / 'research' / 'reports'\nRULES_PATH = WORKSPACE / 'quant_projects' / 'personal-a-share-research-system' / 'config' / 'quant_p0_p1_guard_rules_v1.json'\nREPORT_DIR = WORKSPACE / 'research' / 'reports'\nP1_001_HELPER = WORKSPACE / 'scripts' / 'ensure_p1_001_consistency.py'\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding='utf-8'))\n\n\ndef parse_dt(value: Any) -> datetime:\n    text = str(value or \"\").strip()\n    if not text:\n        return datetime.min\n    for fmt in (\"%Y-%m-%d %H:%M:%S\", \"%Y-%m-%dT%H:%M:%S.%f\", \"%Y-%m-%dT%H:%M:%S\"):\n        try:\n            return datetime.strptime(text, fmt)\n        except ValueError:\n            continue\n    return datetime.min\n\n\ndef main() -> None:\n    date_tag = datetime.now().strftime('%Y%m%d')\n    rules = load_json(RULES_PATH)\n    runtime = load_json(QUANT_REPORT_DIR / 'runtime_risk_state_latest.json')\n    # P1-001 follow-up：优先使用 generated_at 更新的那份报告，避免 dated 文件陈旧时误判\n    dated_report = load_json(QUANT_REPORT_DIR / f'today_stock_strategy_report_{date_tag}.json')\n    latest_report = load_json(QUANT_REPORT_DIR / 'today_stock_strategy_report_latest.json')\n    report = latest_report\n    if dated_report and latest_report:\n        dated_ts = parse_dt(dated_report.get('generated_at'))\n        latest_ts = parse_dt(latest_report.get('generated_at'))\n        if dated_ts > latest_ts:\n            report = dated_report\n    elif dated_report:\n        report = dated_report\n    tester = load_json(REPORT_DIR / 'tester_scheduled_guard_latest.json')"}],"details":{"status":"completed","exitCode":0,"durationMs":55,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nWORKSPACE = Path('/Users/ling/.openclaw/workspace')\nQUANT_REPORT_DIR = WORKSPACE / 'quant_projects' / 'personal-a-share-research-system' / 'research' / 'reports'\nRULES_PATH = WORKSPACE / 'quant_projects' / 'personal-a-share-research-system' / 'config' / 'quant_p0_p1_guard_rules_v1.json'\nREPORT_DIR = WORKSPACE / 'research' / 'reports'\nP1_001_HELPER = WORKSPACE / 'scripts' / 'ensure_p1_001_consistency.py'\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding='utf-8'))\n\n\ndef parse_dt(value: Any) -> datetime:\n    text = str(value or \"\").strip()\n    if not text:\n        return datetime.min\n    for fmt in (\"%Y-%m-%d %H:%M:%S\", \"%Y-%m-%dT%H:%M:%S.%f\", \"%Y-%m-%dT%H:%M:%S\"):\n        try:\n            return datetime.strptime(text, fmt)\n        except ValueError:\n            continue\n    return datetime.min\n\n\ndef main() -> None:\n    date_tag = datetime.now().strftime('%Y%m%d')\n    rules = load_json(RULES_PATH)\n    runtime = load_json(QUANT_REPORT_DIR / 'runtime_risk_state_latest.json')\n    # P1-001 follow-up：优先使用 generated_at 更新的那份报告，避免 dated 文件陈旧时误判\n    dated_report = load_json(QUANT_REPORT_DIR / f'today_stock_strategy_report_{date_tag}.json')\n    latest_report = load_json(QUANT_REPORT_DIR / 'today_stock_strategy_report_latest.json')\n    report = latest_report\n    if dated_report and latest_report:\n        dated_ts = parse_dt(dated_report.get('generated_at'))\n        latest_ts = parse_dt(latest_report.get('generated_at'))\n        if dated_ts > latest_ts:\n            report = dated_report\n    elif dated_report:\n        report = dated_report\n    tester = load_json(REPORT_DIR / 'tester_scheduled_guard_latest.json')","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1776066260232}}
