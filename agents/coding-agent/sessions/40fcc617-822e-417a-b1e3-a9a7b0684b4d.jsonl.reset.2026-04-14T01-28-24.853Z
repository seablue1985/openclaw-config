_key\": \"API 密钥无效\", \"login.error.connect_failed\": \"无法连接到服务器\", \"login.error.min_length\": \"API 密钥至少需要 4 个字符\", \"login.error.no_whitespace\": \"API 密钥不能包含空白字符\", \"login.error.mismatch\": \"两次输入的 API 密钥不一致\", \"login.error.setup_failed\": \"API 密钥设置失败\", \"dashboard.title\": \"控制台 - oMLX 管理后台\", \"navbar.brand\": \"oMLX\", \"navbar.admin\": \"管理\", \"navbar.tab.status\": \"仪表盘\", \"navbar.tab.models\": \"模型\", \"navbar.tab.settings\": \"设置\", \"navbar.tab.logs\": \"日志\", \"navbar.tab.bench\": \"基准\", \"navbar.tab.chat\": \"聊天\", \"navbar.dropdown.manager\": \"管理器\", \"navbar.dropdown.downloader\": \"下载器\", \"navbar.dropdown.quantizer\": \"oQ量化\", \"navbar.dropdown.uploader\": \"oQ Uploader\", \"navbar.dropdown.global_settings\": \"全局设置\", \"navbar.dropdown.model_settings\": \"模型设置\", \"navbar.theme.auto\": \"自动\", \"navbar.theme.dark_mode\": \"深色模式\", \"navbar.theme.light_mode\": \"浅色模式\", \"navbar.logout\": \"退出登录\", \"navbar.update_available\": \"有可用更新: v{version}\", \"navbar.go_to_github\": \"前往GitHub\", \"status.section_label\": \"仪表盘\", \"status.heading\": \"服务统计\", \"status.clear\": \"清除\", \"status.clear_tooltip\": \"清除会话指标\", \"status.clear_confirm\": \"确定要清除吗？\", \"status.clear_yes\": \"确定\", \"status.clear_cancel\": \"取消\", \"status.scope_session\": \"会话\", \"status.scope_alltime\": \"累计\", \"status.clear_alltime\": \"清除\", \"status.clear_alltime_tooltip\": \"清除累计指标\", \"status.clear_ssd_cache_tooltip\": \"删除所有SSD缓存\", \"status.clear_ssd_cache_confirm\": \"确定删除所有SSD缓存吗？\", \"status.filter_all_models\": \"所有模型\", \"status.stat.total_tokens\": \"预填充 Token 总数\", \"status.stat.cached_tokens\": \"缓存 Token 数\", \"status.stat.cache_efficiency\": \"缓存效率\", \"status.speed.section_label\": \"平均速度\", \"status.speed.prompt_processing\": \"提示词处理\", \"status.speed.prompt_processing_note\": \"（不含缓存）\", \"status.speed.token_generation\": \"Token 生成\", \"status.active_models.section_label\": \"活跃模型\", \"status.active_models.no_models\": \"未加载模型\", \"status.active_mo