{"type":"message","id":"fe59def4","parentId":"72cc1fbb","timestamp":"2026-04-13T03:13:14.558Z","message":{"role":"toolResult","toolCallId":"call_function_uksrfatxl7m4_1","toolName":"read","content":[{"type":"text","text":"def _load_provider_config(provider: str) -> dict[str, str]:\n    if provider == \"deepseek\":\n        return {\n            \"api_key\": _get_config_value(\"DEEPSEEK_API_KEY\", \"\"),\n            \"base_url\": _get_config_value(\n                \"DEEPSEEK_BASE_URL\", \"https://api.deepseek.com\"\n            ),\n            \"key_name\": \"DEEPSEEK_API_KEY\",\n        }\n    if provider == \"openai\":\n        return {\n            \"api_key\": _get_config_value(\"OPENAI_API_KEY\", \"\"),\n            \"base_url\": _get_config_value(\"OPENAI_BASE_URL\", \"https://api.openai.com/v1\"),\n            \"key_name\": \"OPENAI_API_KEY\",\n        }\n    return {\n        \"api_key\": _get_config_value(\"GEMINI_API_KEY\", \"\"),\n        \"base_url\": _get_config_value(\n            \"GEMINI_BASE_URL\", \"https://generativelanguage.googleapis.com\"\n        ),\n        \"key_name\": \"GEMINI_API_KEY\",\n    }\n\n\ndef _get_config_value(key: str, default: str = \"\") -> str:\n    try:\n        llm_config = importlib.import_module(\"services.llm_config\")\n    except ModuleNotFoundError:\n        return str(os.getenv(key, default) or default)\n    return str(llm_config.get_config_value(key, default) or default)\n\n\ndef _mask_secret(value: str) -> str:\n    try:\n        llm_config = importlib.import_module(\"services.llm_config\")\n    except ModuleNotFoundError:\n        return \"\" if not value else \"*\" * len(value)\n    return llm_config.mask_secret(value)\n\n\n\n[113 more lines in file. Use offset=578 to continue.]"}],"isError":false,"timestamp":1776049994551}}
