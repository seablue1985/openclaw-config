{"type":"message","id":"4758081a","parentId":"6617941a","timestamp":"2026-04-13T03:07:35.508Z","message":{"role":"toolResult","toolCallId":"call_function_o4k7jtnc23qg_1","toolName":"read","content":[{"type":"text","text":"                )\n                if \"date\" in df.columns:\n                    df[\"date\"] = pd.to_datetime(df[\"date\"])\n                print(f\"[iFinD] ✅ 成功获取 {len(df)} 条数据\")\n                return df\n        except Exception as e:\n            print(f\"[iFinD] ❌ 获取失败: {e}\")\n\n        # iFinD失败，尝试tushare\n        if self.tushare_available:\n            try:\n                print(f\"[Tushare] 正在获取 {symbol} 的历史数据（备用数据源）...\")\n\n                # 转换股票代码格式（添加市场后缀）\n                ts_code = self._convert_to_ts_code(symbol)\n\n                # 转换复权类型\n                adj_dict = {\"qfq\": \"qfq\", \"hfq\": \"hfq\", \"\": None}\n                adj = adj_dict.get(adjust, \"qfq\")\n\n                # 格式化日期\n                start = (\n                    f\"{start_date[:4]}-{start_date[4:6]}-{start_date[6:]}\"\n                    if start_date\n                    else None\n                )\n                end = (\n                    f\"{end_date[:4]}-{end_date[4:6]}-{end_date[6:]}\"\n                    if end_date\n                    else None\n\n[293 more lines in file. Use offset=185 to continue.]"}],"isError":false,"timestamp":1776049655501}}
