{"type":"message","id":"4c2661b7","parentId":"c42185ac","timestamp":"2026-04-13T09:20:00.020Z","message":{"role":"toolResult","toolCallId":"call_function_fxqjgrft9wkf_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env bash\nset -euo pipefail\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\nWORKSPACE_ROOT=\"$(cd \"$ROOT/../..\" && pwd)\"\nPYRUN=\"$ROOT/scripts/cron_python.sh\"\nDATE_TAG=\"${1:-$(date +%Y%m%d)}\"\nTICKETS_FILE=\"${2:-}\"\nRUN_MODE=\"${3:-${PAPER_PROFILE_RUN_MODE:-eod}}\"\nRUN_HEAVY_REPORTS=\"${PAPER_PROFILE_RUN_HEAVY_REPORTS:-}\"\n\ncd \"$ROOT\"\n\nexport LITELLM_LOCAL_MODEL_COST_MAP=true\nexport PAPER_PROFILE_RUN_MODE=\"$RUN_MODE\"\n\"$PYRUN\" --runtime-only\n\nif [[ -z \"$RUN_HEAVY_REPORTS\" ]]; then\n  if [[ \"$RUN_MODE\" == \"morning_open\" ]]; then\n    RUN_HEAVY_REPORTS=\"0\"\n  else\n    RUN_HEAVY_REPORTS=\"1\"\n  fi\nfi\n\n\"$PYRUN\" scripts/run_intraday_risk_recheck.py --date \"$DATE_TAG\"\n\nrun_profile() {\n  local config_file=\"$1\"\n  local orders_file\n  local prep_cmd=(\"$PYRUN\" scripts/prepare_paper_orders_v1.py --config \"$config_file\" --date \"$DATE_TAG\")\n  if [[ -n \"$TICKETS_FILE\" ]]; then\n    prep_cmd+=(--tickets \"$TICKETS_FILE\")\n  fi\n\n  \"${prep_cmd[@]}\"\n\n  orders_file=\"$(\"$PYRUN\" --no-runtime-log - \"$config_file\" \"$DATE_TAG\" <<'PY'\nimport json\nimport sys\nfrom pathlib import Path\n\nproject_root = Path.cwd()\nsys.path.insert(0, str(project_root / \"scripts\"))\nfrom paper_profile_utils import profile_slug_from_config, report_path\n\ncfg = json.loads(Path(sys.argv[1]).read_text(encoding=\"utf-8\"))\ndate_tag = sys.argv[2]\nslug = profile_slug_from_config(cfg)\nprint(report_path(project_root / \"research\" / \"reports\", \"orders\", profile_slug=slug, date_tag=date_tag))\nPY\n)\"\n\n  \"$PYRUN\" scripts/run_paper_trading_sim_v1.py --trading-mode paper --config \"$config_file\" --date \"$DATE_TAG\" --orders \"$orders_file\"\n  \"$PYRUN\" scripts/generate_paper_trading_dashboard.py --config \"$config_file\"\n}\n\nrun_profile \"config/paper_trading_defensive_v1.json\"\nrun_profile \"config/paper_trading_balanced_v1.json\"\nrun_profile \"config/paper_trading_aggressive_v1.json\"\nrun_profile \"config/paper_trading_v4_3_v1.json\"\n\nfor PROBE_GUARD_CONFIG in \\\n  \"$ROOT/config/strategy_probe_guard_defensive_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_balanced_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_aggressive_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_v4_3_v1.json\"\ndo\n  if [[ -f \"$PROBE_GUARD_CONFIG\" ]]; then\n    if ! \"$PYRUN\" scripts/run_strategy_probe_guard.py --config \"$PROBE_GUARD_CONFIG\" --date \"$DATE_TAG\" --push; then\n      echo \"[ERROR] probe guard failed config=${PROBE_GUARD_CONFIG} date=${DATE_TAG}\" >&2\n      exit 1\n    fi\n    if ! \"$PYRUN\" scripts/generate_strategy_probe_daily_reconciliation.py --config \"$PROBE_GUARD_CONFIG\" --date \"$DATE_TAG\"; then\n      echo \"[ERROR] daily reconciliation failed config=${PROBE_GUARD_CONFIG} date=${DATE_TAG}\" >&2\n      exit 1\n    fi\n  fi\ndone"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"#!/usr/bin/env bash\nset -euo pipefail\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\nWORKSPACE_ROOT=\"$(cd \"$ROOT/../..\" && pwd)\"\nPYRUN=\"$ROOT/scripts/cron_python.sh\"\nDATE_TAG=\"${1:-$(date +%Y%m%d)}\"\nTICKETS_FILE=\"${2:-}\"\nRUN_MODE=\"${3:-${PAPER_PROFILE_RUN_MODE:-eod}}\"\nRUN_HEAVY_REPORTS=\"${PAPER_PROFILE_RUN_HEAVY_REPORTS:-}\"\n\ncd \"$ROOT\"\n\nexport LITELLM_LOCAL_MODEL_COST_MAP=true\nexport PAPER_PROFILE_RUN_MODE=\"$RUN_MODE\"\n\"$PYRUN\" --runtime-only\n\nif [[ -z \"$RUN_HEAVY_REPORTS\" ]]; then\n  if [[ \"$RUN_MODE\" == \"morning_open\" ]]; then\n    RUN_HEAVY_REPORTS=\"0\"\n  else\n    RUN_HEAVY_REPORTS=\"1\"\n  fi\nfi\n\n\"$PYRUN\" scripts/run_intraday_risk_recheck.py --date \"$DATE_TAG\"\n\nrun_profile() {\n  local config_file=\"$1\"\n  local orders_file\n  local prep_cmd=(\"$PYRUN\" scripts/prepare_paper_orders_v1.py --config \"$config_file\" --date \"$DATE_TAG\")\n  if [[ -n \"$TICKETS_FILE\" ]]; then\n    prep_cmd+=(--tickets \"$TICKETS_FILE\")\n  fi\n\n  \"${prep_cmd[@]}\"\n\n  orders_file=\"$(\"$PYRUN\" --no-runtime-log - \"$config_file\" \"$DATE_TAG\" <<'PY'\nimport json\nimport sys\nfrom pathlib import Path\n\nproject_root = Path.cwd()\nsys.path.insert(0, str(project_root / \"scripts\"))\nfrom paper_profile_utils import profile_slug_from_config, report_path\n\ncfg = json.loads(Path(sys.argv[1]).read_text(encoding=\"utf-8\"))\ndate_tag = sys.argv[2]\nslug = profile_slug_from_config(cfg)\nprint(report_path(project_root / \"research\" / \"reports\", \"orders\", profile_slug=slug, date_tag=date_tag))\nPY\n)\"\n\n  \"$PYRUN\" scripts/run_paper_trading_sim_v1.py --trading-mode paper --config \"$config_file\" --date \"$DATE_TAG\" --orders \"$orders_file\"\n  \"$PYRUN\" scripts/generate_paper_trading_dashboard.py --config \"$config_file\"\n}\n\nrun_profile \"config/paper_trading_defensive_v1.json\"\nrun_profile \"config/paper_trading_balanced_v1.json\"\nrun_profile \"config/paper_trading_aggressive_v1.json\"\nrun_profile \"config/paper_trading_v4_3_v1.json\"\n\nfor PROBE_GUARD_CONFIG in \\\n  \"$ROOT/config/strategy_probe_guard_defensive_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_balanced_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_aggressive_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_v4_3_v1.json\"\ndo\n  if [[ -f \"$PROBE_GUARD_CONFIG\" ]]; then\n    if ! \"$PYRUN\" scripts/run_strategy_probe_guard.py --config \"$PROBE_GUARD_CONFIG\" --date \"$DATE_TAG\" --push; then\n      echo \"[ERROR] probe guard failed config=${PROBE_GUARD_CONFIG} date=${DATE_TAG}\" >&2\n      exit 1\n    fi\n    if ! \"$PYRUN\" scripts/generate_strategy_probe_daily_reconciliation.py --config \"$PROBE_GUARD_CONFIG\" --date \"$DATE_TAG\"; then\n      echo \"[ERROR] daily reconciliation failed config=${PROBE_GUARD_CONFIG} date=${DATE_TAG}\" >&2\n      exit 1\n    fi\n  fi