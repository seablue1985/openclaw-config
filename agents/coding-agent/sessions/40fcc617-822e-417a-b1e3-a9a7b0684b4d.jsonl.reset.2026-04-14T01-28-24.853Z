{"type":"message","id":"06a365c7","parentId":"20b5ae66","timestamp":"2026-04-13T03:03:19.493Z","message":{"role":"toolResult","toolCallId":"call_function_5uhe7fu0elw5_1","toolName":"read","content":[{"type":"text","text":"from datetime import datetime\nimport os\nimport time\nfrom typing import Any\n\nimport httpx\n\n\ndef _to_iso(ts: float | None) -> str | None:\n    if ts is None:\n        return None\n    return datetime.fromtimestamp(ts).isoformat()\n\n\ndef _normalize_base_url(base_url: str) -> str:\n    base = str(base_url or \"https://api.deepseek.com\").rstrip(\"/\")\n    if base.endswith(\"/v1\"):\n        return base\n    return f\"{base}/v1\"\n\n\ndef _bool_env(name: str, default: bool) -> bool:\n    raw = os.getenv(name)\n    if raw in {None, \"\"}:\n        return bool(default)\n    return str(raw).strip().lower() in {\"1\", \"true\", \"yes\", \"on\"}\n\n\ndef _build_text(body: dict[str, Any], include_reasoning: bool) -> tuple[str, dict[str, Any], Any]:\n    choices = body.get(\"choices\") if isinstance(body, dict) else []\n    message = (choices[0].get(\"message\") if choices and isinstance(choices[0], dict) else {}) or {}\n    content = str(message.get(\"content\") or \"\").strip()\n    reasoning_content = str(message.get(\"reasoning_content\") or \"\").strip()\n    if not content and reasoning_content:\n        text = reasoning_content\n    elif include_reasoning and reasoning_content:\n        text = f\"【推理过程】\\n{reasoning_content}\\n\\n{content}\".strip()\n    else:\n        text = content\n    usage = body.get(\"usage\") if isinstance(body, dict) else {}\n\n[220 more lines in file. Use offset=41 to continue.]"}],"isError":false,"timestamp":1776049399485}}
