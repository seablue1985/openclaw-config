{"type":"message","id":"6882f0c4","parentId":"f9202937","timestamp":"2026-04-13T09:19:45.844Z","message":{"role":"toolResult","toolCallId":"call_function_6n8coktbhcuh_1","toolName":"exec","content":[{"type":"text","text":"--date \"$DATE_TAG\" \\\n    --available-cash \"$available_cash\" \\\n    --account-nav \"$account_nav\" \\\n    $force_flag\n}\n\nensure_same_day_live_system() {\n  if [[ \"$DATE_TAG\" != \"$TODAY_TAG\" ]]; then\n    return 0\n  fi\n  if [[ \"${FORCE_REFRESH:-0}\" == \"1\" ]]; then\n    echo \"[INFO] force rebuilding same-day live system date=${DATE_TAG}\"\n  else\n    echo \"[INFO] missing live_system, materializing same-day live system date=${DATE_TAG}\"\n  fi\n  \"$PYRUN\" scripts/run_live_system_v1.py\n}\n\nrun_once() {\n  if [[ -n \"$TICKETS_FILE\" ]]; then\n    bash scripts/run_paper_trading_profiles_v1.sh \"$DATE_TAG\" \"$TICKETS_FILE\" \"$RUN_MODE\"\n  else\n    bash scripts/run_paper_trading_profiles_v1.sh \"$DATE_TAG\" \"\" \"$RUN_MODE\"\n  fi\n}\n\n# Paper trading uses its own per-panel halt logic (generate_per_panel_runtime_risk_t05.py).\n# Do NOT block paper profiles based on live_trading's halt state, which uses\n# strategy_max_drawdown_pct (OOS historical max, not current risk) and would\n# incorrectly prevent paper from operating. The per-panel risk check is sufficient.\ncheck_runtime_halt_before_profiles && echo \"[WARN] runtime halt active, paper profiles will use per-panel risk gates only\" || true\n\nif [[ \"${FORCE_REFRESH:-0}\" == \"1\" || ! -f \"$LIVE_SYSTEM_FILE\" ]]; then\n  ensure_same_day_live_system\nfi\n\nif [[ ! -f \"$LIVE_SYSTEM_FILE\" ]]; then\n  echo \"[ERROR] 缺少当日 live_system: $LIVE_SYSTEM_FILE\"\n  exit 2\nfi\n\nif [[ -z \"$TICKETS_FILE\" && ( ! -f \"$MERGED_FILE\" || \"${FORCE_REFRESH:-0}\" == \"1\" ) ]]; then\n  ensure_same_day_merged_signals\nfi\n\nif [[ -z \"$TICKETS_FILE\" && ! -f \"$MERGED_FILE\" ]]; then"}],"details":{"status":"completed","exitCode":0,"durationMs":8,"aggregated":"--date \"$DATE_TAG\" \\\n 