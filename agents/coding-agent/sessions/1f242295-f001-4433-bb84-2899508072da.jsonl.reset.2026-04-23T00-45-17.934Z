urrent_price) * 100:.2f}%')\n\""}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":335,"output":849,"cacheRead":49856,"cacheWrite":0,"totalTokens":51040,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776735792183,"responseId":"84e9a164-a6cc-4f12-a811-49f9c11f4458"}}
