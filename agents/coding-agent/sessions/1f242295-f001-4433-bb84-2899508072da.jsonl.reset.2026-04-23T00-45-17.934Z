{"type":"message","id":"ebb24de3","parentId":"ae04ec60","timestamp":"2026-04-21T16:19:06.123Z","message":{"role":"toolResult","toolCallId":"call_00_3IDZPreJAOy7xY0nyVIGsOxk","toolName":"read","content":[{"type":"text","text":"﻿symbol,asset_type,name,quantity,cost_price\n002119.SZ,stock,康强电子,21700,22.8849\n002272.SZ,stock,川润股份,33000,19.6384\n002471.SZ,stock,中超控股,17500,9.1833\n300063.SZ,stock,天龙集团,53700,12.0632\n300265.SZ,stock,通光线缆,7900,18.9067\n300503.SZ,stock,昊志机电,2100,52.076\n301018.SZ,stock,申菱环境,2800,102.5807\n603626.SH,stock,科森科技,6400,23.3206\n"}],"isError":false,"timestamp":1776788346113}}
{"type":"message","id":"d0fd3b60","parentId":"ebb24de3","timestamp":"2026-04-21T16:21:31.412Z","message":{"role":"assistant","content":[{"type":"text","text":"现在让我获取这些股票的实时价格来计算收益："},{"type":"toolCall","id":"call_00_HoC1z8JEh38xNXBz9bu81T2V","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/coding-agent/calculate_simulation_returns.py","content":"#!/usr/bin/env python3\n\"\"\"\n计算所有模拟盘的收益情况\n\"\"\"\n\nimport json\nimport pandas as pd\nfrom pathlib import Path\nfrom datetime import datetime\nimport urllib.request\nimport ssl\n\nPROJECT_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system\")\n\ndef get_realtime_price(ts_code):\n    \"\"\"获取个股实时价格\"\"\"\n    try:\n        if ts_code.endswith('.SH'):\n            market = 'sh' + ts_code.replace('.SH', '')\n        else:\n            market = 'sz' + ts_code.replace('.SZ', '')\n        \n        url = f'http://qt.gtimg.cn/q={market}'\n        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})\n        \n        ctx = ssl.create_default_context()\n        ctx.check_hostname = False\n        ctx.verify_mode = ssl.CERT_NONE\n        \n        with urllib.request.urlopen(req, timeout=5, context=ctx) as r:\n            content = r.read().decode('gbk', errors='replace')\n        \n        parts = content.split('~')\n        if len(parts) > 3:\n            price = float(parts[3])\n            return price\n    except Exception as e:\n        print(f\"获取 {ts_code} 价格失败: {e}\")\n    return None\n\ndef calculate_aggressive_18_returns():\n    \"\"\"计算Aggressive 18%策略收益\"\"\"\n    print(\"📊 Aggressive 18% 策略模拟盘\")\n    print(\"=\" * 60)\n    \n    holdings_file = PROJECT_ROOT / \"config\" / \"paper_aggressive_portfolio_positions.csv\"\n    \n    if not holdings_file.exists():\n        print(\"持仓文件不存在\")\n        return\n    \n    df = pd.read_csv(holdings_file)\n    \n    total_cost = 0\n    total_value = 0\n    holdings = []\n    \n    for _, row in df.iterrows():\n        symbol = row['symbol']\n        quantity = row['quantity']\n        cost_price = row['cost_price']\n        \n        current_price = get_realtime_price(symbol)\n        if current_price is None:\n            current_price = cost_price  # 如果获取失败，使用成本价\n        \n        cost_value = quantity * cost_price\n        current_value = quantity * current_price\n        pnl = current_value - cost_value\n        pnl_pct = (pnl / cost_value * 100) if cost_value > 0 else 0\n        \n        total_cost += cost_value\n        total_value += current_value\n        \n        holdings.append({\n            'symbol': symbol,\n            'name': row['name'],\n            'quantity': quantity,\n            'cost_price': cost_price,\n            'current_price': current_price,\n            'cost_value': cost_value,\n            'current_value': current_value,\n            'pnl': pnl,\n            'pnl_pct': pnl_pct\n        })\n    \n    total_pnl = total_value - total_cost\n    total_pnl_pct = (total_pnl / total_cost * 100) if total_cost > 0 else 0\n    \n    print(f\"初始资金: 1,000,000元\")\n    print(f\"持仓成本: {total_cost:,.2f}元\")\n    print(f\"当前市值: {total_value:,.2f}元\")\n    print(f\"总收益: {total_pnl:+,.2f}元 ({total_pnl_pct:+.2f}%)\")\n    print(f\"净值: {1 + total_pnl_pct/100:.4f}\")\n    print()\n    \n    # 显示持仓详情\n    print(\"持仓明细:\")\n    for h in holdings:\n        print(f\"  {h['symbol']} {h['name']}: {h['quantity']}股\")\n        print(f\"    成本: {h['cost_price']:.2f}元 | 现价: {h['current_price']:.2f}元\")\n        print(f\"    收益: {h['pnl']:+,.2f}元 ({h['pnl_pct']:+.2f}%)\")\n        print()\n    \n    return {\n        'strategy': 'Aggressive 18%',\n        'initial_capital': 1000000,\n        'total_cost': total_cost,\n        'total_value': total_value,\n        'total_pnl': total_pnl,\n        'total_pnl_pct': total_pnl_pct,\n        'nav': 1 + total_pnl_pct/100,\n        'holdings_count': len(holdings)\n    }\n\ndef calculate_breadth_aggressive_returns():\n    \"\"\"计算进取宽度策略模拟盘收益\"\"\"\n    print(\"📊 进取宽度策略模拟盘\")\n    print(\"=\" * 60)\n    \n    # 读取最新状态文件\n    state_file = PROJECT_ROOT / \"paper_breadth_aggressive\" / \"paper_state_20260421.json\"\n    \n    if not state_file.exists():\n        print(\"状态文件不存在\")\n        return\n    \n    with open(state_file, 'r', encoding='utf-8') as f:\n        data = json.load(f)\n    \n    holdings = data.get('holdings', {})\n    cash = data.get('cash', 0)\n    \n    total_cost = 0\n    total_value = 0\n    holding_details = []\n    \n    for symbol, holding in holdings.items():\n        shares = holding.get('shares', 0)\n        avg_price = holding.get('avg_price', 0)\n        current_price = holding.get('current_price', avg_price)\n        \n        cost_value = shares * avg_price\n        current_value = shares * current_price\n        pnl = current_value - cost_value\n        pnl_pct = (pnl / cost_value * 100) if cost_value > 0 else 0\n        \n        total_cost += cost_value\n        total_value += current_value\n        \n        # 获取股票名称\n        name = holding.get('name', '')\n        if not name:\n            # 尝试从其他文件获取名称\n            name = symbol\n        \n        holding_details.append({\n            'symbol': symbol,\n            'name': name,\n            'shares': shares,\n            'avg_price': avg_price,\n            'current_price': current_price,\n            'cost_value': cost_value,\n            'current_value': current_value,\n            'pnl': pnl,\n            'pnl_pct': pnl_pct\n        })\n    \n    total_assets = total_value + cash\n    initial_capital = 1000000  # 假设初始资金100万\n    total_pnl = total_assets - initial_capital\n    total_pnl_pct = (total_pnl / initial_capital * 100)\n    \n    print(f\"初始资金: {initial_capital:,.0f}元\")\n    print(f\"持仓成本: {total_cost:,.2f}元\")\n    print(f\"持仓市值: {total_value:,.2f}元\")\n    print(f\"现金: {cash:,.2f}元\")\n    print(f\"总资产: {total_assets:,.2f}元\")\n    print(f\"总收益: {total_pnl:+,.2f}元 ({total_pnl_pct:+.2f}%)\")\n    print(f\"净值: {total_assets/initial_capital:.4f}\")\n    print()\n    \n    # 显示持仓详情\n    print(f\"持仓明细 ({len(holding_details)}只):\")\n    for h in holding_details[:5]:  # 只显示前5只\n        print(f\"  {h['symbol']}: {h['shares']}股\")\n        print(f\"    成本: {h['avg_price']:.2f}元 | 现价: {h['current_price']:.2f}元\")\n        print(f\"    收益: {h['pnl']:+,.2f}元 ({h['pnl_pct']:+.2f}%)\")\n        print()\n    \n    if len(holding_details) > 5:\n        print(f\"  ... 还有 {len(holding_details)-5} 只股票\")\n    \n    return {\n        'strategy': '进取宽度策略',\n        'initial_capital': initial_capital,\n        'total_cost': total_cost,\n        'total_value': total_value,\n        'cash': cash,\n        'total_assets': total_assets,\n        'total_pnl': total_pnl,\n        'total_pnl_pct': total_pnl_pct,\n        'nav': total_assets/initial_capital,\n        'holdings_count': len(holding_details)\n    }\n\ndef calculate_breadth_strict_oos_returns():\n    \"\"\"计算严格样本外宽度策略模拟盘收益\"\"\"\n    print(\"📊 严格样本外宽度策略模拟盘\")\n    print(\"=\" * 60)\n    \n    # 读取最新状态文件\n    state_file = PROJECT_ROOT / \"paper_breadth_strict_oos\" / \"paper_state_20260416.json\"\n    \n    if not state_file.exists():\n        print(\"状态文件不存在\")\n        return\n    \n    with open(state_file, 'r', encoding='utf-8') as f:\n        data = json.load(f)\n    \n    holdings = data.get('holdings', {})\n    cash = data.get('cash', 0)\n    \n    total_cost = 0\n    total_value = 0\n    holding_details = []\n    \n    for symbol, holding in holdings.items():\n        shares = holding.get('shares', 0)\n        avg_price = holding.get('avg_price', 0)\n        current_price = holding.get('current_price', avg_price)\n        \n        cost_value = shares * avg_price\n        current_value = shares * current_price\n        pnl = current_value - cost_value\n        pnl_pct = (pnl / cost_value * 100) if cost_value > 0 else 0\n        \n        total_cost += cost_value\n        total_value += current_value\n        \n        holding_details.append({\n            'symbol': symbol,\n            'shares': shares,\n            'avg_price': avg_price,\n            'current_price': current_price,\n            'cost_value': cost_value,\n            'current_value': current_value,\n            'pnl': pnl,\n            'pnl_pct': pnl_pct\n        })\n    \n    total_assets = total_value + cash\n    initial_capital = 1000000  # 假设初始资金100万\n    total_pnl = total_assets - initial_capital\n    total_pnl_pct = (total_pnl / initial_capital * 100)\n    \n    print(f\"初始资金: {initial_capital:,.0f}元\")\n    print(f\"持仓成本: {total_cost:,.2f}元\")\n    print(f\"持仓市值: {total_value:,.2f}元\")\n    print(f\"现金: {cash:,.2f}元\")\n    print(f\"总资产: {total_assets:,.2f}元\")\n    print(f\"总收益: {total_pnl:+,.2f}元 ({total_pnl_pct:+.2f}%)\")\n    print(f\"净值: {total_assets/initial_capital:.4f}\")\n    print()\n    \n    print(f\"持仓数量: {len(holding_details)}只\")\n    \n    return {\n        'strategy': '严格样本外宽度策略',\n        'initial_capital': initial_capital,\n        'total_cost': total_cost,\n        'total_value': total_value,\n        'cash': cash,\n        'total_assets': total_assets,\n        'total_pnl': total_pnl,\n        'total_pnl_pct': total_pnl_pct,\n        'nav': total_assets/initial_capital,\n        'holdings_count': len(holding_details)\n    }\n\ndef main():\n    print(\"🎯 所有模拟盘收益情况报告\")\n    print(\"=\" * 60)\n    print(f\"报告时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n    print()\n    \n    all_results = []\n    \n    # 1. Aggressive 18% 策略\n    result1 = calculate_aggressive_18_returns()\n    if result1:\n        all_results.append(result1)\n    \n    print(\"\\n\" + \"=\" * 60 + \"\\n\")\n    \n    # 2. 进取宽度策略\n    result2 = calculate_breadth_aggressive_returns()\n    if result2:\n        all_results.append(result2)\n    \n    print(\"\\n\" + \"=\" * 60 + \"\\n\")\n    \n    # 3. 严格样本外宽度策略\n    result3 = calculate_breadth_strict_oos_returns()\n    if result3:\n        all_results.append(result3)\n    \n    # 汇总报告\n    print(\"\\n\" + \"=\" * 60)\n    print(\"📈 模拟盘收益汇总\")\n    print(\"=\" * 60)\n    \n    if all_results:\n        print(f\"{'策略名称':<20} {'净值':<10} {'收益%':<10} {'持仓数量':<10} {'总资产':<15}\")\n        print(\"-\" * 65)\n        \n        for result in all_results:\n            strategy = result['strategy']\n            nav = result['nav']\n            pnl_pct = result['total_pnl_pct']\n            holdings = result['holdings_count']\n            total_assets = result.get('total_assets', result.get('total_value', 0))\n            \n            # 判断表现\n            if pnl_pct > 5:\n                performance = \"🔥 优秀\"\n            elif pnl_pct > 0:\n                performance = \"✅ 盈利\"\n            else:\n                performance = \"⚠️ 亏损\"\n            \n            print(f\"{strategy:<20} {nav:<10.4f} {pnl_pct:<+10.2f}% {holdings:<10} {total_assets:<15,.0f}元 {performance}\")\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"📊 关键指标分析\")\n    print(\"=\" * 60)\n    \n    if all_results:\n        # 计算平均收益\n        avg_pnl_pct = sum(r['total_pnl_pct'] for r in all_results) / len(all_results)\n        \n        # 找出最佳和最差表现\n        best = max(all_results, key=lambda x: x['total_pnl_pct'])\n        worst = min(all_results, key=lambda x: x['total_pnl_pct'])\n        \n        print(f\"📈 平均收益: {avg_pnl_pct:+.2f}%\")\n        print(f\"🏆 最佳表现: {best['strategy']} ({best['total_pnl_pct']:+.2f}%)\")\n        print(f\"📉 最差表现: {worst['strategy']} ({worst['total_pnl_pct']:+.2f}%)\")\n        print(f\"📊 总持仓股票数: {sum(r['holdings_count'] for r in all_results)}只\")\n        \n        # 计算总资产\n        total_assets_all = sum(r.get('total_assets', r.get('total_value', 0)) for r in all_results)\n        print(f\"💰 模拟盘总资产: {total_assets_all:,.0f}元\")\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"📋 注意事项\")\n    print(\"=\" * 60)\n    print(\"1. 当前为非交易时段，部分价格可能为昨日收盘价\")\n    print(\"2. 进取宽度策略信号已过期（预测文件2026-04-16）\")\n    print(\"3. Aggressive 18%策略检测到6只卖出信号，待明天自动执行\")\n    print(\"4. 严格样本外宽度策略数据更新至2026-04-16\")\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":195,"output":3512,"cacheRead":81536,"cacheWrite":0,"totalTokens":85243,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776788346124,"responseId":"884be068-4055-4b02-b93b-e85033e638d8"}}
