)\nprint(f'      前5大持仓占比: {top5_pct:.2%}')\nprint()\n\nprint(f'   2. 深度亏损股票:')\ndeep_loss = df_clean[df_clean['持有盈亏率'] < -0.30]\nif len(deep_loss) > 0:\n    for _, stock in deep_loss.iterrows():\n        print(f'      ❌ {stock[\\\"名称\\\"]}: 亏损{abs(stock[\\\"持有盈亏率\\\"]):.2%}, 持有{stock[\\\"持仓天数\\\"]:.0f}天')\nprint()\n\nprint(f'   3. 盈利股票分析:')\nprofitable = df_clean[df_clean['持有盈亏'] > 0]\nif len(profitable) > 0:\n    print(f'      盈利股票: {len(profitable)}只 ({len(profitable)/len(df_clean)*100:.1f}%)')\n    for _, stock in profitable.sort_values('持有盈亏率', ascending=False).head(3).iterrows():\n        print(f'      ✅ {stock[\\\"名称\\\"]}: 盈利{stock[\\\"持有盈亏率\\\"]:.2%}, 仓位{stock[\\\"仓位占比_修正\\\"]:.2%}')\nprint()\n\n# 4. 德赛西威加仓策略\nif len(desay) > 0:\n    desay_row = desay.iloc[0]\n    desay_position_pct = desay_row['仓位占比_修正']\n    \n    print(f'💡 德赛西威加仓策略（基于719,028元真实持仓）:')\n    print()\n    \n    # 风控参数\n    max_single_position = 0.15  # 单股最大15%\n    max_desay_value = total_value_clean * max_single_position\n    current_desay_value = desay_row['持有金额']\n    available_for_desay = max(0, max_desay_value - current_desay_value)\n    \n    print(f'   风控框架:')\n    print(f'      - 投资组合总值: {total_value_clean:,.2f}元')\n    print(f'      - 单股最大仓位: {max_single_position:.0%}')\n    print(f'      - 德赛西威当前仓位: {desay_position_pct:.2%}')\n    print(f'      - 德赛西威最大允许市值: {max_desay_value:,.2f}元')\n    print(f'      - 可加仓金额上限: {available_for_desay:,.2f}元')\n    print()\n    \n    # 加仓方案\n    print(f'   加仓方案:')\n    \n    # 方案A：最小加仓（5%现有仓位）\n    add_pct_a = 0.05\n    add_amount_a = current_desay_value * add_pct_a\n    add_shares_a = add_amount_a / current_price\n    new_position_pct_a = (current_desay_value + add_amount_a) / total_value_clean\n    \n    print(f'      🅰️ 最小加仓（5%现有仓位）:')\n    print(f'          加仓金额: {add_amount_a:,.2f}元')\n    print(f'          加仓股数: {add_shares_a:.0f}股')\n    print(f'          加仓后仓位: {new_position_pct_a:.2%}')\n    print(f'          加仓后平均成本: {(current_desay_value + add_amount_a) / (shares + add_shares_a):.3f}元')\n    print(f'          回本需涨幅: {((cost_price - (current_desay_value + add_amount_a) / (shares + add_shares_a)) / ((current_desay_value + add_amount_a) / (shares + add_shares_a)) * 100):.2f}%')\n    print()\n    \n    # 方案B：适中加仓（10%现有仓位）\n    add_pct_b = 0.10\n    add_amount_b = current_desay_value * add_pct_b\n    add_shares_b = add_amount_b / current_price\n    new_position_pct_b = (current_desay_value + add_amount_b) / total_value_clean\n    \n    print(f'      🅱️ 适中加仓（10%现有仓位）:')\n    print(f'          加仓金额: {add_amount_b:,.2f}元')\n    print(f'          加仓股数: {add_shares_b:.0f}股')\n    print(f'          加仓后仓位: {new_position_pct_b:.2%}')\n    print(f'          加仓后平均成本: {(current_desay_value + add_amount_b) / (shares + add_shares_b):.3f}元')\n    print(f'          回本需涨幅: {((cost_price - (current_desay_value + add_amount_b) / (shares + add_shares_b)) / ((current_desay_value + add_amount_b) / (shares + add_shares_b)) * 100):.2f}%')\n    print()\n    \n    # 方案C：最大加仓（至15%上限）\n    add_amount_c = available_for_desay\n    add_shares_c = add_amount_c / current_price\n    new_position_pct_c = (current_desay_value + add_amount_c) / total_value_clean\n    \n    print(f'      🅲️ 上限加仓（至15%仓位）:')\n    print(f'          加仓金额: {add_amount_c:,.2f}元')\n    print(f'          加仓股数: {add_shares_c:.0f}股')\n    print(f'          加仓后仓位: {new_position_pct_c:.2%}')\n    print(f'          加仓后平均成本: {(current_desay_value + add_amount_c) / (shares + add_shares_c):.3f}元')\n    print(f'          回本需涨幅: {((cost_price - (current_desay_value + add_amount_c) / (shares + add_shares_c)) / ((current_desay_value + add_amount_c) / (shares + add_shares_c)) * 100):.2f}%')\n    print()\n    \n    # 价格建议\n    print(f'   加仓价格建议:')\n    print(f'      当前价: 105.81元')\n    print(f'      理想加仓区间: 102-104元（下跌1.7-3.6%）')\n    print(f'      分批加仓策略:')\n    print(f'          第一笔: 104元（加仓方案A的50%）')\n    print(f'          第二笔: 103元（加仓方案A的50%）')\n    print(f'          第三笔: 102元（如继续下跌，考虑方案B）')\n    print()\n    \n    # 风险控制\n    print(f'   ⚠️ 风险控制:')\n    print(f'      止损位: 99元（跌破近期低点101.03元约2%）')\n    print(f'      时间止损: 持有至4月28日一季报，如无起色考虑减仓')\n    print(f'      仓位控制: 德赛西威不超过总仓位15%')\n    print()\n    \n    # 我的建议\n    print(f'   💎 我的建议:')\n    print(f'      鉴于投资组合整体亏损-7.95%，且德赛西威已占14.60%仓位，')\n    print(f'      推荐采用【🅰️ 最小加仓方案】。')\n    print(f'      ')\n    print(f'      具体操作:')\n    print(f'      1. 等待价格跌至104元附近')\n    print(f'      2. 加仓50股（约5,240元）')\n    print(f'      3. 如继续跌至103元，再加仓50股')\n    print(f'      4. 总加仓不超过100股（约10,480元）')\n    print(f'      ')\n    print(f'      这样既能降低平均成本，又不会过度增加风险暴露。')\n\""}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":884,"output":2524,"cacheRead":72256,"cacheWrite":0,"totalTokens":75664,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776737891396,"responseId":"f88fd8af-ff72-4196-9fd5-5f2f86ee7217"}}
