{"type":"message","id":"c7f00c9f","parentId":"937decb8","timestamp":"2026-04-21T14:38:49.656Z","message":{"role":"toolResult","toolCallId":"call_00_npKqNKEfomhHnuIHjYaZ1OzN","toolName":"read","content":[{"type":"text","text":"\"\"\"\n订单执行模拟器 - 模拟涨跌停/流动性约束下的订单成交情况\n\n职责：\n1. 涨停日：买入订单无法成交\n2. 跌停日：卖出订单无法成交\n3. 部分成交：大单按成交率分批执行\n4. T+1 限制：当日买入无法当日卖出\n\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nfrom dataclasses import dataclass, field\nfrom typing import Optional\n\n\n@dataclass\nclass ExecutionResult:\n    \"\"\"订单执行结果\"\"\"\n    ts_code: str\n    side: str  # BUY / SELL\n    requested_qty: int\n    filled_qty: int          # 实际成交数量\n    fill_price: float         # 成交价（若无成交则为0）\n    rejected: bool = False\n    rejection_reason: str = \"\"\n    slippage_bps: float = 0.0  # 滑点（基点）\n\n    @property\n    def fill_rate(self) -> float:\n        \"\"\"成交率\"\"\"\n        if self.requested_qty <= 0:\n            return 0.0\n        return self.filled_qty / self.requested_qty\n\n\n@dataclass\nclass DailyMarketData:\n    \"\"\"单日市场数据\"\"\"\n    ts_code: str\n    trade_date: int\n    open: float\n    high: float\n    low: float\n    close: float\n    limit_up: float\n    limit_down: float\n    suspended: bool = False\n    adv20: float = 0.0  # 20日平均成交量\n\n[306 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1776782329639}}
