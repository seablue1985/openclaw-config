     feishu_log = os.path.join(log_dir, \"feishu_messages.log\")\n        with open(feishu_log, \"a\", encoding=\"utf-8\") as f:\n            timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n            f.write(f\"\\n{'='*60}\\n\")\n            f.write(f\"[{timestamp}] 飞书消息（未发送）\\n\")\n            f.write(f\"{'='*60}\\n\")\n            f.write(message)\n            f.write(f\"\\n{'='*60}\\n\\n\")\n        \n        print(f\"📝 消息已记录到: {feishu_log}\")\n        return True\n    except Exception as e:\n        print(f\"⚠️ 飞书推送异常: {str(e)[:200]}\")\n        return False''')\n            # 跳过原函数内容\n            skip = True\n        elif \"def send_feishu_message\" in line and \"def \" in line:\n            # 函数定义行，已经处理过\n            continue\n        elif line.strip().startswith(\"def \") and \"send_feishu_message\" not in line:\n            # 其他函数，正常添加\n            new_lines.append(line)\n        else:\n            new_lines.append(line)\n    \n    # 写入修复后的脚本\n    with open(signal_script, \"w\", encoding=\"utf-8\") as f:\n        f.write('\\n'.join(new_lines))\n    \n    print(f\"✅ 修复飞书消息函数: {signal_script}\")\n    return True\n\ndef create_complete_script():\n    \"\"\"创建完整执行脚本\"\"\"\n    print(\"🔧 创建完整执行脚本...\")\n    \n    wrapper_path = CODING_AGENT_ROOT / \"run_aggressive_complete.py\"\n    \n    wrapper_content = '''#!/usr/bin/env python3\n\"\"\"\n进取盘完整执行脚本\n1. 检测信号\n2. 推送通知  \n3. 执行交易\n\"\"\"\n\nimport os\nimport sys\nimport subprocess\nfrom pathlib import Path\nfrom datetime import datetime\n\nPROJECT_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system\")\nCODING_AGENT_ROOT = Path(\"/Users/ling/.openclaw/workspace/coding-agent\")\n\ndef main():\n    print(\"=\" * 80)\n    print(\"🚀 进取盘完整执行\")\n    print(\"=\" * 80)\n    \n    # 1. 运行信号检测\n    print(\"🔍 运行信号检测...\")\n    detection_script = CODING_AGENT_ROOT / \"run_aggressive_realtime_signal.py\"\n    \n    if detection_script.exists():\n        try:\n            result = subprocess.run(\n                [sys.executable, str(detection_script)],\n                capture_output=True,\n                text=True,\n                timeout=300\n            )\n            \n            print(\"检测输出:\")\n            print(result.stdout[-500:] if result.stdout else \"无输出\")\n            \n            if result.returncode != 0:\n                print(f\"⚠️ 检测脚本异常: {result.stderr[:200]}\")\n        except Exception as e:\n            print(f\"❌ 检测失败: {str(e)[:200]}\")\n    else:\n        print(f\"❌ 检测脚本不存在: {detection_script}\")\n    \n    # 2. 运行交易执行\n    print(\"\\n🚀 运行交易执行...\")\n    execution_script = PROJECT_ROOT / \"scripts\" / \"reconcile_live_execution_v1.py\"\n    \n    if execution_script.exists():\n        try:\n            today = datetime.now().strftime(\"%Y%m%d\")\n            result = subprocess.run(\n                [sys.executable, str(execution_script), \"--date\", today],\n                capture_output=True,\n                text=True,\n                timeout=300\n            )\n            \n            print(\"执行输出:\")\n            print(result.stdout[-500:] if result.stdout else \"无输出\")\n            \n            if result.returncode != 0:\n                print(f\"⚠️ 执行脚本异常: {result.stderr[:200]}\")\n        except Exception as e:\n            print(f\"❌ 执行失败: {str(e)[:200]}\")\n    else:\n        print(f\"❌ 执行脚本不存在: {execution_script}\")\n    \n    # 3. 记录日志\n    log_dir = CODING_AGENT_ROOT / \"logs\"\n    log_dir.mkdir(exist_ok=True)\n    \n    log_file = log_dir / \"aggressive_complete.log\"\n    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    \n    with open(log_file, \"a\", encoding=\"utf-8\") as f:\n        f.write(f\"\\n[{timestamp}] 完整执行完成\\n\")\n    \n    print(\"=\" * 80)\n    print(\"✅ 完整执行完成\")\n    print(\"=\" * 80)\n\nif __name__ == \"__main__\":\n    main()\n'''\n    \n    with open(wrapper_path, \"w\", encoding=\"utf-8\") as f:\n        f.write(wrapper_content)\n    \n    os.chm