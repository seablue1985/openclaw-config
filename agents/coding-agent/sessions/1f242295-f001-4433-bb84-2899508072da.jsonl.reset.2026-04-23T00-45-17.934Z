{"type":"message","id":"57f066e8","parentId":"dc0fe586","timestamp":"2026-04-21T14:38:09.218Z","message":{"role":"toolResult","toolCallId":"call_00_Pq81z19SPNKPPOaNNgsQhIR9","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nAggressive 18% 策略 - 实时买卖信号推送\n当检测到买卖操作时，立即推送飞书通知\n\"\"\"\nimport sys\nimport json\nimport subprocess\nfrom pathlib import Path\nfrom datetime import datetime\nimport urllib.request\nimport ssl\nimport time\n\nPROJECT_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system\")\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\n\n# 策略参数\nSTOP_LOSS_PCT = -5.0  # 止损线 -5%\nTRAILING_TAKE_PROFIT_PCT = -8.0  # 移动止盈回撤 -8%\nINITIAL_CAPITAL = 1000000.0\n\n# 飞书推送配置\nFEISHU_BOT_URL = \"\"  # 如果有自定义机器人URL可以填在这里\n\ndef send_feishu_message(message):\n    \"\"\"发送飞书消息 - 最终修复版\"\"\"\n    from datetime import datetime\n    import os\n    \n    try:\n        # 方法1：尝试直接导入（在OpenClaw交互环境中有效）\n        from openclaw.tools import message as msg_tool\n        result = msg_tool(action=\"send\", channel=\"feishu\", message=message)\n        print(f\"✅ 飞书消息发送成功\")\n        return True\n    except ImportError:\n        # 方法2：在cron环境中，记录到日志文件\n        print(\"⚠️ 无法导入message工具（可能在cron环境中），记录到日志文件\")\n        \n        # 确保日志目录存在\n        log_dir = \"/Users/ling/.openclaw/workspace/coding-agent/logs\"\n        os.makedirs(log_dir, exist_ok=True)\n        \n        # 记录到feishu消息日志\n        feishu_log = os.path.join(log_dir, \"feishu_messages.log\")\n        with open(feishu_log, \"a\", encoding=\"utf-8\") as f:\n            timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n            f.write(f\"\\n{'='*60}\\n\")\n            f.write(f\"[{timestamp}] 飞书消息（未发送）\\n\")\n            f.write(f\"{'='*60}\\n\")\n            f.write(message)\n            f.write(f\"\\n{'='*60}\\n\\n\")\n        \n        print(f\"📝 消息已记录到: {feishu_log}\")\n        print(f\"💡 建议：可以手动查看日志文件并复制内容到飞书\")\n        \n        # 同时记录到主日志\n        main_log = os.path.join(log_dir, \"aggressive_signal.log\")\n        with open(main_log, \"a\", encoding=\"utf-8\") as f:\n            f.write(f\"[{timestamp}] 飞书消息已记录到 {feishu_log}\\n\")\n        \n        return True  # 返回True表示至少记录了消息\n        \n    except Exception as e:\n        # 其他异常处理\n        error_msg = str(e)[:200]\n        print(f\"⚠️ 飞书推送异常: {error_msg}\")\n        \n        # 记录错误到日志\n        error_log = \"/Users/ling/.openclaw/workspace/coding-agent/logs/feishu_errors.log\"\n        with open(error_log, \"a\", encoding=\"utf-8\") as f:\n            f.write(f\"[{datetime.now()}] 错误: {error_msg}\\n\")\n        \n        return False\n\ndef get_realtime_price(ts_code):\n    \"\"\"获取个股实时价格\"\"\"\n    try:\n        if ts_code.endswith('.SH'):\n            market = 'sh' + ts_code.replace('.SH', '')\n        else:\n            market = 'sz' + ts_code.replace('.SZ', '')\n        \n        url = f'http://qt.gtimg.cn/q={market}'\n        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})\n        \n        ctx = ssl.create_default_context()\n        ctx.check_hostname = False\n        ctx.verify_mode = ssl.CERT_NONE\n        \n        with urllib.request.urlopen(req, timeout=5, context=ctx) as r:\n            content = r.read().decode('gbk', errors='replace')\n        \n        parts = content.split('~')\n        if len(parts) > 3:\n            price = float(parts[3])\n            change_pct = float(parts[32]) if len(parts) > 32 else 0\n            return price, change_pct\n    except Exception as e:\n\n[329 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1776782289210}}
{"type":"message","id":"4b992c4f","parentId":"57f066e8","timestamp":"2026-04-21T14:38:17.070Z","message":{"role":"assistant","content":[{"type":"text","text":"让我继续查看脚本的执行部分："},{"type":"toolCall","id":"call_00_NWC1wPf5hZvRS9Gpf8z1YaP1","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/coding-agent/run_aggressive_realtime_signal.py","offset":200,"limit":100}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":1058,"output":103,"cacheRead":87552,"cacheWrite":0,"totalTokens":88713,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776782289218,"responseId":"e57b0808-69de-4464-8037-6777fbf9c9fb"}}
{"type":"message","id":"4a95afcb","parentId":"4b992c4f","timestamp":"2026-04-21T14:38:17.119Z","message":{"role":"toolResult","toolCallId":"call_00_NWC1wPf5hZvRS9Gpf8z1YaP1","toolName":"read","content":[{"type":"text","text":"            message += f\"   原因: {item['reason']}\\n\\n\"\n        else:\n            emoji = \"🛒\"\n            message += f\"{emoji} {item['symbol']} {item['name']}\\n\"\n            message += f\"   建议买入价: {item['price']:.2f}\\n\"\n            message += f\"   预算: {item.get('budget', 150000):.0f}\\n\"\n            message += f\"   原因: {item['reason']}\\n\\n\"\n    \n    # 发送飞书消息\n    print(f\"\\n📤 推送飞书: {title}\")\n    \n    # 构建推送消息\n    push_msg = f\"{title}\\n时间: {now}\\n\\n\"\n    for item in signals:\n        if signal_type == \"SELL\":\n            push_msg += f\"🚨 {item['symbol']} {item['name']}\\n\"\n            push_msg += f\"   卖出价: {item['price']:.2f} | 收益: {item['pnl_pct']:+.2f}%\\n\"\n            push_msg += f\"   原因: {item['reason'][:50]}...\\n\\n\"\n        else:\n            push_msg += f\"🛒 {item['symbol']} {item['name']}\\n\"\n            push_msg += f\"   建议价: {item['price']:.2f}\\n\\n\"\n    \n    # 使用修复后的send_feishu_message函数发送\n    success = send_feishu_message(push_msg)\n    \n    if success:\n        print(\"✅ 飞书消息已处理（已发送或已记录到日志）\")\n    else:\n        print(\"⚠️ 飞书消息处理失败\")\n        print(\"📝 建议手动检查信号\")\n\ndef calculate_signals(positions):\n    \"\"\"计算买卖信号\"\"\"\n    buy_list = []\n    sell_list = []\n    hold_list = []\n    \n    print(\"\\n📊 持仓分析:\")\n    print(\"=\" * 80)\n    \n    for pos in positions:\n        symbol = pos['symbol']\n        name = pos['name']\n        cost = pos['cost_price']\n        last_price = pos['last_price']\n        pnl_pct = pos['unrealized_pnl_pct']\n        quantity = pos['quantity']\n        \n        # 获取实时价格\n        realtime_price, change_pct = get_realtime_price(symbol)\n        \n        if realtime_price is None:\n            realtime_price = last_price\n            change_pct = 0\n        \n        # 计算当前收益\n        current_pnl_pct = (realtime_price - cost) / cost * 100\n        market_value = quantity * realtime_price\n        \n        # 检查是否触发止损\n        if current_pnl_pct <= STOP_LOSS_PCT:\n            sell_reason = f\"止损: 收益{current_pnl_pct:.2f}% <= {STOP_LOSS_PCT}%\"\n            sell_list.append({\n                'symbol': symbol,\n                'name': name,\n                'action': 'SELL',\n                'price': realtime_price,\n                'quantity': quantity,\n                'reason': sell_reason,\n                'pnl_pct': current_pnl_pct,\n                'market_value': market_value\n            })\n            print(f\"🚨 {symbol} {name}: 触发止损! 当前收益{current_pnl_pct:.2f}%\")\n        \n        # 检查是否触发移动止盈\n        elif pnl_pct > 5 and current_pnl_pct < pnl_pct - abs(TRAILING_TAKE_PROFIT_PCT):\n            sell_reason = f\"移动止盈: 峰值{pos['unrealized_pnl_pct']:.2f}% → 当前{current_pnl_pct:.2f}% (回撤>{abs(TRAILING_TAKE_PROFIT_PCT)}%)\"\n            sell_list.append({\n                'symbol': symbol,\n                'name': name,\n                'action': 'SELL',\n                'price': realtime_price,\n                'quantity': quantity,\n                'reason': sell_reason,\n                'pnl_pct': current_pnl_pct,\n                'market_value': market_value\n            })\n            print(f\"📈 {symbol} {name}: 触发移动止盈! 峰值{pos['unrealized_pnl_pct']:.2f}% → 当前{current_pnl_pct:.2f}%\")\n        \n        # 继续持有\n        else:\n            hold_list.append({\n                'symbol': symbol,\n                'name': name,\n                'price': realtime_price,\n                'change_pct': change_pct,\n                'cost': cost,\n                'pnl_pct': current_pnl_pct,\n                'quantity': quantity,\n                'market_value': market_value\n\n[130 more lines in file. Use offset=300 to continue.]"}],"isError":false,"timestamp":1776782297101}}
