{"type":"message","id":"286e9345","parentId":"0380f00a","timestamp":"2026-04-21T14:38:26.064Z","message":{"role":"toolResult","toolCallId":"call_00_brzMVJcWV21kwWCDbsvtSyme","toolName":"read","content":[{"type":"text","text":"    if sell_list:\n        print(\"\\n\" + \"=\" * 80)\n        print(\"🚨 检测到卖出信号！推送飞书通知...\")\n        push_signal_to_feishu(\"SELL\", sell_list)\n    \n    # 如果有买入信号，立即推送\n    if buy_list:\n        print(\"\\n\" + \"=\" * 80)\n        print(\"🛒 检测到买入信号！推送飞书通知...\")\n        push_signal_to_feishu(\"BUY\", buy_list)\n    \n    # 如果没有信号\n    if not sell_list and not buy_list:\n        print(\"\\n✅ 今日无新的买卖信号\")\n    \n    # 生成完整报告\n    report = generate_full_report(market, buy_list, sell_list, hold_list)\n    \n    # 保存报告\n    report_file = REPORT_DIR / \"aggressive_realtime_signal_latest.md\"\n    with open(report_file, 'w', encoding='utf-8') as f:\n        f.write(report)\n    print(f\"\\n📝 报告已保存: {report_file}\")\n    \n    print(\"\\n\" + \"=\" * 80)\n    print(\"✅ 实时监控完成\")\n    print(\"=\" * 80)\n\nif __name__ == \"__main__\":\n    main()"}],"isError":false,"timestamp":1776782306053}}
