t above into your normal assistant voice and send that user-facing update now. Keep this internal context private (don't mention system/log/stats/session details or announce type).\n<<<END_OPENCLAW_INTERNAL_CONTEXT>>>"}],"timestamp":1775578811530,"provenance":{"kind":"inter_session","sourceSessionKey":"agent:coding-agent:subagent:981f15fa-fc95-4257-aabd-4cbd58e5f373","sourceChannel":"webchat","sourceTool":"subagent_announce"}}}
