{"type":"message","id":"764ad558","parentId":"9c4f4b31","timestamp":"2026-04-07T15:46:04.224Z","message":{"role":"toolResult","toolCallId":"call_function_gpvj9drab0tb_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nimport run_aggressive_walkforward_validation as aggressive_wf\nimport run_oos_validation_2023_2026 as strict_oos\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\n\n\ndef to_timestamp(value: Any) -> pd.Timestamp:\n    return pd.Timestamp(str(value))\n\n\ndef validate_signal_trade_order(signal_date: Any, trade_date: Any) -> None:\n    signal_ts = to_timestamp(signal_date)\n    trade_ts = to_timestamp(trade_date)\n    if signal_ts >= trade_ts:\n        raise ValueError(f\"signal_date must be earlier than trade_date: {signal_ts.date()} >= {trade_ts.date()}\")\n\n\ndef audit_window(window: dict[str, Any], *, window_id: int) -> list[str]:\n    train_start = to_timestamp(window[\"train_start\"])\n    train_end = to_timestamp(window[\"train_end\"])\n    valid_start = to_timestamp(window[\"valid_start\"])\n    valid_end = to_timestamp(window[\"valid_end\"])\n    test_start = to_timestamp(window[\"test_start\"])\n    test_end = to_timestamp(window[\"test_end\"])\n\n    issues: list[str] = []\n    if not (train_start <= train_end < valid_start <= valid_end < test_start <= test_end):\n        issues.append(\n            \"window_order_invalid:\"\n            f\" train={train_start.date()}~{train_end.date()}\"\n            f\" valid={valid_start.date()}~{valid_end.date()}\"\n            f\" test={test_start.date()}~{test_end.date()}\"\n        )\n    return [f\"window_{window_id}:{issue}\" for issue in issues]\n\n\ndef audit_windows(windows: list[dict[str, Any]]) -> list[str]:\n    issues: list[str] = []\n    prior_test_end: pd.Timestamp | None = None\n    for idx, window in enumerate(windows, start=1):\n        issues.extend(audit_window(window, window_id=idx))\n        test_start = to_timestamp(window[\"test_start\"])\n        test_end = to_timestamp(window[\"test_end\"])\n        if prior_test_end is not None and test_start <= prior_test_end:\n            issues.append(\n                f\"window_{idx}:test_overlap previous_test_end={prior_test_end.date()} current_test_start={test_start.date()}\"\n            )\n        prior_test_end = test_end\n    return issues\n\n\ndef build_aggressive_windows(\n    *,\n    train_years: int,\n    valid_years: int,\n    test_months: int,\n    step_months: int,\n) -> list[dict[str, Any]]:\n    calendar = aggressive_wf.build_trade_calendar()\n    return aggressive_wf.generate_windows(\n        calendar,\n        train_years=train_years,\n        valid_years=valid_years,\n        test_months=test_months,\n        step_months=step_months,\n    )\n\n\ndef audit_strict_oos_window() -> list[str]:\n    issues: list[str] = []\n    train_end = to_timestamp(strict_oos.TRAIN_END)\n    oos_start = to_timestamp(strict_oos.OOS_START)\n    oos_end = to_timestamp(strict_oos.OOS_END)\n    if not (train_end < oos_start <= oos_end):\n        issues.append(\n            f\"strict_oos_invalid: train_end={train_end.date()} oos_start={oos_start.date()} oos_end={oos_end.date()}\"\n        )\n    validate_signal_trade_order(train_end, oos_start)\n    return issues\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--train-years\", type=int, default=6)\n    parser.add_argument(\"--valid-years\", type=int, default=2)\n    parser.add_argument(\"--test-months\", type=int, default=6)\n    parser.add_argument(\"--step-months\", type=int, default=3)\n    parser.add_argument(\"--output-json\", default=\"\")\n    args = parser.parse_args()\n\n[39 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1775576764219}}
