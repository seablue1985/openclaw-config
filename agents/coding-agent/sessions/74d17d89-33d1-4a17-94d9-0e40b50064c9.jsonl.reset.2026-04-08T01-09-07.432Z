                _append_audit(\n 463                     trade_date,\n-464                     \";\".join(df.loc[excess_mask, \"ts_code\"].tolist()),\n-465                     \"BUY\",\n-466                     \"LIQUIDITY_CAPPED\",\n-467                     f\"qty > ADV20 * {self.config.max_order_to_adv20_ratio:.2%}\",\n+450                     \";\".join(df.loc[excess, \"ts_code\"].tolist()),\n+451                     \"BUY\", \"LIQUIDITY_CAPPED\",\n+452                     f\"qty > ADV20 * {ratio:.2%}\",\n 468                 )\n 469 \n-470         df.drop(columns=[\"_max_qty_by_adv\"], inplace=True, errors=\"ignore\")\n 471         return df\n 472 \n 473     def apply_execution_filter(self, signals: pd.DataFrame, market_data: dict[str, dict], trade_date: str = \"\") -> pd.DataFrame:\n-474         \"\"\"Vectorized execution filter:涨跌停/停牌 + 流动性。\n+458         \"\"\"Fully vectorized execution filter: no row iteration, pure pandas masks.\n 475 \n-476         Args:\n-477             signals: 通过风控的信号 DataFrame\n-478             market_data: 当日市场数据字典\n-479             trade_date: 审计日志用\n+460         Rules:\n+461         - BUY rejected if: suspended OR close >= limit_up (涨停日无法买入)\n+462         - SELL rejected if: suspended OR close <= limit_down (跌停日无法卖出)\n 480         \"\"\"\n 481         if signals is None or signals.empty:\n 482             return signals\n 483         if not market_data:\n     ...\n 486         df = signals.copy()\n 487         df[\"execution_rejected\"] = False\n 488         df[\"execution_reject_reason\"] = \"\"\n 489 \n-490         # Build DailyMarketData dict once\n-491         md_dict: dict[str, DailyMarketData] = {}\n-492         for code, md in market_data.items():\n-493             md_dict[code] = DailyMarketData(\n-494                 ts_code=md.get(\"ts_code\", code),\n-495                 trade_date=md.get(\"trade_date\", 0),\n-496                 open=md.get(\"open\", 0.0),\n-497                 high=md.get(\"high\", 0.0),\n-498         