{"type":"message","id":"5aadfac0","parentId":"4085b21a","timestamp":"2026-04-07T16:00:50.427Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user sent the same message again - they want all three fixes done. I've already done:\n1. ✅ Fixed pct_change to return NaN\n2. ✅ Fixed load_price_snapshot with vectorized operations  \n3. ✅ Fixed load_latest_ma_snapshot with vectorized operations\n\nNow I need to create the order execution simulator for limit up/down trading. Let me create a new file for this.","thinkingSignature":"39a483f21f9cd8018a1a9d7c5bec8e6247e8ad2ed78a99c46a70339fb7236895"},{"type":"text","text":"\n已完成前两项，现在来实现订单执行模拟器。\n"},{"type":"toolCall","id":"call_function_k7efvnzldp6h_1","name":"write","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/execution/simulator.py","content":"\"\"\"\n订单执行模拟器 - 模拟涨跌停/流动性约束下的订单成交情况\n\n职责：\n1. 涨停日：买入订单无法成交\n2. 跌停日：卖出订单无法成交\n3. 部分成交：大单按成交率分批执行\n4. T+1 限制：当日买入无法当日卖出\n\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nfrom dataclasses import dataclass, field\nfrom typing import Optional\n\n\n@dataclass\nclass ExecutionResult:\n    \"\"\"订单执行结果\"\"\"\n    ts_code: str\n    side: str  # BUY / SELL\n    requested_qty: int\n    filled_qty: int          # 实际成交数量\n    fill_price: float         # 成交价（若无成交则为0）\n    rejected: bool = False\n    rejection_reason: str = \"\"\n    slippage_bps: float = 0.0  # 滑点（基点）\n\n    @property\n    def fill_rate(self) -> float:\n        \"\"\"成交率\"\"\"\n        if self.requested_qty <= 0:\n            return 0.0\n        return self.filled_qty / self.requested_qty\n\n\n@dataclass\nclass DailyMarketData:\n    \"\"\"单日市场数据\"\"\"\n    ts_code: str\n    trade_date: int\n    open: float\n    high: float\n    low: float\n    close: float\n    limit_up: float\n    limit_down: float\n    suspended: bool = False\n    adv20: float = 0.0  # 20日平均成交量\n\n\n@dataclass\nclass Position:\n    \"\"\"持仓记录（用于T+1追踪）\"\"\"\n    ts_code: str\n    buy_date: int       # 买入日期 (YYYYMMDD)\n    qty: int\n    avg_price: float\n\n\n@dataclass\nclass ExecutionConfig:\n    \"\"\"执行模拟配置\"\"\"\n    # 涨跌停约束\n    enforce_limit_up_block: bool = True    # 涨停日禁止买入\n    enforce_limit_down_block: bool = True   # 跌停日禁止卖出\n\n    # 流动性约束\n    max_order_to_adv_ratio: float = 0.02   # 单笔订单不超过ADV20的2%\n    enforce_liquidity: bool = False         # 是否强制执行流动性约束\n\n    # 部分成交\n    enable_partial_fill: bool = True        # 启用部分成交模拟\n    partial_fill_rate: float = 0.8          # 大单部分成交率（实际可成交量/申请量）\n\n    # 滑点（基点）\n    buy_slippage_bps: float = 8.0          # 买入滑点 8bps\n    sell_slippage_bps: float = 5.0         # 卖出滑点 5bps\n    limit_up_slippage_bps: float = 5.0     # 涨停买入额外滑点\n\n    # 成交延迟（天）\n    execution_delay_days: int = 1            # 信号到成交的延迟（T+1）\n\n\nclass ExecutionSimulator:\n    \"\"\"\n    订单执行模拟器\n\n    核心规则：\n    1. 涨停日买入 → 拒绝（无法买入）\n    2. 跌停日卖出 → 拒绝（无法卖出）\n    3. 超出流动性 → 部分成交\n    4. T+1限制 → 当日买入次日才能卖\n    \"\"\"\n\n    def __init__(self, config: Optional[ExecutionConfig] = None):\n        self.config = config or ExecutionConfig()\n        # 持仓记录: ts_code -> Position\n        self._positions: dict[str, Position] = {}\n        # 成交记录: trade_date -> list[ExecutionResult]\n        self._fill_history: dict[int, list[ExecutionResult]] = {}\n\n    def execute_buy(\n        self,\n        ts_code: str,\n        requested_qty: int,\n        price: float,\n        market_data: DailyMarketData,\n        trade_date: int,\n    ) -> ExecutionResult:\n        \"\"\"\n        执行买入订单\n\n        Args:\n            ts_code: 股票代码\n            requested_qty: 申请买入数量\n            price: 限价（通常为涨停价）\n            market_data: 当日市场数据\n            trade_date: 交易日期\n\n        Returns:\n            ExecutionResult: 执行结果\n        \"\"\"\n        if requested_qty <= 0:\n            return ExecutionResult(\n                ts_code=ts_code, side=\"BUY\",\n                requested_qty=0, filled_qty=0, fill_price=0,\n                rejected=True, rejection_reason=\"requested_qty <= 0\"\n            )\n\n        # 规则1: 停牌\n        if market_data.suspended:\n            return self._reject(\n                ts_code, \"BUY\", requested_qty, 0,\n                f\"停牌日无法买入\"\n            )\n\n        # 规则2: 涨停日禁止买入\n        if self.config.enforce_limit_up_block:\n            if market_data.close >= market_data.limit_up - 1e-8:\n                return self._reject(\n                    ts_code, \"BUY\", requested_qty, 0,\n                    f\"涨停日无法买入 (close={market_data.close:.2f}, limit_up={market_data.limit_up:.2f})\"\n                )\n\n        # 规则3: 流动性约束\n        fill_qty = requested_qty\n        fill_price = price\n        slippage = self.config.buy_slippage_bps\n\n        if self.config.enforce_liquidity and market_data.adv20 > 0:\n            max_qty_by_liquidity = int(market_data.adv20 * self.config.max_order_to_adv_ratio)\n            if fill_qty > max_qty_by_liquidity:\n                if self.config.enable_partial_fill:\n                    # 按比例成交\n                    fill_ratio = min(self.config.partial_fill_rate, max_qty_by_liquidity / fill_qty)\n                    fill_qty = int(fill_qty * fill_ratio)\n                    slippage += 5  # 流动性不足额外滑点\n                else:\n                    return self._reject(\n                        ts_code, \"BUY\", requested_qty, 0,\n                        f\"超出流动性限制 (qty={requested_qty}, max={max_qty_by_liquidity})\"\n                    )\n\n        if fill_qty <= 0:\n            return self._reject(\n                ts_code, \"BUY\", requested_qty, 0,\n                \"流动性不足导致无法成交\"\n            )\n\n        # 计算滑点\n        fill_price = price * (1 + slippage / 10000)\n\n        # 更新持仓（T+1生效）\n        entry_date = trade_date + self.config.execution_delay_days\n        self._update_position(ts_code, entry_date, fill_qty, fill_price)\n\n        # 记录成交\n        result = ExecutionResult(\n            ts_code=ts_code, side=\"BUY\",\n            requested_qty=requested_qty,\n            filled_qty=fill_qty,\n            fill_price=fill_price,\n            slippage_bps=slippage\n        )\n        self._record_fill(trade_date, result)\n\n        return result\n\n    def execute_sell(\n        self,\n        ts_code: str,\n        requested_qty: int,\n        price: float,\n        market_data: DailyMarketData,\n        trade_date: int,\n    ) -> ExecutionResult:\n        \"\"\"\n        执行卖出订单\n\n        Args:\n            ts_code: 股票代码\n            requested_qty: 申请卖出数量\n            price: 限价（通常为跌停价）\n            market_data: 当日市场数据\n            trade_date: 交易日期\n\n        Returns:\n            ExecutionResult: 执行结果\n        \"\"\"\n        if requested_qty <= 0:\n            return ExecutionResult(\n                ts_code=ts_code, side=\"SELL\",\n                requested_qty=0, filled_qty=0, fill_price=0,\n                rejected=True, rejection_reason=\"requested_qty <= 0\"\n            )\n\n        # 规则1: 停牌\n        if market_data.suspended:\n            return self._reject(\n                ts_code, \"SELL\", requested_qty, 0,\n                f\"停牌日无法卖出\"\n            )\n\n        # 规则2: 跌停日禁止卖出\n        if self.config.enforce_limit_down_block:\n            if market_data.close <= market_data.limit_down + 1e-8:\n                return self._reject(\n                    ts_code, \"SELL\", requested_qty, 0,\n                    f\"跌停日无法卖出 (close={market_data.close:.2f}, limit_down={market_data.limit_down:.2f})\"\n                )\n\n        # 规则3: T+1 限制\n        position = self._positions.get(ts_code)\n        if position is None or position.qty <= 0:\n            return self._reject(\n                ts_code, \"SELL\", requested_qty, 0,\n                f\"T+1限制：无持仓记录\"\n            )\n\n        # 检查是否在T+1锁定期\n        if trade_date < position.buy_date:\n            return self._reject(\n                ts_code, \"SELL\", requested_qty, 0,\n                f\"T+1限制：{position.buy_date}日买入，需等到{position.buy_date + 1}日才能卖出\"\n            )\n\n        # 规则4: 流动性约束\n        fill_qty = min(requested_qty, position.qty)\n        fill_price = price\n        slippage = self.config.sell_slippage_bps\n\n        if self.config.enforce_liquidity and market_data.adv20 > 0:\n            max_qty_by_liquidity = int(market_data.adv20 * self.config.max_order_to_adv_ratio)\n            if fill_qty > max_qty_by_liquidity:\n                if self.config.enable_partial_fill:\n                    fill_ratio = min(self.config.partial_fill_rate, max_qty_by_liquidity / fill_qty)\n                    fill_qty = max(1, int(fill_qty * fill_ratio))\n                    slippage += 5\n                else:\n                    return self._reject(\n                        ts_code, \"SELL\", requested_qty, 0,\n                        f\"超出流动性限制 (qty={requested_qty}, max={max_qty_by_liquidity})\"\n                    )\n\n        if fill_qty <= 0:\n            return self._reject(\n                ts_code, \"SELL\", requested_qty, 0,\n                \"流动性不足导致无法成交\"\n            )\n\n        # 计算滑点（卖出用bid）\n        fill_price = price * (1 - slippage / 10000)\n\n        # 更新持仓\n        position.qty -= fill_qty\n        if position.qty <= 0:\n            del self._positions[ts_code]\n\n        # 记录成交\n        result = ExecutionResult(\n            ts_code=ts_code, side=\"SELL\",\n            requested_qty=requested_qty,\n            filled_qty=fill_qty,\n            fill_price=fill_price,\n            slippage_bps=slippage\n        )\n        self._record_fill(trade_date, result)\n\n        return result\n\n    def can_buy(self, market_data: DailyMarketData) -> tuple[bool, str]:\n        \"\"\"检查当日是否可以买入\"\"\"\n        if market_data.suspended:\n            return False, \"停牌\"\n        if self.config.enforce_limit_up_block:\n            if market_data.close >= market_data.limit_up - 1e-8:\n                return False, \"涨停\"\n        return True, \"\"\n\n    def can_sell(self, market_data: DailyMarketData) -> tuple[bool, str]:\n        \"\"\"检查当日是否可以卖出\"\"\"\n        if market_data.suspended:\n            return False, \"停牌\"\n        if self.config.enforce_limit_down_block:\n            if market_data.close <= market_data.limit_down + 1e-8:\n                return False, \"跌停\"\n        return True, \"\"\n\n    def get_position(self, ts_code: str) -> Optional[Position]:\n        \"\"\"获取持仓（仅返回非空持仓）\"\"\"\n        pos = self._positions.get(ts_code)\n        if pos and pos.qty > 0:\n            return pos\n        return None\n\n    def get_positions(self) -> dict[str, Position]:\n        \"\"\"获取所有持仓\"\"\"\n        return {k: v for k, v in self._positions.items() if v.qty > 0}\n\n    def get_fill_history(self, trade_date: int) -> list[ExecutionResult]:\n        \"\"\"获取指定日期的成交记录\"\"\"\n        return self._fill_history.get(trade_date, [])\n\n    def _reject(self, ts_code: str, side: str, qty: int, price: float, reason: str) -> ExecutionResult:\n        return ExecutionResult(\n            ts_code=ts_code, side=side,\n            requested_qty=qty, filled_qty=0, fill_price=price,\n            rejected=True, rejection_reason=reason\n        )\n\n    def _update_position(self, ts_code: str, buy_date: int, qty: int, avg_price: float):\n        if ts_code in self._positions:\n            pos = self._positions[ts_code]\n            total_cost = pos.qty * pos.avg_price + qty * avg_price\n            pos.qty += qty\n            pos.avg_price = total_cost / pos.qty\n            # T+1: 如果补仓，保持最早的买入日期\n            if buy_date < pos.buy_date:\n                pos.buy_date = buy_date\n        else:\n            self._positions[ts_code] = Position(\n                ts_code=ts_code, buy_date=buy_date, qty=qty, avg_price=avg_price\n            )\n\n    def _record_fill(self, trade_date: int, result: ExecutionResult):\n        if trade_date not in self._fill_history:\n            self._fill_history[trade_date] = []\n        self._fill_history[trade_date].append(result)\n\n    def reset(self):\n        \"\"\"重置模拟器状态（用于新回测周期）\"\"\"\n        self._positions.clear()\n        self._fill_history.clear()\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5-highspeed","usage":{"input":77,"output":3126,"cacheRead":0,"cacheWrite":79922,"totalTokens":83125,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775577608580,"responseId":"06245d09467bded3ccf3fa8b3944ea18"}}
