.\n-rw-r--r--@  1 ling  staff   6148 Mar 11 16:58 .DS_Store\ndrwx------   8 ling  staff    256 Mar 14 13:41 __pycache__\n-rw-------   1 ling  staff   7388 Mar  5 21:27 optimize_params.py\ndrwx------  39 ling  staff   1248 Mar 14 15:07 results\n-rw-------   1 ling  staff   7596 Mar 26 00:03 run_backtest.py\n-rw-------   1 ling  staff  14215 Mar 11 17:05 run_cross_sectional_backtest.py\n-rw-------   1 ling  staff   5836 Mar 10 20:49 run_ml_enhanced_backtest.py\n-rw-------   1 ling  staff  13291 Mar 26 00:01 run_smallcap_chip_backtest.py\n-rw-r--r--   1 ling  staff   9210 Mar 26 00:02 run_smallcap_walk_forward.py\n-rw-------   1 ling  staff   7137 Mar  5 21:24 run_walk_forward.py\n\n/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/risk/:\ntotal 120\ndrwx------   9 ling  staff    288 Mar 12 17:56 .\ndrwx------  31 ling  staff    992 Apr  3 14:16 ..\n-rw-r--r--@  1 ling  staff   6148 Mar 11 16:58 .DS_Store\ndrwx------   4 ling  staff    128 Mar 16 15:31 __pycache__\ndrwx------   3 ling  staff     96 Mar 10 16:48 configs\n-rw-r--r--   1 ling  staff  36898 Mar 13 09:32 exit_engine.py\ndrwx------   2 ling  staff     64 Mar 10 09:58 reports\n-rw-------   1 ling  staff  11698 Mar 16 15:15 risk_engine.py\ndrwx------   2 ling  staff     64 Mar 10 09:58 rules","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1775576719127}}
{"type":"message","id":"7c2324d6","parentId":"94d61736","timestamp":"2026-04-07T15:45:24.921Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to explore the core files - backtest, risk, signals, etc.\n","thinkingSignature":"6e0c388e479e0fc1b3c75600de3c2a14048f6d38c422ce1444822fffa67b6d36"},{"type":"toolCall","id":"call_function_ofej4a5apgi2_1","name":"read","arguments":{"limit":200,"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/backtest/run_backtest.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":651,"output":77,"cacheRead":50704,"cacheWrite":0,"totalTokens":51432,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775576719132,"responseId":"0624598f1a88e076bd9c0281975217fa"}}
{"type":"message","id":"279337a0","parentId":"7c2324d6","timestamp":"2026-04-07T15:45:24.981Z","message":{"role":"toolResult","toolCallId":"call_function_ofej4a5apgi2_1","toolName":"read","content":[{"type":"text","text":"import argparse\nimport json\nimport sys\nfrom pathlib import Path\n\nimport backtrader as bt\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nSCRIPTS_DIR = PROJECT_ROOT / \"scripts\"\nif str(SCRIPTS_DIR) not in sys.path:\n    sys.path.insert(0, str(SCRIPTS_DIR))\n\nimport experiment_registry as experiment_registry_mod\n\n\nclass AShareCSVFeed(bt.feeds.PandasData):\n    lines = (\"limit_up\", \"limit_down\", \"suspended\")\n    params = (\n        (\"datetime\", None),\n        (\"open\", \"open\"),\n        (\"high\", \"high\"),\n        (\"low\", \"low\"),\n        (\"close\", \"close\"),\n        (\"volume\", \"volume\"),\n        (\"openinterest\", -1),\n        (\"limit_up\", \"limit_up\"),\n        (\"limit_down\", \"limit_down\"),\n        (\"suspended\", \"suspended\"),\n    )\n\n\nclass AShareConstraintStrategy(bt.Strategy):\n    params = dict(\n        sma_period=20,\n        lot_size=100,\n        max_single_position=0.10,\n        stake_cash_ratio=0.95,\n    )\n\n    def __init__(self):\n        self.sma = bt.indicators.SimpleMovingAverage(self.data.close, period=self.p.sma_period)\n        self.entry_bar = None\n        self.blocked = {\n            \"buy_suspended\": 0,\n            \"buy_limit_up\": 0,\n            \"sell_suspended\": 0,\n            \"sell_limit_down\": 0,\n            \"sell_t_plus_1\": 0,\n            \"insufficient_lot\": 0,\n        }\n\n    def _is_suspended(self):\n        return int(self.data.suspended[0]) == 1\n\n    def _is_limit_up(self):\n        return float(self.data.close[0]) >= float(self.data.limit_up[0]) - 1e-8\n\n    def _is_limit_down(self):\n        return float(self.data.close[0]) <= float(self.data.limit_down[0]) + 1e-8\n\n    def _calc_buy_size(self):\n        price = float(self.data.close[0])\n        if price <= 0:\n            return 0\n        cash_budget = self.broker.getcash() * self.p.stake_cash_ratio\n        risk_budget = self.broker.getvalue() * self.p.max_single_position\n        budget = min(cash_budget, risk_budget)\n        raw_size = int(budget / price)\n        return (raw_size // self.p.lot_size) * self.p.lot_size\n\n    def next(self):\n        if len(self) < self.p.sma_period:\n            return\n\n        signal_buy = float(self.data.close[0]) > float(self.sma[0])\n        signal_sell = float(self.data.close[0]) < float(self.sma[0])\n        has_position = self.position.size > 0\n\n        if not has_position and signal_buy:\n            if self._is_suspended():\n                self.blocked[\"buy_suspended\"] += 1\n                return\n            if self._is_limit_up():\n                self.blocked[\"buy_limit_up\"] += 1\n                return\n\n            size = self._calc_buy_size()\n            if size < self.p.lot_size:\n                self.blocked[\"insufficient_lot\"] += 1\n                return\n\n            self.buy(size=size)\n            self.entry_bar = len(self)\n            return\n\n        if has_position and signal_sell:\n            hold_bars = len(self) - (self.entry_bar or len(self))\n            if hold_bars < 1:\n                self.blocked[\"sell_t_plus_1\"] += 1\n                return\n            if self._is_suspended():\n                self.blocked[\"sell_suspended\"] += 1\n                return\n            if self._is_limit_down():\n                self.blocked[\"sell_limit_down\"] += 1\n                return\n\n            self.sell(size=self.position.size)\n\n\ndef load_strategy_config(config_path: Path):\n    with config_path.open(\"r\", encoding=\"utf-8\") as file:\n        config = yaml.safe_load(file)\n    risk = config.get(\"risk\", {})\n    cost = config.get(\"cost\", {})\n    return {\n        \"max_single_position\": float(risk.get(\"max_single_position\", 0.10)),\n        \"commission\": float(cost.get(\"commission_bps\", 3)) / 10000.0,\n        \"slippage\": float(cost.get(\"slippage_bps\", 8)) / 10000.0,\n    }\n\n\ndef load_price_data(csv_path: Path):\n    frame = pd.read_csv(csv_path)\n    frame[\"date\"] = pd.to_datetime(frame[\"date\"])\n    frame = frame.set_index(\"date\").sort_index()\n    required = [\"open\", \"high\", \"low\", \"close\", \"volume\", \"limit_up\", \"limit_down\", \"suspended\"]\n    missing = [column for column in required if column not in frame.columns]\n    if missing:\n        raise ValueError(f\"缺少字段: {missing}\")\n    return frame\n\n\ndef run_backtest(args):\n    project_root = Path(__file__).resolve().parents[1]\n    config = load_strategy_config(project_root / \"config\" / \"strategy.yaml\")\n    data = load_price_data(Path(args.data))\n\n    cerebro = bt.Cerebro(stdstats=False)\n    cerebro.broker.setcash(args.cash)\n    cerebro.broker.setcommission(commission=config[\"commission\"])\n    cerebro.broker.set_slippage_perc(config[\"slippage\"])\n\n    feed = AShareCSVFeed(dataname=data)\n    cerebro.adddata(feed, name=\"A_SHARE\")\n    cerebro.addstrategy(\n        AShareConstraintStrategy,\n        sma_period=args.sma_period,\n        max_single_position=config[\"max_single_position\"],\n    )\n    cerebro.addanalyzer(bt.analyzers.DrawDown, _name=\"drawdown\")\n    cerebro.addanalyzer(bt.analyzers.TradeAnalyzer, _name=\"trades\")\n\n    start_value = cerebro.broker.getvalue()\n    result = cerebro.run()\n    strategy = result[0]\n    final_value = cerebro.broker.getvalue()\n    pnl = final_value - start_value\n\n    drawdown = strategy.analyzers.drawdown.get_analysis()\n    trade_analysis = strategy.analyzers.trades.get_analysis()\n\n    summary = {\n        \"start_value\": round(start_value, 2),\n        \"final_value\": round(final_value, 2),\n        \"pnl\": round(pnl, 2),\n        \"return_pct\": round((pnl / start_value) * 100, 2),\n        \"max_drawdown_pct\": round(float(drawdown.get(\"max\", {}).get(\"drawdown\", 0.0)), 2),\n        \"total_trades\": int(trade_analysis.get(\"total\", {}).get(\"total\", 0) or 0),\n        \"blocked_orders\": strategy.blocked,\n    }\n\n    print(json.dumps(summary, ensure_ascii=False, indent=2))\n\n    if args.output:\n        output_path = Path(args.output)\n        output_path.parent.mkdir(parents=True, exist_ok=True)\n        output_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n        if str(getattr(args, \"strategy_id\", \"\")).strip():\n            experiment_registry_mod.record_experiment(\n                strategy_id=str(args.strategy_id),\n                experiment_type=str(getattr(args, \"experiment_type\", \"full_backtest\")),\n                artifact_path=output_path,\n                params={\n                    \"cash\": args.cash,\n                    \"sma_period\": args.sma_period,\n                },\n                data_sources=[args.data],\n                oos_metrics=summary,\n                promotion_state=str(getattr(args, \"promotion_state\", \"incubating\")),\n                metadata={\n                    \"source\": \"run_backtest\",\n                },\n            )\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"A股回测入口（含T+1/涨跌停/停牌约束）\")\n\n[18 more lines in file. Use offset=201 to continue.]"}],"isError":false,"timestamp":1775576724977}}
{"type":"message","id":"d8de023a","parentId":"279337a0","timestamp":"2026-04-07T15:45:30.661Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me continue reading the backtest file and also check the risk engine:\n","thinkingSignature":"a7220236d65b310b0a204c3ab25dfd4c7920c2771cab44b85cce0802fac56a07"},{"type":"toolCall","id":"call_function_87u7mjs9w126_1","name":"read","arguments":{"limit":150,"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/risk/risk_engine.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":1792,"output":74,"cacheRead":51344,"cacheWrite":0,"totalTokens":53210,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775576724982,"responseId":"06245995783f43e8d42112e462dedbbb"}}
{"type":"message","id":"491f2df2","parentId":"d8de023a","timestamp":"2026-04-07T15:45:30.736Z","message":{"role":"toolResult","toolCallId":"call_function_87u7mjs9w126_1","toolName":"read","content":[{"type":"text","text":"\"\"\"Risk engine skeleton for personal A-share research system.\n\n职责：\n1. 接收标准化 signal dataframe\n2. 应用统一风险约束\n3. 输出通过风控后的 signal / order proposal\n\n当前为骨架版本，后续逐步接入：\n- 市场宽度风控\n- 仓位上限\n- 单票限额\n- 流动性约束\n- 风险关闭期\n- 黑名单/禁买列表\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass, field\nfrom typing import Optional\n\nimport pandas as pd\n\n\n@dataclass\nclass RiskConfig:\n    max_total_exposure: float = 1.0\n    max_single_weight: float = 0.10\n    riskoff_total_exposure: float = 0.65\n    hard_stop_enabled: bool = True\n    allow_new_buy_when_riskoff: bool = False\n    max_order_to_adv20_ratio: float = 0.02\n    blocked_codes: list[str] = field(default_factory=list)\n    index_halt_threshold_pct: Optional[float] = None\n    market_breadth_riskoff_threshold: Optional[float] = None\n    market_breadth_hard_stop_threshold: Optional[float] = None\n    strategy_max_drawdown_riskoff_pct: Optional[float] = None\n    strategy_sharpe_cautious_threshold: Optional[float] = None\n    style_rotation_enabled: bool = False\n    style_rotation_riskoff_short_excess_pct: Optional[float] = None\n    style_rotation_riskoff_medium_excess_pct: Optional[float] = None\n    style_rotation_hard_stop_short_excess_pct: Optional[float] = None\n    style_rotation_hard_stop_medium_excess_pct: Optional[float] = None\n    style_rotation_hard_stop_requires_negative_smallcap: bool = True\n\n\n@dataclass\nclass RiskContext:\n    trade_date: str\n    market_breadth: Optional[float] = None\n    risk_off: bool = False\n    hard_stop: bool = False\n    available_cash: Optional[float] = None\n    account_nav: Optional[float] = None\n    index_ret_pct: Optional[float] = None\n    strategy_max_drawdown_pct: Optional[float] = None\n    strategy_sharpe: Optional[float] = None\n    style_smallcap_short_return_pct: Optional[float] = None\n    style_smallcap_medium_return_pct: Optional[float] = None\n    style_short_excess_pct: Optional[float] = None\n    style_medium_excess_pct: Optional[float] = None\n\n\n@dataclass\nclass RiskDecision:\n    mode: str\n    risk_off: bool\n    hard_stop: bool\n    halt_new_buy: bool\n    reason: str\n    reasons: list[str] = field(default_factory=list)\n\n\nclass RiskEngine:\n    BUY_SIGNAL_TYPES = {\"BUY\", \"ADD\", \"INCREASE\", \"OPEN\"}\n    SELL_SIGNAL_TYPES = {\"SELL\", \"REDUCE\", \"EXIT\", \"CLOSE\"}\n\n    def __init__(self, config: RiskConfig):\n        self.config = config\n\n    @staticmethod\n    def _append_adjustment(df: pd.DataFrame, mask: pd.Series, tag: str) -> None:\n        if not bool(mask.any()):\n            return\n        current = df.loc[mask, \"risk_adjustment\"].fillna(\"\").astype(str).str.strip()\n        df.loc[mask, \"risk_adjustment\"] = current.where(current == \"\", current + \"|\") + tag\n\n    @staticmethod\n    def _fmt_threshold_trigger(name: str, current: float, threshold: float, op: str) -> str:\n        return f\"{name}({current:.4f}) {op} {threshold:.4f}\"\n\n    @staticmethod\n    def _style_rotation_trigger(\n        *,\n        short_excess: Optional[float],\n        medium_excess: Optional[float],\n        short_threshold: Optional[float],\n        medium_threshold: Optional[float],\n    ) -> bool:\n        checks: list[bool] = []\n        if short_threshold is not None and short_excess is not None:\n            checks.append(short_excess <= short_threshold)\n        if medium_threshold is not None and medium_excess is not None:\n            checks.append(medium_excess <= medium_threshold)\n        return bool(checks) and all(checks)\n\n    def evaluate_runtime_state(self, context: RiskContext) -> RiskDecision:\n        reasons: list[str] = []\n        hard_stop = bool(context.hard_stop and self.config.hard_stop_enabled)\n        risk_off = bool(context.risk_off)\n        soft_cautious = False\n\n        if context.hard_stop and self.config.hard_stop_enabled:\n            reasons.append(\"manual_hard_stop\")\n        if context.risk_off:\n            reasons.append(\"manual_risk_off\")\n\n        idx_th = self.config.index_halt_threshold_pct\n        idx_ret = context.index_ret_pct\n        if idx_th is not None and idx_ret is not None and idx_ret <= idx_th:\n            hard_stop = True\n            reasons.append(self._fmt_threshold_trigger(\"index_ret_pct\", idx_ret, idx_th, \"<=\"))\n\n        if self.config.style_rotation_enabled:\n            short_excess = context.style_short_excess_pct\n            medium_excess = context.style_medium_excess_pct\n            hard_style_triggered = self._style_rotation_trigger(\n                short_excess=short_excess,\n                medium_excess=medium_excess,\n                short_threshold=self.config.style_rotation_hard_stop_short_excess_pct,\n                medium_threshold=self.config.style_rotation_hard_stop_medium_excess_pct,\n            )\n            if hard_style_triggered:\n                negative_smallcap_checks: list[bool] = []\n                if context.style_smallcap_short_return_pct is not None:\n                    negative_smallcap_checks.append(context.style_smallcap_short_return_pct <= 0)\n                if context.style_smallcap_medium_return_pct is not None:\n                    negative_smallcap_checks.append(context.style_smallcap_medium_return_pct <= 0)\n                if (\n                    (not self.config.style_rotation_hard_stop_requires_negative_smallcap)\n                    or (negative_smallcap_checks and all(negative_smallcap_checks))\n                ):\n                    hard_stop = True\n                    reasons.append(\"style_rotation_hard_stop\")\n\n            if not hard_stop and self._style_rotation_trigger(\n                short_excess=short_excess,\n                medium_excess=medium_excess,\n                short_threshold=self.config.style_rotation_riskoff_short_excess_pct,\n                medium_threshold=self.config.style_rotation_riskoff_medium_excess_pct,\n\n[147 more lines in file. Use offset=151 to continue.]"}],"isError":false,"timestamp":1775576730733}}
{"type":"message","id":"d0a7d9af","parentId":"491f2df2","timestamp":"2026-04-07T15:45:36.262Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good, I can see the risk engine has well-defined structure. Let me continue reading more of it and check other critical files.\n","thinkingSignature":"d2592e3b043381f2602a4e7d75b6b971a2227bce29a2320bf18b67ac54bf10db"},{"type":"toolCall","id":"call_function_7bzu5cs6jdpt_1","name":"read","arguments":{"limit":150,"offset":151,"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/risk/risk_engine.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":1473,"output":95,"cacheRead":53120,"cacheWrite":0,"totalTokens":54688,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775576730736,"responseId":"0624599a16964f1826611508dafd694c"}}
{"type":"message","id":"236e6391","parentId":"d0a7d9af","timestamp":"2026-04-07T15:45:36.321Z","message":{"role":"toolResult","toolCallId":"call_function_7bzu5cs6jdpt_1","toolName":"read","content":[{"type":"text","text":"            ):\n                risk_off = True\n                reasons.append(\"style_rotation_riskoff\")\n\n        breadth = context.market_breadth\n        breadth_hard_th = self.config.market_breadth_hard_stop_threshold\n        breadth_risk_th = self.config.market_breadth_riskoff_threshold\n        if breadth is not None:\n            if breadth_hard_th is not None and breadth <= breadth_hard_th:\n                hard_stop = True\n                reasons.append(self._fmt_threshold_trigger(\"market_breadth\", breadth, breadth_hard_th, \"<=\"))\n            elif breadth_risk_th is not None and breadth <= breadth_risk_th:\n                risk_off = True\n                reasons.append(self._fmt_threshold_trigger(\"market_breadth\", breadth, breadth_risk_th, \"<=\"))\n\n        max_dd = context.strategy_max_drawdown_pct\n        max_dd_th = self.config.strategy_max_drawdown_riskoff_pct\n        if max_dd_th is not None and max_dd is not None and max_dd >= max_dd_th:\n            risk_off = True\n            reasons.append(self._fmt_threshold_trigger(\"strategy_max_drawdown_pct\", max_dd, max_dd_th, \">=\"))\n\n        sharpe = context.strategy_sharpe\n        sharpe_th = self.config.strategy_sharpe_cautious_threshold\n        if sharpe_th is not None and sharpe is not None and sharpe < sharpe_th:\n            soft_cautious = True\n            reasons.append(self._fmt_threshold_trigger(\"strategy_sharpe\", sharpe, sharpe_th, \"<\"))\n\n        if hard_stop:\n            risk_off = True\n            mode = \"halt\"\n            halt_new_buy = True\n        elif risk_off:\n            mode = \"cautious\"\n            halt_new_buy = not self.config.allow_new_buy_when_riskoff\n        elif soft_cautious:\n            mode = \"cautious\"\n            halt_new_buy = False\n        else:\n            mode = \"normal\"\n            halt_new_buy = False\n\n        return RiskDecision(\n            mode=mode,\n            risk_off=risk_off,\n            hard_stop=hard_stop,\n            halt_new_buy=halt_new_buy,\n            reason=reasons[0] if reasons else \"\",\n            reasons=reasons,\n        )\n\n    def _apply_weight_caps(self, df: pd.DataFrame, *, exposure_cap: float) -> pd.DataFrame:\n        if \"target_weight\" not in df.columns:\n            return df\n\n        buy_mask = df[\"signal_type\"].isin(self.BUY_SIGNAL_TYPES)\n        approved_buy_mask = buy_mask & df[\"approved\"].fillna(False)\n\n        if not bool(approved_buy_mask.any()):\n            return df\n\n        df[\"target_weight\"] = pd.to_numeric(df[\"target_weight\"], errors=\"coerce\")\n        df.loc[approved_buy_mask, \"target_weight\"] = (\n            df.loc[approved_buy_mask, \"target_weight\"].fillna(0.0).clip(lower=0.0)\n        )\n\n        single_cap_mask = approved_buy_mask & (df[\"target_weight\"] > self.config.max_single_weight)\n        if bool(single_cap_mask.any()):\n            df.loc[single_cap_mask, \"target_weight\"] = self.config.max_single_weight\n            self._append_adjustment(df, single_cap_mask, \"cap_single_weight\")\n\n        total_buy_weight = float(df.loc[approved_buy_mask, \"target_weight\"].sum())\n        if exposure_cap > 0 and total_buy_weight > exposure_cap:\n            scale = exposure_cap / total_buy_weight\n            df.loc[approved_buy_mask, \"target_weight\"] = df.loc[approved_buy_mask, \"target_weight\"] * scale\n            self._append_adjustment(df, approved_buy_mask, \"scale_total_exposure\")\n\n        return df\n\n    def apply(self, signals: pd.DataFrame, context: RiskContext) -> pd.DataFrame:\n        \"\"\"Apply basic risk rules to standardized signals.\n\n        Expected columns:\n        - trade_date\n        - ts_code\n        - signal_type\n        - score\n        - target_weight (optional)\n        - strategy_id\n        \"\"\"\n        if signals is None or signals.empty:\n            return pd.DataFrame()\n\n        df = signals.copy()\n        if \"signal_type\" not in df.columns:\n            raise ValueError(\"signals 缺少 signal_type 列\")\n        if \"trade_date\" not in df.columns:\n            df[\"trade_date\"] = context.trade_date\n\n        df[\"signal_type\"] = df[\"signal_type\"].astype(str).str.upper().str.strip()\n        df[\"risk_adjustment\"] = \"none\"\n\n        # 1) 剔除黑名单\n        if self.config.blocked_codes:\n            df = df[~df[\"ts_code\"].isin(self.config.blocked_codes)].copy()\n\n        if df.empty:\n            return df\n\n        decision = self.evaluate_runtime_state(context)\n\n        # 2) 风险关闭 / 硬停止\n        if decision.hard_stop:\n            df[\"risk_status\"] = \"blocked\"\n            df[\"risk_adjustment\"] = \"hard_stop\"\n            df[\"approved\"] = False\n            if \"target_weight\" in df.columns:\n                df[\"target_weight\"] = 0.0\n            return df\n\n        if decision.risk_off:\n            df[\"risk_status\"] = \"riskoff\"\n            df[\"approved\"] = df[\"signal_type\"].isin(self.SELL_SIGNAL_TYPES)\n            buy_mask = df[\"signal_type\"].isin(self.BUY_SIGNAL_TYPES)\n            if self.config.allow_new_buy_when_riskoff:\n                df.loc[buy_mask, \"approved\"] = True\n                self._append_adjustment(df, buy_mask, \"riskoff_buy_limited\")\n            else:\n                df.loc[buy_mask, \"approved\"] = False\n                self._append_adjustment(df, buy_mask, \"riskoff_block_buy\")\n                if \"target_weight\" in df.columns:\n                    df.loc[buy_mask, \"target_weight\"] = 0.0\n\n            return self._apply_weight_caps(df, exposure_cap=self.config.riskoff_total_exposure)\n\n        # 3) 正常态：先标记通过，后续补充细化约束\n        df[\"risk_status\"] = \"normal\"\n        df[\"approved\"] = True\n        return self._apply_weight_caps(df, exposure_cap=self.config.max_total_exposure)\n\n\ndef load_signals(path: str) -> pd.DataFrame:\n    return pd.read_csv(path)\n\n\ndef save_signals(df: pd.DataFrame, path: str) -> None:\n    df.to_csv(path, index=False)\n"}],"isError":false,"timestamp":1775576736317}}
{"type":"message","id":"bf651dda","parentId":"236e6391","timestamp":"2026-04-07T15:45:44.777Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I have a good understanding. Let me also check the ML enhanced backtest for overfitting concerns.\n","thinkingSignature":"c787ab59e56093c085944d51046b68d5fb4a0087387f841bc0400a39f3dd0043"},{"type":"toolCall","id":"call_function_b1hwyaz7e2ob_1","name":"read","arguments":{"limit":150,"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/backtest/run_ml_enhanced_backtest.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":1490,"output":84,"cacheRead":54576,"cacheWrite":0,"totalTokens":56150,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775576736321,"responseId":"062459a0fd685f765c6c90141bd60cd0"}}
{"type":"message","id":"3f9c2b97","parentId":"bf651dda","timestamp":"2026-04-07T15:45:44.837Z","message":{"role":"toolResult","toolCallId":"call_function_b1hwyaz7e2ob_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"ML增强版小市值策略 - 使用简单线性回归\"\"\"\nimport argparse\nfrom pathlib import Path\nimport numpy as np\nimport pandas as pd\nfrom sklearn.linear_model import Ridge\nfrom sklearn.preprocessing import StandardScaler\n\n\ndef load_data(data_path: str) -> pd.DataFrame:\n    df = pd.read_csv(data_path)\n    df['date'] = pd.to_datetime(df['trade_date'], format='%Y%m%d')\n    df = df.sort_values(['ts_code', 'date']).reset_index(drop=True)\n    return df\n\n\ndef ml_enhanced_backtest(\n    data_path: str,\n    top_n: int = 30,\n    max_single_position: float = 0.15,\n    start_date: str = \"2023-01-01\",\n    outdir: str = \"backtest/results/ml_enhanced\"\n) -> dict:\n    \"\"\"ML增强版回测 - 使用滚动回归\"\"\"\n    \n    print(f\"Loading data...\")\n    df = load_data(data_path)\n    \n    # 过滤小市值\n    df = df[df['total_mv'] < 5000000]  # 市值小于50亿\n    \n    # 构建特征\n    print(\"Building features...\")\n    features = []\n    \n    for symbol, group in df.groupby('ts_code'):\n        g = group.set_index('date').sort_index()\n        close = g['close'].fillna(method='ffill')\n        \n        ret_5 = close.pct_change(5)\n        ret_20 = close.pct_change(20)\n        turnover = g['turnover_rate'].fillna(0) / 100\n        \n        feat = pd.DataFrame({\n            'ts_code': symbol,\n            'date': g.index,\n            'ret_5': ret_5,\n            'ret_20': ret_20,\n            'turnover': turnover,\n        })\n        features.append(feat)\n    \n    features = pd.concat(features, ignore_index=True)\n    features = features.dropna()\n    \n    # 滚动预测回测\n    dates = sorted(features['date'].unique())\n    test_dates = [d for d in dates if d >= pd.to_datetime(start_date)]\n    \n    print(f\"Backtesting from {start_date}...\")\n    \n    equity = 1.0\n    peak = 1.0\n    weights = {}\n    equity_curve = []\n    \n    # 滚动窗口：每个月重新训练\n    rebalance_idx = list(range(0, len(test_dates), 20))  # 每月调仓\n    \n    for i, date in enumerate(test_dates):\n        # 重新训练模型\n        if i in rebalance_idx:\n            train_end = date - pd.Timedelta(days=30)\n            train_data = features[features['date'] < train_end].tail(50000)\n            \n            if len(train_data) < 1000:\n                continue\n            \n            feature_cols = ['ret_5', 'ret_20', 'turnover']\n            X = train_data[feature_cols].fillna(0).values\n            y = train_data['ret_20'].shift(-5).fillna(0).values  # 预测未来20日收益\n            \n            # 简单标准化\n            scaler = StandardScaler()\n            X_scaled = scaler.fit_transform(X)\n            \n            model = Ridge(alpha=1.0)\n            model.fit(X_scaled, y)\n        \n        # 当天打分\n        day_data = features[features['date'] == date].copy()\n        \n        if len(day_data) > 0 and i in rebalance_idx:\n            X_pred = day_data[feature_cols].fillna(0).values\n            X_pred_scaled = scaler.transform(X_pred)\n            day_data['ml_score'] = model.predict(X_pred_scaled)\n            \n            # 标准化\n            day_data['ml_score_norm'] = (day_data['ml_score'] - day_data['ml_score'].mean()) / (day_data['ml_score'].std() + 1e-8)\n            \n            # 结合动量\n            day_data['composite'] = 0.6 * day_data['ml_score_norm'] + 0.4 * day_data['ret_20'].rank(pct=True)\n            \n            top_stocks = day_data.nlargest(top_n, 'composite')\n            per = min(1.0 / len(top_stocks), max_single_position)\n            weights = {row['ts_code']: per for _, row in top_stocks.iterrows()}\n        \n        # 计算收益\n        if len(day_data) > 0 and weights:\n            daily_ret = 0\n            for code, w in weights.items():\n                stock_ret = day_data[day_data['ts_code'] == code]['ret_5'].values\n                if len(stock_ret) > 0:\n                    daily_ret += w * stock_ret[0]\n            equity *= (1 + daily_ret)\n        \n        peak = max(peak, equity)\n        drawdown = (peak - equity) / peak if peak > 0 else 0\n        \n        equity_curve.append({'date': date, 'equity': equity, 'drawdown': drawdown})\n    \n    # 计算指标\n    equity_df = pd.DataFrame(equity_curve)\n    returns = equity_df['equity'].pct_change().fillna(0)\n    \n    total_return = equity - 1\n    days = len(test_dates)\n    annual_return = (equity ** (252 / days)) - 1 if days > 0 else 0\n    annual_vol = returns.std() * np.sqrt(252)\n    sharpe = annual_return / annual_vol if annual_vol > 0 else 0\n    max_dd = equity_df['drawdown'].max()\n    \n    result = {\n        \"final_equity\": equity,\n        \"total_return_pct\": total_return * 100,\n        \"annual_return_pct\": annual_return * 100,\n        \"annual_vol_pct\": annual_vol * 100,\n        \"sharpe\": sharpe,\n        \"max_drawdown_pct\": max_dd * 100,\n        \"days\": days,\n        \"top_n\": top_n\n    }\n    \n    print(f\"\\n=== ML Enhanced Backtest Results ===\")\n    print(f\"Annual Return: {annual_return*100:.2f}%\")\n    print(f\"Sharpe: {sharpe:.3f}\")\n    print(f\"Max Drawdown: {max_dd*100:.2f}%\")\n    print(f\"Total Days: {days}\")\n    \n\n[23 more lines in file. Use offset=151 to continue.]"}],"isError":false,"timestamp":1775576744832}}
