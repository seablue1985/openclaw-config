       'open': 10.0, 'high': 9.0, 'low': 8.5, 'close': 8.5,\n        'limit_up': 11.0, 'limit_down': 9.0, 'suspended': False, 'adv20': 1000000,\n    },\n}\n\nctx = RiskContext(trade_date='2026-03-01', market_data=market_data)\nresult = engine.apply(signals, ctx)\n\nprint('自定义索引测试:')\nprint(f'  涨停000001.SZ被拒绝: {result.loc[\\\"a\\\", \\\"execution_rejected\\\"]} (expected: True)')\nprint(f'  正常000002.SZ通过: {result.loc[\\\"b\\\", \\\"execution_rejected\\\"]} (expected: False)')\nprint(f'  跌停000003.SZ卖出拒绝: {result.loc[\\\"c\\\", \\\"execution_rejected\\\"]} (expected: True)')\nassert result.loc['a', 'execution_rejected'] == True, 'Bug: 000001.SZ should be rejected'\nassert result.loc['b', 'execution_rejected'] == False, 'Bug: 000002.SZ should pass'\nassert result.loc['c', 'execution_rejected'] == True, 'Bug: 000003.SZ sell should be rejected'\nprint()\nprint('✅ 索引错位 Bug 已修复')\n\" 2>&1"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5-highspeed","usage":{"input":115338,"output":843,"cacheRead":19793,"cacheWrite":0,"totalTokens":135974,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775580671392,"responseId":"062468ff0abe3a0deab1ab70041b1dfd"}}
