out['error'] = str(e)\\n    print(json.dumps(out, ensure_ascii=False, indent=2))\\n    sys.exit(0)\\n\\ntry:\\n    jar = bc3.edge(domain_name='10jqka.com.cn')\\n    cookies = []\\n    for c in jar:\\n        cookies.append({'name': c.name, 'domain': c.domain, 'expires': c.expires})\\n    out = {'ok': True, 'cookie_count': len(cookies), 'cookies': cookies[:50]}\\nexcept Exception as e:\\n    out = {'ok': False, 'stage': 'load', 'error': str(e)}\\nprint(json.dumps(out, ensure_ascii=False, indent=2))\\nPY\",\"timeout\":30,\"workdir\":\"/Users/ling/.openclaw/workspace/coding-agent\"}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":5023,"output":532,"cacheRead":54144,"cacheWrite":0,"totalTokens":59699,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776232371262,"responseId":"resp_03f39fddca6188290169df27b4eb688198b10e3c5b92f65da4"}}
