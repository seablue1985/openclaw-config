     res.update({'ok': False, 'stage': 'launch', 'error': str(e)})\n        out.write_text(json.dumps(res, ensure_ascii=False, indent=2), encoding='utf-8')\n        print(out)\n        sys.exit(0)\n    try:\n        page = context.new_page()\n        page.goto(page_url, wait_until='domcontentloaded', timeout=30000)\n        page.wait_for_timeout(8000)\n        body = ''\n        try:\n            body = page.locator('body').inner_text(timeout=8000)\n        except Exception:\n            body = ''\n        cookies = context.cookies(['https://tzzb.10jqka.com.cn'])\n        res.update({\n            'ok': True,\n            'final_url': page.url,\n            'title': page.title(),\n            'content_snippet': body[:1200],\n            'cookie_names': sorted([c.get('name','') for c in cookies]),\n            'cookie_count': len(cookies),\n        })\n    except Exception as e:\n        res.update({'ok': False, 'stage': 'navigate', 'error': str(e)})\n    finally:\n        try:\n            context.close()\n        except Exception:\n            pass\n\nout.write_text(json.dumps(res, ensure_ascii=False, indent=2), encoding='utf-8')\nprint(out)\nPY","timeout":180,"workdir":"/Users/ling/.openclaw/workspace/coding-agent"},"partialJson":"{\"command\":\"python3 - <<'PY'\\nfrom pathlib import Path\\nimport shutil, json, sys, tempfile\\nfrom playwright.sync_api import sync_playwright\\n\\nsrc_root = Path.home() / 'Library/Application Support/Microsoft Edge'\\nprofile = 'Default'\\npage_url = 'https://tzzb.10jqka.com.cn/pc/index.html#/myAccount/a/C6QIQGQ'\\nout = Path('/tmp/tzzb_playwright_check_copy.json')\\n\\ntmp_root = Path(tempfile.mkdtemp(prefix='edge-ths-'))\\nuser_data_dir = tmp_root / 'UserData'\\nuser_data_dir.mkdir(parents=True, exist_ok=True)\\n\\n# copy minimal files needed for cookies/local state/profile storage\\nfor name in ['Local State']:\\n    src = src_root / name\\n    if src.exists():\\n        shutil.copy2(src, user_data_dir / name)\\n\\nsrc_profile = src_root / profile\\ndst_profile = user_data_dir / profile\\nshutil.copytree(src_profile, dst_profile, dirs_exist_ok=True, ignore=shutil.ignore_patterns(\\n    'Cache', 'Code Cache', 'GPUCache', 'Service Worker', 'GrShaderCache', 'ShaderCache',\\n    'Crashpad', 'Singleton*', 'lockfile', 'BrowserMetrics*', 'Dawn*', 'GraphiteDawnCache'\\n))\\n\\nres = {'copied_to': str(user_data_dir)}\\nwith sync_playwright() as p:\\n    try:\\n        context = p.chromium.launch_persistent_context(\\n            user_data_dir=str(user_data_dir),\\n            channel='msedge',\\n            headless=True,\\n            args=['--profile-directory=Default', '--disable-blink-features=AutomationControlled']\\n        )\\n    except Exception as e:\\n        res.update({'ok': False, 'stage': 'launch', 'error': str(e)})\\n        out.write_text(json.dumps(res, ensure_ascii=False, indent=2), encoding='utf-8')\\n        print(out)\\n        sys.exit(0)\\n    try:\\n        page = context.new_page()\\n        page.goto(page_url, wait_until='domcontentloaded', timeout=30000)\\n        page.wait_for_timeout(8000)\\n        body = ''\\n        try:\\n            body = page.locator('body').inner_text(timeout=8000)\\n        except Exception:\\n            body = ''\\n        cookies = context.cookies(['https://tzzb.10jqka.com.cn'])\\n        res.update({\\n            'ok': True,\\n            'final_url': page.url,\\n            'title': page.title(),\\n            'content_snippet': body[:1200],\\n            'cookie_names': sorted([c.get('name','') for c in cookies]),\\n            'cookie_count': len(cookies),\\n        })\\n    except Exception as e:\\n        res.update({'ok': False, 'stage': 'navigate', 'error': str(e)})\\n    finally:\\n        try:\\n            context.close()\\n        except Exception:\\n            pass\\n\\nout.write_text(json.dumps(res, ensure_ascii=False, indent=2), encoding='utf-8')\\nprint(out)\\nPY\",\"timeout\":180,\"workdir\":\"/Users/ling/.openclaw/workspace/coding-agent\"}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":51823,"output":947,"cacheRead":0,"cacheWrite":0,"totalTokens":52770,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776232243700,"responseId":"resp_03f39fddca6188290169df273725c0819890b62d3d6f4460a4"}}
