alse, indent=2), encoding='utf-8')\nprint(out)\nPY","timeout":120,"workdir":"/Users/ling/.openclaw/workspace/coding-agent"},"partialJson":"{\"command\":\"python3 - <<'PY'\\nfrom pathlib import Path\\nimport json, sys\\nfrom playwright.sync_api import sync_playwright\\n\\nuser_data_dir = str(Path.home() / 'Library/Application Support/Microsoft Edge')\\npage_url = 'https://tzzb.10jqka.com.cn/pc/index.html#/myAccount/a/C6QIQGQ'\\nout = Path('/tmp/tzzb_playwright_check.json')\\nres = {}\\n\\nwith sync_playwright() as p:\\n    browser_type = p.chromium\\n    try:\\n        context = browser_type.launch_persistent_context(\\n            user_data_dir=user_data_dir,\\n            channel='msedge',\\n            headless=True,\\n            args=['--profile-directory=Default', '--disable-blink-features=AutomationControlled']\\n        )\\n    except Exception as e:\\n        out.write_text(json.dumps({'ok': False, 'stage': 'launch', 'error': str(e)}, ensure_ascii=False, indent=2), encoding='utf-8')\\n        print(out)\\n        sys.exit(0)\\n    try:\\n        page = context.new_page()\\n        page.goto(page_url, wait_until='domcontentloaded', timeout=30000)\\n        page.wait_for_timeout(5000)\\n        res = {\\n            'ok': True,\\n            'final_url': page.url,\\n            'title': page.title(),\\n            'content_snippet': page.locator('body').inner_text(timeout=5000)[:1000],\\n            'cookies': [\\n                {k:v for k,v in c.items() if k in ('name','domain','path','expires')}\\n                for c in context.cookies(['https://tzzb.10jqka.com.cn'])\\n            ]\\n        }\\n    except Exception as e:\\n        res = {'ok': False, 'stage': 'navigate', 'error': str(e)}\\n    finally:\\n        try:\\n            context.close()\\n        except Exception:\\n            pass\\n\\nout.write_text(json.dumps(res, ensure_ascii=False, indent=2), encoding='utf-8')\\nprint(out)\\nPY\",\"timeout\":120,\"workdir\":\"/Users/ling/.openclaw/worksp