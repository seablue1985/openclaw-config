, 'height': 1200})\n    page = context.new_page()\n    try:\n        target = 'https://tzzb.10jqka.com.cn/pc/index.html#/myAccount/a/C6QIQGQ'\n        page.goto(target, wait_until='domcontentloaded', timeout=30000)\n        page.wait_for_timeout(5000)\n        step('opened', url=page.url, title=page.title())\n        page.screenshot(path=str(out_dir / '01_open.png'), full_page=True)\n\n        # collect frames and inputs\n        frames = []\n        for i, fr in enumerate(page.frames):\n            try:\n                frames.append({'i': i, 'name': fr.name, 'url': fr.url})\n            except Exception:\n                pass\n        result['frames_before'] = frames\n\n        # try click login-ish buttons in main page\n        clicked = False\n        candidates = [\n            'text=登录', 'text=立即登录', 'text=账号登录', 'text=去登录',\n            '[class*=\"login\"]', '[id*=\"login\"]', 'button:has-text(\"登录\")'\n        ]\n        for sel in candidates:\n            try:\n                loc = page.locator(sel).first\n                if loc.count() > 0 and loc.is_visible(timeout=1000):\n                    loc.click(timeout=2000)\n                    page.wait_for_timeout(3000)\n                    step('clicked_login_candidate', selector=sel, url=page.url)\n                    clicked = True\n                    break\n            except Exception:\n                continue\n\n        # maybe a login iframe/script appears\n        page.screenshot(path=str(out_dir / '02_after_click.png'), full_page=True)\n        frames = []\n        for i, fr in enumerate(page.frames):\n            try:\n                frames.append({'i': i, 'name': fr.name, 'url': fr.url})\n            except Exception:\n                pass\n        result['frames_after'] = frames\n\n        def fill_in_frame(fr, label):\n            info = {'label': label, 'url': fr.url}\n            try:\n                fr.locator('input[type=\"text\"], input[type=\"email\"], input[placeholder*=\"账\"], input[placeholder*=\"用\"], input[name*=\"user\" i], input[id*=\"user\" i]').first.fill(USERNAME, timeout=3000)\n                info['user_filled'] = True\n            except Exception as e:\n                info['user_filled'] = False\n                info['user_err'] = str(e)\n            try:\n                fr.locator('input[type=\"password\"]').first.fill(PASSWORD, timeout=3000)\n                info['pass_filled'] = True\n            except Exception as e:\n                info['pass_filled'] = False\n                info['pass_err'] = str(e)\n            try:\n                # click login submit\n                btns = [\n                    'button:has-text(\"登录\")', 'text=登录', 'input[type=\"submit\"]',\n                    '[class*=\"submit\"]', '[class*=\"login\"] button'\n                ]\n                clicked_sel = None\n                for sel in btns:\n                    try:\n                        loc = fr.locator(sel).first\n                        if loc.count() > 0 and loc.is_visible(timeout=1000):\n                            loc.click(timeout=3000)\n                            clicked_sel = sel\n                            break\n                    except Exception:\n                        pass\n                info['clicked'] = clicked_sel\n            except Exception as e:\n                info['click_err'] = str(e)\n            return info\n\n        fills = []\n        fills.append(fill_in_frame(page.main_frame, 'main_frame'))\n        for idx, fr in enumerate(page.frames):\n            if fr == page.main_frame:\n                continue\n            try:\n                fills.append(fill_in_frame(fr, f'frame_{idx}'))\n            except Exception as e:\n                fills.append({'label': f'frame_{idx}', 'url': getattr(fr, 'url', ''), 'error': str(e)})\n        result['fill_attempts'] = fills\n\n        page.wait_for_timeout(8000)\n        page.screenshot(path=str(out_dir / '03_post_submit.png'), full_page=True)\n\n        body_text = ''\n        try:\n            body_text = page.locator('body').inner_text(timeout=5000)[:2000]\n        except Exception as e:\n            body_text = f'<body unavailable: {e}>'\n        cookies = context.cookies(['https://tzzb.10jqka.com.cn', 'https://upass.10jqka.com.cn'])\n        result.update({\n            'final_url': page.url,\n            'title': page.title(),\n            'body_text': body_text,\n            'cookie_names': sorted([c['name'] for c in cookies]),\n            'cookie_count': len(cookies),\n        })\n\n    except Exception as e:\n        result['fatal_error'] = str(e)\n    finally:\n        context.close()\n        browser.close()\n\n(out_dir / 'result.json').write_text(json.dumps(result, ensure_ascii=False, indent=2), encoding='utf-8')\nprint(str(out_dir / 'result.json'))\nPY","timeout":180,"workdir":"/Users/ling/.openclaw/workspace/coding-agent"},"partialJson":"{\"command\":\"python3 - <<'PY'\\nfrom pathlib import Path\\nimport json, tempfile, shutil\\nfrom playwright.sync_api import sync_playwright, TimeoutError as PWTimeout\\n\\nUSERNAME = \\\"seablue1985\\\"\\nPASSWORD = \\\"sea1985823\\\"\\n\\nout_dir = Path('/tmp/ths-login-attempt')\\nout_dir.mkdir(parents=True, exist_ok=True)\\nresult = {'steps': []}\\n\\ndef step(msg, **kw):\\n    entry = {'msg': msg}\\n    entry.update(kw)\\n    result['steps'].append(entry)\\n\\nwith sync_playwright() as p:\\n    browser = p.chromium.launch(channel='msedge', headless=True)\\n    context = browser.new_context(viewport={'width': 1440, 'height': 1200})\\n    page = context.new_page()\\n    try:\\n        target = 'https://tzzb.10jqka.com.cn/pc/index.html#/myAccount/a/C6QIQGQ'\\n        page.goto(target, wait_until='domcontentloaded', timeout=30000)\\n        page.wait_for_timeout(5000)\\n        step('opened', url=page.url, title=page.title())\\n        page.screenshot(path=str(out_dir / '01_open.png'), full_page=True)\\n\\n        # collect frames and inputs\\n        frames = []\\n        for i, fr in enumerate(page.frames):\\n            try:\\n                frames.append({'i': i, 'name': fr.name, 'url': fr.url})\\n            except Exception:\\n                pass\\n        result['frames_before'] = frames\\n\\n        # try click login-ish buttons in main page\\n        clicked = False\\n        candidates = [\\n            'text=登录', 'text=立即登录', 'text=账号登录', 'text=去登录',\\n            '[class*=\\\"login\\\"]', '[id*=\\\"login\\\"]', 'button:has-text(\\\"登录\\\")'\\n        ]\\n        for sel in candidates:\\n            try:\\n                loc = page.locator(sel).first\\n                if loc.count() > 0 and loc.is_visible(timeout=1000):\\n                    loc.click(timeout=2000)\\n                    page.wait_for_timeout(3000)\\n                    step('clicked_login_candidate', selector=sel, url=page.url)\\n                    clicked = True\\n                    break\\n            except Exception:\\n                continue\\n\\n        # maybe a login iframe/script appears\\n        page.screenshot(path=str(out_dir / '02_after_click.png'), full_page=True)\\n        frames = []\\n        for i, fr in enumerate(page.frames):\\n            try:\\n                frames.append({'i': i, 'name': fr.name, 'url': fr.url})\\n            except Exception:\\n                pass\\n        result['frames_after'] = frames\\n\\n        def fill_in_frame(fr, label):\\n            info = {'label': label, 'url': fr.url}\\n            try:\\n                fr.locator('input[type=\\\"text\\\"], input[type=\\\"email\\\"], input[placeholder*=\\\"账\\\"], input[placeholder*=\\\"用\\\"], input[name*=\\\"user\\\" i], input[id*=\\\"user\\\" i]').first.fill(USERNAME, timeout=3000)\\n                info['user_filled'] = True\\n            except Exception as e:\\n                info['user_filled'] = False\\n                info['user_err'] = str(e)\\n            try:\\n                fr.locator('input[type=\\\"password\\\"]').first.fill(PASSWORD, timeout=3