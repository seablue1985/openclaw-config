{"type":"message","id":"d6a5fecc","parentId":"f6156638","timestamp":"2026-04-10T06:23:05.021Z","message":{"role":"assistant","content":[{"type":"text","text":"    继续创建回测与实盘对比模块："},{"type":"toolCall","id":"functions.write:34","name":"write","arguments":{"content":"\"\"\"\n回测与实盘对比分析 - 检测策略失效\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nfrom typing import Dict, Tuple\nimport scipy.stats as stats\n\n\nclass BacktestLiveComparator:\n    \"\"\"\n    回测与实盘对比分析器\n    \"\"\"\n    \n    def __init__(self):\n        self.divergence_threshold = 0.20  # 偏差20%触发警告\n        \n    def compare(self, \n                backtest_returns: pd.Series,\n                live_returns: pd.Series,\n                strategy_name: str = \"策略\") -> Dict:\n        \"\"\"\n        对比回测与实盘表现\n        \"\"\"\n        # 对齐时间\n        common_start = max(backtest_returns.index[0], live_returns.index[0])\n        common_end = min(backtest_returns.index[-1], live_returns.index[-1])\n        \n        bt = backtest_returns[common_start:common_end]\n        live = live_returns[common_start:common_end]\n        \n        if len(bt) != len(live):\n            bt = bt.resample('D').sum().fillna(0)\n            live = live.resample('D').sum().fillna(0)\n            \n        # 计算累计收益\n        bt_cum = (1 + bt).cumprod()\n        live_cum = (1 + live).cumprod()\n        \n        # 各项指标对比\n        comparison = {\n            'strategy_name': strategy_name,\n            'period': f\"{common_start.date()} ~ {common_end.date()}\",\n            'days': len(bt),\n            \n            # 收益对比\n            'backtest_return': bt_cum.iloc[-1] - 1,\n            'live_return': live_cum.iloc[-1] - 1,\n            'return_gap': (live_cum.iloc[-1] - 1) - (bt_cum.iloc[-1] - 1),\n            'return_gap_pct': ((live_cum.iloc[-1] - 1) - (bt_cum.iloc[-1] - 1)) / abs(bt_cum.iloc[-1] - 1) if (bt_cum.iloc[-1] - 1) != 0 else 0,\n            \n            # 风险对比\n            'backtest_volatility': bt.std() * np.sqrt(252),\n            'live_volatility': live.std() * np.sqrt(252),\n            \n            # 夏普对比\n            'backtest_sharpe': bt.mean() * 252 / (bt.std() * np.sqrt(252)) if bt.std() > 0 else 0,\n            'live_sharpe': live.mean() * 252 / (live.std() * np.sqrt(252)) if live.std() > 0 else 0,\n            \n            # 统计检验\n            'mean_difference_tstat': self._t_test(bt, live),\n            'variance_ratio': (live.std() / bt.std()) ** 2 if bt.std() > 0 else 0,\n            \n            # 相关性\n            'correlation': bt.corr(live),\n        }\n        \n        # 评估偏差程度\n        comparison['divergence_level'] = self._assess_divergence(comparison)\n        \n        return comparison\n        \n    def _t_test(self, backtest: pd.Series, live: pd.Series) -> Dict:\n        \"\"\"t检验：均值差异显著性\"\"\"\n        try:\n            t_stat, p_value = stats.ttest_ind(backtest, live)\n            return {\n                't_statistic': float(t_stat),\n                'p_value': float(p_value),\n                'significant': p_value < 0.05\n            }\n        except:\n            return {'t_statistic': 0, 'p_value': 1, 'significant': False}\n            \n    def _assess_divergence(self, comparison: Dict) -> str:\n        \"\"\"评估偏差程度\"\"\"\n        gap_pct = abs(comparison['return_gap_pct'])\n        corr = comparison['correlation']\n        \n        if gap_pct > 0.5 or corr < 0.3:\n            return \"SEVERE\"\n        elif gap_pct > 0.2 or corr < 0.7:\n            return \"MODERATE\"\n        elif gap_pct > 0.1:\n            return \"MILD\"\n        else:\n            return \"NORMAL\"\n            \n    def generate_report(self, comparison: Dict) -> str:\n        \"\"\"生成对比报告\"\"\"\n        level_emoji = {\n            'NORMAL': '🟢',\n            'MILD': '🟡',\n            'MODERATE': '🟠',\n            'SEVERE': '🔴'\n        }\n        \n        emoji = level_emoji.get(comparison['divergence_level'], '⚪')\n        \n        report = f\"\"\"\n{emoji} 回测-实盘对比报告: {comparison['strategy_name']}\n{'='*60}\n\n对比期间: {comparison['period']} ({comparison['days']} 个交易日)\n\n【收益对比】\n  回测收益: {comparison['backtest_return']*100:.2f}%\n  实盘收益: {comparison['live_return']*100:.2f}%\n  收益差距: {comparison['return_gap']*100:.2f}% ({comparison['return_gap_pct']*100:+.1f}%)\n  \n【风险对比】\n  回测波动: {comparison['backtest_volatility']*100:.2f}%\n  实盘波动: {comparison['live_volatility']*100:.2f}%\n  方差比: {comparison['variance_ratio']:.2f}\n  \n【夏普对比】\n  回测夏普: {comparison['backtest_sharpe']:.3f}\n  实盘夏普: {comparison['live_sharpe']:.3f}\n  \n【相关性分析】\n  日收益相关系数: {comparison['correlation']:.3f}\n  \n【统计检验】\n  均值差异显著性: {'显著' if comparison['mean_difference_tstat']['significant'] else '不显著'}\n  (p-value: {comparison['mean_difference_tstat']['p_value']:.4f})\n\n【偏差评估】\n  偏差等级: {comparison['divergence_level']}\n  \n{self._get_recommendation(comparison['divergence_level'])}\n\"\"\"\n        return report\n        \n    def _get_recommendation(self, level: str) -> str:\n        \"\"\"根据偏差等级给出建议\"\"\"\n        recommendations = {\n            'NORMAL': \"✅ 回测与实盘表现一致，策略可信度高\",\n            'MILD': \"⚠️ 存在轻微偏差，建议关注并分析原因（如滑点、交易成本）\",\n            'MODERATE': \"⚠️ 中度偏差！建议：\\n  1. 检查策略逻辑是否有未来函数\\n  2. 重新审视交易成本假设\\n  3. 考虑降低仓位或暂停策略\",\n            'SEVERE': \"🚨 严重偏差！策略可能失效，建议：\\n  1. 立即停止实盘交易\\n  2. 全面复盘策略逻辑\\n  3. 检查数据质量和执行问题\"\n        }\n        return recommendations.get(level, \"请人工评估\")\n\n\nclass StrategyDecayDetector:\n    \"\"\"\n    策略失效检测器\n    \"\"\"\n    \n    def __init__(self, window: int = 30):\n        self.window = window\n        \n    def detect_decay(self, returns: pd.Series) -> Dict:\n        \"\"\"\n        检测策略是否失效\n        \"\"\"\n        if len(returns) < self.window * 2:\n            return {'status': 'INSUFFICIENT_DATA'}\n            \n        # 分两段比较\n        recent = returns.tail(self.window)\n        historical = returns.iloc[-self.window*2:-self.window]\n        \n        # 统计检验\n        t_stat, p_value = stats.ttest_ind(recent, historical)\n        \n        # 计算趋势\n        from scipy import stats as scipy_stats\n        x = np.arange(len(recent))\n        slope, intercept, r_value, p_value_trend, std_err = scipy_stats.linregress(x, recent.values)\n        \n        # 判断失效\n        decay_signals = []\n        \n        # 1. 收益显著下降\n        if recent.mean() < historical.mean() * 0.5:\n            decay_signals.append(\"近期收益显著低于历史\")\n            \n        # 2. 夏普比率下降\n        recent_sharpe = recent.mean() / recent.std() if recent.std() > 0 else 0\n        hist_sharpe = historical.mean() / historical.std() if historical.std() > 0 else 0\n        if recent_sharpe < hist_sharpe * 0.5:\n            decay_signals.append(\"夏普比率显著下降\")\n            \n        # 3. 趋势向下\n        if slope < 0 and p_value_trend < 0.1:\n            decay_signals.append(\"收益趋势向下\")\n            \n        # 4. 波动率异常\n        if recent.std() > historical.std() * 1.5:\n            decay_signals.append(\"波动率异常升高\")\n            \n        # 综合判断\n        if len(decay_signals) >= 3:\n            status = \"CRITICAL\"\n        elif len(decay_signals) >= 2:\n            status = \"WARNING\"\n        elif len(decay_signals) >= 1:\n            status = \"ATTENTION\"\n        else:\n            status = \"NORMAL\"\n            \n        return {\n            'status': status,\n            'decay_signals': decay_signals,\n            'recent_return': recent.mean() * 252,\n            'historical_return': historical.mean() * 252,\n            'recent_sharpe': recent_sharpe * np.sqrt(252),\n            'historical_sharpe': hist_sharpe * np.sqrt(252),\n            'trend_slope': slope,\n            'trend_pvalue': p_value_trend\n        }\n","path":"/Users/ling/quant/monitoring/backtest_vs_live.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":2816,"output":2397,"cacheRead":70464,"cacheWrite":0,"totalTokens":75677,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775802107207,"responseId":"7e80578d9c0341b59b90610eab440df3"}}
{"type":"message","id":"c36bc591","parentId":"d6a5fecc","timestamp":"2026-04-10T06:23:05.121Z","message":{"role":"toolResult","toolCallId":"functions.write:34","toolName":"write","content":[{"type":"text","text":"Successfully wrote 7144 bytes to /Users/ling/quant/monitoring/backtest_vs_live.py"}],"isError":false,"timestamp":1775802185115}}
{"type":"message","id":"1e12c3f7","parentId":"c36bc591","timestamp":"2026-04-10T06:24:09.574Z","message":{"role":"assistant","content":[{"type":"text","text":"     现在创建一个策略模板文件，方便用户快速创建新策略："},{"type":"toolCall","id":"functions.write:35","name":"write","arguments":{"content":"\"\"\"\n策略模板 - 复制此文件创建新策略\n\n命名规范: your_strategy_name.py\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom strategies.framework.backtest_engine import BaseStrategy, BacktestConfig, BacktestReporter\n\n\nclass MyStrategy(BaseStrategy):\n    \"\"\"\n    策略名称: [填写策略名称]\n    \n    策略逻辑:\n    [详细描述策略逻辑]\n    \n    买入条件:\n    - [条件1]\n    - [条件2]\n    \n    卖出条件:\n    - [条件1]\n    - [条件2]\n    \n    风险控制:\n    - [风控措施]\n    \"\"\"\n    \n    def __init__(self, config: BacktestConfig, \n                 param1: int = 10,      # 参数说明\n                 param2: float = 0.5,   # 参数说明\n                 position_pct: float = 0.8):\n        \"\"\"\n        初始化策略\n        \n        Args:\n            config: 回测配置\n            param1: 参数1说明\n            param2: 参数2说明\n            position_pct: 仓位比例\n        \"\"\"\n        super().__init__(config)\n        self.param1 = param1\n        self.param2 = param2\n        self.position_pct = position_pct\n        \n        # 初始化指标缓存\n        self.indicator_cache = {}\n        \n    def initialize(self, data: pd.DataFrame):\n        \"\"\"\n        策略初始化 - 预计算指标\n        \"\"\"\n        super().initialize(data)\n        \n        # 预计算技术指标\n        # self.indicator_cache['ma_short'] = data['close'].rolling(self.param1).mean()\n        # self.indicator_cache['ma_long'] = data['close'].rolling(self.param2).mean()\n        \n    def on_bar(self, date: pd.Timestamp, bar_data: pd.Series) -> dict:\n        \"\"\"\n        每个Bar触发，返回交易信号\n        \n        Args:\n            date: 当前日期\n            bar_data: 当前Bar数据 (open, high, low, close, volume)\n            \n        Returns:\n            交易信号或None\n            {\n                'action': 'BUY' or 'SELL',\n                'symbol': '000001.SZ',\n                'shares': 1000  # 股数\n            }\n        \"\"\"\n        # 获取当前持仓\n        symbol = '000001.SZ'  # 交易标的\n        current_position = self.positions.get(symbol, 0)\n        \n        # 确保有足够的历史数据\n        if self.current_idx < self.param1:\n            return None\n            \n        # ========== 在这里编写你的策略逻辑 ==========\n        \n        # 示例：计算移动平均线\n        # hist = self.data.iloc[:self.current_idx+1]\n        # ma_short = hist['close'].tail(self.param1).mean()\n        # ma_long = hist['close'].tail(self.param2).mean()\n        \n        # 买入信号示例\n        buy_signal = False  # 替换为你的买入条件\n        \n        if buy_signal and current_position == 0:\n            # 计算买入股数\n            target_value = self.config.initial_capital * self.position_pct\n            shares = int(target_value / bar_data['close'] / 100) * 100  # 整手\n            \n            return {\n                'action': 'BUY',\n                'symbol': symbol,\n                'shares': shares\n            }\n            \n        # 卖出信号示例\n        sell_signal = False  # 替换为你的卖出条件\n        \n        if sell_signal and current_position > 0:\n            return {\n                'action': 'SELL',\n                'symbol': symbol,\n                'shares': current_position\n            }\n            \n        return None\n        \n    def calculate_position_size(self, signal_strength: float) -> int:\n        \"\"\"\n        计算仓位大小（可选）\n        \n        Args:\n            signal_strength: 信号强度 0-1\n            \n        Returns:\n            股数\n        \"\"\"\n        base_position = self.config.initial_capital * self.position_pct\n        adjusted_position = base_position * signal_strength\n        shares = int(adjusted_position / 100) * 100\n        return shares\n\n\ndef run_backtest():\n    \"\"\"\n    运行回测\n    \"\"\"\n    import os\n    \n    # 1. 加载数据\n    # 从文件加载\n    # data = pd.read_csv('data/stocks/000001.SZ.csv', index_col='date', parse_dates=True)\n    \n    # 或使用模拟数据测试\n    np.random.seed(42)\n    dates = pd.date_range('2020-01-01', '2023-12-31', freq='B')\n    n = len(dates)\n    returns = np.random.normal(0.0005, 0.02, n)\n    price = 100 * (1 + returns).cumprod()\n    \n    data = pd.DataFrame({\n        'open': price * (1 + np.random.uniform(-0.01, 0.01, n)),\n        'high': price * (1 + np.random.uniform(0, 0.02, n)),\n        'low': price * (1 + np.random.uniform(-0.02, 0, n)),\n        'close': price,\n        'volume': np.random.randint(1000000, 10000000, n)\n    }, index=dates)\n    \n    # 2. 配置\n    config = BacktestConfig(\n        start_date='2020-01-01',\n        end_date='2023-12-31',\n        initial_capital=1_000_000,\n        commission_rate=0.0003,  # 万3佣金\n        slippage=0.001,          # 千1滑点\n    )\n    \n    # 3. 运行回测\n    print(\"=\" * 50)\n    print(\"运行策略回测...\")\n    print(\"=\" * 50)\n    \n    strategy = MyStrategy(\n        config,\n        param1=10,\n        param2=20,\n        position_pct=0.8\n    )\n    \n    metrics = strategy.run_backtest(data)\n    \n    # 4. 输出结果\n    print(f\"\\n📊 回测结果:\")\n    print(f\"   总收益: {metrics['total_return']:.2f}%\")\n    print(f\"   年化收益: {metrics['annual_return']:.2f}%\")\n    print(f\"   夏普比率: {metrics['sharpe_ratio']:.3f}\")\n    print(f\"   最大回撤: {metrics['max_drawdown']:.2f}%\")\n    print(f\"   胜率: {metrics['win_rate']:.1f}%\")\n    print(f\"   交易次数: {metrics['total_trades']}\")\n    \n    # 5. 生成报告\n    os.makedirs('results/backtest_reports', exist_ok=True)\n    \n    report_path = 'results/backtest_reports/my_strategy_report.md'\n    BacktestReporter.generate_report(\n        '我的策略',\n        {\n            'param1': 10,\n            'param2': 20,\n            'position_pct': 0.8\n        },\n        metrics,\n        report_path\n    )\n    \n    print(f\"\\n✅ 报告已保存: {report_path}\")\n    \n    return metrics\n\n\nif __name__ == '__main__':\n    run_backtest()\n","path":"/Users/ling/quant/strategies/your_strategies/strategy_template.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":2433,"output":1825,"cacheRead":73280,"cacheWrite":0,"totalTokens":77538,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775802185122,"responseId":"9e6a1be573964a318f53a3aa2132dc0d"}}
