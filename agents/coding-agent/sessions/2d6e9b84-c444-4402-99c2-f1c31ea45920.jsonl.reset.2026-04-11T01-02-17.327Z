{"type":"message","id":"6128881b","parentId":"e0f5e1e2","timestamp":"2026-04-10T10:22:37.404Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's a formatting error. Let me fix it - `diff` is already a percentage value, not needing `*100` since it's calculated from already percentage values. Let me debug and fix the code.\n","thinkingSignature":"d58adb250534e44f5fdd0dcf8d9797e4bc5723b1ad25f57d29599e487f2c0adf"},{"type":"toolCall","id":"call_a1ff69f227b7403ea7cff640","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport baostock as bs\nimport pandas as pd\nimport numpy as np\nimport warnings\nwarnings.filterwarnings('ignore')\n\nlg = bs.login()\nrs = bs.query_history_k_data_plus('sh.000300', 'date,open,high,low,close,volume',\n    start_date='2024-01-01', end_date='2026-04-10', frequency='d')\ndata_list = []\nwhile rs.error_code == '0' and rs.next():\n    data_list.append(rs.get_row_data())\ndf = pd.DataFrame(data_list, columns=rs.fields)\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date')\nfor col in ['open','high','low','close','volume']:\n    df[col] = pd.to_numeric(df[col], errors='coerce')\ndf = df.dropna()\nbs.logout()\n\nbenchmark = (df.iloc[-1]['close'] / df.iloc[0]['close'] - 1)\nprint(f\"沪深300买入持有: {benchmark*100:.1f}%\\n\")\n\ndef rsi_ma_strategy(data, rsi_p, os, ma_s, ma_l):\n    sig = pd.Series(0, index=data.index)\n    delta = data['close'].diff()\n    gain = delta.where(delta > 0, 0).rolling(rsi_p).mean()\n    loss = (-delta.where(delta < 0, 0)).rolling(rsi_p).mean()\n    rsi = 100 - (100 / (1 + gain/(loss+1e-10)))\n    ma_s_ = data['close'].rolling(ma_s).mean()\n    ma_l_ = data['close'].rolling(ma_l).mean()\n    sig[rsi < os] = 1\n    sig[(ma_s_ < ma_l_) & (ma_s_.shift(1) >= ma_l_.shift(1))] = -1\n    return sig\n\ndef backtest(data, signals):\n    capital = 100000.0\n    cash = capital\n    shares = 0\n    trades = []\n    \n    equity_dates = []\n    equity_values = []\n    current_cash = cash\n    current_shares = 0\n    \n    for date, row in data.iterrows():\n        price = row['close']\n        equity_dates.append(date)\n        equity_values.append(current_cash + current_shares * price)\n        \n        if date not in signals.index or pd.isna(signals.loc[date]):\n            continue\n        \n        sig = signals.loc[date]\n        \n        if sig == 1 and current_shares == 0 and current_cash > price:\n            n = int(current_cash / price * 0.95)\n            if n > 0:\n                current_cash -= n * price * 1.0003\n                current_shares = n\n                trades.append(('BUY', date.date(), price))\n        elif sig == -1 and current_shares > 0:\n            current_cash += current_shares * price * 0.9997\n            trades.append(('SELL', date.date(), price))\n            current_shares = 0\n    \n    final_price = data.iloc[-1]['close']\n    final_value = current_cash + current_shares * final_price\n    total_ret = (final_value - capital) / capital\n    annual = (1 + total_ret) ** (252 / len(data)) - 1\n    \n    equity = pd.Series(equity_values, index=equity_dates)\n    returns = equity.pct_change().dropna()\n    sharpe = returns.mean() / returns.std() * np.sqrt(252) if returns.std() > 0 else 0\n    peak = equity.cummax()\n    max_dd = ((equity - peak) / peak).min()\n    \n    buys = [t for t in trades if t[0]=='BUY']\n    sells = [t for t in trades if t[0]=='SELL']\n    wins = sum(1 for i,t in enumerate(sells) if i < len(buys) and t[2] > buys[i][2])\n    win = wins / len(sells) if sells else 0\n    \n    return {'total': total_ret, 'annual': annual, 'sharpe': sharpe, 'max_dd': max_dd, 'trades': len(trades), 'win': win, 'trades_list': trades}\n\n# 测试参数\nparams = [\n    (7, 25, 5, 20),   # 之前最优\n    (7, 25, 8, 25),   # 新参数\n    (6, 25, 3, 25),\n    (6, 20, 5, 30),\n    (5, 20, 10, 25),\n    (6, 30, 3, 25),\n]\n\nprint(\"=\" * 65)\nprint(\"参数测试\")\nprint(\"=\" * 65)\nprint(f\"{'策略':<18} {'总收益':>8} {'年化':>8} {'夏普':>6} {'回撤':>8} {'交易':>5}\")\nprint(\"-\" * 65)\n\nresults = []\nfor rp, os, ms, ml in params:\n    sig = rsi_ma_strategy(df, rp, os, ms, ml)\n    r = backtest(df, sig)\n    name = f\"RSI({rp},{os})MA({ms}/{ml})\"\n    results.append((name, r))\n    print(f\"{name:<18} {r['total']*100:>7.2f}% {r['annual']*100:>7.2f}% {r['sharpe']:>6.3f} {r['max_dd']*100:>7.2f}% {r['trades']:>5}\")\n\nresults.sort(key=lambda x: x[1]['total'], reverse=True)\n\nprint()\nprint(f\"基准沪深300: {benchmark*100:.1f}%\")\nbest_name, best_r = results[0]\ndiff = (best_r['total'] - benchmark) * 100\nprint(f\"\\n🏆 最佳: {best_name}\")\nprint(f\"   收益: {best_r['total']*100:.2f}% (vs基准 {diff:+.2f}%)\")\nprint(f\"   年化: {best_r['annual']*100:.2f}% | 夏普: {best_r['sharpe']:.3f} | 回撤: {best_r['max_dd']*100:.2f}%\")\n\nprint()\nprint(\"📋 最近10笔交易:\")\nfor t in best_r['trades_list'][-10:]:\n    print(f\"   {t[0]} {t[1]} {t[2]:.2f}\")\nEOF","timeout":30}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":1831,"output":1528,"cacheRead":84288,"cacheWrite":0,"totalTokens":87647,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775816517644,"responseId":"06280246e18ccfe93801c3b4405750a3"}}
