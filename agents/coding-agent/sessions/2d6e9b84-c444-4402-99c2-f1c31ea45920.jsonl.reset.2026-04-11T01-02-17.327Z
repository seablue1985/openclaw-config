ig, BacktestEngine, BacktestReporter\n\n\ndef get_stock_data(symbol: str, start_date: str, end_date: str) -> pd.DataFrame:\n    \"\"\"使用 AKShare 获取真实股票数据\"\"\"\n    try:\n        # 尝试获取 A 股日线数据\n        df = ak.stock_zh_a_hist(symbol=symbol, start_date=start_date, \n                               end_date=end_date, adjust=\"qfq\")\n        if df is not None and len(df) > 0:\n            df.columns = ['date', 'open', 'close', 'high', 'low', 'volume', 'amount', 'amplitude', 'change\n... (truncated)"},"isError":false,"timestamp":1775811057279}}
{"type":"message","id":"bf4a6e5f","parentId":"fcbd18c5","timestamp":"2026-04-10T08:51:31.345Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"语法错误太多，直接重写这个脚本。\n","thinkingSignature":"2a452439986a763d37f47267dda54caaf712b99d08f1113ea2bf6c0e9347a198"},{"type":"toolCall","id":"call_function_8pvot53tm9u6_1","name":"exec","arguments":{"command":"python3 -c \"\nimport sys\nsys.path.insert(0, '/Users/ling/quant/strategies/framework')\nfrom backtest_engine import BacktestConfig, BacktestEngine\nimport akshare as ak\nimport pandas as pd\nimport warnings\nwarnings.filterwarnings('ignore')\n\nprint('获取沪深300数据...')\ndf = ak.stock_zh_index_daily(symbol='000300')\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date').sort_index()\ndf = df['2020':][['open', 'high', 'low', 'close', 'volume']].astype(float)\nprint(f'数据: {len(df)} 条, {df.index[0]}~{df.index[-1]}')\n\nconfig = BacktestConfig(initial_capital=100000, commission=0.0003, slippage=0.001)\nengine = BacktestEngine(config)\n\n# 均线金叉策略\ndef ma_cross(data):\n    signals = pd.Series(0, index=data.index)\n    ma5 = data['close'].rolling(5).mean()\n    ma20 = data['close'].rolling(20).mean()\n    cross = (ma5 > ma20) & (ma5.shift(1) <= ma20.shift(1))\n    signals[cross] = 1\n    death = (ma5 < ma20) & (ma5.shift(1) >= ma20.shift(1))\n    signals[death] = -1\n    return signals\n\nresult = engine.run(data=df, strategy_func=ma_cross, name='MA金叉')\nprint(f'MA金叉: 收益={result[\\\"total_return\\\"]:.2%}, 夏普={result[\\\"sharpe\\\"]:.3f}, 交易={result[\\\"trade_count\\\"]}')\n\" 2>&1","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":460,"output":428,"cacheRead":110128,"cacheWrite":0,"totalTokens":111016,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775811057286,"responseId":"0627ecf19b0cb80a12e76f59fdc0d5fe"}}
