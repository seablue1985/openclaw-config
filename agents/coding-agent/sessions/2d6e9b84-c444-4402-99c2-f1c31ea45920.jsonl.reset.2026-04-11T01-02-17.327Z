{"type":"message","id":"413e8fbf","parentId":"2ce11771","timestamp":"2026-04-10T03:50:15.352Z","message":{"role":"assistant","content":[{"type":"text","text":"    继续创建监控面板代码："},{"type":"toolCall","id":"functions.write:16","name":"write","arguments":{"content":"\"\"\"\nStreamlit 监控面板 - 量化系统实时监控\n\"\"\"\n\nimport streamlit as st\nimport pandas as pd\nimport numpy as np\nimport psycopg2\nimport plotly.graph_objects as go\nimport plotly.express as px\nfrom datetime import datetime, timedelta\nimport os\n\nst.set_page_config(\n    page_title=\"量化交易系统监控\",\n    page_icon=\"📊\",\n    layout=\"wide\",\n    initial_sidebar_state=\"expanded\"\n)\n\n# 数据库连接\ndef get_db_conn():\n    return psycopg2.connect(\n        host=os.getenv('DB_HOST', 'quant-db'),\n        port=os.getenv('DB_PORT', '5432'),\n        user=os.getenv('DB_USER', 'quant'),\n        password=os.getenv('DB_PASS', 'quant_pass'),\n        database=os.getenv('DB_NAME', 'quant_db')\n    )\n\n# 页面标题\nst.title(\"📊 量化交易系统监控面板\")\n\n# 侧边栏\nst.sidebar.header(\"导航\")\npage = st.sidebar.radio(\"选择页面\", [\n    \"系统概览\",\n    \"策略监控\", \n    \"数据状态\",\n    \"回测结果\",\n    \"策略对比\"\n])\n\nif page == \"系统概览\":\n    st.header(\"系统概览\")\n    \n    # 关键指标卡片\n    col1, col2, col3, col4 = st.columns(4)\n    \n    try:\n        conn = get_db_conn()\n        \n        # 股票数量\n        cur = conn.cursor()\n        cur.execute(\"SELECT COUNT(DISTINCT symbol) FROM stock_daily\")\n        stock_count = cur.fetchone()[0]\n        \n        # 数据条数\n        cur.execute(\"SELECT COUNT(*) FROM stock_daily\")\n        data_count = cur.fetchone()[0]\n        \n        # 最新数据日期\n        cur.execute(\"SELECT MAX(trade_date) FROM stock_daily\")\n        latest_date = cur.fetchone()[0]\n        \n        # 回测数量\n        cur.execute(\"SELECT COUNT(*) FROM backtest_results\")\n        backtest_count = cur.fetchone()[0]\n        \n        cur.close()\n        conn.close()\n        \n        col1.metric(\"股票数量\", f\"{stock_count}\")\n        col2.metric(\"数据条数\", f\"{data_count:,}\")\n        col3.metric(\"最新数据\", str(latest_date))\n        col4.metric(\"回测记录\", f\"{backtest_count}\")\n        \n    except Exception as e:\n        st.error(f\"数据库连接失败: {e}\")\n    \n    # 数据更新日志\n    st.subheader(\"最近数据更新\")\n    try:\n        conn = get_db_conn()\n        df_logs = pd.read_sql(\"\"\"\n            SELECT data_type, symbol, update_date, records_count, status, created_at\n            FROM data_update_log\n            ORDER BY created_at DESC\n            LIMIT 20\n        \"\"\", conn)\n        conn.close()\n        \n        # 状态颜色\n        def color_status(val):\n            if val == 'SUCCESS':\n                return 'background-color: #d4edda'\n            elif val == 'FAILED':\n                return 'background-color: #f8d7da'\n            return ''\n        \n        st.dataframe(df_logs.style.applymap(color_status, subset=['status']))\n    except Exception as e:\n        st.warning(f\"无法加载更新日志: {e}\")\n\nelif page == \"策略监控\":\n    st.header(\"策略健康度监控\")\n    \n    try:\n        conn = get_db_conn()\n        \n        # 获取策略列表\n        df_monitor = pd.read_sql(\"\"\"\n            SELECT DISTINCT ON (strategy_name)\n                strategy_name, check_date, return_7d, return_30d,\n                max_drawdown, sharpe_30d, status, anomalies\n            FROM strategy_monitor\n            ORDER BY strategy_name, check_date DESC\n        \"\"\", conn)\n        \n        if not df_monitor.empty:\n            # 状态统计\n            status_counts = df_monitor['status'].value_counts()\n            \n            col1, col2, col3 = st.columns(3)\n            col1.metric(\"🟢 健康\", status_counts.get('HEALTHY', 0))\n            col2.metric(\"🟡 警告\", status_counts.get('WARNING', 0))\n            col3.metric(\"🔴 严重\", status_counts.get('CRITICAL', 0))\n            \n            # 详细表格\n            st.subheader(\"策略详情\")\n            \n            def highlight_status(val):\n                if val == 'HEALTHY':\n                    return 'color: green'\n                elif val == 'WARNING':\n                    return 'color: orange'\n                elif val == 'CRITICAL':\n                    return 'color: red'\n                return ''\n            \n            st.dataframe(\n                df_monitor.style.applymap(highlight_status, subset=['status'])\n            )\n        else:\n            st.info(\"暂无策略监控数据\")\n            \n        conn.close()\n        \n    except Exception as e:\n        st.error(f\"加载策略监控失败: {e}\")\n\nelif page == \"数据状态\":\n    st.header(\"数据质量监控\")\n    \n    try:\n        conn = get_db_conn()\n        \n        # 各股票数据覆盖情况\n        df_coverage = pd.read_sql(\"\"\"\n            SELECT \n                symbol,\n                COUNT(*) as record_count,\n                MIN(trade_date) as start_date,\n                MAX(trade_date) as end_date\n            FROM stock_daily\n            GROUP BY symbol\n            ORDER BY record_count DESC\n        \"\"\", conn)\n        \n        if not df_coverage.empty:\n            st.subheader(\"数据覆盖情况\")\n            st.dataframe(df_coverage)\n            \n            # 数据完整性图表\n            fig = px.bar(\n                df_coverage.head(20),\n                x='symbol',\n                y='record_count',\n                title='Top 20 股票数据量'\n            )\n            st.plotly_chart(fig, use_container_width=True)\n        else:\n            st.info(\"暂无数据\")\n            \n        conn.close()\n        \n    except Exception as e:\n        st.error(f\"加载数据状态失败: {e}\")\n\nelif page == \"回测结果\":\n    st.header(\"策略回测结果\")\n    \n    try:\n        conn = get_db_conn()\n        \n        # 获取回测结果\n        df_results = pd.read_sql(\"\"\"\n            SELECT \n                strategy_name, symbol, start_date, end_date,\n                total_return, annual_return, max_drawdown, sharpe_ratio,\n                total_trades, created_at\n            FROM backtest_results\n            ORDER BY created_at DESC\n            LIMIT 100\n        \"\"\", conn)\n        \n        if not df_results.empty:\n            # 筛选\n            strategies = df_results['strategy_name'].unique().tolist()\n            selected_strategy = st.selectbox(\"选择策略\", [\"全部\"] + strategies)\n            \n            if selected_strategy != \"全部\":\n                df_results = df_results[df_results['strategy_name'] == selected_strategy]\n            \n            st.dataframe(df_results)\n            \n            # 收益分布图\n            fig = px.scatter(\n                df_results,\n                x='annual_return',\n                y='sharpe_ratio',\n                color='max_drawdown',\n                size='total_trades',\n                hover_data=['strategy_name', 'symbol'],\n                title='策略收益-风险分布'\n            )\n            st.plotly_chart(fig, use_container_width=True)\n        else:\n            st.info(\"暂无回测结果\")\n            \n        conn.close()\n        \n    except Exception as e:\n        st.error(f\"加载回测结果失败: {e}\")\n\nelif page == \"策略对比\":\n    st.header(\"多策略对比分析\")\n    \n    try:\n        conn = get_db_conn()\n        \n        # 获取最新回测结果\n        df = pd.read_sql(\"\"\"\n            SELECT DISTINCT ON (strategy_name)\n                strategy_name, total_return, annual_return, \n                max_drawdown, sharpe_ratio, sortino_ratio, calmar_ratio\n            FROM backtest_results\n            ORDER BY strategy_name, created_at DESC\n        \"\"\", conn)\n        \n        if not df.empty:\n            # 雷达图对比\n            metrics = ['annual_return', 'sharpe_ratio', 'sortino_ratio', 'calmar_ratio']\n            \n            fig = go.Figure()\n            \n            for _, row in df.iterrows():\n                fig.add_trace(go.Scatterpolar(\n                    r=[row[m] for m in metrics],\n                    theta=metrics,\n                    fill='toself',\n                    name=row['strategy_name']\n                ))\n            \n            fig.update_layout(\n                polar=dict(radialaxis=dict(visible=True)),\n                showlegend=True,\n                title='策略多维度对比'\n            )\n            \n            st.plotly_chart(fig, use_container_width=True)\n            \n            # 详细对比表\n            st.dataframe(df.set_index('strategy_name'))\n        else:\n            st.info(\"暂无策略数据\")\n            \n        conn.close()\n        \n    except Exception as e:\n        st.error(f\"加载策略对比失败: {e}\")\n\n# 页脚\nst.sidebar.markdown(\"---\")\nst.sidebar.info(\"量化交易系统 v1.0\")\n","path":"/Users/ling/quant/docker/dashboard/src/app.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":106,"output":2215,"cacheRead":53952,"cacheWrite":0,"totalTokens":56273,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775792937163,"responseId":"7ef9657dd46e4065bdacb3558ef17b31"}}
