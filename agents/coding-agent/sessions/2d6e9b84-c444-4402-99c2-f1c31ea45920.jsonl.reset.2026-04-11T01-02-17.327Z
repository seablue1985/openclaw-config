{"type":"message","id":"b112006c","parentId":"70f5d7ee","timestamp":"2026-04-10T07:32:08.058Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_hOaajXOYISVLd0koYx9vJ6","name":"write","arguments":{"content":"\"\"\"\n批量回测 - 对所有迁移的策略进行回测验证\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nimport sys\nimport os\nfrom datetime import datetime\n\nsys.path.insert(0, '/Users/ling/quant')\n\nfrom strategies.framework.backtest_engine import BacktestConfig, BacktestReporter\nfrom strategies.framework.validation import StrategyValidator\nfrom strategies.framework.strategy_comparison import StrategyComparison\nfrom strategies.framework.data_quality import DataQualityChecker\nfrom strategies.framework.whitepaper import StrategyWhitepaper\nfrom strategies.framework.pre_launch_checklist import run_standard_checks\n\nfrom strategies.your_strategies.migrated_strategies import STRATEGY_REGISTRY\n\n\ndef generate_test_data(n_days: int = 1000, seed: int = 42) -> pd.DataFrame:\n    \"\"\"生成模拟A股行情数据\"\"\"\n    np.random.seed(seed)\n    dates = pd.date_range('2020-01-02', periods=n_days, freq='B')\n    \n    # 模拟带趋势+震荡的走势\n    trend = np.cumsum(np.random.normal(0.0003, 0.001, n_days))\n    noise = np.random.normal(0, 0.02, n_days)\n    returns = trend + noise\n    \n    price = 20 * np.exp(np.cumsum(returns))\n    \n    # 生成 OHLCV\n    data = pd.DataFrame(index=dates)\n    data['close'] = price\n    data['open'] = price * (1 + np.random.uniform(-0.01, 0.01, n_days))\n    data['high'] = np.maximum(data['open'], data['close']) * (1 + np.random.uniform(0, 0.015, n_days))\n    data['low'] = np.minimum(data['open'], data['close']) * (1 - np.random.uniform(0, 0.015, n_days))\n    data['volume'] = np.random.randint(5_000_000, 50_000_000, n_days).astype(float)\n    \n    # 模拟量价关系：涨时放量\n    for i in range(1, n_days):\n        if data['close'].iloc[i] > data['close'].iloc[i-1]:\n            data.iloc[i, data.columns.get_loc('volume')] *= np.random.uniform(1.0, 1.5)\n        else:\n            data.iloc[i, data.columns.get_loc('volume')] *= np.random.uniform(0.6, 1.0)\n            \n    return data\n\n\ndef run_all_backtests():\n    \"\"\"\n    运行所有迁移策略的回测\n    \"\"\"\n    print(\"=\" * 70)\n    print(\"量化策略批量回测\")\n    print(f\"时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n    print(\"=\" * 70)\n    \n    # 1. 生成测试数据\n    print(\"\\n📊 1. 生成测试数据...\")\n    data = generate_test_data(n_days=1000)\n    print(f\"   数据: {data.index[0].date()} ~ {data.index[-1].date()}, {len(data)} 条\")\n    \n    # 2. 数据质量检查\n    print(\"\\n🔍 2. 数据质量检查...\")\n    checker = DataQualityChecker()\n    quality_report = checker.check_dataframe(data, 'TEST_DATA')\n    print(f\"   质量评分: {quality_report.quality_score:.1f}/100 [{quality_report.status}]\")\n    \n    # 3. 回测配置\n    config = BacktestConfig(\n        start_date=str(data.index[0].date()),\n        end_date=str(data.index[-1].date()),\n        initial_capital=1_000_000,\n        commission_rate=0.0003,\n        slippage=0.001,\n        stamp_duty=0.001,\n    )\n    \n    # 4. 逐策略回测\n    print(\"\\n🚀 3. 运行策略回测...\\n\")\n    \n    all_results = {}\n    comparison = StrategyComparison()\n    \n    for key, info in STRATEGY_REGISTRY.items():\n        strategy_class = info['class']\n        name = info['name']\n        default_params = info['default_params']\n        \n        print(f\"   📈 {name} ({key})...\")\n        \n        try:\n            strategy = strategy_class(config, **default_params)\n            metrics = strategy.run_backtest(data)\n            \n            all_results[key] = {\n                'name': name,\n                'metrics': metrics,\n                'strategy': strategy\n            }\n            \n            # 提取日收益序列用于对比\n            if strategy.daily_values:\n                df_values = pd.DataFrame(strategy.daily_values)\n                df_values.set_index('date', inplace=True)\n                daily_returns = df_values['total_value'].pct_change().dropna()\n                comparison.add_strategy(name, daily_returns)\n            \n            # 打印结果\n            sharpe_icon = \"✅\" if metrics['sharpe_ratio'] > 1 else \"⚠️\" if metrics['sharpe_ratio'] > 0.5 else \"❌\"\n            dd_icon = \"✅\" if abs(metrics['max_drawdown']) < 20 else \"⚠️\" if abs(metrics['max_drawdown']) < 30 else \"❌\"\n            \n            print(f\"      收益: {metrics['total_return']:.2f}% | \"\n                  f\"年化: {metrics['annual_return']:.2f}% | \"\n                  f\"夏普: {metrics['sharpe_ratio']:.3f} {sharpe_icon} | \"\n                  f\"回撤: {metrics['max_drawdown']:.2f}% {dd_icon} | \"\n                  f\"交易: {metrics['total_trades']}次\")\n                  \n        except Exception as e:\n            print(f\"      ❌ 回测失败: {e}\")\n            all_results[key] = {'name': name, 'metrics': None, 'error': str(e)}\n            \n    # 5. 策略对比\n    print(\"\\n📊 4. 策略对比分析...\\n\")\n    \n    if len(comparison.results) > 0:\n        comparison_df = comparison.compare()\n        print(comparison_df.to_string())\n        \n        # 保存对比图\n        os.makedirs('/Users/ling/quant/results/comparisons', exist_ok=True)\n        try:\n            comparison.plot_comparison(\n                save_path='/Users/ling/quant/results/comparisons/all_strategies.html',\n                use_plotly=True\n            )\n            print(\"\\n   对比图已保存: results/comparisons/all_strategies.html\")\n        except Exception as e:\n            print(f\"\\n   对比图生成跳过: {e}\")\n    \n    # 6. 策略验证（对表现最好的策略做WFA）\n    print(\"\\n🧪 5. 策略验证 (Walk-Forward Analysis)...\\n\")\n    \n    # 找出夏普最高的策略\n    best_key = None\n    best_sharpe = -np.inf\n    for key, result in all_results.items():\n        if result.get('metrics') and result['metrics']['sharpe_ratio'] > best_sharpe:\n            best_sharpe = result['metrics']['sharpe_ratio']\n            best_key = key\n            \n    if best_key:\n        best_info = STRATEGY_REGISTRY[best_key]\n        best_name = best_info['name']\n        best_class = best_info['class']\n        best_params = best_info['default_params']\n        \n        print(f\"   最优策略: {best_name} (夏普: {best_sharpe:.3f})\")\n        print(f\"   运行 Walk-Forward 验证...\")\n        \n        validator = StrategyValidator(data)\n        \n        try:\n            wfa_result = validator.walk_forward_analysis(\n                best_class, config,\n                train_size=252,\n                test_size=63,\n                step_size=63\n            )\n            \n            print(f\"\\n   稳健性评分: {wfa_result['robust_score']}/100\")\n            print(f\"   正收益比例: {wfa_result['positive_ratio']*100:.1f}%\")\n            print(f\"   平均夏普: {wfa_result['avg_sharpe']:.3f}\")\n            \n            if wfa_result['robust_score'] >= 70:\n                print(\"   ✅ 策略通过稳健性测试！\")\n            elif wfa_result['robust_score'] >= 50:\n                print(\"   ⚠️  策略需要优化\")\n            else:\n                print(\"   ❌ 策略未通过测试\")\n        except Exception as e:\n            print(f\"   验证跳过: {e}\")\n            wfa_result = None\n    else:\n        wfa_result = None\n        \n    # 7. 生成报告\n    print(\"\\n📝 6. 生成报告...\\n\")\n    \n    os.makedirs('/Users/ling/quant/results/backtest_reports', exist_ok=True)\n    os.makedirs('/Users/ling/quant/docs/strategy_whitepapers', exist_ok=True)\n    \n    for key, result in all_results.items():\n        if not result.get('metrics'):\n            continue\n            \n        info = STRATEGY_REGISTRY[key]\n        metrics = result['metrics']\n        \n        # 回测报告\n        BacktestReporter.generate_report(\n            info['name'],\n            info['default_params'],\n            metrics,\n            f'/Users/ling/quant/results/backtest_reports/{key}_report.md'\n        )\n        \n        # 策略白皮书\n        StrategyWhitepaper.generate(\n            strategy_name=info['name'],\n            version='1.0.0',\n            author='量化系统',\n            logic_description=f\"基于 {info['source']} 迁移的策略\",\n            entry_conditions=['见策略源文件'],\n            exit_conditions=['见策略源文件'],\n            risk_controls=['仓位限制', '止损止盈'],\n            params=info['default_params'],\n            backtest_metrics=metrics,\n            validation_result=wfa_result if key == best_key else None,\n            output_path=f'/Users/ling/quant/docs/strategy_whitepapers/{key}_whitepaper.md'\n        )\n        \n    print(f\"   已生成 {sum(1 for r in all_results.values() if r.get('metrics'))} 份回测报告\")\n    print(f\"   已生成 {sum(1 for r in all_results.values() if r.get('metrics'))} 份策略白皮书\")\n    \n    # 8. 上线检查（最优策略）\n    if best_key and all_results[best_key].get('metrics'):\n        print(f\"\\n🔒 7. 上线前检查 ({STRATEGY_REGISTRY[best_key]['name']})...\\n\")\n        \n        checklist = run_standard_checks(\n            strategy_name=STRATEGY_REGISTRY[best_key]['name'],\n            version='1.0.0',\n            backtest_metrics=all_results[best_key]['metrics'],\n            validation_result=wfa_result,\n            has_whitepaper=True,\n            has_risk_controls=True,\n            data_quality_passed=quality_report.status == 'PASS'\n        )\n        \n        report = checklist.generate_report(\n            f'/Users/ling/quant/results/backtest_reports/{best_key}_prelaunch.md'\n        )\n        \n        if checklist.is_ready():\n            print(\"   ✅ 策略通过上线检查！可进入模拟盘阶段\")\n        else:\n            failed = checklist.get_failed_items()\n            print(f\"   ❌ 策略未通过上线检查，{len(failed)} 项未通过:\")\n            for item in failed:\n                tag = \"🔴 必过\" if item.mandatory else \"🟡 建议\"\n                print(f\"      {tag}: {item.name} - {item.notes}\")\n    \n    # 9. 汇总\n    print(\"\\n\" + \"=\" * 70)\n    print(\"回测汇总\")\n    print(\"=\" * 70)\n    \n    print(f\"\\n{'策略名称':<15} {'总收益':>10} {'年化收益':>10} {'夏普':>8} {'最大回撤':>10} {'交易':>6} {'评价':<8}\")\n    print(\"-\" * 70)\n    \n    for key, result in all_results.items():\n        if not result.get('metrics'):\n            print(f\"{result['name']:<15} {'❌ 回测失败':>50}\")\n            continue\n            \n        m = result['metrics']\n        \n        # 评价\n        if m['sharpe_ratio'] > 1.5 and abs(m['max_drawdown']) < 15:\n            grade = \"🟢 优秀\"\n        elif m['sharpe_ratio'] > 1.0 and abs(m['max_drawdown']) < 25:\n            grade = \"🟡 良好\"\n        elif m['sharpe_ratio'] > 0.5:\n            grade = \"🟠 一般\"\n        else:\n            grade = \"🔴 不佳\"\n            \n        print(f\"{result['name']:<15} {m['total_return']:>9.2f}% {m['annual_return']:>9.2f}% \"\n              f\"{m['sharpe_ratio']:>7.3f} {m['max_drawdown']:>9.2f}% {m['total_trades']:>5d} {grade:<8}\")\n    \n    print(\"\\n\" + \"=\" * 70)\n    print(\"📁 输出文件:\")\n    print(f\"   回测报告: results/backtest_reports/\")\n    print(f\"   策略白皮书: docs/strategy_whitepapers/\")\n    print(f\"   策略对比: results/comparisons/\")\n    print(\"=\" * 70)\n    \n    return all_results\n\n\nif __name__ == '__main__':\n    results = run_all_backtests()\n","path":"/Users/ling/quant/strategies/your_strategies/run_all_backtests.py"}}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":6000,"output":3907,"cacheRead":145372,"cacheWrite":0,"totalTokens":155279,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775806264842,"responseId":"58766898-b219-4b44-9660-289a056fb959"}}
