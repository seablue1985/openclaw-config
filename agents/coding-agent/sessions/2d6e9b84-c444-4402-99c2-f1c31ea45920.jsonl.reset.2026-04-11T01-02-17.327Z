{"type":"message","id":"91f4055b","parentId":"41b5756f","timestamp":"2026-04-10T08:49:57.784Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"回测运行了，但结果不佳因为用的是模拟数据。需要使用真实 AKShare 数据来测试。让我创建一个使用真实数据的回测脚本。\n","thinkingSignature":"6345aefac6db9b6bcb24654dde5fef4097a1ef5265b947d51830152a908b6fb9"},{"type":"text","text":"\n\n回测框架运行成功！但因为用模拟数据所以结果差。现在用真实 AKShare 数据回测：\n"},{"type":"toolCall","id":"call_function_a6jm3fkjs7n6_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n真实数据回测 - 使用 AKShare 获取真实市场数据\n\"\"\"\nimport sys\nimport warnings\nwarnings.filterwarnings('ignore')\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nimport akshare as ak\n\n# 添加框架路径\nsys.path.insert(0, '/Users/ling/quant/strategies/framework')\nfrom backtest_engine import BacktestConfig, BacktestEngine, BacktestReporter\n\n\ndef get_stock_data(symbol: str, start_date: str, end_date: str) -> pd.DataFrame:\n    \"\"\"使用 AKShare 获取真实股票数据\"\"\"\n    try:\n        # 尝试获取 A 股日线数据\n        df = ak.stock_zh_a_hist(symbol=symbol, start_date=start_date, \n                               end_date=end_date, adjust=\"qfq\")\n        if df is not None and len(df) > 0:\n            df.columns = ['date', 'open', 'close', 'high', 'low', 'volume', 'amount', 'amplitude', 'change_pct', 'change', 'turnover']\n            df['date'] = pd.to_datetime(df['date'])\n            df = df.set_index('date').sort_index()\n            df = df[['open', 'high', 'low', 'close', 'volume']].astype(float)\n            return df\n    except Exception as e:\n        print(f\"获取 {symbol} 数据失败: {e}\")\n    \n    return pd.DataFrame()\n\n\ndef get_index_data(symbol: str = \"000300\", start_date: str = \"20200101\") -> pd.DataFrame:\n    \"\"\"获取指数数据\"\"\"\n    try:\n        df = ak.stock_zh_index_daily(symbol=symbol)\n        if df is not None and len(df) > 0:\n            df['date'] = pd.to_datetime(df['date'])\n            df = df.set_index('date').sort_index()\n            df = df[start_date:][['open', 'high', 'low', 'close', 'volume']].astype(float)\n            return df\n    except Exception as e:\n        print(f\"获取指数数据失败: {e}\")\n    \n    return pd.DataFrame()\n\n\ndef run_real_backtest():\n    \"\"\"运行真实数据回测\"\"\"\n    print(\"=\" * 60)\n    print(\"🎯 真实数据回测 - 使用 AKShare\")\n    print(\"=\" * 60)\n    \n    # 获取沪深300指数数据（代表大盘）\n    print(\"\\n📥 获取沪深300指数数据...\")\n    df = get_index_data(\"000300\", \"20200101\")\n    \n    if df.empty:\n        print(\"❌ 无法获取数据\")\n        return\n    \n    print(f\"✅ 获取到 {len(df)} 条数据\")\n    print(f\"   时间范围: {df.index[0]} ~ {df.index[-1]}\")\n    \n    # 回测配置\n    config = BacktestConfig(\n        initial_capital=100000,\n        commission=0.0003,\n        slippage=0.001,\n    )\n    \n    engine = BacktestEngine(config)\n    \n    # === 策略1: 均线金叉 ===\n    print(\"\\n📈 策略1: 均线金叉\")\n    \n    def ma_cross_strategy(data: pd.DataFrame) -> pd.Series:\n        \"\"\"简单的均线金叉策略\"\"\"\n        signals = pd.Series(0, index=data.index)\n        \n        # 计算均线\n        ma5 = data['close'].rolling(5).mean()\n        ma20 = data['close'].rolling(20).mean()\n        \n        # 金叉买入信号\n        cross = (ma5 > ma20) & (ma5.shift(1) <= (ma20.shift(1))\n        signals[cross] = 1\n        \n        # 死叉卖出信号\n        death_cross = (ma5 < ma20) & (ma5.shift(1) >= (ma20.shift(1)))\n        signals[death_cross] = -1\n        \n        return signals\n    \n    result1 = engine.run(data=df, strategy_func=ma_cross_strategy, name=\"MA金叉\")\n    print(f\"   收益: {result1['total_return']:.2%} | 夏普: {result1['sharpe']:.3f} | 交易: {result1['trade_count']}\")\n    \n    # === 策略2: 突破买入 ===\n    print(\"\\n📈 策略2: 20日高点突破\")\n    \n    def breakout_strategy(data: pd.DataFrame) -> pd.Series:\n        \"\"\"突破20日高点策略\"\"\"\n        signals = pd.Series(0, index=data.index)\n        \n        # 20日高点\n        high_20 = data['high'].rolling(20).max()\n        \n        # 突破买入\n        breakout = data['close'] > high_20.shift(1)\n        signals[breakout] = 1\n        \n        # 跌破5日均线卖出\n        ma5 = data['close'].rolling(5).mean()\n        below_ma5 = data['close'] < ma5.shift(1)\n        signals[below_ma5] = -1\n        \n        return signals\n    \n    result2 = engine.run(data=df, strategy_func=breakout_strategy, name=\"20日突破\")\n    print(f\"   收益: {result2['total_return']:.2%} | 夏普: {result2['sharpe']:.3f} | 交易: {result2['trade_count']}\")\n    \n    # === 策略3: RSI 超卖 ===\n    print(\"\\n📈 策略3: RSI超卖反转\")\n    \n    def rsi_strategy(data: pd.DataFrame) -> pd.Series:\n        \"\"\"RSI超卖策略\"\"\"\n        signals = pd.Series(0, index=data.index)\n        \n        # 计算RSI\n        delta = data['close'].diff()\n        gain = delta.where(delta > 0, 0).rolling(14).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(14).mean()\n        rs = gain / (loss + 1e-10)\n        rsi = 100 - (100 / (1 + rs))\n        \n        # RSI<30买入\n        buy_signal = rsi < 30\n        signals[buy_signal] = 1\n        \n        # RSI>70卖出\n        sell_signal = rsi > 70\n        signals[sell_signal] = -1\n        \n        return signals\n    \n    result3 = engine.run(data=df, strategy_func=rsi_strategy, name=\"RSI反转\")\n    print(f\"   收益: {result3['total_return']:.2%} | 夏普: {result3['sharpe']:.3f} | 交易: {result3['trade_count']}\")\n    \n    # 对比\n    print(\"\\n\" + \"=\" * 60)\n    print(\"📊 策略对比\")\n    print(\"=\" * 60)\n    results = [\n        (\"MA金叉\", result1),\n        (\"20日突破\", result2),\n        (\"RSI反转\", result3),\n    ]\n    \n    print(f\"{'策略':<12} {'收益':>10} {'年化':>10} {'夏普':>8} {'回撤':>8} {'交易':>6}\")\n    print(\"-\" * 60)\n    \n    for name, r in results:\n        print(f\"{name:<12} {r['total_return']:>9.2%} {r['annual_return']:>9.2%} {r['sharpe']:>8.3f} {r['max_drawdown']:>7.2%} {r['trade_count']:>6}\")\n    \n    # 保存报告\n    reporter = BacktestReporter('/Users/ling/quant/results/backtest_reports')\n    for name, r in results:\n        reporter.generate_report(r, name)\n    \n    print(\"\\n✅ 真实数据回测完成!\")\n    print(f\"📁 报告保存于: /Users/ling/quant/results/backtest_reports/\")\n\n\nif __name__ == \"__main__\":\n    run_real_backtest()","path":"/Users/ling/quant/strategies/your_strategies/real_backtest.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":2000,"output":1814,"cacheRead":106016,"cacheWrite":0,"totalTokens":109830,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775810948163,"responseId":"0627ec84074d19a0d3e04b9c29b750a9"}}
