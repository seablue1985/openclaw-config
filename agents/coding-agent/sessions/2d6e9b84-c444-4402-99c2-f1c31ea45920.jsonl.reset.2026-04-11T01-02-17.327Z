{"type":"message","id":"2ecee709","parentId":"f814690b","timestamp":"2026-04-10T03:52:40.504Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create an example strategy to demonstrate how to use the framework.","thinkingSignature":"9b62b9f360097bad3adb906e6b37d61939caa6ffb6006036f761615ecf9c9faf"},{"type":"toolCall","id":"call_function_szumxc9peidl_1","name":"write","arguments":{"content":"\"\"\"\n示例策略：双均线交叉策略\n展示如何基于 BaseStrategy 构建自己的策略\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom strategies.framework.backtest_engine import BaseStrategy, BacktestConfig, BacktestReporter\nimport os\n\n\nclass DualMAStrategy(BaseStrategy):\n    \"\"\"\n    双均线交叉策略\n    \n    买入信号：短期均线上穿长期均线 (金叉)\n    卖出信号：短期均线下穿长期均线 (死叉)\n    \"\"\"\n    \n    def __init__(self, config: BacktestConfig, \n                 short_window: int = 5, \n                 long_window: int = 20,\n                 position_pct: float = 0.8):\n        super().__init__(config)\n        self.short_window = short_window\n        self.long_window = long_window\n        self.position_pct = position_pct\n        \n    def on_bar(self, date, bar_data):\n        \"\"\"每个Bar触发\"\"\"\n        # 确保有足够的历史数据计算均线\n        if self.current_idx < self.long_window:\n            return None\n            \n        # 计算均线\n        hist = self.data.iloc[:self.current_idx+1]\n        ma_short = hist['close'].tail(self.short_window).mean()\n        ma_long = hist['close'].tail(self.long_window).mean()\n        \n        # 获取前一根均线的值\n        prev_hist = self.data.iloc[:self.current_idx]\n        prev_ma_short = prev_hist['close'].tail(self.short_window).mean()\n        prev_ma_long = prev_hist['close'].tail(self.long_window).mean()\n        \n        # 交易标的\n        symbol = '000001.SZ'\n        \n        # 买入逻辑：金叉且当前无持仓或持仓不足\n        if prev_ma_short <= prev_ma_long and ma_short > ma_long:\n            if symbol not in self.positions or self.positions[symbol] == 0:\n                # 计算买入股数\n                target_value = self.config.initial_capital * self.position_pct\n                shares = int(target_value / bar_data['close'] / 100) * 100  # 整手\n                return {\n                    'action': 'BUY',\n                    'symbol': symbol,\n                    'shares': shares\n                }\n                \n        # 卖出逻辑：死叉且持有持仓\n        elif prev_ma_short >= prev_ma_long and ma_short < ma_long:\n            if symbol in self.positions and self.positions[symbol] > 0:\n                return {\n                    'action': 'SELL',\n                    'symbol': symbol,\n                    'shares': self.positions[symbol]\n                }\n                \n        return None\n\n\nclass RSIStrategy(BaseStrategy):\n    \"\"\"\n    RSI 均值回归策略\n    \n    买入信号：RSI < 30 超卖\n    卖出信号：RSI > 70 超买\n    \"\"\"\n    \n    def __init__(self, config: BacktestConfig,\n                 rsi_period: int = 14,\n                 oversold: int = 30,\n                 overbought: int = 70,\n                 position_pct: float = 0.8):\n        super().__init__(config)\n        self.rsi_period = rsi_period\n        self.oversold = oversold\n        self.overbought = overbought\n        self.position_pct = position_pct\n        \n    def _calculate_rsi(self, prices: pd.Series, period: int = 14) -> float:\n        \"\"\"计算RSI\"\"\"\n        delta = prices.diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=period).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=period).mean()\n        \n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        return rsi.iloc[-1]\n        \n    def on_bar(self, date, bar_data):\n        if self.current_idx < self.rsi_period + 5:\n            return None\n            \n        # 计算RSI\n        hist = self.data.iloc[:self.current_idx+1]\n        rsi = self._calculate_rsi(hist['close'], self.rsi_period)\n        \n        symbol = '000001.SZ'\n        \n        # 买入信号\n        if rsi < self.oversold:\n            if symbol not in self.positions or self.positions[symbol] == 0:\n                target_value = self.config.initial_capital * self.position_pct\n                shares = int(target_value / bar_data['close'] / 100) * 100\n                return {\n                    'action': 'BUY',\n                    'symbol': symbol,\n                    'shares': shares\n                }\n                \n        # 卖出信号\n        elif rsi > self.overbought:\n            if symbol in self.positions and self.positions[symbol] > 0:\n                return {\n                    'action': 'SELL',\n                    'symbol': symbol,\n                    'shares': self.positions[symbol]\n                }\n                \n        return None\n\n\ndef run_demo():\n    \"\"\"运行示例回测\"\"\"\n    \n    # 1. 准备数据 (模拟数据，实际从数据库获取)\n    np.random.seed(42)\n    dates = pd.date_range('2020-01-01', '2023-12-31', freq='B')\n    n = len(dates)\n    \n    # 模拟价格走势\n    returns = np.random.normal(0.0005, 0.02, n)\n    price = 100 * (1 + returns).cumprod()\n    \n    data = pd.DataFrame({\n        'open': price * (1 + np.random.uniform(-0.01, 0.01, n)),\n        'high': price * (1 + np.random.uniform(0, 0.02, n)),\n        'low': price * (1 + np.random.uniform(-0.02, 0, n)),\n        'close': price,\n        'volume': np.random.randint(1000000, 10000000, n)\n    }, index=dates)\n    \n    # 2. 配置\n    config = BacktestConfig(\n        start_date='2020-01-01',\n        end_date='2023-12-31',\n        initial_capital=1_000_000,\n        commission_rate=0.0003,\n        slippage=0.001\n    )\n    \n    # 3. 运行双均线策略回测\n    print(\"=\" * 50)\n    print(\"运行双均线策略回测...\")\n    print(\"=\" * 50)\n    \n    strategy = DualMAStrategy(config, short_window=5, long_window=20)\n    metrics = strategy.run_backtest(data)\n    \n    print(f\"\\n总收益: {metrics['total_return']}%\")\n    print(f\"年化收益: {metrics['annual_return']}%\")\n    print(f\"夏普比率: {metrics['sharpe_ratio']}\")\n    print(f\"最大回撤: {metrics['max_drawdown']}%\")\n    print(f\"交易次数: {metrics['total_trades']}\")\n    \n    # 4. 生成报告\n    os.makedirs('results/backtest_reports', exist_ok=True)\n    BacktestReporter.generate_report(\n        '双均线策略',\n        {'short_window': 5, 'long_window': 20},\n        metrics,\n        'results/backtest_reports/dual_ma_report.md'\n    )\n    \n    # 5. 运行RSI策略对比\n    print(\"\\n\" + \"=\" * 50)\n    print(\"运行RSI策略回测...\")\n    print(\"=\" * 50)\n    \n    strategy_rsi = RSIStrategy(config, rsi_period=14)\n    metrics_rsi = strategy_rsi.run_backtest(data)\n    \n    print(f\"\\n总收益: {metrics_rsi['total_return']}%\")\n    print(f\"年化收益: {metrics_rsi['annual_return']}%\")\n    print(f\"夏普比率: {metrics_rsi['sharpe_ratio']}\")\n    print(f\"最大回撤: {metrics_rsi['max_drawdown']}%\")\n    print(f\"交易次数: {metrics_rsi['total_trades']}\")\n    \n    BacktestReporter.generate_report(\n        'RSI策略',\n        {'rsi_period': 14, 'oversold': 30, 'overbought': 70},\n        metrics_rsi,\n        'results/backtest_reports/rsi_report.md'\n    )\n    \n    print(\"\\n✅ 回测完成！报告已保存到 results/backtest_reports/\")\n\n\nif __name__ == '__main__':\n    run_demo()\n","path":"/Users/ling/quant/strategies/demo_strategy.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":2414,"output":1863,"cacheRead":57888,"cacheWrite":0,"totalTokens":62165,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775793144524,"responseId":"0627a6f849e9c0fa86f86adfb9780f07"}}
