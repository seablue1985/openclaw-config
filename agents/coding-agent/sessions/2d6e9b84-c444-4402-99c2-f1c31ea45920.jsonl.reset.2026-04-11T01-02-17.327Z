{"type":"message","id":"f2fc6278","parentId":"a0f3cb0c","timestamp":"2026-04-10T06:37:39.975Z","message":{"role":"assistant","content":[{"type":"text","text":"  明白，继续修复自检发现的其他问题。让我先回顾一下之前自检报告中提到的问题，然后逐一修复。\n\n从之前的自检报告，主要问题包括：\n1. ~~Docker 容器化~~ - 已完成\n2. 策略回测规范化 - 需要补充\n3. 数据质量保障 - 需要补充\n4. 策略有效性验证 - 需要补充\n5. 监控告警 - 需要补充\n\n让我继续完善这些模块。首先，让我创建一个完整的数据质量检查模块："},{"type":"toolCall","id":"functions.write:40","name":"write","arguments":{"content":"\"\"\"\n数据质量检查模块 - 确保数据准确性和完整性\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nfrom typing import Dict, List, Tuple, Optional\nimport logging\nfrom dataclasses import dataclass\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\n\n@dataclass\nclass DataQualityReport:\n    \"\"\"数据质量报告\"\"\"\n    symbol: str\n    check_date: datetime\n    total_records: int\n    missing_records: int\n    missing_rate: float\n    anomalies: List[Dict]\n    quality_score: float  # 0-100\n    status: str  # PASS / WARNING / FAIL\n\n\nclass DataQualityChecker:\n    \"\"\"\n    数据质量检查器\n    \"\"\"\n    \n    def __init__(self):\n        self.anomaly_threshold = {\n            'price_jump': 0.21,      # 涨跌停阈值\n            'volume_zero': 0.1,      # 零成交量比例阈值\n            'missing_rate': 0.05,    # 缺失率阈值\n        }\n        \n    def check_ohlc_logic(self, df: pd.DataFrame) -> List[Dict]:\n        \"\"\"\n        检查OHLC逻辑一致性\n        \n        规则:\n        - high >= max(open, close)\n        - low <= min(open, close)\n        - high >= low\n        \"\"\"\n        anomalies = []\n        \n        # 检查 high < low\n        invalid_hl = df[df['high'] < df['low']]\n        if len(invalid_hl) > 0:\n            anomalies.append({\n                'type': 'HIGH_LOW_INVERSION',\n                'count': len(invalid_hl),\n                'dates': invalid_hl.index.tolist()[:5],\n                'severity': 'CRITICAL'\n            })\n            \n        # 检查 high < max(open, close)\n        invalid_high = df[df['high'] < df[['open', 'close']].max(axis=1)]\n        if len(invalid_high) > 0:\n            anomalies.append({\n                'type': 'HIGH_TOO_LOW',\n                'count': len(invalid_high),\n                'dates': invalid_high.index.tolist()[:5],\n                'severity': 'HIGH'\n            })\n            \n        # 检查 low > min(open, close)\n        invalid_low = df[df['low'] > df[['open', 'close']].min(axis=1)]\n        if len(invalid_low) > 0:\n            anomalies.append({\n                'type': 'LOW_TOO_HIGH',\n                'count': len(invalid_low),\n                'dates': invalid_low.index.tolist()[:5],\n                'severity': 'HIGH'\n            })\n            \n        return anomalies\n        \n    def check_price_jumps(self, df: pd.DataFrame) -> List[Dict]:\n        \"\"\"\n        检查价格异常跳动\n        \n        检测涨跌停、价格跳空等异常\n        \"\"\"\n        anomalies = []\n        \n        # 计算涨跌幅\n        df['price_change'] = df['close'].pct_change()\n        \n        # 检查涨跌停（超过20%视为异常，可能是除权除息未处理）\n        limit_up = df[df['price_change'] > self.anomaly_threshold['price_jump']]\n        limit_down = df[df['price_change'] < -self.anomaly_threshold['price_jump']]\n        \n        if len(limit_up) > 0:\n            anomalies.append({\n                'type': 'LIMIT_UP',\n                'count': len(limit_up),\n                'dates': limit_up.index.tolist()[:5],\n                'severity': 'WARNING',\n                'message': f'发现 {len(limit_up)} 个涨停/大幅跳空，请检查复权处理'\n            })\n            \n        if len(limit_down) > 0:\n            anomalies.append({\n                'type': 'LIMIT_DOWN',\n                'count': len(limit_down),\n                'dates': limit_down.index.tolist()[:5],\n                'severity': 'WARNING',\n                'message': f'发现 {len(limit_down)} 个跌停/大幅跳空，请检查复权处理'\n            })\n            \n        # 检查价格归零或负数\n        invalid_price = df[\n            (df['open'] <= 0) | (df['high'] <= 0) | \n            (df['low'] <= 0) | (df['close'] <= 0)\n        ]\n        if len(invalid_price) > 0:\n            anomalies.append({\n                'type': 'INVALID_PRICE',\n                'count': len(invalid_price),\n                'dates': invalid_price.index.tolist()[:5],\n                'severity': 'CRITICAL'\n            })\n            \n        return anomalies\n        \n    def check_volume_anomalies(self, df: pd.DataFrame) -> List[Dict]:\n        \"\"\"\n        检查成交量异常\n        \"\"\"\n        anomalies = []\n        \n        # 检查零成交量\n        zero_volume = df[df['volume'] == 0]\n        zero_volume_rate = len(zero_volume) / len(df)\n        \n        if zero_volume_rate > self.anomaly_threshold['volume_zero']:\n            anomalies.append({\n                'type': 'ZERO_VOLUME',\n                'count': len(zero_volume),\n                'rate': zero_volume_rate,\n                'severity': 'WARNING',\n                'message': f'零成交量比例 {zero_volume_rate*100:.1f}% 超过阈值'\n            })\n            \n        # 检查成交量异常波动\n        volume_mean = df['volume'].mean()\n        volume_std = df['volume'].std()\n        \n        volume_spike = df[df['volume'] > volume_mean + 5 * volume_std]\n        if len(volume_spike) > 0:\n            anomalies.append({\n                'type': 'VOLUME_SPIKE',\n                'count': len(volume_spike),\n                'dates': volume_spike.index.tolist()[:5],\n                'severity': 'INFO'\n            })\n            \n        return anomalies\n        \n    def check_missing_data(self, df: pd.DataFrame, \n                          expected_dates: pd.DatetimeIndex = None) -> List[Dict]:\n        \"\"\"\n        检查数据缺失情况\n        \"\"\"\n        anomalies = []\n        \n        if expected_dates is not None:\n            # 检查缺失的交易日\n            actual_dates = pd.DatetimeIndex(df.index)\n            missing_dates = expected_dates.difference(actual_dates)\n            \n            if len(missing_dates) > 0:\n                anomalies.append({\n                    'type': 'MISSING_DATES',\n                    'count': len(missing_dates),\n                    'dates': missing_dates.tolist()[:10],\n                    'severity': 'WARNING'\n                })\n                \n        # 检查列缺失\n        required_cols = ['open', 'high', 'low', 'close', 'volume']\n        missing_cols = [col for col in required_cols if col not in df.columns]\n        \n        if missing_cols:\n            anomalies.append({\n                'type': 'MISSING_COLUMNS',\n                'columns': missing_cols,\n                'severity': 'CRITICAL'\n            })\n            \n        # 检查空值\n        null_counts = df.isnull().sum()\n        null_cols = null_counts[null_counts > 0]\n        \n        if len(null_cols) > 0:\n            for col, count in null_cols.items():\n                anomalies.append({\n                    'type': 'NULL_VALUES',\n                    'column': col,\n                    'count': count,\n                    'severity': 'HIGH' if count / len(df) > 0.01 else 'WARNING'\n                })\n                \n        return anomalies\n        \n    def check_duplicates(self, df: pd.DataFrame) -> List[Dict]:\n        \"\"\"\n        检查重复数据\n        \"\"\"\n        anomalies = []\n        \n        # 检查索引重复\n        duplicated = df.index.duplicated()\n        if duplicated.any():\n            anomalies.append({\n                'type': 'DUPLICATE_INDEX',\n                'count': duplicated.sum(),\n                'dates': df.index[duplicated].tolist()[:5],\n                'severity': 'HIGH'\n            })\n            \n        return anomalies\n        \n    def calculate_quality_score(self, df: pd.DataFrame, \n                                anomalies: List[Dict]) -> float:\n        \"\"\"\n        计算数据质量评分 (0-100)\n        \"\"\"\n        score = 100\n        \n        for anomaly in anomalies:\n            severity = anomaly.get('severity', 'INFO')\n            count = anomaly.get('count', 1)\n            \n            if severity == 'CRITICAL':\n                score -= min(30, count * 5)\n            elif severity == 'HIGH':\n                score -= min(20, count * 2)\n            elif severity == 'WARNING':\n                score -= min(10, count * 0.5)\n            elif severity == 'INFO':\n                score -= min(5, count * 0.1)\n                \n        return max(0, score)\n        \n    def check_dataframe(self, df: pd.DataFrame, \n                        symbol: str = 'unknown',\n                        expected_dates: pd.DatetimeIndex = None) -> DataQualityReport:\n        \"\"\"\n        对DataFrame进行全面质量检查\n        \"\"\"\n        all_anomalies = []\n        \n        # 执行各项检查\n        all_anomalies.extend(self.check_ohlc_logic(df))\n        all_anomalies.extend(self.check_price_jumps(df))\n        all_anomalies.extend(self.check_volume_anomalies(df))\n        all_anomalies.extend(self.check_missing_data(df, expected_dates))\n        all_anomalies.extend(self.check_duplicates(df))\n        \n        # 计算缺失率\n        total_cells = df.size\n        missing_cells = df.isnull().sum().sum()\n        missing_rate = missing_cells / total_cells if total_cells > 0 else 0\n        \n        # 计算质量评分\n        quality_score = self.calculate_quality_score(df, all_anomalies)\n        \n        # 确定状态\n        if quality_score >= 90:\n            status = 'PASS'\n        elif quality_score >= 70:\n            status = 'WARNING'\n        else:\n            status = 'FAIL'\n            \n        return DataQualityReport(\n            symbol=symbol,\n            check_date=datetime.now(),\n            total_records=len(df),\n            missing_records=missing_cells,\n            missing_rate=missing_rate,\n            anomalies=all_anomalies,\n            quality_score=quality_score,\n            status=status\n        )\n        \n    def generate_report(self, report: DataQualityReport) -> str:\n        \"\"\"\n        生成质量检查报告\n        \"\"\"\n        lines = [\n            f\"# 数据质量检查报告: {report.symbol}\",\n            f\"\",\n            f\"检查时间: {report.check_date.strftime('%Y-%m-%d %H:%M:%S')}\",\n            f\"\",\n            f\"## 总体评估\",\n            f\"\",\n            f\"质量评分: {report.quality_score:.1f}/100\",\n            f\"状态: {report.status}\",\n            f\"\",\n            f\"## 数据统计\",\n            f\"\",\n            f\"- 总记录数: {report.total_records}\",\n            f\"- 缺失单元格: {report.missing_records}\",\n            f\"- 缺失率: {report.missing_rate*100:.2f}%\",\n            f\"\",\n            f\"## 异常详情\",\n            f\"\",\n        ]\n        \n        if report.anomalies:\n            for anomaly in report.anomalies:\n                severity_emoji = {\n                    'CRITICAL': '🔴',\n                    'HIGH': '🟠',\n                    'WARNING': '🟡',\n                    'INFO': '🔵'\n                }.get(anomaly.get('severity', 'INFO'), '⚪')\n                \n                lines.append(f\"### {severity_emoji} {anomaly['type']}\")\n                lines.append(f\"\")\n                lines.append(f\"- 严重程度: {anomaly.get('severity', 'INFO')}\")\n                lines.append(f\"- 数量: {anomaly.get('count', 'N/A')}\")\n                \n                if 'message' in anomaly:\n                    lines.append(f\"- 说明: {anomaly['message']}\")\n                if 'dates' in anomaly:\n                    lines.append(f\"- 日期: {', '.join(str(d) for d in anomaly['dates'][:5])}\")\n                    \n                lines.append(f\"\")\n        else:\n            lines.append(\"✅ 未发现异常\")\n            \n        return '\\n'.join(lines)\n\n\nclass MultiSourceValidator:\n    \"\"\"\n    多数据源交叉验证\n    \"\"\"\n    \n    def __init__(self):\n        self.price_tolerance = 0.01  # 1%价格容差\n        \n    def validate_cross_source(self, \n                              source1: pd.DataFrame, \n                              source2: pd.DataFrame,\n                              source1_name: str = 'Source1',\n                              source2_name: str = 'Source2') -> Dict:\n        \"\"\"\n        对比两个数据源的数据\n        \"\"\"\n        # 对齐日期\n        common_dates = source1.index.intersection(source2.index)\n        \n        if len(common_dates) == 0:\n            return {\n                'status': 'NO_OVERLAP',\n                'message': '两个数据源没有重叠日期'\n            }\n            \n        s1 = source1.loc[common_dates]\n        s2 = source2.loc[common_dates]\n        \n        discrepancies = []\n        \n        # 对比收盘价\n        price_diff = abs(s1['close'] - s2['close']) / s1['close']\n        significant_diff = price_diff[price_diff > self.price_tolerance]\n        \n        if len(significant_diff) > 0:\n            discrepancies.append({\n                'type': 'PRICE_MISMATCH',\n                'count': len(significant_diff),\n                'max_diff': price_diff.max(),\n                'dates': significant_diff.index.tolist()[:5]\n            })\n            \n        # 对比成交量\n        volume_diff = abs(s1['volume'] - s2['volume']) / s1['volume']\n        significant_vol_diff = volume_diff[volume_diff > self.price_tolerance]\n        \n        if len(significant_vol_diff) > 0:\n            discrepancies.append({\n                'type': 'VOLUME_MISMATCH',\n                'count': len(significant_vol_diff),\n                'max_diff': volume_diff.max(),\n                'dates': significant_vol_diff.index.tolist()[:5]\n            })\n            \n        return {\n            'status': 'DISCREPANCY_FOUND' if discrepancies else 'CONSISTENT',\n            'common_dates': len(common_dates),\n            'discrepancies': discrepancies\n        }\n","path":"/Users/ling/quant/strategies/framework/data_quality.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":78748,"output":3627,"cacheRead":4160,"cacheWrite":0,"totalTokens":86535,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775802921293,"responseId":"5d415e1461a3485f8f2201fd3665cf60"}}
{"type":"message","id":"bbc9c5d1","parentId":"f2fc6278","timestamp":"2026-04-10T06:37:40.057Z","message":{"role":"toolResult","toolCallId":"functions.write:40","toolName":"write","content":[{"type":"text","text":"Successfully wrote 12801 bytes to /Users/ling/quant/strategies/framework/data_quality.py"}],"isError":false,"timestamp":1775803060049}}
{"type":"message","id":"7aeb6959","parentId":"bbc9c5d1","timestamp":"2026-04-10T06:39:25.187Z","message":{"role":"assistant","content":[{"type":"text","text":"     继续创建风险管理模块："},{"type":"toolCall","id":"functions.write:41","name":"write","arguments":{"content":"\"\"\"\n风险管理模块 - 核心风控系统\n\n与策略解耦的独立风控系统\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, time\nfrom typing import Dict, List, Optional, Callable\nfrom dataclasses import dataclass\nfrom enum import Enum\nimport logging\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\n\nclass RiskLevel(Enum):\n    \"\"\"风险等级\"\"\"\n    PASS = \"PASS\"\n    WARNING = \"WARNING\"\n    BLOCK = \"BLOCK\"\n\n\n@dataclass\nclass RiskCheckResult:\n    \"\"\"风控检查结果\"\"\"\n    rule_name: str\n    level: RiskLevel\n    message: str\n    details: Dict = None\n\n\n@dataclass\nclass Order:\n    \"\"\"订单\"\"\"\n    symbol: str\n    action: str  # BUY/SELL\n    shares: int\n    price: float\n    order_type: str = \"MARKET\"\n    strategy_name: str = \"\"\n\n\n@dataclass\nclass Position:\n    \"\"\"持仓\"\"\"\n    symbol: str\n    shares: int\n    avg_cost: float\n    market_value: float\n\n\n@dataclass\nclass Account:\n    \"\"\"账户\"\"\"\n    cash: float\n    positions: Dict[str, Position]\n    total_value: float\n    daily_pnl: float\n\n\nclass RiskRule:\n    \"\"\"风控规则基类\"\"\"\n    \n    def __init__(self, name: str, enabled: bool = True):\n        self.name = name\n        self.enabled = enabled\n        \n    def check(self, order: Order, account: Account, \n              market_data: Dict) -> RiskCheckResult:\n        raise NotImplementedError\n\n\nclass PositionLimitRule(RiskRule):\n    \"\"\"\n    仓位限制规则\n    \n    限制单票最大仓位和总仓位\n    \"\"\"\n    \n    def __init__(self, max_single_position: float = 0.2,\n                 max_total_position: float = 0.95):\n        super().__init__(\"PositionLimit\")\n        self.max_single_position = max_single_position\n        self.max_total_position = max_total_position\n        \n    def check(self, order: Order, account: Account, \n              market_data: Dict) -> RiskCheckResult:\n        if not self.enabled:\n            return RiskCheckResult(self.name, RiskLevel.PASS, \"规则已禁用\")\n            \n        # 计算当前持仓\n        current_position = account.positions.get(order.symbol, None)\n        current_shares = current_position.shares if current_position else 0\n        \n        # 计算交易后的持仓\n        if order.action == \"BUY\":\n            new_shares = current_shares + order.shares\n        else:\n            new_shares = current_shares - order.shares\n            \n        new_value = new_shares * order.price\n        new_ratio = new_value / account.total_value if account.total_value > 0 else 0\n        \n        # 检查单票仓位\n        if new_ratio > self.max_single_position:\n            return RiskCheckResult(\n                self.name, RiskLevel.BLOCK,\n                f\"单票仓位 {new_ratio*100:.1f}% 超过限制 {self.max_single_position*100:.1f}%\",\n                {\"current_ratio\": new_ratio, \"limit\": self.max_single_position}\n            )\n            \n        # 检查总仓位\n        total_position_value = sum(p.market_value for p in account.positions.values())\n        if order.action == \"BUY\":\n            total_position_value += order.shares * order.price\n        total_ratio = total_position_value / account.total_value if account.total_value > 0 else 0\n        \n        if total_ratio > self.max_total_position:\n            return RiskCheckResult(\n                self.name, RiskLevel.BLOCK,\n                f\"总仓位 {total_ratio*100:.1f}% 超过限制 {self.max_total_position*100:.1f}%\",\n                {\"current_ratio\": total_ratio, \"limit\": self.max_total_position}\n            )\n            \n        return RiskCheckResult(\n            self.name, RiskLevel.PASS,\n            f\"仓位检查通过，单票 {new_ratio*100:.1f}%，总仓位 {total_ratio*100:.1f}%\"\n        )\n\n\nclass DailyLossLimitRule(RiskRule):\n    \"\"\"\n    单日亏损限制\n    \"\"\"\n    \n    def __init__(self, max_daily_loss_pct: float = 0.02):\n        super().__init__(\"DailyLossLimit\")\n        self.max_daily_loss_pct = max_daily_loss_pct\n        \n    def check(self, order: Order, account: Account, \n              market_data: Dict) -> RiskCheckResult:\n        if not self.enabled:\n            return RiskCheckResult(self.name, RiskLevel.PASS, \"规则已禁用\")\n            \n        # 检查当日亏损\n        daily_loss_pct = -account.daily_pnl / account.total_value if account.total_value > 0 else 0\n        \n        if daily_loss_pct > self.max_daily_loss_pct:\n            return RiskCheckResult(\n                self.name, RiskLevel.BLOCK,\n                f\"当日亏损 {daily_loss_pct*100:.1f}% 超过限制 {self.max_daily_loss_pct*100:.1f}%\",\n                {\"daily_loss\": daily_loss_pct, \"limit\": self.max_daily_loss_pct}\n            )\n            \n        return RiskCheckResult(\n            self.name, RiskLevel.PASS,\n            f\"当日亏损 {daily_loss_pct*100:.1f}% 在限制范围内\"\n        )\n\n\nclass TradingTimeRule(RiskRule):\n    \"\"\"\n    交易时间限制\n    \"\"\"\n    \n    def __init__(self, \n                 allow_pre_market: bool = False,\n                 allow_after_hours: bool = False,\n                 restricted_times: List[Tuple[time, time]] = None):\n        super().__init__(\"TradingTime\")\n        self.allow_pre_market = allow_pre_market\n        self.allow_after_hours = allow_after_hours\n        self.restricted_times = restricted_times or []\n        \n    def check(self, order: Order, account: Account, \n              market_data: Dict) -> RiskCheckResult:\n        if not self.enabled:\n            return RiskCheckResult(self.name, RiskLevel.PASS, \"规则已禁用\")\n            \n        now = datetime.now().time()\n        \n        # A股交易时间\n        morning_start = time(9, 30)\n        morning_end = time(11, 30)\n        afternoon_start = time(13, 0)\n        afternoon_end = time(15, 0)\n        \n        is_trading_time = (\n            (morning_start <= now <= morning_end) or\n            (afternoon_start <= now <= afternoon_end)\n        )\n        \n        if not is_trading_time:\n            return RiskCheckResult(\n                self.name, RiskLevel.BLOCK,\n                f\"当前时间 {now} 不在交易时段\",\n                {\"current_time\": now}\n            )\n            \n        # 检查限制时段\n        for start, end in self.restricted_times:\n            if start <= now <= end:\n                return RiskCheckResult(\n                    self.name, RiskLevel.WARNING,\n                    f\"当前时间 {now} 在限制时段内\",\n                    {\"restricted_period\": f\"{start} - {end}\"}\n                )\n                \n        return RiskCheckResult(\n            self.name, RiskLevel.PASS,\n            f\"交易时间检查通过\"\n        )\n\n\nclass PriceLimitRule(RiskRule):\n    \"\"\"\n    价格限制规则\n    \n    防止以异常价格下单\n    \"\"\"\n    \n    def __init__(self, max_price_deviation: float = 0.05):\n        super().__init__(\"PriceLimit\")\n        self.max_price_deviation = max_price_deviation\n        \n    def check(self, order: Order, account: Account, \n              market_data: Dict) -> RiskCheckResult:\n        if not self.enabled:\n            return RiskCheckResult(self.name, RiskLevel.PASS, \"规则已禁用\")\n            \n        # 获取最新市场价\n        last_price = market_data.get('last_price', order.price)\n        \n        if last_price <= 0:\n            return RiskCheckResult(\n                self.name, RiskLevel.BLOCK,\n                \"无法获取有效市场价格\",\n                {}\n            )\n            \n        # 检查价格偏离\n        price_deviation = abs(order.price - last_price) / last_price\n        \n        if price_deviation > self.max_price_deviation:\n            return RiskCheckResult(\n                self.name, RiskLevel.WARNING,\n                f\"订单价格 {order.price} 偏离市场价 {last_price} 超过 {self.max_price_deviation*100}%\",\n                {\"order_price\": order.price, \"market_price\": last_price, \n                 \"deviation\": price_deviation}\n            )\n            \n        return RiskCheckResult(\n            self.name, RiskLevel.PASS,\n            f\"价格检查通过，偏离 {price_deviation*100:.2f}%\"\n        )\n\n\nclass SelfTradeRule(RiskRule):\n    \"\"\"\n    自成交检查\n    \n    防止同一策略同时发出买卖信号导致自成交\n    \"\"\"\n    \n    def __init__(self, pending_orders: List[Order] = None):\n        super().__init__(\"SelfTrade\")\n        self.pending_orders = pending_orders or []\n        \n    def check(self, order: Order, account: Account, \n              market_data: Dict) -> RiskCheckResult:\n        if not self.enabled:\n            return RiskCheckResult(self.name, RiskLevel.PASS, \"规则已禁用\")\n            \n        # 检查是否有相反方向的待成交订单\n        for pending in self.pending_orders:\n            if (pending.symbol == order.symbol and \n                pending.action != order.action):\n                return RiskCheckResult(\n                    self.name, RiskLevel.WARNING,\n                    f\"存在相反方向的待成交订单，可能导致自成交\",\n                    {\"pending_order\": pending}\n                )\n                \n        return RiskCheckResult(\n            self.name, RiskLevel.PASS,\n            \"无自成交风险\"\n        )\n\n\nclass RiskManager:\n    \"\"\"\n    风险管理器\n    \n    统一管理所有风控规则\n    \"\"\"\n    \n    def __init__(self):\n        self.rules: List[RiskRule] = []\n        self.block_on_warning = False  # 是否在WARNING时阻断\n        \n    def add_rule(self, rule: RiskRule):\n        \"\"\"添加风控规则\"\"\"\n        self.rules.append(rule)\n        logger.info(f\"添加风控规则: {rule.name}\")\n        \n    def check_order(self, order: Order, account: Account, \n                    market_data: Dict) -> List[RiskCheckResult]:\n        \"\"\"\n        检查订单\n        \n        Returns:\n            所有规则的检查结果\n        \"\"\"\n        results = []\n        \n        for rule in self.rules:\n            try:\n                result = rule.check(order, account, market_data)\n                results.append(result)\n                \n                if result.level == RiskLevel.BLOCK:\n                    logger.warning(f\"风控阻断 [{rule.name}]: {result.message}\")\n                elif result.level == RiskLevel.WARNING:\n                    logger.warning(f\"风控警告 [{rule.name}]: {result.message}\")\n                    \n            except Exception as e:\n                logger.error(f\"风控规则 {rule.name} 执行异常: {e}\")\n                results.append(RiskCheckResult(\n                    rule.name, RiskLevel.BLOCK,\n                    f\"规则执行异常: {e}\",\n                    {\"error\": str(e)}\n                ))\n                \n        return results\n        \n    def can_execute(self, results: List[RiskCheckResult]) -> bool:\n        \"\"\"\n        判断订单是否可以执行\n        \"\"\"\n        for result in results:\n            if result.level == RiskLevel.BLOCK:\n                return False\n            if result.level == RiskLevel.WARNING and self.block_on_warning:\n                return False\n        return True\n        \n    def get_default_manager() -> 'RiskManager':\n        \"\"\"\n        获取默认配置的风控管理器\n        \"\"\"\n        manager = RiskManager()\n        \n        # 添加默认规则\n        manager.add_rule(PositionLimitRule(\n            max_single_position=0.2,\n            max_total_position=0.95\n        ))\n        \n        manager.add_rule(DailyLossLimitRule(\n            max_daily_loss_pct=0.02\n        ))\n        \n        manager.add_rule(TradingTimeRule())\n        \n        manager.add_rule(PriceLimitRule(\n            max_price_deviation=0.05\n        ))\n        \n        return manager\n","path":"/Users/ling/quant/strategies/framework/risk_management.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":3691,"output":2993,"cacheRead":82880,"cacheWrite":0,"totalTokens":89564,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775803060058,"responseId":"349aa242a9dc47389f29fe9bfcaa6ff8"}}
{"type":"message","id":"bb9d2b25","parentId":"7aeb6959","timestamp":"2026-04-10T06:39:25.256Z","message":{"role":"toolResult","toolCallId":"functions.write:41","toolName":"write","content":[{"type":"text","text":"Successfully wrote 10824 bytes to /Users/ling/quant/strategies/framework/risk_management.py"}],"isError":false,"timestamp":1775803165250}}
{"type":"message","id":"3c5cc70d","parentId":"bb9d2b25","timestamp":"2026-04-10T06:41:33.593Z","message":{"role":"assistant","content":[{"type":"text","text":"    继续创建交易执行模块："},{"type":"toolCall","id":"functions.write:42","name":"write","arguments":{"content":"\"\"\"\n交易执行模块 - 模拟和实盘交易执行\n\n支持模拟盘和实盘交易（预留接口）\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\nfrom typing import Dict, List, Optional\nfrom dataclasses import dataclass, field\nfrom enum import Enum\nimport logging\n\nfrom strategies.framework.risk_management import (\n    RiskManager, Order, Account, Position, RiskCheckResult, RiskLevel\n)\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\n\nclass OrderStatus(Enum):\n    \"\"\"订单状态\"\"\"\n    PENDING = \"PENDING\"\n    FILLED = \"FILLED\"\n    PARTIAL = \"PARTIAL\"\n    REJECTED = \"REJECTED\"\n    CANCELLED = \"CANCELLED\"\n\n\n@dataclass\nclass Trade:\n    \"\"\"成交记录\"\"\"\n    trade_id: str\n    order_id: str\n    symbol: str\n    action: str\n    price: float\n    shares: int\n    amount: float\n    commission: float\n    trade_time: datetime\n    strategy_name: str = \"\"\n\n\n@dataclass\nclass OrderRecord:\n    \"\"\"订单记录\"\"\"\n    order_id: str\n    symbol: str\n    action: str\n    order_shares: int\n    filled_shares: int\n    order_price: float\n    filled_price: float\n    status: OrderStatus\n    create_time: datetime\n    update_time: datetime\n    strategy_name: str = \"\"\n    reject_reason: str = \"\"\n\n\nclass ExecutionEngine:\n    \"\"\"\n    交易执行引擎基类\n    \"\"\"\n    \n    def __init__(self, risk_manager: RiskManager = None):\n        self.risk_manager = risk_manager or RiskManager.get_default_manager()\n        self.orders: List[OrderRecord] = []\n        self.trades: List[Trade] = []\n        self.order_counter = 0\n        \n    def generate_order_id(self) -> str:\n        \"\"\"生成订单ID\"\"\"\n        self.order_counter += 1\n        return f\"ORD{datetime.now().strftime('%Y%m%d%H%M%S')}_{self.order_counter:06d}\"\n        \n    def generate_trade_id(self) -> str:\n        \"\"\"生成成交ID\"\"\"\n        return f\"TRD{datetime.now().strftime('%Y%m%d%H%M%S')}_{len(self.trades)+1:06d}\"\n        \n    def submit_order(self, order: Order, account: Account, \n                     market_data: Dict) -> OrderRecord:\n        \"\"\"\n        提交订单\n        \"\"\"\n        # 风控检查\n        risk_results = self.risk_manager.check_order(order, account, market_data)\n        \n        can_execute = self.risk_manager.can_execute(risk_results)\n        \n        order_id = self.generate_order_id()\n        now = datetime.now()\n        \n        if not can_execute:\n            # 记录被拒绝的订单\n            reject_reasons = [r.message for r in risk_results if r.level == RiskLevel.BLOCK]\n            record = OrderRecord(\n                order_id=order_id,\n                symbol=order.symbol,\n                action=order.action,\n                order_shares=order.shares,\n                filled_shares=0,\n                order_price=order.price,\n                filled_price=0,\n                status=OrderStatus.REJECTED,\n                create_time=now,\n                update_time=now,\n                strategy_name=order.strategy_name,\n                reject_reason=\"; \".join(reject_reasons)\n            )\n            self.orders.append(record)\n            logger.warning(f\"订单被拒绝: {reject_reasons}\")\n            return record\n            \n        # 执行订单\n        return self._execute_order(order_id, order, account, market_data)\n        \n    def _execute_order(self, order_id: str, order: Order, \n                       account: Account, market_data: Dict) -> OrderRecord:\n        \"\"\"\n        执行订单（子类实现）\n        \"\"\"\n        raise NotImplementedError\n        \n    def cancel_order(self, order_id: str) -> bool:\n        \"\"\"\n        撤销订单\n        \"\"\"\n        for order in self.orders:\n            if order.order_id == order_id and order.status == OrderStatus.PENDING:\n                order.status = OrderStatus.CANCELLED\n                order.update_time = datetime.now()\n                return True\n        return False\n        \n    def get_order_status(self, order_id: str) -> Optional[OrderRecord]:\n        \"\"\"\n        获取订单状态\n        \"\"\"\n        for order in self.orders:\n            if order.order_id == order_id:\n                return order\n        return None\n        \n    def get_trades_by_strategy(self, strategy_name: str) -> List[Trade]:\n        \"\"\"\n        获取策略的成交记录\n        \"\"\"\n        return [t for t in self.trades if t.strategy_name == strategy_name]\n\n\nclass SimulatedExecutionEngine(ExecutionEngine):\n    \"\"\"\n    模拟交易执行引擎\n    \n    用于回测和模拟盘\n    \"\"\"\n    \n    def __init__(self, risk_manager: RiskManager = None,\n                 fill_rate: float = 1.0,  # 成交率\n                 slippage: float = 0.001):  # 滑点\n        super().__init__(risk_manager)\n        self.fill_rate = fill_rate\n        self.slippage = slippage\n        \n    def _execute_order(self, order_id: str, order: Order, \n                       account: Account, market_data: Dict) -> OrderRecord:\n        \"\"\"\n        模拟执行订单\n        \"\"\"\n        now = datetime.now()\n        \n        # 获取市场价格\n        market_price = market_data.get('close', order.price)\n        \n        # 模拟滑点\n        if order.action == \"BUY\":\n            filled_price = market_price * (1 + self.slippage)\n        else:\n            filled_price = market_price * (1 - self.slippage)\n            \n        # 模拟部分成交\n        if np.random.random() > self.fill_rate:\n            filled_shares = int(order.shares * np.random.uniform(0.5, 0.9))\n        else:\n            filled_shares = order.shares\n            \n        # 计算金额和佣金\n        amount = filled_shares * filled_price\n        commission = amount * 0.0003  # 万3佣金\n        \n        if order.action == \"SELL\":\n            commission += amount * 0.001  # 千1印花税\n            \n        # 创建订单记录\n        status = OrderStatus.FILLED if filled_shares == order.shares else OrderStatus.PARTIAL\n        \n        record = OrderRecord(\n            order_id=order_id,\n            symbol=order.symbol,\n            action=order.action,\n            order_shares=order.shares,\n            filled_shares=filled_shares,\n            order_price=order.price,\n            filled_price=filled_price,\n            status=status,\n            create_time=now,\n            update_time=now,\n            strategy_name=order.strategy_name\n        )\n        self.orders.append(record)\n        \n        # 创建成交记录\n        if filled_shares > 0:\n            trade = Trade(\n                trade_id=self.generate_trade_id(),\n                order_id=order_id,\n                symbol=order.symbol,\n                action=order.action,\n                price=filled_price,\n                shares=filled_shares,\n                amount=amount,\n                commission=commission,\n                trade_time=now,\n                strategy_name=order.strategy_name\n            )\n            self.trades.append(trade)\n            \n        logger.info(f\"订单执行: {order_id} {order.action} {filled_shares}@{filled_price:.2f}\")\n        \n        return record\n\n\nclass LiveExecutionEngine(ExecutionEngine):\n    \"\"\"\n    实盘交易执行引擎\n    \n    预留接口，接入券商API\n    \"\"\"\n    \n    def __init__(self, risk_manager: RiskManager = None,\n                 broker_api=None):\n        super().__init__(risk_manager)\n        self.broker_api = broker_api\n        \n    def _execute_order(self, order_id: str, order: Order, \n                       account: Account, market_data: Dict) -> OrderRecord:\n        \"\"\"\n        实盘执行订单\n        \n        TODO: 接入券商API\n        \"\"\"\n        logger.info(f\"实盘订单提交: {order_id} {order.symbol} {order.action} {order.shares}\")\n        \n        # 这里接入券商API\n        # result = self.broker_api.submit_order(...)\n        \n        # 临时返回模拟结果\n        now = datetime.now()\n        record = OrderRecord(\n            order_id=order_id,\n            symbol=order.symbol,\n            action=order.action,\n            order_shares=order.shares,\n            filled_shares=0,\n            order_price=order.price,\n            filled_price=0,\n            status=OrderStatus.PENDING,\n            create_time=now,\n            update_time=now,\n            strategy_name=order.strategy_name\n        )\n        self.orders.append(record)\n        \n        return record\n        \n    def query_order_status(self, order_id: str):\n        \"\"\"\n        查询订单状态\n        \n        TODO: 接入券商API\n        \"\"\"\n        # result = self.broker_api.query_order(order_id)\n        pass\n        \n    def sync_trades(self):\n        \"\"\"\n        同步成交记录\n        \n        TODO: 接入券商API\n        \"\"\"\n        # trades = self.broker_api.get_trades()\n        pass\n\n\nclass PaperTradingEngine(SimulatedExecutionEngine):\n    \"\"\"\n    模拟盘引擎\n    \n    使用真实市场数据，模拟交易执行\n    \"\"\"\n    \n    def __init__(self, risk_manager: RiskManager = None,\n                 initial_capital: float = 1_000_000):\n        super().__init__(risk_manager)\n        self.initial_capital = initial_capital\n        self.cash = initial_capital\n        self.positions: Dict[str, Position] = {}\n        self.daily_pnl = 0\n        \n    def get_account(self) -> Account:\n        \"\"\"获取当前账户状态\"\"\"\n        total_value = self.cash + sum(\n            p.market_value for p in self.positions.values()\n        )\n        return Account(\n            cash=self.cash,\n            positions=self.positions,\n            total_value=total_value,\n            daily_pnl=self.daily_pnl\n        )\n        \n    def update_position(self, trade: Trade):\n        \"\"\"更新持仓\"\"\"\n        symbol = trade.symbol\n        \n        if symbol not in self.positions:\n            self.positions[symbol] = Position(\n                symbol=symbol,\n                shares=0,\n                avg_cost=0,\n                market_value=0\n            )\n            \n        position = self.positions[symbol]\n        \n        if trade.action == \"BUY\":\n            # 更新平均成本\n            total_cost = position.avg_cost * position.shares + trade.amount\n            position.shares += trade.shares\n            position.avg_cost = total_cost / position.shares if position.shares > 0 else 0\n            self.cash -= trade.amount + trade.commission\n        else:\n            # 卖出\n            position.shares -= trade.shares\n            self.cash += trade.amount - trade.commission\n            \n        # 更新市值\n        position.market_value = position.shares * trade.price\n        \n        # 清理空仓\n        if position.shares == 0:\n            del self.positions[symbol]\n            \n    def run_strategy(self, strategy, data: pd.DataFrame) -> Dict:\n        \"\"\"\n        运行策略（模拟盘模式）\n        \"\"\"\n        strategy.initialize(data)\n        \n        for idx, (date, row) in enumerate(data.iterrows()):\n            strategy.current_idx = idx\n            \n            # 获取账户状态\n            account = self.get_account()\n            \n            # 获取市场数据\n            market_data = {\n                'close': row['close'],\n                'open': row['open'],\n                'high': row['high'],\n                'low': row['low'],\n                'volume': row['volume']\n            }\n            \n            # 获取信号\n            signal = strategy.on_bar(date, row)\n            \n            if signal:\n                order = Order(\n                    symbol=signal['symbol'],\n                    action=signal['action'],\n                    shares=signal['shares'],\n                    price=row['close'],\n                    strategy_name=strategy.__class__.__name__\n                )\n                \n                # 提交订单\n                record = self.submit_order(order, account, market_data)\n                \n                # 更新持仓\n                if record.status in [OrderStatus.FILLED, OrderStatus.PARTIAL]:\n                    # 查找对应的成交记录\n                    trade = next(\n                        (t for t in self.trades if t.order_id == record.order_id),\n                        None\n                    )\n                    if trade:\n                        self.update_position(trade)\n                        \n        # 计算绩效\n        final_value = self.get_account().total_value\n        total_return = (final_value - self.initial_capital) / self.initial_capital\n        \n        return {\n            'initial_capital': self.initial_capital,\n            'final_value': final_value,\n            'total_return': total_return,\n            'trades': len(self.trades),\n            'positions': len(self.positions)\n        }\n","path":"/Users/ling/quant/strategies/framework/execution.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":3072,"output":3209,"cacheRead":86528,"cacheWrite":0,"totalTokens":92809,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775803165257,"responseId":"06073fe15ba24fd2a3d07c5693ec4fe9"}}
{"type":"message","id":"26686584","parentId":"3c5cc70d","timestamp":"2026-04-10T06:41:33.673Z","message":{"role":"toolResult","toolCallId":"functions.write:42","toolName":"write","content":[{"type":"text","text":"Successfully wrote 12008 bytes to /Users/ling/quant/strategies/framework/execution.py"}],"isError":false,"timestamp":1775803293667}}
{"type":"message","id":"c9428efa","parentId":"26686584","timestamp":"2026-04-10T06:43:03.973Z","message":{"role":"assistant","content":[{"type":"text","text":"    继续创建工具函数模块："},{"type":"toolCall","id":"functions.write:43","name":"write","arguments":{"content":"\"\"\"\n工具函数模块 - 常用工具函数\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nfrom typing import List, Tuple, Optional\nimport logging\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\n\ndef calculate_drawdown(returns: pd.Series) -> pd.Series:\n    \"\"\"\n    计算回撤序列\n    \n    Args:\n        returns: 收益率序列\n        \n    Returns:\n        回撤序列\n    \"\"\"\n    cumret = (1 + returns).cumprod()\n    cummax = cumret.cummax()\n    drawdown = (cumret - cummax) / cummax\n    return drawdown\n\n\ndef calculate_max_drawdown(returns: pd.Series) -> float:\n    \"\"\"\n    计算最大回撤\n    \"\"\"\n    return calculate_drawdown(returns).min()\n\n\ndef calculate_sharpe_ratio(returns: pd.Series, \n                           risk_free_rate: float = 0.03,\n                           periods_per_year: int = 252) -> float:\n    \"\"\"\n    计算夏普比率\n    \"\"\"\n    excess_returns = returns - risk_free_rate / periods_per_year\n    if returns.std() == 0:\n        return 0\n    return excess_returns.mean() / returns.std() * np.sqrt(periods_per_year)\n\n\ndef calculate_sortino_ratio(returns: pd.Series,\n                            risk_free_rate: float = 0.03,\n                            periods_per_year: int = 252) -> float:\n    \"\"\"\n    计算索提诺比率\n    \"\"\"\n    excess_returns = returns - risk_free_rate / periods_per_year\n    downside_returns = returns[returns < 0]\n    \n    if len(downside_returns) == 0 or downside_returns.std() == 0:\n        return 0\n        \n    return excess_returns.mean() / downside_returns.std() * np.sqrt(periods_per_year)\n\n\ndef calculate_calmar_ratio(returns: pd.Series,\n                           periods_per_year: int = 252) -> float:\n    \"\"\"\n    计算卡尔玛比率\n    \"\"\"\n    annual_return = returns.mean() * periods_per_year\n    max_dd = calculate_max_drawdown(returns)\n    \n    if max_dd == 0:\n        return 0\n        \n    return annual_return / abs(max_dd)\n\n\ndef calculate_win_rate(returns: pd.Series) -> float:\n    \"\"\"\n    计算胜率\n    \"\"\"\n    if len(returns) == 0:\n        return 0\n    return (returns > 0).sum() / len(returns)\n\n\ndef calculate_profit_factor(returns: pd.Series) -> float:\n    \"\"\"\n    计算盈亏比\n    \"\"\"\n    gains = returns[returns > 0].sum()\n    losses = abs(returns[returns < 0].sum())\n    \n    if losses == 0:\n        return 0\n        \n    return gains / losses\n\n\ndef calculate_beta(returns: pd.Series, benchmark_returns: pd.Series) -> float:\n    \"\"\"\n    计算Beta\n    \"\"\"\n    # 对齐数据\n    aligned = pd.concat([returns, benchmark_returns], axis=1).dropna()\n    \n    if len(aligned) < 2:\n        return 0\n        \n    cov = aligned.iloc[:, 0].cov(aligned.iloc[:, 1])\n    var = aligned.iloc[:, 1].var()\n    \n    if var == 0:\n        return 0\n        \n    return cov / var\n\n\ndef calculate_alpha(returns: pd.Series, \n                    benchmark_returns: pd.Series,\n                    risk_free_rate: float = 0.03) -> float:\n    \"\"\"\n    计算Alpha\n    \"\"\"\n    beta = calculate_beta(returns, benchmark_returns)\n    \n    strategy_annual = returns.mean() * 252\n    benchmark_annual = benchmark_returns.mean() * 252\n    \n    return strategy_annual - risk_free_rate - beta * (benchmark_annual - risk_free_rate)\n\n\ndef calculate_var(returns: pd.Series, confidence: float = 0.95) -> float:\n    \"\"\"\n    计算VaR (Value at Risk)\n    \n    Args:\n        returns: 收益率序列\n        confidence: 置信水平\n        \n    Returns:\n        VaR值 (负数表示亏损)\n    \"\"\"\n    return np.percentile(returns, (1 - confidence) * 100)\n\n\ndef calculate_cvar(returns: pd.Series, confidence: float = 0.95) -> float:\n    \"\"\"\n    计算CVaR (Conditional Value at Risk)\n    \"\"\"\n    var = calculate_var(returns, confidence)\n    return returns[returns <= var].mean()\n\n\ndef calculate_rolling_metrics(returns: pd.Series, \n                              window: int = 30) -> pd.DataFrame:\n    \"\"\"\n    计算滚动指标\n    \"\"\"\n    metrics = pd.DataFrame(index=returns.index)\n    \n    metrics['return'] = returns\n    metrics['cumulative'] = (1 + returns).cumprod()\n    metrics['drawdown'] = calculate_drawdown(returns)\n    \n    metrics['rolling_return'] = returns.rolling(window).mean() * 252\n    metrics['rolling_volatility'] = returns.rolling(window).std() * np.sqrt(252)\n    metrics['rolling_sharpe'] = (\n        metrics['rolling_return'] / metrics['rolling_volatility']\n    )\n    \n    return metrics\n\n\ndef resample_returns(returns: pd.Series, \n                     freq: str = 'M') -> pd.Series:\n    \"\"\"\n    重采样收益率\n    \n    Args:\n        returns: 日收益率序列\n        freq: 重采样频率 'D', 'W', 'M', 'Y'\n        \n    Returns:\n        重采样后的收益率\n    \"\"\"\n    return returns.resample(freq).apply(lambda x: (1 + x).prod() - 1)\n\n\ndef get_trade_dates(start_date: str, \n                    end_date: str,\n                    exclude_weekends: bool = True) -> pd.DatetimeIndex:\n    \"\"\"\n    获取交易日列表\n    \"\"\"\n    dates = pd.date_range(start=start_date, end=end_date, freq='D')\n    \n    if exclude_weekends:\n        dates = dates[dates.dayofweek < 5]\n        \n    return dates\n\n\ndef align_time_series(*series: pd.Series) -> List[pd.Series]:\n    \"\"\"\n    对齐多个时间序列\n    \"\"\"\n    # 找到共同的时间范围\n    common_index = series[0].index\n    for s in series[1:]:\n        common_index = common_index.intersection(s.index)\n        \n    return [s.loc[common_index] for s in series]\n\n\ndef detect_outliers(data: pd.Series, \n                    method: str = 'iqr',\n                    threshold: float = 3) -> pd.Series:\n    \"\"\"\n    检测异常值\n    \n    Args:\n        data: 数据序列\n        method: 'iqr' 或 'zscore'\n        threshold: Z-score阈值\n        \n    Returns:\n        异常值布尔序列\n    \"\"\"\n    if method == 'iqr':\n        q1 = data.quantile(0.25)\n        q3 = data.quantile(0.75)\n        iqr = q3 - q1\n        lower = q1 - 1.5 * iqr\n        upper = q3 + 1.5 * iqr\n        return (data < lower) | (data > upper)\n        \n    elif method == 'zscore':\n        zscore = (data - data.mean()) / data.std()\n        return abs(zscore) > threshold\n        \n    else:\n        raise ValueError(f\"Unknown method: {method}\")\n\n\ndef fill_missing_values(data: pd.Series,\n                        method: str = 'ffill') -> pd.Series:\n    \"\"\"\n    填充缺失值\n    \n    Args:\n        data: 数据序列\n        method: 'ffill', 'bfill', 'interpolate', 'mean', 'median'\n    \"\"\"\n    if method == 'ffill':\n        return data.fillna(method='ffill')\n    elif method == 'bfill':\n        return data.fillna(method='bfill')\n    elif method == 'interpolate':\n        return data.interpolate()\n    elif method == 'mean':\n        return data.fillna(data.mean())\n    elif method == 'median':\n        return data.fillna(data.median())\n    else:\n        raise ValueError(f\"Unknown method: {method}\")\n\n\ndef annualize_metric(daily_value: float, \n                     metric_type: str = 'return') -> float:\n    \"\"\"\n    年化指标\n    \n    Args:\n        daily_value: 日度值\n        metric_type: 'return', 'volatility', 'sharpe'\n    \"\"\"\n    if metric_type == 'return':\n        return daily_value * 252\n    elif metric_type == 'volatility':\n        return daily_value * np.sqrt(252)\n    elif metric_type == 'sharpe':\n        return daily_value * np.sqrt(252)\n    else:\n        return daily_value\n\n\ndef format_percentage(value: float, decimals: int = 2) -> str:\n    \"\"\"\n    格式化百分比\n    \"\"\"\n    return f\"{value * 100:.{decimals}f}%\"\n\n\ndef format_number(value: float, decimals: int = 2) -> str:\n    \"\"\"\n    格式化数字\n    \"\"\"\n    if abs(value) >= 1e8:\n        return f\"{value / 1e8:.{decimals}f}亿\"\n    elif abs(value) >= 1e4:\n        return f\"{value / 1e4:.{decimals}f}万\"\n    else:\n        return f\"{value:.{decimals}f}\"\n","path":"/Users/ling/quant/strategies/framework/utils.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":3244,"output":2382,"cacheRead":89600,"cacheWrite":0,"totalTokens":95226,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775803293674,"responseId":"03f80e8287c84404b1025e7a9e93292c"}}
