{"type":"message","id":"4502b3ed","parentId":"b841906c","timestamp":"2026-04-10T07:17:47.310Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_FWyhijNaRYrRzrdv6KNDVf","name":"write","arguments":{"content":"\"\"\"\n经验沉淀与知识管理模块\n\"\"\"\n\nimport os\nimport json\nfrom datetime import datetime\nfrom typing import Dict, List, Optional\nimport logging\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\n\nclass TradingJournal:\n    \"\"\"\n    交易日志\n    \n    记录每笔交易的思考、教训\n    \"\"\"\n    \n    def __init__(self, journal_dir: str = 'docs/trading_journal'):\n        self.journal_dir = journal_dir\n        os.makedirs(journal_dir, exist_ok=True)\n        \n    def add_entry(self, \n                  date: str = None,\n                  strategy: str = \"\",\n                  market_condition: str = \"\",\n                  trades: List[Dict] = None,\n                  observations: str = \"\",\n                  lessons: str = \"\",\n                  emotions: str = \"\",\n                  rating: int = 3):\n        \"\"\"\n        添加日志条目\n        \n        Args:\n            date: 日期\n            strategy: 策略名称\n            market_condition: 市场状况描述\n            trades: 今日交易列表\n            observations: 观察记录\n            lessons: 经验教训\n            emotions: 情绪记录\n            rating: 今日评分 1-5\n        \"\"\"\n        date = date or datetime.now().strftime('%Y-%m-%d')\n        \n        entry = {\n            'date': date,\n            'strategy': strategy,\n            'market_condition': market_condition,\n            'trades': trades or [],\n            'observations': observations,\n            'lessons': lessons,\n            'emotions': emotions,\n            'rating': rating,\n            'created_at': datetime.now().isoformat()\n        }\n        \n        # 保存为markdown\n        md_content = f\"\"\"# 交易日志 - {date}\n\n## 市场状况\n{market_condition}\n\n## 策略: {strategy}\n\n## 今日交易\n\"\"\"\n        if trades:\n            md_content += \"| 时间 | 标的 | 方向 | 价格 | 数量 | 原因 |\\n\"\n            md_content += \"|------|------|------|------|------|------|\\n\"\n            for trade in trades:\n                md_content += f\"| {trade.get('time', '')} | {trade.get('symbol', '')} | {trade.get('action', '')} | {trade.get('price', '')} | {trade.get('shares', '')} | {trade.get('reason', '')} |\\n\"\n        else:\n            md_content += \"今日无交易\\n\"\n            \n        md_content += f\"\"\"\n## 观察记录\n{observations}\n\n## 经验教训\n{lessons}\n\n## 情绪记录\n{emotions}\n\n## 今日评分: {'⭐' * rating}{'☆' * (5 - rating)}\n\n---\n\"\"\"\n        \n        filepath = os.path.join(self.journal_dir, f'{date}.md')\n        with open(filepath, 'w', encoding='utf-8') as f:\n            f.write(md_content)\n            \n        # 同时保存JSON\n        json_path = os.path.join(self.journal_dir, f'{date}.json')\n        with open(json_path, 'w', encoding='utf-8') as f:\n            json.dump(entry, f, indent=2, ensure_ascii=False)\n            \n        logger.info(f\"交易日志已保存: {filepath}\")\n        \n    def get_lessons(self, days: int = 30) -> List[Dict]:\n        \"\"\"获取最近N天的教训\"\"\"\n        lessons = []\n        \n        for filename in sorted(os.listdir(self.journal_dir), reverse=True):\n            if not filename.endswith('.json'):\n                continue\n                \n            filepath = os.path.join(self.journal_dir, filename)\n            with open(filepath, 'r', encoding='utf-8') as f:\n                entry = json.load(f)\n                \n            if entry.get('lessons'):\n                lessons.append({\n                    'date': entry['date'],\n                    'lesson': entry['lessons'],\n                    'strategy': entry['strategy']\n                })\n                \n            if len(lessons) >= days:\n                break\n                \n        return lessons\n\n\nclass LessonsLearned:\n    \"\"\"\n    经验教训管理\n    \"\"\"\n    \n    def __init__(self, filepath: str = 'docs/lessons_learned.md'):\n        self.filepath = filepath\n        self.lessons = self._load()\n        \n    def _load(self) -> List[Dict]:\n        \"\"\"加载经验\"\"\"\n        if not os.path.exists(self.filepath):\n            return []\n        try:\n            # 尝试从 JSON sidecar 加载\n            json_path = self.filepath.replace('.md', '.json')\n            if os.path.exists(json_path):\n                with open(json_path, 'r', encoding='utf-8') as f:\n                    return json.load(f)\n        except:\n            pass\n        return []\n        \n    def _save(self):\n        \"\"\"保存经验\"\"\"\n        os.makedirs(os.path.dirname(self.filepath), exist_ok=True)\n        \n        # 保存 JSON\n        json_path = self.filepath.replace('.md', '.json')\n        with open(json_path, 'w', encoding='utf-8') as f:\n            json.dump(self.lessons, f, indent=2, ensure_ascii=False)\n            \n        # 生成 Markdown\n        md = \"# 经验教训汇总\\n\\n\"\n        md += f\"最后更新: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\n\\n\"\n        \n        # 按类别分组\n        categories = {}\n        for lesson in self.lessons:\n            cat = lesson.get('category', '其他')\n            if cat not in categories:\n                categories[cat] = []\n            categories[cat].append(lesson)\n            \n        for cat, items in categories.items():\n            md += f\"## {cat}\\n\\n\"\n            for item in items:\n                md += f\"### {item['title']}\\n\\n\"\n                md += f\"- **日期**: {item['date']}\\n\"\n                md += f\"- **影响**: {item.get('impact', '未评估')}\\n\"\n                md += f\"- **描述**: {item['description']}\\n\"\n                md += f\"- **改进措施**: {item.get('action', '无')}\\n\"\n                md += f\"- **状态**: {item.get('status', '未处理')}\\n\\n\"\n                \n        with open(self.filepath, 'w', encoding='utf-8') as f:\n            f.write(md)\n            \n    def add_lesson(self, title: str, description: str,\n                   category: str = \"策略\",\n                   impact: str = \"中\",\n                   action: str = \"\",\n                   status: str = \"待处理\"):\n        \"\"\"添加经验教训\"\"\"\n        self.lessons.append({\n            'date': datetime.now().strftime('%Y-%m-%d'),\n            'title': title,\n            'description': description,\n            'category': category,\n            'impact': impact,\n            'action': action,\n            'status': status\n        })\n        self._save()\n        logger.info(f\"经验教训已添加: {title}\")\n        \n    def update_status(self, title: str, status: str):\n        \"\"\"更新状态\"\"\"\n        for lesson in self.lessons:\n            if lesson['title'] == title:\n                lesson['status'] = status\n                self._save()\n                return True\n        return False\n        \n    def get_by_category(self, category: str) -> List[Dict]:\n        \"\"\"按类别获取\"\"\"\n        return [l for l in self.lessons if l.get('category') == category]\n        \n    def get_pending(self) -> List[Dict]:\n        \"\"\"获取待处理的教训\"\"\"\n        return [l for l in self.lessons if l.get('status') == '待处理']\n","path":"/Users/ling/quant/strategies/framework/knowledge.py"}}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":3142,"output":2158,"cacheRead":131188,"cacheWrite":0,"totalTokens":136488,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775805433926,"responseId":"f4c3e275-a545-4d37-9f79-6c129c609a6a"}}
