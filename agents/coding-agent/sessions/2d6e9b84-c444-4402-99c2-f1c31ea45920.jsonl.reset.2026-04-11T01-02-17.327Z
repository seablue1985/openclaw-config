{"type":"message","id":"76ac05f7","parentId":"b47ea21b","timestamp":"2026-04-10T06:19:09.217Z","message":{"role":"assistant","content":[{"type":"text","text":" 好的，继续创建核心回测框架和策略模板。"},{"type":"toolCall","id":"functions.write:31","name":"write","arguments":{"content":"\"\"\"\n策略验证框架 - 防止过拟合的金标准\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom typing import Dict, List, Tuple\nfrom datetime import datetime\nimport scipy.stats as stats\n\n\nclass StrategyValidator:\n    \"\"\"\n    策略验证器 - 确保策略稳健性\n    \"\"\"\n    \n    def __init__(self, data: pd.DataFrame):\n        self.data = data\n        \n    def walk_forward_analysis(self, strategy_class, config, \n                             train_size: int = 504,  # 约2年\n                             test_size: int = 63,    # 约3个月\n                             step_size: int = 63) -> Dict:\n        \"\"\"\n        滚动前向验证（Walk-Forward Analysis）\n        \n        这是防止过拟合的金标准\n        \"\"\"\n        results = []\n        n_samples = len(self.data)\n        \n        start_idx = 0\n        fold = 0\n        \n        while start_idx + train_size + test_size <= n_samples:\n            fold += 1\n            \n            # 划分训练集和测试集\n            train_start = start_idx\n            train_end = start_idx + train_size\n            test_end = train_end + test_size\n            \n            train_data = self.data.iloc[train_start:train_end]\n            test_data = self.data.iloc[train_end:test_end]\n            \n            # 在训练集上优化参数\n            best_params = self._optimize_params(strategy_class, config, train_data)\n            \n            # 在测试集上验证\n            strategy = strategy_class(config, **best_params)\n            metrics = strategy.run_backtest(test_data)\n            \n            results.append({\n                'fold': fold,\n                'train_period': f\"{train_data.index[0]} ~ {train_data.index[-1]}\",\n                'test_period': f\"{test_data.index[0]} ~ {test_data.index[-1]}\",\n                'params': best_params,\n                'metrics': metrics\n            })\n            \n            print(f\"Fold {fold}: 训练期 {train_data.index[0].date()} ~ {train_data.index[-1].date()}, \"\n                  f\"测试期 {test_data.index[0].date()} ~ {test_data.index[-1].date()}, \"\n                  f\"收益 {metrics['total_return']:.2f}%, 夏普 {metrics['sharpe_ratio']:.3f}\")\n            \n            start_idx += step_size\n            \n        # 汇总结果\n        returns = [r['metrics']['total_return'] for r in results]\n        sharpes = [r['metrics']['sharpe_ratio'] for r in results]\n        \n        summary = {\n            'folds': results,\n            'avg_return': np.mean(returns),\n            'std_return': np.std(returns),\n            'min_return': np.min(returns),\n            'max_return': np.max(returns),\n            'avg_sharpe': np.mean(sharpes),\n            'sharpe_consistency': np.std(sharpes),\n            'positive_ratio': sum(1 for r in returns if r > 0) / len(returns),\n            'robust_score': self._calc_robust_score(results)\n        }\n        \n        return summary\n        \n    def _optimize_params(self, strategy_class, config, train_data) -> Dict:\n        \"\"\"简化版参数优化\"\"\"\n        best_sharpe = -np.inf\n        best_params = {}\n        \n        for short in [3, 5, 10]:\n            for long in [20, 30, 60]:\n                if short >= long:\n                    continue\n                    \n                try:\n                    strategy = strategy_class(config, short_window=short, long_window=long)\n                    metrics = strategy.run_backtest(train_data)\n                    \n                    if metrics['sharpe_ratio'] > best_sharpe:\n                        best_sharpe = metrics['sharpe_ratio']\n                        best_params = {'short_window': short, 'long_window': long}\n                except:\n                    continue\n                    \n        return best_params\n        \n    def _calc_robust_score(self, results: List[Dict]) -> float:\n        \"\"\"计算稳健性评分 0-100\"\"\"\n        returns = [r['metrics']['total_return'] for r in results]\n        sharpes = [r['metrics']['sharpe_ratio'] for r in results]\n        \n        score = 0\n        \n        # 1. 正收益比例 (30分)\n        positive_ratio = sum(1 for r in returns if r > 0) / len(returns)\n        score += positive_ratio * 30\n        \n        # 2. 收益稳定性 (30分)\n        if np.mean(returns) > 0:\n            consistency = max(0, 1 - np.std(returns) / abs(np.mean(returns)))\n            score += consistency * 30\n            \n        # 3. 夏普比率 (20分)\n        avg_sharpe = np.mean(sharpes)\n        score += min(avg_sharpe / 2, 1) * 20\n        \n        # 4. 最大回撤控制 (20分)\n        max_dd = max([r['metrics']['max_drawdown'] for r in results])\n        score += max(0, 1 - abs(max_dd) / 30) * 20\n        \n        return round(score, 2)\n        \n    def monte_carlo_simulation(self, returns: pd.Series, n_simulations: int = 1000) -> Dict:\n        \"\"\"蒙特卡洛模拟\"\"\"\n        np.random.seed(42)\n        \n        final_returns = []\n        max_drawdowns = []\n        \n        for _ in range(n_simulations):\n            shuffled = np.random.choice(returns, size=len(returns), replace=True)\n            cumret = (1 + shuffled).cumprod()\n            \n            final_returns.append(cumret[-1] - 1)\n            max_drawdowns.append(self._calc_max_drawdown(cumret))\n            \n        return {\n            'median_final_return': np.median(final_returns) * 100,\n            'percentile_5': np.percentile(final_returns, 5) * 100,\n            'percentile_95': np.percentile(final_returns, 95) * 100,\n            'prob_profit': sum(1 for r in final_returns if r > 0) / n_simulations * 100,\n            'median_max_dd': np.median(max_drawdowns) * 100,\n            'worst_case_dd': np.percentile(max_drawdowns, 95) * 100\n        }\n        \n    def _calc_max_drawdown(self, values: np.ndarray) -> float:\n        cummax = np.maximum.accumulate(values)\n        drawdown = (values - cummax) / cummax\n        return drawdown.min()\n\n\nclass CrossValidator:\n    \"\"\"\n    交叉验证器\n    \"\"\"\n    \n    @staticmethod\n    def time_series_split(data: pd.DataFrame, n_splits: int = 5) -> List[Tuple]:\n        \"\"\"时间序列交叉验证分割\"\"\"\n        n_samples = len(data)\n        fold_size = n_samples // (n_splits + 1)\n        \n        splits = []\n        for i in range(n_splits):\n            train_end = fold_size * (i + 1)\n            test_end = fold_size * (i + 2)\n            \n            train_data = data.iloc[:train_end]\n            test_data = data.iloc[train_end:test_end]\n            \n            splits.append((train_data, test_data))\n            \n        return splits\n        \n    @staticmethod\n    def purged_k_fold(data: pd.DataFrame, n_splits: int = 5, \n                      embargo_pct: float = 0.01) -> List[Tuple]:\n        \"\"\"\n        清洗K折交叉验证（带 embargo）\n        \n        防止数据泄露\n        \"\"\"\n        n_samples = len(data)\n        fold_size = n_samples // n_splits\n        embargo_size = int(fold_size * embargo_pct)\n        \n        splits = []\n        for i in range(n_splits):\n            test_start = i * fold_size\n            test_end = (i + 1) * fold_size\n            \n            # 训练集 = 测试集之前的数据（排除 embargo 区域）\n            train_data = data.iloc[:max(0, test_start - embargo_size)]\n            test_data = data.iloc[test_start:test_end]\n            \n            splits.append((train_data, test_data))\n            \n        return splits\n","path":"/Users/ling/quant/strategies/framework/validation.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":65210,"output":2061,"cacheRead":512,"cacheWrite":0,"totalTokens":67783,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775801883068,"responseId":"f4d1430772dd4304b0d93c7d7bb14e65"}}
{"type":"message","id":"a5315bd9","parentId":"76ac05f7","timestamp":"2026-04-10T06:19:09.321Z","message":{"role":"toolResult","toolCallId":"functions.write:31","toolName":"write","content":[{"type":"text","text":"Successfully wrote 7048 bytes to /Users/ling/quant/strategies/framework/validation.py"}],"isError":false,"timestamp":1775801949311}}
{"type":"message","id":"a24abb96","parentId":"a5315bd9","timestamp":"2026-04-10T06:20:26.769Z","message":{"role":"assistant","content":[{"type":"text","text":"   继续创建策略对比分析模块："},{"type":"toolCall","id":"functions.write:32","name":"write","arguments":{"content":"\"\"\"\n策略对比分析框架\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom typing import Dict, List\nimport matplotlib.pyplot as plt\nimport plotly.graph_objects as go\nfrom plotly.subplots import make_subplots\n\n\nclass StrategyComparison:\n    \"\"\"\n    多策略对比分析\n    \"\"\"\n    \n    def __init__(self):\n        self.results = {}\n        \n    def add_strategy(self, name: str, daily_returns: pd.Series, \n                     trades: List[Dict] = None, metadata: Dict = None):\n        \"\"\"添加策略结果\"\"\"\n        self.results[name] = {\n            'returns': daily_returns,\n            'trades': trades or [],\n            'metadata': metadata or {}\n        }\n        \n    def compare(self, benchmark: pd.Series = None) -> pd.DataFrame:\n        \"\"\"生成对比报告\"\"\"\n        comparison = {}\n        \n        for name, data in self.results.items():\n            returns = data['returns']\n            \n            # 计算各项指标\n            total_return = (returns.sum()) * 100\n            annual_return = (returns.mean() * 252) * 100\n            volatility = (returns.std() * np.sqrt(252)) * 100\n            sharpe = (returns.mean() * 252) / (returns.std() * np.sqrt(252)) if returns.std() > 0 else 0\n            \n            # 最大回撤\n            cumret = (1 + returns).cumprod()\n            running_max = cumret.expanding().max()\n            drawdown = (cumret - running_max) / running_max\n            max_dd = drawdown.min() * 100\n            \n            # 卡玛比率\n            calmar = annual_return / abs(max_dd) if max_dd != 0 else 0\n            \n            comparison[name] = {\n                '总收益率': f\"{total_return:.2f}%\",\n                '年化收益': f\"{annual_return:.2f}%\",\n                '年化波动': f\"{volatility:.2f}%\",\n                '夏普比率': f\"{sharpe:.3f}\",\n                '最大回撤': f\"{max_dd:.2f}%\",\n                '卡玛比率': f\"{calmar:.3f}\",\n                '胜率': f\"{(returns > 0).sum() / len(returns) * 100:.1f}%\",\n            }\n            \n        df = pd.DataFrame(comparison).T\n        \n        # 添加与基准的对比\n        if benchmark is not None:\n            df['超额收益'] = df['总收益率'].apply(\n                lambda x: f\"{float(x.strip('%')) - (benchmark.sum() * 100):.2f}%\"\n            )\n            \n        return df\n        \n    def plot_comparison(self, save_path: str = None, use_plotly: bool = True):\n        \"\"\"绘制对比图\"\"\"\n        if use_plotly:\n            return self._plot_plotly(save_path)\n        else:\n            return self._plot_matplotlib(save_path)\n            \n    def _plot_plotly(self, save_path: str = None):\n        \"\"\"使用 Plotly 绘制\"\"\"\n        fig = make_subplots(\n            rows=2, cols=2,\n            subplot_titles=('累计收益曲线', '回撤曲线', '收益分布', '月度收益'),\n            specs=[[{}, {}], [{}, {}]]\n        )\n        \n        colors = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd']\n        \n        for i, (name, data) in enumerate(self.results.items()):\n            returns = data['returns']\n            cumret = (1 + returns).cumprod()\n            color = colors[i % len(colors)]\n            \n            # 1. 累计收益\n            fig.add_trace(\n                go.Scatter(x=cumret.index, y=cumret, name=name, \n                          line=dict(color=color)),\n                row=1, col=1\n            )\n            \n            # 2. 回撤曲线\n            running_max = cumret.expanding().max()\n            drawdown = (cumret - running_max) / running_max\n            fig.add_trace(\n                go.Scatter(x=drawdown.index, y=drawdown, name=f\"{name} 回撤\",\n                          line=dict(color=color, dash='dash'), showlegend=False),\n                row=1, col=2\n            )\n            \n            # 3. 收益分布\n            fig.add_trace(\n                go.Histogram(x=returns * 100, name=name, opacity=0.6,\n                           marker_color=color, showlegend=False),\n                row=2, col=1\n            )\n            \n        fig.update_layout(\n            height=800,\n            title_text=\"策略对比分析\",\n            showlegend=True\n        )\n        \n        if save_path:\n            fig.write_html(save_path)\n            \n        return fig\n        \n    def _plot_matplotlib(self, save_path: str = None):\n        \"\"\"使用 Matplotlib 绘制\"\"\"\n        fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n        \n        # 1. 累计收益\n        ax1 = axes[0, 0]\n        for name, data in self.results.items():\n            cumret = (1 + data['returns']).cumprod()\n            ax1.plot(cumret.index, cumret, label=name)\n        ax1.set_title('累计收益曲线')\n        ax1.legend()\n        ax1.set_ylabel('净值')\n        \n        # 2. 回撤\n        ax2 = axes[0, 1]\n        for name, data in self.results.items():\n            cumret = (1 + data['returns']).cumprod()\n            cummax = cumret.cummax()\n            drawdown = (cumret - cummax) / cummax\n            ax2.fill_between(drawdown.index, drawdown, 0, alpha=0.3, label=name)\n        ax2.set_title('回撤曲线')\n        ax2.legend()\n        \n        # 3. 收益分布\n        ax3 = axes[1, 0]\n        for name, data in self.results.items():\n            ax3.hist(data['returns'] * 100, bins=50, alpha=0.5, label=name)\n        ax3.set_title('日收益分布')\n        ax3.legend()\n        \n        # 4. 月度收益\n        ax4 = axes[1, 1]\n        first_strategy = list(self.results.keys())[0]\n        returns = self.results[first_strategy]['returns']\n        monthly = returns.resample('M').apply(lambda x: (1+x).prod() - 1)\n        colors = ['green' if x > 0 else 'red' for x in monthly]\n        ax4.bar(range(len(monthly)), monthly * 100, color=colors)\n        ax4.set_title(f'{first_strategy} - 月度收益')\n        \n        plt.tight_layout()\n        \n        if save_path:\n            plt.savefig(save_path, dpi=150, bbox_inches='tight')\n            \n        return fig\n        \n    def generate_report(self, output_path: str = None) -> str:\n        \"\"\"生成对比报告\"\"\"\n        comparison_df = self.compare()\n        \n        report = f\"\"\"\n# 策略对比分析报告\n\n生成时间: {pd.Timestamp.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n## 策略列表\n{', '.join(self.results.keys())}\n\n## 绩效对比\n\n{comparison_df.to_markdown()}\n\n## 详细分析\n\n\"\"\"\n        \n        for name, data in self.results.items():\n            returns = data['returns']\n            report += f\"\\n### {name}\\n\"\n            report += f\"- 总收益: {(returns.sum() * 100):.2f}%\\n\"\n            report += f\"- 年化收益: {(returns.mean() * 252 * 100):.2f}%\\n\"\n            report += f\"- 夏普比率: {(returns.mean() * 252 / (returns.std() * np.sqrt(252))):.3f}\\n\"\n            \n        if output_path:\n            with open(output_path, 'w', encoding='utf-8') as f:\n                f.write(report)\n                \n        return report\n\n\nclass PortfolioOptimizer:\n    \"\"\"\n    投资组合优化器\n    \"\"\"\n    \n    @staticmethod\n    def mean_variance_optimization(returns: pd.DataFrame, \n                                    risk_free_rate: float = 0.03,\n                                    target_return: float = None) -> Dict:\n        \"\"\"\n        均值-方差优化\n        \n        Returns:\n            最优权重配置\n        \"\"\"\n        n_assets = len(returns.columns)\n        \n        # 预期收益和协方差\n        expected_returns = returns.mean() * 252\n        cov_matrix = returns.cov() * 252\n        \n        # 生成随机权重组合\n        n_portfolios = 10000\n        weights_record = []\n        returns_record = []\n        risks_record = []\n        sharpe_record = []\n        \n        np.random.seed(42)\n        \n        for _ in range(n_portfolios):\n            weights = np.random.random(n_assets)\n            weights /= np.sum(weights)\n            \n            portfolio_return = np.dot(weights, expected_returns)\n            portfolio_risk = np.sqrt(np.dot(weights.T, np.dot(cov_matrix, weights)))\n            sharpe = (portfolio_return - risk_free_rate) / portfolio_risk\n            \n            weights_record.append(weights)\n            returns_record.append(portfolio_return)\n            risks_record.append(portfolio_risk)\n            sharpe_record.append(sharpe)\n            \n        # 找到最优组合\n        max_sharpe_idx = np.argmax(sharpe_record)\n        min_risk_idx = np.argmin(risks_record)\n        \n        return {\n            'max_sharpe_weights': dict(zip(returns.columns, weights_record[max_sharpe_idx])),\n            'max_sharpe_return': returns_record[max_sharpe_idx],\n            'max_sharpe_risk': risks_record[max_sharpe_idx],\n            'max_sharpe_ratio': sharpe_record[max_sharpe_idx],\n            'min_risk_weights': dict(zip(returns.columns, weights_record[min_risk_idx])),\n            'min_risk_return': returns_record[min_risk_idx],\n            'min_risk': risks_record[min_risk_idx],\n            'efficient_frontier': {\n                'returns': returns_record,\n                'risks': risks_record,\n                'sharpe': sharpe_record\n            }\n        }\n        \n    @staticmethod\n    def risk_parity_weights(returns: pd.DataFrame) -> pd.Series:\n        \"\"\"\n        风险平价权重\n        \n        使各资产对组合风险的贡献相等\n        \"\"\"\n        cov = returns.cov()\n        inv_diag = 1 / np.diag(cov)\n        weights = inv_diag / inv_diag.sum()\n        \n        return pd.Series(weights, index=returns.columns)\n","path":"/Users/ling/quant/strategies/framework/strategy_comparison.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":2156,"output":2657,"cacheRead":65664,"cacheWrite":0,"totalTokens":70477,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775801949322,"responseId":"8c34f123d1c84b0b85ed117a575cb618"}}
{"type":"message","id":"18e65b54","parentId":"a24abb96","timestamp":"2026-04-10T06:20:26.852Z","message":{"role":"toolResult","toolCallId":"functions.write:32","toolName":"write","content":[{"type":"text","text":"Successfully wrote 8966 bytes to /Users/ling/quant/strategies/framework/strategy_comparison.py"}],"isError":false,"timestamp":1775802026845}}
{"type":"message","id":"d8fb0207","parentId":"18e65b54","timestamp":"2026-04-10T06:21:47.130Z","message":{"role":"assistant","content":[{"type":"text","text":"   继续创建策略监控模块："},{"type":"toolCall","id":"functions.write:33","name":"write","arguments":{"content":"\"\"\"\n策略监控中心 - 跟踪策略表现，及时发现问题\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nfrom typing import Dict, List, Optional\nimport json\nimport logging\nfrom dataclasses import dataclass, asdict\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\n\n@dataclass\nclass StrategyHealth:\n    \"\"\"策略健康度指标\"\"\"\n    strategy_name: str\n    date: datetime\n    status: str  # HEALTHY / WARNING / CRITICAL\n    \n    # 收益指标\n    total_return_7d: float\n    total_return_30d: float\n    total_return_90d: float\n    \n    # 风险指标\n    max_drawdown_current: float\n    volatility_30d: float\n    \n    # 质量指标\n    sharpe_30d: float\n    win_rate_30d: float\n    \n    # 异常标记\n    anomalies: List[str]\n    \n    def to_dict(self):\n        return asdict(self)\n\n\nclass StrategyMonitor:\n    \"\"\"\n    策略监控器\n    \"\"\"\n    \n    # 预警阈值配置\n    THRESHOLDS = {\n        'drawdown_warning': -0.10,      # 回撤10%警告\n        'drawdown_critical': -0.20,     # 回撤20%严重\n        'sharpe_min': 0.5,              # 夏普最低要求\n        'return_deviation': 0.20,       # 收益偏离预期20%\n        'consecutive_loss_days': 5,     # 连续亏损天数\n    }\n    \n    def __init__(self, history_file: str = 'monitoring/strategy_health.json'):\n        self.history_file = history_file\n        self.history = self._load_history()\n        \n    def _load_history(self) -> List[Dict]:\n        \"\"\"加载历史记录\"\"\"\n        try:\n            with open(self.history_file, 'r') as f:\n                return json.load(f)\n        except FileNotFoundError:\n            return []\n            \n    def _save_history(self):\n        \"\"\"保存历史记录\"\"\"\n        import os\n        os.makedirs(os.path.dirname(self.history_file), exist_ok=True)\n        with open(self.history_file, 'w') as f:\n            json.dump(self.history, f, indent=2, default=str)\n            \n    def check_strategy(self, strategy_name: str, \n                       daily_returns: pd.Series,\n                       expected_annual_return: float = 0.20) -> StrategyHealth:\n        \"\"\"检查策略健康度\"\"\"\n        anomalies = []\n        today = datetime.now()\n        \n        # 计算各周期收益\n        returns_7d = daily_returns.tail(7).sum() if len(daily_returns) >= 7 else 0\n        returns_30d = daily_returns.tail(30).sum() if len(daily_returns) >= 30 else 0\n        returns_90d = daily_returns.tail(90).sum() if len(daily_returns) >= 90 else 0\n        \n        # 计算当前回撤\n        cumret = (1 + daily_returns).cumprod()\n        running_max = cumret.expanding().max()\n        drawdown = (cumret - running_max) / running_max\n        current_dd = drawdown.iloc[-1]\n        \n        # 计算30天波动率和夏普\n        ret_30d = daily_returns.tail(30)\n        vol_30d = ret_30d.std() * np.sqrt(252) if len(ret_30d) > 0 else 0\n        sharpe_30d = (ret_30d.mean() * 252) / (ret_30d.std() * np.sqrt(252)) if ret_30d.std() > 0 else 0\n        \n        # 胜率\n        win_rate_30d = (ret_30d > 0).sum() / len(ret_30d) if len(ret_30d) > 0 else 0\n        \n        # 异常检测\n        # 1. 回撤检查\n        if current_dd < self.THRESHOLDS['drawdown_critical']:\n            anomalies.append(f\"严重回撤: {current_dd*100:.1f}%\")\n        elif current_dd < self.THRESHOLDS['drawdown_warning']:\n            anomalies.append(f\"回撤警告: {current_dd*100:.1f}%\")\n            \n        # 2. 夏普比率检查\n        if sharpe_30d < self.THRESHOLDS['sharpe_min'] and len(ret_30d) >= 30:\n            anomalies.append(f\"夏普过低: {sharpe_30d:.2f}\")\n            \n        # 3. 收益偏离检查\n        actual_annual = returns_30d * 12\n        if abs(actual_annual - expected_annual_return) / expected_annual_return > self.THRESHOLDS['return_deviation']:\n            if actual_annual < expected_annual_return:\n                anomalies.append(f\"收益低于预期: 实际{actual_annual*100:.1f}% vs 预期{expected_annual_return*100:.1f}%\")\n                \n        # 4. 连续亏损检查\n        consecutive_losses = 0\n        for ret in reversed(daily_returns.tail(20)):\n            if ret < 0:\n                consecutive_losses += 1\n            else:\n                break\n        if consecutive_losses >= self.THRESHOLDS['consecutive_loss_days']:\n            anomalies.append(f\"连续亏损{consecutive_losses}天\")\n            \n        # 5. 波动率异常\n        hist_vol = daily_returns.std() * np.sqrt(252)\n        if vol_30d > hist_vol * 1.5:\n            anomalies.append(f\"波动率异常升高: {vol_30d*100:.1f}% vs 历史{hist_vol*100:.1f}%\")\n            \n        # 确定状态\n        if any(\"严重\" in a for a in anomalies):\n            status = \"CRITICAL\"\n        elif anomalies:\n            status = \"WARNING\"\n        else:\n            status = \"HEALTHY\"\n            \n        health = StrategyHealth(\n            strategy_name=strategy_name,\n            date=today,\n            status=status,\n            total_return_7d=round(returns_7d, 4),\n            total_return_30d=round(returns_30d, 4),\n            total_return_90d=round(returns_90d, 4),\n            max_drawdown_current=round(current_dd, 4),\n            volatility_30d=round(vol_30d, 4),\n            sharpe_30d=round(sharpe_30d, 3),\n            win_rate_30d=round(win_rate_30d, 3),\n            anomalies=anomalies\n        )\n        \n        # 保存记录\n        self.history.append(health.to_dict())\n        self._save_history()\n        \n        return health\n        \n    def generate_report(self, strategy_names: List[str] = None) -> str:\n        \"\"\"生成监控报告\"\"\"\n        if not self.history:\n            return \"暂无监控数据\"\n            \n        df = pd.DataFrame(self.history)\n        df['date'] = pd.to_datetime(df['date'])\n        \n        # 取最新记录\n        latest = df.sort_values('date').groupby('strategy_name').last()\n        \n        if strategy_names:\n            latest = latest.loc[latest.index.isin(strategy_names)]\n            \n        report = []\n        report.append(\"=\" * 60)\n        report.append(\"策略健康度监控报告\")\n        report.append(f\"生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n        report.append(\"=\" * 60)\n        \n        for name, row in latest.iterrows():\n            status_emoji = {\n                'HEALTHY': '🟢',\n                'WARNING': '🟡', \n                'CRITICAL': '🔴'\n            }.get(row['status'], '⚪')\n            \n            report.append(f\"\\n{status_emoji} {name} [{row['status']}]\")\n            report.append(f\"   7日收益: {row['total_return_7d']*100:.2f}%\")\n            report.append(f\"   30日收益: {row['total_return_30d']*100:.2f}%\")\n            report.append(f\"   当前回撤: {row['max_drawdown_current']*100:.2f}%\")\n            report.append(f\"   30日夏普: {row['sharpe_30d']:.2f}\")\n            \n            if row['anomalies']:\n                report.append(f\"   ⚠️ 异常: {'; '.join(row['anomalies'])}\")\n                \n        return '\\n'.join(report)\n        \n    def get_alerts(self) -> List[Dict]:\n        \"\"\"获取需要告警的策略\"\"\"\n        if not self.history:\n            return []\n            \n        latest = {}\n        for record in reversed(self.history):\n            name = record['strategy_name']\n            if name not in latest:\n                latest[name] = record\n                \n        alerts = []\n        for name, record in latest.items():\n            if record['status'] in ['WARNING', 'CRITICAL']:\n                alerts.append({\n                    'strategy': name,\n                    'status': record['status'],\n                    'anomalies': record['anomalies'],\n                    'time': record['date']\n                })\n                \n        return alerts\n\n\nclass LiveTracker:\n    \"\"\"\n    实盘跟踪器\n    \"\"\"\n    \n    def __init__(self, strategy_name: str):\n        self.strategy_name = strategy_name\n        self.trades = []\n        self.signals = []\n        \n    def record_signal(self, date: datetime, symbol: str, action: str, \n                      price: float, shares: int, reason: str = \"\"):\n        \"\"\"记录信号\"\"\"\n        self.signals.append({\n            'date': date,\n            'symbol': symbol,\n            'action': action,\n            'price': price,\n            'shares': shares,\n            'reason': reason\n        })\n        \n    def record_trade(self, date: datetime, symbol: str, action: str,\n                     price: float, shares: int, amount: float, \n                     commission: float, status: str = \"FILLED\"):\n        \"\"\"记录成交\"\"\"\n        self.trades.append({\n            'date': date,\n            'symbol': symbol,\n            'action': action,\n            'price': price,\n            'shares': shares,\n            'amount': amount,\n            'commission': commission,\n            'status': status\n        })\n        \n    def calculate_live_performance(self) -> Dict:\n        \"\"\"计算实盘表现\"\"\"\n        if not self.trades:\n            return {}\n            \n        df = pd.DataFrame(self.trades)\n        \n        # 计算盈亏\n        buys = df[df['action'] == 'BUY']['amount'].sum()\n        sells = df[df['action'] == 'SELL']['amount'].sum()\n        commissions = df['commission'].sum()\n        \n        pnl = sells - buys - commissions\n        \n        return {\n            'total_trades': len(df),\n            'total_pnl': pnl,\n            'total_commission': commissions,\n            'buy_amount': buys,\n            'sell_amount': sells\n        }\n","path":"/Users/ling/quant/monitoring/strategy_monitor.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":2737,"output":2732,"cacheRead":67776,"cacheWrite":0,"totalTokens":73245,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775802026853,"responseId":"b0ff4c91413c4c03b6838d40cfe98e25"}}
