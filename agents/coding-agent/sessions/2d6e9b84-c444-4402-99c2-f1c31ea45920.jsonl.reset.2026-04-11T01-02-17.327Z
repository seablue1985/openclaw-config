{"type":"message","id":"dce777d4","parentId":"ad853d16","timestamp":"2026-04-10T12:06:19.990Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user wants me to re-analyze the data with correct calculations. Let me properly calculate the metrics from the raw equity data.","thinkingSignature":"48484e5f422b943c0784361080151fc7ce0f6362b747862c6b6a8fabc819a20c"},{"type":"toolCall","id":"call_30537e566ed14d979547c038","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport pandas as pd\nimport numpy as np\nimport baostock as bs\n\neq = pd.read_csv('/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/backtest/results/stock_alpha_v1_20260307/equity_curve.csv')\neq['date'] = pd.to_datetime(eq['date'])\neq = eq.sort_values('date').reset_index(drop=True)\n\n# 权益从1开始，初期有几天是1.0（模拟期），实际运行从2018-02-01开始\n# 找到第一个>1.0的日期作为实盘起始\nfirst_active = eq[eq['equity'] > 1.0].iloc[0]\nfirst_idx = eq[eq['date'] == first_active['date']].index[0]\nprint(f\"实盘起始: {first_active['date'].date()}, 初始权益={first_active['equity']:.4f}\")\n\n# 只用实盘期数据\nactive = eq[eq['date'] >= first_active['date']].copy()\nactive = active[active['equity'] > 0].copy().reset_index(drop=True)\n\n# 权益归一化到1.0\ninit_equity = active['equity'].iloc[0]\nactive['norm_equity'] = active['equity'] / init_equity\n\n# 重新计算回撤\npeak = np.maximum.accumulate(active['norm_equity'].values)\nactive['real_drawdown'] = (active['norm_equity'].values - peak) / peak\n\n# 每日收益\nactive['daily_ret'] = active['norm_equity'].pct_change().fillna(0)\n\nprint(\"=\" * 70)\nprint(\"📊 小市值策略真实绩效 (stock_alpha_v1, 正确计算)\")\nprint(\"=\" * 70)\nprint(f\"时间: {active['date'].iloc[0].date()} ~ {active['date'].iloc[-1].date()}\")\nprint(f\"天数: {len(active)}天, 约{(active['date'].iloc[-1] - active['date'].iloc[0]).days/365:.1f}年\")\n\n# 按年度\nactive['year'] = active['date'].dt.year\nprint(f\"\\n{'年份':<6} {'年初权益':>10} {'年末权益':>10} {'年收益':>10} {'最大回撤':>10}\")\nprint(\"-\" * 50)\n\nannual_returns = []\nfor year in sorted(active['year'].unique()):\n    ydata = active[active['year'] == year]\n    if len(ydata) == 0:\n        continue\n    y_start = ydata['norm_equity'].iloc[0]\n    y_end = ydata['norm_equity'].iloc[-1]\n    y_ret = (y_end / y_start - 1) * 100\n    y_dd = ydata['real_drawdown'].min() * 100\n    annual_returns.append({'year': year, 'return': y_ret, 'drawdown': y_dd})\n    print(f\"{year:<6} {y_start:>10.4f} {y_end:>10.4f} {y_ret:>9.2f}% {y_dd:>9.2f}%\")\n\n# 总体\ntotal_ret = (active['norm_equity'].iloc[-1] / active['norm_equity'].iloc[0] - 1) * 100\nyears = (active['date'].iloc[-1] - active['date'].iloc[0]).days / 365\nannual = ((active['norm_equity'].iloc[-1] / active['norm_equity'].iloc[0]) ** (1/years) - 1) * 100 if years > 0 else 0\noverall_dd = active['real_drawdown'].min() * 100\n\n# 夏普\ndaily_rets = active['daily_ret'].dropna()\nsharpe = daily_rets.mean() / daily_rets.std() * np.sqrt(252) if daily_rets.std() > 0 else 0\n\n# 卡玛比\ncalmar = annual / abs(overall_dd) if overall_dd != 0 else 0\n\nprint()\nprint(\"=\" * 70)\nprint(\"📈 总体绩效\")\nprint(\"=\" * 70)\nprint(f\"  总收益:     {total_ret:>8.2f}%\")\nprint(f\"  年化:       {annual:>8.2f}%\")\nprint(f\"  夏普:       {sharpe:>8.3f}\")\nprint(f\"  卡玛比:     {calmar:>8.3f}\")\nprint(f\"  最大回撤:   {overall_dd:>8.2f}%\")\n\n# 沪深300对比\nlg = bs.login()\nrs = bs.query_history_k_data_plus('sh.000300', 'close',\n    start_date=str(active['date'].iloc[0].date()), \n    end_date=str(active['date'].iloc[-1].date()), frequency='d')\ndl = []\nwhile rs.error_code == '0' and rs.next():\n    dl.append(rs.get_row_data())\ndf_bench = pd.DataFrame(dl, columns=['date','close'])\ndf_bench['close'] = pd.to_numeric(df_bench['close'], errors='coerce')\ndf_bench['date'] = pd.to_datetime(df_bench['date'])\nbs.logout()\n\nbench_start = df_bench['close'].dropna().iloc[0]\nbench_end = df_bench['close'].dropna().iloc[-1]\nbench_ret = (bench_end / bench_start - 1) * 100\nbench_years = (df_bench['date'].iloc[-1] - df_bench['date'].iloc[0]).days / 365\nbench_annual = ((bench_end / bench_start) ** (1/bench_years) - 1) * 100 if bench_years > 0 else 0\n\nprint()\nprint(\"=\" * 70)\nprint(\"🔄 vs 沪深300\")\nprint(\"=\" * 70)\nprint(f\"  基准总收益:   {bench_ret:>8.2f}%\")\nprint(f\"  基准年化:     {bench_annual:>8.2f}%\")\nprint(f\"  超额收益:     {total_ret - bench_ret:>+8.2f}%\")\nprint(f\"  年化超额:     {annual - bench_annual:>+8.2f}%\")\n\nprint()\nprint(\"=\" * 70)\nprint(\"⚠️  结论\")\nprint(\"=\" * 70)\nif total_ret > bench_ret:\n    print(f\"  ✅ 跑赢沪深300 {total_ret - bench_ret:+.2f}%\")\nelse:\n    print(f\"  ❌ 跑输沪深300 {bench_ret - total_ret:.2f}%\")\n\nif annual > 50:\n    print(f\"  ✅ 年化 {annual:.2f}% 超过50%目标!\")\nelif annual > 20:\n    print(f\"  🟡 年化 {annual:.2f}% (接近优秀水平)\")\nelse:\n    print(f\"  ⚠️ 年化 {annual:.2f}% 距离50%有差距\")\n\nprint(f\"  最大回撤修正为: {overall_dd:.2f}%\")\nEOF","timeout":30}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":125551,"output":1646,"cacheRead":1152,"cacheWrite":0,"totalTokens":128349,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775822742490,"responseId":"06281a96dc7b628a96b3aeb98c60b153"}}
