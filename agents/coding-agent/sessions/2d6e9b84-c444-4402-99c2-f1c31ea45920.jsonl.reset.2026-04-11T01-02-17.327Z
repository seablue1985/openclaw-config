{"type":"message","id":"556f9f27","parentId":"a56eda15","timestamp":"2026-04-10T07:33:51.658Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"functions.read:75","name":"read","arguments":{"path":"/Users/ling/quant/strategies/framework/strategy_comparison.py","limit":20}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":286,"output":33,"cacheRead":127296,"cacheWrite":0,"totalTokens":127615,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775806421962,"responseId":"6875b0b5b7e0405caffb2e778da3ac44"}}
{"type":"message","id":"31fda4bb","parentId":"556f9f27","timestamp":"2026-04-10T07:33:51.748Z","message":{"role":"toolResult","toolCallId":"functions.read:75","toolName":"read","content":[{"type":"text","text":"\"\"\"\n策略对比分析框架\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom typing import Dict, List\nimport matplotlib.pyplot as plt\nimport logging\n\ntry:\n    import plotly.graph_objects as go\n    import plotly.express as px\n    from plotly.subplots import make_subplots\n    PLOTLY_AVAILABLE = True\nexcept ImportError:\n    PLOTLY_AVAILABLE = False\n\nlogger = logging.getLogger(__name__)\n\n\n[275 more lines in file. Use offset=21 to continue.]"}],"isError":false,"timestamp":1775806431741}}
{"type":"message","id":"4da99e9c","parentId":"31fda4bb","timestamp":"2026-04-10T07:33:59.288Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"functions.read:76","name":"read","arguments":{"path":"/Users/ling/quant/strategies/framework/strategy_comparison.py","offset":21}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":183,"output":33,"cacheRead":127552,"cacheWrite":0,"totalTokens":127768,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775806431749,"responseId":"c1d52b29147742e1b908ba8828e21ad9"}}
{"type":"message","id":"eac3925d","parentId":"4da99e9c","timestamp":"2026-04-10T07:33:59.364Z","message":{"role":"toolResult","toolCallId":"functions.read:76","toolName":"read","content":[{"type":"text","text":"\nclass StrategyComparison:\n    \"\"\"\n    多策略对比分析\n    \"\"\"\n    \n    def __init__(self):\n        self.results = {}\n        \n    def add_strategy(self, name: str, daily_returns: pd.Series, \n                     trades: List[Dict] = None, metadata: Dict = None):\n        \"\"\"添加策略结果\"\"\"\n        self.results[name] = {\n            'returns': daily_returns,\n            'trades': trades or [],\n            'metadata': metadata or {}\n        }\n        \n    def compare(self, benchmark: pd.Series = None) -> pd.DataFrame:\n        \"\"\"生成对比报告\"\"\"\n        comparison = {}\n        \n        for name, data in self.results.items():\n            returns = data['returns']\n            \n            # 计算各项指标\n            total_return = (returns.sum()) * 100\n            annual_return = (returns.mean() * 252) * 100\n            volatility = (returns.std() * np.sqrt(252)) * 100\n            sharpe = (returns.mean() * 252) / (returns.std() * np.sqrt(252)) if returns.std() > 0 else 0\n            \n            # 最大回撤\n            cumret = (1 + returns).cumprod()\n            running_max = cumret.expanding().max()\n            drawdown = (cumret - running_max) / running_max\n            max_dd = drawdown.min() * 100\n            \n            # 卡玛比率\n            calmar = annual_return / abs(max_dd) if max_dd != 0 else 0\n            \n            comparison[name] = {\n                '总收益率': f\"{total_return:.2f}%\",\n                '年化收益': f\"{annual_return:.2f}%\",\n                '年化波动': f\"{volatility:.2f}%\",\n                '夏普比率': f\"{sharpe:.3f}\",\n                '最大回撤': f\"{max_dd:.2f}%\",\n                '卡玛比率': f\"{calmar:.3f}\",\n                '胜率': f\"{(returns > 0).sum() / len(returns) * 100:.1f}%\",\n            }\n            \n        df = pd.DataFrame(comparison).T\n        \n        # 添加与基准的对比\n        if benchmark is not None:\n            df['超额收益'] = df['总收益率'].apply(\n                lambda x: f\"{float(x.strip('%')) - (benchmark.sum() * 100):.2f}%\"\n            )\n            \n        return df\n        \n    def plot_comparison(self, save_path: str = None, use_plotly: bool = True):\n        \"\"\"绘制对比图\"\"\"\n        if use_plotly and PLOTLY_AVAILABLE:\n            return self._plot_plotly(save_path)\n        else:\n            return self._plot_matplotlib(save_path)\n            \n    def _plot_plotly(self, save_path: str = None):\n        \"\"\"使用 Plotly 绘制\"\"\"\n        if not PLOTLY_AVAILABLE:\n            logger.warning(\"Plotly 未安装，使用 matplotlib\")\n            return self._plot_matplotlib(save_path)\n            \n        fig = make_subplots(\n            rows=2, cols=2,\n            subplot_titles=('累计收益曲线', '回撤曲线', '收益分布', '月度收益'),\n            specs=[[{}, {}], [{}, {}]]\n        )\n        \n        colors = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd']\n        \n        for i, (name, data) in enumerate(self.results.items()):\n            returns = data['returns']\n            cumret = (1 + returns).cumprod()\n            color = colors[i % len(colors)]\n            \n            # 1. 累计收益\n            fig.add_trace(\n                go.Scatter(x=cumret.index, y=cumret, name=name, \n                          line=dict(color=color)),\n                row=1, col=1\n            )\n            \n            # 2. 回撤曲线\n            running_max = cumret.expanding().max()\n            drawdown = (cumret - running_max) / running_max\n            fig.add_trace(\n                go.Scatter(x=drawdown.index, y=drawdown, name=f\"{name} 回撤\",\n                          line=dict(color=color, dash='dash'), showlegend=False),\n                row=1, col=2\n            )\n            \n            # 3. 收益分布\n            fig.add_trace(\n                go.Histogram(x=returns * 100, name=name, opacity=0.6,\n                           marker_color=color, showlegend=False),\n                row=2, col=1\n            )\n            \n        fig.update_layout(\n            height=800,\n            title_text=\"策略对比分析\",\n            showlegend=True\n        )\n        \n        if save_path:\n            fig.write_html(save_path)\n            \n        return fig\n        \n    def _plot_matplotlib(self, save_path: str = None):\n        \"\"\"使用 Matplotlib 绘制\"\"\"\n        fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n        \n        # 1. 累计收益\n        ax1 = axes[0, 0]\n        for name, data in self.results.items():\n            cumret = (1 + data['returns']).cumprod()\n            ax1.plot(cumret.index, cumret, label=name)\n        ax1.set_title('累计收益曲线')\n        ax1.legend()\n        ax1.set_ylabel('净值')\n        \n        # 2. 回撤\n        ax2 = axes[0, 1]\n        for name, data in self.results.items():\n            cumret = (1 + data['returns']).cumprod()\n            cummax = cumret.cummax()\n            drawdown = (cumret - cummax) / cummax\n            ax2.fill_between(drawdown.index, drawdown, 0, alpha=0.3, label=name)\n        ax2.set_title('回撤曲线')\n        ax2.legend()\n        \n        # 3. 收益分布\n        ax3 = axes[1, 0]\n        for name, data in self.results.items():\n            ax3.hist(data['returns'] * 100, bins=50, alpha=0.5, label=name)\n        ax3.set_title('日收益分布')\n        ax3.legend()\n        \n        # 4. 月度收益\n        ax4 = axes[1, 1]\n        first_strategy = list(self.results.keys())[0]\n        returns = self.results[first_strategy]['returns']\n        monthly = returns.resample('M').apply(lambda x: (1+x).prod() - 1)\n        colors = ['green' if x > 0 else 'red' for x in monthly]\n        ax4.bar(range(len(monthly)), monthly * 100, color=colors)\n        ax4.set_title(f'{first_strategy} - 月度收益')\n        \n        plt.tight_layout()\n        \n        if save_path:\n            plt.savefig(save_path, dpi=150, bbox_inches='tight')\n            \n        return fig\n        \n    def generate_report(self, output_path: str = None) -> str:\n        \"\"\"生成对比报告\"\"\"\n        comparison_df = self.compare()\n        \n        report = f\"\"\"\n# 策略对比分析报告\n\n生成时间: {pd.Timestamp.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n## 策略列表\n{', '.join(self.results.keys())}\n\n## 绩效对比\n\n{comparison_df.to_markdown()}\n\n## 详细分析\n\n\"\"\"\n        \n        for name, data in self.results.items():\n            returns = data['returns']\n            report += f\"\\n### {name}\\n\"\n            report += f\"- 总收益: {(returns.sum() * 100):.2f}%\\n\"\n            report += f\"- 年化收益: {(returns.mean() * 252 * 100):.2f}%\\n\"\n            report += f\"- 夏普比率: {(returns.mean() * 252 / (returns.std() * np.sqrt(252))):.3f}\\n\"\n            \n        if output_path:\n            with open(output_path, 'w', encoding='utf-8') as f:\n                f.write(report)\n                \n        return report\n\n\nclass PortfolioOptimizer:\n    \"\"\"\n    投资组合优化器\n    \"\"\"\n    \n    @staticmethod\n    def mean_variance_optimization(returns: pd.DataFrame, \n                                    risk_free_rate: float = 0.03,\n                                    target_return: float = None) -> Dict:\n        \"\"\"\n        均值-方差优化\n        \n        Returns:\n            最优权重配置\n        \"\"\"\n        n_assets = len(returns.columns)\n        \n        # 预期收益和协方差\n        expected_returns = returns.mean() * 252\n        cov_matrix = returns.cov() * 252\n        \n        # 生成随机权重组合\n        n_portfolios = 10000\n        weights_record = []\n        returns_record = []\n        risks_record = []\n        sharpe_record = []\n        \n        np.random.seed(42)\n        \n        for _ in range(n_portfolios):\n            weights = np.random.random(n_assets)\n            weights /= np.sum(weights)\n            \n            portfolio_return = np.dot(weights, expected_returns)\n            portfolio_risk = np.sqrt(np.dot(weights.T, np.dot(cov_matrix, weights)))\n            sharpe = (portfolio_return - risk_free_rate) / portfolio_risk\n            \n            weights_record.append(weights)\n            returns_record.append(portfolio_return)\n            risks_record.append(portfolio_risk)\n            sharpe_record.append(sharpe)\n            \n        # 找到最优组合\n        max_sharpe_idx = np.argmax(sharpe_record)\n        min_risk_idx = np.argmin(risks_record)\n        \n        return {\n            'max_sharpe_weights': dict(zip(returns.columns, weights_record[max_sharpe_idx])),\n            'max_sharpe_return': returns_record[max_sharpe_idx],\n            'max_sharpe_risk': risks_record[max_sharpe_idx],\n            'max_sharpe_ratio': sharpe_record[max_sharpe_idx],\n            'min_risk_weights': dict(zip(returns.columns, weights_record[min_risk_idx])),\n            'min_risk_return': returns_record[min_risk_idx],\n            'min_risk': risks_record[min_risk_idx],\n            'efficient_frontier': {\n                'returns': returns_record,\n                'risks': risks_record,\n                'sharpe': sharpe_record\n            }\n        }\n        \n    @staticmethod\n    def risk_parity_weights(returns: pd.DataFrame) -> pd.Series:\n        \"\"\"\n        风险平价权重\n        \n        使各资产对组合风险的贡献相等\n        \"\"\"\n        cov = returns.cov()\n        inv_diag = 1 / np.diag(cov)\n        weights = inv_diag / inv_diag.sum()\n        \n        return pd.Series(weights, index=returns.columns)\n"}],"isError":false,"timestamp":1775806439351}}
