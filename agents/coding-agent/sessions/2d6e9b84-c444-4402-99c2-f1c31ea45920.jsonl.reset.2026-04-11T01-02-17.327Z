{"type":"message","id":"4e619931","parentId":"1373e117","timestamp":"2026-04-10T09:35:39.091Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's a typo in my code - I wrote `row['continue']` instead of `row['close']`. Let me fix that.\n","thinkingSignature":"acd188c2d6cce05f5ee2bc67561490c73e04108488ef65c1d51afddb30381027"},{"type":"toolCall","id":"call_function_z128bm8an87y_1","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport sys\nsys.path.insert(0, '/Users/ling/quant/strategies/framework')\n\nimport baostock as bs\nimport pandas as pd\nimport numpy as np\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# 获取数据\nlg = bs.login()\nrs = bs.query_history_k_data_plus('sh.000300', 'date,open,high,low,close,volume',\n    start_date='2024-01-01', end_date='2026-04-10', frequency='d')\ndata_list = []\nwhile rs.error_code == '0' and rs.next():\n    data_list.append(rs.get_row_data())\ndf = pd.DataFrame(data_list, columns=rs.fields)\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date')\nfor col in ['open','high','low','close','volume']:\n    df[col] = pd.to_numeric(df[col], errors='coerce')\ndf = df.dropna()\nbs.logout()\n\nprint(f\"数据: {len(df)} 条, {df.index[0].date()} ~ {df.index[-1].date()}\")\nprint()\n\n# 回测函数\ndef backtest(data, ma_short, ma_long, use_stop_loss=False, stop_loss_pct=0.05, use_filter=False):\n    capital = 100000\n    cash = capital\n    shares = 0\n    trades = []\n    \n    ma_s = data['close'].rolling(ma_short).mean()\n    ma_l = data['close'].rolling(ma_long).mean()\n    vma20 = data['volume'].rolling(20).mean()\n    \n    for date, row in data.iterrows():\n        if pd.isna(ma_s.loc[date]) or pd.isna(ma_l.loc[date]):\n            continue\n        price = row['close']\n        \n        # 买入条件\n        buy_signal = ma_s.loc[date] > ma_l.loc[date] and ma_s.shift(1).loc[date] <= ma_l.shift(1).loc[date]\n        \n        # 滤网: 成交量放大\n        if use_filter:\n            buy_signal = buy_signal and row['volume'] > vma20.loc[date] * 0.8\n        \n        # 止损\n        if use_stop_loss and shares > 0:\n            if len([t for t in trades if t[0]=='BUY']) > 0:\n                cost = [t for t in trades if t[0]=='BUY'][-1][2]\n                if price < cost * (1 - stop_loss_pct):\n                    cash += shares * price * 0.9997\n                    trades.append(('SELL', date.date(), price, '止损'))\n                    shares = 0\n                    buy_signal = False\n        \n        if shares == 0 and buy_signal:\n            shares = int(cash / price * 0.95)\n            cash -= shares * price * 1.0003\n            trades.append(('BUY', date.date(), price))\n        elif shares > 0 and ma_s.loc[date] < ma_l.loc[date] and ma_s.shift(1).loc[date] >= ma_l.shift(1).loc[date]:\n            cash += shares * price * 0.9997\n            trades.append(('SELL', date.date(), price))\n            shares = 0\n    \n    final_value = cash + shares * data.iloc[-1]['close']\n    total_return = (final_value - capital) / capital\n    annual_return = (1 + total_return) ** (252 / len(data)) - 1\n    \n    # 计算夏普\n    equity = []\n    tc, ts = capital, 0\n    for date, row in data.iterrows():\n        if pd.isna(ma_s.loc[date]) or pd.isna(ma_l.loc[date]):\n            equity.append(tc + ts * row['close'])\n            continue\n        price = row['close']\n        buy = ma_s.loc[date] > ma_l.loc[date] and ma_s.shift(1).loc[date] <= ma_l.shift(1).loc[date]\n        sell = ma_s.loc[date] < ma_l.loc[date] and ma_s.shift(1).loc[date] >= ma_l.shift(1).loc[date]\n        if ts == 0 and buy:\n            ts = int(tc / price * 0.95)\n            tc -= ts * price * 1.0003\n        elif ts > 0 and sell:\n            tc += ts * price * 0.9997\n            ts = 0\n        equity.append(tc + ts * price)\n    \n    equity = pd.Series(equity, index=data.index)\n    returns = equity.pct_change().dropna()\n    sharpe = returns.mean() / returns.std() * np.sqrt(252) if returns.std() > 0 else 0\n    peak = equity.cummax()\n    max_dd = ((equity - peak) / peak).min()\n    \n    # 胜率\n    buy_trades = [t for t in trades if t[0] == 'BUY']\n    sell_trades = [t for t in trades if t[0] == 'SELL']\n    wins = 0\n    for i, t in enumerate(sell_trades):\n        if i < len(buy_trades):\n            if t[2] > buy_trades[i][2]:\n                wins += 1\n    win_rate = wins / len(sell_trades) if sell_trades else 0\n    \n    return {\n        'ma': f\"{ma_short}/{ma_long}\",\n        'total': total_return,\n        'annual': annual_return,\n        'sharpe': sharpe,\n        'max_dd': max_dd,\n        'trades': len(trades),\n        'win_rate': win_rate\n    }\n\n# 参数优化\nprint(\"=\" * 70)\nprint(\"🔧 参数优化 - 寻找最佳均线组合\")\nprint(\"=\" * 70)\n\nresults = []\nfor short in [5, 10, 15, 20]:\n    for long in [30, 40, 60, 80]:\n        if short >= long:\n            continue\n        # 基础策略\n        r = backtest(df, short, long)\n        results.append((r, False, False))\n        # 带止损\n        r2 = backtest(df, short, long, use_stop_loss=True)\n        results.append((r2, True, False))\n        # 带滤网\n        r3 = backtest(df, short, long, use_filter=True)\n        results.append((r3, False, True))\n\nresults.sort(key=lambda x: x[0]['sharpe'], reverse=True)\n\nprint(f\"{'MA周期':<8} {'止损':<4} {'滤网':<4} {'总收益':>8} {'年化':>8} {'夏普':>6} {'回撤':>8} {'交易':>5} {'胜率':>6}\")\nprint(\"-\" * 70)\n\nfor r, use_sl, use_f in results[:15]:\n    stop = \"√\" if use_sl else \"-\"\n    filt = \"√\" if use_f else \"-\"\n    print(f\"{r['ma']:<8} {stop:<4} {filt:<4} {r['total']:>7.2%} {r['annual']:>7.2%} {r['sharpe']:>6.3f} {r['max_dd']:>7.2%} {r['trades']:>5} {r['win_rate']:>5.1%}\")\n\n# 通过自检的\nprint()\nprint(\"=\" * 70)\nprint(\"✅ 通过自检的策略 (夏普>1.0 且 年化>10% 且 回撤<25%)\")\nprint(\"=\" * 70)\n\npassed = [r for r, _, _ in results if r['sharpe'] > 1.0 and r['annual'] > 0.10 and r['max_dd'] > -0.25]\n\nif passed:\n    print(f\"{'MA周期':<8} {'总收益':>8} {'年化':>8} {'夏普':>6} {'回撤':>8} {'交易':>5} {'胜率':>6}\")\n    print(\"-\" * 55)\n    for r in passed[:5]:\n        print(f\"{r['ma']:<8} {r['total']:>7.2%} {r['annual']:>7.2%} {r['sharpe']:>6.3f} {r['max_dd']:>7.2%} {r['trades']:>5} {r['win_rate']:>5.1%}\")\nelse:\n    print(\"暂无完全通过自检的策略，显示最优5个:\")\n    for r, _, _ in results[:5]:\n        print(f\"  {r['ma']}: 夏普={r['sharpe']:.3f}, 年化={r['annual']:.2%}\")\n\nprint()\nprint(f\"优化完成 | 尝试了 {len(results)} 种参数组合\")\nEOF","timeout":120}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":560,"output":2036,"cacheRead":51328,"cacheWrite":0,"totalTokens":53924,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775813693539,"responseId":"0627f73ec6e83312463d4c9344479375"}}
