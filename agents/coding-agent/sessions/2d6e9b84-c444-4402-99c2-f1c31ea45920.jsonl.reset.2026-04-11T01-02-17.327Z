{"type":"message","id":"1cb2e17b","parentId":"53503a93","timestamp":"2026-04-10T09:26:15.816Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user replied to the message saying \"报告\" (report). They want to see the self-check report. Let me run the self-check again with proper metrics and generate a comprehensive report.","thinkingSignature":"8be997dbe64243c62e1d876fcb428168c536072b1a55f34566bd4380e92b78cd"},{"type":"text","text":"\n\n好的，我来生成完整的自检报告。\n\n"},{"type":"toolCall","id":"call_16d9641133b5411da0d6f9ae","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport sys\nsys.path.insert(0, '/Users/ling/quant/strategies/framework')\n\nimport baostock as bs\nimport pandas as pd\nimport numpy as np\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# 获取数据\nlg = bs.login()\nrs = bs.query_history_k_data_plus('sh.000300', 'date,open,high,low,close,volume',\n    start_date='2024-01-01', end_date='2026-04-10', frequency='d')\ndata_list = []\nwhile rs.error_code == '0' and rs.next():\n    data_list.append(rs.get_row_data())\ndf = pd.DataFrame(data_list, columns=rs.fields)\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date')\nfor col in ['open','high','low','close','volume']:\n    df[col] = pd.to_numeric(df[col], errors='coerce')\ndf = df.dropna()\nbs.logout()\n\n# 均线金叉策略回测\ncapital = 100000\ncash = capital\nshares = 0\ntrades = []\n\nma5 = df['close'].rolling(5).mean()\nma20 = df['close'].rolling(20).mean()\n\nfor date, row in df.iterrows():\n    if pd.isna(ma5.loc[date]) or pd.isna(ma20.loc[date]):\n        continue\n    price = row['close']\n    if shares == 0 and ma5.loc[date] > ma20.loc[date] and ma5.shift(1).loc[date] <= ma20.shift(1).loc[date]:\n        shares = int(cash / price * 0.95)\n        cash -= shares * price * 1.0003\n        trades.append(('BUY', date.date(), price, shares))\n    elif shares > 0 and ma5.loc[date] < ma20.loc[date] and ma5.shift(1).loc[date] >= ma20.shift(1).loc[date]:\n        cash += shares * price * 0.9997\n        trades.append(('SELL', date.date(), price))\n        shares = 0\n\nfinal_value = cash + shares * df.iloc[-1]['close']\ntotal_return = (final_value - capital) / capital\nannual_return = (1 + total_return) ** (252 / len(df)) - 1\n\n# 计算夏普和回撤\nequity = []\ntemp_cash = capital\ntemp_shares = 0\nfor date, row in df.iterrows():\n    if pd.isna(ma5.loc[date]) or pd.isna(ma20.loc[date]):\n        equity.append(temp_cash + temp_shares * row['close'])\n        continue\n    price = row['close']\n    if temp_shares == 0 and ma5.loc[date] > ma20.loc[date] and ma5.shift(1).loc[date] <= ma20.shift(1).loc[date]:\n        temp_shares = int(temp_cash / price * 0.95)\n        temp_cash -= temp_shares * price * 1.0003\n    elif temp_shares > 0 and ma5.loc[date] < ma20.loc[date] and ma5.shift(1).loc[date] >= ma20.shift(1).loc[date]:\n        temp_cash += temp_shares * price * 0.9997\n        temp_shares = 0\n    equity.append(temp_cash + temp_shares * price)\n\nequity = pd.Series(equity, index=df.index)\nreturns = equity.pct_change().dropna()\nsharpe = returns.mean() / returns.std() * np.sqrt(252) if returns.std() > 0 else 0\npeak = equity.cummax()\nmax_drawdown = ((equity - peak) / peak).min()\n\n# 胜率计算\nbuy_trades = [t for t in trades if t[0] == 'BUY']\nsell_trades = [t for t in trades if t[0] == 'SELL']\nwin_count = 0\nfor i, t in enumerate(sell_trades):\n    if i < len(buy_trades):\n        buy_price = buy_trades[i][2]\n        sell_price = t[2]\n        if sell_price > buy_price:\n            win_count += 1\nwin_rate = win_count / len(sell_trades) if sell_trades else 0\n\nprint(\"=\" * 65)\nprint(\"📋 量化策略自检报告\")\nprint(\"=\" * 65)\nprint(f\"策略名称: 均线金叉策略 (MA Cross)\")\nprint(f\"版本: v1.0.0\")\nprint(f\"数据周期: 2024-01-02 ~ 2026-04-09\")\nprint(f\"数据来源: 沪深300指数 (BaoStock)\")\nprint()\nprint(\"【一、回测绩效指标】\")\nprint(f\"  总收益率:    {total_return:>8.2%}\")\nprint(f\"  年化收益率:  {annual_return:>8.2%}\")\nprint(f\"  夏普比率:    {sharpe:>8.3f}\")\nprint(f\"  最大回撤:    {max_drawdown:>8.2%}\")\nprint(f\"  交易次数:    {len(trades):>8} 次\")\nprint(f\"  胜率:        {win_rate:>8.2%}\")\nprint()\nprint(\"【二、检查项结果】\")\nprint(f\"  {'检查项':<30} {'标准':<12} {'实际':<10} {'结果'}\")\nprint(f\"  {'-'*60}\")\n\nchecks = [\n    (\"夏普比率 > 1.0\", \">1.0\", f\"{sharpe:.3f}\", sharpe > 1.0),\n    (\"最大回撤 < 25%\", \"<25%\", f\"{max_drawdown:.2%}\", max_drawdown > -0.25),\n    (\"年化收益 > 10%\", \">10%\", f\"{annual_return:.2%}\", annual_return > 0.10),\n    (\"交易次数 > 30\", \">30次\", f\"{len(trades)}次\", len(trades) > 30),\n    (\"胜率 > 50%\", \">50%\", f\"{win_rate:.2%}\", win_rate > 0.5),\n]\nfor name, std, actual, passed in checks:\n    status = \"✅\" if passed else \"❌\"\n    print(f\"  {name:<30} {std:<12} {actual:<10} {status}\")\n\nprint()\nprint(\"【三、自检结论】\")\npassed_count = sum(1 for _, _, _, p in checks if p)\nfailed_count = len(checks) - passed_count\nprint(f\"  检查项: {passed_count} 通过 / {failed_count} 未通过\")\nif failed_count == 0:\n    print(\"  状态: ✅ 可以上线\")\nelse:\n    print(\"  状态: ⚠️  需要优化\")\n    print(\"  优化建议:\")\n    if sharpe <= 1.0:\n        print(\"    → 调整均线周期参数 (当前5/20，可尝试10/30)\")\n    if annual_return <= 0.10:\n        print(\"    → 增加止损止盈机制\")\n    if win_rate <= 0.5:\n        print(\"    → 添加滤网减少假信号\")\n\nprint()\nprint(\"=\" * 65)\nprint(f\"生成时间: 2026-04-10 17:23 | 模型: MiniMax-M2.7\")\nprint(\"=\" * 65)\nEOF\n","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":46917,"output":1713,"cacheRead":1152,"cacheWrite":0,"totalTokens":49782,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775813130393,"responseId":"0627f50b32bbfb7aedc229dfa3cee997"}}
