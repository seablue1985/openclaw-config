{"type":"message","id":"b8bbeae2","parentId":"5ab5eb07","timestamp":"2026-04-10T08:57:23.178Z","message":{"role":"toolResult","toolCallId":"call_function_nl3k6pzvd6c6_1","toolName":"process","content":[{"type":"text","text":"---\n=== 用 BaoStock 获取真实数据 ===\nlogin success!\n登录: success\n获取到 1212 条沪深300数据\n时间范围: 2020-01-02 ~ 2024-12-31\nlogout success!\n登录成功，数据格式正确!\n\n\nProcess exited with code 0."}],"details":{"status":"completed","sessionId":"kind-crustacean","exitCode":0,"aggregated":"---\n=== 用 BaoStock 获取真实数据 ===\nlogin success!\n登录: success\n获取到 1212 条沪深300数据\n时间范围: 2020-01-02 ~ 2024-12-31\nlogout success!\n登录成功，数据格式正确!\n","name":"find /Users/ling/quant/data"},"isError":false,"timestamp":1775811443170}}
{"type":"message","id":"5a6c4417","parentId":"b8bbeae2","timestamp":"2026-04-10T08:57:50.558Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"BaoStock works! Now let me run the real backtest with actual market data using BaoStock. I'll also write the results to the reports directory.","thinkingSignature":"90c06e72aba29ddacb547cf0a9d5c8ccf2fb41b989a05b3517ea266864f7fdad"},{"type":"text","text":"BaoStock 数据获取成功！现在用真实数据运行回测：\n"},{"type":"toolCall","id":"call_function_w7yaz3fw6xq2_1","name":"exec","arguments":{"command":"python3 -c \"\nimport baostock as bs\nimport pandas as pd\nimport numpy as np\nimport warnings\nwarnings.filterwarnings('ignore')\n\nprint('=' * 60)\nprint('🎯 真实数据回测 - 沪深300指数 (2020-2024)')\nprint('=' * 60)\n\n# 获取数据\nlg = bs.login()\nrs = bs.query_history_k_data_plus('sh.000300', 'date,open,high,low,close,volume',\n    start_date='2020-01-01', end_date='2024-12-31', frequency='d')\ndata_list = []\nwhile rs.error_code == '0' and rs.next():\n    data_list.append(rs.get_row_data())\ndf = pd.DataFrame(data_list, columns=rs.fields)\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date')\nfor col in ['open','high','low','close','volume']:\n    df[col] = pd.to_numeric(df[col], errors='coerce')\ndf = df.dropna()\nbs.logout()\n\nprint(f'数据: {len(df)} 条 | {df.index[0].date()} ~ {df.index[-1].date()}')\n\n# 简单回测引擎\ndef backtest(data, strategy_func, name):\n    capital = 100000\n    cash = capital\n    shares = 0\n    trades = []\n    equity = []\n    \n    signals = strategy_func(data)\n    for i, (date, row) in enumerate(data.iterrows()):\n        if pd.isna(signals.loc[date]):\n            equity.append(cash + shares * row['close'])\n            continue\n        \n        price = row['close']\n        sig = signals.loc[date]\n        \n        if sig == 1 and shares == 0:\n            shares = int(cash / price * 0.95)\n            cost = shares * price * 1.0003\n            cash -= cost\n            trades.append(('BUY', date.date(), price, shares))\n        elif sig == -1 and shares > 0:\n            proceeds = shares * price * 0.9997\n            cash += proceeds\n            trades.append(('SELL', date.date(), price))\n            shares = 0\n        \n        equity.append(cash + shares * price)\n    \n    equity = pd.Series(equity, index=data.index)\n    returns = equity.pct_change().dropna()\n    \n    # 计算指标\n    total_ret = (equity.iloc[-1] - capital) / capital\n    annual_ret = (1 + total_ret) ** (252 / len(data)) - 1\n    sharpe = returns.mean() / returns.std() * np.sqrt(252) if returns.std() > 0 else 0\n    peak = equity.cummax()\n    drawdown = (equity - peak) / peak\n    max_dd = drawdown.min()\n    \n    return {\n        'total_return': total_ret,\n        'annual_return': annual_ret,\n        'sharpe': sharpe,\n        'max_drawdown': max_dd,\n        'trade_count': len(trades),\n        'equity': equity,\n        'trades': trades\n    }\n\n# 均线金叉策略\ndef ma_cross(data):\n    ma5 = data['close'].rolling(5).mean()\n    ma20 = data['close'].rolling(20).mean()\n    signals = pd.Series(0, index=data.index)\n    golden = (ma5 > ma20) & (ma5.shift(1) <= ma20.shift(1))\n    death = (ma5 < ma20) & (ma5.shift(1) >= ma20.shift(1))\n    signals[golden] = 1\n    signals[death] = -1\n    return signals\n\n# 20日突破策略\ndef breakout(data):\n    high_20 = data['high'].rolling(20).max().shift(1)\n    ma5 = data['close'].rolling(5).mean()\n    signals = pd.Series(0, index=data.index)\n    signals[data['close'] > high_20] = 1\n    signals[data['close'] < ma5] = -1\n    return signals\n\n# RSI策略\ndef rsi_strategy(data):\n    delta = data['close'].diff()\n    gain = delta.where(delta > 0, 0).rolling(14).mean()\n    loss = (-delta.where(delta < 0, 0)).rolling(14).mean()\n    rs = gain / (loss + 1e-10)\n    rsi = 100 - (100 / (1 + rs))\n    signals = pd.Series(0, index=data.index)\n    signals[rsi < 30] = 1\n    signals[rsi > 70] = -1\n    return signals\n\n# 布林带策略\ndef bollinger(data):\n    mid = data['close'].rolling(20).mean()\n    std = data['close'].rolling(20).std()\n    upper = mid + 2 * std\n    lower = mid - 2 * std\n    signals = pd.Series(0, index=data.index)\n    signals[data['close'] < lower] = 1\n    signals[data['close'] > upper] = -1\n    return signals\n\n# 运行回测\nstrategies = [\n    ('均线金叉(5/20)', ma_cross),\n    ('20日突破', breakout),\n    ('RSI反转到70', rsi_strategy),\n    ('布林带下轨买', bollinger),\n]\n\nresults = []\nfor name, func in strategies:\n    print(f'\\n📈 {name}...')\n    result = backtest(df, func, name)\n    results.append((name, result))\n    status = '✅' if result['sharpe'] > 0.5 else ('🟡' if result['sharpe'] > 0 else '❌')\n    print(f'   收益: {result[\\\"total_return\\\"]:.2%} | 年化: {result[\\\"annual_return\\\"]:.2%} | 夏普: {result[\\\"sharpe\\\"]:.3f} | 回撤: {result[\\\"max_drawdown\\\"]:.2%} | 交易: {result[\\\"trade_count\\\"]}次 {status}')\n\n# 对比表格\nprint(f'\\n{\\\"=\\\" * 60}')\nprint(f'📊 策略对比 (2020-01 至 2024-12)')\nprint(f'{\\\"=\\\" * 60}')\nprint(f'{\\\"策略\\\":<16} {\\\"总收益\\\":>10} {\\\"年化\\\":>10} {\\\"夏普\\\":>8} {\\\"最大回撤\\\":>10} {\\\"交易\\\":>6}')\nprint(f'{\\\"-\\\" * 60}')\nfor name, r in results:\n    print(f'{name:<16} {r[\\\"total_return\\\"]:>9.2%} {r[\\\"annual_return\\\"]:>9.2%} {r[\\\"sharpe\\\"]:>8.3f} {r[\\\"max_drawdown\\\"]:>9.2%} {r[\\\"trade_count\\\"]:>6}')\n\n# 最佳策略\nbest = max(results, key=lambda x: x[1]['sharpe'])\nprint(f'\\n🏆 最佳策略: {best[0]} (夏普={best[1][\\\"sharpe\\\"]:.3f})')\nprint(f'\\n✅ 回测完成! 数据来源: BaoStock (沪深300指数)')\n\" 2>&1","timeout":120}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5-highspeed","usage":{"input":90622,"output":1680,"cacheRead":24074,"cacheWrite":0,"totalTokens":116376,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775811443179,"responseId":"0627ee738d1d6c35d75030fbba91fe63"}}
