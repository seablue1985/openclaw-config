{"type":"message","id":"867ec9ba","parentId":"33d08c83","timestamp":"2026-04-10T06:44:59.221Z","message":{"role":"assistant","content":[{"type":"text","text":"    让我创建一个综合示例，展示如何使用所有新模块："},{"type":"toolCall","id":"functions.write:45","name":"write","arguments":{"content":"\"\"\"\n完整示例 - 展示如何使用所有模块\n\n包括:\n1. 数据质量检查\n2. 策略回测\n3. 风控管理\n4. 模拟交易\n5. 绩效分析\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\nimport os\nimport sys\n\n# 添加路径\nsys.path.append('/home/jovyan')\n\nfrom strategies.framework.backtest_engine import BaseStrategy, BacktestConfig, BacktestReporter\nfrom strategies.framework.data_quality import DataQualityChecker\nfrom strategies.framework.risk_management import RiskManager, PositionLimitRule, DailyLossLimitRule\nfrom strategies.framework.execution import SimulatedExecutionEngine, PaperTradingEngine\nfrom strategies.framework.validation import StrategyValidator\nfrom strategies.framework.utils import (\n    calculate_drawdown, calculate_sharpe_ratio,\n    calculate_max_drawdown, calculate_win_rate\n)\n\n\nclass CompleteStrategy(BaseStrategy):\n    \"\"\"\n    完整策略示例 - 双均线 + RSI 过滤\n    \"\"\"\n    \n    def __init__(self, config: BacktestConfig,\n                 short_window: int = 5,\n                 long_window: int = 20,\n                 rsi_period: int = 14,\n                 rsi_oversold: int = 30,\n                 rsi_overbought: int = 70,\n                 position_pct: float = 0.8):\n        super().__init__(config)\n        self.short_window = short_window\n        self.long_window = long_window\n        self.rsi_period = rsi_period\n        self.rsi_oversold = rsi_oversold\n        self.rsi_overbought = rsi_overbought\n        self.position_pct = position_pct\n        \n    def _calculate_rsi(self, prices: pd.Series) -> float:\n        \"\"\"计算RSI\"\"\"\n        delta = prices.diff()\n        gain = (delta.where(delta > 0, 0)).rolling(window=self.rsi_period).mean()\n        loss = (-delta.where(delta < 0, 0)).rolling(window=self.rsi_period).mean()\n        \n        rs = gain / loss\n        rsi = 100 - (100 / (1 + rs))\n        return rsi.iloc[-1]\n        \n    def on_bar(self, date, bar_data):\n        \"\"\"策略逻辑\"\"\"\n        if self.current_idx < self.long_window:\n            return None\n            \n        # 计算指标\n        hist = self.data.iloc[:self.current_idx+1]\n        \n        # 均线\n        ma_short = hist['close'].tail(self.short_window).mean()\n        ma_long = hist['close'].tail(self.long_window).mean()\n        \n        # RSI\n        rsi = self._calculate_rsi(hist['close'])\n        \n        symbol = '000001'\n        current_position = self.positions.get(symbol, 0)\n        \n        # 买入信号：金叉 + RSI 超卖\n        if ma_short > ma_long and rsi < self.rsi_oversold:\n            if current_position == 0:\n                target_value = self.config.initial_capital * self.position_pct\n                shares = int(target_value / bar_data['close'] / 100) * 100\n                return {\n                    'action': 'BUY',\n                    'symbol': symbol,\n                    'shares': shares\n                }\n                \n        # 卖出信号：死叉 + RSI 超买\n        elif ma_short < ma_long and rsi > self.rsi_overbought:\n            if current_position > 0:\n                return {\n                    'action': 'SELL',\n                    'symbol': symbol,\n                    'shares': current_position\n                }\n                \n        return None\n\n\ndef run_complete_example():\n    \"\"\"\n    运行完整示例\n    \"\"\"\n    print(\"=\" * 60)\n    print(\"完整量化系统示例\")\n    print(\"=\" * 60)\n    \n    # 1. 准备数据\n    print(\"\\n1. 准备模拟数据...\")\n    np.random.seed(42)\n    dates = pd.date_range('2020-01-01', '2023-12-31', freq='B')\n    n = len(dates)\n    \n    returns = np.random.normal(0.0005, 0.02, n)\n    price = 100 * (1 + returns).cumprod()\n    \n    data = pd.DataFrame({\n        'open': price * (1 + np.random.uniform(-0.01, 0.01, n)),\n        'high': price * (1 + np.random.uniform(0, 0.02, n)),\n        'low': price * (1 + np.random.uniform(-0.02, 0, n)),\n        'close': price,\n        'volume': np.random.randint(1000000, 10000000, n)\n    }, index=dates)\n    \n    print(f\"   数据条数: {len(data)}\")\n    \n    # 2. 数据质量检查\n    print(\"\\n2. 数据质量检查...\")\n    checker = DataQualityChecker()\n    report = checker.check_dataframe(data, symbol='000001')\n    \n    print(f\"   质量评分: {report.quality_score:.1f}/100\")\n    print(f\"   状态: {report.status}\")\n    \n    if report.anomalies:\n        print(f\"   发现 {len(report.anomalies)} 个异常\")\n    else:\n        print(\"   数据质量良好\")\n        \n    # 3. 配置回测\n    print(\"\\n3. 配置回测...\")\n    config = BacktestConfig(\n        start_date='2020-01-01',\n        end_date='2023-12-31',\n        initial_capital=1_000_000,\n        commission_rate=0.0003,\n        slippage=0.001\n    )\n    \n    # 4. 运行回测\n    print(\"\\n4. 运行策略回测...\")\n    strategy = CompleteStrategy(\n        config,\n        short_window=5,\n        long_window=20,\n        rsi_period=14\n    )\n    \n    metrics = strategy.run_backtest(data)\n    \n    print(f\"   总收益: {metrics['total_return']:.2f}%\")\n    print(f\"   年化收益: {metrics['annual_return']:.2f}%\")\n    print(f\"   夏普比率: {metrics['sharpe_ratio']:.3f}\")\n    print(f\"   最大回撤: {metrics['max_drawdown']:.2f}%\")\n    print(f\"   胜率: {metrics['win_rate']:.1f}%\")\n    print(f\"   交易次数: {metrics['total_trades']}\")\n    \n    # 5. 策略验证\n    print(\"\\n5. 策略稳健性验证...\")\n    validator = StrategyValidator(data)\n    \n    wfa_result = validator.walk_forward_analysis(\n        CompleteStrategy,\n        config,\n        train_size=504,\n        test_size=63,\n        step_size=63\n    )\n    \n    print(f\"   稳健性评分: {wfa_result['robust_score']}/100\")\n    print(f\"   正收益比例: {wfa_result['positive_ratio']*100:.1f}%\")\n    print(f\"   平均夏普: {wfa_result['avg_sharpe']:.3f}\")\n    \n    if wfa_result['robust_score'] >= 70:\n        print(\"   ✅ 策略通过稳健性测试\")\n    else:\n        print(\"   ⚠️  策略需要优化\")\n        \n    # 6. 模拟盘测试\n    print(\"\\n6. 模拟盘测试...\")\n    \n    # 创建风控管理器\n    risk_manager = RiskManager()\n    risk_manager.add_rule(PositionLimitRule(max_single_position=0.3))\n    risk_manager.add_rule(DailyLossLimitRule(max_daily_loss_pct=0.03))\n    \n    # 创建模拟盘引擎\n    paper_engine = PaperTradingEngine(\n        risk_manager=risk_manager,\n        initial_capital=1_000_000\n    )\n    \n    # 运行模拟盘\n    result = paper_engine.run_strategy(strategy, data)\n    \n    print(f\"   初始资金: {result['initial_capital']:,.0f}\")\n    print(f\"   最终资金: {result['final_value']:,.0f}\")\n    print(f\"   总收益: {result['total_return']*100:.2f}%\")\n    print(f\"   成交次数: {result['trades']}\")\n    print(f\"   当前持仓: {result['positions']}\")\n    \n    # 7. 生成报告\n    print(\"\\n7. 生成回测报告...\")\n    os.makedirs('results/backtest_reports', exist_ok=True)\n    \n    report_path = 'results/backtest_reports/complete_example_report.md'\n    BacktestReporter.generate_report(\n        '完整示例策略',\n        {\n            'short_window': 5,\n            'long_window': 20,\n            'rsi_period': 14,\n            'position_pct': 0.8\n        },\n        metrics,\n        report_path\n    )\n    \n    print(f\"   报告已保存: {report_path}\")\n    \n    # 8. 保存质量检查报告\n    quality_report_path = 'results/backtest_reports/data_quality_report.md'\n    with open(quality_report_path, 'w', encoding='utf-8') as f:\n        f.write(checker.generate_report(report))\n    print(f\"   数据质量报告已保存: {quality_report_path}\")\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"示例运行完成！\")\n    print(\"=\" * 60)\n    \n    return {\n        'backtest_metrics': metrics,\n        'validation_result': wfa_result,\n        'paper_trading': result\n    }\n\n\nif __name__ == '__main__':\n    results = run_complete_example()\n","path":"/Users/ling/quant/notebooks/research/complete_example.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":233,"output":2376,"cacheRead":95232,"cacheWrite":0,"totalTokens":97841,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775803409085,"responseId":"2fa8787d90b74f6e9f594df3f554a079"}}
