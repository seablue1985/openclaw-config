{"type":"message","id":"86a2f212","parentId":"fe846dbc","timestamp":"2026-04-10T09:41:50.500Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user wants me to continue adjusting the RSI(7) strategy to try to get the Sharpe ratio above 1.0. Let me try some parameter tuning - different RSI periods, different overbought/oversold thresholds, or adding stop-loss/take-profit mechanisms.","thinkingSignature":"31372ddc386bce667b7ea2188b3e017ff848f76fec3e83bbdfceec8b88c26394"},{"type":"text","text":"\n\n继续调整RSI策略，尝试让夏普>1.0。尝试不同参数组合：\n"},{"type":"toolCall","id":"call_f8815ec095b84fadabcd64c1","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport baostock as bs\nimport pandas as pd\nimport numpy as np\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# 获取数据\nlg = bs.login()\nrs = bs.query_history_k_data_plus('sh.000300', 'date,open,high,low,close,volume',\n    start_date='2024-01-01', end_date='2026-04-10', frequency='d')\ndata_list = []\nwhile rs.error_code == '0' and rs.next():\n    data_list.append(rs.get_row_data())\ndf = pd.DataFrame(data_list, columns=rs.fields)\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date')\nfor col in ['open','high','low','close','volume']:\n    df[col] = pd.to_numeric(df[col], errors='coerce')\ndf = df.dropna()\nbs.logout()\n\nprint(f\"数据: {len(df)} 条\\n\")\n\ndef full_backtest(data, rsi_period, oversold, overbought, use_stop_loss=False, stop_pct=0.05):\n    capital = 100000\n    cash = capital\n    shares = 0\n    trades = []\n    signals = pd.Series(0, index=data.index)\n    \n    delta = data['close'].diff()\n    gain = delta.where(delta > 0, 0).rolling(rsi_period).mean()\n    loss = (-delta.where(delta < 0, 0)).rolling(rsi_period).mean()\n    rs = gain / (loss + 1e-10)\n    rsi = 100 - (100 / (1 + rs))\n    \n    buy_prices = []\n    for date, row in data.iterrows():\n        if pd.isna(rsi.loc[date]):\n            continue\n        price = row['close']\n        \n        # 止损\n        if use_stop_loss and shares > 0 and buy_prices:\n            cost = buy_prices[-1]\n            if price < cost * (1 - stop_pct):\n                cash += shares * price * 0.9997\n                trades.append(('SELL', date.date(), price, '止损'))\n                shares = 0\n        \n        if shares == 0 and rsi.loc[date] < oversold:\n            shares = int(cash / price * 0.95)\n            cash -= shares * price * 1.0003\n            buy_prices.append(price)\n            trades.append(('BUY', date.date(), price))\n        elif shares > 0 and rsi.loc[date] > overbought:\n            cash += shares * price * 0.9997\n            trades.append(('SELL', date.date(), price))\n            shares = 0\n    \n    final_value = cash + shares * df.iloc[-1]['close']\n    total_return = (final_value - capital) / capital\n    annual_return = (1 + total_return) ** (252 / len(df)) - 1\n    \n    # 计算夏普\n    equity = []\n    tc, ts = capital, 0\n    buy_prices2 = []\n    for date, row in data.iterrows():\n        if pd.isna(rsi.loc[date]):\n            equity.append(tc + ts * row['close'])\n            continue\n        price = row['close']\n        if ts == 0 and rsi.loc[date] < oversold:\n            ts = int(tc / price * 0.95)\n            tc -= ts * price * 1.0003\n            buy_prices2.append(price)\n        elif ts > 0 and rsi.loc[date] > overbought:\n            tc += ts * price * 0.9997\n            ts = 0\n        equity.append(tc + ts * price)\n    \n    equity = pd.Series(equity, index=data.index)\n    returns = equity.pct_change().dropna()\n    sharpe = returns.mean() / returns.std() * np.sqrt(252) if returns.std() > 0 else 0\n    peak = equity.cummax()\n    max_dd = ((equity - peak) / peak).min()\n    \n    buy_trades = [t for t in trades if t[0] == 'BUY']\n    sell_trades = [t for t in trades if t[0] == 'SELL']\n    wins = sum(1 for i, t in enumerate(sell_trades) if i < len(buy_trades) and t[2] > buy_trades[i][2])\n    win_rate = wins / len(sell_trades) if sell_trades else 0\n    \n    return {\n        'total': total_return,\n        'annual': annual_return,\n        'sharpe': sharpe,\n        'max_dd': max_dd,\n        'trades': len(trades),\n        'win_rate': win_rate\n    }\n\n# 参数网格搜索\nprint(\"=\" * 75)\nprint(\"🔧 RSI策略参数调优\")\nprint(\"=\" * 75)\nprint(f\"{'周期':<5} {'超卖':<6} {'超买':<6} {'止损':<4} {'总收益':>8} {'年化':>8} {'夏普':>6} {'回撤':>8} {'交易':>5} {'胜率':>6}\")\nprint(\"-\" * 75)\n\nresults = []\nfor period in [5, 6, 7, 8, 9, 10, 12, 14]:\n    for oversold in [20, 25, 30, 35]:\n        for overbought in [70, 75, 80, 85]:\n            for use_sl in [False, True]:\n                r = full_backtest(df, period, oversold, overbought, use_sl)\n                results.append({\n                    'period': period,\n                    'oversold': oversold,\n                    'overbought': overbought,\n                    'stop_loss': use_sl,\n                    **r\n                })\n\nresults.sort(key=lambda x: x['sharpe'], reverse=True)\n\nfor r in results[:20]:\n    sl = \"√\" if r['stop_loss'] else \"-\"\n    print(f\"{r['period']:<5} {r['oversold']:<6} {r['overbought']:<6} {sl:<4} {r['total']:>7.2%} {r['annual']:>7.2%} {r['sharpe']:>6.3f} {r['max_dd']:>7.2%} {r['trades']:>5} {r['win_rate']:>5.1%}\")\n\n# 通过自检的\nprint()\nprint(\"=\" * 75)\nprint(\"✅ 通过自检 (夏普>1.0 且 年化>10% 且 回撤<25%)\")\nprint(\"=\" * 75)\n\npassed = [r for r in results if r['sharpe'] > 1.0 and r['annual'] > 0.10 and r['max_dd'] > -0.25]\n\nif passed:\n    print(f\"{'周期':<5} {'超卖':<6} {'超买':<6} {'止损':<4} {'总收益':>8} {'年化':>8} {'夏普':>6} {'回撤':>8} {'交易':>5}\")\n    print(\"-\" * 60)\n    for r in passed[:5]:\n        sl = \"√\" if r['stop_loss'] else \"-\"\n        print(f\"{r['period']:<5} {r['oversold']:<6} {r['overbought']:<6} {sl:<4} {r['total']:>7.2%} {r['annual']:>7.2%} {r['sharpe']:>6.3f} {r['max_dd']:>7.2%} {r['trades']:>5}\")\nelse:\n    print(\"暂无完全通过自检的策略，显示夏普最高的5个:\")\n    for r in results[:5]:\n        sl = \"√\" if r['stop_loss'] else \"-\"