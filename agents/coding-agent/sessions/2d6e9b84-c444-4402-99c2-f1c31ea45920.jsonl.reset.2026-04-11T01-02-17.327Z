{"type":"message","id":"68f0d02c","parentId":"b3a8adfd","timestamp":"2026-04-10T03:46:41.631Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the core Python modules for data sync, monitoring dashboard, and the core backtest framework."},{"type":"toolCall","id":"call_function_nhv4z9p5wnif_1","name":"write","arguments":{"content":"\"\"\"\n数据库初始化脚本\n\"\"\"\n\nimport psycopg2\nfrom psycopg2.extensions import ISOLATION_LEVEL_AUTOCOMMIT\nimport os\nimport logging\n\nlogging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')\nlogger = logging.getLogger(__name__)\n\n\ndef get_connection(db_name='quant_db'):\n    return psycopg2.connect(\n        host=os.getenv('DB_HOST', 'localhost'),\n        port=os.getenv('DB_PORT', '5432'),\n        user=os.getenv('DB_USER', 'quant'),\n        password=os.getenv('DB_PASS', 'quant_pass'),\n        database=db_name\n    )\n\n\ndef create_extension(conn):\n    \"\"\"创建 TimescaleDB 扩展\"\"\"\n    cur = conn.cursor()\n    try:\n        cur.execute(\"CREATE EXTENSION IF NOT EXISTS timescaledb CASCADE;\")\n        conn.commit()\n        logger.info(\"TimescaleDB 扩展创建成功\")\n    except Exception as e:\n        logger.warning(f\"TimescaleDB 扩展创建跳过: {e}\")\n        conn.rollback()\n    finally:\n        cur.close()\n\n\ndef create_tables(conn):\n    \"\"\"创建核心数据表\"\"\"\n    cur = conn.cursor()\n    \n    # 股票日线数据表\n    cur.execute(\"\"\"\n        CREATE TABLE IF NOT EXISTS stock_daily (\n            id SERIAL PRIMARY KEY,\n            symbol VARCHAR(20) NOT NULL,\n            trade_date DATE NOT NULL,\n            open NUMERIC(10, 3),\n            high NUMERIC(10, 3),\n            low NUMERIC(10, 3),\n            close NUMERIC(10, 3),\n            volume BIGINT,\n            amount NUMERIC(20, 3),\n            pct_change NUMERIC(10, 4),\n            turnover NUMERIC(10, 4),\n            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n            UNIQUE(symbol, trade_date)\n        );\n    \"\"\")\n    \n    # 创建索引\n    cur.execute(\"\"\"\n        CREATE INDEX IF NOT EXISTS idx_stock_daily_symbol_date \n        ON stock_daily(symbol, trade_date DESC);\n    \"\"\")\n    \n    # 分钟数据表\n    cur.execute(\"\"\"\n        CREATE TABLE IF NOT EXISTS stock_minute (\n            id SERIAL PRIMARY KEY,\n            symbol VARCHAR(20) NOT NULL,\n            trade_date DATE NOT NULL,\n            trade_time TIMESTAMP NOT NULL,\n            open NUMERIC(10, 3),\n            high NUMERIC(10, 3),\n            low NUMERIC(10, 3),\n            close NUMERIC(10, 3),\n            volume BIGINT,\n            amount NUMERIC(20, 3),\n            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n            UNIQUE(symbol, trade_time)\n        );\n    \"\"\")\n    \n    cur.execute(\"\"\"\n        CREATE INDEX IF NOT EXISTS idx_stock_minute_symbol_time\n        ON stock_minute(symbol, trade_time DESC);\n    \"\"\")\n    \n    # 指数数据表\n    cur.execute(\"\"\"\n        CREATE TABLE IF NOT EXISTS index_daily (\n            id SERIAL PRIMARY KEY,\n            index_code VARCHAR(20) NOT NULL,\n            trade_date DATE NOT NULL,\n            open NUMERIC(12, 3),\n            high NUMERIC(12, 3),\n            low NUMERIC(12, 3),\n            close NUMERIC(12, 3),\n            volume BIGINT,\n            amount NUMERIC(20, 3),\n            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n            UNIQUE(index_code, trade_date)\n        );\n    \"\"\")\n    \n    # 策略回测结果表\n    cur.execute(\"\"\"\n        CREATE TABLE IF NOT EXISTS backtest_results (\n            id SERIAL PRIMARY KEY,\n            strategy_name VARCHAR(100) NOT NULL,\n            symbol VARCHAR(20),\n            start_date DATE NOT NULL,\n            end_date DATE NOT NULL,\n            initial_capital NUMERIC(20, 2),\n            final_capital NUMERIC(20, 2),\n            total_return NUMERIC(10, 4),\n            annual_return NUMERIC(10, 4),\n            volatility NUMERIC(10, 4),\n            max_drawdown NUMERIC(10, 4),\n            sharpe_ratio NUMERIC(10, 4),\n            sortino_ratio NUMERIC(10, 4),\n            calmar_ratio NUMERIC(10, 4),\n            win_rate NUMERIC(10, 4),\n            profit_factor NUMERIC(10, 4),\n            total_trades INTEGER,\n            params JSONB,\n            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n        );\n    \"\"\")\n    \n    # 策略模拟盘/实盘记录表\n    cur.execute(\"\"\"\n        CREATE TABLE IF NOT EXISTS live_trades (\n            id SERIAL PRIMARY KEY,\n            strategy_name VARCHAR(100) NOT NULL,\n            symbol VARCHAR(20) NOT NULL,\n            trade_date DATE NOT NULL,\n            action VARCHAR(10) NOT NULL,\n            price NUMERIC(10, 3),\n            shares INTEGER,\n            amount NUMERIC(20, 3),\n            commission NUMERIC(10, 4),\n            signal_id VARCHAR(100),\n            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n        );\n    \"\"\")\n    \n    # 数据更新日志\n    cur.execute(\"\"\"\n        CREATE TABLE IF NOT EXISTS data_update_log (\n            id SERIAL PRIMARY KEY,\n            data_type VARCHAR(50) NOT NULL,\n            symbol VARCHAR(20),\n            update_date DATE,\n            records_count INTEGER,\n            status VARCHAR(20),\n            error_message TEXT,\n            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n        );\n    \"\"\")\n    \n    # 策略监控记录\n    cur.execute(\"\"\"\n        CREATE TABLE IF NOT EXISTS strategy_monitor (\n            id SERIAL PRIMARY KEY,\n            strategy_name VARCHAR(100) NOT NULL,\n            check_date DATE NOT NULL,\n            return_7d NUMERIC(10, 4),\n            return_30d NUMERIC(10, 4),\n            return_90d NUMERIC(10, 4),\n            max_drawdown NUMERIC(10, 4),\n            volatility_30d NUMERIC(10, 4),\n            sharpe_30d NUMERIC(10, 4),\n            win_rate_30d NUMERIC(10, 4),\n            status VARCHAR(20),\n            anomalies JSONB,\n            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n        );\n    \"\"\")\n    \n    conn.commit()\n    logger.info(\"数据库表创建成功\")\n    cur.close()\n\n\ndef convert_to_timescale(conn):\n    \"\"\"转换为 TimescaleDB 超表\"\"\"\n    cur = conn.cursor()\n    tables = [\n        ('stock_daily', 'trade_date'),\n        ('stock_minute', 'trade_time'),\n        ('index_daily', 'trade_date'),\n    ]\n    \n    for table, time_col in tables:\n        try:\n            cur.execute(f\"\"\"\n                SELECT create_hypertable('{table}', '{time_col}', \n                    if_not_exists => TRUE, migrate_data => TRUE);\n            \"\"\")\n            conn.commit()\n            logger.info(f\"超表 {table} 创建成功\")\n        except Exception as e:\n            logger.warning(f\"超表 {table} 创建跳过: {e}\")\n            conn.rollback()\n    cur.close()\n\n\ndef init_db():\n    \"\"\"初始化数据库\"\"\"\n    db_name = os.getenv('DB_NAME', 'quant_db')\n    db_user = os.getenv('DB_USER', 'quant')\n    db_pass = os.getenv('DB_PASS', 'quant_pass')\n    db_host = os.getenv('DB_HOST', 'localhost')\n    db_port = os.getenv('DB_PORT', '5432')\n    \n    # 先连接到默认数据库创建目标数据库\n    try:\n        conn = psycopg2.connect(\n            host=db_host, port=db_port,\n            user=db_user, password=db_pass,\n            database='postgres'\n        )\n        conn.set_isolation_level(ISOLATION_LEVEL_AUTOCOMMIT)\n        cur = conn.cursor()\n        \n        cur.execute(f\"SELECT 1 FROM pg_database WHERE datname = '{db_name}'\")\n        if not cur.fetchone():\n            cur.execute(f\"CREATE DATABASE {db_name};\")\n            logger.info(f\"数据库 {db_name} 创建成功\")\n        else:\n            logger.info(f\"数据库 {db_name} 已存在\")\n            \n        cur.close()\n        conn.close()\n    except Exception as e:\n        logger.error(f\"创建数据库失败: {e}\")\n        raise\n    \n    # 连接到目标数据库\n    conn = get_connection(db_name)\n    \n    create_extension(conn)\n    create_tables(conn)\n    convert_to_timescale(conn)\n    \n    conn.close()\n    logger.info(\"数据库初始化完成\")\n\n\nif __name__ == '__main__':\n    init_db()\n","path":"/Users/ling/quant/docker/data-sync/src/init_db.py"}},{"type":"toolCall","id":"call_function_nhv4z9p5wnif_2","name":"write","arguments":{"content":"\"\"\"\n数据同步服务 - 从 AKShare/Tushare 获取数据并存储到 PostgreSQL\n\"\"\"\n\nimport os\nimport sys\nimport time\nimport logging\nfrom datetime import datetime, timedelta\nfrom typing import Optional, List\nimport pandas as pd\nimport psycopg2\nfrom psycopg2.extras import execute_values\nimport schedule\nimport yaml\n\n# 配置日志\nos.makedirs('/app/logs', exist_ok=True)\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s - %(levelname)s - %(message)s',\n    handlers=[\n        logging.FileHandler('/app/logs/data_sync.log'),\n        logging.StreamHandler()\n    ]\n)\nlogger = logging.getLogger(__name__)\n\n# 加载配置\ndef load_config():\n    config_path = '/app/config/sync_config.yaml'\n    if os.path.exists(config_path):\n        with open(config_path, 'r') as f:\n            return yaml.safe_load(f)\n    return {}\n\n\ndef get_db_conn():\n    return psycopg2.connect(\n        host=os.getenv('DB_HOST', 'localhost'),\n        port=os.getenv('DB_PORT', '5432'),\n        user=os.getenv('DB_USER', 'quant'),\n        password=os.getenv('DB_PASS', 'quant_pass'),\n        database=os.getenv('DB_NAME', 'quant_db')\n    )\n\n\ndef log_update(data_type: str, symbol: str, count: int, status: str, error: str = ''):\n    \"\"\"记录更新日志\"\"\"\n    conn = get_db_conn()\n    cur = conn.cursor()\n    try:\n        cur.execute(\"\"\"\n            INSERT INTO data_update_log (data_type, symbol, update_date, records_count, status, error_message)\n            VALUES (%s, %s, %s, %s, %s, %s)\n        \"\"\", (data_type, symbol, datetime.now().date(), count, status, error))\n        conn.commit()\n    finally:\n        cur.close()\n        conn.close()\n\n\ndef fetch_stock_daily(symbol: str, start_date: str, end_date: str) -> Optional[pd.DataFrame]:\n    \"\"\"从 AKShare 获取股票日线数据\"\"\"\n    try:\n        import akshare as ak\n        \n        # 转换symbol格式: 000001.SZ -> 000001\n        code = symbol.split('.')[0]\n        \n        df = ak.stock_zh_a_hist(\n            symbol=code,\n            period=\"daily\",\n            start_date=start_date.replace('-', ''),\n            end_date=end_date.replace('-', ''),\n            adjust=\"qfq\"\n        )\n        \n        # 标准化列名\n        df.columns = ['date', 'open', 'close', 'high', 'low', 'volume', \n                      'amount', 'amplitude', 'pct_change', 'change', 'turnover']\n        df['date'] = pd.to_datetime(df['date'])\n        \n        return df\n        \n    except Exception as e:\n        logger.error(f\"获取 {symbol} 数据失败: {e}\")\n        log_update('stock_daily', symbol, 0, 'FAILED', str(e))\n        return None\n\n\ndef validate_data(df: pd.DataFrame, symbol: str) -> bool:\n    \"\"\"数据质量验证\"\"\"\n    if df is None or df.empty:\n        return False\n        \n    # 检查必填列\n    required_cols = ['date', 'open', 'high', 'low', 'close', 'volume']\n    for col in required_cols:\n        if col not in df.columns:\n            return False\n            \n    # 检查OHLC逻辑\n    invalid = (\n        (df['high'] < df['low']) |\n        (df['high'] < df[['open', 'close']].max(axis=1)) |\n        (df['low'] > df[['open', 'close']].min(axis=1))\n    )\n    if invalid.any():\n        logger.warning(f\"{symbol} 有 {invalid.sum()} 条 OHLC 逻辑异常数据，将被过滤\")\n        df = df[~invalid]\n        \n    # 检查价格正数\n    if (df[['open', 'high', 'low', 'close']] <= 0).any().any():\n        logger.warning(f\"{symbol} 存在非正价格数据\")\n        return False\n        \n    return True\n\n\ndef save_stock_daily(df: pd.DataFrame, symbol: str) -> int:\n    \"\"\"保存到数据库\"\"\"\n    if df is None or df.empty:\n        return 0\n        \n    conn = get_db_conn()\n    cur = conn.cursor()\n    \n    # 准备数据\n    records = []\n    for _, row in df.iterrows():\n        records.append((\n            symbol,\n            row['date'].date(),\n            float(row['open']),\n            float(row['high']),\n            float(row['low']),\n            float(row['close']),\n            int(row['volume']),\n            float(row['amount']) if 'amount' in row and pd.notna(row['amount']) else 0,\n            float(row.get('pct_change', 0)),\n            float(row.get('turnover', 0)),\n        ))\n    \n    try:\n        # 使用 upsert\n        execute_values(\n            cur,\n            \"\"\"\n            INSERT INTO stock_daily (symbol, trade_date, open, high, low, close, volume, amount, pct_change, turnover)\n            VALUES %s\n            ON CONFLICT (symbol, trade_date) DO UPDATE SET\n                open = EXCLUDED.open,\n                high = EXCLUDED.high,\n                low = EXCLUDED.low,\n                close = EXCLUDED.close,\n                volume = EXCLUDED.volume,\n                amount = EXCLUDED.amount,\n                pct_change = EXCLUDED.pct_change,\n                turnover = EXCLUDED.turnover\n            \"\"\",\n            records,\n            template=None,\n            page_size=1000\n        )\n        conn.commit()\n        count = len(records)\n        logger.info(f\"{symbol}: 保存 {count} 条日线数据\")\n        log_update('stock_daily', symbol, count, 'SUCCESS')\n        return count\n    except Exception as e:\n        conn.rollback()\n        logger.error(f\"保存 {symbol} 数据失败: {e}\")\n        log_update('stock_daily', symbol, 0, 'FAILED', str(e))\n        return 0\n    finally:\n        cur.close()\n        conn.close()\n\n\ndef get_last_update_date(symbol: str) -> str:\n    \"\"\"获取最后更新日期\"\"\"\n    conn = get_db_conn()\n    cur = conn.cursor()\n    try:\n        cur.execute(\"\"\"\n            SELECT MAX(trade_date) FROM stock_daily WHERE symbol = %s\n        \"\"\", (symbol,))\n        result = cur.fetchone()[0]\n        if result:\n            return (result + timedelta(days=1)).strftime('%Y-%m-%d')\n        return (datetime.now() - timedelta(days=365)).strftime('%Y-%m-%d')\n    except:\n        return (datetime.now() - timedelta(days=365)).strftime('%Y-%m-%d')\n    finally:\n        cur.close()\n        conn.close()\n\n\ndef sync_stock(symbol: str, days: int = 365):\n    \"\"\"同步单只股票数据\"\"\"\n    last_date = get_last_update_date(symbol)\n    end_date = datetime.now().strftime('%Y-%m-%d')\n    \n    if last_date >= end_date:\n        logger.info(f\"{symbol}: 数据已是最新\")\n        return 0\n        \n    logger.info(f\"{symbol}: 同步 {last_date} ~ {end_date}\")\n    df = fetch_stock_daily(symbol, last_date, end_date)\n    \n    if df is not None:\n        if validate_data(df, symbol):\n            return save_stock_daily(df, symbol)\n            \n    return 0\n\n\ndef sync_watchlist(config: dict) -> dict:\n    \"\"\"同步关注列表\"\"\"\n    symbols = config.get('watchlist', [])\n    if not symbols:\n        # 默认沪深300成分股\n        try:\n            import akshare as ak\n            stocks = ak.index_stock_cons_weight_csindex(symbol=\"000300\")\n            symbols = stocks['成分券代码'].tolist()[:50]\n            logger.info(f\"获取沪深300成分股 {len(symbols)} 只\")\n        except Exception as e:\n            logger.error(f\"获取成分股列表失败: {e}\")\n            return {'success': 0, 'failed': 0, 'total': 0}\n    \n    success, failed = 0, 0\n    for symbol in symbols:\n        try:\n            count = sync_stock(symbol)\n            success += 1\n        except Exception as e:\n            logger.error(f\"{symbol} 同步异常: {e}\")\n            failed += 1\n            \n        time.sleep(0.5)  # 避免请求过快\n        \n    return {'success': success, 'failed': failed, 'total': len(symbols)}\n\n\ndef sync_index_data(index_codes: List[str] = None):\n    \"\"\"同步指数数据\"\"\"\n    if index_codes is None:\n        index_codes = ['000001', '399001', '399006', '000300', '000016']\n        \n    try:\n        import akshare as ak\n        \n        for code in index_codes:\n            try:\n                df = ak.index_zh_a_hist(symbol=code, period=\"daily\")\n                df.columns = ['date', 'open', 'close', 'high', 'low', 'volume', 'amount', 'amplitude']\n                df['date'] = pd.to_datetime(df['date'])\n                \n                conn = get_db_conn()\n                cur = conn.cursor()\n                \n                records = []\n                for _, row in df.iterrows():\n                    records.append((\n                        code,\n                        row['date'].date(),\n                        float(row['open']),\n                        float(row['high']),\n                        float(row['low']),\n                        float(row['close']),\n                        int(row['volume']),\n                        float(row.get('amount', 0)),\n                    ))\n                \n                execute_values(\n                    cur,\n                    \"\"\"\n                    INSERT INTO index_daily (index_code, trade_date, open, high, low, close, volume, amount)\n                    VALUES %s\n                    ON CONFLICT (index_code, trade_date) DO UPDATE SET\n                        open = EXCLUDED.open,\n                        high = EXCLUDED.high,\n                        low = EXCLUDED.low,\n                        close = EXCLUDED.close,\n                        volume = EXCLUDED.volume,\n                        amount = EXCLUDED.amount\n                    \"\"\",\n                    records\n                )\n                conn.commit()\n                cur.close()\n                conn.close()\n                \n                logger.info(f\"指数 {code}: 保存 {len(records)} 条数据\")\n                \n            except Exception as e:\n                logger.error(f\"指数 {code} 同步失败: {e}\")\n                \n    except ImportError:\n        logger.warning(\"AKShare 未安装，跳过指数数据同步\")\n\n\ndef daily_full_sync():\n    \"\"\"每日全量同步\"\"\"\n    logger.info(\"=\" * 50)\n    logger.info(\"开始每日数据同步...\")\n    \n    config = load_config()\n    \n    # 同步指数\n    logger.info(\"同步指数数据...\")\n    sync_index_data()\n    \n    # 同步股票\n    logger.info(\"同步股票数据...\")\n    result = sync_watchlist(config)\n    \n    logger.info(f\"同步完成: 成功 {result['success']}, 失败 {result['failed']}\")\n    logger.info(\"=\" * 50)\n\n\ndef main():\n    \"\"\"主函数\"\"\"\n    logger.info(\"数据同步服务启动\")\n    \n    # 立即执行一次全量同步\n    daily_full_sync()\n    \n    # 设置定时任务\n    schedule.every().day.at(\"08:30\").do(daily_full_sync)  # 每天早上8:30\n    schedule.every().day.at(\"16:35\").do(daily_full_sync)  # 收盘后16:35\n    \n    # 实时数据更新 (工作日每30分钟)\n    def intraday_update():\n        hour = datetime.now().hour\n        if 9 <= hour <= 15 or (hour == 12 and datetime.now().minute >= 30):\n            config = load_config()\n            sync_watchlist(config)\n    \n    schedule.every(30).minutes.do(intraday_update)\n    \n    # 主循环\n    logger.info(\"进入调度循环，等待任务执行...\")\n    while True:\n        schedule.run_pending()\n        time.sleep(30)\n\n\nif __name__ == '__main__':\n    main()\n","path":"/Users/ling/quant/docker/data"}}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":49035,"output":4460,"cacheRead":0,"cacheWrite":0,"totalTokens":53495,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775792703020,"responseId":"0627a546bf4e3781ec91c2093a87d16c"}}
