{"type":"message","id":"7e94abf4","parentId":"b5370279","timestamp":"2026-04-10T07:13:36.991Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_KDdImJnutSvgouAvRA7SEd","name":"write","arguments":{"content":"\"\"\"\n定时调度器 - 定时执行数据同步、策略监控、报告生成等任务\n\"\"\"\n\nimport os\nimport time\nimport logging\nfrom datetime import datetime, timedelta\nimport schedule\nimport yaml\n\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s - %(levelname)s - %(message)s',\n    handlers=[\n        logging.FileHandler('/app/logs/scheduler.log'),\n        logging.StreamHandler()\n    ]\n)\nlogger = logging.getLogger(__name__)\n\n\ndef load_config():\n    config_path = '/app/config/scheduler_config.yaml'\n    if os.path.exists(config_path):\n        with open(config_path, 'r') as f:\n            return yaml.safe_load(f)\n    return {}\n\n\ndef job_data_quality_check():\n    \"\"\"每日数据质量检查\"\"\"\n    logger.info(\"[JOB] 数据质量检查开始...\")\n    try:\n        import psycopg2\n        import pandas as pd\n        \n        conn = psycopg2.connect(\n            host=os.getenv('DB_HOST', 'quant-db'),\n            port=os.getenv('DB_PORT', '5432'),\n            user=os.getenv('DB_USER', 'quant'),\n            password=os.getenv('DB_PASS', 'quant_pass'),\n            database=os.getenv('DB_NAME', 'quant_db')\n        )\n        \n        # 获取所有股票\n        symbols = pd.read_sql(\n            \"SELECT DISTINCT symbol FROM stock_daily\", conn\n        )['symbol'].tolist()\n        \n        issues = []\n        \n        for symbol in symbols:\n            df = pd.read_sql(f\"\"\"\n                SELECT trade_date, open, high, low, close, volume\n                FROM stock_daily\n                WHERE symbol = '{symbol}'\n                ORDER BY trade_date\n            \"\"\", conn, parse_dates=['trade_date'])\n            \n            if df.empty:\n                continue\n                \n            # OHLC 逻辑检查\n            invalid = (\n                (df['high'] < df['low']) |\n                (df['high'] < df[['open', 'close']].max(axis=1)) |\n                (df['low'] > df[['open', 'close']].min(axis=1))\n            )\n            if invalid.any():\n                issues.append({\n                    'symbol': symbol,\n                    'type': 'OHLC_INVALID',\n                    'count': int(invalid.sum())\n                })\n                \n            # 缺失值检查\n            null_count = df.isnull().sum().sum()\n            if null_count > 0:\n                issues.append({\n                    'symbol': symbol,\n                    'type': 'NULL_VALUES',\n                    'count': int(null_count)\n                })\n                \n        conn.close()\n        \n        if issues:\n            logger.warning(f\"[JOB] 数据质量检查发现 {len(issues)} 个问题\")\n            for issue in issues:\n                logger.warning(f\"  {issue['symbol']}: {issue['type']} ({issue['count']})\")\n        else:\n            logger.info(\"[JOB] 数据质量检查通过，无异常\")\n            \n    except Exception as e:\n        logger.error(f\"[JOB] 数据质量检查失败: {e}\")\n\n\ndef job_strategy_monitor():\n    \"\"\"策略健康度检查\"\"\"\n    logger.info(\"[JOB] 策略健康度检查开始...\")\n    try:\n        import psycopg2\n        import pandas as pd\n        import numpy as np\n        \n        conn = psycopg2.connect(\n            host=os.getenv('DB_HOST', 'quant-db'),\n            port=os.getenv('DB_PORT', '5432'),\n            user=os.getenv('DB_USER', 'quant'),\n            password=os.getenv('DB_PASS', 'quant_pass'),\n            database=os.getenv('DB_NAME', 'quant_db')\n        )\n        \n        # 获取策略列表\n        strategies = pd.read_sql(\n            \"SELECT DISTINCT strategy_name FROM backtest_results\", conn\n        )['strategy_name'].tolist()\n        \n        for strategy_name in strategies:\n            # 获取最近回测结果\n            result = pd.read_sql(f\"\"\"\n                SELECT * FROM backtest_results\n                WHERE strategy_name = '{strategy_name}'\n                ORDER BY created_at DESC\n                LIMIT 1\n            \"\"\", conn)\n            \n            if result.empty:\n                continue\n                \n            row = result.iloc[0]\n            \n            # 评估\n            anomalies = []\n            if row['max_drawdown'] < -0.20:\n                anomalies.append(f\"回撤过大: {row['max_drawdown']*100:.1f}%\")\n            if row['sharpe_ratio'] < 0.5:\n                anomalies.append(f\"夏普过低: {row['sharpe_ratio']:.2f}\")\n                \n            status = 'CRITICAL' if any('回撤过大' in a for a in anomalies) else \\\n                     'WARNING' if anomalies else 'HEALTHY'\n                     \n            # 写入监控表\n            cur = conn.cursor()\n            cur.execute(\"\"\"\n                INSERT INTO strategy_monitor \n                (strategy_name, check_date, return_7d, return_30d, return_90d,\n                 max_drawdown, sharpe_30d, status, anomalies)\n                VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s)\n            \"\"\", (\n                strategy_name, datetime.now().date(),\n                0, 0, 0,\n                row['max_drawdown'],\n                row['sharpe_ratio'],\n                status,\n                str(anomalies)\n            ))\n            conn.commit()\n            cur.close()\n            \n            logger.info(f\"  {strategy_name}: {status}\")\n            \n        conn.close()\n        logger.info(\"[JOB] 策略健康度检查完成\")\n        \n    except Exception as e:\n        logger.error(f\"[JOB] 策略健康度检查失败: {e}\")\n\n\ndef job_generate_daily_report():\n    \"\"\"生成每日报告\"\"\"\n    logger.info(\"[JOB] 生成每日报告...\")\n    try:\n        import psycopg2\n        import pandas as pd\n        \n        conn = psycopg2.connect(\n            host=os.getenv('DB_HOST', 'quant-db'),\n            port=os.getenv('DB_PORT', '5432'),\n            user=os.getenv('DB_USER', 'quant'),\n            password=os.getenv('DB_PASS', 'quant_pass'),\n            database=os.getenv('DB_NAME', 'quant_db')\n        )\n        \n        today = datetime.now().date()\n        \n        # 数据统计\n        data_stats = pd.read_sql(\"\"\"\n            SELECT \n                COUNT(DISTINCT symbol) as stock_count,\n                COUNT(*) as total_records,\n                MAX(trade_date) as latest_date\n            FROM stock_daily\n        \"\"\", conn).iloc[0]\n        \n        # 策略统计\n        strategy_stats = pd.read_sql(\"\"\"\n            SELECT \n                COUNT(*) as total_backtests,\n                COUNT(DISTINCT strategy_name) as strategy_count\n            FROM backtest_results\n        \"\"\", conn).iloc[0]\n        \n        # 最近更新\n        update_stats = pd.read_sql(f\"\"\"\n            SELECT \n                COUNT(*) as updates_today,\n                SUM(CASE WHEN status = 'SUCCESS' THEN 1 ELSE 0 END) as success,\n                SUM(CASE WHEN status = 'FAILED' THEN 1 ELSE 0 END) as failed\n            FROM data_update_log\n            WHERE update_date = '{today}'\n        \"\"\", conn).iloc[0]\n        \n        conn.close()\n        \n        # 生成报告\n        report = f\"\"\"# 每日报告 - {today}\n\n## 数据概况\n- 股票数量: {data_stats['stock_count']}\n- 总记录数: {data_stats['total_records']:,}\n- 最新数据: {data_stats['latest_date']}\n\n## 策略概况\n- 策略数量: {strategy_stats['strategy_count']}\n- 回测记录: {strategy_stats['total_backtests']}\n\n## 今日更新\n- 更新次数: {update_stats['updates_today']}\n- 成功: {update_stats['success']}\n- 失败: {update_stats['failed']}\n\n生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n\"\"\"\n        \n        os.makedirs('/app/logs/reports', exist_ok=True)\n        report_path = f'/app/logs/reports/daily_{today}.md'\n        with open(report_path, 'w', encoding='utf-8') as f:\n            f.write(report)\n            \n        logger.info(f\"[JOB] 每日报告已保存: {report_path}\")\n        \n    except Exception as e:\n        logger.error(f\"[JOB] 生成每日报告失败: {e}\")\n\n\ndef job_cleanup_old_logs():\n    \"\"\"清理过期日志\"\"\"\n    logger.info(\"[JOB] 清理过期日志...\")\n    try:\n        import glob\n        \n        log_dirs = ['/app/logs/reports', '/app/logs']\n        retention_days = 30\n        cutoff = datetime.now() - timedelta(days=retention_days)\n        \n        removed = 0\n        for log_dir in log_dirs:\n            for f in glob.glob(os.path.join(log_dir, '*.log')):\n                mtime = datetime.fromtimestamp(os.path.getmtime(f))\n                if mtime < cutoff:\n                    os.remove(f)\n                    removed += 1\n                    \n        logger.info(f\"[JOB] 清理了 {removed} 个过期日志文件\")\n        \n    except Exception as e:\n        logger.error(f\"[JOB] 清理日志失败: {e}\")\n\n\ndef job_db_maintenance():\n    \"\"\"数据库维护\"\"\"\n    logger.info(\"[JOB] 数据库维护开始...\")\n    try:\n        import psycopg2\n        \n        conn = psycopg2.connect(\n            host=os.getenv('DB_HOST', 'quant-db'),\n            port=os.getenv('DB_PORT', '5432'),\n            user=os.getenv('DB_USER', 'quant'),\n            password=os.getenv('DB_PASS', 'quant_pass'),\n            database=os.getenv('DB_NAME', 'quant_db')\n        )\n        conn.autocommit = True\n        cur = conn.cursor()\n        \n        # VACUUM ANALYZE\n        tables = ['stock_daily', 'index_daily', 'backtest_results', \n                  'data_update_log', 'strategy_monitor']\n        for table in tables:\n            try:\n                cur.execute(f\"VACUUM ANALYZE {table}\")\n                logger.info(f\"  VACUUM ANALYZE {table} 完成\")\n            except Exception as e:\n                logger.warning(f\"  VACUUM {table} 失败: {e}\")\n                \n        cur.close()\n        conn.close()\n        logger.info(\"[JOB] 数据库维护完成\")\n        \n    except Exception as e:\n        logger.error(f\"[JOB] 数据库维护失败: {e}\")\n\n\ndef main():\n    \"\"\"主调度器\"\"\"\n    logger.info(\"=\" * 50)\n    logger.info(\"定时调度器启动\")\n    logger.info(\"=\" * 50)\n    \n    # 每日任务\n    schedule.every().day.at(\"08:00\").do(job_data_quality_check)\n    schedule.every().day.at(\"16:45\").do(job_strategy_monitor)\n    schedule.every().day.at(\"17:00\").do(job_generate_daily_report)\n    \n    # 每周任务\n    schedule.every().sunday.at(\"03:00\").do(job_cleanup_old_logs)\n    schedule.every().sunday.at(\"04:00\").do(job_db_maintenance)\n    \n    logger.info(\"已注册定时任务:\")\n    for job in schedule.get_jobs():\n        logger.info(f\"  {job}\")\n        \n    # 主循环\n    while True:\n        schedule.run_pending()\n        time.sleep(30)\n\n\nif __name__ == '__main__':\n    main()\n","path":"/Users/ling/quant/docker/scheduler/src/scheduler.py"}}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":97222,"output":3402,"cacheRead":24306,"cacheWrite":0,"totalTokens":124930,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775805149354,"responseId":"27186dcb-4c4c-449b-87b5-3534b42dfe8d"}}
