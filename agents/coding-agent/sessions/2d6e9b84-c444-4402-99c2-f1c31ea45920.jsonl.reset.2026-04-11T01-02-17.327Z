{"type":"message","id":"45b077ff","parentId":"320be7fc","timestamp":"2026-04-10T03:52:24.445Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the framework files and then give the user instructions on how to start the system.","thinkingSignature":"532c53fa5b08e0fc95170cf7a8cb776cfb1fd19234672917b71cd358b7916ae1"},{"type":"toolCall","id":"call_function_yj85fmxwsbst_1","name":"write","arguments":{"content":"\"\"\"\n统一回测框架 - 核心引擎\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom dataclasses import dataclass, field\nfrom typing import Dict, List, Optional, Callable\nfrom datetime import datetime\nimport json\nimport logging\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\n\n@dataclass\nclass BacktestConfig:\n    \"\"\"回测配置\"\"\"\n    start_date: str\n    end_date: str\n    initial_capital: float = 1_000_000\n    commission_rate: float = 0.0003  # 万3佣金\n    slippage: float = 0.001  # 千1滑点\n    stamp_duty: float = 0.001  # 千1印花税(卖出)\n    position_limit: float = 0.95  # 最大仓位限制\n\n\n@dataclass\nclass TradeRecord:\n    \"\"\"交易记录\"\"\"\n    date: datetime\n    symbol: str\n    action: str  # BUY/SELL\n    price: float\n    shares: int\n    amount: float\n    commission: float\n    slippage: float\n\n\nclass BaseStrategy:\n    \"\"\"\n    策略基类 - 所有策略必须继承\n    \"\"\"\n    \n    def __init__(self, config: BacktestConfig, **params):\n        self.config = config\n        self.params = params\n        self.capital = config.initial_capital\n        self.positions: Dict[str, int] = {}  # 当前持仓\n        self.trades: List[TradeRecord] = []  # 交易记录\n        self.daily_values: List[Dict] = []   # 每日净值\n        self.pending_orders: List[Dict] = [] # 待成交订单\n        self.data = None\n        self.current_idx = 0\n        \n    def initialize(self, data: pd.DataFrame):\n        \"\"\"策略初始化\"\"\"\n        self.data = data\n        self.current_idx = 0\n        \n    def on_bar(self, date: datetime, bar_data: pd.Series) -> Optional[Dict]:\n        \"\"\"\n        每个Bar触发，返回交易信号\n        Returns: {'action': 'BUY'/'SELL', 'symbol': '000001.SZ', 'shares': 1000}\n        \"\"\"\n        raise NotImplementedError(\"子类必须实现此方法\")\n        \n    def calculate_metrics(self) -> Dict:\n        \"\"\"计算绩效指标\"\"\"\n        if not self.daily_values:\n            return {}\n            \n        df = pd.DataFrame(self.daily_values)\n        df.set_index('date', inplace=True)\n        \n        returns = df['total_value'].pct_change().dropna()\n        \n        # 收益率\n        total_return = (df['total_value'].iloc[-1] / self.config.initial_capital - 1) * 100\n        annual_return = ((1 + total_return/100) ** (252 / len(df)) - 1) * 100\n        \n        # 风险\n        volatility = returns.std() * np.sqrt(252) * 100\n        max_drawdown = self._calc_max_drawdown(df['total_value']) * 100\n        \n        # 风险调整收益\n        sharpe = (annual_return - 3) / volatility if volatility > 0 else 0\n        sortino = self._calc_sortino(returns, annual_return)\n        calmar = annual_return / abs(max_drawdown) if max_drawdown != 0 else 0\n        \n        # 交易统计\n        wins = [t for t in self.trades if t.action == 'SELL' and t.amount > 0]\n        losses = [t for t in self.trades if t.action == 'SELL' and t.amount < 0]\n        \n        win_rate = len(wins) / len(self.trades) * 100 if self.trades else 0\n        profit_factor = abs(sum(t.amount for t in wins) / sum(t.amount for t in losses)) if losses else 0\n        \n        return {\n            'start_date': df.index[0].strftime('%Y-%m-%d'),\n            'end_date': df.index[-1].strftime('%Y-%m-%d'),\n            'total_return': round(total_return, 2),\n            'annual_return': round(annual_return, 2),\n            'volatility': round(volatility, 2),\n            'max_drawdown': round(max_drawdown, 2),\n            'sharpe_ratio': round(sharpe, 3),\n            'sortino_ratio': round(sortino, 3),\n            'calmar_ratio': round(calmar, 3),\n            'win_rate': round(win_rate, 2),\n            'profit_factor': round(profit_factor, 2),\n            'total_trades': len(self.trades),\n            'final_capital': round(df['total_value'].iloc[-1], 2),\n        }\n        \n    def _calc_max_drawdown(self, values: pd.Series) -> float:\n        cummax = values.cummax()\n        drawdown = (values - cummax) / cummax\n        return drawdown.min()\n        \n    def _calc_sortino(self, returns: pd.Series, annual_return: float) -> float:\n        downside = returns[returns < 0].std() * np.sqrt(252)\n        return (annual_return - 3) / (downside * 100) if downside > 0 else 0\n        \n    def run_backtest(self, data: pd.DataFrame) -> Dict:\n        \"\"\"运行回测\"\"\"\n        self.initialize(data)\n        \n        for idx, (date, row) in enumerate(data.iterrows()):\n            self.current_idx = idx\n            \n            # 获取信号\n            signal = self.on_bar(date, row)\n            \n            # 执行交易\n            if signal:\n                self._execute_trade(date, signal)\n                \n            # 记录每日净值\n            self._record_daily_value(date)\n            \n        return self.calculate_metrics()\n        \n    def _execute_trade(self, date: datetime, signal: Dict):\n        \"\"\"执行交易\"\"\"\n        symbol = signal['symbol']\n        action = signal['action']\n        shares = signal.get('shares', 0)\n        \n        # 获取当前价格\n        price = self.data.loc[date, 'close']\n        \n        # 计算滑点\n        slippage_price = price * (1 + self.config.slippage) if action == 'BUY' else price * (1 - self.config.slippage)\n        \n        # 计算佣金\n        amount = shares * slippage_price\n        commission = amount * self.config.commission_rate\n        \n        # 印花税(仅卖出)\n        stamp_duty = 0\n        if action == 'SELL':\n            stamp_duty = amount * self.config.stamp_duty\n            \n        total_cost = amount + commission + stamp_duty\n        \n        # 执行\n        if action == 'BUY':\n            if total_cost <= self.capital:\n                self.capital -= total_cost\n                self.positions[symbol] = self.positions.get(symbol, 0) + shares\n                \n                self.trades.append(TradeRecord(\n                    date=date, symbol=symbol, action=action,\n                    price=slippage_price, shares=shares, amount=-total_cost,\n                    commission=commission, slippage=shares * price * self.config.slippage\n                ))\n                \n        elif action == 'SELL':\n            if self.positions.get(symbol, 0) >= shares:\n                self.capital += amount - commission - stamp_duty\n                self.positions[symbol] -= shares\n                \n                self.trades.append(TradeRecord(\n                    date=date, symbol=symbol, action=action,\n                    price=slippage_price, shares=shares, amount=amount - commission - stamp_duty,\n                    commission=commission, slippage=shares * price * self.config.slippage\n                ))\n                \n    def _record_daily_value(self, date: datetime):\n        \"\"\"记录每日净值\"\"\"\n        position_value = 0\n        for symbol, shares in self.positions.items():\n            if symbol in self.data.columns:\n                position_value += shares * self.data.loc[date, 'close']\n                \n        self.daily_values.append({\n            'date': date,\n            'cash': self.capital,\n            'position_value': position_value,\n            'total_value': self.capital + position_value\n        })\n\n\nclass BacktestReporter:\n    \"\"\"回测报告生成器\"\"\"\n    \n    @staticmethod\n    def generate_report(strategy_name: str, params: Dict, metrics: Dict, output_path: str):\n        \"\"\"生成 Markdown 报告\"\"\"\n        \n        score = 0\n        if metrics.get('sharpe_ratio', 0) > 1.5: score += 2\n        elif metrics.get('sharpe_ratio', 0) > 1: score += 1\n        if metrics.get('max_drawdown', 0) > -20: score += 2\n        elif metrics.get('max_drawdown', 0) > -30: score += 1\n        if metrics.get('total_return', 0) > 50: score += 1\n        \n        evaluations = {\n            5: \"🟢 优秀策略\",\n            4: \"🟡 良好策略\",\n            3: \"🟡 一般策略\",\n            2: \"🔴 较差策略\",\n        }\n        \n        report = f\"\"\"# {strategy_name} - 回测报告\n\n**生成时间**: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n## 参数配置\n```\n{json.dumps(params, indent=2, ensure_ascii=False)}\n```\n\n## 收益指标\n\n| 指标 | 数值 |\n|------|------|\n| 总收益率 | {metrics['total_return']}% |\n| 年化收益率 | {metrics['annual_return']}% |\n| 夏普比率 | {metrics['sharpe_ratio']} |\n| 索提诺比率 | {metrics['sortino_ratio']} |\n| 卡尔玛比率 | {metrics['calmar_ratio']} |\n\n## 风险指标\n\n| 指标 | 数值 |\n|------|------|\n| 年化波动率 | {metrics['volatility']}% |\n| 最大回撤 | {metrics['max_drawdown']}% |\n| 胜率 | {metrics['win_rate']}% |\n| 盈亏比 | {metrics['profit_factor']} |\n\n## 交易统计\n\n- 总交易次数: {metrics['total_trades']}\n- 回测区间: {metrics['start_date']} ~ {metrics['end_date']}\n- 最终资金: {metrics['final_capital']:,.0f}\n\n## 综合评价\n\n{evaluations.get(score, '需进一步分析')}\n\n\"\"\"\n        \n        with open(output_path, 'w', encoding='utf-8') as f:\n            f.write(report)\n            \n        logger.info(f\"回测报告已生成: {output_path}\")\n        return report\n","path":"/Users/ling/quant/strategies/framework/backtest_engine.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":185,"output":2375,"cacheRead":57728,"cacheWrite":0,"totalTokens":60288,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775793123169,"responseId":"0627a6e3baa9d0961adf7b4468db33e3"}}
