{"type":"message","id":"9daa5b81","parentId":"536639fb","timestamp":"2026-04-10T11:33:48.554Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user wants a longer backtest period without leverage. Let me use BaoStock to get data going back further - maybe 10+ years to 2015 or earlier. This will give a more robust test across different market conditions (bull, bear, sideways markets).","thinkingSignature":"ba168103b513237fe0938808e282cb327e741bba6bf05b7bb5b2e01b401fe067"},{"type":"text","text":"\n\n好！拉长回测到10年以上，穿越牛熊：\n\n\n"},{"type":"toolCall","id":"call_ad6c87a3dc774f9a8766bbf4","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport baostock as bs\nimport pandas as pd\nimport numpy as np\nimport warnings\nwarnings.filterwarnings('ignore')\n\nlg = bs.login()\n\n# 获取更长周期数据 (2010年至今)\nrs = bs.query_history_k_data_plus('sh.000300', 'date,open,high,low,close,volume',\n    start_date='2010-01-01', end_date='2026-04-10', frequency='d')\ndata_list = []\nwhile rs.error_code == '0' and rs.next():\n    data_list.append(rs.get_row_data())\ndf = pd.DataFrame(data_list, columns=rs.fields)\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date')\nfor col in ['open','high','low','close','volume']:\n    df[col] = pd.to_numeric(df[col], errors='coerce')\ndf = df.dropna()\nbs.logout()\n\nbenchmark = (df.iloc[-1]['close'] / df.iloc[0]['close'] - 1) * 100\nyears = (df.index[-1] - df.index[0]).days / 365\nbenchmark_annual = ((df.iloc[-1]['close'] / df.iloc[0]['close']) ** (1/years) - 1) * 100\n\nprint(f\"=\" * 70)\nprint(f\"📊 长期回测: {df.index[0].date()} ~ {df.index[-1].date()}\")\nprint(f\"=\" * 70)\nprint(f\"数据: {len(df)} 条 ({years:.1f}年)\")\nprint(f\"沪深300: {df.iloc[0]['close']:.2f} → {df.iloc[-1]['close']:.2f}\")\nprint(f\"总收益: {benchmark:.1f}% | 年化: {benchmark_annual:.1f}%\\n\")\n\ndef backtest(data, signals, pos=0.95):\n    capital = 100000.0\n    c, s = capital, 0\n    trades = []\n    \n    eq_vals = []\n    for date, row in data.iterrows():\n        price = row['close']\n        eq_vals.append(c + s * price)\n        \n        if date not in signals.index or pd.isna(signals.loc[date]):\n            continue\n        sig = signals.loc[date]\n        \n        if sig == 1 and s == 0:\n            n = int(c * pos / price)\n            if n > 0:\n                c -= n * price * 1.0003\n                s = n\n                trades.append(('B', date.date(), price))\n        elif sig == -1 and s > 0:\n            c += s * price * 0.9997\n            trades.append(('S', date.date(), price))\n            s = 0\n    \n    fv = c + s * data.iloc[-1]['close']\n    tr = (fv - capital) / capital\n    \n    eq = pd.Series(eq_vals, index=data.index)\n    rets = eq.pct_change().dropna()\n    sharpe = rets.mean() / rets.std() * np.sqrt(252) if rets.std() > 0 else 0\n    peak = eq.cummax()\n    max_dd = ((eq - peak) / peak).min()\n    \n    buys = [t for t in trades if t[0]=='B']\n    sells = [t for t in trades if t[0]=='S']\n    wins = sum(1 for i,t in enumerate(sells) if i < len(buys) and t[2] > buys[i][2])\n    win = wins / len(sells) if sells else 0\n    \n    return {\n        'total': tr*100,\n        'annual': ((1+tr)**(252/len(data))-1)*100,\n        'sharpe': sharpe,\n        'max_dd': max_dd*100,\n        'trades': len(trades),\n        'win': win*100,\n        'trades_list': trades\n    }\n\ndef rsi_ma(data, rp=7, os=25, ms=5, ml=20):\n    sig = pd.Series(0, index=data.index)\n    d = data['close'].diff()\n    g = d.where(d>0,0).rolling(rp).mean()\n    l = (-d.where(d<0,0)).rolling(rp).mean()\n    rsi = 100 - (100/(1+g/(l+1e-10)))\n    ma_s = data['close'].rolling(ms).mean()\n    ma_l = data['close'].rolling(ml).mean()\n    sig[rsi < os] = 1\n    sig[(ma_s < ma_l) & (ma_s.shift(1) >= ma_l.shift(1))] = -1\n    return sig\n\ndef rsi_only(data, rp=7, os=25, ob=75):\n    sig = pd.Series(0, index=data.index)\n    d = data['close'].diff()\n    g = d.where(d>0,0).rolling(rp).mean()\n    l = (-d.where(d<0,0)).rolling(rp).mean()\n    rsi = 100 - (100/(1+g/(l+1e-10)))\n    sig[rsi < os] = 1\n    sig[rsi > ob] = -1\n    return sig\n\ndef ma_cross_long(data, ms=5, ml=60):\n    sig = pd.Series(0, index=data.index)\n    ma_s = data['close'].rolling(ms).mean()\n    ma_l = data['close'].rolling(ml).mean()\n    sig[(ma_s > ma_l) & (ma_s.shift(1) <= ma_l.shift(1))] = 1\n    sig[(ma_s < ma_l) & (ma_s.shift(1) >= ma_l.shift(1))] = -1\n    return sig\n\nprint(\"=\" * 70)\nprint(\"🔍 长期回测 - 寻找年化50%+策略\")\nprint(\"=\" * 70)\nprint(f\"{'策略':<25} {'总收益':>8} {'年化':>8} {'夏普':>6} {'回撤':>8} {'交易':>5} {'vs基准':>8}\")\nprint(\"-\" * 70)\n\nall_results = []\n\n# RSI+MA 参数搜索\nfor rp in [5, 7, 10, 14]:\n    for os in [20, 25, 30, 35]:\n        for ms in [5, 8, 10]:\n            for ml in [20, 25, 30, 60]:\n                if ms >= ml: continue\n                sig = rsi_ma(df, rp, os, ms, ml)\n                r = backtest(df, sig)\n                name = f\"RSI({rp},{os})MA({ms}/{ml})\"\n                all_results.append((name, r))\n\n# RSI 独立\nfor rp in [7, 14]:\n    for os in [25, 30]:\n        for ob in [70, 75, 80]:\n            sig = rsi_only(df, rp, os, ob)\n            r = backtest(df, sig)\n            all_results.append((f\"RSI({rp},{os},{ob})\", r))\n\n# 均线金叉\nfor ms in [5, 10, 20]:\n    for ml in [30, 60, 120]:\n        if ms >= ml: continue\n        sig = ma_cross_long(df, ms, ml)\n        r = backtest(df, sig)\n        all_results.append((f\"均线({ms}/{ml})\", r))\n\nall_results.sort(key=lambda x: x[1]['annual'], reverse=True)\n\nfor name, r in all_results[:20]:\n    diff = r['annual'] - benchmark_annual\n    mark = \" 🔥\" if diff > 0 else \"\"\n    print(f\"{name:<25} {r['total']:>7.1f}% {r['annual']:>7.1f}% {r['sharpe']:>6.3f} {r['max_dd']:>7.1f}% {r['trades']:>5} {diff:>+6.1f}%{mark}\")\n\nprint()\nprint(f\"基准沪深300: 总{benchmark:.1f}% | 年化{benchmark_annual:.1f}%\")\nbest_name, best_r = all_results[0]\nprint(f\"\\n🏆 最佳: {best_name}\")\nprint(f\"   总收益: {best_r['total']:.1f}% | 年化: {best_r['annual']:.1f}%\")\nprint(f\"   夏普: {best_r['sharpe']:.3f} | 最大回撤: {best_r['max_dd']:.1f}%\")\nprint(f\"   交易: {best_r['trades']}次 | 胜率: {best_r['win']:.1f}%\")\nprint(f\"   vs基准: {best_r['annual']-benchmark_annual:+.1f}%\")\n\n# 熊市表现分析\nprint()\nprint(\"📊 分阶段表现:\")\n# 2015年牛市顶点到2018年底 (熊市)\nbull_start = '2014-07-01'\nbull_end = '2015-06-15'\nbear_start = '2015-06-15'\nbear_end = '2016-02-29'\nrecent_start = '2024-01-01'\n\nfor start, end, label in [(bull_start, bull_end, '2015牛市'), (bear_start, bear_end, '2015熊市'), (recent_start, '2026-04-10', '近3年')]:\n    mask = (df.index >= start) & (df.index <= end)\n    sub = df[mask]\n    if len(sub) < 50: continue\n    index_ret = (sub.iloc[-1]['close'] / sub.iloc[0]['close'] - 1) * 100\n    print(f\"   {label}: 沪深300 {index_ret:+.1f}%\", end=\"\")\n    \n    # 策略在这段时间\n    sig = rsi_ma(df, 7, 25, 8, 25) if 'RSI' not in best_name else None\n    if sig is not None:\n        r = backtest(sub, sig)\n        print(f\" | 策略 {r['total']:+.1f}%\")\n    else:\n        print()\nEOF","timeout":180}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":622,"output":2362,"cacheRead":98176,"cacheWrite":0,"totalTokens":101160,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775820790266,"responseId":"062812f66ea6cb558da13db0955217f8"}}
