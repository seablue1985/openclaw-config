{"type":"message","id":"208c5f40","parentId":"5f6fb72f","timestamp":"2026-04-10T03:47:55.563Z","message":{"role":"assistant","content":[{"type":"text","text":"   继续创建监控面板和回测框架代码："},{"type":"toolCall","id":"functions.write:14","name":"write","arguments":{"content":"\"\"\"\n数据同步服务 - 从 AKShare/Tushare 获取数据并存储到 PostgreSQL\n\"\"\"\n\nimport os\nimport time\nimport logging\nfrom datetime import datetime, timedelta\nimport pandas as pd\nimport psycopg2\nfrom psycopg2.extras import execute_values\nimport schedule\n\n# 配置日志\nos.makedirs('/app/logs', exist_ok=True)\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s - %(levelname)s - %(message)s',\n    handlers=[\n        logging.FileHandler('/app/logs/data_sync.log'),\n        logging.StreamHandler()\n    ]\n)\nlogger = logging.getLogger(__name__)\n\n\ndef get_db_conn():\n    return psycopg2.connect(\n        host=os.getenv('DB_HOST', 'localhost'),\n        port=os.getenv('DB_PORT', '5432'),\n        user=os.getenv('DB_USER', 'quant'),\n        password=os.getenv('DB_PASS', 'quant_pass'),\n        database=os.getenv('DB_NAME', 'quant_db')\n    )\n\n\ndef log_update(data_type: str, symbol: str, count: int, status: str, error: str = ''):\n    \"\"\"记录更新日志\"\"\"\n    conn = get_db_conn()\n    cur = conn.cursor()\n    try:\n        cur.execute(\"\"\"\n            INSERT INTO data_update_log (data_type, symbol, update_date, records_count, status, error_message)\n            VALUES (%s, %s, %s, %s, %s, %s)\n        \"\"\", (data_type, symbol, datetime.now().date(), count, status, error))\n        conn.commit()\n    finally:\n        cur.close()\n        conn.close()\n\n\ndef fetch_stock_daily(symbol: str, start_date: str, end_date: str):\n    \"\"\"从 AKShare 获取股票日线数据\"\"\"\n    try:\n        import akshare as ak\n        \n        code = symbol.split('.')[0]\n        df = ak.stock_zh_a_hist(\n            symbol=code,\n            period=\"daily\",\n            start_date=start_date.replace('-', ''),\n            end_date=end_date.replace('-', ''),\n            adjust=\"qfq\"\n        )\n        \n        df.columns = ['date', 'open', 'close', 'high', 'low', 'volume', \n                      'amount', 'amplitude', 'pct_change', 'change', 'turnover']\n        df['date'] = pd.to_datetime(df['date'])\n        \n        return df\n    except Exception as e:\n        logger.error(f\"获取 {symbol} 数据失败: {e}\")\n        return None\n\n\ndef save_stock_daily(df, symbol: str) -> int:\n    \"\"\"保存到数据库\"\"\"\n    if df is None or df.empty:\n        return 0\n        \n    conn = get_db_conn()\n    cur = conn.cursor()\n    \n    records = []\n    for _, row in df.iterrows():\n        records.append((\n            symbol, row['date'].date(),\n            float(row['open']), float(row['high']), float(row['low']), float(row['close']),\n            int(row['volume']), float(row.get('amount', 0)),\n            float(row.get('pct_change', 0)), float(row.get('turnover', 0)),\n        ))\n    \n    try:\n        execute_values(\n            cur,\n            \"\"\"\n            INSERT INTO stock_daily (symbol, trade_date, open, high, low, close, volume, amount, pct_change, turnover)\n            VALUES %s\n            ON CONFLICT (symbol, trade_date) DO UPDATE SET\n                open = EXCLUDED.open, high = EXCLUDED.high, low = EXCLUDED.low, close = EXCLUDED.close,\n                volume = EXCLUDED.volume, amount = EXCLUDED.amount, pct_change = EXCLUDED.pct_change, turnover = EXCLUDED.turnover\n            \"\"\",\n            records, page_size=1000\n        )\n        conn.commit()\n        count = len(records)\n        logger.info(f\"{symbol}: 保存 {count} 条日线数据\")\n        log_update('stock_daily', symbol, count, 'SUCCESS')\n        return count\n    except Exception as e:\n        conn.rollback()\n        logger.error(f\"保存失败: {e}\")\n        log_update('stock_daily', symbol, 0, 'FAILED', str(e))\n        return 0\n    finally:\n        cur.close()\n        conn.close()\n\n\ndef get_last_update_date(symbol: str) -> str:\n    \"\"\"获取最后更新日期\"\"\"\n    conn = get_db_conn()\n    cur = conn.cursor()\n    try:\n        cur.execute(\"SELECT MAX(trade_date) FROM stock_daily WHERE symbol = %s\", (symbol,))\n        result = cur.fetchone()[0]\n        if result:\n            return (result + timedelta(days=1)).strftime('%Y-%m-%d')\n        return (datetime.now() - timedelta(days=365)).strftime('%Y-%m-%d')\n    except:\n        return (datetime.now() - timedelta(days=365)).strftime('%Y-%m-%d')\n    finally:\n        cur.close()\n        conn.close()\n\n\ndef sync_stock(symbol: str):\n    \"\"\"同步单只股票数据\"\"\"\n    last_date = get_last_update_date(symbol)\n    end_date = datetime.now().strftime('%Y-%m-%d')\n    \n    if last_date >= end_date:\n        return 0\n        \n    logger.info(f\"{symbol}: 同步 {last_date} ~ {end_date}\")\n    df = fetch_stock_daily(symbol, last_date, end_date)\n    if df is not None:\n        return save_stock_daily(df, symbol)\n    return 0\n\n\ndef daily_full_sync():\n    \"\"\"每日全量同步\"\"\"\n    logger.info(\"=\" * 50)\n    logger.info(\"开始每日数据同步...\")\n    \n    # 默认沪深300成分股\n    try:\n        import akshare as ak\n        stocks = ak.index_stock_cons_weight_csindex(symbol=\"000300\")\n        symbols = stocks['成分券代码'].tolist()[:50]\n    except:\n        symbols = ['000001', '000002', '600000', '600519']\n    \n    success = 0\n    for symbol in symbols:\n        try:\n            sync_stock(symbol)\n            success += 1\n        except Exception as e:\n            logger.error(f\"{symbol} 同步异常: {e}\")\n        time.sleep(0.5)\n    \n    logger.info(f\"同步完成: 成功 {success}/{len(symbols)}\")\n\n\ndef main():\n    \"\"\"主函数\"\"\"\n    logger.info(\"数据同步服务启动\")\n    \n    # 立即执行一次\n    daily_full_sync()\n    \n    # 设置定时任务\n    schedule.every().day.at(\"08:30\").do(daily_full_sync)\n    schedule.every().day.at(\"16:35\").do(daily_full_sync)\n    \n    logger.info(\"进入调度循环...\")\n    while True:\n        schedule.run_pending()\n        time.sleep(30)\n\n\nif __name__ == '__main__':\n    main()\n","path":"/Users/ling/quant/docker/data-sync/src/data_sync.py"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":5347,"output":1696,"cacheRead":46912,"cacheWrite":0,"totalTokens":53955,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775792801735,"responseId":"7d317f0989d64e8d961a1d082ae8b183"}}
