{"type":"message","id":"514a6b32","parentId":"bd744c58","timestamp":"2026-04-10T07:16:10.821Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_hXhr798KRGgO0aa0JXRFm9","name":"write","arguments":{"content":"\"\"\"\n策略上线检查清单 - 每次策略上线前必须通过\n\"\"\"\n\nimport json\nfrom datetime import datetime\nfrom typing import Dict, List, Tuple\nfrom dataclasses import dataclass\n\n\n@dataclass\nclass CheckItem:\n    \"\"\"检查项\"\"\"\n    category: str\n    name: str\n    description: str\n    passed: bool\n    mandatory: bool  # 是否为必过项\n    notes: str = \"\"\n\n\nclass PreLaunchChecklist:\n    \"\"\"\n    策略上线前检查清单\n    \n    所有 mandatory 项必须通过才能上线\n    \"\"\"\n    \n    def __init__(self, strategy_name: str, version: str):\n        self.strategy_name = strategy_name\n        self.version = version\n        self.items: List[CheckItem] = []\n        self.check_date = datetime.now()\n        \n    def add_check(self, category: str, name: str, description: str,\n                  passed: bool, mandatory: bool = True, notes: str = \"\"):\n        \"\"\"添加检查项\"\"\"\n        self.items.append(CheckItem(\n            category=category,\n            name=name,\n            description=description,\n            passed=passed,\n            mandatory=mandatory,\n            notes=notes\n        ))\n        \n    def is_ready(self) -> bool:\n        \"\"\"是否可以上线\"\"\"\n        return all(item.passed for item in self.items if item.mandatory)\n        \n    def get_failed_items(self) -> List[CheckItem]:\n        \"\"\"获取未通过的检查项\"\"\"\n        return [item for item in self.items if not item.passed]\n        \n    def generate_report(self, output_path: str = None) -> str:\n        \"\"\"生成检查报告\"\"\"\n        \n        total = len(self.items)\n        passed = sum(1 for item in self.items if item.passed)\n        failed = total - passed\n        mandatory_failed = sum(1 for item in self.items if item.mandatory and not item.passed)\n        \n        can_launch = self.is_ready()\n        \n        report = f\"\"\"# 策略上线检查报告\n\n## 基本信息\n- 策略名称: {self.strategy_name}\n- 版本: {self.version}\n- 检查时间: {self.check_date.strftime('%Y-%m-%d %H:%M:%S')}\n\n## 检查结果\n- 总检查项: {total}\n- 通过: {passed} ✅\n- 未通过: {failed} ❌\n- 必过项未通过: {mandatory_failed}\n\n## 上线决定: {'✅ 可以上线' if can_launch else '❌ 不能上线'}\n\n---\n\n## 详细检查\n\n\"\"\"\n        \n        # 按类别分组\n        categories = {}\n        for item in self.items:\n            if item.category not in categories:\n                categories[item.category] = []\n            categories[item.category].append(item)\n            \n        for category, items in categories.items():\n            report += f\"### {category}\\n\\n\"\n            report += \"| 检查项 | 必过 | 结果 | 说明 |\\n\"\n            report += \"|--------|------|------|------|\\n\"\n            \n            for item in items:\n                status = \"✅\" if item.passed else \"❌\"\n                mandatory = \"是\" if item.mandatory else \"否\"\n                report += f\"| {item.name} | {mandatory} | {status} | {item.notes or item.description} |\\n\"\n                \n            report += \"\\n\"\n            \n        # 未通过项详情\n        failed_items = self.get_failed_items()\n        if failed_items:\n            report += \"---\\n\\n## 未通过项详情\\n\\n\"\n            for item in failed_items:\n                mandatory_tag = \"🔴 必过项\" if item.mandatory else \"🟡 建议项\"\n                report += f\"### {mandatory_tag}: {item.name}\\n\\n\"\n                report += f\"- 类别: {item.category}\\n\"\n                report += f\"- 描述: {item.description}\\n\"\n                if item.notes:\n                    report += f\"- 备注: {item.notes}\\n\"\n                report += \"\\n\"\n                \n        if output_path:\n            import os\n            os.makedirs(os.path.dirname(output_path), exist_ok=True)\n            with open(output_path, 'w', encoding='utf-8') as f:\n                f.write(report)\n                \n        return report\n\n\ndef run_standard_checks(strategy_name: str, \n                        version: str,\n                        backtest_metrics: Dict,\n                        validation_result: Dict = None,\n                        has_whitepaper: bool = False,\n                        has_risk_controls: bool = False,\n                        data_quality_passed: bool = False) -> PreLaunchChecklist:\n    \"\"\"\n    运行标准上线检查\n    \n    Args:\n        strategy_name: 策略名称\n        version: 版本号\n        backtest_metrics: 回测绩效指标\n        validation_result: 验证结果\n        has_whitepaper: 是否有策略白皮书\n        has_risk_controls: 是否有风控规则\n        data_quality_passed: 数据质量是否通过\n    \"\"\"\n    \n    checklist = PreLaunchChecklist(strategy_name, version)\n    \n    # 一、数据质量\n    checklist.add_check(\n        \"数据质量\", \"数据质量检查\",\n        \"所有数据通过质量检查（OHLC逻辑、缺失值、异常值）\",\n        data_quality_passed,\n        mandatory=True,\n        notes=\"通过\" if data_quality_passed else \"请先运行数据质量检查\"\n    )\n    \n    # 二、策略逻辑\n    checklist.add_check(\n        \"策略逻辑\", \"策略白皮书\",\n        \"策略有完整的白皮书文档\",\n        has_whitepaper,\n        mandatory=True,\n        notes=\"已有\" if has_whitepaper else \"请先生成策略白皮书\"\n    )\n    \n    checklist.add_check(\n        \"策略逻辑\", \"无未来函数\",\n        \"策略不使用未来数据（如收盘价在开盘时用）\",\n        True,  # 需要人工确认\n        mandatory=True,\n        notes=\"需人工确认\"\n    )\n    \n    # 三、回测绩效\n    sharpe = backtest_metrics.get('sharpe_ratio', 0)\n    checklist.add_check(\n        \"回测绩效\", \"夏普比率 > 1.0\",\n        f\"回测夏普比率为 {sharpe:.3f}\",\n        sharpe > 1.0,\n        mandatory=True,\n        notes=f\"当前: {sharpe:.3f}\"\n    )\n    \n    max_dd = abs(backtest_metrics.get('max_drawdown', 0))\n    checklist.add_check(\n        \"回测绩效\", \"最大回撤 < 25%\",\n        f\"回测最大回撤为 {max_dd:.2f}%\",\n        max_dd < 25,\n        mandatory=True,\n        notes=f\"当前: {max_dd:.2f}%\"\n    )\n    \n    total_trades = backtest_metrics.get('total_trades', 0)\n    checklist.add_check(\n        \"回测绩效\", \"交易次数 > 30\",\n        \"足够的交易样本量\",\n        total_trades > 30,\n        mandatory=True,\n        notes=f\"当前: {total_trades} 次\"\n    )\n    \n    annual_return = backtest_metrics.get('annual_return', 0)\n    checklist.add_check(\n        \"回测绩效\", \"年化收益 > 10%\",\n        f\"年化收益为 {annual_return:.2f}%\",\n        annual_return > 10,\n        mandatory=False,\n        notes=f\"当前: {annual_return:.2f}%\"\n    )\n    \n    # 四、稳健性验证\n    if validation_result:\n        robust_score = validation_result.get('robust_score', 0)\n        checklist.add_check(\n            \"稳健性验证\", \"稳健性评分 > 60\",\n            f\"Walk-Forward 验证评分为 {robust_score}\",\n            robust_score > 60,\n            mandatory=True,\n            notes=f\"当前: {robust_score}/100\"\n        )\n        \n        positive_ratio = validation_result.get('positive_ratio', 0)\n        checklist.add_check(\n            \"稳健性验证\", \"正收益比例 > 60%\",\n            f\"正收益比例为 {positive_ratio*100:.1f}%\",\n            positive_ratio > 0.6,\n            mandatory=True,\n            notes=f\"当前: {positive_ratio*100:.1f}%\"\n        )\n    else:\n        checklist.add_check(\n            \"稳健性验证\", \"稳健性验证\",\n            \"策略需通过 Walk-Forward 验证\",\n            False,\n            mandatory=True,\n            notes=\"未执行验证\"\n        )\n        \n    # 五、风险控制\n    checklist.add_check(\n        \"风险控制\", \"风控规则配置\",\n        \"策略有独立的风控规则（仓位限制、止损等）\",\n        has_risk_controls,\n        mandatory=True,\n        notes=\"已配置\" if has_risk_controls else \"请先配置风控规则\"\n    )\n    \n    checklist.add_check(\n        \"风险控制\", \"硬止损机制\",\n        \"存在与策略解耦的硬止损\",\n        has_risk_controls,\n        mandatory=True,\n        notes=\"已配置\" if has_risk_controls else \"需配置\"\n    )\n    \n    # 六、运维\n    checklist.add_check(\n        \"运维准备\", \"监控告警\",\n        \"策略有健康度监控和告警配置\",\n        True,\n        mandatory=False,\n        notes=\"已有策略监控模块\"\n    )\n    \n    checklist.add_check(\n        \"运维准备\", \"日志记录\",\n        \"所有信号和交易有完整日志\",\n        True,\n        mandatory=True,\n        notes=\"已有日志模块\"\n    )\n    \n    return checklist\n","path":"/Users/ling/quant/strategies/framework/pre_launch_checklist.py"}}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":2990,"output":2871,"cacheRead":125287,"cacheWrite":0,"totalTokens":131148,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775805285530,"responseId":"59564156-9c22-41de-b209-baa6317dbb96"}}
{"type":"message","id":"8957ed92","parentId":"514a6b32","timestamp":"2026-04-10T07:16:10.922Z","message":{"role":"toolResult","toolCallId":"tooluse_hXhr798KRGgO0aa0JXRFm9","toolName":"write","content":[{"type":"text","text":"Successfully wrote 7393 bytes to /Users/ling/quant/strategies/framework/pre_launch_checklist.py"}],"isError":false,"timestamp":1775805370916}}
{"type":"message","id":"3c94687f","parentId":"8957ed92","timestamp":"2026-04-10T07:17:13.815Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_MyczCLb6ki7PJeI4iOKGnE","name":"write","arguments":{"content":"\"\"\"\n策略失效检测与下线机制\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nfrom typing import Dict, List, Optional\nfrom dataclasses import dataclass\nfrom enum import Enum\nimport logging\nimport json\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\n\nclass StrategyStatus(Enum):\n    \"\"\"策略状态\"\"\"\n    ACTIVE = \"ACTIVE\"          # 正常运行\n    WATCH = \"WATCH\"            # 关注中（出现衰减信号）\n    SUSPENDED = \"SUSPENDED\"    # 暂停（等待复核）\n    RETIRED = \"RETIRED\"        # 已下线\n\n\n@dataclass\nclass RetirementCriteria:\n    \"\"\"\n    策略下线标准\n    \"\"\"\n    # 连续亏损月数\n    max_consecutive_loss_months: int = 3\n    \n    # 最大回撤超过历史回测的倍数\n    max_drawdown_multiplier: float = 1.5\n    \n    # 滚动夏普低于阈值的持续天数\n    min_rolling_sharpe: float = 0.5\n    sharpe_below_days: int = 60\n    \n    # 收益率低于基准的持续月数\n    underperform_months: int = 3\n    \n    # 策略失效检测的置信度\n    decay_confidence: float = 0.95\n\n\nclass StrategyLifecycleManager:\n    \"\"\"\n    策略生命周期管理\n    \n    管理策略从上线到下线的全过程\n    \"\"\"\n    \n    def __init__(self, criteria: RetirementCriteria = None):\n        self.criteria = criteria or RetirementCriteria()\n        self.strategies: Dict[str, Dict] = {}\n        self.history_file = 'monitoring/strategy_lifecycle.json'\n        self._load()\n        \n    def _load(self):\n        \"\"\"加载状态\"\"\"\n        try:\n            with open(self.history_file, 'r') as f:\n                self.strategies = json.load(f)\n        except FileNotFoundError:\n            self.strategies = {}\n            \n    def _save(self):\n        \"\"\"保存状态\"\"\"\n        import os\n        os.makedirs(os.path.dirname(self.history_file), exist_ok=True)\n        with open(self.history_file, 'w') as f:\n            json.dump(self.strategies, f, indent=2, default=str)\n            \n    def register_strategy(self, name: str, \n                          backtest_max_drawdown: float,\n                          backtest_sharpe: float,\n                          launch_date: str = None):\n        \"\"\"\n        注册策略\n        \"\"\"\n        self.strategies[name] = {\n            'status': StrategyStatus.ACTIVE.value,\n            'launch_date': launch_date or datetime.now().strftime('%Y-%m-%d'),\n            'backtest_max_drawdown': backtest_max_drawdown,\n            'backtest_sharpe': backtest_sharpe,\n            'watch_reasons': [],\n            'suspend_reasons': [],\n            'status_history': [{\n                'date': datetime.now().strftime('%Y-%m-%d'),\n                'from': None,\n                'to': StrategyStatus.ACTIVE.value,\n                'reason': '策略上线'\n            }]\n        }\n        self._save()\n        logger.info(f\"策略 {name} 已注册，状态: ACTIVE\")\n        \n    def evaluate(self, name: str, \n                 monthly_returns: pd.Series,\n                 daily_returns: pd.Series,\n                 benchmark_returns: pd.Series = None) -> Dict:\n        \"\"\"\n        评估策略是否需要状态变更\n        \"\"\"\n        if name not in self.strategies:\n            return {'action': 'UNKNOWN', 'message': '策略未注册'}\n            \n        strategy = self.strategies[name]\n        current_status = strategy['status']\n        signals = []\n        \n        # 1. 连续亏损月数检查\n        consecutive_loss = 0\n        for ret in reversed(monthly_returns):\n            if ret < 0:\n                consecutive_loss += 1\n            else:\n                break\n                \n        if consecutive_loss >= self.criteria.max_consecutive_loss_months:\n            signals.append({\n                'type': 'CONSECUTIVE_LOSS',\n                'severity': 'HIGH',\n                'detail': f'连续 {consecutive_loss} 个月亏损'\n            })\n            \n        # 2. 最大回撤检查\n        cumret = (1 + daily_returns).cumprod()\n        running_max = cumret.expanding().max()\n        current_dd = ((cumret - running_max) / running_max).min()\n        \n        backtest_dd = strategy['backtest_max_drawdown']\n        if abs(current_dd) > abs(backtest_dd) * self.criteria.max_drawdown_multiplier:\n            signals.append({\n                'type': 'DRAWDOWN_EXCEEDED',\n                'severity': 'CRITICAL',\n                'detail': f'回撤 {current_dd*100:.1f}% 超过回测 {backtest_dd*100:.1f}% 的 {self.criteria.max_drawdown_multiplier}x'\n            })\n            \n        # 3. 滚动夏普检查\n        if len(daily_returns) >= self.criteria.sharpe_below_days:\n            rolling_sharpe = daily_returns.tail(self.criteria.sharpe_below_days)\n            sharpe_value = rolling_sharpe.mean() / rolling_sharpe.std() * np.sqrt(252) if rolling_sharpe.std() > 0 else 0\n            \n            if sharpe_value < self.criteria.min_rolling_sharpe:\n                signals.append({\n                    'type': 'LOW_SHARPE',\n                    'severity': 'MEDIUM',\n                    'detail': f'滚动夏普 {sharpe_value:.2f} 低于阈值 {self.criteria.min_rolling_sharpe}'\n                })\n                \n        # 4. 跑输基准检查\n        if benchmark_returns is not None and len(monthly_returns) >= self.criteria.underperform_months:\n            aligned_bench = benchmark_returns.reindex(monthly_returns.index).fillna(0)\n            recent_excess = monthly_returns.tail(self.criteria.underperform_months) - \\\n                          aligned_bench.tail(self.criteria.underperform_months)\n            \n            if (recent_excess < 0).all():\n                signals.append({\n                    'type': 'UNDERPERFORM',\n                    'severity': 'MEDIUM',\n                    'detail': f'连续 {self.criteria.underperform_months} 个月跑输基准'\n                })\n                \n        # 决策\n        action = self._decide_action(name, current_status, signals)\n        \n        return action\n        \n    def _decide_action(self, name: str, current_status: str, \n                       signals: List[Dict]) -> Dict:\n        \"\"\"\n        根据信号决定操作\n        \"\"\"\n        if not signals:\n            return {\n                'action': 'KEEP',\n                'message': '策略运行正常',\n                'signals': []\n            }\n            \n        critical_signals = [s for s in signals if s['severity'] == 'CRITICAL']\n        high_signals = [s for s in signals if s['severity'] == 'HIGH']\n        \n        # CRITICAL 信号直接暂停\n        if critical_signals:\n            new_status = StrategyStatus.SUSPENDED.value\n            self._change_status(name, new_status, \n                              f\"触发 CRITICAL 信号: {critical_signals[0]['detail']}\")\n            return {\n                'action': 'SUSPEND',\n                'message': f'策略已暂停: {critical_signals[0][\"detail\"]}',\n                'signals': signals,\n                'recommendation': '建议立即停止实盘交易并复盘'\n            }\n            \n        # 多个 HIGH 信号也暂停\n        if len(high_signals) >= 2:\n            new_status = StrategyStatus.SUSPENDED.value\n            self._change_status(name, new_status, \n                              f\"触发多个 HIGH 信号\")\n            return {\n                'action': 'SUSPEND',\n                'message': f'策略已暂停: 多个高风险信号',\n                'signals': signals,\n                'recommendation': '建议降低仓位并密切关注'\n            }\n            \n        # HIGH 信号进入 WATCH\n        if high_signals:\n            if current_status != StrategyStatus.WATCH.value:\n                new_status = StrategyStatus.WATCH.value\n                self._change_status(name, new_status, \n                                  f\"触发 HIGH 信号: {high_signals[0]['detail']}\")\n            return {\n                'action': 'WATCH',\n                'message': f'策略进入关注: {high_signals[0][\"detail\"]}',\n                'signals': signals,\n                'recommendation': '建议降低仓位，密切关注'\n            }\n            \n        return {\n            'action': 'MONITOR',\n            'message': '存在中等风险信号',\n            'signals': signals,\n            'recommendation': '建议持续监控'\n        }\n        \n    def _change_status(self, name: str, new_status: str, reason: str):\n        \"\"\"变更状态\"\"\"\n        old_status = self.strategies[name]['status']\n        self.strategies[name]['status'] = new_status\n        self.strategies[name]['status_history'].append({\n            'date': datetime.now().strftime('%Y-%m-%d'),\n            'from': old_status,\n            'to': new_status,\n            'reason': reason\n        })\n        self._save()\n        logger.info(f\"策略 {name}: {old_status} -> {new_status} ({reason})\")\n        \n    def retire_strategy(self, name: str, reason: str = \"手动下线\"):\n        \"\"\"下线策略\"\"\"\n        self._change_status(name, StrategyStatus.RETIRED.value, reason)\n        \n    def reactivate_strategy(self, name: str, reason: str = \"复核后恢复\"):\n        \"\"\"恢复策略\"\"\"\n        self._change_status(name, StrategyStatus.ACTIVE.value, reason)\n        \n    def get_status_report(self) -> str:\n        \"\"\"获取所有策略状态报告\"\"\"\n        lines = [\n            \"# 策略生命周期状态报告\",\n            f\"\\n生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\n\",\n            \"| 策略名称 | 状态 | 上线日期 | 运行天数 |\",\n            \"|----------|------|----------|----------|\"\n        ]\n        \n        for name, info in self.strategies.items():\n            status_emoji = {\n                'ACTIVE': '🟢',\n                'WATCH': '🟡',\n                'SUSPENDED': '🔴',\n                'RETIRED': '⚫'\n            }.get(info['status'], '⚪')\n            \n            launch = datetime.strptime(info['launch_date'], '%Y-%m-%d')\n            days = (datetime.now() - launch).days\n            \n            lines.append(\n                f\"| {name} | {status_emoji} {info['status']} | {info['launch_date']} | {days} |\"\n            )\n            \n        return '\\n'.join(lines)\n","path":"/Users/ling/quant/strategies/framework/lifecycle.py"}}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":2913,"output":3105,"cacheRead":128276,"cacheWrite":0,"totalTokens":134294,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775805370924,"responseId":"bd6c7854-f70a-4d79-ab85-1e5d7410c588"}}
