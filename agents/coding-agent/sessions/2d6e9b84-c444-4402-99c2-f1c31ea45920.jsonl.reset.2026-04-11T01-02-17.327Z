{"type":"message","id":"7d940b62","parentId":"ca3f37e6","timestamp":"2026-04-10T08:52:37.172Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"没有 BacktestEngine 类。让我直接用 akshare 做简单回测。\n","thinkingSignature":"3ef740fb5a752564fa351cf64b6dd4eeb61fd9acdb49a84d4285b13435c99cfa"},{"type":"toolCall","id":"call_function_qrlepdsk34er_1","name":"exec","arguments":{"command":"python3 -c \"\nimport akshare as ak\nimport pandas as pd\nimport warnings\nwarnings.filterwarnings('ignore')\n\nprint('=== 真实数据回测 (AKShare) ===')\n\n# 获取沪深300数据\ndf = ak.stock_zh_index_daily(symbol='000300')\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date').sort_index()\ndf = df['2020':][['open', 'high', 'low', 'close', 'volume']].astype(float)\nprint(f'数据: {len(df)} 条, {df.index[0].date()} ~ {df.index[-1].date()}')\n\n# 回测\ncapital = 100000\ncash = capital\nshares = 0\ntrade_count = 0\ntrades = []\n\n# 均线金叉策略\nma5 = df['close'].rolling(5).mean()\nma20 = df['close'].rolling(20).mean()\n\nfor date, row in df.iterrows():\n    if pd.isna(ma5.loc[date]) or pd.isna(ma20.loc[date]):\n        continue\n    \n    price = row['close']\n    \n    # 买入信号: 金叉\n    if shares == 0 and ma5.loc[date] > ma20.loc[date] and ma5.shift(1).loc[date] <= ma20.shift(1).loc[date]:\n        shares = int(cash / price * 0.95)  # 95%仓位\n        cash -= shares * price * 1.0003  # 万3手续费\n        trade_count += 1\n        trades.append(('BUY', date.date(), price))\n    \n    # 卖出信号: 死叉\n    elif shares > 0 and ma5.loc[date] < ma20.loc[date] and ma5.shift(1).loc[date] >= ma20.shift(1).loc[date]:\n        cash += shares * price * 0.9997\n        trades.append(('SELL', date.date(), price))\n        shares = 0\n        trade_count += 1\n\n# 最终权益\nfinal_value = cash + shares * df.iloc[-1]['close']\ntotal_return = (final_value - capital) / capital\n\nprint(f'')\nprint(f'=== MA金叉策略结果 ===')\nprint(f'初始资金: {capital:,.0f}')\nprint(f'最终权益: {final_value:,.0f}')\nprint(f'总收益: {total_return:.2%}')\nprint(f'交易次数: {trade_count}')\nprint(f'最后持仓: {shares}股')\n\" 2>&1","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":113,"output":606,"cacheRead":111088,"cacheWrite":0,"totalTokens":111807,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775811116518,"responseId":"0627ed2c1dc50ec4048708b65ebebbb1"}}
