{"type":"message","id":"e329e34d","parentId":"baf99706","timestamp":"2026-04-10T10:20:26.435Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user wants higher returns. Let me try to optimize the strategy further to beat the market by a larger margin. Let me try more aggressive parameters, different combinations, and also explore other strategies like momentum, breakout, etc.","thinkingSignature":"50019bb325cf94376f410bfd31e5d17bfd9cb110231fd33f22677b924a2d7827"},{"type":"text","text":"\n\n好，继续优化！尝试更激进参数 + 多策略组合：\n\n"},{"type":"toolCall","id":"call_00af8120b966431eaa832198","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport baostock as bs\nimport pandas as pd\nimport numpy as np\nimport warnings\nwarnings.filterwarnings('ignore')\n\nlg = bs.login()\nrs = bs.query_history_k_data_plus('sh.000300', 'date,open,high,low,close,volume',\n    start_date='2024-01-01', end_date='2026-04-10', frequency='d')\ndata_list = []\nwhile rs.error_code == '0' and rs.next():\n    data_list.append(rs.get_row_data())\ndf = pd.DataFrame(data_list, columns=rs.fields)\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date')\nfor col in ['open','high','low','close','volume']:\n    df[col] = pd.to_numeric(df[col], errors='coerce')\ndf = df.dropna()\nbs.logout()\n\nbenchmark = (df.iloc[-1]['close'] / df.iloc[0]['close'] - 1) * 100\nprint(f\"沪深300买入持有: {benchmark:.1f}%\\n\")\n\ndef backtest(data, strategy_func, name):\n    capital = 100000.0\n    cash = capital\n    shares = 0\n    trades = []\n    signals = strategy_func(data)\n    \n    equity_dates = []\n    equity_values = []\n    current_cash = cash\n    current_shares = 0\n    \n    for date, row in data.iterrows():\n        price = row['close']\n        equity_dates.append(date)\n        equity_values.append(current_cash + current_shares * price)\n        \n        if date not in signals.index or pd.isna(signals.loc[date]):\n            continue\n        \n        sig = signals.loc[date]\n        \n        if sig == 1 and current_shares == 0 and current_cash > price:\n            n = int(current_cash / price * 0.95)\n            if n > 0:\n                current_cash -= n * price * 1.0003\n                current_shares = n\n                trades.append(('BUY', date.date(), price))\n        elif sig == -1 and current_shares > 0:\n            current_cash += current_shares * price * 0.9997\n            trades.append(('SELL', date.date(), price))\n            current_shares = 0\n    \n    final_price = data.iloc[-1]['close']\n    final_value = current_cash + current_shares * final_price\n    total_ret = (final_value - capital) / capital\n    annual = (1 + total_ret) ** (252 / len(data)) - 1\n    \n    equity = pd.Series(equity_values, index=equity_dates)\n    returns = equity.pct_change().dropna()\n    sharpe = returns.mean() / returns.std() * np.sqrt(252) if returns.std() > 0 else 0\n    peak = equity.cummax()\n    max_dd = ((equity - peak) / peak).min()\n    \n    buys = [t for t in trades if t[0]=='BUY']\n    sells = [t for t in trades if t[0]=='SELL']\n    wins = sum(1 for i,t in enumerate(sells) if i < len(buys) and t[2] > buys[i][2])\n    win = wins / len(sells) if sells else 0\n    \n    return {'name': name, 'total': total_ret, 'annual': annual, 'sharpe': sharpe, 'max_dd': max_dd, 'trades': len(trades), 'win': win}\n\n# === 更激进的参数搜索 ===\n\n# RSI超卖+均线止盈的多种参数组合\ndef rsi_ma(data, rsi_p, os, ma_s, ma_l):\n    sig = pd.Series(0, index=data.index)\n    delta = data['close'].diff()\n    gain = delta.where(delta > 0, 0).rolling(rsi_p).mean()\n    loss = (-delta.where(delta < 0, 0)).rolling(rsi_p).mean()\n    rsi = 100 - (100 / (1 + gain/(loss+1e-10)))\n    ma_s_ = data['close'].rolling(ma_s).mean()\n    ma_l_ = data['close'].rolling(ma_l).mean()\n    sig[rsi < os] = 1\n    sig[(ma_s_ < ma_l_) & (ma_s_.shift(1) >= ma_l_.shift(1))] = -1\n    return sig\n\n# RSI + 固定止盈止损\ndef rsi_stop(data, rsi_p=7, os=25, take=0.15, stop=0.05):\n    sig = pd.Series(0, index=data.index)\n    delta = data['close'].diff()\n    gain = delta.where(delta > 0, 0).rolling(rsi_p).mean()\n    loss = (-delta.where(delta < 0, 0)).rolling(rsi_p).mean()\n    rsi = 100 - (100 / (1 + gain/(loss+1e-10)))\n    sig[rsi < os] = 1\n    sig[rsi > 80] = -1  # 超买卖\n    return sig\n\n# 趋势线 (价格>均线持有，跌破卖)\ndef price_ma(data, ma_period=20):\n    sig = pd.Series(0, index=data.index)\n    ma = data['close'].rolling(ma_period).mean()\n    sig[data['close'] > ma] = 1\n    sig[data['close'] < ma] = -1\n    return sig\n\n# 高点突破\ndef high_break(data, window=10):\n    sig = pd.Series(0, index=data.index)\n    high_max = data['high'].rolling(window).max().shift(1)\n    sig[data['close'] > high_max] = 1\n    sig[data['close'] < data['close'].rolling(5).mean()] = -1\n    return sig\n\n# === 网格搜索最佳参数 ===\nprint(\"=\" * 75)\nprint(\"🔍 大规模参数搜索\")\nprint(\"=\" * 75)\n\nall_results = []\n\n# RSI+MA 参数搜索\nfor rsi_p in [5, 6, 7, 8, 9, 10]:\n    for os in [20, 25, 30, 35]:\n        for ma_s in [3, 5, 8, 10]:\n            for ma_l in [15, 20, 25, 30]:\n                if ma_s >= ma_l:\n                    continue\n                r = backtest(df, lambda d, rp=rsi_p, o=os, ms=ma_s, ml=ma_l: rsi_ma(d, rp, o, ms, ml), \n                           f\"RSI({rsi_p},{os})MA({ma_s}/{ma_l})\")\n                all_results.append(r)\n\n# 高点突破搜索\nfor window in [5, 8, 10, 15, 20]:\n    r = backtest(df, lambda d, w=window: high_break(d, w), f\"高点突破({window})\")\n    all_results.append(r)\n\n# 价格均线搜索\nfor period in [5, 10, 15, 20, 30]:\n    r = backtest(df, lambda d, p=period: price_ma(d, p), f\"价格>{period}日均线\")\n    all_results.append(r)\n\nall_results.sort(key=lambda x: x['total'], reverse=True)\n\nprint(f\"{'策略':<25} {'总收益':>8} {'年化':>8} {'夏普':>6} {'回撤':>8} {'交易':>5} {'vs基准':>8}\")\nprint(\"-\" * 75)\n\nfor r in all_results[:15]:\n    diff = r['total']*100 - benchmark\n    mark = \" 🔥\" if diff > 0 else \"\"\n    print(f\"{r['name']:<25} {r['total']*100:>7.2%} {r['annual']*100:>7.2%} {r['sharpe']:>6.3f} {r['max_dd']*100:>7.2%} {r['trades']:>5} {diff:>+7.2%}{mark}\")\n\nprint()\nprint(f\"基准沪深300: {benchmark:.1f}%\")\nbest = all_results[0]\nprint(f\"\\n🏆 最佳策略: {best['name']}\")\nprint(f\"   收益: {best['total']*100:.2f}% (vs基准 {best['total']*100-benchmark:+.2f}%)\")\nprint(f\"   年化: {best['annual']*100:.2f}% | 夏普: {best['sharpe']:.3f} | 回撤: {best['max_dd']*100:.2f}%\")\nEOF","timeout":120}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":80263,"output":2011,"cacheRead":1152,"cacheWrite":0,"totalTokens":83426,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775816373562,"responseId":"062801b6415fdc8a4c3a1d237a50ae3d"}}
