(7)             收益:  29.52%\n  2. 布林带突破(30)            收益:  24.07%\n  3. 布林带突破(20)            收益:  19.17%\n  4. 动量突破(10)             收益:  13.85%\n  5. RSI反转(14)            收益:  10.63%\n","name":"python3 <<"},"isError":false,"timestamp":1775813883810}}
{"type":"message","id":"28278d39","parentId":"92928b7f","timestamp":"2026-04-10T09:38:53.964Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"找到了几个表现不错的策略！让我对这些最优策略进行完整回测计算夏普等指标。\n","thinkingSignature":"c0b64f5ce8513ff0963127177452bce63b4420b19e6801fc953c0d92bce0683b"},{"type":"toolCall","id":"call_function_643m0sonezif_1","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport baostock as bs\nimport pandas as pd\nimport numpy as np\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# 获取数据\nlg = bs.login()\nrs = bs.query_history_k_data_plus('sh.000300', 'date,open,high,low,close,volume',\n    start_date='2024-01-01', end_date='2026-04-10', frequency='d')\ndata_list = []\nwhile rs.error_code == '0' and rs.next():\n    data_list.append(rs.get_row_data())\ndf = pd.DataFrame(data_list, columns=rs.fields)\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date')\nfor col in ['open','high','low','close','volume']:\n    df[col] = pd.to_numeric(df[col], errors='coerce')\ndf = df.dropna()\nbs.logout()\n\n# 完整回测函数\ndef full_backtest(strategy_func, name):\n    capital = 100000\n    cash = capital\n    shares = 0\n    trades = []\n    \n    signals = strategy_func(df)\n    \n    for date, row in df.iterrows():\n        if date not in signals.index or pd.isna(signals.loc[date]):\n            continue\n        price = row['close']\n        sig = signals.loc[date]\n        \n        if sig == 1 and shares == 0:\n            shares = int(cash / price * 0.95)\n            cash -= shares * price * 1.0003\n            trades.append(('BUY', date.date(), price))\n        elif sig == -1 and shares > 0:\n            cash += shares * price * 0.9997\n            trades.append(('SELL', date.date(), price))\n            shares = 0\n    \n    final_value = cash + shares * df.iloc[-1]['close']\n    total_return = (final_value - capital) / capital\n    annual_return = (1 + total_return) ** (252 / len(df)) - 1\n    \n    # 计算权益曲线和夏普\n    equity = []\n    tc, ts = capital, 0\n    for date, row in df.iterrows():\n        if date not in signals.index or pd.isna(signals.loc[date]):\n            equity.append(tc + ts * row['close'])\n            continue\n        price = row['close']\n        sig = signals.loc[date]\n        if ts == 0 and sig == 1:\n            ts = int(tc / price * 0.95)\n            tc -= ts * price * 1.0003\n        elif ts > 0 and sig == -1:\n            tc += ts * price * 0.9997\n            ts = 0\n        equity.append(tc + ts * price)\n    \n    equity = pd.Series(equity, index=df.index)\n    returns = equity.pct_change().dropna()\n    sharpe = returns.mean() / returns.std() * np.sqrt(252) if returns.std() > 0 else 0\n    peak = equity.cummax()\n    max_dd = ((equity - peak) / peak).min()\n    \n    # 胜率\n    buy_trades = [t for t in trades if t[0] == 'BUY']\n    sell_trades = [t for t in trades if t[0] == 'SELL']\n    wins = sum(1 for i, t in enumerate(sell_trades) if i < len(buy_trades) and t[2] > buy_trades[i][2])\n    win_rate = wins / len(sell_trades) if sell_trades else 0\n    \n    return {\n        'name': name,\n        'total': total_return,\n        'annual': annual_return,\n        'sharpe': sharpe,\n        'max_dd': max_dd,\n        'trades': len(trades),\n        'win_rate': win_rate\n    }\n\n# 最优策略: RSI反转(7)\ndef rsi7_strategy(data):\n    signals = pd.Series(0, index=data.index)\n    delta = data['close'].diff()\n    gain = delta.where(delta > 0, 0).rolling(7).mean()\n    loss = (-delta.where(delta < 0, 0)).rolling(7).mean()\n    rs = gain / (loss + 1e-10)\n    rsi = 100 - (100 / (1 + rs))\n    signals[rsi < 25] = 1\n    signals[rsi > 75] = -1\n    return signals\n\n# 布林带突破(30)\ndef boll30_strategy(data):\n    signals = pd.Series(0, index=data.index)\n    mid = data['close'].rolling(30).mean()\n    std = data['close'].rolling(30).std()\n    upper = mid + 2 * std\n    signals[data['close'] > upper.shift(1)] = 1\n    signals[data['close'] < mid] = -1\n    return signals\n\n# 均线金叉(10/40) - 最优均线参数\ndef ma1040_strategy(data):\n    signals = pd.Series(0, index=data.index)\n    ma10 = data['close'].rolling(10).mean()\n    ma40 = data['close'].rolling(40).mean()\n    golden = (ma10 > ma40) & (ma10.shift(1) <= ma40.shift(1))\n    death = (ma10 < ma40) & (ma10.shift(1) >= ma40.shift(1))\n    signals[golden] = 1\n    signals[death] = -1\n    return signals\n\n# 运行完整回测\nprint(\"=\" * 70)\nprint(\"🏆 优化后策略完整回测\")\nprint(\"=\" * 70)\nprint(f\"数据: 2024-01-02 ~ 2026-04-10 (沪深300)\\n\")\n\nresults = [\n    full_backtest(rsi7_strategy, \"RSI反转(7)\"),\n    full_backtest(boll30_strategy, \"布林带突破(30)\"),\n    full_backtest(ma1040_strategy, \"均线金叉(10/40)\"),\n]\n\nprint(f\"{'策略':<20} {'总收益':>8} {'年化':>8} {'夏普':>6} {'回撤':>8} {'交易':>5} {'胜率':>6}\")\nprint(\"-\" * 70)\n\nfor r in results:\n    print(f\"{r['name']:<20} {r['total']:>7.2%} {r['annual']:>7.2%} {r['sharpe']:>6.3f} {r['max_dd']:>7.2%} {r['trades']:>5} {r['win_rate']:>5.1%}\")\n\n# 自检\nprint()\nprint(\"=\" * 70)\nprint(\"✅ 自检结果\")\nprint(\"=\" * 70)\n\nfor r in results:\n    checks = []\n    checks.append((\"夏普>1.0\", r['sharpe'] > 1.0))\n    checks.append((\"年化>10%\", r['annual'] > 0.10))\n    checks.append((\"回撤<25%\", r['max_dd'] > -0.25))\n    checks.append((\"交易>30\", r['trades'] > 30))\n    checks.append((\"胜率>50%\", r['win_rate'] > 0.5))\n    \n    passed = sum(1 for _, p in checks if p)\n    status = \"✅ 通过\" if passed >= 4 else \"⚠️ 需改进\"\n    \n    print(f\"\\n{r['name']}: {passed}/5 项通过 ({status})\")\n    for name, p in checks:\n        print(f\"   {'✅' if p else '❌'} {name}\")\nEOF","timeout":90}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":443,"output":1735,"cacheRead":56640,"cacheWrite":0,"totalTokens":58818,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775813883838,"responseId":"0627f7fd446cf61a1ae71bcded32d67f"}}
