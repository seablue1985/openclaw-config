{"type":"message","id":"a79ad918","parentId":"b52e39db","timestamp":"2026-04-10T08:59:57.406Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's a syntax error in my code. Let me fix the strategy definitions.\n","thinkingSignature":"a4c2674c675f8b0f42dad70fad1fda100c82457b6a283bf60b8939247ac324e2"},{"type":"toolCall","id":"call_function_e1fualwy2co9_1","name":"exec","arguments":{"command":"python3 -c \"\nimport baostock as bs\nimport pandas as pd\nimport numpy as np\nimport warnings\nwarnings.filterwarnings('ignore')\n\nprint('=' * 65)\nprint('🎯 模拟盘刷新 - 沪深300指数 (2024-01 ~ 2026-04)')\nprint('=' * 65)\n\n# 获取数据\nlg = bs.login()\nrs = bs.query_history_k_data_plus('sh.000300', 'date,open,high,low,close,volume',\n    start_date='2024-01-01', end_date='2026-04-10', frequency='d')\ndata_list = []\nwhile rs.error_code == '0' and rs.next():\n    data_list.append(rs.get_row_data())\ndf = pd.DataFrame(data_list, columns=rs.fields)\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.set_index('date')\nfor col in ['open','high','low','close','volume']:\n    df[col] = pd.to_numeric(df[col], errors='coerce')\ndf = df.dropna()\nbs.logout()\n\nprint(f'数据: {len(df)} 条 | {df.index[0].date()} ~ {df.index[-1].date()}')\n\n# 回测函数\ndef backtest(data, strategy_func, name):\n    capital = 100000\n    cash = capital\n    shares = 0\n    trades = []\n    equity = []\n    \n    signals = strategy_func(data)\n    for date, row in data.iterrows():\n        if date not in signals.index or pd.isna(signals.loc[date]):\n            equity.append(cash + shares * row['close'])\n            continue\n        \n        price = row['close']\n        sig = signals.loc[date]\n        \n        if sig == 1 and shares == 0:\n            shares = int(cash / price * 0.95)\n            cash -= shares * price * 1.0003\n            trades.append((date.date(), '买入', round(price,2), shares))\n        elif sig == -1 and shares > 0:\n            cash += shares * price * 0.9997\n            trades.append((date.date(), '卖出', round(price,2)))\n            shares = 0\n        \n        equity.append(cash + shares * price)\n    \n    equity = pd.Series(equity, index=data.index)\n    returns = equity.pct_change().dropna()\n    \n    total_ret = (equity.iloc[-1] - capital) / capital\n    annual_ret = (1 + total_ret) ** (252 / len(data)) - 1\n    sharpe = returns.mean() / returns.std() * np.sqrt(252) if returns.std() > 0 else 0\n    max_dd = ((equity - equity.cummax()) / equity.cummax()).min()\n    \n    return {\n        'total_return': total_ret, 'annual_return': annual_ret,\n        'sharpe': sharpe, 'max_drawdown': max_dd,\n        'trade_count': len(trades), 'trades': trades,\n        'equity': equity\n    }\n\n# 20日突破策略\ndef breakout(data):\n    signals = pd.Series(0, index=data.index)\n    high_20 = data['high'].rolling(20).max().shift(1)\n    ma5 = data['close'].rolling(5).mean()\n    buy_signals = data['close'] > high_20\n    sell_signals = data['close'] < ma5\n    signals[buy_signals] = 1\n    signals[sell_signals] = -1\n    return signals\n\n# 均线金叉策略\ndef ma_cross(data):\n    signals = pd.Series(0, index=data.index)\n    ma5 = data['close'].rolling(5).mean()\n    ma20 = data['close'].rolling(20).mean()\n    golden = (ma5 > ma20) & (ma5.shift(1) <= ma20.shift(1))\n    death = (ma5 < ma20) & (ma5.shift(1) >= ma20.shift(1))\n    signals[golden] = 1\n    signals[death] = -1\n    return signals\n\n# 运行回测\nprint()\nr1 = backtest(df, breakout, '20日突破')\nprint(f'📈 20日突破: 收益: {r1[\\\"total_return\\\"]:+.2%} | 年化: {r1[\\\"annual_return\\\"]:+.2%} | 夏普: {r1[\\\"sharpe\\\"]:.3f} | 回撤: {r1[\\\"max_drawdown\\\"]:.2%} | 交易: {r1[\\\"trade_count\\\"]}次')\n\nr2 = backtest(df, ma_cross, '均线金叉')\nprint(f'📈 均线金叉: 收益: {r2[\\\"total_return\\\"]:+.2%} | 年化: {r2[\\\"annual_return\\\"]:+.2%} | 夏普: {r2[\\\"sharpe\\\"]:.3f} | 回撤: {r2[\\\"max_drawdown\\\"]:.2%} | 交易: {r2[\\\"trade_count\\\"]}次')\n\n# 排行榜\nprint()\nprint('=' * 65)\nprint('📊 模拟盘排行榜 (2024-01 ~ 2026-04)')\nprint('=' * 65)\nprint(f'{\\\"策略\\\":<14} {\\\"总收益\\\":>10} {\\\"年化\\\":>10} {\\\"夏普\\\":>8} {\\\"回撤\\\":>8} {\\\"交易\\\":>6}')\nprint('-' * 65)\nresults = [('20日突破', r1), ('均线金叉', r2)]\nfor name, r in sorted(results, key=lambda x: x[1]['sharpe'], reverse=True):\n    print(f'{name:<14} {r[\\\"total_return\\\"]:>+9.2%} {r[\\\"annual_return\\\"]:>+9.2%} {r[\\\"sharpe\\\"]:>8.3f} {r[\\\"max_drawdown\\\"]:>7.2%} {r[\\\"trade_count\\\"]:>6}')\n\n# 最近交易\nprint()\nprint('📋 最近交易记录:')\nall_trades = []\nfor name, r in results:\n    for t in r['trades'][-5:]:\n        all_trades.append((name, t))\nfor s, t in all_trades[-6:]:\n    print(f'   [{s}] {t[0]} {t[1]} {t[2]}' + (f' x{t[3]}' if len(t)>3 else ''))\n\nprint()\nprint('🕐 更新时间: 2026-04-10 16:38 | 数据源: BaoStock')\n\" 2>&1","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":1480,"output":1513,"cacheRead":112512,"cacheWrite":0,"totalTokens":115505,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775811555662,"responseId":"0627eee47aa29763ce1284d3744bd352"}}
