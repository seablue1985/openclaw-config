{"type":"message","id":"09e79bbc","parentId":"b59f91c8","timestamp":"2026-04-10T07:14:45.465Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"tooluse_3BYXvxpkPeeZ9rs0EiDLCK","name":"write","arguments":{"content":"\"\"\"\n策略白皮书生成器 - 自动生成标准化策略文档\n\"\"\"\n\nimport json\nfrom datetime import datetime\nfrom typing import Dict, List, Optional\n\n\nclass StrategyWhitepaper:\n    \"\"\"\n    生成标准化策略白皮书\n    \n    包括策略逻辑、参数、回测绩效、风险评估\n    \"\"\"\n    \n    @staticmethod\n    def generate(\n        strategy_name: str,\n        version: str,\n        author: str,\n        logic_description: str,\n        entry_conditions: List[str],\n        exit_conditions: List[str],\n        risk_controls: List[str],\n        params: Dict,\n        backtest_metrics: Dict,\n        validation_result: Dict = None,\n        notes: str = \"\",\n        output_path: str = None\n    ) -> str:\n        \"\"\"\n        生成策略白皮书\n        \"\"\"\n        \n        # 参数敏感性分析文本\n        param_text = \"\"\n        for name, value in params.items():\n            param_text += f\"| {name} | {value} | |\\n\"\n        \n        # 策略评级\n        rating = StrategyWhitepaper._rate_strategy(backtest_metrics, validation_result)\n        \n        doc = f\"\"\"# 策略白皮书: {strategy_name}\n\n## 文档信息\n\n| 字段 | 值 |\n|------|------|\n| 策略名称 | {strategy_name} |\n| 版本 | {version} |\n| 作者 | {author} |\n| 创建时间 | {datetime.now().strftime('%Y-%m-%d')} |\n| 策略评级 | {rating['grade']} ({rating['score']}/100) |\n\n---\n\n## 一、策略概述\n\n### 1.1 策略逻辑\n\n{logic_description}\n\n### 1.2 买入条件\n\n\"\"\"\n        for i, cond in enumerate(entry_conditions, 1):\n            doc += f\"{i}. {cond}\\n\"\n            \n        doc += f\"\"\"\n### 1.3 卖出条件\n\n\"\"\"\n        for i, cond in enumerate(exit_conditions, 1):\n            doc += f\"{i}. {cond}\\n\"\n            \n        doc += f\"\"\"\n### 1.4 风险控制\n\n\"\"\"\n        for i, ctrl in enumerate(risk_controls, 1):\n            doc += f\"{i}. {ctrl}\\n\"\n            \n        doc += f\"\"\"\n---\n\n## 二、参数配置\n\n| 参数名 | 当前值 | 说明 |\n|--------|--------|------|\n{param_text}\n\n---\n\n## 三、回测绩效\n\n### 3.1 核心指标\n\n| 指标 | 数值 | 评价 |\n|------|------|------|\n| 总收益率 | {backtest_metrics.get('total_return', 0):.2f}% | {StrategyWhitepaper._eval_return(backtest_metrics.get('total_return', 0))} |\n| 年化收益率 | {backtest_metrics.get('annual_return', 0):.2f}% | {StrategyWhitepaper._eval_annual_return(backtest_metrics.get('annual_return', 0))} |\n| 夏普比率 | {backtest_metrics.get('sharpe_ratio', 0):.3f} | {StrategyWhitepaper._eval_sharpe(backtest_metrics.get('sharpe_ratio', 0))} |\n| 索提诺比率 | {backtest_metrics.get('sortino_ratio', 0):.3f} | |\n| 卡尔玛比率 | {backtest_metrics.get('calmar_ratio', 0):.3f} | |\n\n### 3.2 风险指标\n\n| 指标 | 数值 | 评价 |\n|------|------|------|\n| 年化波动率 | {backtest_metrics.get('volatility', 0):.2f}% | |\n| 最大回撤 | {backtest_metrics.get('max_drawdown', 0):.2f}% | {StrategyWhitepaper._eval_drawdown(backtest_metrics.get('max_drawdown', 0))} |\n| 胜率 | {backtest_metrics.get('win_rate', 0):.1f}% | |\n| 盈亏比 | {backtest_metrics.get('profit_factor', 0):.2f} | |\n\n### 3.3 交易统计\n\n| 指标 | 数值 |\n|------|------|\n| 总交易次数 | {backtest_metrics.get('total_trades', 0)} |\n| 回测区间 | {backtest_metrics.get('start_date', 'N/A')} ~ {backtest_metrics.get('end_date', 'N/A')} |\n| 最终资金 | {backtest_metrics.get('final_capital', 0):,.0f} |\n\n\"\"\"\n\n        if validation_result:\n            doc += f\"\"\"\n---\n\n## 四、稳健性验证\n\n### 4.1 滚动前向验证 (Walk-Forward Analysis)\n\n| 指标 | 数值 |\n|------|------|\n| 稳健性评分 | {validation_result.get('robust_score', 0)}/100 |\n| 正收益比例 | {validation_result.get('positive_ratio', 0)*100:.1f}% |\n| 平均收益 | {validation_result.get('avg_return', 0):.2f}% |\n| 收益标准差 | {validation_result.get('std_return', 0):.2f}% |\n| 平均夏普 | {validation_result.get('avg_sharpe', 0):.3f} |\n| 夏普稳定性 | {validation_result.get('sharpe_consistency', 0):.3f} |\n\n### 4.2 稳健性评估\n\n\"\"\"\n            robust_score = validation_result.get('robust_score', 0)\n            if robust_score >= 80:\n                doc += \"🟢 **策略表现优秀**，各时段表现稳定，建议进入模拟盘阶段。\\n\"\n            elif robust_score >= 60:\n                doc += \"🟡 **策略表现良好**，部分时段波动较大，建议优化后再进入模拟盘。\\n\"\n            elif robust_score >= 40:\n                doc += \"🟠 **策略表现一般**，存在明显不稳定性，需进一步优化。\\n\"\n            else:\n                doc += \"🔴 **策略表现较差**，稳健性不足，不建议使用。\\n\"\n\n        doc += f\"\"\"\n---\n\n## 五、风险评估\n\n### 5.1 已识别风险\n\n1. **过拟合风险**: {'低' if validation_result and validation_result.get('robust_score', 0) > 60 else '需关注'}\n2. **流动性风险**: 需根据实际交易标的评估\n3. **市场环境风险**: 策略可能对特定市场环境敏感\n4. **执行风险**: 实盘滑点和成交率可能影响表现\n\n### 5.2 建议措施\n\n1. 进入模拟盘验证至少1个月\n2. 初始实盘资金不超过总资产的10%\n3. 设置硬止损（单日亏损不超过2%）\n4. 每月定期复盘并更新本文档\n\n---\n\n## 六、备注\n\n{notes if notes else '无'}\n\n---\n\n## 七、变更历史\n\n| 日期 | 版本 | 变更内容 |\n|------|------|----------|\n| {datetime.now().strftime('%Y-%m-%d')} | {version} | 初始版本 |\n\n---\n\n*本文档由量化系统自动生成，仅供参考，不构成投资建议。*\n\"\"\"\n        \n        if output_path:\n            import os\n            os.makedirs(os.path.dirname(output_path), exist_ok=True)\n            with open(output_path, 'w', encoding='utf-8') as f:\n                f.write(doc)\n                \n        return doc\n    \n    @staticmethod\n    def _rate_strategy(metrics: Dict, validation: Dict = None) -> Dict:\n        \"\"\"策略评级\"\"\"\n        score = 0\n        \n        # 收益 (30分)\n        ar = metrics.get('annual_return', 0)\n        if ar > 30: score += 30\n        elif ar > 20: score += 25\n        elif ar > 10: score += 15\n        elif ar > 0: score += 5\n        \n        # 夏普 (25分)\n        sr = metrics.get('sharpe_ratio', 0)\n        if sr > 2: score += 25\n        elif sr > 1.5: score += 20\n        elif sr > 1: score += 15\n        elif sr > 0.5: score += 5\n        \n        # 回撤 (25分)\n        dd = abs(metrics.get('max_drawdown', 0))\n        if dd < 10: score += 25\n        elif dd < 20: score += 20\n        elif dd < 30: score += 10\n        \n        # 稳健性 (20分)\n        if validation:\n            rs = validation.get('robust_score', 0)\n            score += int(rs * 0.2)\n            \n        # 评级\n        if score >= 85: grade = \"A+\"\n        elif score >= 75: grade = \"A\"\n        elif score >= 65: grade = \"B+\"\n        elif score >= 55: grade = \"B\"\n        elif score >= 45: grade = \"C\"\n        else: grade = \"D\"\n        \n        return {'score': score, 'grade': grade}\n    \n    @staticmethod\n    def _eval_return(val): return \"优秀\" if val > 50 else \"良好\" if val > 20 else \"一般\" if val > 0 else \"亏损\"\n    \n    @staticmethod\n    def _eval_annual_return(val): return \"优秀\" if val > 30 else \"良好\" if val > 15 else \"一般\" if val > 5 else \"不佳\"\n    \n    @staticmethod\n    def _eval_sharpe(val): return \"优秀\" if val > 2 else \"良好\" if val > 1 else \"一般\" if val > 0.5 else \"不佳\"\n    \n    @staticmethod\n    def _eval_drawdown(val): return \"优秀\" if abs(val) < 10 else \"可控\" if abs(val) < 20 else \"偏大\" if abs(val) < 30 else \"危险\"\n","path":"/Users/ling/quant/strategies/framework/whitepaper.py"}}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":321,"output":2951,"cacheRead":124967,"cacheWrite":0,"totalTokens":128239,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775805231199,"responseId":"ad291e4b-4b92-4ac3-b384-2b6515e0450e"}}
