{"type":"message","id":"88a2830e","parentId":"b8a45a98","timestamp":"2026-04-10T06:25:19.628Z","message":{"role":"assistant","content":[{"type":"text","text":"       现在创建一个 Jupyter Notebook 示例："},{"type":"toolCall","id":"functions.write:36","name":"write","arguments":{"content":"{\n \"cells\": [\n  {\n   \"cell_type\": \"markdown\",\n   \"metadata\": {},\n   \"source\": [\n    \"# 量化策略研究 Notebook\\n\",\n    \"\\n\",\n    \"这是量化策略研究的起始 notebook，包含常用代码片段。\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# 导入常用库\\n\",\n    \"import pandas as pd\\n\",\n    \"import numpy as np\\n\",\n    \"import matplotlib.pyplot as plt\\n\",\n    \"import plotly.graph_objects as go\\n\",\n    \"from datetime import datetime, timedelta\\n\",\n    \"\\n\",\n    \"# 设置显示选项\\n\",\n    \"pd.set_option('display.max_rows', 100)\\n\",\n    \"pd.set_option('display.max_columns', 50)\\n\",\n    \"plt.style.use('seaborn-v0_8')\\n\",\n    \"\\n\",\n    \"print(\\\"✅ 环境准备完成\\\")\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 1. 加载数据\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# 从数据库加载数据\\n\",\n    \"import psycopg2\\n\",\n    \"\\n\",\n    \"conn = psycopg2.connect(\\n\",\n    \"    host='quant-db',\\n\",\n    \"    port=5432,\\n\",\n    \"    user='quant',\\n\",\n    \"    password='quant_pass',\\n\",\n    \"    database='quant_db'\\n\",\n    \")\\n\",\n    \"\\n\",\n    \"# 查询股票数据\\n\",\n    \"query = \\\"\\\"\\\"\\n\",\n    \"SELECT * FROM stock_daily \\n\",\n    \"WHERE symbol = '000001' \\n\",\n    \"ORDER BY trade_date\\n\",\n    \"\\\"\\\"\\\"\\n\",\n    \"\\n\",\n    \"df = pd.read_sql(query, conn, parse_dates=['trade_date'])\\n\",\n    \"df.set_index('trade_date', inplace=True)\\n\",\n    \"\\n\",\n    \"print(f\\\"数据条数: {len(df)}\\\")\\n\",\n    \"df.head()\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 2. 快速回测\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# 导入回测框架\\n\",\n    \"import sys\\n\",\n    \"sys.path.append('/home/jovyan/strategies')\\n\",\n    \"\\n\",\n    \"from framework.backtest_engine import BaseStrategy, BacktestConfig\\n\",\n    \"\\n\",\n    \"# 定义简单策略\\n\",\n    \"class SimpleMAStrategy(BaseStrategy):\\n\",\n    \"    def __init__(self, config, short=5, long=20):\\n\",\n    \"        super().__init__(config)\\n\",\n    \"        self.short = short\\n\",\n    \"        self.long = long\\n\",\n    \"        \\n\",\n    \"    def on_bar(self, date, bar_data):\\n\",\n    \"        if self.current_idx < self.long:\\n\",\n    \"            return None\\n\",\n    \"            \\n\",\n    \"        hist = self.data.iloc[:self.current_idx+1]\\n\",\n    \"        ma_short = hist['close'].tail(self.short).mean()\\n\",\n    \"        ma_long = hist['close'].tail(self.long).mean()\\n\",\n    \"        \\n\",\n    \"        symbol = '000001'\\n\",\n    \"        \\n\",\n    \"        if ma_short > ma_long and symbol not in self.positions:\\n\",\n    \"            return {'action': 'BUY', 'symbol': symbol, 'shares': 1000}\\n\",\n    \"        elif ma_short < ma_long and symbol in self.positions:\\n\",\n    \"            return {'action': 'SELL', 'symbol': symbol, 'shares': self.positions[symbol]}\\n\",\n    \"            \\n\",\n    \"        return None\\n\",\n    \"\\n\",\n    \"# 运行回测\\n\",\n    \"config = BacktestConfig(\\n\",\n    \"    start_date='2020-01-01',\\n\",\n    \"    end_date='2023-12-31',\\n\",\n    \"    initial_capital=1_000_000\\n\",\n    \")\\n\",\n    \"\\n\",\n    \"strategy = SimpleMAStrategy(config, short=5, long=20)\\n\",\n    \"metrics = strategy.run_backtest(df)\\n\",\n    \"\\n\",\n    \"print(f\\\"总收益: {metrics['total_return']:.2f}%\\\")\\n\",\n    \"print(f\\\"夏普比率: {metrics['sharpe_ratio']:.3f}\\\")\\n\",\n    \"print(f\\\"最大回撤: {metrics['max_drawdown']:.2f}%\\\")\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 3. 可视化\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# 绘制净值曲线\\n\",\n    \"daily_values = pd.DataFrame(strategy.daily_values)\\n\",\n    \"daily_values.set_index('date', inplace=True)\\n\",\n    \"\\n\",\n    \"fig, axes = plt.subplots(2, 1, figsize=(12, 8))\\n\",\n    \"\\n\",\n    \"# 净值\\n\",\n    \"ax1 = axes[0]\\n\",\n    \"ax1.plot(daily_values.index, daily_values['total_value'], label='Strategy')\\n\",\n    \"ax1.set_title('Portfolio Value')\\n\",\n    \"ax1.legend()\\n\",\n    \"\\n\",\n    \"# 回撤\\n\",\n    \"ax2 = axes[1]\\n\",\n    \"cummax = daily_values['total_value'].cummax()\\n\",\n    \"drawdown = (daily_values['total_value'] - cummax) / cummax\\n\",\n    \"ax2.fill_between(drawdown.index, drawdown, 0, color='red', alpha=0.3)\\n\",\n    \"ax2.set_title('Drawdown')\\n\",\n    \"\\n\",\n    \"plt.tight_layout()\\n\",\n    \"plt.show()\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 4. 参数优化\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# 网格搜索参数\\n\",\n    \"results = []\\n\",\n    \"\\n\",\n    \"for short in [3, 5, 10]:\\n\",\n    \"    for long in [20, 30, 60]:\\n\",\n    \"        if short >= long:\\n\",\n    \"            continue\\n\",\n    \"            \\n\",\n    \"        strategy = SimpleMAStrategy(config, short=short, long=long)\\n\",\n    \"        metrics = strategy.run_backtest(df)\\n\",\n    \"        \\n\",\n    \"        results.append({\\n\",\n    \"            'short': short,\\n\",\n    \"            'long': long,\\n\",\n    \"            'return': metrics['total_return'],\\n\",\n    \"            'sharpe': metrics['sharpe_ratio'],\\n\",\n    \"            'max_dd': metrics['max_drawdown']\\n\",\n    \"        })\\n\",\n    \"\\n\",\n    \"results_df = pd.DataFrame(results)\\n\",\n    \"results_df.sort_values('sharpe', ascending=False).head(10)\"\n   ]\n  }\n ],\n \"metadata\": {\n  \"kernelspec\": {\n   \"display_name\": \"Python 3\",\n   \"language\": \"python\",\n   \"name\": \"python3\"\n  },\n  \"language_info\": {\n   \"name\": \"python\",\n   \"version\": \"3.11.0\"\n  }\n },\n \"nbformat\": 4,\n \"nbformat_minor\": 4\n}\n","path":"/Users/ling/quant/notebooks/research/00_quick_start.ipynb"}},{"type":"text","text":"  "}],"api":"anthropic-messages","provider":"camel-claude","model":"claude-opus-4-6","usage":{"input":1865,"output":2182,"cacheRead":75712,"cacheWrite":0,"totalTokens":79759,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775802249681,"responseId":"de8fc071d7d24806a9f1d6e67c687c85"}}
