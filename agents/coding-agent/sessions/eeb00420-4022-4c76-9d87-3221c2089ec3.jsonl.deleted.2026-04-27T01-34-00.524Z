{"type":"message","id":"baaee24c","parentId":"2c67af10","timestamp":"2026-04-26T01:31:06.358Z","message":{"role":"toolResult","toolCallId":"call_function_y01b2y46118i_1","toolName":"exec","content":[{"type":"text","text":"from __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport re\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom runtime_state_schema import build_precheck_runtime_truth, get_runtime_truth\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\nWORKSPACE_ROOT = ROOT.parents[1] if len(ROOT.parents) >= 2 else ROOT\nSTATE_PATH = Path(\n    str(\n        os.environ.get(\"PREMARKET_PRECHECK_STATE_PATH\")\n        or (WORKSPACE_ROOT / \"memory\" / \"premarket_precheck_state.json\")\n    )\n)\n\n\ndef now_shanghai() -> datetime:\n    return datetime.now()\n\n\ndef load_state() -> dict:\n    if not STATE_PATH.exists():\n        return {}\n    try:\n        return json.loads(STATE_PATH.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef save_state(payload: dict) -> None:\n    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)\n    STATE_PATH.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef is_trading_day(date_str: str) -> bool:\n    \"\"\"\n    交易日判断：优先用腾讯行情 API，API 异常时降级为工作日（周一~五）判断。\n    \"\"\"\n    try:\n        date_obj = datetime.strptime(date_str, \"%Y-%m-%d\")\n        weekday_fallback = date_obj.weekday() < 5\n    except Exception:\n        weekday_fallback = False"}],"details":{"status":"completed","exitCode":0,"durationMs":29,"aggregated":"from __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport re\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom runtime_state_schema import build_precheck_runtime_truth, get_runtime_truth\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\nWORKSPACE_ROOT = ROOT.parents[1] if len(ROOT.parents) >= 2 else ROOT\nSTATE_PATH = Path(\n    str(\n        os.environ.get(\"PREMARKET_PRECHECK_STATE_PATH\")\n        or (WORKSPACE_ROOT / \"memory\" / \"premarket_precheck_state.json\")\n    )\n)\n\n\ndef now_shanghai() -> datetime:\n    return datetime.now()\n\n\ndef load_state() -> dict:\n    if not STATE_PATH.exists():\n        return {}\n    try:\n        return json.loads(STATE_PATH.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef save_state(payload: dict) -> None:\n    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)\n    STATE_PATH.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef is_trading_day(date_str: str) -> bool:\n    \"\"\"\n    交易日判断：优先用腾讯行情 API，API 异常时降级为工作日（周一~五）判断。\n    \"\"\"\n    try:\n        date_obj = datetime.strptime(date_str, \"%Y-%m-%d\")\n        weekday_fallback = date_obj.weekday() < 5\n    except Exception:\n        weekday_fallback = False","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1777167066354}}
