\\nfrom pathlib import Path\\nfrom typing import Any\\n\\nfrom risk_intervention_log import ensure_log_header, write_intervention_audit_report\\nfrom runtime_state_schema import TRADING_STATUS_PRIORITY, get_runtime_truth, trading_status_to_cn\\n\\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\\nREPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n\\nTRACKED_ACCOUNT_PROFILES = [\\n    \\\"defensive\\\",\\n    \\\"balanced\\\",\\n    \\\"aggressive\\\",\\n    \\\"exit_dual\\\",\\n    \\\"exit_tight\\\",\\n    \\\"alpha55\\\",\\n]\\nRECONCILIATION_PROFILE_SLUGS = [\\\"defensive\\\", \\\"balanced\\\", \\\"aggressive\\\"]\\n\\n\\ndef resolve_primary_trading_status(*truths: dict[str, Any]) -> dict[str, Any]:\\n    selected_status = \\\"TRADING_ALLOWED\\\"\\n    selected_reason = \\\"\\\"\\n    selected_source = \\\"\\\"\\n    for truth in truths:\\n        if not isinstance(truth, dict):\\n            continue\\n        status = str(truth.get(\\\"trading_status\\\") or \\\"\\\").strip().upper()\\n        if not status:\\n            continue\\n        if TRADING_STATUS_PRIORITY.get(status, -1) >= TRADING_STATUS_PRIORITY.get(selected_status, -1):\\n            selected_status = status\\n            selected_reason = str(truth.get(\\\"trading_status_reason\\\") or truth.get(\\\"state_reason\\\") or \\\"\\\").strip()\\n            selected_source = str(truth.get(\\\"source\\\") or \\\"\\\").strip()\\n    return {\\n        \\\"status\\\": selected_status,\\n        \\\"label_cn\\\": trading_status_to_cn(selected_status),\\n        \\\"reason\\\": selected_reason,\\n        \\\"source\\\": selected_source,\\n    }\\n\\n\\ndef load_json(path: Path) -> dict[str, Any]:\\n    if not path.exists():\\n        return {}\\n    return json.loads(path.read_text(encoding=\\\"utf-8\\\"))\\n\\n\\ndef load_csv_tail(path: Path, limit: int = 5) -> list[dict[str, Any]]:\\n    if not path.exists():\\n        return []\\n\\n    with path.open(\\\"r\\\", encoding=\\\"utf-8-sig\\\", newline=\\\"\\\") as f:\\n        rows = list(csv.DictReader(f))\\n    return rows[-limit:]\\n\\n\\ndef load_csv_rows(path: Path) -> list[dict[str, Any]]:\\n    if not path.exists():\\n        return []\\n    with path.open(\\\"r\\\", encoding=\\\"utf-8-sig\\\", newline=\\\"\\\") as f:\\n        return list(csv.DictReader(f))\\n\\n\\ndef file_state(path: Path, stale_hours: int = 24) -> dict[str, Any]:\\n    if not path.exists():\\n        return {\\\"status\\\": \\\"RED\\\", \\\"path\\\": str(path), \\\"mtime\\\": \\\"\\\", \\\"reason\\\": \\\"missing\\\"}\\n    mtime = datetime.fromtimestamp(path.stat().st_mtime)\\n    age_hours = (datetime.now() - mtime).total_seconds() / 3600.0\\n    status = \\\"GREEN\\\" if age_hours <= stale_hours else \\\"YELLOW\\\"\\n    return {\\n        \\\"status\\\": status,\\n        \\\"path\\\": str(path),\\n        \\\"mtime\\\": mtime.strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n        \\\"reason\\\": f\\\"age_hours={age_hours:.1f}\\\",\\n    }\\n\\n\\ndef latest_report(pattern: str) -> Path | None:\\n    files = sorted(REPORT_DIR.glob(pattern))\\n    return files[-1] if files else None\\n\\n\\ndef extract_date_tag_from_name(path: Path | None) -> str:\\n    if path is None:\\n        return \\\"\\\"\\n    stem = path.stem\\n    for part in reversed(stem.split(\\\"_\\\")):\\n        if len(part) == 8 and part.isdigit():\\n            return part\\n    return \\\"\\\"\\n\\n\\ndef governance_gate_state() -> dict[str, Any]:\\n    path = REPORT_DIR / \\\"strategy_governance_gate_latest.json\\\"\\n    if not path.exists():\\n        return {\\n            \\\"status\\\": \\\"RED\\\",\\n            \\\"path\\\": str(path),\\n            \\\"mtime\\\": \\\"\\\",\\n            \\\"reason\\\": \\\"missing_governance_gate_report\\\",\\n            \\\"report_status\\\": \\\"MISSING\\\",\\n            \\\"blocking_issues\\\": [\\\"missing_governance_gate_report\\\"],\\n            \\\"registry_rows\\\": [],\\n        }\\n\\n    try:\\n        payload = json.loads(path.read_text(encoding=\\\"utf-8\\\"))\\n    except Exception:\\n        return {\\n            \\\"status\\\": \\\"RED\\\",\\n            \\\"path\\\": str(path),\\n            \\\"mtime\\\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n            \\\"reason\\\": \\\"invalid_governance_gate_report\\\",\\n            \\\"report_status\\\": \\\"INVALID\\\",\\n            \\\"blocking_issues\\\": [\\\"invalid_governance_gate_report\\\"],\\n            \\\"registry_rows\\\": [],\\n        }\\n\\n    mtime = datetime.fromtimestamp(path.stat().st_mtime)\\n    age_hours = (datetime.now() - mtime).total_seconds() / 3600.0\\n    report_status = str(payload.get(\\\"overall_status\\\") or \\\"UNKNOWN\\\").upper()\\n    blocking_issues = [str(x).strip() for x in (payload.get(\\\"blocking_issues\\\") or []) if str(x).strip()]\\n    stale = age_hours > 72\\n    if stale:\\n        blocking_issues.append(\\\"stale_governance_gate_report\\\")\\n    status = \\\"GREEN\\\" if report_status == \\\"PASS\\\" and not blocking_issues else \\\"RED\\\"\\n    if blocking_issues:\\n        reason = f\\\"blocking:{blocking_issues[0]}\\\"\\n    elif report_status == \\\"PASS\\\":\\n        reason = \\\"ok\\\"\\n    else:\\n        reason = f\\\"report_status={report_status.lower()}\\\"\\n    return {\\n        \\\"status\\\": status,\\n        \\\"path\\\": str(path),\\n        \\\"mtime\\\": mtime.strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n        \\\"reason\\\": reason,\\n        \\\"report_status\\\": report_status,\\n        \\\"blocking_issues\\\": blocking_issues,\\n        \\\"registry_rows\\\": payload.get(\\\"registry_rows\\\") or [],\\n        \\\"generated_at\\\": str(payload.get(\\\"generated_at\\\") or \\\"\\\"),\\n    }\\n\\n\\ndef live_chain_failure_state(expected_date_tag: str) -> dict[str, Any]:\\n    path = REPORT_DIR / \\\"live_chain_failure_summary_latest.json\\\"\\n    if not path.exists():\\n        return {\\n            \\\"status\\\": \\\"YELLOW\\\",\\n            \\\"path\\\": str(path),\\n            \\\"mtime\\\": \\\"\\\",\\n            \\\"reason\\\": \\\"missing_live_chain_failure_summary\\\",\\n        }\\n    try:\\n        payload = json.loads(path.read_text(encoding=\\\"utf-8\\\"))\\n    except Exception:\\n        return {\\n            \\\"status\\\": \\\"RED\\\",\\n            \\\"path\\\": str(path),\\n            \\\"mtime\\\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n            \\\"reason\\\": \\\"invalid_live_chain_failure_summary\\\",\\n        }\\n    summary_date = str(payload.get(\\\"date_tag\\\") or \\\"\\\")\\n    if summary_date and summary_date != expected_date_tag:\\n        return {\\n            \\\"status\\\": \\\"YELLOW\\\",\\n            \\\"path\\\": str(path),\\n            \\\"mtime\\\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n            \\\"reason\\\": f\\\"stale_live_chain_failure_summary:{summary_date}\\\",\\n        }\\n    return {\\n        \\\"status\\\": str(payload.get(\\\"overall_status\\\") or \\\"YELLOW\\\"),\\n        \\\"path\\\": str(path),\\n        \\\"mtime\\\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n        \\\"reason\\\": str(payload.get(\\\"reason\\\") or \\\"ok\\\"),\\n    }\\n\\n\\ndef manual_review_closure_alert_state(expected_date_tag: str) -> dict[str, Any]:\\n    path = REPORT_DIR / \\\"manual_review_closure_alert_latest.json\\\"\\n    if not path.exists():\\n        return {\\n            \\\"status\\\": \\\"YELLOW\\\",\\n            \\\"path\\\": str(path),\\n            \\\"mtime\\\": \\\"\\\",\\n            \\\"reason\\\": \\\"missing_manual_review_closure_alert\\\",\\n        }\\n    payload = load_json(path)\\n    report_date = str(payload.get(\\\"date_tag\\\") or \\\"\\\")\\n    if report_date and report_date != expected_date_tag:\\n        return {\\n            \\\"status\\\": \\\"YELLOW\\\",\\n            \\\"path\\\": str(path),\\n            \\\"mtime\\\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n            \\\"reason\\\": f\\\"stale_manual_review_closure_alert:{report_date}\\\",\\n        }\\n    return {\\n        \\\"status\\\": str(payload.get(\\\"overall_status\\\") or \\\"YELLOW\\\"),\\n        \\\"path\\\": str(path),\\n        \\\"mtime\\\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n        \\\"reason\\\": str(payload.get(\\\"reason\\\") or \\\"ok\\\"),\\n    }\\n\\n\\ndef _is_blank(value: Any) -> bool:\\n    text = str(value or \\\"\\\").strip()\\n    return text == \\\"\\\" or text.lower() == \\\"nan\\\"\\n\\n\\ndef manual_review_file_state(path: Path | None) -> dict[str, Any]:\\n    if path is None:\\n        return {\\n            \\\"status\\\": \\\"RED\\\",\\n            \\\"path\\\": \\\"\\\",\\n            \\\"mtime\\\": \\\"\\\",\\n            \\\"reason\\\": \\\"missing_reconciliation_file\\\",\\n            \\\"completed\\\": False,\\n            \\\"pending_items\\\": [\\\"missing_reconciliation_file\\\"],\\n            \\\"reviewer\\\": \\\"\\\",\\n        }\\n    if not path.exists():\\n        return {\\n            \\\"status\\\": \\\"RED\\\",\\n            \\\"path\\\": str(path),\\n            \\\"mtime\\\": \\\"\\\",\\n            \\\"reason\\\": \\\"missing_reconciliation_file\\\",\\n            \\\"completed\\\": False,\\n            \\\"pending_items\\\": [\\\"missing_reconciliation_file\\\"],\\n            \\\"reviewer\\\": \\\"\\\",\\n        }\\n\\n    rows = load_csv_rows(path)\\n    mtime = datetime.fromtimestamp(path.stat().st_mtime).strftime(\\\"%Y-%m-%d %H:%M:%S\\\")\\n    if not rows:\\n        return {\\n            \\\"status\\\": \\\"RED\\\",\\n            \\\"path\\\": str(path),\\n            \\\"mtime\\\": mtime,\\n            \\\"reason\\\": \\\"empty_reconciliation_file\\\",\\n            \\\"completed\\\": False,\\n            \\\"pending_items\\\": [\\\"empty_reconciliation_file\\\"],\\n            \\\"reviewer\\\": \\\"\\\",\\n        }\\n\\n    pending_items: list[str] = []\\n    reviewer = \\\"\\\"\\n    for row in rows:\\n        section = str(row.get(\\\"section\\\") or \\\"\\\").strip()\\n        item = str(row.get(\\\"item\\\") or \\\"\\\").strip()\\n        if section not in {\\\"人工复核\\\", \\\"结论\\\"}:\\n            continue\\n        status = str(row.get(\\\"status\\\") or \\\"\\\").strip().upper()\\n\"}}\n/Users/ling/.openclaw/memory/codex-bridge/raw_sessions/sessions/2026/03/25/rollout-2026-03-25T14-12-15-019d239f-4ab0-7882-9a44-b71e7b688a7c.jsonl:4287:{\"timestamp\":\"2026-03-25T16:12:29.559Z\",\"type\":\"response_item\",\"payload\":{\"type\":\"function_call_output\",\"call_id\":\"call_I3v0hXz5STSYCgtXz1cheJSw\",\"output\":\"Exit code: 0\\nWall time: 0.1 seconds\\nOutput:\\n#!/usr/bin/env python3\\nfrom __future__ import annotations\\n\\nimport csv\\nimport html\\nimport json\\nfrom datetime import datetime\\nfrom pathlib import Path\\nfrom typing import Any\\n\\nfrom risk_intervention_log import ensure_log_header, write_intervention_audit_report\\nfrom runtime_state_schema import TRADING_STATUS_PRIORITY, get_runtime_truth, trading_status_to_cn\\n\\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\\nREPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n\\nTRACKED_ACCOUNT_PROFILES = [\\n    \\\"defensive\\\",\\n    \\\"balanced\\\",\\n    \\\"aggressive\\\",\\n    \\\"exit_dual\\\",\\n    \\\"exit_tight\\\",\\n    \\\"alpha55\\\",\\n]\\nRECONCILIATION_PROFILE_SLUGS = [\\\"defensive\\\", \\\"balanced\\\", \\\"aggressive\\\"]\\n\\n\\ndef resolve_primary_trading_status(*truths: dict[str, Any]) -> dict[str, Any]:\\n    selected_status = \\\"TRADING_ALLOWED\\\"\\n    selected_reason = \\\"\\\"\\n    selected_source = \\\"\\\"\\n    for truth in truths:\\n        if not isinstance(truth, dict):\\n            continue\\n        status = str(truth.get(\\\"trading_status\\\") or \\\"\\\").strip().upper()\\n        if not status:\\n            continue\\n        if TRADING_STATUS_PRIORITY.get(status, -1) >= TRADING_STATUS_PRIORITY.get(selected_status, -1):\\n            selected_status = status\\n            selected_reason = str(truth.get(\\\"trading_status_reason\\\") or truth.get(\\\"state_reason\\\") or \\\"\\\").strip()\\n\"}}\n/Users/ling/.openclaw/memory/codex-bridge/raw_sessions/sessions/2026/03/25/rollout-2026-03-25T14-12-15-019d239f-4ab0-7882-9a44-b71e7b688a7c.jsonl:4687:{\"timestamp\":\"2026-03-25T17:02:33.660Z\",\"type\":\"compacted\",\"payload\":{\"message\":\"Another language model started to solve this problem and produced a summary of its thinking process. You also have access to the state of the tools that were used by that language model. Use this to build on the work that has already been done and avoid duplicating work. Here is the summary produced by the other language model, use the information in this summary to assist with your own analysis:\\n**Current Progress**\\n- Workspace/session bootstrap was already handled earlier: read `/Users/ling/.openclaw/workspace/SOUL.md`, `/Users/ling/.openclaw/workspace/USER.md`, `/Users/ling/.openclaw/workspace/memory/2026-03-26.md` not needed because same session carried over from 2026-03-25 flow, plus `/Users/ling/.openclaw/workspace/MEMORY.md`; `ACTIVE_TASK` is authoritative.\\n- User rule is explicit and persistent: for procedural/internal tasks, do not ask whether to continue. Keep executing until acceptance is met or there is a real blocker. User wants Chinese responses.\\n- `ACTIVE_TASK` now:\\n  - `Current`: `落实 P0-2：扩展 fallback/continue 静默失败审计并把新增阻断接回控制塔`\\n  - `Next`: `回归 live_chain_failure / control_tower / 日审计，产出 P0-2 扩围报告`\\n  - Use `python3 /Users/ling/.openclaw/workspace/scripts/active_task_cli.py ...` only for updates.\\n\\n**Already Completed This Session**\\n- `P1-1` closed:\\n  - Added machine-readable experiment registry:\\n    -