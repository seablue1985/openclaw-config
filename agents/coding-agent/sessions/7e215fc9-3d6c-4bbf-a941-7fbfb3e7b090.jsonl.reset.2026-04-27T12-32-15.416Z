ry_text\",\"text\":\"**Inspecting scripts for push disable**\\n\\nI need to look into the scripts: `cron_premarket_precheck_v2.sh` and `auto_run_premarket_precheck.py` to see if I should disable pushes on non-trading days. It sounds like an important step! I’ll probably need to search among these scripts and read their contents carefully to find the relevant parts. Making sure I handle this correctly is essential, so I'm eager to get this inspection done!\"}]}"},{"type":"toolCall","id":"call_nJk6NObdbmoNilgqHT1aSGrF|fc_0b2145179fde31c00169ed6c49350c819b806db2f5e9a6ad04","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/cron_premarket_precheck_v2.sh","limit":260},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/cron_premarket_precheck_v2.sh\",\"limit\":260}"},{"type":"toolCall","id":"call_MjMiR0fsDWIDpoIi9IOTy2p4|fc_0b2145179fde31c00169ed6c49351c819b9f581acdbd3b605e","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/auto_run_premarket_precheck.py","limit":400},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/auto_run_premarket_precheck.py\",\"limit\":400}"},{"type":"toolCall","id":"call_wCdOwvx78tptU7565nOaxbQL|fc_0b2145179fde31c00169ed6c493524819b95fceb4605790e7b","name":"exec","arguments":{"command":"find /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts -maxdepth 1 -type f -print0 | xargs -0 grep -nH -E 'Feishu|feishu|push|notify|message|non[-_ ]trading|trade day|is_trading|trading day|周日|weekday|weekend' 2>/dev/null | head -n 250","workdir":"/Users/ling/.openclaw/workspace/coding-agent","timeout":120,"yieldMs":1000},"partialJson":"{\"command\":\"find /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts -maxdepth 1 -type f -print0 | xargs -0 grep -nH -E 'Feishu|feishu|push|notify|message|non[-_ ]trading|trade day|is_trading|trading day|周日|weekday|weekend' 2>/dev/null | head -n 250\",\"workdir\":\"/Users/ling/.openclaw/workspace/coding-agent\",\"timeout\":120,\"yieldMs\":1000}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":90029,"output":302,"cacheRead":31744,"cacheWrite":0,"totalTokens":122075,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777167422224,"responseId":"resp_0b2145179fde31c00169ed6c406eb8819bb3870cca05d2503a"}}
{"type":"message","id":"b369d069","parentId":"ca35c5c0","timestamp":"2026-04-26T01:37:13.703Z","message":{"role":"toolResult","toolCallId":"call_nJk6NObdbmoNilgqHT1aSGrF|fc_0b2145179fde31c00169ed6c49350c819b806db2f5e9a6ad04","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env bash\nset -euo pipefail\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\ncd \"$ROOT\"\nPYRUN=\"$ROOT/scripts/cron_python.sh\"\n\"$PYRUN\" --runtime-only\n\nAVAILABLE_CASH=\"${1:-500000}\"\nACCOUNT_NAV=\"${2:-1200000}\"\n\nexec \"$PYRUN\" scripts/auto_run_premarket_precheck.py --available-cash \"$AVAILABLE_CASH\" --account-nav \"$ACCOUNT_NAV\"\n"}],"isError":false,"timestamp":1777167433695}}
{"type":"message","id":"70e5af28","parentId":"b369d069","timestamp":"2026-04-26T01:37:13.710Z","message":{"role":"toolResult","toolCallId":"call_MjMiR0fsDWIDpoIi9IOTy2p4|fc_0b2145179fde31c00169ed6c49351c819b9f581acdbd3b605e","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport re\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom runtime_state_schema import build_precheck_runtime_truth, get_runtime_truth\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\nWORKSPACE_ROOT = ROOT.parents[1] if len(ROOT.parents) >= 2 else ROOT\nSTATE_PATH = Path(\n    str(\n        os.environ.get(\"PREMARKET_PRECHECK_STATE_PATH\")\n        or (WORKSPACE_ROOT / \"memory\" / \"premarket_precheck_state.json\")\n    )\n)\n\n\ndef now_shanghai() -> datetime:\n    return datetime.now()\n\n\ndef load_state() -> dict:\n    if not STATE_PATH.exists():\n        return {}\n    try:\n        return json.loads(STATE_PATH.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef save_state(payload: dict) -> None:\n    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)\n    STATE_PATH.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef is_trading_day(date_str: str) -> bool:\n    \"\"\"\n    交易日判断：优先用腾讯行情 API，API 异常时降级为工作日（周一~五）判断。\n    \"\"\"\n    try:\n        date_obj = datetime.strptime(date_str, \"%Y-%m-%d\")\n        weekday_fallback = date_obj.weekday() < 5\n    except Exception:\n        weekday_fallback = False\n\n    if date_obj.weekday() >= 5:  # 周末直接返回 False\n        return False\n\n    try:\n        import urllib.request\n        req = urllib.request.Request(\n            \"https://qt.gtimg.cn/q=sh000001\",\n            headers={\"User-Agent\": \"Mozilla/5.0\"},\n        )\n        with urllib.request.urlopen(req, timeout=5) as resp:\n            content = resp.read().decode(\"gbk\", errors=\"replace\")\n        for line in content.split(\";\"):\n            if \"sh000001\" in line:\n                parts = line.split(\"~\")\n                if len(parts) > 30:\n                    mkt_str = parts[30].strip()[:8]\n                    market_date = f\"{mkt_str[:4]}-{mkt_str[4:6]}-{mkt_str[6:8]}\"\n                    return market_date == date_str\n                break\n        return weekday_fallback\n    except Exception:\n        return weekday_fallback\n\n\ndef in_window(hhmm: str, start: str, end: str) -> bool:\n    return start <= hhmm <= end\n\n\ndef _extract_yyyymmdd(name: str) -> str:\n    m = re.search(r\"(20\\d{6})\", name)\n    return m.group(1) if m else \"\"\n\n\ndef latest_by_patterns(\n    patterns: list[str],\n    *,\n    required_date_tag: str = \"\",\n    allow_stale: bool = True,\n) -> Path | None:\n    if required_date_tag:\n        for pat in patterns:\n            dated = sorted(\n                [p for p in REPORT_DIR.glob(pat) if _extract_yyyymmdd(p.name) == required_date_tag],\n                key=lambda p: p.stat().st_mtime,\n                reverse=True,\n            )\n            if dated:\n                return dated[0]\n        if not allow_stale:\n            return None\n\n    for pat in patterns:\n        files = sorted(REPORT_DIR.glob(pat), key=lambda p: p.stat().st_mtime, reverse=True)\n        if files:\n            return files[0]\n    return None\n\n\ndef build_empty_today_ticket(date_tag: str) -> tuple[Path, dict]:\n    \"\"\"构造当日空票据，避免因“无当日票据文件”导致流程中断。\"\"\"\n    fallback = latest_by_patterns(\n        [\n            \"stock_signal_tickets_live_*.csv\",\n            \"stock_signal_tickets_*.csv\",\n            \"live_stock_signal_*.csv\",\n            \"stock_orders_signal_*.csv\",\n            \"joinquant_order_tickets_*.csv\",\n        ],\n        allow_stale=True,\n    )\n\n    default_header = \"ticket_time,ts_code,side,source_time,source_qty,source_price,source_amount,reason,confirm_status,execute_status,notes\"\n    header = default_header\n    if fallback and fallback.exists():\n        try:\n            first_line = fallback.read_text(encoding=\"utf-8\").splitlines()[0].strip()\n            if first_line:\n                header = first_line\n        except Exception:\n            pass\n\n    out = REPORT_DIR / f\"joinquant_order_tickets_{date_tag}_autogen.csv\"\n    out.write_text(header + \"\\n\", encoding=\"utf-8\")\n    return out, {\n        \"autogen\": True,\n        \"autogen_reason\": \"no_today_tickets_use_empty_template\",\n        \"autogen_from\": str(fallback) if fallback else \"\",\n    }\n\n\ndef prepare_today_ticket(date_tag: str, available_cash: float, account_nav: float) -> tuple[Path | None, dict]:\n    cmd = [\n        \"python3\",\n        \"scripts/prepare_live_signal_tickets.py\",\n        \"--date\",\n        date_tag,\n        \"--available-cash\",\n        str(available_cash),\n        \"--account-nav\",\n        str(account_nav),\n    ]\n    proc = subprocess.run(cmd, cwd=str(ROOT), capture_output=True, text=True)\n\n    meta: dict = {\n        \"prepared\": proc.returncode == 0,\n        \"cmd\": \" \".join(cmd),\n        \"returncode\": proc.returncode,\n        \"stdout\": proc.stdout,\n        \"stderr\": proc.stderr,\n    }\n    stdout = (proc.stdout or \"\").strip()\n    if stdout:\n        try:\n            parsed = json.loads(stdout)\n            if isinstance(parsed, dict):\n                meta.update(parsed)\n        except Exception:\n            pass\n\n    ticket_file = str(meta.get(\"ticket_file\") or \"\").strip()\n    ticket_path = Path(ticket_file).resolve() if ticket_file else None\n    if ticket_path is not None and ticket_path.exists():\n        meta[\"autogen\"] = bool(meta.get(\"status\") == \"EMPTY\")\n        meta[\"autogen_reason\"] = str(meta.get(\"reason\") or \"\")\n        return ticket_path, meta\n    return None, meta\n\n\ndef run_precheck(available_cash: float, account_nav: float, tickets: Path, holdings: Path | None) -> dict:\n    cmd = [\n        \"python3\",\n        \"scripts/run_live_execution_v1.py\",\n        \"--trading-mode\",\n        \"live\",\n        \"--allow-advice-only\",\n        \"--config\",\n        \"config/live_stock_alpha_v3.json\",\n        \"--available-cash\",\n        str(available_cash),\n        \"--account-nav\",\n        str(account_nav),\n        \"--tickets\",\n        str(tickets),\n    ]\n    if holdings is not None:\n        cmd.extend([\"--holdings\", str(holdings)])\n\n    proc = subprocess.run(cmd, cwd=str(ROOT), capture_output=True, text=True)\n\n    parsed = {}\n    stdout = (proc.stdout or \"\").strip()\n    if stdout:\n        try:\n            parsed = json.loads(stdout)\n        except Exception:\n            parsed = {\"raw_stdout\": stdout}\n\n    return {\n        \"cmd\": \" \".join(cmd),\n        \"returncode\": proc.returncode,\n        \"stdout\": proc.stdout,\n        \"stderr\": proc.stderr,\n        \"parsed\": parsed,\n    }\n\n\ndef build_execution_truth(result: dict, ticket_meta: dict | None = None) -> dict:\n    raw_returncode = result.get(\"returncode\", 1)\n    if raw_returncode is None:\n        raw_returncode = 1\n    raw_returncode = int(raw_returncode)\n\n    parsed = result.get(\"parsed\")\n    if not isinstance(parsed, dict):\n        return build_precheck_runtime_truth(\n            mode=\"normal\" if raw_returncode == 0 else \"review_required\",\n            risk_off=False,\n            hard_stop=False,\n            halt_new_buy=False,\n            source=\"auto_run_premarket_precheck\",\n            precheck_passed=raw_returncode == 0,\n            pipeline_ok=raw_returncode == 0,\n        )\n\n    embedded_truth = get_runtime_truth(parsed)\n    if embedded_truth.get(\"trading_status\"):\n        if isinstance(ticket_meta, dict) and embedded_truth.get(\"state\") == \"no_signal\":\n            empty_signal_reason = str(ticket_meta.get(\"reason\") or ticket_meta.get(\"autogen_reason\") or \"\").strip()\n            if empty_signal_reason:\n                embedded_truth[\"trading_status_reason\"] = empty_signal_reason\n                embedded_truth[\"state_reason\"] = empty_signal_reason\n        return embedded_truth\n\n    precheck = parsed.get(\"precheck\") or {}\n    reasons = [str(x).strip() for x in (precheck.get(\"reasons\") or []) if str(x).strip()]\n    halt_reason = str(parsed.get(\"halt_reason\") or \"\").strip()\n    hard_stop = bool(parsed.get(\"hard_stop\"))\n    risk_off = bool(parsed.get(\"risk_off\"))\n    halt_new_buy = bool(parsed.get(\"halt_new_buy\"))\n    mode = str(parsed.get(\"mode\") or \"\").strip()\n    precheck_passed = bool(precheck.get(\"passed\"))\n\n    no_order_reasons = {\n        \"预处理后无有效信号（pending_after_gate=0）\",\n        \"净额合并后无有效订单（pending_netted=0）\",\n    }\n    only_no_order_reasons = bool(reasons) and all(reason in no_order_reasons for reason in reasons)\n\n    empty_signal_reason = \"\"\n    if only_no_order_reasons and isinstance(ticket_meta, dict):\n        empty_signal_reason = str(ticket_meta.get(\"reason\") or ticket_meta.get(\"autogen_reason\") or \"\").strip()\n\n    return build_precheck_runtime_truth(\n        mode=mode,\n        risk_off=risk_off,\n        hard_stop=hard_stop,\n        halt_new_buy=halt_new_buy,\n        halt_reason=halt_reason,\n        gate_reasons=parsed.get(\"gate_reasons\") or [],\n        precheck_passed=precheck_passed,\n        pipeline_ok=raw_returncode == 0,\n        precheck_reasons=reasons,\n        source=\"auto_run_premarket_precheck\",\n        empty_signal_reason=empty_signal_reason,\n    )\n\n\ndef classify_precheck_status(result: dict, ticket_meta: dict | None = None) -> tuple[str, str]:\n    truth = build_execution_truth(result, ticket_meta=ticket_meta)\n    return str(truth.get(\"trading_status\") or \"FULL_HALT\"), str(truth.get(\"trading_status_reason\") or \"\")\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"自动盘前强制检查执行器\")\n    parser.add_argument(\"--available-cash\", type=float, default=1000000)\n    parser.add_argument(\"--account-nav\", type=float, default=1000000)\n    parser.add_argument(\"--start\", default=\"09:20\")\n    parser.add_argument(\"--end\", default=\"09:40\")\n    parser.add_argument(\"--force\", action=\"store_true\")\n    parser.add_argument(\n        \"--emit-skip-json\",\n        action=\"store_true\",\n        help=\"输出 skip JSON（默认静默跳过，避免非交易日/窗口外任务被外层转成推送）\",\n    )\n    args = parser.parse_args()\n\n    now = now_shanghai()\n    date_str = now.strftime(\"%Y-%m-%d\")\n    hhmm = now.strftime(\"%H:%M\")\n\n    state = load_state()\n    if state.get(\"last_run_date\") == date_str and (not args.force):\n        if args.emit_skip_json:\n            print(json.dumps({\"status\": \"skip\", \"reason\": \"already_run_today\", \"date\": date_str}, ensure_ascii=False))\n        return\n\n    if (not args.force) and (not is_trading_day(date_str)):\n        if args.emit_skip_json:\n            print(json.dumps({\"status\": \"skip\", \"reason\": \"non_trading_day\", \"date\": date_str}, ensure_ascii=False))\n        return\n\n    if (not args.force) and (not in_window(hhmm, args.start, args.end)):\n        if args.emit_skip_json:\n            print(json.dumps({\"status\": \"skip\", \"reason\": \"outside_window\", \"now\": hhmm, \"window\": [args.start, args.end]}, ensure_ascii=False))\n        return\n\n    date_tag = now.strftime(\"%Y%m%d\")\n\n    tickets = latest_by_patterns(\n        [\n            \"stock_signal_tickets_live_*.csv\",\n            \"stock_signal_tickets_*.csv\",\n            \"live_stock_signal_*.csv\",\n            \"stock_orders_signal_*.csv\",\n            \"joinquant_order_tickets_*.csv\",\n        ],\n        required_date_tag=date_tag,\n        allow_stale=False,\n    )\n    ticket_meta: dict = {\"autogen\": False}\n\n    if tickets is None:\n        tickets, ticket_meta = prepare_today_ticket(date_tag, args.available_cash, args.account_nav)\n    if tickets is None:\n        tickets, ticket_meta = build_empty_today_ticket(date_tag)\n\n    holdings = latest_by_patterns(\n        [\n            \"broker_api_holdings_*.csv\",\n            \"ths_selected_holdings_*.csv\",\n            \"account_holdings_selected_*.csv\",\n        ],\n        required_date_tag=date_tag,\n        allow_stale=True,\n    )\n\n    result = run_precheck(\n        available_cash=args.available_cash,\n        account_nav=args.account_nav,\n        tickets=tickets,\n        holdings=holdings,\n    )\n    execution_truth = build_execution_truth(result, ticket_meta=ticket_meta)\n    status, status_reason = classify_precheck_status(result, ticket_meta=ticket_meta)\n    parsed = result.get(\"parsed\") if isinstance(result.get(\"parsed\"), dict) else {}\n    parsed_precheck = parsed.get(\"precheck\") if isinstance(parsed.get(\"precheck\"), dict) else {}\n\n    out_file = REPORT_DIR / f\"auto_premarket_precheck_{now.strftime('%Y%m%d')}.json\"\n    out_payload = {\n        \"status\": status,\n        \"status_reason\": status_reason,\n        \"date\": date_str,\n        \"time\": hhmm,\n        \"tickets\": str(tickets),\n        \"ticket_meta\": ticket_meta,\n        \"holdings\": str(holdings) if holdings else \"\",\n        \"passed\": parsed_precheck.get(\"passed\"),\n        \"strict_precheck\": parsed.get(\"strict_precheck\"),\n        \"hard_stop\": parsed.get(\"hard_stop\"),\n        \"halt_reason\": parsed.get(\"halt_reason\"),\n        \"execution_truth\": execution_truth,\n        \"result\": result,\n        \"report_file\": str(out_file),\n    }\n    out_file.write_text(json.dumps(out_payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n    save_state({\"last_run_date\": date_str, \"last_status\": out_payload})\n    print(json.dumps(out_payload, ensure_ascii=False, indent=2))\n\n    if not (result[\"returncode\"] != 0 and status == \"FULL_HALT\"):\n        return\n\n    raise SystemExit(result[\"returncode\"])\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1777167433703}}
