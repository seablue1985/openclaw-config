, dict):\\n---\\n\\n===== scripts/run_docx14_sentiment_factor_panel.py snippet =====\\n  83: \\n  84: def get_pro() -> Any:\\n  85:     return ts.pro_api()\\n  86: \\n  87: \\n  88: def fetch_margin_balance(start_date: int, end_date: int) -> pd.DataFrame:\\n  89:     cache_path = CACHE_DIR / f\\\"docx14_margin_{start_date}_{end_date}.csv\\\"\\n  90:     if cache_path.exists():\\n  91:         frame = pd.read_csv(cache_path)\\n  92:     else:\\n  93:         pro = get_pro()\\n  94:         frame = pro.margin(start_date=str(start_date), end_date=str(end_date))\\n  95:         cache_path.parent.mkdir(parents=True, exist_ok=True)\\n  96:         frame.to_csv(cache_path, index=False, encoding=\\\"utf-8-sig\\\")\\n  97:         time.sleep(0.2)\\n  98:     if frame.empty:\\n  99:         return pd.DataFrame(columns=[\\\"trade_date\\\", \\\"margin_balance\\\"])\\n 100:     frame[\\\"trade_date\\\"] = pd.to_numeric(frame[\\\"trade_date\\\"], errors=\\\"coerce\\\").fillna(0).astype(int)\\n 101:     frame[\\\"rzrqye\\\"] = pd.to_numeric(frame.get(\\\"rzrqye\\\"), errors=\\\"coerce\\\")\\n 102:     daily = frame.groupby(\\\"trade_date\\\", as_index=False)[\\\"rzrqye\\\"].sum().rename(columns={\\\"rzrqye\\\": \\\"margin_balance\\\"})\\n 103:     return daily\\n 104: \\n 105: \\n 106: def fetch_gov_10y_yield(start_date: int, end_date: int) -> pd.DataFrame:\\n 107:     cache_path = CACHE_DIR / f\\\"docx14_yc_cb_10y_{start_date}_{end_date}.csv\\\"\\n 108:     if cache_path.exists():\\n 109:         frame = pd.read_csv(cache_path)\\n---\\n 178: \\n 179: \\n 180: def build_panel(start_date: int, end_date: int) -> pd.DataFrame:\\n 181:     basic = pd.read_csv(BASIC_CSV, usecols=[\\\"ts_code\\\", \\\"trade_date\\\", \\\"turnover_rate\\\", \\\"total_mv\\\", \\\"pe\\\"])\\n 182:     basic[\\\"trade_date\\\"] = pd.to_numeric(basic[\\\"trade_date\\\"], errors=\\\"coerce\\\").fillna(0).astype(int)\\n 183:     basic = basic[(basic[\\\"trade_date\\\"] >= start_date) & (basic[\\\"trade_date\\\"] <= end_date)].copy()\\n 184:     equity_universe = set(basic[\\\"ts_code\\\"].dropna().astype(str).unique().tolist())\\n 185: \\n 186:     price = pd.read_csv(PRICE_CSV, usecols=[\\\"ts_code\\\", \\\"trade_date\\\", \\\"close\\\", \\\"vol\\\"])\\n 187:     price[\\\"trade_date\\\"] = pd.to_numeric(price[\\\"trade_date\\\"], errors=\\\"coerce\\\").fillna(0).astype(int)\\n 188:     price = price[(price[\\\"trade_date\\\"] >= start_date) & (price[\\\"trade_date\\\"] <= end_date)].copy()\\n 189:     price[\\\"ts_code\\\"] = price[\\\"ts_code\\\"].astype(str)\\n 190: \\n 191:     equity_price = price[price[\\\"ts_code\\\"].isin(equity_universe)].copy()\\n 192:     equity_price = equity_price.sort_values([\\\"ts_code\\\", \\\"trade_date\\\"]).reset_index(drop=True)\\n 193:     equity_price[\\\"prev_close\\\"] = equity_price.groupby(\\\"ts_code\\\")[\\\"close\\\"].shift(1)\\n 194:     equity_price[\\\"pct_change\\\"] = equity_price[\\\"close\\\"] / equity_price[\\\"prev_close\\\"].replace(0, pd.NA) - 1.0\\n 195:     equity_price[\\\"limit_up_flag_proxy\\\"] = equity_price[\\\"pct_change\\\"] >= 0.095\\n 196: \\n 197:     volume_daily = (\\n 198:         equity_price.groupby(\\\"trade_date\\\", as_index=False)[\\\"vol\\\"].sum().rename(columns={\\\"vol\\\": \\\"ashare_trading_volume\\\"})\\n 199:     )\\n 200:     limit_up_daily = (\\n 201:         equity_price.groupby(\\\"trade_date\\\", as_index=False)[\\\"limit_up_flag_proxy\\\"].sum().rename(columns={\\\"limit_up_flag_proxy\\\": \\\"limit_up_stock_count\\\"})\\n 202:     )\\n 203:     turnover_daily = (\\n 204:         basic.groupby(\\\"trade_date\\\", as_index=False)[\\\"turnover_rate\\\"].mean().rename(columns={\\\"turnover_rate\\\": \\\"ashare_turnover_rate\\\"})\\n---\\n   9: from typing import Any\\n  10: \\n  11: import pandas as pd\\n  12: import tushare as ts\\n  13: \\n  14: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  15: WORKSPACE = PROJECT_ROOT.parent.parent\\n  16: REPORT_DIR = WORKSPACE / \\\"