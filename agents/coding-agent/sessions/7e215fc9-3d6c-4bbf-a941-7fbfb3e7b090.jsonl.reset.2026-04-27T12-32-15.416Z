x.set_names(target_index.names)\\n  99:     return stacked.reindex(target_index)\\n 100: \\n 101: \\n 102: def load_price_panel(price_csv: Path, instruments: set[str], start_date: str) -> pd.DataFrame:\\n 103:     frame = pd.read_csv(price_csv, usecols=[\\\"ts_code\\\", \\\"trade_date\\\", \\\"open\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\", \\\"vol\\\", \\\"amount\\\"])\\n 104:     frame[\\\"trade_date\\\"] = pd.to_numeric(frame[\\\"trade_date\\\"], errors=\\\"coerce\\\").fillna(0).astype(int)\\n 105:     min_date = int(pd.Timestamp(start_date).strftime(\\\"%Y%m%d\\\")) - 20000\\n 106:     frame = frame[frame[\\\"trade_date\\\"] >= min_date].copy()\\n 107:     frame[\\\"instrument\\\"] = frame[\\\"ts_code\\\"].astype(str).map(ts_to_instrument)\\n 108:     frame = frame[frame[\\\"instrument\\\"].isin(instruments)].copy()\\n 109:     frame[\\\"date\\\"] = pd.to_datetime(frame[\\\"trade_date\\\"].astype(str), format=\\\"%Y%m%d\\\", errors=\\\"coerce\\\")\\n 110:     frame = frame.dropna(subset=[\\\"date\\\"]).copy()\\n 111:     for column in [\\\"open\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\", \\\"vol\\\", \\\"amount\\\"]:\\n 112:         frame[column] = pd.to_numeric(frame[column], errors=\\\"coerce\\\")\\n 113:     frame[\\\"amount\\\"] = frame[\\\"amount\\\"].fillna(0.0) * 1000.0\\n 114:     frame[\\\"vol\\\"] = frame[\\\"vol\\\"].fillna(0.0)\\n 115:     return frame.sort_values([\\\"date\\\", \\\"instrument\\\"])\\n 116: \\n 117: \\n 118: def build_price_feature_panels(price_panel: pd.DataFrame) -> tuple[pd.Index, dict[str, pd.DataFrame], dict[str, Any]]:\\n 119:     pivot_args = dict(index=\\\"date\\\", columns=\\\"instrument\\\")\\n 120:     close = price_panel.pivot(**pivot_args, values=\\\"close\\\").sort_index()\\n 121:     open_ = price_panel.pivot(**pivot_args, values=\\\"open\\\").sort_index().reindex(index=close.index, columns=close.columns)\\n---\\n   7: from typing import Any\\n   8: \\n   9: import numpy as np\\n  10: import pandas as pd\\n  11: