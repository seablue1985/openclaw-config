a(subset=[\\\"open\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\", \\\"vol\\\", \\\"amount\\\"]).copy()\\n  81: \\n  82:     frame = frame.sort_values([\\\"ts_code\\\", \\\"date\\\"]).drop_duplicates(subset=[\\\"ts_code\\\", \\\"date\\\"], keep=\\\"last\\\")\\n  83: \\n  84:     frame[\\\"symbol\\\"] = frame[\\\"ts_code\\\"].map(to_qlib_symbol)\\n---\\n   9: from typing import Any\\n  10: \\n  11: import numpy as np\\n  12: import pandas as pd\\n  13: \\n  14: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  15: WORKSPACE_ROOT = PROJECT_ROOT.parents[1]\\n  16: QLIB_REPO = WORKSPACE_ROOT / \\\"quant_projects\\\" / \\\"qlib\\\"\\n  17: A_STOCK_HISTORY = WORKSPACE_ROOT / \\\"data\\\" / \\\"a_stock_history.csv\\\"\\n  18: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  19: QLIB_LONG_ROOT = Path.home() / \\\".qlib\\\" / \\\"qlib_data\\\" / \\\"cn_data_long_2015_2026_180\\\"\\n  20: \\n  21: sys.path.append(str(PROJECT_ROOT / \\\"scripts\\\"))\\n  22: import run_strategy_695_batch as batch  # noqa: E402\\n  23: \\n  24: \\n  25: def to_qlib_symbol(ts_code: str) -> str:\\n  26:     code, exch = ts_code.split(\\\".\\\")\\n  27:     return f\\\"{exch.upper()}{code}\\\"\\n  28: \\n  29: \\n  30: def calc_metrics(daily_ret: pd.Series) -> dict[str, float]:\\n  31:     series = daily_ret.fillna(0.0).astype(float)\\n  32:     if series.empty:\\n  33:         return {\\n  34:             \\\"annual_return_pct\\\": 0.0,\\n  35:             \\\"annual_vol_pct\\\": 0.0,\\n---\\n\\n===== scripts/generate_control_tower_daily.py snippet =====\\n 194: \\n 195: \\n 196: def resolve_expected_trade_date(report_date_tag: str) -> dict[str, str]:\\n 197:     normalized = str(report_date_tag or \\\"\\\").strip()\\n 198:     candidates: list[tuple[str, str]] = []\\n 199: \\n 200:     if MARKET_PRICE_HISTORY.exists():\\n 201:         try:\\n 202:             frame = pd.read_csv(MARKET_PRICE_HISTORY, usecols=[\\\"trade_date\\\"])\\n 203:             trade_dates = pd.to_numeric(frame[\\\"trade_date\\\"], errors=\\\"coerce\\\").dropna()\\n 204:             if not trade_dates.empty:\\n 205:                 latest_market_trade_date = str(int(trade_dates.max()))\\n 206:                 if latest_market_trade_date <= normalized:\\n 207:                     candidates.append((\\\"market_price_history\\\", latest_market_trade_date))\\n 208:         except Exception:\\n 209:             pass\\n 210: \\n 211:     today_report = load_json(REPORT_DIR / \\\"today_stock_strategy_report_latest.json\\\")\\n 212:     today_report_date_tag = str(today_report.get(\\\"date_tag\\\") or \\\"\\\").strip()\\n 213:     if len(today_report_date_tag) == 8 and today_report_date_tag.isdigit() and today_report_date_tag <= normalized:\\n 214:         candidates.append((\\\"today_stock_strategy_report\\\", today_report_date_tag))\\n 215: \\n 216:     latest_live_review_tag = extract_date_tag_from_name(latest_report(\\\"live_close_review_v2_*.json\\\"))\\n 217:     if len(latest_live_review_tag) == 8 and latest_live_review_tag.isdigit() and latest_live_review_tag <= normalized:\\n 218:         candidates.append((\\\"live_close_review\\\", latest_live_review_tag))\\n 219: \\n 220:     for profile_slug in TRACKED_ACCOUNT_PROFILES:\\n---\\n  10: \\n  11: import incident_registry as incident_registry_mod\\n  12: import pandas as pd\\n  13: from risk_intervention_log import ensure_log_header, write_intervention_audit_report\\n  14: from runtime_state_schema import TRADING_STATUS_PRIORITY, get_runtime_truth, trading_status_to_cn\\n  15: \\n  16: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  17: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  18: MARKET_PRICE_HISTORY = PROJECT_ROOT.parents[1] / \\\"data\\\" / \\\"a_stock_history.csv\\\"\\n  19: \\n  20: TRACKED_ACCOUNT_PROFILES = [\\n  21:     \\\"defensive\\\",\\n  22:     \\\"balanced\\\",\\n  23:     \\\"aggressive\\\",\\n  24:     \\\"exit_dual\\\",\\n  25:     \\\"exit_tight\\\",\\n  26:    