\\"utf-8\\\") as file:\\n  14:         return yaml.safe_load(file)\\n  15: \\n  16: \\n  17: def pick_liquid_symbols(frame: pd.DataFrame, max_symbols: int) -> list[str]:\\n  18:     if max_symbols <= 0:\\n  19:         return sorted(frame[\\\"ts_code\\\"].unique().tolist())\\n  20: \\n  21:     latest_dates = sorted(frame[\\\"date\\\"].dropna().unique())\\n  22:     if not latest_dates:\\n  23:         return []\\n  24: \\n  25:     cutoff = latest_dates[max(0, len(latest_dates) - 60)]\\n  26:     recent = frame[frame[\\\"date\\\"] >= cutoff]\\n  27:     ranked = (\\n  28:         recent.groupby(\\\"ts_code\\\", as_index=False)[\\\"amount\\\"]\\n  29:         .mean()\\n  30:         .sort_values(\\\"amount\\\", ascending=False)\\n  31:         .head(max_symbols)\\n  32:     )\\n  33:     return sorted(ranked[\\\"ts_code\\\"].tolist())\\n  34: \\n  35: \\n  36: def build_matrices(frame: pd.DataFrame) -> tuple[pd.DataFrame, pd.DataFrame]:\\n  37:     close = frame.pivot(index=\\\"date\\\", columns=\\\"ts_code\\\", values=\\\"close\\\").sort_index()\\n  38:     amount = frame.pivot(index=\\\"date\\\", columns=\\\"ts_code\\\", values=\\\"amount\\\").sort_index()\\n  39:     return close, amount\\n  40: \\n  41: \\n  42: def get_rebalance_dates(index: pd.DatetimeIndex, frequency: str) -> pd.DatetimeIndex:\\n  43:     if frequency == \\\"weekly\\\":\\n  44:         weeks = index.to_series().dt.strftime(\\\"%Y-%W\\\")\\n  45:         return index[weeks.ne(weeks.shift(1)).values]\\n  46:     if frequency == \\\"monthly\\\":\\n  47:         months = index.to_series().dt.strftime(\\\"%Y-%m\\\")\\n  48:         return index[months.ne(months.shift(1)).values]\\n  49:     return index\\n  50: \\n  51: \\n  52: def simulate(close: pd.DataFrame, amount: pd.DataFrame, cfg: dict) -> tuple[dict, pd.DataFrame, pd.DataFrame]:\\n  53:     rebalance_cfg = cfg.get(\\\"rebalance\\\", {})\\n  54:     risk_cfg = cfg.get(\\\"risk\\\", {})\\n  55:     cost_cfg = cfg.get(\\\"cost\\\", {})\\n  56:     universe_cfg = cfg.get(\\\"universe\\\", {})\\n  57: \\n  58:     frequency = rebalance_cfg.get(\\\"frequency\\\", \\\"weekly\\\")\\n  59:     top_n = int(rebalance_cfg.get(\\\"top_n\\\", 30))\\n  60: \\n  61:     max_single_position = float(risk_cfg.get(\\\"max_single_position\\\", 0.10))\\n  62:     max_drawdown = float(risk_cfg.get(\\\"max_portfolio_drawdown\\\", 0.10))\\n  63:     stop_new_positions_dd = float(risk_cfg.get(\\\"stop_new_positions_if_drawdown_exceed\\\", 0.08))\\n  64:     daily_turnover_limit = float(risk_cfg.get(\\\"daily_turnover_limit\\\", 0.25))\\n  65:     max_gross_exposure = float(risk_cfg.get(\\\"max_gross_exposure\\\", 1.0))\\n  66: \\n  67:     min_turnover_20d = float(universe_cfg.get(\\\"min_turnover_20d\\\", 30_000_000))\\n  68: \\n  69:     commission = float(cost_cfg.get(\\\"commission_bps\\\", 3)) / 10000.0\\n  70:     slippage = float(cost_cfg.get(\\\"slippage_bps\\\", 8)) / 10000.0\\n\\n===== scripts/run_live_execution_v1.py top =====\\n   1: from __future__ import annotations\\n   2: \\n   3: import argparse\\n   4: import csv\\n   5: import json\\n   6: import os\\n   7: import re\\n   8: import shutil\\n   9: import sys\\n  10: from dataclasses import dataclass\\n  11: from datetime import datetime, timedelta\\n  12: from pathlib import Path\\n  13: from typing import Any\\n  14: \\n  15: import pandas as pd\\n  16: \\n  17: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  18: if str(PROJECT_ROOT) not in sys.path:\\n  19:     sys.path.insert(0, str(PROJECT_ROOT))\\n  20: \\n  21: from risk.risk_engine import RiskConfig, RiskContext, RiskEngine\\n  22: from stock_analysis_decision_bridge import DEFAULT_DSA_ROOT, dsa_runtime_context\\n  23: from runtime_state_schema import build_precheck_runtime_truth\\n  24: \\n  25: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  26: CONFIG_PATH = PROJECT_ROOT / \\\"config\\\" / \\\"live_trading_v1.json\\\"\\n  27: WORKSPACE_ROOT = PROJECT_ROOT.parents[1] if le