BJ{s}\\\"\\n  35:         return f\\\"SZ{s}\\\"\\n  36:     return s\\n  37: \\n  38: \\n  39: def load_history(src: Path) -> pd.DataFrame:\\n  40:     use_cols = [\\\"ts_code\\\", \\\"trade_date\\\", \\\"open\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\"]\\n  41:     df = pd.read_csv(src, usecols=use_cols)\\n  42:     trade_date_str = df[\\\"trade_date\\\"].astype(str).str.replace(r\\\"\\\\.0$\\\", \\\"\\\", regex=True)\\n  43:     df[\\\"trade_date\\\"] = pd.to_datetime(trade_date_str, format=\\\"%Y%m%d\\\", errors=\\\"coerce\\\")\\n  44:     for c in [\\\"open\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\"]:\\n  45:         df[c] = pd.to_numeric(df[c], errors=\\\"coerce\\\")\\n  46:     df = df.dropna(subset=[\\\"trade_date\\\", \\\"ts_code\\\", \\\"open\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\"]).copy()\\n  47:     df = df.sort_values([\\\"ts_code\\\", \\\"trade_date\\\"]).reset_index(drop=True)\\n  48:     return df\\n  49: \\n  50: \\n  51: def compute_factor(df: pd.DataFrame, factor_name: str) -> pd.DataFrame:\\n  52:     g = df.groupby(\\\"ts_code\\\", sort=False)\\n  53:     out = df[[\\\"trade_date\\\", \\\"ts_code\\\"]].copy()\\n  54: \\n  55:     if factor_name in {\\\"alpha053\\\", \\\"alpha053_5\\\", \\\"alpha053_15\\\"}:\\n  56:         n = {\\\"alpha053\\\": 9, \\\"alpha053_5\\\": 5, \\\"alpha053_15\\\": 15}[factor_name]\\n  57:         den = (df[\\\"close\\\"] - df[\\\"low\\\"]).replace(0, np.nan)\\n  58:         ratio = (df[\\\"close\\\"] - df[\\\"low\\\"] - (df[\\\"high\\\"] - df[\\\"close\\\"])) / den\\n  59:         out[\\\"score\\\"] = -ratio.groupby(df[\\\"ts_code\\\"]).diff(n)\\n---\\n   9: import numpy as np\\n  10: import pandas as pd\\n  11: \\n  12: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  13: WORKSPACE_ROOT = PROJECT_ROOT.parents[1]\\n  14: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  15: \\n  16: RD_AGENT_JSON = WORKSPACE_ROOT / \\\"other_projects\\\" / \\\"RD-Agent\\\" / \\\"docs\\\" / \\\"_static\\\" / \\\"RD2bench.json\\\"\\n  17: A_STOCK_HISTORY = WORKSPACE_ROOT / \\\"data\\\" / \\\"a_stock_history.csv\\\"\\n  18: RD_FACTOR_OUT_DIR = WORKSPACE_ROOT / \\\"other_projects\\\" / \\\"RD-Agent\\\" / \\\"outputs\\\" / \\\"factors\\\"\\n  19: \\n  20: \\n  21: def normalize_symbol(ts_code: str) -> str:\\n  22:     s = str(ts_code).strip().upper()\\n  23:     if s.startswith((\\\"SH\\\", \\\"SZ\\\", \\\"BJ\\\", \\\"HK\\\")) and len(s) >= 8:\\n  24:         return s\\n  25:     if \\\".\\\" in s:\\n  26:         code, suffix = s.split(\\\".\\\", 1)\\n  27:         code = \\\"\\\".join(ch for ch in code if ch.isalnum())\\n  28:         suffix = \\\"\\\".join(ch for ch in suffix if ch.isalnum()).upper()\\n  29:         return f\\\"{suffix}{code}\\\"\\n  30:     if len(s) == 6 and s.isdigit():\\n  31:         if s.startswith((\\\"5\\\", \\\"6\\\", \\\"9\\\")):\\n  32:             return f\\\"SH{s}\\\"\\n  33:         if s.startswith((\\\"4\\\", \\\"8\\\")):\\n  34:             return f\\\"BJ{s}\\\"\\n  35:         return f\\\"SZ{s}\\\"\\n---\\n\\n===== scripts/extract_rd_agent_real_factors.py snippet =====\\n  65:     return df\\n  66: \\n  67: \\n  68: def compute_alpha053_15_from_history(src: Path) -> pd.DataFrame:\\n  69:     if not src.exists():\\n  70:         raise FileNotFoundError(f\\\"历史行情文件不存在: {src}\\\")\\n  71: \\n  72:     use_cols = [\\\"ts_code\\\", \\\"trade_date\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\"]\\n  73:     df = pd.read_csv(src, usecols=use_cols)\\n  74:     # trade_date 在本地数据里通常是 20260308 这种整数格式，需按 YYYYMMDD 解析\\n  75:     trade_date_str = df[\\\"trade_date\\\"].astype(str).str.replace(r\\\"\\\\.0$\\\", \\\"\\\", regex=True)\\n  76:     df[\\\"trade_date\\\"] = pd.to_datetime(trade_date_str, format=\\\"%Y%m%d\\\", errors=\\\"coerce\\\")\\n  77:     df[\\\"high\\\"] = pd.to_numeric(df[\\\"high\\\"], errors=\\\"coerce\\\")\\n  78:     df[\\\"low\\\"] = pd.to_numeric(df[\\\"low\\\"], errors=\\\"coerce\\\")\\n  79:     df[\\\"close\\\"] = pd.to_numeric(df[\\\"close\\\"], errors=\\\"coerce\\\")\\n  80:     df = df.dropna(subset=[\\\"trade_date\\\", \\\"ts_code\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\"]).copy()\\n  81: \\n  82:     df = df.sort_values([\\\"ts_code\\\", \\\"trade_date\\\"])\\n  83:     den = (df[\\\"close\\\"] - df[\\\"low\\\"]).replace(0, np.nan)\\n  84:     ratio = (df[\\\"close\\\"] - df[\\\"low\\\"] - (df[\\\"high\\\"] - df[\\\"close\\\"])) / den\\n  85:     df[\\\"score\\\"] = -ratio.groupby(df[\\\"ts_code\\\"]).diff(15)\\n  86: \\n  87:     out = df[[\\\"trade_date\\\", \\\"ts_code\\\", \\\"score\\\"]].dropna(subset=[\\\"score\\\"]).copy()\\n  88:     out[\\\"date\\\"] = out[\\\"trade_date\\\"].dt.strftime(\\\"%Y-%m-%d\\\")\\n  89:     out[\\\"instrument\\\"] = out[\\\"ts_code\\\"].map(normalize_symbol)\\n  90: \\n  91:     out = out[[\\\"date\\\", \\\"instrument\\\", \\\"score\\\"]].sort_values([\\\"date\\\", \\\"instrument\\\"]).reset_index(drop=True)\\n---\\n   8: import numpy as np\\n   9: import pandas as pd\\n  10: \\n  11: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  12: WORKSPACE_ROOT = PROJECT_ROOT.parents[1]\\n  13: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  14: \\n  15: RD_AGENT_JSON = WORKSPACE_ROOT / \\\"other_projects\\\" / \\\"RD-Agent\\\" / \\\"docs\\\" / \\\"_static\\\" / \\\"RD2bench.json\\\"\\n  16: A_STOCK_HISTORY = WORKSPACE_ROOT / \\\"data\\\" / \\\"a_stock_history.csv\\\"\\n  17: RD_FACTOR_OUT_DIR = WORKSPACE_ROOT / \\\"other_projects\\\" / \\\"RD-Agent\\\" / \\\"outputs\\\" / \\\"factors\\\"\\n  18: \\n  19: \\n  20: def normalize_symbol(ts_code: str) -> str:\\n  21:     s = str(ts_code).strip().upper()\\n  22:     if \\\".\\\" in s:\\n  23:         return s\\n  24:     if len(s) == 6 and s.isdigit():\\n  25:         if s.startswith((\\\"5\\\", \\\"6\\\", \\\"9\\\")):\\n  26:             return f\\\"{s}.SH\\\"\\n  27:         if s.startswith((\\\"4\\\", \\\"8\\\")):\\n  28:             return f\\\"{s}.BJ\\\"\\n  29:         return f\\\"{s}.SZ\\\"\\n  30:     return s\\n  31: \\n  32: \\n  33: def load_rd2bench(path: Path) -> dict[str, Any]:\\n  34:     if not path.exists():\\n---\\n\\n===== scripts/run_qlib_breadth_stock_pool_filter_sensitivity.py snippet =====\\n  95: \\n  96: def stack_align(frame: pd.DataFrame, target_index: pd.MultiIndex) -> pd.Series:\\n  97:     stacked = frame.stack(dropna=False)\\n  98:     stacked.index = stacked.index.set_names(target_index.names)\\n  99:     return stacked.reindex(target_index)\\n 100: \\n 101: \\n 102: def load_price_panel(price_csv: Path, instruments: set[str], start_date: str) -> pd.DataFrame:\\n 103:     frame = pd.read_csv(price_csv, usecols=[\\\"ts_code\\\", \\\"trade_date\\\", \\\"open\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\", \\\"vol\\\", \\\"amount\\\"])\\n 104:     frame[\\\"trade_date\\\"] = pd.to_numeric(frame[\\\"trade_date\\\"], errors=\\\"coerce\\\").fillna(0).astype(int)\\n 105:     min_date = int(pd.Timestamp(start_date).strftime(\\\"%Y%m%d\\\")) - 20000\\n 106:     frame = frame[frame[\\\"trade_date\\\"] >= min_date].copy()\\n 107:     frame[\\\"instrument\\\"] = frame[\\\"ts_code\\\"].astype(str).map(ts_to_instrument)\\n 108:     frame = frame[frame[\\\"instrument\\\"].isin(instruments)].copy()\\n 109:     frame[\\\"date\\\"] = pd.to_datetime(frame[\\\"trade_date\\\"].astype(str), format=\\\"%Y%m%d\\\", errors=\\\"coerce\\\")\\n 110:     frame = frame.dropna(subset=[\\\"date\\\"]).copy()\\n 111:     for column in [\\\"open\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\", \\\"vol\\\", \\\"amount\\\"]:\\n 112:         frame[column] = pd.to_numeric(frame[column], errors=\\\"coerce\\\")\\n 113:     frame[\\\"amount\\\"] = frame[\\\"amount\\\"].fillna(0.0) * 1000.0\\n 114:     frame[\\\"vol\\\"] = frame[\\\"vol\\\"].fillna(0.0)\\n 115:     return frame.sort_values([\\\"date\\\", \\\"instrument\\\"])\\n 116: \\n 117: \\n 118: def build_price_feature_panels(price_panel: pd.DataFrame) -> tuple[pd.Index, dict[str, pd.DataFrame], dict[str, Any]]:\\n 119:     pivot_args = dict(index=\\\"date\\\", columns=\\\"instrument\\\")\\n 120:     close = price_panel.pivot(**pivot_args, values=\\\"close\\\").sort_index()\\n 121:     open_ = price_panel.pivot(**pivot_args, values=\\\"open\\\").sort_index().reindex(index=close.index, columns=close.columns)\\n---\\n   7: from typing import Any\\n   8: \\n   9: import numpy as np\\n  10: import pandas as pd\\n  11: \\n  12: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  13: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  14: PRED_CACHE_DIR = REPORT_DIR / \\\"cache\\\"\\n  15: DEFAULT_PRICE_CSV = Path(\\\"/Users/ling/.openclaw/workspace/data/a_stock_history.csv\\\")\\n  16: DEFAULT_STOCK_BASIC_CSV = Path(\\\"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis/stock_basic_20260303.csv\\\")\\n  17: DEFAULT_DAILY_BASIC_CSV = Path(\\\"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis/data/daily_basic_all.csv\\\")\\n  18: \\n  19: import sys\\n  20: \\n  21: sys.path.append(str(PROJECT_ROOT / \\\"scripts\\\"))\\n  22: import run_qlib_breadth_sanity_check as sanity  # noqa: E402\\n  23: import run_qlib_breadth_robust_optimize as robust  # noqa: E402\\n  24: \\n  25: \\n  26: def ts_to_instrument(ts_code: str) -> str:\\n  27:     text = str(ts_code).upper().strip()\\n  28:     if \\\".\\\" not in text:\\n  29:         return text\\n  30:     code, exchange = text.split(\\\".\\\", 1)\\n  31:     return f\\\"{exchange}{code}\\\"\\n  32: \\n  33: \\n---\\n\\n===== scripts/run_strategy_695_batch.py snippet =====\\n 279:             \\\"min_exposure_scale\\\": 0.35,\\n 280:             \\\"max_exposure_scale\\\": 1.0,\\n 281:         },\\n 282:     }\\n 283:     return cfg\\n 284: \\n 285: \\n 286: def load_market_matrices(max_symbols: int = 180) -> tuple[pd.DataFrame, pd.DataFrame, int, str, str]:\\n 287:     frame = pd.read_csv(DATA_FILE, usecols=[\\\"ts_code\\\", \\\"trade_date\\\", \\\"close\\\", \\\"amo