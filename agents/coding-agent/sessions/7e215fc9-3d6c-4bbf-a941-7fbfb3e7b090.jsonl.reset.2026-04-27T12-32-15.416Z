    return False\\n  40:     symbol, market = code.split(\\\".\\\", 1)\\n  41:     if market == \\\"SH\\\":\\n  42:         return symbol.startswith((\\\"600\\\", \\\"601\\\", \\\"603\\\", \\\"605\\\", \\\"688\\\"))\\n  43:     if market == \\\"SZ\\\":\\n  44:         return symbol.startswith((\\\"000\\\", \\\"001\\\", \\\"002\\\", \\\"003\\\", \\\"300\\\", \\\"301\\\"))\\n  45:     return False\\n  46: \\n  47: \\n  48: def parse_float(value: Any, default: float = 0.0) -> float:\\n  49:     try:\\n  50:         return float(str(value).replace(\\\",\\\", \\\"\\\").strip())\\n  51:     except Exception:\\n  52:         return default\\n  53: \\n  54: \\n  55: def parse_optional_float(value: Any) -> f"},"isError":false,"timestamp":1777167387973}}
