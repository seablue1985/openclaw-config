lse)[\\\"amount\\\"]\\n  29:         .mean()\\n  30:         .sort_values(\\\"amount\\\", ascending=False)\\n  31:         .head(max_symbols)\\n  32:     )\\n  33:     return sorted(ranked[\\\"ts_code\\\"].tolist())\\n  34: \\n  35: \\n  36: def build_matrices(frame: pd.DataFrame) -> tuple[pd.DataFrame, pd.DataFrame]:\\n  37:     close = frame.pivot(index=\\\"date\\\", columns=\\\"ts_code\\\", values=\\\"close\\\").sort_index()\\n  38:     amount = frame.pivot(index=\\\"date\\\", columns=\\\"ts_code\\\", values=\\\"amount\\\").sort_index()\\n  39:     return close, amount\\n  40: \\n  41: \\n  42: def get_rebalance_dates(index: pd.DatetimeIndex, frequency: str) -> pd.DatetimeIndex:\\n  43:     if frequency == \\\"weekly\\\":\\n  44:         weeks = index.to_series().dt.strftime(\\\"%Y-%W\\\")\\n  45:         return index[weeks.ne(weeks.shift(1)).values]\\n  46:     if frequency == \\\"monthly\\\":\\n  47:         months = index.to_series().dt.strftime(\\\"%Y-%m\\\")\\n  48:         return index[months.ne(months.shift(1)).values]\\n  49:     return index\\n  50: \\n  51: \\n  52: def simulate(close: pd.DataFrame, amount: pd.DataFrame, cfg: dict) -> tuple[dict, pd.DataFrame, pd.DataFrame]:\\n  53:     rebalance_cfg = cfg.get(\\\"rebalance\\\", {})\\n  54:     risk_cfg = cfg.get(\\\"risk\\\", {})\\n  55:     cost_cfg = cfg.get(\\\"cost\\\", {})\\n  56:     universe_cfg = cfg.get(\\\"universe\\\", {})\\n  57: \\n  58:     frequency = rebalance_cfg.get(\\\"frequency\\\", \\\"weekly\\\")\\n  59:     top_n = int(rebalance_cfg.get(\\\"top_n\\\", 30))\\n  60: \\n  61:     max_single_position = float(risk_cfg.get(\\\"max_single_position\\\", 0.10))\\n  62:     max_drawdown = float(risk_cfg.get(\\\"max_portfolio_drawdown\\\", 0.10))\\n  63:     stop_new_positions_dd = float(risk_cfg.get(\\\"stop_new_positions_if_drawdown_exceed\\\", 0.08))\\n  64:     daily_turnover_limit = float(risk_cfg.get(\\\"daily_turnover_limit\\\", 0.25))\\n  65:     max_gross_exposure = float(risk_cfg.get(\\\"max_gross_exposure\\\", 1.0))\\n  66: \\n  67:     min_turnover_20d = float(universe_cfg.get(\\\"min_turnover_20d\\\", 30_000_000))\\n  68: \\n  69:     commission = float(cost_cfg.get(\\\"commission_bps\\\", 3)) / 10000.0\\n  70:     slippage = float(cost_cfg.get(\\\"slippage_bps\\\", 8)) / 10000.0\\n\\n===== scripts/run_live_execution_v1.py top =====\\n   1: from __future__ import annotations\\n   2: \\n   3: import argparse\\n   4: import csv\\n   5: import json\\n   6: import os\\n   7: import re\\n   8: import shutil\\n   9: import sys\\n  10: from dataclasses import dataclass\\n  11: from datetime import datetime, timedelta\\n  12: from pathlib import Path\\n  13: from typing import Any\\n  14: \\n  15: import pandas as pd\\n  16: \\n  17: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  18: if str(PROJECT_ROOT) not in sys.path:\\n  19:     sys.path.insert(0, str(PROJECT_ROOT))\\n  20: \\n  21: from risk.risk_engine import RiskConfig, RiskContext, RiskEngine\\n  22: from stock_analysis_decision_bridge import DEFAULT_DSA_ROOT, dsa_runtime_context\\n  23: from runtime_state_schema import build_precheck_runtime_truth\\n  24: \\n  25: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  26: CONFIG_PATH = PROJECT_ROOT / \\\"config\\\" / \\\"live_trading_v1.json\\\"\\n  27: WORKSPACE_ROOT = PROJECT_ROOT.parents[1] if len(PROJECT_ROOT.parents) >= 2 else PROJECT_ROOT\\n  28: DEFAULT_INDEX_DATA_ROOT = WORKSPACE_ROOT / \\\"quant_projects\\\" / \\\"daily_stock_analysis\\\"\\n  29: DEFAULT_A_STOCK_CSV = WORKSPACE_ROOT / \\\"data\\\" / \\\"a_stock_history.csv\\\"\\n  30: DEFAULT_DATA_MOUNT_ROOT = Path(\\\"/Volumes/A\\\")\\n  31: DEFAULT_LOCAL_FALLBACK_DIR = PROJECT_ROOT / \\\"data_snapshots\\\" / \\\"mount_fallback\\\"\\n  32: INDEX_FILENAME_MAP = {\\n  33:     \\\"HS300\\\": \\\"index_000300_SH.csv\\\",\\n  34:     \\\"ZZ2000\\\": \\\"index_000852_SH.csv\\\",\\n  35:     \\\"ZZ500\\\": \\\"index_000905_SH.csv\\\",\\n  36:     \\\"CYB\\\": \\\"index_399006_SZ.csv\\\",\\n  37: }\\n  38: LOCAL_INDEX_FILENAME_MAP = {\\n  39:     \\\"HS300\\\": \\\"index_sh000300.csv\\\",\\n  40:     \\\"ZZ2000\\\": \\\"index_sh000852.csv\\\",\\n  41:     \\\"ZZ500\\\": \\\"index_sh000905.csv\\\",\\n  42:     \\\"CYB\\\": \\\"index_sz399006.csv\\\",\\n  43: }\\n  44: \\n  45: # — Slippage buffer: 15 bp = 0.15% (文章「滑点真的会积累」: ETF换仓一年差了两三个点)\\n  46: SLIPPAGE_BP = 15  # basis points, applied as conservative bid-ask spread buffer on est_amount\\n  47: \\n  48: INDEX_DATA_ROOT = DEFAULT_INDEX_DATA_ROOT\\n  49: BENCH_CSV = INDEX_DATA_ROOT / INDEX_FILENAME_MAP[\\\"ZZ2000\\\"]\\n  50: A_STOCK_CSV = DEFAULT_A_STOCK_CSV\\n  51: INDEX_FILE_CANDIDATES: dict[str, list[Path]] = {\\n  52:     \\\"HS300\\\": [INDEX_DATA_ROOT / INDEX_FILENAME_MAP[\\\"HS300\\\"], PROJECT_ROOT / \\\"data\\\" / LOCAL_INDEX_FILENAME_MAP[\\\"HS300\\\"]],\\n  53:     \\\"ZZ2000\\\": [INDEX_DATA_ROOT / INDEX_FILENAME_MAP[\\\"ZZ2000\\\"], PROJECT_ROOT / \\\"data\\\" / LOCAL_INDEX_FILENAME_MAP[\\\"ZZ2000\\\"]],\\n  54:     \\\"ZZ500\\\": [INDEX_DATA_ROOT / INDEX_FILENAME_MAP[\\\"ZZ500\\\"], PROJECT_ROOT / \\\"data\\\" / LOCAL_INDEX_FILENAME_MAP[\\\"ZZ500\\\"]],\\n  55:     \\\"CYB\\\": [INDEX_DATA_ROOT / INDEX_FILENAME_MAP[\\\"CYB\\\"], PROJECT_ROOT / \\\"data\\\" / LOCAL_INDEX_FILENAME_MAP[\\\"CYB\\\"]],\\n  56: }\\n  57: \\n  58: \\n  59: @dataclass\\n  60: class DataPathState:\\n  61:     index_data_root: Path\\n  62:     a_stock_csv: Path\\n  63:     benchmark_csv: Path\\n  64:     index_file_candidates: dict[str, list[Path]]\\n  65:     mount_health: dict[str, Any]\\n  66:     warnings: list[str]\\n  67: \\n  68: \\n  69: def _resolve_path(value: Any, *, default: Path) -> Path:\\n  70:     text = str(value or \\\"\\\").strip()\\n\\n===== scripts/generate_control_tower_daily.py top =====\\n   1: #!/usr/bin/env python3\\n   2: from __future__ import annotations\\n   3: \\n   4: import csv\\n   5: import html\\n   6: import json\\n   7: from datetime import datetime\\n   8: from pathlib import Path\\n   9: from typing import Any\\n  10: \\n  11: import incident_registry as incident_registry_mod\\n  12: import pandas as pd\\n  13: from risk_intervention_log import ensure_log_header, write_intervention_audit_report\\n  14: from runtime_state_schema import TRADING_STATUS_PRIORITY, get_runtime_truth, trading_status_to_cn\\n  15: \\n  16: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  17: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  18: MARKET_PRICE_HISTORY = PROJECT_ROOT.parents[1] / \\\"data\\\" / \\\"a_stock_history.csv\\\"\\n  19: \\n  20: TRACKED_ACCOUNT_PROFILES = [\\n  21:     \\\"defensive\\\",\\n  22:     \\\"balanced\\\",\\n  23:     \\\"aggressive\\\",\\n  24:     \\\"exit_dual\\\",\\n  25:     \\\"exit_tight\\\",\\n  26:     \\\"alpha55\\\",\\n  27: ]\\n  28: RECONCILIATION_PROFILE_SLUGS = [\\\"defensive\\\", \\\"balanced\\\", \\\"aggressive\\\"]\\n  29: \\n  30: \\n  31: def resolve_primary_trading_status(*truths: dict[str, Any]) -> dict[str, Any]:\\n  32:     selected_status = \\\"TRADING_ALLOWED\\\"\\n  33:     selected_reason = \\\"\\\"\\n  34:     selected_source = \\\"\\\"\\n  35:     for truth in truths:\\n  36:         if not isinstance(truth, dict):\\n  37:             continue\\n  38:         status = str(truth.get(\\\"trading_status\\\") or \\\"\\\").strip().upper()\\n  39:         if not status:\\n  40:             continue\\n  41:         if TRADING_STATUS_PRIORITY.get(status, -1) >= TRADING_STATUS_PRIORITY.get(selected_status, -1):\\n  42:             selected_status = status\\n  43:             selected_reason = str(truth.get(\\\"trading_status_reason\\\") or truth.get(\\\"state_reason\\\") or \\\"\\\").strip()\\n  44:             selected_source = str(truth.get(\\\"source\\\") or \\\"\\\").strip()\\n  45:     return {\\n  46:         \\\"status\\\": selected_status,\\n  47:         \\\"label_cn\\\": trading_status_to_cn(selected_status),\\n  48:         \\\"reason\\\": selected_reason,\\n  49:         \\\"source\\\": selected_source,\\n  50:     }\\n  51: \\n  52: \\n  53: def load_json(path: Path) -> dict[str, Any]:\\n  54:     if not path.exists():\\n  55:         return {}\\n  56:     return json.loads(path.read_text(encoding=\\\"utf-8\\\"))\\n  57: \\n  58: \\n  59: def load_csv_tail(path: Path, limit: int = 5) -> list[dict[str, Any]]:\\n  60:     if not path.exists():\\n  61:         return []\\n  62: \\n  63:     with path.open(\\\"r\\\", encoding=\\\"utf-8-sig\\\", newline=\\\"\\\") as f:\\n  64:         rows = list(csv.DictReader(f))\\n  65:     return rows[-limit:]\\n  66: \\n  67: \\n  68: def load_csv_rows(path: Path) -> list[dict[str, Any]]:\\n  69:     if not path.exists():\\n  70:         return []\\n\\n===== scripts/run_strategy_695_batch.py top =====\\n   1: from __future__ import annotations\\n   2: \\n   3: import hashlib\\n   4: import json\\n   5: import re\\n   6: from collections import Counter\\n   7: from datetime import datetime\\n   8: from pathlib import Path\\n   9: from typing import Any\\n  10: \\n  11: import numpy as np\\n  12: import pandas as pd\\n  13: \\n  14: import sys\\n  15: \\n  16: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  17: WORKSPACE_ROOT = PROJECT_ROOT.parents[1]\\n  18: SOURCE_ROOT = WORKSPACE_ROOT / \\\"quant_strategies_raw\\\" / \\\"聚宽策略合集\\\"\\n  19: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  20: PROGRESS_FILE = REPORT_DIR / \\\"strategy_695_progress.md\\\"\\n  21: FINAL_REPORT_FILE = REPORT_DIR / \\\"strategy_695_final_report.md\\\"\\n  22: PARSED_FILE = REPORT_DIR / \\\"strategy_695_parsed.csv\\\"\\n  23: RESULTS_FILE = REPORT_DIR / \\\"strategy_695_backtest_results.csv\\\"\\n  24: TOP_FILE = REPORT_DIR / \\\"strategy_695_top_candidates.csv\\\"\\n  25: SUMMARY_JSON = REPORT_DIR / \\\"strategy_695_summary.json\\\"\\n  26: \\n  27: DATA_FILE = WORKSPACE_ROOT / \\\"data\\\" / \\\"a_stock_history.csv\\\"\\n  28: \\n  29: sys.path.append(str(PROJECT_ROOT / \\\"backtest\\\"))\\n  30: import run_cross_sectional_backtest as cross  # noqa: E402\\n  31: \\n  32: \\n  33: def now_text() -> str:\\n  34:     return datetime.now().strftime(\\\"%Y-%m-%d %H:%M:%S\\\")\\n  35: \\n  36: \\n  37: def log_progress(message: str) -> None:\\n  38:     REPORT_DIR.mkdir(parents=True, exist_ok=True)\\n  39:     with PROGRESS_FILE.open(\\\"a\\\", encoding=\\\"utf-8\\\") as f:\\n  40:         f.write(f\\\"\\\\n- [{now_text()}] {message}\\\\n\\\")\\n  41: \\n  42: \\n  43: def discover_source_files() -> list[Path]:\\n  44:     files = sorted(SOURCE_ROOT.glob(\\\"*-strategies/Strategies_*_Combined.txt\\\"))\\n  45:     if not files:\\n  46:         raise FileNotFoundError(f\\\"未找到策略合集文件: {SOURCE_ROOT}\\\")\\n  47:     return files\\n  48: \\n  49: \\n  50: def count_starts(path: Path) -> int:\\n  51:     text = path.read_text(encoding=\\\"utf-8\\\", errors=\\\"ignore\\\")\\n  52:     return len(re.findall(r\\\"^START OF FILE:\\\", text, flags=re.MULTILINE))\\n  53: \\n  54: \\n  55: def parse_strategy_blocks(source_files: list[Path]) -> pd.DataFrame:\\n  56:     rows: list[dict[str, Any]] = []\\n  57: \\n  58:     for source_file in source_files:\\n  59:         text = source_file.read_text(encoding=\\\"utf-8\\\", errors=\\\"ignore\\\")\\n  60:         year_match = re.search(r\\\"(20\\\\d{2})\\\", source_file.name)\\n  61:         year = int(year_match.group(1)) if year_match else 0\\n  62: \\n  63:         markers = list(re.finditer(r\\\"^START OF FILE:\\\\s*(.+?)\\\\s*$\\\", text, flags=re.MULTILINE))\\n  64:         for index, marker in enumerate(markers):\\n  65:             name_raw = marker.group(1).strip()\\n  66:             name = name_raw[:-4] if name_raw.lower().endswith(\\\".txt\\\") else name_raw\\n  67: \\n  68:             block_start = marker.end()\\n  69:             block_end = markers[index + 1].start() if index + 1 < len(markers) else len(text)\\n  70:             block_text = text[block_start:block_end].strip()\\n\\n===== scripts/run_qlib_long_compare.py top =====\\n   1: from __future__ import annotations\\n   2: \\n   3: import argparse\\n   4: import json\\n   5: import subprocess\\n   6: import sys\\n   7: from datetime import datetime\\n   8: from pathlib import Path\\n   9: from typing import Any\\n  10: \\n  11: import numpy as np\\n  12: import pandas as pd\\n  13: \\n  14: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  15: WORKSPACE_ROOT = PROJECT_ROOT.parents[1]\\n  16: QLIB_REPO = WORKSPACE_ROOT / \\\"quant_projects\\\" / \\\"qlib\\\"\\n  17: A_STOCK_HISTORY = WORKSPACE_ROOT / \\\"data\\\" / \\\"a_stock_history.csv\\\"\\n  18: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  19: QLIB_LONG_ROOT = Path.home() / \\\".qlib\\\" / \\\"qlib_data\\\" / \\\"cn_data_long_2015_2026_180\\\"\\n  20: \\n  21: sys.path.append(str(PROJECT_ROOT / \\\"scripts\\\"))\\n  22: import run_strategy_695_batch as batch  # noqa: E402\\n  23: \\n  24: \\n  25: def to_qlib_symbol(ts_code: str) -> str:\\n  26:     code, exch = ts_code.split(\\\".\\\")\\n  27:     return f\\\"{exch.upper()}{code}\\\"\\n  28: \\n  29: \\n  30: def calc_metrics(daily_ret: pd.Series) -> dict[str, float]:\\n  31:     series = daily_ret.fillna(0.0).astype(float)\\n  32:     if series.empty:\\n  33:         return {\\n  34:             \\\"annual_return_pct\\\": 0.0,\\n  35:             \\\"annual_vol_pct\\\": 0.0,\\n  36:             \\\"sharpe\\\": 0.0,\\n  37:             \\\"max_drawdown_pct\\\": 0.0,\\n  38:             \\\"final_equity\\\": 1.0,\\n  39:             \\\"trading_days\\\": 0,\\n  40:         }\\n  41: \\n  42:     equity = (1 + series).cumprod()\\n  43:     annual = float(equity.iloc[-1] ** (252 / len(series)) - 1)\\n  44:     annual_vol = float(series.std(ddof=0) * np.sqrt(252))\\n  45:     sharpe = annual / annual_vol if annual_vol > 0 else 0.0\\n  46:     peak = equity.cummax()\\n  47:     max_dd = float(((peak - equity) / peak).max())\\n  48:     return {\\n  49:         \\\"annual_return_pct\\\": round(annual * 100, 2),\\n  50:         \\\"annual_vol_pct\\\": round(annual_vol * 100, 2),\\n  51:         \\\"sharpe\\\": round(sharpe, 3),\\n  52:         \\\"max_drawdown_pct\\\": round(max_dd * 100, 2),\\n  53:         \\\"final_equity\\\": round(float(equity.iloc[-1]), 4),\\n  54:         \\\"trading_days\\\": int(len(series)),\\n  55:     }\\n  56: \\n  57: \\n  58: def prepare_csv_universe(csv_dir: Path, max_symbols: int) -> tuple[list[str], str, str]:\\n  59:     close, _, _, start_date, end_date = batch.load_market_matrices(max_symbols=max_symbols)\\n  60:     symbols = [str(x) for x in close.columns]\\n  61:     symbols_with_benchmark = sorted(set(symbols + [\\\"000300.SH\\\"]))\\n  62: \\n  63:     csv_dir.mkdir(parents=True, exist_ok=True)\\n  64: \\n  65:     usecols = [\\\"ts_code\\\", \\\"trade_date\\\", \\\"open\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\", \\\"vol\\\", \\\"amount\\\"]\\n  66:     frame = pd.read_csv(A_STOCK_HISTORY, usecols=usecols)\\n  67:     frame = frame[frame[\\\"ts_code\\\"].isin(symbols_with_benchmark)].copy()\\n  68: \\n  69:     benchmark_csv = WORKSPACE_ROOT / \\\"quant_projects\\\" / \\\"daily_stock_analysis\\\" / \\\"index_000300_SH.csv\\\"\\n  70:     if benchmark_csv.exists():\\n\\n===== risk/exit_engine.py top =====\\n   1: from __future__ import annotations\\n   2: \\n   3: import json\\n   4: import math\\n   5: import re\\n   6: from collections import deque\\n   7: from datetime import datetime\\n   8: from pathlib import Path\\n   9: from typing import Any\\n  10: \\n  11: import pandas as pd\\n  12: \\n  13: DEFAULT_PRICE_HISTORY_PATH = Path(\\\"/Users/ling/.openclaw/workspace/data/a_stock_history.csv\\\")\\n  14: \\n  15: BUY_SIDES = {\\\"BUY\\\", \\\"B\\\", \\\"LONG\\\", \\\"买\\\"}\\n  16: \\n  17: \\n  18: def normalize_ts_code(value: Any) -> str:\\n  19:     text = str(value or \\\"\\\").strip().upper()\\n  20:     if not text or text == \\\"NAN\\\":\\n  21:         return \\\"\\\"\\n  22:     if text.endswith(\\\".XSHG\\\"):\\n  23:         return f\\\"{text[:-5]}.SH\\\"\\n  24:     if text.endswith(\\\".XSHE\\\"):\\n  25:         return f\\\"{text[:-5]}.SZ\\\"\\n  26:     if text.endswith((\\\".SH\\\", \\\".SZ\\\", \\\".BJ\\\", \\\".HK\\\")):\\n  27:         return text\\n  28:     if text.isdigit() and len(text) == 6:\\n  29:         if text.startswith((\\\"600\\\", \\\"601\\\", \\\"603\\\", \\\"605\\\", \\\"688\\\")):\\n  30:             return f\\\"{text}.SH\\\"\\n  31:         if text.startswith((\\\"000\\\", \\\"001\\\", \\\"002\\\", \\\"003\\\", \\\"300\\\", \\\"301\\\")):\\n  32:             return f\\\"{text}.SZ\\\"\\n  33:     return text\\n  34: \\n  35: \\n  36: def is_a_share_stock(ts_code: str) -> bool:\\n  37:     code = normalize_ts_code(ts_code)\\n  38:     if \\\".\\\" not in code:\\n  39:         return False\\n  40:     symbol, market = code.split(\\\".\\\", 1)\\n  41:     if market == \\\"SH\\\":\\n  42:         return symbol.startswith((\\\"600\\\", \\\"601\\\", \\\"603\\\", \\\"605\\\", \\\"688\\\"))\\n  43:     if market == \\\"SZ\\\":\\n  44:         return symbol.startswith((\\\"000\\\", \\\"001\\\", \\\"002\\\", \\\"003\\\", \\\"300\\\", \\\"301\\\"))\\n  45:     return False\\n  46: \\n  47: \\n  48: def parse_float(value: Any, default: float = 0.0) -> float:\\n  49:     try:\\n  50:         return float(str(value).replace(\\\",\\\", \\\"\\\").strip())\\n  51:     except Exception:\\n  52:         return default\\n  53: \\n  54: \\n  55: def parse_optional_float(value: Any) -> float | None:\\n  56:     if value is None:\\n  57:         return None\\n  58:     text = str(value).replace(\\\",\\\", \\\"\\\").strip()\\n  59:     if not text or text.lower() == \\\"none\\\":\\n  60:         return None\\n  61:     try:\\n  62:         return float(text)\\n  63:     except Exception:\\n  64:         return None\\n  65: \\n  66: \\n  67: def parse_int(value: Any, default: int = 0) -> int:\\n  68:     try:\\n  69:         return int(float(str(value).replace(\\\",\\\", \\\"\\\").strip()))\\n  70:     except Exception:\"}],\"details\":{\"status\":\"completed\",\"exitCode\":0,\"durationMs\":66,\"aggregated\":\"===== backtest/run_cross_sectional_backtest.py top =====\\n   1: from __future__ import annotations\\n   2: \\n   3: import argparse\\n   4: import json\\n   5: from pathlib import Path\\n   6: \\n   7: import numpy as np\\n   8: import pandas as pd\\n   9: import yaml\\n  10: \\n  11: \\n  12: def load_config(path: Path) -> dict:\\n  13:     with path.open(\\\"r\\\", encoding=\\\"utf-8\\\") as file:\\n  14:         return yaml.safe_load(file)\\n  15: \\n  16: \\n  17: def pick_liquid_symbols(frame: pd.DataFrame, max_symbols: int) -> list[str]:\\n  18:     if max_symbols <= 0:\\n  19:         return sorted(frame[\\\"ts_code\\\"].unique().tolist())\\n  20: \\n  21:     latest_dates = sorted(frame[\\\"date\\\"].dropna().unique())\\n  22:     if not latest_dates:\\n  23:         return []\\n  24: \\n  25:     cutoff = latest_dates[max(0, len(latest_dates) - 60)]\\n  26:     recent = frame[frame[\\\"date\\\"] >= cutoff]\\n  27:     ranked = (\\n  28:         recent.groupby(\\\"ts_code\\\", as_index=False)[\\\"amount\\\"]\\n  29:         .mean()\\n  30:         .sort_values(\\\"amount\\\", ascending=False)\\n  31:         .head(max_symbols)\\n  32:     )\\n  33:     return sorted(ranked[\\\"ts_code\\\"].tolist())\\n  34: \\n  35: \\n  36: def build_matrices(frame: pd.DataFrame) -> tuple[pd.DataFrame, pd.DataFrame]:\\n  37:     close = frame.pivot(index=\\\"date\\\", columns=\\\"ts_code\\\", values=\\\"close\\\").sort_index()\\n  38:     amount = frame.pivot(index=\\\"date\\\", columns=\\\"ts_code\\\", values=\\\"amount\\\").sort_index()\\n  39:     return close, amount\\n  40: \\n  41: \\n  42: def get_rebalance_dates(index: pd.DatetimeIndex, frequency: str) -> pd.DatetimeIndex:\\n  43:     if frequency == \\\"weekly\\\":\\n  44:         weeks = index.to_series().dt.strftime(\\\"%Y-%W\\\")\\n  45:         return index[weeks.ne(weeks.shift(1)).values]\\n  46:     if frequency == \\\"monthly\\\":\\n  47:         months = index.to_series().dt.strftime(\\\"%Y-%m\\\")\\n  48:         return index[months.ne(months.shift(1)).values]\\n  49:     return index\\n  50: \\n  51: \\n  52: def simulate(close: pd.DataFrame, amount: pd.DataFrame, cfg: dict) -> tuple[dict, pd.DataFrame, pd.DataFrame]:\\n  53:     rebalance_cfg = cfg.get(\\\"rebalance\\\", {})\\n  54:     risk_cfg = cfg.get(\\\"risk\\\", {})\\n  55:     cost_cfg = cfg.get(\\\"cost\\\", {})\\n  56:     universe_cfg = cfg.get(\\\"universe\\\", {})\\n  57: \\n  58:     frequency = rebalance_cfg.get(\\\"frequency\\\", \\\"weekly\\\")\\n  59:     top_n = int(rebalance_cfg.get(\\\"top_n\\\", 30))\\n  60: \\n  61:     max_single_position = float(risk_cfg.get(\\\"max_single_position\\\", 0.10))\\n  62:     max_drawdown = float(risk_cfg.get(\\\"max_portfolio_drawdown\\\", 0.10))\\n  63:     stop_new_positions_dd = float(risk_cfg.get(\\\"stop_new_positions_if_drawdown_exceed\\\", 0.08))\\n  64:     daily_turnover_limit = float(risk_cfg.get(\\\"daily_turnover_limit\\\", 0.25))\\n  65:     max_gross_exposure = float(risk_cfg.get(\\\"max_gross_exposure\\\", 1.0))\\n  66: \\n  67:     min_turnover_20d = float(universe_cfg.get(\\\"min_turnover_20d\\\", 30_000_000))\\n  68: \\n  69:     commission = float(cost_cfg.get(\\\"commission_bps\\\", 3)) / 10000.0\\n  70:     slippage = float(cost_cfg.get(\\\"slippage_bps\\\", 8)) / 10000.0\\n\\n===== scripts/run_live_execution_v1.py top =====\\n   1: from __future__ import annotations\\n   2: \\n   3: import argparse\\n   4: import csv\\n   5: import json\\n   6: import os\\n   7: import re\\n   8: import shutil\\n   9: import sys\\n  10: from dataclasses import dataclass\\n  11: from datetime import datetime, timedelta\\n  12: from pathlib import Path\\n  13: from typing import Any\\n  14: \\n  15: import pandas as pd\\n  16: \\n  17: PROJECT_ROOT = Path(__file__).resol