de_date\\\"] <= end_date)].copy()\\n 184:     equity_universe = set(basic[\\\"ts_code\\\"].dropna().astype(str).unique().tolist())\\n 185: \\n 186:     price = pd.read_csv(PRICE_CSV, usecols=[\\\"ts_code\\\", \\\"trade_date\\\", \\\"close\\\", \\\"vol\\\"])\\n 187:     price[\\\"trade_date\\\"] = pd.to_numeric(price[\\\"trade_date\\\"], errors=\\\"coerce\\\").fillna(0).astype(int)\\n 188:     price = price[(price[\\\"trade_date\\\"] >= start_date) & (price[\\\"trade_date\\\"] <= end_date)].copy()\\n 189:     price[\\\"ts_code\\\"] = price[\\\"ts_code\\\"].astype(str)\\n 190: \\n 191:     equity_price = price[price[\\\"ts_code\\\"].isin(equity_universe)].copy()\\n 192:     equity_price = equity_price.sort_values([\\\"ts_code\\\", \\\"trade_date\\\"]).reset_index(drop=True)\\n 193:     equity_price[\\\"prev_close\\\"] = equity_price.groupby(\\\"ts_code\\\")[\\\"close\\\"].shift(1)\\n 194:     equity_price[\\\"pct_change\\\"] = equity_price[\\\"close\\\"] / equity_price[\\\"prev_close\\\"].replace(0, pd.NA) - 1.0\\n 195:     equity_price[\\\"limit_up_flag_proxy\\\"] = equity_price[\\\"pct_change\\\"] >= 0.095\\n 196: \\n 197:     volume_daily = (\\n 198:         equity_price.groupby(\\\"trade_date\\\", as_index=False)[\\\"vol\\\"].sum().rename(columns={\\\"vol\\\": \\\"ashare_trading_volume\\\"})\\n 199:     )\\n 200:     limit_up_daily = (\\n 201:         equity_price.groupby(\\\"trade_date\\\", as_index=False)[\\\"limit_up_flag_proxy\\\"].sum().rename(columns={\\\"limit_up_flag_proxy\\\": \\\"limit_up_stock_count\\\"})\\n 202:     )\\n 203:     turnover_daily = (\\n 204:         basic.groupby(\\\"trade_date\\\", as_index=False)[\\\"turnover_rate\\\"].mean().rename(columns={\\\"turnover_rate\\\": \\\"ashare_turnover_rate\\\"})\\n---\\n   9: from typing import Any\\n  10: \\n  11: import pandas as pd\\n  12: import tushare as ts\\n  13: \\n  14: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  15: WORKSPACE = PROJECT_ROOT.parent.parent\\n  16: REPORT_DIR = WORKSP