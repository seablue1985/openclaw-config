:         year = int(year_match.group(1)) if year_match else 0\\n  62: \\n  63:         markers = list(re.finditer(r\\\"^START OF FILE:\\\\s*(.+?)\\\\s*$\\\", text, flags=re.MULTILINE))\\n  64:         for index, marker in enumerate(markers):\\n  65:             name_raw = marker.group(1).strip()\\n  66:             name = name_raw[:-4] if name_raw.lower().endswith(\\\".txt\\\") else name_raw\\n  67: \\n  68:             block_start = marker.end()\\n  69:             block_end = markers[index + 1].start() if index + 1 < len(markers) else len(text)\\n  70:             block_text = text[block_start:block_end].strip()\\n\\n===== scripts/run_qlib_long_compare.py top =====\\n   1: from __future__ import annotations\\n   2: \\n   3: import argparse\\n   4: import json\\n   5: import subprocess\\n   6: import sys\\n   7: from datetime import datetime\\n   8: from pathlib import Path\\n   9: from typing import Any\\n  10: \\n  11: import numpy as np\\n  12: import pandas as pd\\n  13: \\n  14: PROJECT_ROOT = Path(__file__).resolve().parents[1]\\n  15: WORKSPACE_ROOT = PROJECT_ROOT.parents[1]\\n  16: QLIB_REPO = WORKSPACE_ROOT / \\\"quant_projects\\\" / \\\"qlib\\\"\\n  17: A_STOCK_HISTORY = WORKSPACE_ROOT / \\\"data\\\" / \\\"a_stock_history.csv\\\"\\n  18: REPORT_DIR = PROJECT_ROOT / \\\"research\\\" / \\\"reports\\\"\\n  19: QLIB_LONG_ROOT = Path.home() / \\\".qlib\\\" / \\\"qlib_data\\\" / \\\"cn_data_long_2015_2026_180\\\"\\n  20: \\n  21: sys.path.append(str(PROJECT_ROOT / \\\"scripts\\\"))\\n  22: import run_strategy_695_batch as batch  # noqa: E402\\n  23: \\n  24: \\n  25: def to_qlib_symbol(ts_code: str) -> str:\\n  26:     code, exch = ts_code.split(\\\".\\\")\\n  27:     return f\\\"{exch.upper()}{code}\\\"\\n  28: \\n  29: \\n  30: def calc_metrics(daily_ret: pd.Series) -> dict[str, float]:\\n  31:     series = daily_ret.fillna(0.0).astype(float)\\n  32:     if series.empty:\\n  33:         return {\\n  34:             \\\"annual_return_pct\\\": 0.0,\\n  35:             \\\"annual_vol_pct\\\": 0.0,\\n  36:             \\\"sharpe\\\": 0.0,\\n  37:             \\\"max_drawdown_pct\\\": 0.0,\\n  38:             \\\"final_equity\\\": 1.0,\\n  39:             \\\"trading_days\\\": 0,\\n  40:         }\\n  41: \\n  42:     equity = (1 + series).cumprod()\\n  43:     annual = float(equity.iloc[-1] ** (252 / len(series)) - 1)\\n  44:     annual_vol = float(series.std(ddof=0) * np.sqrt(252))\\n  45:     sharpe = annual / annual_vol if annual_vol > 0 else 0.0\\n  46:     peak = equity.cummax()\\n  47:     max_dd = float(((peak - equity) / peak).max())\\n  48:     return {\\n  49:         \\\"annual_return_pct\\\": round(annual * 100, 2),\\n  50:         \\\"annual_vol_pct\\\": round(annual_vol * 100, 2),\\n  51:         \\\"sharpe\\\": round(sharpe, 3),\\n  52:         \\\"max_drawdown_pct\\\": round(max_dd * 100, 2),\\n  53:         \\\"final_equity\\\": round(float(equity.iloc[-1]), 4),\\n  54:         \\\"trading_days\\\": int(len(series)),\\n  55:     }\\n  56: \\n  57: \\n  58: def prepare_csv_universe(csv_dir: Path, max_symbols: int) -> tuple[list[str], str, str]:\\n  59:     close, _, _, start_date, end_date = batch.load_market_matrices(max_symbols=max_symbols)\\n  60:     symbols = [str(x) for x in close.columns]\\n  61:     symbols_with_benchmark = sorted(set(symbols + [\\\"000300.SH\\\"]))\\n  62: \\n  63:     csv_dir.mkdir(parents=True, exist_ok=True)\\n  64: \\n  65:     usecols = [\\\"ts_code\\\", \\\"trade_date\\\", \\\"open\\\", \\\"high\\\", \\\"low\\\", \\\"close\\\", \\\"vol\\\", \\\"amount\\\"]\\n  66:     frame = pd.read_csv(A_STOCK_HISTORY, usecols=usecols)\\n  67:     frame = frame[frame[\\\"ts_code\\\"].isin(symbols_with_benchmark)].copy()\\n  68: \\n  69:     benchmark_csv = WORKSPACE_ROOT / \\\"quant_projects\\\" / \\\"daily_stock_analysis\\\" / \\\"index_000300_SH.csv\\\"\\n  70:     if benchmark_csv.exists():\\n\\n===== risk/exit_engine.py top =====\\n   1: from __future__ import annotations\\n   2: \\n   