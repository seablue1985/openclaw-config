lized, existing_normalized)\n+    if word_sim >= 0.50:\n+        return True\n+\n+    return False\n \n \n \n@@ -381,11 +404,6 @@ def build_report(items: List[Dict[str, str]], date_str: str, *, slot: str, prior\n     lines: List[str] = []\n     lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n     lines.append(f\"📡 {report_title(slot)} | {date_str}\")\n-    lines.append(f\"📊 原始财经 {len(fin_items)} 条｜去重后 {len(deduped_items)} 条｜本次发送 {len(filtered_items)} 条\")\n-    if duplicates_removed:\n-        lines.append(f\"🧹 已筛除重复 {duplicates_removed} 条\")\n-    if filtered_repeat_count:\n-        lines.append(f\"🚫 已跳过早报重复 {filtered_repeat_count} 条\")\n     lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n \n     for cat_name, _ in CATEGORY_MAP:"}],"details":{"status":"completed","exitCode":0,"durationMs":26,"aggregated":"diff --git a/format_push_v2.py b/format_push_v2.py\nindex 8994084..bb15f90 100644\n--- a/format_push_v2.py\n+++ b/format_push_v2.py\n@@ -17,6 +17,8 @@ from difflib import SequenceMatcher\n from pathlib import Path\n from typing import Dict, List, Tuple\n \n+import jieba\n+\n BASE_DIR = Path(__file__).resolve().parent\n STATE_DIR = BASE_DIR / \"logs\"\n STATE_PATH = STATE_DIR / \"push_state.json\"\n@@ -281,18 +283,39 @@ def choose_better_item(current: Dict[str, str], candidate: Dict[str, str]) -> Di\n \n \n \n+def word_jaccard_sim(s1: str, s2: str) -> float:\n+    \"\"\"Word-level Jaccard similarity using jieba segmentation.\"\"\"\n+    if not s1 or not s2:\n+        return 0.0\n+    w1 = set(jieba.cut(s1))\n+    w2 = set(jieba.cut(s2))\n+    inter = len(w1 & w2)\n+    union = len(w1 | w2)\n+    return inter / union if union else 0.0\n+\n+\n def is_near_duplicate(normalized: str, existing_normalized: str) -> bool:\n-    \"\"\"Conservative near-duplicate detection for same-event title variants.\"\"\"\n+    \"\"\"Near-duplicate detection: character-level (relaxed) + word-level Jaccard.\"\"\"\n     if not normalized or not existing_normalized:\n         return False\n \n     shorter