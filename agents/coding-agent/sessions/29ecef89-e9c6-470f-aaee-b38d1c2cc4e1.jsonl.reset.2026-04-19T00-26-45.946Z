一事件不同表述\"\n+    word_sim = word_jaccard_sim(normalized, existing_normalized)\n+    if word_sim >= 0.50:\n+        return True\n+\n+    return False\n \n \n \n(2/3) Stage this hunk [y,n,q,a,d,K,j,J,g,/,s,e,p,?]? @@ -381,11 +404,6 @@ def build_report(items: List[Dict[str, str]], date_str: str, *, slot: str, prior\n     lines: List[str] = []\n     lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n     lines.append(f\"📡 {report_title(slot)} | {date_str}\")\n-    lines.append(f\"📊 原始财经 {len(fin_items)} 条｜去重后 {len(deduped_items)} 条｜本次发送 {len(filtered_items)} 条\")\n-    if duplicates_removed:\n-        lines.append(f\"🧹 已筛除重复 {duplicates_removed} 条\")\n-    if filtered_repeat_count:\n-        lines.append(f\"🚫 已跳过早报重复 {filtered_repeat_count} 条\")\n     lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n \n     for cat_name, _ in CATEGORY_MAP:\n(3/3) Stage this hunk [y,n,q,a,d,K,g,/,e,p,?]? \ndiff --git a/format_push_v2.py b/format_push_v2.py\nindex 8994084..3396cf6 100644\n--- a/format_push_v2.py\n+++ b/format_push_v2.py\n@@ -381,11 +381,6 @@ def build_report(items: List[Dict[str, str]], date_str: str, *, slot: str, prior\n     lines: List[str] = []\n     lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n     lines.append(f\"📡 {report_title(slot)} | {date_str}\")\n-    lines.append(f\"📊 原始财经 {len(fin_items)} 条｜去重后 {len(deduped_items)} 条｜本次发送 {len(filtered_items)} 条\")\n-    if duplicates_removed:\n-        lines.append(f\"🧹 已筛除重复 {duplicates_removed} 条\")\n-    if filtered_repeat_count:\n-        lines.append(f\"🚫 已跳过早报重复 {filtered_repeat_count} 条\")\n     lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n \n     for cat_name, _ in CATEGORY_MAP:\n[master c8577a8] Hide internal count lines from Feishu report\n 1 file changed, 5 deletions(-)"}],"details":{"status":"completed","exitCode":0,"durationMs":72,"aggregated":"diff --git a/format_push_v2.py b/format_push_v2.py\nindex 8994084..bb15f90 100644\n--- a/format_push_v2.py\n+++ b/format_push_v2.py\n@@ -17,6 +17,8 @@ from difflib import SequenceMatcher\n from pathli