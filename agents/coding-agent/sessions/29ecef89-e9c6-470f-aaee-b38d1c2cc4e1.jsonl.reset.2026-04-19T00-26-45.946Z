{"type":"message","id":"6fcc2b94","parentId":"e916fac4","timestamp":"2026-04-16T10:12:23.056Z","message":{"role":"toolResult","toolCallId":"call_o6T5NnKqNZ7U0jAdsnshUhM3|fc_02923f355d58c8e10169e0b605fa50819ba91b1c6391d0caa5","toolName":"read","content":[{"type":"text","text":"        return None, {\"sent_items\": [], \"raw_financial_count\": 0, \"deduped_count\": 0, \"duplicates_removed\": 0, \"filtered_repeat_count\": 0}\n\n    deduped_items, duplicates_removed = deduplicate_items(fin_items)\n    if not deduped_items:\n        return None, {\"sent_items\": [], \"raw_financial_count\": len(fin_items), \"deduped_count\": 0, \"duplicates_removed\": duplicates_removed, \"filtered_repeat_count\": 0}\n\n    prior_sent_norm_titles = prior_sent_norm_titles or set()\n    filtered_items = [item for item in deduped_items if normalize_title(item[\"title\"]) not in prior_sent_norm_titles]\n    filtered_repeat_count = len(deduped_items) - len(filtered_items)\n    if not filtered_items:\n        return None, {\n            \"sent_items\": [],\n            \"raw_financial_count\": len(fin_items),\n            \"deduped_count\": len(deduped_items),\n            \"duplicates_removed\": duplicates_removed,\n            \"filtered_repeat_count\": filtered_repeat_count,\n        }\n\n    categories: Dict[str, List[Dict[str, str]]] = {}\n    for item in filtered_items:\n        category = classify(item) or \"📰 其他\"\n        categories.setdefault(category, []).append(item)\n\n    sent_items: List[Dict[str, str]] = []\n    lines: List[str] = []\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"📡 {report_title(slot)} | {date_str}\")\n    lines.append(f\"📊 原始财经 {len(fin_items)} 条｜去重后 {len(deduped_items)} 条｜本次发送 {len(filtered_items)} 条\")\n    if duplicates_removed:\n        lines.append(f\"🧹 已筛除重复 {duplicates_removed} 条\")\n    if filtered_repeat_count:\n        lines.append(f\"🚫 已跳过早报重复 {filtered_repeat_count} 条\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    for cat_name, _ in CATEGORY_MAP:\n        cat_items = categories.get(cat_name, [])\n        if not cat_items:\n            continue\n        lines.append(\"\")\n        lines.append(f\"{cat_name} ({len(cat_items)} 条)\")\n        lines.append(\"\")\n        for item in cat_items[:6]:\n            signal = market_signal(item[\"title\"])\n            title = item[\"title\"][:48] + (\"…\" if len(item[\"title\"]) > 48 else \"\")\n            lines.append(f\"  {signal} {title}\")\n            sent_items.append(item)\n\n    other_items = categories.get(\"📰 其他\", [])\n    if other_items:\n        lines.append(\"\")\n        lines.append(f\"📰 其他财经 ({len(other_items)} 条)\")\n        lines.append(\"\")\n        for item in other_items[:4]:\n            title = item[\"title\"][:48] + (\"…\" if len(item[\"title\"]) > 48 else \"\")\n            lines.append(f\"  ⚪ {title}\")\n            sent_items.append(item)\n\n    lines.append(\"\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"📊 数据来源：TrendRadar | {datetime.now().strftime('%H:%M:%S')}\")\n    return \"\\n\".join(lines), {\n        \"sent_items\": sent_items,\n        \"raw_financial_count\": len(fin_items),\n        \"deduped_count\": len(deduped_items),\n        \"duplicates_removed\": duplicates_removed,\n        \"filtered_repeat_count\": filtered_repeat_count,\n    }\n\n\n\ndef send_feishu(text: str) -> dict:\n    \"\"\"发送飞书\"\"\"\n    import requests\n\n    payload = {\"msg_type\": \"text\", \"content\": {\"text\": text}}\n    response = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\n    return response.json()\n\n\n\n\n[62 more lines in file. Use offset=460 to continue.]"}],"isError":false,"timestamp":1776334343047}}
