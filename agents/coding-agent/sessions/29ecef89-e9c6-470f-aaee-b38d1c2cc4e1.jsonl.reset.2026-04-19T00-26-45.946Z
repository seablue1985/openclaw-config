{"type":"message","id":"9d6f2d98","parentId":"c9aa48ef","timestamp":"2026-04-16T10:13:11.520Z","message":{"role":"toolResult","toolCallId":"call_iX5z8EgGF0unFW4kamY4NkJt|fc_02923f355d58c8e10169e0b6373834819ba808c0d075c906d3","toolName":"exec","content":[{"type":"text","text":"diff --git a/format_push_v2.py b/format_push_v2.py\nindex 8994084..bb15f90 100644\n--- a/format_push_v2.py\n+++ b/format_push_v2.py\n@@ -19,0 +20,2 @@ from typing import Dict, List, Tuple\n+import jieba\n+\n@@ -283,0 +286,11 @@ def choose_better_item(current: Dict[str, str], candidate: Dict[str, str]) -> Di\n+def word_jaccard_sim(s1: str, s2: str) -> float:\n+    \"\"\"Word-level Jaccard similarity using jieba segmentation.\"\"\"\n+    if not s1 or not s2:\n+        return 0.0\n+    w1 = set(jieba.cut(s1))\n+    w2 = set(jieba.cut(s2))\n+    inter = len(w1 & w2)\n+    union = len(w1 | w2)\n+    return inter / union if union else 0.0\n+\n+\n@@ -285 +298 @@ def is_near_duplicate(normalized: str, existing_normalized: str) -> bool:\n-    \"\"\"Conservative near-duplicate detection for same-event title variants.\"\"\"\n+    \"\"\"Near-duplicate detection: character-level (relaxed) + word-level Jaccard.\"\"\"\n@@ -290 +302,0 @@ def is_near_duplicate(normalized: str, existing_normalized: str) -> bool:\n-    similarity = title_similarity(normalized, existing_normalized)\n@@ -291,0 +304 @@ def is_near_duplicate(normalized: str, existing_normalized: str) -> bool:\n+    # 子串快速路径\n@@ -295 +308,11 @@ def is_near_duplicate(normalized: str, existing_normalized: str) -> bool:\n-    return similarity >= 0.93\n+    # 字符级相似度（阈值从 0.93 降至 0.75）\n+    char_sim = title_similarity(normalized, existing_normalized)\n+    if char_sim >= 0.75:\n+        return True\n+\n+    # 词级 Jaccard（阈值 0.50）：捕获\"同一事件不同表述\"\n+    word_sim = word_jaccard_sim(normalized, existing_normalized)\n+    if word_sim >= 0.50:\n+        return True\n+\n+    return False\n@@ -384,5 +406,0 @@ def build_report(items: List[Dict[str, str]], date_str: 