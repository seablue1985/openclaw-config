law/skills/akshare-stock/SKILL.md"},"partialJson":"{\"path\":\"~/.openclaw/skills/akshare-stock/SKILL.md\"}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":48674,"output":670,"cacheRead":1536,"cacheWrite":0,"totalTokens":50880,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776989400020,"responseId":"resp_0059dd7f9d4e6a410169eab4d980fc819a8b7cfa82be7f3135"}}
{"type":"message","id":"d784bde4","parentId":"6eee5c16","timestamp":"2026-04-24T00:10:20.846Z","message":{"role":"toolResult","toolCallId":"call_nky4XNI1Fv3VyGT3iiziXgcE|fc_0059dd7f9d4e6a410169eab4e8b1f8819ab3b61da80afd2399","toolName":"read","content":[{"type":"text","text":"---\nname: akshare-stock\ndescription: A股量化数据分析工具，基于AkShare库获取A股行情、财务数据、板块信息等。用于回答关于A股股票查询、行情数据、财务分析、选股等问题。\n---\n\n# A股量化 - AkShare 数据接口\n\n## 快速开始\n\n安装依赖：\n```bash\npip install akshare\n```\n\n## 支持的功能\n\n### 1. 实时行情查询（优先快接口）\n\n```python\nimport akshare as ak\n\n# 单票实时行情（推荐，通常 <1s）\nquote_df = ak.stock_bid_ask_em(symbol=\"301333\")\nquote = {row[\"item\"]: row[\"value\"] for _, row in quote_df.iterrows()}\nprint(\"最新价:\", quote.get(\"最新\"))\nprint(\"涨跌幅:\", quote.get(\"涨幅\"))\nprint(\"昨收:\", quote.get(\"昨收\"))\n\n# 需要按名称模糊匹配股票代码时，再用全市场快照（约 8~15s）\nall_df = ak.stock_zh_a_spot()\nall_df[all_df[\"名称\"].str.contains(\"诺思格\", na=False)]\n```\n\n### 2. 历史K线数据\n\n```python\nimport akshare as ak\n\n# 日K线\nstock_zh_a_hist(symbol=\"000001\", period=\"daily\", start_date=\"20240101\", end_date=\"20241231\", adjust=\"qfq\")\n\n# 周K线\nstock_zh_a_hist(symbol=\"000001\", period=\"weekly\", start_date=\"20240101\", end_date=\"20241231\", adjust=\"qfq\")\n\n# 月K线\nstock_zh_a_hist(symbol=\"000001\", period=\"monthly\", start_date=\"20240101\", end_date=\"20241231\", adjust=\"qfq\")\n```\n\n### 3. 财务数据\n\n```python\nimport akshare as ak\n\n# 财务报表\nstock_financial_abstract_ths(symbol=\"000001\", indicator=\"按报告期\")\n\n# 主要财务指标\nstock_financial_analysis_indicator(symbol=\"000001\")\n```\n\n### 4. 板块/行业分析\n\n```python\nimport akshare as ak\n\n# 行业板块行情\nstock_board_industry_name_em()\n\n# 概念板块行情\nstock_board_concept_name_em()\n\n# 板块内个股\nstock_board_industry_cons_em(symbol=\"半导体\")\n```\n\n### 5. 资金流向\n\n```python\nimport akshare as ak\n\n# 个股资金流向\nstock_individual_fund_flow(stock=\"000001\", market=\"sh\")\n\n# 大单净流入\nstock_individual_fund_flow(stock=\"000001\", market=\"sh\", symbol=\"大单净流入\")\n```\n\n### 6. 龙虎榜\n\n```python\nimport akshare as ak\n\n# 每日龙虎榜\nstock_lhb_detail_em(date=\"20240930\")\n\n# 机构调研\nstock_zlzj_em()\n```\n\n### 7. 新股/IPO\n\n```python\nimport akshare as ak\n\n# 新股申购\nstock_new_ipo_em()\n\n# 待上市新股\nstock_new_ipo_start_em()\n```\n\n### 8. 融资融券\n\n```python\nimport akshare as ak\n\n# 融资融券\nstock_margin_sse(symbol=\"600000\")\n\n# 融资融券明细\nstock_rzrq_detail_em(symbol=\"600000\", date=\"20240930\")\n```\n\n## 常用股票代码\n\n- **平安银行**: 000001\n- **贵州茅台**: 600519\n- **宁德时代**: 300750\n- **比亚迪**: 002594\n- **招商银行**: 600036\n\n## 备选方案: Baostock\n\n如果 AkShare 安装失败，可使用 baostock（更轻量）:\n\n```python\nimport baostock as bs\n\n# 登录\nlg = bs.login()\nprint(lg.error_msg)\n\n# 获取历史K线\nrs = bs.query_history_k_data_plus('sh.600519',\n    'date,code,open,high,low,close,volume',\n    start_date='20250101',\n    end_date='20251231')\n\ndata_list = []\nwhile rs.next:\n    data_list.append(rs.get_row_data())\n    \nbs.logout()\n```\n\n## 注意事项\n\n1. 数据仅供学术研究，不构成投资建议\n2. 接口可能因目标网站变动而失效\n3. 建议添加异常处理和重试机制\n4. **当前环境网络问题可能导致测试失败，请在本地环境测试**\n5. **单票查询禁止默认使用 `stock_zh_a_spot_em()`，该接口会抓取全市场，常见耗时 60~90 秒**\n6. 飞书对话优先返回结论：若查询超过 15 秒，先给阶段性结论，再继续深挖\n"}],"isError":false,"timestamp":1776989420835}}
{"type":"message","id":"3a7f1d21","parentId":"d784bde4","timestamp":"2026-04-24T00:10:27.178Z","message":{"role":"assistant","content":[{"type":"text","text":"我先确认一下你说的“利通电子”对应哪只票，再看它为什么继续涨、你是不是卖早了。","textSignature":"{\"v\":1,\"id\":\"msg_0059dd7f9d4e6a410169eab4efa968819abfa72e6e9eaa8613\",\"phase\":\"commentary\"}"},{"type":"toolCall","id":"call_NWpwLXxvGxxuKw0bfvixRBTC|fc_0059dd7f9d4e6a410169eab4f07274819aaf27ce07b9f1f2c1","name":"exec","arguments":{"command":"python3 - <<'PY'\nimport akshare as ak\nimport pandas as pd\n\ndf = ak.stock_zh_a_spot()\nmask = df['名称'].astype(str).str.contains('利通|电子', na=False)\nprint(df.loc[mask, ['代码','名称','最新价','涨跌幅']].head(50).to_string(index=False))\nPY","workdir":"/Users/ling/.openclaw/workspace/coding-agent","timeout":60},"partialJson":"{\"command\":\"python3 - <<'PY'\\nimport akshare as ak\\nimport pandas as pd\\n\\ndf = ak.stock_zh_a_spot()\\nmask = df['名称'].astype(str).str.contains('利通|电子', na=False)\\nprint(df.loc[mask, ['代码','名称','最新价','涨跌幅']].head(50).to_string(index=False))\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace/coding-agent\",\"timeout\":60}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":50420,"output":157,"cacheRead":1536,"cacheWrite":0,"totalTokens":52113,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776989420846,"responseId":"resp_0059dd7f9d4e6a410169eab4ee7704819aace2c69356121657"}}
