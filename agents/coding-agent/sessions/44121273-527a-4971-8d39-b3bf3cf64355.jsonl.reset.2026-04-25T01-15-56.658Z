{"type":"message","id":"518f7a2b","parentId":"29c1080c","timestamp":"2026-04-24T15:19:58.717Z","message":{"role":"toolResult","toolCallId":"call_81fVJmQkEIBhiFN4G950uMth|fc_0059dd7f9d4e6a410169eb8a1d5990819a9c4db3821ece90a1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nSkill / OpenClaw Update Checker v5\n\n目标：\n1. 不再只盯 ~/.openclaw/workspace/skills，改为扫描实际存在的多个 skills 根目录\n2. 明确区分：ClawHub 托管 / 本地自定义 / 扩展技能 / 内置技能 / ACP 技能 / 缺失记录\n3. 对 ClawHub 托管技能支持“安全自动更新”：直接调用 `clawhub update <slug>`\n   - 若本地 hash 不匹配 → 视为本地变更，保留本地\n   - 若被标记 suspicious → 不自动更新\n   - 若已是最新 → 明确说明\n   - 若成功升级 → 明确列出\n4. OpenClaw 版本检查改为检查 `openclaw` 包，而不是误查 `clawhub`\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport glob\nimport json\nimport os\nimport re\nimport shutil\nimport subprocess\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\nHOME = Path.home()\nWORKSPACE = HOME / \".openclaw\" / \"workspace\"\nOUTPUT_JSON = WORKSPACE / \"memory\" / \"skill_update_check.json\"\n\nRISK_PATTERNS = [\n    \"eval(\",\n    \"exec(\",\n    \"subprocess.\",\n    \"os.system(\",\n    \"shell=True\",\n    \"requests.\",\n    \"httpx.\",\n    \"socket.\",\n    \"cryptography\",\n    \"Crypto.\",\n]\n\nROOT_SPECS = [\n    (HOME / \".openclaw\" / \"workspace\" / \"skills\", \"clawhub\"),\n    (HOME / \".openclaw\" / \"skills\", \"local\"),\n    (HOME / \".agents\" / \"skills\", \"agent-local\"),\n    (HOME / \".openclaw\" / \"extensions\" / \"openclaw-lark\" / \"skills\", \"extension\"),\n]\nGLOB_ROOT_SPECS = [\n    (\n        HOME\n        / \"Library\"\n        / \"pnpm\"\n        / \"global\"\n        / \"5\"\n        / \".pnpm\"\n        / \"openclaw@*\"\n        / \"node_modules\"\n        / \"openclaw\"\n        / \"skills\",\n        \"builtin\",\n    ),\n    (\n        HOME\n        / \"Library\"\n        / \"pnpm\"\n        / \"global\"\n        / \"5\"\n        / \".pnpm\"\n        / \"openclaw@*\"\n        / \"node_modules\"\n        / \"openclaw\"\n        / \"dist\"\n        / \"extensions\"\n        / \"acpx\"\n        / \"skills\",\n        \"acpx\",\n    ),\n]\n\nROOT_LABELS = {\n    \"clawhub\": \"ClawHub 托管\",\n    \"local\": \"本地技能\",\n    \"agent-local\": \"Agent 本地技能\",\n    \"extension\": \"扩展技能\",\n    \"builtin\": \"OpenClaw 内置\",\n    \"acpx\": \"ACPX 内置\",\n}\n\n\n@dataclass\nclass SkillLocation:\n    path: Path\n    root_kind: str\n\n\ndef run_cmd(cmd: list[str], timeout: int = 60, cwd: Path | None = None) -> tuple[str, str, int]:\n    try:\n        result = subprocess.run(\n            cmd,\n            capture_output=True,\n            text=True,\n            timeout=timeout,\n            cwd=str(cwd) if cwd else None,\n        )\n        return result.stdout.strip(), result.stderr.strip(), result.returncode\n    except subprocess.TimeoutExpired as exc:\n        return exc.stdout or \"\", exc.stderr or f\"timeout after {timeout}s\", -1\n    except FileNotFoundError as exc:\n        return \"\", str(exc), 127\n    except Exception as exc:  # pragma: no cover\n        return \"\", str(exc), -1\n\n\ndef iter_skill_roots() -> list[tuple[Path, str]]:\n    roots: list[tuple[Path, str]] = []\n    seen: set[Path] = set()\n    for path, kind in ROOT_SPECS:\n        if path.exists() and path.is_dir() and path not in seen:\n            roots.append((path, kind))\n            seen.add(path)\n    for pattern, kind in GLOB_ROOT_SPECS:\n        for matched in sorted(glob.glob(str(pattern))):\n            path = Path(matched)\n            if path.exists() and path.is_dir() and path not in seen:\n                roots.append((path, kind))\n                seen.add(path)\n    return roots\n\n\ndef list_skill_dirs(root: Path) -> list[Path]:\n    result: list[Path] = []\n    if not root.exists():\n        return result\n    for item in sorted(root.iterdir()):\n        if not item.is_dir():\n            continue\n        if item.name in {\"dist\", \"memory\", \"__pycache__\", \"node_modules\"}:\n            continue\n        if (item / \"SKILL.md\").exists():\n            result.append(item)\n    return result\n\n\ndef resolve_skill(name: str, roots: list[tuple[Path, str]]) -> SkillLocation | None:\n    for root, kind in roots:\n        candidate = root / name\n        if candidate.is_dir() and (candidate / \"SKILL.md\").exists():\n            return SkillLocation(candidate, kind)\n    return None\n\n\ndef gather_local_only_skills(clawhub_names: set[str], roots: list[tuple[Path, str]]) -> list[dict[str, Any]]:\n    items: list[dict[str, Any]] = []\n    seen: set[str] = set()\n    for root, kind in roots:\n        for skill_dir in list_skill_dirs(root):\n            name = skill_dir.name\n            if name in clawhub_names or name in seen:\n                continue\n            seen.add(name)\n            items.append(\n                {\n                    \"name\": name,\n                    \"source\": kind,\n                    \"source_label\": ROOT_LABELS.get(kind, kind),\n                    \"path\": str(skill_dir),\n                    \"type\": \"local_only\",\n                }\n            )\n    return sorted(items, key=lambda x: (x[\"source_label\"], x[\"name\"]))\n\n\ndef get_installed_clawhub_skills() -> list[dict[str, str]]:\n    stdout, stderr, rc = run_cmd([\"clawhub\", \"list\"], timeout=30)\n    if rc != 0:\n        return []\n    skills: list[dict[str, str]] = []\n    for line in stdout.splitlines():\n        parts = line.strip().split()\n        if len(parts) >= 2:\n            skills.append({\"name\": parts[0], \"version\": parts[1]})\n    return skills\n\n\ndef scan_risk(skill_path: Path) -> dict[str, Any]:\n    code_files: list[str] = []\n    hits: list[str] = []\n    for file in skill_path.rglob(\"*\"):\n        if not file.is_file():\n            continue\n        if any(part in {\".git\", \"node_modules\", \"__pycache__\"} for part in file.parts):\n            continue\n        if file.suffix.lower() not in {\".py\", \".js\", \".sh\", \".ts\"}:\n            continue\n        rel = str(file.relative_to(skill_path))\n        code_files.append(rel)\n        try:\n            content = file.read_text(encoding=\"utf-8\", errors=\"ignore\")[:20000]\n        except Exception:\n            continue\n        for pattern in RISK_PATTERNS:\n            if pattern in content:\n                hits.append(f\"{rel}:{pattern}\")\n                if len(hits) >= 5:\n                    break\n        if len(hits) >= 5:\n            break\n    return {\"code_count\": len(code_files), \"risk_hits\": hits}\n\n\ndef read_clawhub_origin(skill_path: Path) -> dict[str, Any]:\n    origin = skill_path / \".clawhub\" / \"origin.json\"\n    if not origin.exists():\n        return {}\n    try:\n        return json.loads(origin.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef parse_clawhub_update_output(name: str, output: str) -> dict[str, Any]:\n    text = (output or \"\").strip()\n    lower = text.lower()\n    if not text:\n        return {\n            \"update_status\": \"unknown\",\n            \"recommendation\": \"🔍 需人工确认\",\n            \"reason\": \"clawhub 无输出\",\n            \"updated\": False,\n        }\n    if \"local changes (no match)\" in lower:\n        return {\n            \"update_status\": \"local_changes\",\n            \"recommendation\": \"✅ 保留本地\",\n            \"reason\": \"ClawHub 判定本地内容已偏离已发布版本，自动更新已跳过\",\n            \"updated\": False,\n        }\n    if \"skipped (use --force to update suspicious skills)\" in lower or \"flagged as suspicious\" in lower:\n        return {\n            \"update_status\": \"suspicious\",\n            \"recommendation\": \"⚠️ 需review\",\n            \"reason\": \"被 ClawHub 标记为 suspicious，未自动覆盖\",\n            \"updated\": False,\n        }\n    if \"already up to date\" in lower or \"up-to-date\" in lower or \"already latest\" in lower:\n        return {\n            \"update_status\": \"up_to_date\",\n            \"recommendation\": \"✅ 已是最新\",\n            \"reason\": \"已是最新版本\",\n            \"updated\": False,\n        }\n    if f\"- checking {name}\".lower() in lower and (\"updated\" in lower or \"installed\" in lower or \"latest\" in lower):\n        return {\n            \"update_status\": \"updated\",\n            \"recommendation\": \"🚀 已自动更新\",\n            \"reason\": text.splitlines()[-1][:160],\n\n[212 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1777043998706}}
{"type":"message","id":"8e5731bb","parentId":"518f7a2b","timestamp":"2026-04-24T15:19:58.729Z","message":{"role":"toolResult","toolCallId":"call_uTrNH8YCwEU26Or1lgyghwuj|fc_0059dd7f9d4e6a410169eb8a1d599c819ab686b9034ba87b68","toolName":"process","content":[{"type":"text","text":"\")\n/Users/ling/.openclaw/workspace/scripts/skill_update_check.py:444:    parser.add_argument(\"--auto-update-safe\", action=\"store_true\", help=\"run `clawhub update <slug>` for ClawHub-managed skills\")\n/Users/ling/.openclaw/workspace/scripts/skill_update_check.py:448:    clawhub_skills = get_installed_clawhub_skills()\n/Users/ling/.openclaw/workspace/scripts/skill_update_check.py:449:    clawhub_names = {item[\"name\"] for item in clawhub_skills}\n/Users/ling/.openclaw/workspace/scripts/skill_update_check.py:451:    results = [evaluate_clawhub_skill(item, roots, auto_update_safe=args.auto_update_safe) for item in clawhub_skills]\n/Users/ling/.openclaw/workspace/scripts/skill_update_check.py:452:    local_only = gather_local_only_skills(clawhub_names, roots)\n/Users/ling/.openclaw/workspace/scripts/skill_update_check.py:459:        \"clawhub_results\": results,\n/Users/ling/.openclaw/workspace/openclaw_projects/Agent-Reach/agent_reach/cli.py:981:    \"\"\"Classify update-check errors for user-friendly diagnostics.\"\"\"\n/Users/ling/.openclaw/workspace/skills/xiaohongshu-skills/.venv/lib/python3.11/site-packages/_pytest/terminal.py:755:                self._timing_nodeids_reported.update(r.nodeid for r in not_reported)\n/Users/ling/.openclaw/workspace/skills/xiaohongshu-skills/.venv/lib/python3.11/site-packages/_pytest/junitxml.py:617:        \"\"\"Accumulate total duration for nodeid from given report and update\n/Users/ling/.openclaw/workspace/skills/xiaohongshu-skills/.venv/lib/python3.11/site-packages/_pytest/junitxml.py:633:        reporter.attrs.update(classname=\"pytest\", name=\"internal\")\n/Users/ling/.openclaw/workspace/skills/union-search-skill/scripts/github/github_search.p