   if result.returncode == 0:\n            print(\"✅ 任务已成功提交到低成本模型\")\n            print(f\"💾 模型: {model}\")\n            print(f\"🎯 目标: 节省GPT token使用\")\n            \n            # 尝试解析JSON输出\n            try:\n                output = json.loads(result.stdout)\n                if \"childSessionKey\" in output:\n                    print(f\"📋 会话ID: {output['childSessionKey']}\")\n            except:\n                pass\n                \n            return True\n        else:\n            print(f\"❌ 任务提交失败\")\n            print(f\"错误: {result.stderr}\")\n            return False\n            \n    except Exception as e:\n        print(f\"❌ 执行错误: {str(e)}\")\n        return False\n","newText":"        if result.returncode == 0:\n            print(\"✅ 任务已成功提交到低成本模型\")\n            print(f\"💾 模型: {model}\")\n            print(f\"🎯 目标: 节省GPT token使用\")\n            \n            # 尝试解析JSON输出\n            try:\n                output = json.loads(result.stdout)\n                if \"childSessionKey\" in output:\n                    print(f\"📋 会话ID: {output['childSessionKey']}\")\n            except:\n                pass\n                \n            return True\n        else:\n            print(f\"❌ 任务提交失败\")\n            print(f\"错误: {result.stderr}\")\n            ok, notify_msg = send_failure_alert(task_type, model, result.stderr or result.stdout, openclaw_bin)\n            print(\"📣 失败提醒已发送\" if ok else f\"⚠️ 失败提醒发送也失败: {notify_msg}\")\n            return False\n            \n    except Exception as e:\n        print(f\"❌ 执行错误: {str(e)}\")\n        ok, notify_msg = send_failure_alert(task_type, model, str(e), openclaw_bin if 'openclaw_bin' in locals() else (os.environ.get('OPENCLAW_BIN') or shutil.which('openclaw') or 'openclaw'))\n        print(\"📣 失败提醒已发送\" if ok else f\"⚠️ 失败提醒发送也失败: {notify_msg}\")\n        return False\n"}]},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/coding-agent/periodic_task_executor.py\",\"edits\":[{\"oldText\":\"import sys\\nimport json\\nimport os\\nimport shutil\\nimport subprocess\\nfrom datetime import datetime\\n\\ndef run_periodic_task(task_type, model=\\\"minimax-m2.7\\\"):\\n\",\"newText\":\"import sys\\nimport json\\nimport os\\nimport shutil\\nimport subprocess\\nfrom datetime import datetime\\n\\nNOTIFY_TO = os.environ.get(\\\"OPENCLAW_NOTIFY_TO\\\", \\\"user:ou_47c21eede907b0c4f9fd4d34519d84ae\\\")\\nNOTIFY_CHANNEL = os.environ.get(\\\"OPENCLAW_NOTIFY_CHANNEL\\\", \\\"feishu\\\")\\nNOTIFY_ACCOUNT = os.environ.get(\\\"OPENCLAW_NOTIFY_ACCOUNT\\\", \\\"coding-agent\\\")\\nLOG_PATH = os.environ.get(\\\"PERIODIC_TASK_LOG\\\", \\\"/tmp/periodic_tasks.log\\\")\\n\\n\\ndef send_failure_alert(task_type, model, error_text, openclaw_bin):\\n    \\\"\\\"\\\"任务失败时发送飞书提醒\\\"\\\"\\\"\\n    ts = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\\n    err = (error_text or \\\"unknown error\\\").strip().replace(\\\"\\\\n\\\", \\\" \\\")\\n    err = err[:400]\\n    prompt = (\\n        \\\"请原样发送下面这条失败提醒，不要扩写，不要解释：\\\\n\\\"\\n        f\\\"【周期任务失败】{task_type} | 模型: {model} | 时间: {ts} | 日志: {LOG_PATH} | 错误: {err}\\\"\\n    )\\n    cmd = [\\n        openclaw_bin, \\\"agent\\\",\\n        \\\"--agent\\\", NOTIFY_ACCOUNT,\\n        \\\"--message\\\", prompt,\\n        \\\"--deliver\\\",\\n        \\\"--reply-channel\\\", NOTIFY_CHANNEL,\\n        \\\"--reply-to\\\", NOTIFY_TO,\\n        \\\"--reply-account\\\", NOTIFY_ACCOUNT,\\n        \\\"--timeout\\\", \\\"90\\\",\\n    ]\\n    result = subprocess.run(cmd, capture_output=True, text=True)\\n    return result.returncode == 0, (result.stderr or result.stdout or \\\"\\\").strip()\\n\\n\\ndef run_periodic_task(task_type, model=\\\"minimax-m2.7\\\"):\\n\"},{\"oldText\":\"        if result.returncode == 0:\\n            print(\\\"✅ 任务已成功提交到低成本模型\\\")\\n            print(f\\\"💾 模型: {model}\\\")\\n            print(f\\\"🎯 目标: 节省GPT token使用\\\")\\n            \\n            # 尝试解析JSON输出\\n            try:\\n                output = json.loads(result.stdou