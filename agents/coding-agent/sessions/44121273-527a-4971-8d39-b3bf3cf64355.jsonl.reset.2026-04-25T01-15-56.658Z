)}'\n    if ahead > 0 and behind == 0:\n        return 'local_only', '🟡 仅本地待整理', f'本地有 {ahead} 个未推送提交，上游无新增'\n    return 'manual_review', '⚠️ 需人工 review', '状态复杂，需人工判断'\n","newText":"def classify(item: dict[str, Any]) -> tuple[str, str, str, str]:\n    behind = int(item.get('commits_behind') or 0)\n    ahead = int(item.get('commits_ahead') or 0)\n    dirty = bool(item.get('working_tree_dirty'))\n    breaking = bool(item.get('breaking_changes'))\n    fetch_error = item.get('fetch_error')\n    wt = worktree_text(item)\n\n    if fetch_error:\n        return 'manual_high_risk', '🔴 高风险人工处理', '暂不建议更新', f'抓取上游失败：{fetch_error}'\n    if breaking:\n        return 'manual_high_risk', '🔴 高风险人工处理', '暂不建议更新', '检测到 breaking changes，不应自动推进'\n    if behind == 0 and ahead == 0 and not dirty:\n        return 'synced', '✅ 已同步', '无需更新', '本地与上游一致'\n    if behind > 0 and ahead == 0 and not dirty:\n        if behind <= 20:\n            return 'fast_forward', '🟢 可直接快进', '建议更新', f'仅落后 {behind} 个提交，且工作区干净，可直接 fast-forward'\n        return 'manual_high_risk', '🔴 高风险人工处理', '暂不建议更新', f'落后 {behind} 个提交，跨度过大，当前不值得直接更新'\n    if behind > 0 and ahead > 0 and not dirty:\n        if behind <= 20 and ahead <= 20:\n            return 'auto_rebase', '🔵 可自动 rebase', '建议更新', f'本地 ahead {ahead} / upstream behind {behind}，且工作区干净，值得做一次自动 rebase'\n        return 'needs_merge', '🟠 本地有改动且上游有更新，需合并', '暂不建议更新', f'已分叉（behind {behind} / ahead {ahead}），分叉过深，当前不建议直接更新'\n    if behind > 0 and dirty and ahead == 0:\n        if behind <= 20:\n            return 'needs_merge', '🟠 本地有改动且上游有更新，需合并', '建议更新', f'上游有 {behind} 个提交未并入，但本地只是工作区改动（{wt}）；先整理本地后值得更新'\n        return 'needs_merge', '🟠 本地有改动且上游有更新，需合并', '暂不建议更新', f'本地工作区有改动（{wt}），且上游落后 {behind} 个提交，当前更新成本偏高'\n    if behind > 0 and (ahead > 0 or dirty):\n        return 'needs_merge', '🟠 本地有改动且上游有更新，需合并', '暂不建议更新', f'本地有改动（ahead {ahead}，工作区 {wt}）且上游还有 {behind} 个提交未并入，当前不建议直接更新'\n    if dirty and behind == 0:\n        return 'local_only', '🟡 仅本地待整理', '无需更新', f'上游无新提交，但本地工作区有改动：{wt}'\n    if ahead > 0 and behind == 0:\n        return 'local_only', '🟡 仅本地待整理', '无需更新', f'本地有 {ahead} 个未推送提交，上游无新增'\n    return 'manual_review', '⚠️ 需人工 review', '暂不建议更新', '状态复杂，当前不建议自动推进'\n"},{"oldText":"        action_key, action_label, action_reason = classify(item)\n        row = dict(item)\n        row['action_key'] = action_key\n        row['action_label'] = action_label\n        row['action_reason'] = action_reason\n","newText":"        action_key, action_label, final_verdict, action_reason = classify(item)\n        row = dict(item)\n        row['action_key'] = action_key\n        row['action_label'] = action_label\n        row['final_verdict'] = final_verdict\n        row['action_reason'] = action_reason\n"},{"oldText":"            md.append(f\"- behind {item.get('commits_behind', 0)} | ahead {item.get('commits_ahead', 0)} | 工作区：{item['worktree_text']}\")\n            md.append(f\"- **动作判断：{item['action_reason']}**\")\n","newText":"            md.append(f\"- behind {item.get('commits_behind', 0)} | ahead {item.get('commits_ahead', 0)} | 工作区：{item['worktree_text']}\")\n            md.append(f\"- **最终结论：{item['final_verdict']}**\")\n            md.append(f\"- 动作判断：{item['action_reason']}\")\n"}]},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/scripts/refine_github_repo_update_report.py\",\"edits\":[{\"oldText\":\"def classify(item: dict[str, Any]) -> tuple[str, str, str]:\\n    behind = int(item.get('commits_behind') or 0)\\n    ahead = int(item.get('commits_ahead') or 0)\\n    dirty = bool(item.get('working_tree_dirty'))\\n    breaking = bool(item.get('breaking_changes'))\\n    fetch_error = item.get('fetch_error')\\n\\n    if fetch_error:\\n        return 'manual_high_risk', '🔴 高风险人工处理', f'抓取上游失败：{fetch_error}'\\n    if breaking:\\n        return 'manual_high_risk', '🔴 高风险人工处理', '检测到 breaking changes，不应自动推进'\\n    if behind == 0 and ahead == 0 and not dirty:\\n        return 'synced', '✅ 已同步', '本地与上游一致'\\n    if behind > 0 and ahead == 0 a