value:\n        return ()\n    parts = re.findall(r\"\\d+\", value)\n    return tuple(int(p) for p in parts)\n\n\ndef is_remote_newer(local_version: str | None, remote_version: str | None) -> bool:\n    if not local_version or not remote_version:\n        return False\n    return parse_version_tuple(remote_version) > parse_version_tuple(local_version)\n"},{"oldText":"def get_installed_clawhub_skills() -> list[dict[str, str]]:\n    stdout, stderr, rc = run_cmd([\"clawhub\", \"list\"], timeout=30)\n    if rc != 0:\n        return []\n    skills: list[dict[str, str]] = []\n    for line in stdout.splitlines():\n        parts = line.strip().split()\n        if len(parts) >= 2:\n            skills.append({\"name\": parts[0], \"version\": parts[1]})\n    return skills\n","newText":"def get_installed_clawhub_skills() -> list[dict[str, str]]:\n    stdout, stderr, rc = run_cmd([\"clawhub\", \"list\"], timeout=30)\n    if rc != 0:\n        return []\n    skills: list[dict[str, str]] = []\n    for line in stdout.splitlines():\n        parts = line.strip().split()\n        if len(parts) >= 2:\n            skills.append({\"name\": parts[0], \"version\": parts[1]})\n    return skills\n\n\ndef fetch_remote_latest_version(name: str) -> dict[str, Any]:\n    stdout, stderr, rc = run_cmd([\"clawhub\", \"inspect\", name, \"--json\"], timeout=60)\n    text = stdout or stderr\n    if rc != 0 or not text.strip():\n        return {\"latest_version\": None, \"inspect_error\": (stderr or stdout or \"\").strip()[:200]}\n    try:\n        payload = json.loads(text)\n    except Exception:\n        return {\"latest_version\": None, \"inspect_error\": text.strip()[:200]}\n    latest_version = ((payload.get(\"latestVersion\") or {}).get(\"version\")) or ((payload.get(\"skill\") or {}).get(\"tags\") or {}).get(\"latest\")\n    return {\n        \"latest_version\": latest_version,\n        \"inspect_error\": None,\n        \"remote_updated_at\": ((payload.get(\"skill\") or {}).get(\"updatedAt\")),\n    }\n"},{"oldText":"def evaluate_clawhub_skill(\n    item: dict[str, str],\n    roots: list[tuple[Path, str]],\n    auto_update_safe: bool,\n) -> dict[str, Any]:\n","newText":"def evaluate_clawhub_skill(\n    item: dict[str, str],\n    roots: list[tuple[Path, str]],\n    auto_update_safe: bool,\n) -> dict[str, Any]:\n"},{"oldText":"    result: dict[str, Any] = {\n        \"name\": name,\n        \"version\": version,\n        \"installed\": True,\n        \"path\": str(loc.path),\n        \"source\": loc.root_kind,\n        \"source_label\": ROOT_LABELS.get(loc.root_kind, loc.root_kind),\n        \"code_count\": risk[\"code_count\"],\n        \"risk_hits\": risk[\"risk_hits\"],\n        \"clawhub_origin\": origin,\n    }\n","newText":"    remote_meta = fetch_remote_latest_version(name)\n    remote_latest = remote_meta.get(\"latest_version\")\n    result: dict[str, Any] = {\n        \"name\": name,\n        \"version\": version,\n        \"installed\": True,\n        \"path\": str(loc.path),\n        \"source\": loc.root_kind,\n        \"source_label\": ROOT_LABELS.get(loc.root_kind, loc.root_kind),\n        \"code_count\": risk[\"code_count\"],\n        \"risk_hits\": risk[\"risk_hits\"],\n        \"clawhub_origin\": origin,\n        \"remote_latest_version\": remote_latest,\n        \"remote_has_newer\": is_remote_newer(version, remote_latest),\n        \"inspect_error\": remote_meta.get(\"inspect_error\"),\n    }\n"},{"oldText":"        parsed = parse_clawhub_update_output(name, \"\\n\".join([stdout, stderr]).strip())\n        result.update(parsed)\n        result[\"update_stdout\"] = stdout\n        result[\"update_stderr\"] = stderr\n        result[\"update_rc\"] = rc\n        result[\"status\"] = parsed[\"update_status\"]\n","newText":"        parsed = parse_clawhub_update_output(name, \"\\n\".join([stdout, stderr]).strip())\n        result.update(parsed)\n        result[\"update_stdout\"] = stdout\n        result[\"update_stderr\"] = stderr\n        result[\"