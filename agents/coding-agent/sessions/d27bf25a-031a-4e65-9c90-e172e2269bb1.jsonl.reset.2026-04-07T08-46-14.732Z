{"type":"message","id":"fe6f2ee3","parentId":"2699e308","timestamp":"2026-04-06T11:32:19.703Z","message":{"role":"toolResult","toolCallId":"call_function_zgsx2nzd58zz_1","toolName":"edit","content":[{"type":"text","text":"Successfully replaced text in /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_strategy_param_auto_audit.py."}],"details":{"diff":"     ...\n 222     return \"\\n\".join(lines)\n 223 \n 224 \n 225 def push_feishu(report: str, alerts: list[dict]) -> bool:\n-226     \"\"\"通过 OpenClaw message 工具推送到飞书私聊（张玲）。\"\"\"\n+226     \"\"\"通过 openclaw message send 命令推送到飞书私聊。\"\"\"\n 227     try:\n-228         # 构造带告警 emoji 的消息摘要\n+228         import subprocess\n+229 \n+230         # 构造消息摘要\n 229         severity_emoji = \"🔴\" if any(a[\"severity\"] == \"HIGH\" for a in alerts) else \"🟡\"\n-230         summary_lines = [f\"{severity_emoji} 策略参数巡检 | {datetime.now().strftime('%m/%d %H:%M')}\"]\n+232         lines = [f\"{severity_emoji} 策略参数巡检 | {datetime.now().strftime('%m/%d %H:%M')}\"]\n 231         for a in alerts:\n 232             sev = \"🔴\" if a[\"severity\"] == \"HIGH\" else \"🟡\"\n-233             summary_lines.append(f\"{sev} {a['type']}: {a['message'][:100]}\")\n-234         summary_lines.append(\"\")\n-235         summary_lines.append(\"报告文件: strategy_param_auto_audit_YYYYMMDD.md\")\n+235             lines.append(f\"{sev} {a['type']}: {a['message'][:100]}\")\n+236         lines.append(\"\")\n+237         lines.append(\"报告: research/reports/strategy_param_auto_audit_YYYYMMDD.md\")\n+238         message_text = \"\\n\".join(lines)\n 236 \n-237         message_text = \"\\n\".join(summary_lines)\n-238         # 通过 OpenClaw 内置 message 工具发送\n-239         import subprocess\n 240         result = subprocess.run(\n 241             [\n-242                 sys.executable, \"-c\",\n-243                 f\"\"\"\n-244 import sys\n-245 sys.path.insert(0, '{SCRIPTS_DIR}')\n-246 # 延迟导入避免循环依赖\n-247 from run_strategy_param_auto_audit import _send_via_openclaw\n-248 _send_via_openclaw({json.dumps(message_text)!r})\n-249 \"\"\"\n+242                 \"openclaw\", \"message\", \"send\",\n+243                 \"--channel\", \"feishu\",\n+244                 \"--target\", \"user:ou_47c21eede907b0c4f9fd4d34519d84ae\",\n+245                 \"--message\", message_text,\n 250             ],\n 251             capture_output=True,\n 252             text=True,\n-253             timeout=15,\n+249             timeout=20,\n 254         )\n 255         return result.returncode == 0\n 256     except Exception:\n 257         return False\n 258 \n 259 \n-260 def _send_via_openclaw(message: str) -> None:\n-261     \"\"\"通过 OpenClaw 发送飞书消息（供 subprocess 调用）。\"\"\"\n-262     try:\n-263         from pathlib import Path\n-264         import urllib.request, urllib.error\n-265 \n-266         # 读取 openclaw.json 中的所有飞书账号配置\n-267         openclaw_cfg = Path.home() / \".openclaw\" / \"openclaw.json\"\n-268         data = json.loads(openclaw_cfg.read_text(encoding=\"utf-8\"))\n-269         feishu_cfg = data.get(\"channels\", {}).get(\"feishu\", {})\n-270         accounts = feishu_cfg.get(\"accounts\", {})\n-271         target_open_id = \"ou_47c21eede907b0c4f9fd4d34519d84ae\"\n-272 \n-273         # 尝试所有 app，找到能发给 target_open_id 的那个\n-274         tried = []\n-275         for acc_name, account in accounts.items():\n-276             app_id = account.get(\"appId\", \"\")\n-277             app_secret = account.get(\"appSecret\", \"\")\n-278             if not app_id or not app_secret:\n-279                 continue\n-280             tried.append(acc_name)\n-281             try:\n-282                 # 获取 token\n-283                 token_url = \"https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal\"\n-284                 token_req = urllib.request.Request(\n-285                     token_url,\n-286                     data=json.dumps({\"app_id\": app_id, \"app_secret\": app_secret}).encode(\"utf-8\"),\n-287                     headers={\"Content-Type\": \"application/json\"},\n-288                 )\n-289                 with urllib.request.urlopen(token_req, timeout=8) as resp:\n-290                     token_result = json.loads(resp.read())\n-291                 if token_result.get(\"code\") != 0:\n-292                     continue\n-293                 token = token_result[\"tenant_access_token\"]\n-294 \n-295                 # 发消息\n-296                 msg_url = \"https://open.feishu.cn/open-apis/im/v1/messages?receive_id_type=open_id\"\n-297                 msg_req = urllib.request.Request(\n-298                     msg_url,\n-299                     data=json.dumps({\n-300                         \"receive_id\": target_open_id,\n-301                         \"msg_type\": \"text\",\n-302                         \"content\": {\"text\": message},\n-303                     }).encode(\"utf-8\"),\n-304                     headers={\"Authorization\": f\"Bearer {token}\", \"Content-Type\": \"application/json\"},\n-305                 )\n-306                 with urllib.request.urlopen(msg_req, timeout=8) as resp:\n-307                     result = json.loads(resp.read())\n-308                 if result.get(\"code\") == 0:\n-309                     print(f\"OK via {acc_name}\")\n-310                     return\n-311             except Exception:\n-312                 pass\n-313 \n-314         print(f\"Failed, tried: {tried}\")\n-315     except Exception as e:\n-316         print(f\"Error: {e}\")\n-317 \n-318 \n 319 def main() -> None:\n 320     parser = argparse.ArgumentParser(description=\"策略参数自动巡检（轻量级）\")\n 321     parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n 322     parser.add_argument(\"--skip-feishu\", action=\"store_true\", help=\"跳过 Feishu 推送\")\n     ...","firstChangedLine":226},"isError":false,"timestamp":1775475139691}}
