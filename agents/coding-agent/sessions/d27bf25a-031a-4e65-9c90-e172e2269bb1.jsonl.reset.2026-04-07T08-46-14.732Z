{"type":"message","id":"299959c4","parentId":"0f4e804e","timestamp":"2026-04-06T13:33:58.936Z","message":{"role":"toolResult","toolCallId":"call_function_y8nvej56f96l_1","toolName":"exec","content":[{"type":"text","text":"from __future__ import annotations\n\nfrom typing import Any\n\n# ---------------------------------------------------------------------------\n# Panel-level runtime risk truth configuration\n# ---------------------------------------------------------------------------\n# 三盘重构核心：每盘使用独立的 runtime risk truth source，不再共享全局 halt。\n# 关键字段说明：\n#   strategy_max_drawdown_riskoff_pct : 本盘允许的最大回撤阈值（触发 risk_off）\n#   strategy_max_drawdown_halt_pct    : 本盘的硬停阈值（触发 halt_new_buy）\n#   halt_gate_source                   : 本盘的 halt gate 来源文件路径模板\n#   candidate_source_tag               : 本盘使用的候选股来源标签\n#   probe_budget_tag                   : 本盘使用的探测预算标签\n#\n# 当前全局风险真相（20260331）：strategy_max_drawdown_pct=24.51%，halt_new_buy=true\n# 三盘分层目标（首轮）：\n#   aggressive : strategy_max_drawdown_riskoff_pct=30%, halt_pct=35%  （容忍最高回撤）\n#   balanced   : strategy_max_drawdown_riskoff_pct=22%, halt_pct=28%\n#   defensive  : strategy_max_drawdown_riskoff_pct=10%, halt_pct=15%  （与原全局一致）\n# ---------------------------------------------------------------------------\n\nPROFILE_RUNTIME_RISK_CONFIG: dict[str, dict[str, Any]] = {\n    \"aggressive\": {\n        \"strategy_max_drawdown_riskoff_pct\": 30.0,\n        \"strategy_max_drawdown_halt_pct\": 35.0,\n        \"halt_gate_source\": \"runtime_risk_state_latest_aggressive.json\",\n        \"candidate_source_tag\": \"aggressive_high_elasticity\",\n        \"probe_budget_tag\": \"probe_budget_high\",\n        \"risk_off_exposure_cap\": 0.85,\n        \"hard_stop_enabled\": True,\n    },\n    \"balanced\": {\n        \"strategy_max_drawdown_riskoff_pct\": 22.0,\n        \"strategy_max_drawdown_halt_pct\": 28.0,\n        \"halt_gate_source\": \"runtime_risk_state_latest_balanced.json\",\n        \"candidate_source_tag\": \"balanced_mid_quality\",\n        \"probe_budget_tag\": \"probe_budget_mid\",\n        \"risk_off_exposure_cap\": 0.70,\n        \"hard_stop_enabled\": True,\n    },\n    \"defensive\": {\n        \"strategy_max_drawdown_riskoff_pct\": 10.0,\n        \"strategy_max_drawdown_halt_pct\": 15.0,\n        \"halt_gate_source\": \"runtime_risk_state_latest_defensive.json\",\n        \"candidate_source_tag\": \"defensive_top_quality\",\n        \"probe_budget_tag\": \"probe_budget_low\",\n        \"risk_off_exposure_cap\": 0.55,\n        \"hard_stop_enabled\": True,\n    },\n}\n\n\ndef profile_runtime_risk_config(profile_slug: str) -> dict[str, Any]:\n    \"\"\"Return the panel-level runtime risk config for a given profile slug.\n\n    Returns a copy so callers can mutate without affecting the registry.\n    Falls back to the defensive defaults if the slug is not found.\n    \"\"\"\n    default_cfg = PROFILE_RUNTIME_RISK_CONFIG.get(\"defensive\", {})\n    return dict(PROFILE_RUNTIME_RISK_CONFIG.get(profile_slug, default_cfg))\n\n\ndef is_panel_level_risk_enabled(profile_slug: str) -> bool:\n    \"\"\"Return True if this profile uses the new panel-level runtime risk truth.\"\"\"\n    return profile_slug in PROFILE_RUNTIME_RISK_CONFIG\n\n\nCURRENT_PAPER_PROFILE_SPECS: list[dict[str, Any]] = [\n    {\n        \"slug\": \"exit_dual\",\n        \"name\": \"双阈退出验证盘（paper_exit_dual）\",\n        \"short_name\": \"双阈退出验证盘\",\n        \"group\": \"exit_validation\",\n        \"group_label\": \"退出实验/失效盘\",\n    },\n    {\n        \"slug\": \"exit_tight\",\n        \"name\": \"紧阈退出验证盘（paper_exit_tight）\",\n        \"short_name\": \"紧阈退出验证盘\","}],"details":{"status":"completed","exitCode":0,"durationMs":14,"aggregated":"from __future__ import annotations\n\nfrom typing import Any\n\n# ---------------------------------------------------------------------------\n# Panel-level runtime risk truth configuration\n# ---------------------------------------------------------------------------\n# 三盘重构核心：每盘使用独立的 runtime risk truth source，不再共享全局 halt。\n# 关键字段说明：\n#   strategy_max_drawdown_riskoff_pct : 本盘允许的最大回撤阈值（触发 risk_off）\n#   strategy_max_drawdown_halt_pct    : 本盘的硬停阈值（触发 halt_new_buy）\n#   halt_gate_source                   : 本盘的 halt gate 来源文件路径模板\n#   candidate_source_tag               : 本盘使用的候选股来源标签\n#   probe_budget_tag                   : 本盘使用的探测预算标签\n#\n# 当前全局风险真相（20260331）：strategy_max_drawdown_pct=24.51%，halt_new_buy=true\n# 三盘分层目标（首轮）：\n#   aggressive : strategy_max_drawdown_riskoff_pct=30%, halt_pct=35%  （容忍最高回撤）\n#   balanced   : strategy_max_drawdown_riskoff_pct=22%, halt_pct=28%\n#   defensive  : strategy_max_drawdown_riskoff_pct=10%, halt_pct=15%  （与原全局一致）\n# ---------------------------------------------------------------------------\n\nPROFILE_RUNTIME_RISK_CONFIG: dict[str, dict[str, Any]] = {\n    \"aggressive\": {\n        \"strategy_max_drawdown_riskoff_pct\": 30.0,\n        \"strategy_max_drawdown_halt_pct\": 35.0,\n        \"halt_gate_source\": \"runtime_risk_state_latest_aggressive.json\",\n        \"candidate_source_tag\": \"aggressive_high_elasticity\",\n        \"probe_budget_tag\": \"probe_budget_high\",\n        \"risk_off_exposure_cap\": 0.85,\n        \"hard_stop_enabled\": True,\n    },\n    \"balanced\": {\n        \"strategy_max_drawdown_riskoff_pct\": 22.0,\n        \"strategy_max_drawdown_halt_pct\": 28.0,\n        \"halt_gate_source\": \"runtime_risk_state_latest_balanced.json\",\n        \"candidate_source_tag\": \"balanced_mid_quality\",\n        \"probe_budget_tag\": \"probe_budget_mid\",\n        \"risk_off_exposure_cap\": 0.70,\n        \"hard_stop_enabled\": True,\n    },\n    \"defensive\": {\n        \"strategy_max_drawdown_riskoff_pct\": 10.0,\n        \"strategy_max_drawdown_halt_pct\": 15.0,\n        \"halt_gate_source\": \"runtime_risk_state_latest_defensive.json\",\n        \"candidate_source_tag\": \"defensive_top_quality\",\n        \"probe_budget_tag\": \"probe_budget_low\",\n        \"risk_off_exposure_cap\": 0.55,\n        \"hard_stop_enabled\": True,\n    },\n}\n\n\ndef profile_runtime_risk_config(profile_slug: str) -> dict[str, Any]:\n    \"\"\"Return the panel-level runtime risk config for a given profile slug.\n\n    Returns a copy so callers can mutate without affecting the registry.\n    Falls back to the defensive defaults if the slug is not found.\n    \"\"\"\n    default_cfg = PROFILE_RUNTIME_RISK_CONFIG.get(\"defensive\", {})\n    return dict(PROFILE_RUNTIME_RISK_CONFIG.get(profile_slug, default_cfg))\n\n\ndef is_panel_level_risk_enabled(profile_slug: str) -> bool:\n    \"\"\"Return True if this profile uses the new panel-level runtime risk truth.\"\"\"\n    return profile_slug in PROFILE_RUNTIME_RISK_CONFIG\n\n\nCURRENT_PAPER_PROFILE_SPECS: list[dict[str, Any]] = [\n    {\n        \"slug\": \"exit_dual\",\n        \"name\": \"双阈退出验证盘（paper_exit_dual）\",\n        \"short_name\": \"双阈退出验证盘\",\n        \"group\": \"exit_validation\",\n        \"group_label\": \"退出实验/失效盘\",\n    },\n    {\n        \"slug\": \"exit_tight\",\n        \"name\": \"紧阈退出验证盘（paper_exit_tight）\",\n        \"short_name\": \"紧阈退出验证盘\",","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775482438925}}
