{"type":"message","id":"4887a5ae","parentId":"dce0825c","timestamp":"2026-04-06T13:25:49.774Z","message":{"role":"toolResult","toolCallId":"call_function_m2q4dfn668da_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport tempfile\nfrom pathlib import Path\nfrom typing import Any\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\n\n\ndef atomic_write_text(path: Path, content: str, *, encoding: str = \"utf-8\") -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with tempfile.NamedTemporaryFile(\"w\", encoding=encoding, dir=str(path.parent), delete=False) as handle:\n        handle.write(content)\n        tmp_path = Path(handle.name)\n    os.replace(tmp_path, path)\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef fmt_money(value: Any) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{float(value):,.2f}\"\n\n\ndef fmt_pct(value: Any) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{float(value):.2f}%\"\n\n\ndef fmt_int(value: Any) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return str(int(value))\n\n\ndef fmt_text(value: Any) -> str:\n    text = str(value or \"\").strip()\n    return text or \"-\"\n\n\ndef short_sources(paths: list[str]) -> str:\n    return \", \".join(Path(item).name for item in paths if item) or \"-\"\n\n\ndef build_profile_table(rows: list[dict[str, Any]]) -> list[str]:\n    lines = [\n        \"| 组合 | 状态 | 次日模式 | 净值 | 总收益 | 当日盈亏 | 回撤 | 持仓数 |\",\n        \"|------|------|----------|------:|-------:|---------:|-----:|-------:|\",\n    ]\n    for row in rows:\n        lines.append(\n            \"| {name} | {status} | {mode} | {nav} | {ret} | {pnl} | {dd} | {pos} |\".format(\n                name=row.get(\"profile_name\") or row.get(\"profile_slug\") or \"-\",\n                status=row.get(\"status\") or \"-\",\n                mode=row.get(\"tomorrow_mode\") or \"-\",\n                nav=fmt_money(row.get(\"nav\")),\n                ret=fmt_pct(row.get(\"total_return_pct\")),\n                pnl=fmt_money(row.get(\"day_pnl\")),\n                dd=fmt_pct(row.get(\"drawdown_pct\")),\n                pos=fmt_int(row.get(\"position_count\")),\n            )\n        )\n    return lines\n\n\ndef build_profile_holdings_lines(payload: dict[str, Any]) -> list[str]:\n    entries = payload.get(\"profile_holdings\") or []\n    if not entries:\n        return [\"- 当前无模拟盘持仓明细。\"]\n    lines: list[str] = []\n    for entry in entries:"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport tempfile\nfrom pathlib import Path\nfrom typing import Any\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\n\n\ndef atomic_write_text(path: Path, content: str, *, encoding: str = \"utf-8\") -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with tempfile.NamedTemporaryFile(\"w\", encoding=encoding, dir=str(path.parent), delete=False) as handle:\n        handle.write(content)\n        tmp_path = Path(handle.name)\n    os.replace(tmp_path, path)\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef fmt_money(value: Any) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{float(value):,.2f}\"\n\n\ndef fmt_pct(value: Any) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{float(value):.2f}%\"\n\n\ndef fmt_int(value: Any) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return str(int(value))\n\n\ndef fmt_text(value: Any) -> str:\n    text = str(value or \"\").strip()\n    return text or \"-\"\n\n\ndef short_sources(paths: list[str]) -> str:\n    return \", \".join(Path(item).name for item in paths if item) or \"-\"\n\n\ndef build_profile_table(rows: list[dict[str, Any]]) -> list[str]:\n    lines = [\n        \"| 组合 | 状态 | 次日模式 | 净值 | 总收益 | 当日盈亏 | 回撤 | 持仓数 |\",\n        \"|------|------|----------|------:|-------:|---------:|-----:|-------:|\",\n    ]\n    for row in rows:\n        lines.append(\n            \"| {name} | {status} | {mode} | {nav} | {ret} | {pnl} | {dd} | {pos} |\".format(\n                name=row.get(\"profile_name\") or row.get(\"profile_slug\") or \"-\",\n                status=row.get(\"status\") or \"-\",\n                mode=row.get(\"tomorrow_mode\") or \"-\",\n                nav=fmt_money(row.get(\"nav\")),\n                ret=fmt_pct(row.get(\"total_return_pct\")),\n                pnl=fmt_money(row.get(\"day_pnl\")),\n                dd=fmt_pct(row.get(\"drawdown_pct\")),\n                pos=fmt_int(row.get(\"position_count\")),\n            )\n        )\n    return lines\n\n\ndef build_profile_holdings_lines(payload: dict[str, Any]) -> list[str]:\n    entries = payload.get(\"profile_holdings\") or []\n    if not entries:\n        return [\"- 当前无模拟盘持仓明细。\"]\n    lines: list[str] = []\n    for entry in entries:","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775481949763}}
