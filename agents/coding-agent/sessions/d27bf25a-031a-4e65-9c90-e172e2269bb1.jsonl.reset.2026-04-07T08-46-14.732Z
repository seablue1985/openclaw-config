{"type":"message","id":"4a0ece08","parentId":"4df29703","timestamp":"2026-04-06T13:26:10.014Z","message":{"role":"toolResult","toolCallId":"call_function_kc915u77jn9y_1","toolName":"read","content":[{"type":"text","text":"def main() -> None:\n    parser = argparse.ArgumentParser(description=\"Build structured daily quant analysis JSON artifact\")\n    parser.add_argument(\"--date-tag\", default=\"\", help=\"Optional explicit trade date tag (YYYYMMDD)\")\n    args = parser.parse_args()\n\n    control_tower_path = resolve_latest_json(INPUT_FILES[\"control_tower\"], \"control_tower_daily_*.json\")\n    panel_path = resolve_latest_json(INPUT_FILES[\"strategy_performance_panel\"], \"strategy_performance_panel_*.json\")\n    gate_path = resolve_latest_json(INPUT_FILES[\"strategy_governance_gate\"], \"strategy_governance_gate_*.json\")\n    daily_audit_path = resolve_latest_json(INPUT_FILES[\"daily_strategy_audit\"], \"daily_strategy_audit_*.json\")\n    today_report_path = resolve_latest_json(INPUT_FILES[\"today_stock_strategy_report\"], \"today_stock_strategy_report_*.json\")\n    incident_path = resolve_latest_json(INPUT_FILES[\"incident_registry\"], \"incident_registry_*.json\")\n    closure_path = resolve_latest_json(INPUT_FILES[\"manual_review_closure_alert\"], \"manual_review_closure_alert_*.json\")\n    archive_path = resolve_latest_json(INPUT_FILES[\"role_output_archive\"], \"role_output_archive_*.json\")\n    remediation_path = latest_file(\"remediation_roadmap_alignment_report_*.json\")\n    detailed_report_path = latest_file(\"selfcheck_and_remediation_detailed_report_*.json\")\n\n    control_tower = load_json(control_tower_path)\n    panel = load_json(panel_path)\n    gate = load_json(gate_path)\n    daily_audit = load_json(daily_audit_path)\n    today_report = load_json(today_report_path)\n    incident_registry = load_json(incident_path)\n    manual_review_closure = load_json(closure_path)\n    role_output_archive = load_json(archive_path)\n    remediation = load_json(remediation_path)\n    detailed_report = load_json(detailed_report_path)\n\n    trade_date_tag = args.date_tag.strip() or guess_trade_date_tag(today_report, control_tower, daily_audit, remediation)\n    trade_date = to_trade_date(trade_date_tag)\n    generated_at = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n    required_payloads = {\n        \"control_tower\": control_tower,\n        \"strategy_performance_panel\": panel,\n        \"strategy_governance_gate\": gate,\n        \"daily_strategy_audit\": daily_audit,\n    }\n    required_paths = {\n        \"control_tower\": control_tower_path,\n        \"strategy_performance_panel\": panel_path,\n        \"strategy_governance_gate\": gate_path,\n        \"daily_strategy_audit\": daily_audit_path,\n    }\n    optional_payloads = {\n        \"today_stock_strategy_report\": today_report,\n        \"incident_registry\": incident_registry,\n        \"manual_review_closure_alert\": manual_review_closure,\n        \"role_output_archive\": role_output_archive,\n        \"remediation_roadmap\": remediation,\n        \"selfcheck_detailed_report\": detailed_report,\n    }\n    optional_paths = {\n        \"today_stock_strategy_report\": today_report_path,\n        \"incident_registry\": incident_path,\n        \"manual_review_closure_alert\": closure_path,\n        \"role_output_archive\": archive_path,\n        \"remediation_roadmap\": remediation_path,\n        \"selfcheck_detailed_report\": detailed_report_path,\n    }\n\n    required_inputs = {\n        label: file_entry(label, required_paths.get(label), required_payloads.get(label) or {}, required=True, trade_date_tag=trade_date_tag)\n        for label in REQUIRED_INPUT_LABELS\n    }\n    optional_inputs = {\n        label: file_entry(label, optional_paths.get(label), optional_payloads.get(label) or {}, required=False, trade_date_tag=trade_date_tag)\n        for label in [\n            \"today_stock_strategy_report\",\n            \"incident_registry\",\n            \"manual_review_closure_alert\",\n            \"role_output_archive\",\n            \"remediation_roadmap\",\n            \"selfcheck_detailed_report\",\n        ]\n    }\n\n    missing_required = [label for label, meta in required_inputs.items() if not meta[\"exists\"]]\n    mismatched_required = [label for label, meta in required_inputs.items() if meta[\"exists\"] and meta[\"freshness_status\"] == \"MISMATCH\"]\n    unknown_required = [label for label, meta in required_inputs.items() if meta[\"exists\"] and meta[\"freshness_status\"] == \"UNKNOWN\"]\n\n\n[100 more lines in file. Use offset=465 to continue.]"}],"isError":false,"timestamp":1775481970004}}
