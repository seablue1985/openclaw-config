{"type":"message","id":"ba97c537","parentId":"b7d6895f","timestamp":"2026-04-06T10:53:23.303Z","message":{"role":"toolResult","toolCallId":"call_function_w4c10w22mof6_1","toolName":"exec","content":[{"type":"text","text":"from __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom pathlib import Path\n\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nSCRIPTS_DIR = PROJECT_ROOT / \"scripts\"\nif str(SCRIPTS_DIR) not in sys.path:\n    sys.path.insert(0, str(SCRIPTS_DIR))\n\nimport experiment_registry as experiment_registry_mod\n\nfrom run_smallcap_chip_backtest import (\n    load_smallcap_config,\n    pick_liquid_symbols,\n    simulate,\n    warn_unsupported_config_keys,\n)\nfrom run_walk_forward import build_folds\n\n\ndef aggregate_metrics(frame: pd.DataFrame, prefix: str) -> dict:\n    if frame.empty:\n        return {\n            f\"{prefix}_folds\": 0,\n            f\"{prefix}_annual_return_pct_mean\": 0.0,\n            f\"{prefix}_sharpe_mean\": 0.0,\n            f\"{prefix}_max_drawdown_pct_mean\": 0.0,\n            f\"{prefix}_total_return_pct_mean\": 0.0,\n        }\n\n    return {\n        f\"{prefix}_folds\": int(len(frame)),\n        f\"{prefix}_annual_return_pct_mean\": round(float(frame[\"annual_return_pct\"].mean()), 2),\n        f\"{prefix}_sharpe_mean\": round(float(frame[\"sharpe\"].mean()), 3),\n        f\"{prefix}_max_drawdown_pct_mean\": round(float(frame[\"max_drawdown_pct\"].mean()), 2),\n        f\"{prefix}_total_return_pct_mean\": round(float(frame[\"total_return_pct\"].mean()), 2),\n    }\n\n\ndef infer_strategy_id(config_path: str | None, outdir_value: str | None) -> str:\n    combined = f\"{config_path or ''} {outdir_value or ''}\".lower()\n    if \"candidate_top50\" in combined or \"candidate\" in combined:\n        return \"smallcap_chip_v4_2_alpha_recover\"\n    if \"strategy_smallcap_chip.yaml\" in combined or \"current\" in combined:\n        return \"smallcap_chip_v4_1_alpha_guard\""}],"details":{"status":"completed","exitCode":0,"durationMs":12,"aggregated":"from __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom pathlib import Path\n\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nSCRIPTS_DIR = PROJECT_ROOT / \"scripts\"\nif str(SCRIPTS_DIR) not in sys.path:\n    sys.path.insert(0, str(SCRIPTS_DIR))\n\nimport experiment_registry as experiment_registry_mod\n\nfrom run_smallcap_chip_backtest import (\n    load_smallcap_config,\n    pick_liquid_symbols,\n    simulate,\n    warn_unsupported_config_keys,\n)\nfrom run_walk_forward import build_folds\n\n\ndef aggregate_metrics(frame: pd.DataFrame, prefix: str) -> dict:\n    if frame.empty:\n        return {\n            f\"{prefix}_folds\": 0,\n            f\"{prefix}_annual_return_pct_mean\": 0.0,\n            f\"{prefix}_sharpe_mean\": 0.0,\n            f\"{prefix}_max_drawdown_pct_mean\": 0.0,\n            f\"{prefix}_total_return_pct_mean\": 0.0,\n        }\n\n    return {\n        f\"{prefix}_folds\": int(len(frame)),\n        f\"{prefix}_annual_return_pct_mean\": round(float(frame[\"annual_return_pct\"].mean()), 2),\n        f\"{prefix}_sharpe_mean\": round(float(frame[\"sharpe\"].mean()), 3),\n        f\"{prefix}_max_drawdown_pct_mean\": round(float(frame[\"max_drawdown_pct\"].mean()), 2),\n        f\"{prefix}_total_return_pct_mean\": round(float(frame[\"total_return_pct\"].mean()), 2),\n    }\n\n\ndef infer_strategy_id(config_path: str | None, outdir_value: str | None) -> str:\n    combined = f\"{config_path or ''} {outdir_value or ''}\".lower()\n    if \"candidate_top50\" in combined or \"candidate\" in combined:\n        return \"smallcap_chip_v4_2_alpha_recover\"\n    if \"strategy_smallcap_chip.yaml\" in combined or \"current\" in combined:\n        return \"smallcap_chip_v4_1_alpha_guard\"","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775472803300}}
{"type":"message","id":"ff3a521c","parentId":"ba97c537","timestamp":"2026-04-06T10:53:23.309Z","message":{"role":"toolResult","toolCallId":"call_function_w4c10w22mof6_2","toolName":"exec","content":[{"type":"text","text":"from __future__ import annotations\n\nimport argparse\nimport copy\nimport json\nfrom dataclasses import dataclass\nfrom pathlib import Path\n\nimport pandas as pd\n\nfrom run_cross_sectional_backtest import build_matrices, load_config, pick_liquid_symbols, simulate\n\n\n@dataclass\nclass FoldRange:\n    fold_id: int\n    train_start: pd.Timestamp\n    train_end: pd.Timestamp\n    test_start: pd.Timestamp\n    test_end: pd.Timestamp\n\n\ndef build_folds(dates: pd.DatetimeIndex, train_months: int, test_months: int) -> list[FoldRange]:\n    if dates.empty:\n        return []\n\n    start = pd.Timestamp(dates.min()).normalize().replace(day=1)\n    last = pd.Timestamp(dates.max()).normalize()\n\n    folds: list[FoldRange] = []\n    fold_id = 1\n    cursor = start\n\n    while True:\n        train_start = cursor\n        train_end = (train_start + pd.DateOffset(months=train_months)) - pd.Timedelta(days=1)\n        test_start = train_end + pd.Timedelta(days=1)\n        test_end = (test_start + pd.DateOffset(months=test_months)) - pd.Timedelta(days=1)\n\n        if test_end > last:\n            break\n\n        folds.append(\n            FoldRange(\n                fold_id=fold_id,\n                train_start=train_start,\n                train_end=train_end,\n                test_start=test_start,\n                test_end=test_end,\n            )\n        )\n        fold_id += 1\n        cursor = cursor + pd.DateOffset(months=test_months)\n\n    return folds\n\n\ndef run_one_segment(close: pd.DataFrame, amount: pd.DataFrame, cfg: dict) -> dict | None:\n    close_seg = close.dropna(axis=1, how=\"all\")\n    amount_seg = amount[close_seg.columns]"}],"details":{"status":"completed","exitCode":0,"durationMs":16,"aggregated":"from __future__ import annotations\n\nimport argparse\nimport copy\nimport json\nfrom dataclasses import dataclass\nfrom pathlib import Path\n\nimport pandas as pd\n\nfrom run_cross_sectional_backtest import build_matrices, load_config, pick_liquid_symbols, simulate\n\n\n@dataclass\nclass FoldRange:\n    fold_id: int\n    train_start: pd.Timestamp\n    train_end: pd.Timestamp\n    test_start: pd.Timestamp\n    test_end: pd.Timestamp\n\n\ndef build_folds(dates: pd.DatetimeIndex, train_months: int, test_months: int) -> list[FoldRange]:\n    if dates.empty:\n        return []\n\n    start = pd.Timestamp(dates.min()).normalize().replace(day=1)\n    last = pd.Timestamp(dates.max()).normalize()\n\n    folds: list[FoldRange] = []\n    fold_id = 1\n    cursor = start\n\n    while True:\n        train_start = cursor\n        train_end = (train_start + pd.DateOffset(months=train_months)) - pd.Timedelta(days=1)\n        test_start = train_end + pd.Timedelta(days=1)\n        test_end = (test_start + pd.DateOffset(months=test_months)) - pd.Timedelta(days=1)\n\n        if test_end > last:\n            break\n\n        folds.append(\n            FoldRange(\n                fold_id=fold_id,\n                train_start=train_start,\n                train_end=train_end,\n                test_start=test_start,\n                test_end=test_end,\n            )\n        )\n        fold_id += 1\n        cursor = cursor + pd.DateOffset(months=test_months)\n\n    return folds\n\n\ndef run_one_segment(close: pd.DataFrame, amount: pd.DataFrame, cfg: dict) -> dict | None:\n    close_seg = close.dropna(axis=1, how=\"all\")\n    amount_seg = amount[close_seg.columns]","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775472803304}}
