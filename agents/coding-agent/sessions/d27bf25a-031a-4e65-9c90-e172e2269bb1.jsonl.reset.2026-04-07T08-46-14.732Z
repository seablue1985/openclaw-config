{"type":"message","id":"5c18063e","parentId":"215ffb01","timestamp":"2026-04-06T11:28:55.933Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The Feishu push uses the Feishu Open Platform API with app_id and app_secret from `openclaw.json`. It's not a webhook URL approach. I need to update my audit script's `push_feishu` function to use this same API approach.Let me update the `push_feishu` function in `run_strategy_param_auto_audit.py` to use the Feishu API like `feishu_push.py` does.","thinkingSignature":"8a71fde41e121e1db8c7b5cc051ca30761ecf0d6744858479a9180f5c551ea7e"},{"type":"text","text":"找到了！用的是飞书 Open Platform API，不是 webhook。现在更新审计脚本的推送函数：\n"},{"type":"toolCall","id":"call_function_pos64u2daclw_1","name":"edit","arguments":{"file_path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_strategy_param_auto_audit.py","old_string":"def push_feishu(report: str, alerts: list[dict]) -> bool:\n    \"\"\"推送 Feishu 消息。\"\"\"\n    try:\n        from feishu_client import feishu_post\n    except Exception:\n        pass\n    try:\n        import urllib.request\n        payload = json.dumps({\n            \"msg_type\": \"text\",\n            \"content\": {\"text\": report[:2000]}\n        }).encode(\"utf-8\")\n        # 尝试从环境变量获取飞书 webhook\n        webhook = Path.home() / \".openclaw\" / \"config\" / \"feishu_alert_webhook.txt\"\n        if not webhook.exists():\n            webhook = Path.home() / \".openclaw\" / \"config\" / \"feishu_webhook.txt\"\n        if webhook.exists():\n            url = webhook.read_text().strip()\n            req = urllib.request.Request(\n                url,\n                data=payload,\n                headers={\"Content-Type\": \"application/json\"},\n            )\n            with urllib.request.urlopen(req, timeout=10) as resp:\n                return resp.status == 200\n    except Exception:\n        pass\n    return False","new_string":"def push_feishu(report: str, alerts: list[dict]) -> bool:\n    \"\"\"通过飞书 Open Platform API 推送消息给张玲。\"\"\"\n    try:\n        import urllib.request\n        import urllib.error\n\n        # 读取 openclaw.json 中的飞书配置\n        openclaw_cfg = Path.home() / \".openclaw\" / \"openclaw.json\"\n        data = json.loads(openclaw_cfg.read_text(encoding=\"utf-8\"))\n        feishu_cfg = data.get(\"channels\", {}).get(\"feishu\", {})\n        accounts = feishu_cfg.get(\"accounts\", {})\n        account = accounts.get(feishu_cfg.get(\"defaultAccount\", \"main\"), {})\n        app_id = account.get(\"appId\", \"\")\n        app_secret = account.get(\"appSecret\", \"\")\n        open_id = \"ou_47c21eede907b0c4f9fd4d34519d84ae\"\n\n        if not app_id or not app_secret:\n            return False\n\n        # 获取 tenant_access_token\n        token_url = \"https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal\"\n        token_body = json.dumps({\"app_id\": app_id, \"app_secret\": app_secret}).encode(\"utf-8\")\n        token_req = urllib.request.Request(token_url, data=token_body, headers={\"Content-Type\": \"application/json\"})\n        with urllib.request.urlopen(token_req, timeout=10) as resp:\n            token_result = json.loads(resp.read())\n        if token_result.get(\"code\") != 0:\n            return False\n        token = token_result[\"tenant_access_token\"]\n\n        # 发送富文本消息（markdown）\n        msg_url = \"https://open.feishu.cn/open-apis/im/v1/messages?receive_id_type=open_id\"\n        headers = {\n            \"Authorization\": f\"Bearer {token}\",\n            \"Content-Type\": \"application/json\",\n        }\n\n        # 构造带告警emoji的消息摘要\n        severity_emoji = \"🔴\" if any(a[\"severity\"] == \"HIGH\" for a in alerts) else \"🟡\"\n        summary_lines = [f\"{severity_emoji} **策略参数巡检告警** | {datetime.now().strftime('%m/%d %H:%M')}\"]\n        for a in alerts:\n            sev = \"🔴\" if a[\"severity\"] == \"HIGH\" else \"🟡\"\n            summary_lines.append(f\"{sev} {a['type']}: {a['message'][:80]}\")\n        summary_lines.append(\"\")\n        summary_lines.append(f\"[查看完整报告](file://research/reports/strategy_param_auto_audit_{datetime.now().strftime('%Y%m%d')}.md)\")\n\n        content = {\"text\": \"\\n\".join(summary_lines)}\n        payload = json.dumps({\n            \"receive_id\": open_id,\n            \"msg_type\": \"text\",\n            \"content\": json.dumps(content),\n        }).encode(\"utf-8\")\n        msg_req = urllib.request.Request(msg_url, data=payload, headers=headers)\n        with urllib.request.urlopen(msg_req, timeout=10) as resp:\n            result = json.loads(resp.read())\n        return result.get(\"code\") == 0\n    except Exception:\n        return False"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":106501,"output":1106,"cacheRead":21467,"cacheWrite":0,"totalTokens":129074,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775474915278,"responseId":"0622cbe3dfefdcfdd61789d341cc555e"}}
