{"type":"message","id":"090eca75","parentId":"3af785ae","timestamp":"2026-04-06T11:30:52.302Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The message sending failed with HTTP 400. Let me debug this more. The token was fetched successfully. Let me print the actual response to understand what's wrong.","thinkingSignature":"006c161ae9f024c3d171daead07bf4bfb2a59f5f1d1172532622c50c6ddc52b5"},{"type":"toolCall","id":"call_function_a2ezya14f38v_1","name":"exec","arguments":{"command":"cd /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system && python3 -c \"\nimport json, urllib.request\nfrom pathlib import Path\n\nopenclaw_cfg = Path.home() / '.openclaw' / 'openclaw.json'\ndata = json.loads(openclaw_cfg.read_text(encoding='utf-8'))\nfeishu_cfg = data.get('channels', {}).get('feishu', {})\naccounts = feishu_cfg.get('accounts', {})\naccount = accounts.get(feishu_cfg.get('defaultAccount', 'main'), {})\napp_id = account.get('appId', '')\napp_secret = account.get('appSecret', '')\nopen_id = 'ou_47c21eede907b0c4f9fd4d34519d84ae'\n\n# Get token\ntoken_url = 'https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal'\ntoken_body = json.dumps({'app_id': app_id, 'app_secret': app_secret}).encode('utf-8')\nwith urllib.request.urlopen(urllib.request.Request(token_url, data=token_body, headers={'Content-Type': 'application/json'}), timeout=10) as resp:\n    result = json.loads(resp.read())\ntoken = result['tenant_access_token']\n\n# Send message - check error detail\nmsg_url = 'https://open.feishu.cn/open-apis/im/v1/messages?receive_id_type=open_id'\nheaders = {'Authorization': f'Bearer {token}', 'Content-Type': 'application/json'}\npayload = {\n    'receive_id': open_id,\n    'msg_type': 'text',\n    'content': {'text': 'test'},\n}\nreq = urllib.request.Request(msg_url, data=json.dumps(payload).encode('utf-8'), headers=headers)\ntry:\n    with urllib.request.urlopen(req, timeout=10) as resp:\n        result = json.loads(resp.read())\n    print('OK:', result)\nexcept urllib.error.HTTPError as e:\n    body = e.read().decode('utf-8')\n    print('HTTP Error:', e.code, body)\n\" 2>&1"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":106403,"output":502,"cacheRead":21467,"cacheWrite":0,"totalTokens":128372,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775475040686,"responseId":"0622cc60bad5ea6fcd8611c375f90b27"}}
