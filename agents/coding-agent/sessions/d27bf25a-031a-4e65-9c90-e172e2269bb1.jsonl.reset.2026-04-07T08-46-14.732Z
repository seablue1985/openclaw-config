{"type":"message","id":"c686531f","parentId":"6e250bd9","timestamp":"2026-04-06T13:54:12.440Z","message":{"role":"toolResult","toolCallId":"call_function_h4axg4chi0hk_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env bash\nset -euo pipefail\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\ncd \"$ROOT\"\nPYRUN=\"$ROOT/scripts/cron_python.sh\"\nDSA_ROOT=\"${LIVE_DSA_ROOT:-$ROOT/../daily_stock_analysis}\"\n\n# shellcheck disable=SC1091\nsource \"$ROOT/scripts/source_optional_env.sh\"\n\nexport LITELLM_LOCAL_MODEL_COST_MAP=true\n\"$PYRUN\" --runtime-only\n\nfor ENV_FILE in \\\n  \"$ROOT/.env.tushare\" \\\n  \"$DSA_ROOT/.env.tushare\"\ndo\n  source_optional_env_file \"$ENV_FILE\"\ndone\n\nDATE_TAG=\"${1:-$(date +%Y%m%d)}\"\nstatus=0\n\n\"$PYRUN\" scripts/live_chain_failure_tracker.py reset --date \"$DATE_TAG\" --source \"cron_close_review_v2\" >/dev/null\n\nhas_order_file() {\n  local date_tag=\"$1\"\n  local candidates=(\n    \"$ROOT/research/reports/live_orders_v1_${date_tag}.csv\"\n    \"$ROOT/research/reports/stock_signal_tickets_live_${date_tag}.csv\"\n    \"$ROOT/research/reports/stock_signal_tickets_${date_tag}.csv\"\n    \"$ROOT/research/reports/live_stock_signal_${date_tag}.csv\"\n    \"$ROOT/research/reports/stock_orders_signal_${date_tag}.csv\"\n  )\n  for fp in \"${candidates[@]}\"; do\n    [[ -f \"$fp\" ]] && return 0\n  done\n  compgen -G \"$ROOT/research/reports/joinquant_order_tickets_${date_tag}*.csv\" > /dev/null\n}\n\necho \"[1/7] sync execution reports date=${DATE_TAG}\"\nif \"$PYRUN\" scripts/sync_broker_api_data.py --date \"$DATE_TAG\"; then\n  echo \"[INFO] broker_api sync ok\"\nelse\n  code=$?\n  if [[ \"$code\" -eq 2 ]]; then\n    echo \"[INFO] broker_api skipped, fallback to ths app sync\"\n    \"$PYRUN\" scripts/live_chain_failure_tracker.py record --date \"$DATE_TAG\" --stage \"sync_execution_reports\" --severity \"YELLOW\" --reason \"broker_api_skipped_fallback_to_ths\" --detail \"broker_api exit=${code}\" --source \"cron_close_review_v2\" >/dev/null\n  else\n    echo \"[WARN] broker_api sync failed exit=${code}, fallback to ths app sync\"\n    \"$PYRUN\" scripts/live_chain_failure_tracker.py record --date \"$DATE_TAG\" --stage \"sync_execution_reports\" --severity \"YELLOW\" --reason \"broker_api_failed_fallback_to_ths\" --detail \"broker_api exit=${code}\" --source \"cron_close_review_v2\" >/dev/null\n  fi\n  if \"$PYRUN\" scripts/sync_ths_app_data.py --date \"$DATE_TAG\" --max-db 20; then\n    echo \"[INFO] ths app sync ok\"\n  else\n    code=$?\n    status=$code\n    echo \"[ERROR] ths app sync failed exit=${code}\"\n    \"$PYRUN\" scripts/live_chain_failure_tracker.py record --date \"$DATE_TAG\" --stage \"sync_execution_reports\" --severity \"RED\" --reason \"ths_app_sync_failed_after_broker_fallback\" --detail \"ths_app exit=${code}\" --blocking --source \"cron_close_review_v2\" >/dev/null\n  fi\nfi\n\necho \"[2/7] reconcile live execution date=${DATE_TAG}\"\nif has_order_file \"$DATE_TAG\"; then\n  if \"$PYRUN\" scripts/reconcile_live_execution_v1.py --date \"$DATE_TAG\" --no-strict; then\n    echo \"[INFO] reconcile ok\"\n  else\n    code=$?\n    status=$code\n    echo \"[WARN] reconcile failed exit=${code}, continue close review with explicit no-data signal\"\n    \"$PYRUN\" scripts/live_chain_failure_tracker.py record --date \"$DATE_TAG\" --stage \"reconcile_live_execution\" --severity \"RED\" --reason \"reconcile_failed_continue_with_explicit_no_data\" --detail \"reconcile exit=${code}\" --blocking --source \"cron_close_review_v2\" >/dev/null\n  fi\nelse\n  echo \"[WARN] reconcile skipped: missing same-day orders/tickets\"\n  status=22\n  \"$PYRUN\" scripts/live_chain_failure_tracker.py record --date \"$DATE_TAG\" --stage \"reconcile_live_execution\" --severity \"RED\" --reason \"missing_same_day_orders_or_tickets\" --detail \"reconcile skipped before close review\" --blocking --source \"cron_close_review_v2\" >/dev/null\nfi\n\necho \"[3/7] run_close_review_v2 date=${DATE_TAG}\"\n\"$PYRUN\" scripts/run_close_review_v2.py --date \"$DATE_TAG\" --skip-stock-analysis\n\necho \"[4/8] run_paper_trading_autoclose_core_v1 date=${DATE_TAG}\"\nTRADING_MODE=paper bash scripts/run_paper_trading_autoclose_core_v1.sh \"$DATE_TAG\"\n\necho \"[5/8] refresh_current_paper_profiles date=${DATE_TAG}\"\nif \"$PYRUN\" scripts/run_paper_exit_candidate_profiles.py --date \"$DATE_TAG\"; then\n  echo \"[INFO] exit candidate paper suite ok\"\nelse\n  code=$?\n  echo \"[WARN] exit candidate paper suite failed exit=${code}\"\n  \"$PYRUN\" scripts/live_chain_failure_tracker.py record --date \"$DATE_TAG\" --stage \"current_paper_refresh\" --severity \"YELLOW\" --reason \"exit_candidate_refresh_failed\" --detail \"run_paper_exit_candidate_profiles exit=${code}\" --source \"cron_close_review_v2\" >/dev/null\nfi\nif \"$PYRUN\" scripts/run_alpha55_paper_sim.py --date \"$DATE_TAG\" --cash 1000000; then\n  if \"$PYRUN\" scripts/generate_paper_trading_dashboard.py --config config/paper_live_alpha55_v1.json; then\n    echo \"[INFO] alpha55 paper refresh ok\"\n  else\n    code=$?\n    echo \"[WARN] alpha55 dashboard refresh failed exit=${code}\"\n    \"$PYRUN\" scripts/live_chain_failure_tracker.py record --date \"$DATE_TAG\" --stage \"current_paper_refresh\" --severity \"YELLOW\" --reason \"alpha55_dashboard_refresh_failed\" --detail \"generate_paper_trading_dashboard exit=${code}\" --source \"cron_close_review_v2\" >/dev/null\n  fi\nelse\n  code=$?\n  echo \"[WARN] alpha55 paper refresh failed exit=${code}\"\n  \"$PYRUN\" scripts/live_chain_failure_tracker.py record --date \"$DATE_TAG\" --stage \"current_paper_refresh\" --severity \"YELLOW\" --reason \"alpha55_refresh_failed\" --detail \"run_alpha55_paper_sim exit=${code}\" --source \"cron_close_review_v2\" >/dev/null\nfi\n\necho \"[6/8] run_strategy_probe_daily_suite date=${DATE_TAG}\"\nfor PROBE_GUARD_CONFIG in \\\n  \"$ROOT/config/strategy_probe_guard_defensive_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_balanced_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_aggressive_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_exit_dual_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_exit_tight_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_alpha55_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_breadth_strict_oos_v1.json\" \\\n  \"$ROOT/config/strategy_probe_guard_breadth_aggressive_v1.json\"\ndo\n  if [[ -f \"$PROBE_GUARD_CONFIG\" ]]; then\n    if ./scripts/run_strategy_probe_daily_suite.sh \"$DATE_TAG\" \"$PROBE_GUARD_CONFIG\"; then\n      :\n    else\n      code=$?\n      echo \"[WARN] probe daily suite failed config=${PROBE_GUARD_CONFIG} exit=${code}\"\n      \"$PYRUN\" scripts/live_chain_failure_tracker.py record --date \"$DATE_TAG\" --stage \"strategy_probe_daily_suite\" --severity \"YELLOW\" --reason \"probe_daily_suite_failed\" --detail \"${PROBE_GUARD_CONFIG} exit=${code}\" --source \"cron_close_review_v2\" >/dev/null\n    fi\n  fi\ndone\n\necho \"[7/8] refresh_control_tower date=${DATE_TAG}\"\n\"$PYRUN\" scripts/generate_control_tower_daily.py\n\necho \"[8/8] push_paper_trade_fill_to_feishu date=${DATE_TAG}\"\nif ! \"$PYRUN\" scripts/push_paper_trade_fill_to_feishu.py --date \"$DATE_TAG\" --profile aggressive; then\n  echo \"[WARN] push_paper_trade_fill_to_feishu failed date=${DATE_TAG}\" >&2\nfi\n\nexit \"$status\""}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"#!/usr/bin/env bash\nset -euo pipefail\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\ncd \"$ROOT\"\nPYRUN=\"$ROOT/scripts/cron_python.sh\"\nDSA_ROOT=\"${LIVE_DSA_ROOT:-$ROOT/../daily_stock_analysis}\"\n\n# shellcheck disable=SC1091\nsource \"$ROOT/scripts/source_optional_env.sh\"\n\nexport LITELLM_LOCAL_MODEL_COST_MAP=true\n\"$PYRUN\" --runtime-only\n\nfor ENV_FILE in \\\n  \"$ROOT/.env.tushare\" \\\n  \"$DSA_ROOT/.env.tushare\"\ndo\n  source_optional_env_file \"$ENV_FILE\"\ndone\n\nDATE_TAG=\"${1:-$(date +%Y%m%d)}\"\nstatus=0\n\n\"$PYRUN\" scripts/live_c