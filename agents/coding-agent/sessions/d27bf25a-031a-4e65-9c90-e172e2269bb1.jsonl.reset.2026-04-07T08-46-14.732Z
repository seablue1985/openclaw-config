{"type":"message","id":"6fc3bc31","parentId":"e5ad305d","timestamp":"2026-04-06T10:53:45.859Z","message":{"role":"toolResult","toolCallId":"call_function_f9xy9csxsox0_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom collections import Counter\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nSCRIPTS_DIR = PROJECT_ROOT / \"scripts\"\nif str(SCRIPTS_DIR) not in sys.path:\n    sys.path.insert(0, str(SCRIPTS_DIR))\n\nimport run_qlib_breadth_long_turnover_hardcap_relaxed_scan as base_scan\nimport run_qlib_breadth_sanity_check as sanity\nimport audit_future_leak_walkforward as leak_audit\n\n\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nACCOUNT_NAV = 900000\nGLOBAL_START = \"2015-01-05\"\nGLOBAL_END = \"2026-03-03\"\n\n\ndef parse_float_list(text: str) -> list[float]:\n    values: list[float] = []\n    for item in str(text).split(\",\"):\n        item = item.strip()\n        if item:\n            values.append(float(item))\n    return values\n\n\ndef parse_int_list(text: str) -> list[int]:\n    values: list[int] = []\n    for item in str(text).split(\",\"):\n        item = item.strip()\n        if item:\n            values.append(int(item))\n    return values\n\n\ndef init_qlib() -> None:\n    import qlib\n    from qlib.config import C\n\n    C[\"joblib_backend\"] = \"sequential\"\n    C[\"kernels\"] = 1\n    qlib.init(provider_uri=str(sanity.QLIB_LONG_ROOT), region=\"cn\")\n\n\ndef build_trade_calendar() -> pd.DatetimeIndex:\n    breadth = sanity.load_market_breadth()\n    dates = pd.DatetimeIndex(breadth.index.unique()).sort_values()\n    return dates[(dates >= pd.Timestamp(GLOBAL_START)) & (dates <= pd.Timestamp(GLOBAL_END))]\n\n\ndef align_trade_date(calendar: pd.DatetimeIndex, target: pd.Timestamp, side: str) -> pd.Timestamp | None:\n    if side == \"left\":\n        candidates = calendar[calendar >= target]\n        return candidates[0] if len(candidates) else None\n    if side == \"right\":\n        candidates = calendar[calendar <= target]\n        return candidates[-1] if len(candidates) else None\n    raise ValueError(f\"unsupported side: {side}\")\n\n\ndef generate_windows(\n    calendar: pd.DatetimeIndex,\n    *,\n    train_years: int,\n    valid_years: int,\n    test_months: int,\n    step_months: int,"}],"details":{"status":"completed","exitCode":0,"durationMs":14,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom collections import Counter\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nimport numpy as np\nimport pandas as pd\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nSCRIPTS_DIR = PROJECT_ROOT / \"scripts\"\nif str(SCRIPTS_DIR) not in sys.path:\n    sys.path.insert(0, str(SCRIPTS_DIR))\n\nimport run_qlib_breadth_long_turnover_hardcap_relaxed_scan as base_scan\nimport run_qlib_breadth_sanity_check as sanity\nimport audit_future_leak_walkforward as leak_audit\n\n\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nACCOUNT_NAV = 900000\nGLOBAL_START = \"2015-01-05\"\nGLOBAL_END = \"2026-03-03\"\n\n\ndef parse_float_list(text: str) -> list[float]:\n    values: list[float] = []\n    for item in str(text).split(\",\"):\n        item = item.strip()\n        if item:\n            values.append(float(item))\n    return values\n\n\ndef parse_int_list(text: str) -> list[int]:\n    values: list[int] = []\n    for item in str(text).split(\",\"):\n        item = item.strip()\n        if item:\n            values.append(int(item))\n    return values\n\n\ndef init_qlib() -> None:\n    import qlib\n    from qlib.config import C\n\n    C[\"joblib_backend\"] = \"sequential\"\n    C[\"kernels\"] = 1\n    qlib.init(provider_uri=str(sanity.QLIB_LONG_ROOT), region=\"cn\")\n\n\ndef build_trade_calendar() -> pd.DatetimeIndex:\n    breadth = sanity.load_market_breadth()\n    dates = pd.DatetimeIndex(breadth.index.unique()).sort_values()\n    return dates[(dates >= pd.Timestamp(GLOBAL_START)) & (dates <= pd.Timestamp(GLOBAL_END))]\n\n\ndef align_trade_date(calendar: pd.DatetimeIndex, target: pd.Timestamp, side: str) -> pd.Timestamp | None:\n    if side == \"left\":\n        candidates = calendar[calendar >= target]\n        return candidates[0] if len(candidates) else None\n    if side == \"right\":\n        candidates = calendar[calendar <= target]\n        return candidates[-1] if len(candidates) else None\n    raise ValueError(f\"unsupported side: {side}\")\n\n\ndef generate_windows(\n    calendar: pd.DatetimeIndex,\n    *,\n    train_years: int,\n    valid_years: int,\n    test_months: int,\n    step_months: int,","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775472825852}}
{"type":"message","id":"e6f17456","parentId":"6fc3bc31","timestamp":"2026-04-06T10:54:01.285Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good. Now I understand the structure. The `run_aggressive_walkforward_validation.py` script:\n1. Uses qlib breadth/turnover strategy\n2. Runs a grid search over parameters\n3. Does walk-forward validation\n4. Produces a summary JSON with OOS metrics\n\nFor the auto-audit cron, I need to design something that:\n1. Runs periodically (e.g., weekly on weekends or after market close on Fridays)\n2. Checks if the latest OOS window (the most recent 6-month test window) shows drift from the historical baseline\n3. If significant drift is detected, triggers a new full walk-forward run\n\n\n4. Alerts via Feishu if a better parameter set is found\n\nThe core metrics to watch are the most recent OOS Sharpe ratio, annual return, and max drawdown, plus whether the latest window diverges materially from the 9-window historical average. If drift crosses a threshold, I'd run a new walk-forward scan and update the registry with better parameters if found.\n\nFor the alerting logic, I should flag when the latest window Sharpe drops below 0.8 or annual return turns negative, and notify when a new best parameter set beats the current benchmark by more than 5%.\n\nThe cron should run weekly on weekends since that's when new market data becomes available, using the previous week's close. Now I need to build out the script itself—checking the latest window metrics, comparing against baselines, triggering a walk-forward rescan if there's meaningful drift, and posting results to Feishu. Let me examine how the current walk-forward script is structured to understand what I'm working with.","thinkingSignature":"db9a5fa2893b9680a6619c911ac86e7f4ff3edafb75042358b11c5445a37063e"},{"type":"toolCall","id":"call_function_tjphy1cgljnc_1","name":"exec","arguments":{"command":"grep -n \"def main\\|argparse\\|if __name__\" /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_aggressive_walkforward_validation.py | head -20"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":102257,"output":407,"cacheRead":21467,"cacheWrite":0,"totalTokens":124131,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775472825861,"responseId":"0622c3ba2f3541cd2b8e5aef519305f9"}}
{"type":"message","id":"228060e1","parentId":"e6f17456","timestamp":"2026-04-06T10:54:01.327Z","message":{"role":"toolResult","toolCallId":"call_function_tjphy1cgljnc_1","toolName":"exec","content":[{"type":"text","text":"4:import argparse\n334:def build_param_grid(args: argparse.Namespace) -> list[dict[str, Any]]:\n457:def main() -> None:\n458:    parser = argparse.ArgumentParser(description=\"进取宽度策略 walk-forward 验证\")\n605:if __name__ == \"__main__\":"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"4:import argparse\n334:def build_param_grid(args: argparse.Namespace) -> list[dict[str, Any]]:\n457:def main() -> None:\n458:    parser = argparse.ArgumentParser(description=\"进取宽度策略 walk-forward 验证\")\n605:if __name__ == \"__main__\":","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775472841320}}
{"type":"message","id":"34e57b94","parentId":"228060e1","timestamp":"2026-04-06T10:54:10.502Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I have a clear picture. Let me design the cron:\n\nThe `run_aggressive_walkforward_validation.py` takes a long time to run (it's doing a full grid search across 9 windows). I shouldn't run this every week - only when there's a signal.\n\nThe auto-audit cron should:\n1. **Quick check** (runs every Saturday 10am):\n   - Load the latest aggressive walk-forward summary\n   - Extract the most recent OOS window metrics (the last completed 6-month test window)\n   - Compare against baseline (v4.3: Sharpe 1.441, ann 58.48%)\n   - If the latest window shows concerning signals (Sharpe < 0.5 or ann < 20% or mdd > 15%), trigger an alert and potentially a rescan\n\n2. **Full rescan** (only triggered manually or by the quick check):\n   - Run the full walk-forward validation\n   - Update the registry if better params found\n\nI should create a lightweight monitoring script that runs weekly without the overhead of a full rescan. Looking at the existing scripts, the `scan_high_yield_aggressive.py` seems like a good candidate to check out.","thinkingSignature":"33cccce23a7bb098eb5d8fe3f90360e05f3bbb67b8e81911744a55897bf5001e"},{"type":"toolCall","id":"call_function_2l38teo2o3cb_1","name":"exec","arguments":{"command":"head -60 /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/scan_high_yield_aggressive.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":102740,"output":307,"cacheRead":21467,"cacheWrite":0,"totalTokens":124514,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775472841329,"responseId":"0622c3c9dc08a3c9e5b849399e51d7f7"}}
{"type":"message","id":"eeec78d5","parentId":"34e57b94","timestamp":"2026-04-06T10:54:10.531Z","message":{"role":"toolResult","toolCallId":"call_function_2l38teo2o3cb_1","toolName":"exec","content":[{"type":"text","text":"\"\"\"\n激进高收益参数扫描\n在现有最优参数基础上，扩展风险敞口，追求更高年化收益。\n\n主要扩展方向：\n1. risk_degree: 0.55 → 0.60~0.90（更高集中度）\n2. topk: 10 → 5~10（更集中持仓）\n3. 更激进的 breadth profile（高位满仓）\n4. 更低的 min_score_improve（接受更弱信号）\n5. 更激进的 turnover cap（更高摩擦换手）\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\n\nimport pandas as pd\n\nROOT = Path(__file__).resolve().parents[1]\nSCRIPTS_DIR = ROOT / \"scripts\"\nif str(SCRIPTS_DIR) not in sys.path:\n    sys.path.insert(0, str(SCRIPTS_DIR))\n\nimport run_qlib_breadth_long_turnover_hardcap_relaxed_scan as base_scan\nimport run_qlib_breadth_robust_optimize_long as longopt\nimport run_qlib_breadth_sanity_check as sanity\n\nREPORT_DIR = ROOT / \"research\" / \"reports\"\n\n\ndef main() -> None:\n    REPORT_DIR.mkdir(parents=True, exist_ok=True)\n    date_tag = datetime.now().strftime(\"%Y%m%d_%H%M\")\n\n    print(\"加载市场宽度数据...\")\n    breadth = sanity.load_market_breadth()\n\n    print(\"加载/训练 Qlib Alpha158 预测...\")\n    pred, start_date, end_date = longopt.train_prediction_long(\"2015-01-05\", \"2026-03-03\")\n    pred_shifted = sanity.shift_signal_one_day(pred)\n    print(f\"预测区间: {start_date} ~ {end_date}\")\n    print(f\"预测样本数: {len(pred_shifted)}\")\n\n    # 激进参数空间\n    # 主要变化：更高的 risk_degree、更小的 topk、更宽松的 min_score_improve\n    param_grid: list[tuple] = []\n    for topk in [5, 6, 7, 8, 10]:\n        for n_drop in [1, 2]:  # 多试 n_drop=2\n            for hold_thresh in [3, 4, 5]:\n                for risk_degree in [0.60, 0.65, 0.70, 0.75, 0.80, 0.85, 0.90]:\n                    for min_score_improve in [0.0, 0.0002]:  # 放松信号阈值\n                        for daily_turnover_cap in [0.22, 0.28, 0.35]:  # 允许更高换手\n                            for profile in [\n                                # 更激进的 breadth profile\n                                {\"low_th\": 0.50, \"mid_th\": 0.58, \"low_scale\": 0.30, \"mid_scale\": 0.60, \"high_scale\": 1.00},  # 高位满仓\n                                {\"low_th\": 0.52, \"mid_th\": 0.60, \"low_scale\": 0.30, \"mid_scale\": 0.55, \"high_scale\": 0.95},  # 稍微保守\n                                {\"low_th\": 0.45, \"mid_th\": 0.55, \"low_scale\": 0.40, \"mid_scale\": 0.70, \"high_scale\": 1.00},  # 更激进"}],"details":{"status":"completed","exitCode":0,"durationMs":13,"aggregated":"\"\"\"\n激进高收益参数扫描\n在现有最优参数基础上，扩展风险敞口，追求更高年化收益。\n\n主要扩展方向：\n1. risk_degree: 0.55 → 0.60~0.90（更高集中度）\n2. topk: 10 → 5~10（更集中持仓）\n3. 更激进的 breadth profile（高位满仓）\n4. 更低的 min_score_improve（接受更弱信号）\n5. 更激进的 turnover cap（更高摩擦换手）\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\n\nimport pandas as pd\n\nROOT = Path(__file__).resolve().parents[1]\nSCRIPTS_DIR = ROOT / \"scripts\"\nif str(SCRIPTS_DIR) not in sys.path:\n    sys.path.insert(0, str(SCRIPTS_DIR))\n\nimport run_qlib_breadth_long_turnover_hardcap_relaxed_scan as base_scan\nimport run_qlib_breadth_robust_optimize_long as longopt\nimport run_qlib_breadth_sanity_check as sanity\n\nREPORT_DIR = ROOT / \"research\" / \"reports\"\n\n\ndef main() -> None:\n    REPORT_DIR.mkdir(parents=True, exist_ok=True)\n    date_tag = datetime.now().strftime(\"%Y%m%d_%H%M\")\n\n    print(\"加载市场宽度数据...\")\n    breadth = sanity.load_market_breadth()\n\n    print(\"加载/训练 Qlib Alpha158 预测...\")\n    pred, start_date, end_date = longopt.train_prediction_long(\"2015-01-05\", \"2026-03-03\")\n    pred_shifted = sanity.shift_signal_one_day(pred)\n    print(f\"预测区间: {start_date} ~ {end_date}\")\n    print(f\"预测样本数: {len(pred_shifted)}\")\n\n    # 激进参数空间\n    # 主要变化：更高的 risk_degree、更小的 topk、更宽松的 min_score_improve\n    param_grid: list[tuple] = []\n    for topk in [5, 6, 7, 8, 10]:\n        for n_drop in [1, 2]:  # 多试 n_drop=2\n            for hold_thresh in [3, 4, 5]:\n                for risk_degree in [0.60, 0.65, 0.70, 0.75, 0.80, 0.85, 0.90]:\n                    for min_score_improve in [0.0, 0.0002]:  # 放松信号阈值\n                        for daily_turnover_cap in [0.22, 0.28, 0.35]:  # 允许更高换手\n                            for profile in [\n                                # 更激进的 breadth profile\n                                {\"low_th\": 0.50, \"mid_th\": 0.58, \"low_scale\": 0.30, \"mid_scale\": 0.60, \"high_scale\": 1.00},  # 高位满仓\n                                {\"low_th\": 0.52, \"mid_th\": 0.60, \"low_scale\": 0.30, \"mid_scale\": 0.55, \"high_scale\": 0.95},  # 稍微保守\n                                {\"low_th\": 0.45, \"mid_th\": 0.55, \"low_scale\": 0.40, \"mid_scale\": 0.70, \"high_scale\": 1.00},  # 更激进","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775472850524}}
{"type":"message","id":"1dd4b010","parentId":"eeec78d5","timestamp":"2026-04-06T10:55:10.289Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I have a good understanding. Let me design the auto-audit cron properly.\n\nThe auto-audit should be a lightweight monitoring script that:\n1. Runs every Saturday (after the last trading day of the week)\n2. Loads the latest walk-forward summary\n3. Checks the most recent OOS window (which represents the latest market conditions)\n4. Alerts if there's drift or new best params\n5. Optionally triggers a full rescan if significant drift is detected\n\nLet me create the cron script `run_strategy_param_auto_audit.py`.\n\nKey design decisions:\n- **Frequency**: Weekly on Saturday at 10am (after market close on Friday)\n- **Quick check**: Load latest summary, check latest window metrics vs baseline\n\n\n- **Alert thresholds**: I'll flag if the latest OOS Sharpe drops below 0.8, annual returns fall below 40%, or max drawdown exceeds 12%\n- **Decision tree**: If any alert fires, I'll push a Feishu notification, and if the latest OOS performance is notably better than the current baseline, I'll suggest a rescan","thinkingSignature":"926ca48f86bbc2bde4b31ddd2e9a561097b0bcfa3a829a828bd98abd0429e7ad"},{"type":"text","text":"好，设计思路清晰了。我来写一个轻量级的参数监控脚本：\n"},{"type":"toolCall","id":"call_function_x0fi9frjwy1g_1","name":"exec","arguments":{"command":"cat > /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_strategy_param_auto_audit.py << 'PYEOF'\n#!/usr/bin/env python3\n\"\"\"\n策略参数自动巡检\n- 每周六运行（节后首个交易日不运行）\n- 轻量级：只读取最新 walk-forward 结果，不跑完整回测\n- 对比最新 OOS 窗口 vs 基准，发现异常则推送 Feishu 告警\n- 触发阈值：最新 Sharpe < 0.8 或 年化 < 40% 或 回撤 > 12%\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nSCRIPTS_DIR = PROJECT_ROOT / \"scripts\"\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nWORKSPACE_ROOT = PROJECT_ROOT.parent.parent\n\nsys.path.insert(0, str(WORKSPACE_ROOT / \"scripts\"))\n\n# 基准（v4.3进取型）\nBENCHMARK = {\n    \"strategy_id\": \"smallcap_chip_v4_3_aggressive\",\n    \"oos_annual_mean\": 58.48,\n    \"oos_sharpe_mean\": 1.441,\n    \"oos_mdd_mean\": 9.05,\n    \"positive_windows\": 9,\n    \"total_windows\": 9,\n}\n\n# 告警阈值\nALERT_THRESHOLDS = {\n    \"sharpe_min\": 0.8,      # 最新窗口 Sharpe 低于此值告警\n    \"annual_min_pct\": 40.0,  # 最新窗口年化低于此值告警\n    \"mdd_max_pct\": 12.0,     # 最新窗口回撤高于此值告警\n    \"sharpe_drift\": 0.5,     # Sharpe 较均值下降超过此值告警\n}\n\n\ndef find_latest_summary() -> Path | None:\n    \"\"\"找到最新的 aggressive walk-forward summary JSON。\"\"\"\n    summaries = sorted(\n        REPORT_DIR.glob(\"aggressive_walkforward_summary_*.json\"),\n        key=lambda p: p.stat().st_mtime,\n        reverse=True,\n    )\n    for s in summaries:\n        # 跳过临时/调试文件\n        if \"_audit\" in s.name or \"_temp\" in s.name:\n            continue\n        return s\n    return None\n\n\ndef load_latest_summary(path: Path) -> dict | None:\n    try:\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return None\n\n\ndef extract_latest_window(d: dict) -> dict | None:\n    \"\"\"从 summary 中提取最晚的一个 test window。\"\"\"\n    windows = d.get(\"windows\", [])\n    if not windows:\n        return None\n    # 按 test_end 排序，取最晚的\n    latest = max(windows, key=lambda w: w.get(\"test_end\", \"\"))\n    return latest\n\n\ndef compute_alerts(latest_window: dict, summary: dict) -> list[dict]:\n    \"\"\"计算告警项。\"\"\"\n    alerts = []\n    s = summary.get(\"summary\", {})\n    mean_sharpe = s.get(\"mean_test_sharpe_daily\", 0)\n    mean_annual = s.get(\"mean_test_annual_pct\", 0)\n    mean_mdd = s.get(\"mean_test_mdd_pct\", 0)\n\n    w_sharpe = latest_window.get(\"test_sharpe_daily\", 0)\n    w_annual = latest_window.get(\"test_annual_pct\", 0)\n    w_mdd = latest_window.get(\"test_mdd_pct\", 0)\n    w_start = latest_window.get(\"test_start\", \"?\")\n    w_end = latest_window.get(\"test_end\", \"?\")\n\n    # 条件1：最新窗口 Sharpe < 阈值\n    if w_sharpe < ALERT_THRESHOLDS[\"sharpe_min\"]:\n        alerts.append({\n            \"type\": \"sharpe_low\",\n            \"severity\": \"HIGH\",\n            \"message\": f\"最新窗口 Sharpe {w_sharpe:.3f} < 阈值 {ALERT_THRESHOLDS['sharpe_min']}（窗口：{w_start} ~ {w_end}）\",\n            \"detail\": f\" Sharpe={w_sharpe:.3f}，均值基准={mean_sharpe:.3f}\",\n        })\n\n    # 条件2：最新窗口年化 < 阈值\n    if w_annual < ALERT_THRESHOLDS[\"annual_min_pct\"]:\n        alerts.append({\n            \"type\": \"annual_low\",\n            \"severity\": \"HIGH\",\n            \"message\": f\"最新窗口年化 {w_annual:.2f}% < 阈值 {ALERT_THRESHOLDS['annual_min_pct']}%（窗口：{w_start} ~ {w_end}）\",\n            \"detail\": f\" 年化={w_annual:.2f}%，均值基准={mean_annual:.2f}%\",\n        })\n\n    # 条件3：最新窗口回撤 > 阈值\n    if w_mdd > ALERT_THRESHOLDS[\"mdd_max_pct\"]:\n        alerts.append({\n            \"type\": \"mdd_high\",\n            \"severity\": \"HIGH\",\n            \"message\": f\"最新窗口回撤 {w_mdd:.2f}% > 阈值 {ALERT_THRESHOLDS['mdd_max_pct']}%（窗口：{w_start} ~ {w_end}）\",\n            \"detail\": f\" 回撤={w_mdd:.2f}%，均值基准={mean_mdd:.2f}%\",\n        })\n\n    # 条件4：Sharpe 漂移（最新窗口 vs 均值下降超过阈值）\n    drift = mean_sharpe - w_sharpe\n    if drift > ALERT_THRESHOLDS[\"sharpe_drift\"]:\n        alerts.append({\n            \"type\": \"sharpe_drift\",\n            \"severity\": \"MEDIUM\",\n            \"message\": f\"Sharpe 漂移告警：均值 {mean_sharpe:.3f}，最新 {w_sharpe:.3f}，下降 {drift:.3f}\",\n            \"detail\": f\"（阈值：下降超过 {ALERT_THRESHOLDS['sharpe_drift']}）\",\n        })\n\n    return alerts\n\n\ndef build_report(latest_window: dict, summary: dict, alerts: list[dict], summary_path: Path) -> str:\n    s = summary.get(\"summary\", {})\n    w_start = latest_window.get(\"test_start\", \"?\")\n    w_end = latest_window.get(\"test_end\", \"?\")\n    w_sharpe = latest_window.get(\"test_sharpe_daily\", 0)\n    w_annual = latest_window.get(\"test_annual_pct\", 0)\n    w_mdd = latest_window.get(\"test_mdd_pct\", 0)\n\n    lines = [\n        \"## 📊 策略参数自动巡检汇报\",\n        \"\",\n        f\"**巡检时间**: {datetime.now().strftime('%Y-%m-%d %H:%M')}\",\n        f\"**数据来源**: `{summary_path.name}`\",\n        \"\",\n        \"### 最新测试窗口\",\n        f\"- 区间：{w_start} ~ {w_end}\",\n        f\"- Sharpe：{w_sharpe:.3f}\",\n        f\"- 年化收益：{w_annual:.2f}%\",\n        f\"- 最大回撤：{w_mdd:.2f}%\",\n        \"\",\n        \"### 基准（v4.3进取型）\",\n        f\"- OOS 均值年化：{BENCHMARK['oos_annual_mean']:.2f}%\",\n        f\"- OOS 均值 Sharpe：{BENCHMARK['oos_sharpe_mean']:.3f}\",\n        f\"- OOS 均值回撤：{BENCHMARK['oos_mdd_mean']:.2f}%\",\n        f\"- 正收益窗口：{BENCHMARK['positive_windows']}/{BENCHMARK['total_windows']}\",\n        \"\",\n        \"### 全部窗口均值（参考）\",\n        f\"- 年化收益：{s.get('mean_test_annual_pct', '?'):.2f}%\",\n        f\"- Sharpe：{s.get('mean_test_sharpe_daily', '?'):.3f}\",\n        f\"- 回撤：{s.get('mean_test_mdd_pct', '?'):.2f}%\",\n        f\"- 正收益窗口：{s.get('positive_test_windows', '?')}/{s.get('window_count', '?')}\",\n        \"\",\n    ]\n\n    if alerts:\n        lines.append(\"### 🔴 告警项\")\n        for a in alerts:\n            sev = \"🔴\" if a[\"severity\"] == \"HIGH\" else \"🟡\"\n            lines.append(f\"{sev} **{a['type']}**: {a['message']}{a['detail']}\")\n        lines.append(\"\")\n        lines.append(\"**建议**：触发完整 walk-forward 重新扫描，或在下次人工复盘时重点关注。\")\n    else:\n        lines.append(\"### ✅ 无告警\")\n        lines.append(\"最新窗口各项指标均处于正常范围，策略运行平稳。\")\n\n    return \"\\n\".join(lines)\n\n\ndef push_feishu(report: str, alerts: list[dict]) -> bool:\n    \"\"\"推送 Feishu 消息。\"\"\"\n    try:\n        from feishu_client import feishu_post\n    except Exception:\n        pass\n    try:\n        import urllib.request\n        payload = json.dumps({\n            \"msg_type\": \"text\",\n            \"content\": {\"text\": report[:2000]}\n        }).encode(\"utf-8\")\n        # 尝试从环境变量获取飞书 webhook\n        webhook = Path.home() / \".openclaw\" / \"config\" / \"feishu_alert_webhook.txt\"\n        if not webhook.exists():\n            webhook = Path.home() / \".openclaw\" / \"config\" / \"feishu_webhook.txt\"\n        if webhook.exists():\n            url = webhook.read_text().strip()\n            req = urllib.request.Request(\n                url,\n                data=payload,\n                headers={\"Content-Type\": \"application/json\"},\n            )\n            with urllib.request.urlopen(req, timeout=10) as resp:\n                return resp.status == 200\n    except Exception:\n        pass\n    return False\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"策略参数自动巡检（轻量级）\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--skip-feishu\", action=\"store_true\", help=\"跳过 Feishu 推送\")\n    parser.add_argument(\"--force-report\", action=\"store_true\", help=\"强制输出报告（即使无告警）\")\n    args = parser.parse_args()\n\n    print(f\"[{datetime.now():%Y-%m-%d %H:%M}] 策略参数自动巡检开始...\")\n\n    summary_path = find_latest_summary()\n    if summary_path is None:\n        print(\"未找到 aggressive_walkforward_summary 文件，跳过。\")\n        return\n\n    summary = load_latest_summary(summary_path)\n    if summary is None:\n        print(f\"读取文件失败: {summary_path}\")\n        return\n\n    latest_window = extract_latest_window(summary)\n    if latest_window is None:\n        print(\"无法提取最新测试窗口，跳过。\")\n        return\n\n    alerts = compute_alerts(latest_window, summary)\n    report = build_report(latest_window, summary, alerts, summary_path)\n\n    # 写入报告\n    date_tag = args.date or datetime.now().strftime(\"%Y%m%d\")\n    report_path = REPORT_DIR / f\"strategy_param_auto_audit_{date_tag}.md\"\n    report_path.write_text(report, encoding=\"utf-8\")\n    print(f\"报告已写入: {report_path}\")\n\n    json_path = REPORT_DIR / f\"strategy_param_auto_audit_{date_tag}.json\"\n    json.dump({\n        \"generated_at\": datetime.now().isoformat(),\n        \"summary_file\": str(summary_path.name),\n        \"latest_window\": latest_window,\n        \"alerts\": alerts,\n        \"benchmark\": BENCHMARK,\n    }, json_path.open(\"w\", encoding=\"utf-8\"), indent=2, ensure_ascii=False)\n    print(f\"JSON 已写入: {json_path}\")\n\n    # Feishu 推送（有告警时 or --force-report）\n    if not args.skip_feishu and (alerts or args.force_report):\n        ok = push_feishu(report, alerts)\n        print(f\"Feishu 推送: {'成功' if ok else '失败（无webhook配置）'}\")\n\n    if alerts:\n        print(f\"\\n🔴 触发 {len(alerts)} 项告警，请查看报告。\")\n    else:\n        print(\"\\n✅ 各项指标正常，无告警。\")\n\n\nif __name__ == \"__main__\":\n    main()\nPYEOF\necho \"脚本创建完成\""}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":102520,"output":3042,"cacheRead":21467,"cacheWrite":0,"totalTokens":127029,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775472850533,"responseId":"0622c3d26eb286da2400fa0b0487fc6e"}}
