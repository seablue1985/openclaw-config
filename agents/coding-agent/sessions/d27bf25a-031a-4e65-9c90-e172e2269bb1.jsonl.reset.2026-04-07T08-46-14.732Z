{"type":"message","id":"629a121d","parentId":"4973a5d7","timestamp":"2026-04-06T13:54:09.578Z","message":{"role":"toolResult","toolCallId":"call_function_f2hylotjmoqi_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nimport subprocess\nfrom pathlib import Path\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nSUMMARY_PATH = REPORT_DIR / \"breadth_strict_oos_paper_latest.json\"\nSTATE_PATH = REPORT_DIR / \"breadth_strict_oos_push_state.json\"\n\n\ndef load_json(path: Path) -> dict:\n    if not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef write_json(path: Path, payload: dict) -> None:\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef push(message: str) -> tuple[bool, str]:\n    cmd = [\n        \"openclaw\", \"message\", \"send\",\n        \"--channel\", \"feishu\",\n        \"--account\", \"main\",\n        \"--target\", \"user:ou_968a615509dc191f04220e18cda67080\",\n        \"-m\", message,\n    ]\n    proc = subprocess.run(cmd, capture_output=True, text=True, timeout=120)\n    detail = ((proc.stdout or \"\").strip() or (proc.stderr or \"\").strip())[-2000:]\n    return proc.returncode == 0, detail\n\n\ndef main() -> None:\n    summary = load_json(SUMMARY_PATH)\n    if not summary:\n        raise SystemExit(\"missing breadth_strict_oos_paper_latest.json\")\n    dedupe = f\"{summary.get('signal_date')}|{summary.get('nav')}|{summary.get('position_count')}|{','.join(summary.get('buy_list', []))}|{','.join(summary.get('sell_list', []))}\"\n    prev = load_json(STATE_PATH)\n    if prev.get(\"dedupe\") == dedupe:\n        print(json.dumps({\"status\": \"SKIPPED\", \"reason\": \"duplicate\"}, ensure_ascii=False, indent=2))\n        return\n    message = \"\\n\".join([\n        f\"严格样本外宽度策略模拟盘｜{summary.get('generated_at')}\",\n        f\"信号日期: {summary.get('signal_date')}\",\n        f\"净值: {summary.get('nav')}\",\n        f\"总资产: {summary.get('total_value')}\",\n        f\"现金: {summary.get('cash')}\",\n        f\"持仓数: {summary.get('position_count')}\",\n        f\"目标仓位: {summary.get('target_position_pct')}%\",\n        f\"市场宽度: {summary.get('breadth')}\",\n        f\"买入: {', '.join(summary.get('buy_list', [])) or '无'}\",\n        f\"卖出: {', '.join(summary.get('sell_list', [])) or '无'}\",\n        f\"日报: {REPORT_DIR / 'breadth_strict_oos_paper_latest.md'}\",\n        f\"面板: {REPORT_DIR / 'breadth_strict_oos_dashboard_latest.html'}\",\n    ])\n    ok, detail = push(message)\n    payload = {\"dedupe\": dedupe, \"ok\": ok, \"detail\": detail, \"summary_path\": str(SUMMARY_PATH)}\n    write_json(STATE_PATH, payload)\n    print(json.dumps(payload, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()"}],"details":{"status":"completed","exitCode":0,"durationMs":14,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nimport subprocess\nfrom pathlib import Path\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nSUMMARY_PATH = REPORT_DIR / \"breadth_strict_oos_paper_latest.json\"\nSTATE_PATH = REPORT_DIR / \"breadth_strict_oos_push_state.json\"\n\n\ndef load_json(path: Path) -> dict:\n    if not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef write_json(path: Path, payload: dict) -> None:\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef push(message: str) -> tuple[bool, str]:\n    cmd = [\n        \"openclaw\", \"message\", \"send\",\n        \"--channel\", \"feishu\",\n        \"--account\", \"main\",\n        \"--target\", \"user:ou_968a615509dc191f04220e18cda67080\",\n        \"-m\", message,\n    ]\n    proc = subprocess.run(cmd, capture_output=True, text=True, timeout=120)\