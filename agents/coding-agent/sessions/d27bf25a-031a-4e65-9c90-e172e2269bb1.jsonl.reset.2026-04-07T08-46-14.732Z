{"type":"message","id":"f22e0825","parentId":"4db0ba34","timestamp":"2026-04-06T11:48:20.354Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good, the Lark Node.js SDK is available. Now let me figure out how to use it with the app credentials from openclaw.json.\n\nActually, let me look at how the extension itself creates the LarkClient.","thinkingSignature":"41437fec615b75a9435ba42a189763ed85129c3a351cc00ec677a1fe538277a2"},{"type":"toolCall","id":"call_function_ci2xi7u46rkl_1","name":"exec","arguments":{"command":"cat /Users/ling/.openclaw/extensions/openclaw-lark/src/core/lark-client.js 2>/dev/null | head -60"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":110460,"output":97,"cacheRead":21467,"cacheWrite":0,"totalTokens":132024,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775476095633,"responseId":"0622d07fc953df01ca24ccb83e73636c"}}
{"type":"message","id":"5ef0bf52","parentId":"f22e0825","timestamp":"2026-04-06T11:48:20.388Z","message":{"role":"toolResult","toolCallId":"call_function_ci2xi7u46rkl_1","toolName":"exec","content":[{"type":"text","text":"\"use strict\";\n/**\n * Copyright (c) 2026 ByteDance Ltd. and/or its affiliates\n * SPDX-License-Identifier: MIT\n *\n * Feishu / Lark SDK client management.\n *\n * Provides `LarkClient` — a unified manager for Lark SDK client instances,\n * WebSocket connections, EventDispatcher lifecycle, and bot identity.\n *\n * Consumers obtain instances via factory methods:\n *   - `LarkClient.fromCfg(cfg, accountId)` — resolve account from config\n *   - `LarkClient.fromAccount(account)` — from a pre-resolved account\n *   - `LarkClient.fromCredentials(credentials)` — ephemeral instance (not cached)\n */\n/* eslint-disable @typescript-eslint/no-explicit-any */\nimport * as Lark from '@larksuiteoapi/node-sdk';\nimport { getLarkAccount } from './accounts';\nimport { clearUserNameCache } from '../messaging/inbound/user-name-cache';\nimport { clearChatInfoCache } from './chat-info-cache';\nimport { getUserAgent } from './version';\nimport { larkLogger } from './lark-logger';\nconst log = larkLogger('core/lark-client');\n// ---------------------------------------------------------------------------\n// 注入 User-Agent 到所有飞书 SDK 请求\n// ---------------------------------------------------------------------------\nconst GLOBAL_LARK_USER_AGENT_KEY = 'LARK_USER_AGENT';\nfunction installGlobalUserAgent() {\n    // node-sdk 内置拦截器最终会读取 global.LARK_USER_AGENT 并覆盖 User-Agent\n    globalThis[GLOBAL_LARK_USER_AGENT_KEY] = getUserAgent();\n}\ninstallGlobalUserAgent();\nLark.defaultHttpInstance.interceptors.request.handlers = [];\n// 使用 interceptors 在所有 HTTP 请求中注入 User-Agent header\nLark.defaultHttpInstance.interceptors.request.use((req) => {\n    if (req.headers) {\n        req.headers['User-Agent'] = getUserAgent();\n    }\n    return req;\n}, undefined, { synchronous: true });\n// ---------------------------------------------------------------------------\n// Brand → SDK domain\n// ---------------------------------------------------------------------------\nconst BRAND_TO_DOMAIN = {\n    feishu: Lark.Domain.Feishu,\n    lark: Lark.Domain.Lark,\n};\n/** Map a `LarkBrand` to the SDK `domain` parameter. */\nfunction resolveBrand(brand) {\n    return BRAND_TO_DOMAIN[brand ?? 'feishu'] ?? brand.replace(/\\/+$/, '');\n}\n// ---------------------------------------------------------------------------\n// LarkClient\n// ---------------------------------------------------------------------------\n/** Instance cache keyed by accountId. */\nconst cache = new Map();\nexport class LarkClient {\n    account;\n    _sdk = null;\n    _wsClient = null;"}],"details":{"status":"completed","exitCode":0,"durationMs":17,"aggregated":"\"use strict\";\n/**\n * Copyright (c) 2026 ByteDance Ltd. and/or its affiliates\n * SPDX-License-Identifier: MIT\n *\n * Feishu / Lark SDK client management.\n *\n * Provides `LarkClient` — a unified manager for Lark SDK client instances,\n * WebSocket connections, EventDispatcher lifecycle, and bot identity.\n *\n * Consumers obtain instances via factory methods:\n *   - `LarkClient.fromCfg(cfg, accountId)` — resolve account from config\n *   - `LarkClient.fromAccount(account)` — from a pre-resolved account\n *   - `LarkClient.fromCredentials(credentials)` — ephemeral instance (not cached)\n */\n/* eslint-disable @typescript-eslint/no-explicit-any */\nimport * as Lark from '@larksuiteoapi/node-sdk';\nimport { getLarkAccount } from './accounts';\nimport { clearUserNameCache } from '../messaging/inbound/user-name-cache';\nimport { clearChatInfoCache } from './chat-info-cache';\nimport { getUserAgent } from './version';\nimport { larkLogger } from './lark-logger';\nconst log = larkLogger('core/lark-client');\n// ---------------------------------------------------------------------------\n// 注入 User-Agent 到所有飞书 SDK 请求\n// ---------------------------------------------------------------------------\nconst GLOBAL_LARK_USER_AGENT_KEY = 'LARK_USER_AGENT';\nfunction installGlobalUserAgent() {\n    // node-sdk 内置拦截器最终会读取 global.LARK_USER_AGENT 并覆盖 User-Agent\n    globalThis[GLOBAL_LARK_USER_AGENT_KEY] = getUserAgent();\n}\ninstallGlobalUserAgent();\nLark.defaultHttpInstance.interceptors.request.handlers = [];\n// 使用 interceptors 在所有 HTTP 请求中注入 User-Agent header\nLark.defaultHttpInstance.interceptors.request.use((req) => {\n    if (req.headers) {\n        req.headers['User-Agent'] = getUserAgent();\n    }\n    return req;\n}, undefined, { synchronous: true });\n// ---------------------------------------------------------------------------\n// Brand → SDK domain\n// ---------------------------------------------------------------------------\nconst BRAND_TO_DOMAIN = {\n    feishu: Lark.Domain.Feishu,\n    lark: Lark.Domain.Lark,\n};\n/** Map a `LarkBrand` to the SDK `domain` parameter. */\nfunction resolveBrand(brand) {\n    return BRAND_TO_DOMAIN[brand ?? 'feishu'] ?? brand.replace(/\\/+$/, '');\n}\n// ---------------------------------------------------------------------------\n// LarkClient\n// ---------------------------------------------------------------------------\n/** Instance cache keyed by accountId. */\nconst cache = new Map();\nexport class LarkClient {\n    account;\n    _sdk = null;\n    _wsClient = null;","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775476100380}}
{"type":"message","id":"f66ba5c5","parentId":"5ef0bf52","timestamp":"2026-04-06T11:48:32.227Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The `LarkClient.fromCfg` method is what I need. But it reads from the openclaw.json format. Let me try to use the SDK directly.\n\nActually, looking at the code, the SDK client is created with the app credentials. Let me just write a Node.js script that sends a message using the SDK.\n\nLet me first test if the SDK works with the openclaw.json credentials.","thinkingSignature":"0650dc53727c29b4dd12ad368b04d0ef3a9cc27eca63df551002136eb48cada0"},{"type":"toolCall","id":"call_function_mixr2yfpa57q_1","name":"exec","arguments":{"command":"node -e \"\nconst {Client} = require('/Users/ling/.openclaw/extensions/openclaw-lark/node_modules/@larksuiteoapi/node-sdk');\nconst fs = require('fs');\nconst cfg = JSON.parse(fs.readFileSync('/Users/ling/.openclaw/openclaw.json', 'utf-8'));\nconst feishu = cfg.channels.fishu || cfg.channels.feishu;\nconst accounts = feishu ? feishu.accounts : {};\nconst main = accounts.main || Object.values(accounts)[0];\nconsole.log('appId:', main.appId, 'hasSecret:', !!main.appSecret);\n\" 2>&1"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":108035,"output":240,"cacheRead":21467,"cacheWrite":0,"totalTokens":129742,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775476100393,"responseId":"0622d08429d13b74b888b3f70425f6e7"}}
