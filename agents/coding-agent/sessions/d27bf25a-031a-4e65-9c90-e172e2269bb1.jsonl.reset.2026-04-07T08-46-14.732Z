{"type":"message","id":"990125ff","parentId":"a3f4f8c7","timestamp":"2026-04-06T13:55:27.003Z","message":{"role":"toolResult","toolCallId":"call_function_261awlglmu5y_1","toolName":"exec","content":[{"type":"text","text":"def send_feishu(msg):\n    \"\"\"发送飞书\"\"\"\n    import requests\n\n    payload = {\"msg_type\": \"text\", \"content\": {\"text\": msg}}\n    resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\n    return resp.json()\n\n\ndef is_trading_day() -> bool:\n    \"\"\"判断今天是否为 A 股交易日（周一~周五）。\"\"\"\n    return datetime.now().weekday() < 5\n\n\ndef main():\n    if not is_trading_day():\n        print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] 非 A 股交易日，跳过可执行简报\")\n        return\n\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] 生成可执行简报...\")\n\n    trade_card = get_latest_trade_card()\n    audit = get_latest_audit()\n    strategy = get_latest_strategy()\n    real_holdings, real_meta = get_real_holdings()\n    if real_meta.get(\"fallback_reason\") == \"missing_selected_real_holdings_source\":\n        print(f\"[{datetime.now().strftime('%H:%M:%S')}] 中止发送：missing_selected_real_holdings_source\")\n        return\n    sim_meta = get_simulated_holdings_summary()\n\n    brief = build_actionable_brief(\n        trade_card,\n        audit,\n        strategy,\n        real_holdings,\n        real_meta,\n        sim_meta,\n    )\n\n    out_file = REPORTS / \"actionable_brief_latest.md\"\n    out_file.write_text(brief, encoding=\"utf-8\")\n    print(f\"已保存: {out_file.name}\")\n\n    print(\"\\n发送飞书...\")\n    result = send_feishu(brief)\n    print(f\"发送结果: {result}\")\n\n    print(\"\\n\" + brief)\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())"}],"details":{"status":"completed","exitCode":0,"durationMs":17,"aggregated":"def send_feishu(msg):\n    \"\"\"发送飞书\"\"\"\n    import requests\n\n    payload = {\"msg_type\": \"text\", \"content\": {\"text\": msg}}\n    resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\n    return resp.json()\n\n\ndef is_trading_day() -> bool:\n    \"\"\"判断今天是否为 A 股交易日（周一~周五）。\"\"\"\n    return datetime.now().weekday() < 5\n\n\ndef main():\n    if not is_trading_day():\n        print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] 非 A 股交易日，跳过可执行简报\")\n        return\n\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] 生成可执行简报...\")\n\n    trade_card = get_latest_trade_card()\n    audit = get_latest_audit()\n    strategy = get_latest_strategy()\n    real_holdings, real_meta = get_real_holdings()\n    if real_meta.get(\"fallback_reason\") == \"missing_selected_real_holdings_source\":\n        print(f\"[{datetime.now().strftime('%H:%M:%S')}] 中止发送：missing_selected_real_holdings_source\")\n        return\n    sim_meta = get_simulated_holdings_summary()\n\n    brief = build_actionable_brief(\n        trade_card,\n        audit,\n        strategy,\n        real_holdings,\n        real_meta,\n        sim_meta,\n    )\n\n    out_file = REPORTS / \"actionable_brief_latest.md\"\n    out_file.write_text(brief, encoding=\"utf-8\")\n    print(f\"已保存: {out_file.name}\")\n\n    print(\"\\n发送飞书...\")\n    result = send_feishu(brief)\n    print(f\"发送结果: {result}\")\n\n    print(\"\\n\" + brief)\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775483726997}}
