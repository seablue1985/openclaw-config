{"type":"message","id":"5f1d7423","parentId":"f869aa8e","timestamp":"2026-04-06T13:59:02.919Z","message":{"role":"toolResult","toolCallId":"call_function_0gi2i5v2w3ic_1","toolName":"exec","content":[{"type":"text","text":"def main() -> int:\n    parser = argparse.ArgumentParser(description=\"Report overnight autopilot result only when armed\")\n    parser.add_argument(\"--force-report\", action=\"store_true\")\n    parser.add_argument(\"--dry-run\", action=\"store_true\")\n    args = parser.parse_args()\n\n    today = str(date.today())\n    arm = load_json(ARM_FILE)\n    if not arm:\n        print(json.dumps({\"status\": \"NO_ARMED_TASK\", \"checked_at\": now_str(), \"date\": today}, ensure_ascii=False, indent=2))\n        return 0\n\n    if arm.get(\"report_sent_at\"):\n        print(json.dumps({\"status\": \"ALREADY_REPORTED\", \"checked_at\": now_str(), \"date\": today, \"report_sent_at\": arm.get('report_sent_at')}, ensure_ascii=False, indent=2))\n        return 0\n\n    report_date = str(arm.get(\"report_date\") or \"\")\n    if not args.force_report and report_date != today:\n        print(json.dumps({\n            \"status\": \"NO_REPORT_TODAY\",\n            \"checked_at\": now_str(),\n            \"date\": today,\n            \"armed_report_date\": report_date,\n        }, ensure_ascii=False, indent=2))\n        return 0\n\n    state = load_json(STATE_FILE)\n    channel = arm.get(\"channel\", \"feishu\")\n    account = arm.get(\"account\", \"main\")\n    target_user = arm.get(\"target_user\", \"user:ou_968a615509dc191f04220e18cda67080\")\n\n    success = state.get(\"status\") == \"OK\" and state.get(\"execute_date\") == arm.get(\"execute_date\")\n    message = build_success_message(state) if success else build_failure_message(state, arm)\n    ok, info = push_to_feishu(channel=channel, account=account, target_user=target_user, message=message, dry_run=args.dry_run)\n\n    arm_update = {\n        **arm,\n        \"report_attempted_at\": now_str(),\n        \"report_sent_at\": None if args.dry_run else now_str(),"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"def main() -> int:\n    parser = argparse.ArgumentParser(description=\"Report overnight autopilot result only when armed\")\n    parser.add_argument(\"--force-report\", action=\"store_true\")\n    parser.add_argument(\"--dry-run\", action=\"store_true\")\n    args = parser.parse_args()\n\n    today = str(date.today())\n    arm = load_json(ARM_FILE)\n    if not arm:\n        print(json.dumps({\"status\": \"NO_ARMED_TASK\", \"checked_at\": now_str(), \"date\": today}, ensure_ascii=False, indent=2))\n        return 0\n\n    if arm.get(\"report_sent_at\"):\n        print(json.dumps({\"status\": \"ALREADY_REPORTED\", \"checked_at\": now_str(), \"date\": today, \"report_sent_at\": arm.get('report_sent_at')}, ensure_ascii=False, indent=2))\n        return 0\n\n    report_date = str(arm.get(\"report_date\") or \"\")\n    if not args.force_report and report_date != today:\n        print(json.dumps({\n            \"status\": \"NO_REPORT_TODAY\",\n            \"checked_at\": now_str(),\n            \"date\": today,\n            \"armed_report_date\": report_date,\n        }, ensure_ascii=False, indent=2))\n        return 0\n\n    state = load_json(STATE_FILE)\n    channel = arm.get(\"channel\", \"feishu\")\n    account = arm.get(\"account\", \"main\")\n    target_user = arm.get(\"target_user\", \"user:ou_968a615509dc191f04220e18cda67080\")\n\n    success = state.get(\"status\") == \"OK\" and state.get(\"execute_date\") == arm.get(\"execute_date\")\n    message = build_success_message(state) if success else build_failure_message(state, arm)\n    ok, info = push_to_feishu(channel=channel, account=account, target_user=target_user, message=message, dry_run=args.dry_run)\n\n    arm_update = {\n        **arm,\n        \"report_attempted_at\": now_str(),\n        \"report_sent_at\": None if args.dry_run else now_str(),","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775483942913}}
