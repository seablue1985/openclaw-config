{"type":"message","id":"78c80c8a","parentId":"f0b4d1e6","timestamp":"2026-04-06T13:35:24.816Z","message":{"role":"toolResult","toolCallId":"call_function_3862cew4fgfc_1","toolName":"read","content":[{"type":"text","text":"        )\n        lines.append(\"  当前时点无新增买入候选\")\n        if signals.get(\"buy_candidates_count\") is not None or signals.get(\"research_buy_candidates_count\") is not None:\n            lines.append(\n                f\"  可执行候选 {signals.get('buy_candidates_count', 0)} | 研究层候选 {signals.get('research_buy_candidates_count', 0)}\"\n            )\n\n    text = \"\\n\".join(lines)\n    return send_feishu(text)\n\n\n# ============ 主流程 ============\n\ndef main():\n    # ── 命令行参数 ──────────────────────────────────────────\n    parser = argparse.ArgumentParser(description=\"投研情报汇聚\", add_help=False)\n    parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"仅采集和保存，不发飞书\")\n    parser.add_argument(\"--no-send\", action=\"store_true\", help=\"同 --dry-run\")\n    parser.add_argument(\"--force-send\", action=\"store_true\", help=\"强制发送，忽略内容去重\")\n    args = parser.parse_args()\n    dry_run = args.dry_run or args.no_send\n\n    # ── 内容去重：读取上一条简报摘要，若内容完全相同且非 force-send 则跳过 ──\n    dedup_marker = OUTPUT_DIR / \"intelligence_brief_last_sent_hash.txt\"\n    last_hash = \"\"\n    if dedup_marker.exists():\n        last_hash = dedup_marker.read_text(encoding=\"utf-8\").strip()\n\n    # ── 采集 ───────────────────────────────────────────────\n    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n\n    print(f\"[{datetime.now():%Y-%m-%d %H:%M:%S}] 汇聚投研情报...\")\n\n    trend_cats, trend_total = get_trendradar()\n    weibo    = get_weibo()\n    signals  = get_quant_signals()\n    holdings = get_holdings()\n    if holdings.get(\"error\") == \"missing_selected_real_holdings_source\":\n        print(f\"[{datetime.now():%H:%M:%S}] 中止：missing_selected_real_holdings_source\")\n        return\n    profiles = get_paper_profiles()\n\n    print(f\"  TrendRadar: {trend_total} 条（财经 {sum(len(v) for v in trend_cats.values())} 条）\")\n    print(f\"  微博监控: {weibo.get('status', '?')} | {weibo.get('last_time', '?')}\")\n    print(f\"  量化信号: {len(signals.get('top_buy', []))} 买入候选\")\n    print(f\"  持仓: {holdings.get('count', 0)} 只\")\n    print(f\"  三盘: {list(profiles.keys())}\")\n\n    brief = build_brief(trend_cats, weibo, signals, holdings, profiles)\n\n    # ── 保存 ───────────────────────────────────────────────\n    date_code = datetime.now().strftime(\"%Y%m%d_%H%M\")\n    f1 = OUTPUT_DIR / f\"intelligence_brief_{date_code}.md\"\n    f2 = OUTPUT_DIR / \"intelligence_brief_latest.md\"\n    f1.write_text(brief, encoding=\"utf-8\")\n    f2.write_text(brief, encoding=\"utf-8\")\n    print(f\"  已保存: {f1.name}\")\n    print(f\"  已更新: intelligence_brief_latest.md\")\n\n    # ── 飞书推送（去重） ──────────────────────────────────\n\n[21 more lines in file. Use offset=760 to continue.]"}],"isError":false,"timestamp":1775482524805}}
