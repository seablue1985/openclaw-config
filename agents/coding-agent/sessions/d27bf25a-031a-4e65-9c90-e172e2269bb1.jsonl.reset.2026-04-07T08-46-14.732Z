{"type":"message","id":"f6709f34","parentId":"dd870b45","timestamp":"2026-04-06T13:55:10.654Z","message":{"role":"toolResult","toolCallId":"call_function_gqphejblt5f6_1","toolName":"exec","content":[{"type":"text","text":"def build_exec_card(strategy, audit, holdings, ibrief):\n    now = datetime.now()\n    date_str = now.strftime(\"%Y-%m-%d\")\n    holdings = [norm_h(h) for h in holdings]\n\n    lines = []\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(\"📋 每日执行卡 v2\")\n    lines.append(f\"{date_str} {now.strftime('%H:%M')} | 交易日\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    status = audit.get(\"overall_status\", \"?\")\n    ar = audit.get(\"annual_return_pct\", 0)\n    mdd = audit.get(\"max_drawdown_pct\", 0)\n    sharpe = audit.get(\"sharpe\", 0)\n    mode = audit.get(\"execution_scope\", \"unknown\")\n    risk_off = audit.get(\"risk_off\", None)\n\n    lines.append(f\"\\n【系统状态】{'✅' if status in ('PASS', 'ok') else '⚠️'} {'正常' if status in ('PASS', 'ok') else status}\")\n    lines.append(f\"  年化 {ar:.1f}% | 回撤 {mdd:.1f}% | 夏普 {sharpe:.2f}\")\n\n    if risk_off is not None:\n        lines.append(f\"\\n【风险框架】{'🔴' if risk_off else '🟢'} {'风险收缩中' if risk_off else '正常'}\")\n\n    bw = strategy.get(\"market_breadth\")\n    if bw:\n        icon = \"🟢\" if bw >= 28 else \"🟡\" if bw >= 14 else \"🔴\"\n        lines.append(f\"  市场宽度 {bw:.2f}% {icon}\")\n\n    mode_map = {\n        \"halt\": (\"⏸️ 暂停开仓\", \"风控阻断，不追新仓\"),\n        \"probe\": (\"🟡 试探模式\", \"小仓位试探\"),\n        \"normal\": (\"🟢 正常执行\", \"可执行信号\"),\n        \"paper_profiles_only\": (\"🟡 模拟盘模式\", \"观察为主，不执行\"),\n    }\n    mode_text, mode_note = mode_map.get(mode, (f\"❓ {mode}\", \"\"))\n    lines.append(f\"\\n【执行模式】{mode_text}\")\n    if mode_note:\n        lines.append(f\"  → {mode_note}\")\n\n    etf_stock = [h for h in holdings if h[\"asset_type\"] in (\"etf\", \"fund\")]\n    hk_stock = [h for h in holdings if h[\"currency\"] == \"HKD\" and h[\"asset_type\"] not in (\"fund\", \"etf\")]\n    a_stock = [h for h in holdings if h[\"currency\"] != \"HKD\" and h[\"asset_type\"] not in (\"fund\", \"etf\")]\n\n    lines.append(f\"\\n【持仓】A股 {len(a_stock)} 只 | 港股 {len(hk_stock)} 只 | ETF {len(etf_stock)} 只\")\n    lines.append(\"  注：实时盈亏需网络畅通，akshare断开时显示成本价\")\n\n    strat_prices = {c[\"code\"]: c for c in strategy.get(\"buy_candidates\", [])}\n\n    shown = 0\n    for h in holdings:\n        if shown >= 5:\n            break\n        code = h[\"symbol\"]\n        name = h.get(\"name\", \"\") or code\n        qty = h[\"quantity\"]\n        cost = h[\"cost_price\"]\n        strat = strat_prices.get(code, {})\n        strat_price = strat.get(\"price\", \"\")\n        action = strat.get(\"action\", \"\")\n        stop_loss = strat.get(\"stop_loss\", \"\")\n        take_profit = strat.get(\"take_profit\", \"\")\n\n        sig = \"\"\n        if action == \"卖出\":\n            sig = \" ⚠️ 卖出信号\"\n        elif action == \"观望\":\n            sig = \" 👀 观望\"\n\n        lines.append(f\"  • {code} {name[:8]} ×{qty}手 成本:{cost}{sig}\")\n        if strat_price:\n            lines.append(f\"    当前参考价:{strat_price} | 止损:{stop_loss or '?'} 目标:{take_profit or '?'}\")\n        shown += 1\n\n    if len(holdings) > 5:\n        lines.append(f\"  ... 还有 {len(holdings) - 5} 只（见完整持仓）\")\n\n    buy_cands = strategy.get(\"buy_candidates\", [])\n    buy_count = strategy.get(\"buy_count\", 0)\n\n    if buy_count > 0:\n        lines.append(f\"\\n【今日 BUY 信号】{buy_count} 个候选\")\n        shown = 0\n        for cand in buy_cands:\n            if shown >= 3:\n                break\n            action = cand.get(\"action\", \"\")\n            exec_icon = \"⚠️\" if \"观望\" in action else (\"✅\" if mode == \"normal\" else (\"🟡\" if mode == \"probe\" else \"⛔\"))\n            lines.append(f\"  {exec_icon} {cand['code']} {cand.get('name', '')[:8]} @ {cand['price']}\")\n            sl = cand.get(\"stop_loss\") or \"?\"\n            tp = cand.get(\"take_profit\") or \"?\"\n            lines.append(f\"     止损:{sl} | 目标:{tp}\")\n            shown += 1\n        if buy_count > 3:\n            lines.append(f\"  ... 还有 {buy_count - 3} 个（见完整报告）\")\n    else:\n        lines.append(\"\\n【今日 BUY 信号】0 个（市场宽度或风控阻断）\")\n\n    sell_count = strategy.get(\"sell_count\", 0)\n    if sell_count > 0:\n        lines.append(f\"\\n【今日 SELL 信号】{sell_count} 个\")\n    else:\n        lines.append(f\"\\n【持仓监控】软止损 {audit.get('soft_stop_pct', -5)}% | 硬止损 {audit.get('stop_loss_pct', -8)}%\")\n\n    lines.append(\"\\n【风控红线】\")\n    lines.append(f\"  软止损: {audit.get('soft_stop_pct', -5)}% | 硬止损: {audit.get('stop_loss_pct', -8)}%\")\n    lines.append(f\"  市场宽度门槛: {audit.get('market_breadth_threshold', 0.28) * 100:.1f}%\")\n\n    ib_sections = parse_intelligence(ibrief)\n    if ib_sections:\n        lines.append(\"\\n【舆情热点】\")\n        for sec in ib_sections[:4]:\n            if sec[\"items\"]:\n                lines.append(f\"  【{sec['name']}】{sec['items'][0][:30]}\")\n                if len(sec[\"items\"]) > 1:\n                    lines.append(f\"    +{len(sec['items']) - 1} 条更多\")\n\n    lines.append(\"\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"📊 {now.strftime('%H:%M:%S')} | 详细报告见原始文件\")\n\n    return \"\\n\".join(lines)\n\n\ndef send_feishu(msg):"}],"details":{"status":"completed","exitCode":0,"durationMs":16,"aggregated":"def build_exec_card(strategy, audit, holdings, ibrief):\n    now = datetime.now()\n    date_str = now.strftime(\"%Y-%m-%d\")\n    holdings = [norm_h(h) for h in holdings]\n\n    lines = []\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(\"📋 每日执行卡 v2\")\n    lines.append(f\"{date_str} {now.strftime('%H:%M')} | 交易日\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    status = audit.get(\"overall_status\", \"?\")\n    ar = audit.get(\"annual_return_pct\", 0)\n    mdd = audit.get(\"max_drawdown_pct\", 0)\n    sharpe = audit.get(\"sharpe\", 0)\n    mode = audit.get(\"execution_scope\", \"unknown\")\n    risk_off = audit.get(\"risk_off\", None)\n\n    lines.append(f\"\\n【系统状态】{'✅' if status in ('PASS', 'ok') else '⚠️'} {'正常' if status in ('PASS', 'ok') else status}\")\n    lines.append(f\"  年化 {ar:.1f}% | 回撤 {mdd:.1f}% | 夏普 {sharpe:.2f}\")\n\n    if risk_off is not None:\n        lines.append(f\"\\n【风险框架】{'🔴' if risk_off else '🟢'} {'风险收缩中' if risk_off else '正常'}\")\n\n    bw = strategy.get(\"market_breadth\")\n    if bw:\n        icon = \"🟢\" if bw >= 28 else \"🟡\" if bw >= 14 else \"🔴\"\n        lines.append(f\"  市场宽度 {bw:.2f}% {icon}\")\n\n    mode_map = {\n        \"halt\": (\"⏸️ 暂停开仓\", \"风控阻断，不追新仓\"),\n        \"probe\": (\"🟡 试探模式\", \"小仓位试探\"),\n        \"normal\": (\"🟢 正常执行\", \"可执行信号\"),\n        \"paper_profiles_only\": (\"🟡 模拟盘模式\", \"观察为主，不执行\"),\n    }\n    mode_text, mode_note = mode_map.get(mode, (f\"❓ {mode}\", \"\"))\n    lines.append(f\"\\n【执行模式】{mode_text}\")\n    if mode_note:\n        lines.append(f\"  → {mode_note}\")\n\n    etf_stock = [h for h in holdings if h[\"asset_type\"] in (\"etf\", \"fund\")]\n    hk_stock = [h for h in holdings if h[\"currency\"] == \"HKD\" and h[\"asset_type\"] not in (\"fund\", \"etf\")]\n    a_stock = [h for h in holdings if h[\"currency\"] != \"HKD\" and h[\"asset_type\"] not in (\"fund\", \"etf\")]\n\n    lines.append(f\"\\n【持仓】A股 {len(a_stock)} 只 | 港股 {len(hk_stock)} 只 | ETF {len(etf_stock)} 只\")\n    lines.append(\"  注：实时盈亏需网络畅通，akshare断开时显示成本价\")\n\n    strat_prices = {c[\"code\"]: c for c in strategy.get(\"buy_candidates\", [])}\n\n    shown = 0\n    for h in holdings:\n        if shown >= 5:\n            break\n        code = h[\"symbol\"]\n        name = h.get(\"name\", \"\") or code\n        qty = h[\"quantity\"]\n        cost = h[\"cost_price\"]\n        strat = strat_prices.get(code, {})\n        strat_price = strat.get(\"price\", \"\")\n        action = strat.get(\"action\", \"\")\n        stop_loss = strat.get(\"stop_loss\", \"\")\n        take_profit = strat.get(\"take_profit\", \"\")\n\n        sig = \"\"\n        if action == \"卖出\":\n            sig = \" ⚠️ 卖出信号\"\n        elif action == \"观望\":\n            sig = \" 👀 观望\"\n\n        lines.append(f\"  • {code} {name[:8]} ×{qty}手 成本:{cost}{sig}\")\n        if strat_price:\n            lines.append(f\"    当前参考价:{strat_price} | 止损:{stop_loss or '?'} 目标:{take_profit or '?'}\")\n        shown += 1\n\n    if len(holdings) > 5:\n        lines.append(f\"  ... 还有 {len(holdings) - 5} 只（见完整持仓）\")\n\n    buy_cands = strategy.get(\"buy_candidates\", [])\n    buy_count = strategy.get(\"buy_count\", 0)\n\n    if buy_count > 0:\n        lines.append(f\"\\n【今日 BUY 信号】{buy_count} 个候选\")\n        shown = 0\n        for cand in buy_cands:\n            if shown >= 3:\n                break\n            action = cand.get(\"action\", \"\")\n            exec_icon = \"⚠️\" if \"观望\" in action else (\"✅\" if mode == \"normal\" else (\"🟡\" if mode == \"probe\" else \"⛔\"))\n            lines.append(f\"  {exec_icon} {cand['code']} {cand.get('name', '')[:8]} @ {cand['price']}\")\n            sl = cand.get(\"stop_loss\") or \"?\"\n            tp = cand.get(\"take_profit\") or \"?\"\n            lines.append(f\"     止损:{sl} | 目标:{tp}\")\n            shown += 1\n        if buy_count > 3:\n            lines.append(f\"  ... 还有 {buy_count - 3} 个（见完整报告）\")\n    else:\n        lines.append(\"\\n【今日 BUY 信号】0 个（市场宽度或风控阻断）\")\n\n    sell_count = strategy.get(\"sell_count\", 0)\n    if sell_count > 0:\n        lines.append(f\"\\n【今日 SELL 信号】{sell_count} 个\")\n    else:\n        lines.append(f\"\\n【持仓监控】软止损 {audit.get('soft_stop_pct', -5)}% | 硬止损 {audit.get('stop_loss_pct', -8)}%\")\n\n    lines.append(\"\\n【风控红线】\")\n    lines.append(f\"  软止损: {audit.get('soft_stop_pct', -5)}% | 硬止损: {audit.get('stop_loss_pct', -8)}%\")\n    lines.append(f\"  市场宽度门槛: {audit.get('market_breadth_threshold', 0.28) * 100:.1f}%\")\n\n    ib_sections = parse_intelligence(ibrief)\n    if ib_sections:\n        lines.append(\"\\n【舆情热点】\")\n        for sec in ib_sections[:4]:\n            if sec[\"items\"]:\n 