          content = resp.read().decode(\"gbk\", errors=\"replace\")\n        for line in content.split(\";\"):\n            if \"sh000001\" in line:\n                parts = line.split(\"~\")\n                if len(parts) > 30:\n                    mkt_str = parts[30].strip()[:8]\n                    market_date = f\"{mkt_str[:4]}-{mkt_str[4:6]}-{mkt_str[6:8]}\"\n                    today = datetime.now().strftime(\"%Y-%m-%d\")\n                    return market_date == today\n                break\n        return datetime.now().weekday() < 5\n    except Exception:\n        return datetime.now().weekday() < 5"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":35066,"output":585,"cacheRead":21467,"cacheWrite":0,"totalTokens":57118,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775483750222,"responseId":"0622ee665a029acfc07b1ff95bf3ede9"}}
