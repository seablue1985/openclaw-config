{"type":"message","id":"9913c4d9","parentId":"09a80e47","timestamp":"2026-04-06T13:55:30.078Z","message":{"role":"toolResult","toolCallId":"call_function_yy9y5z8hb1s5_1","toolName":"exec","content":[{"type":"text","text":"def send_feishu(msg):\n    import requests\n    payload = {\"msg_type\": \"text\", \"content\": {\"text\": msg}}\n    resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\n    return resp.json()\n\n\ndef build_report(holdings, date, strategy, audit):\n    now = datetime.now()\n\n    a_stocks = []\n    hk_stocks = []\n    etf_funds = []\n    for h in holdings:\n        ts = h.get(\"ts_code\", \"\")\n        cur = h.get(\"currency\", \"CNY\")\n        name = h.get(\"name\", \"\") or ts\n        qty = int(float(h.get(\"qty\", 0) or 0))\n        cost = float(h.get(\"cost_price\", 0) or 0)\n        asset_type = h.get(\"asset_type\", \"stock\")\n\n        item = {\"code\": ts, \"name\": name, \"qty\": qty, \"cost_price\": cost, \"currency\": cur}\n        if cur == \"HKD\":\n            hk_stocks.append(item)\n        elif asset_type == \"etf\" or ts.startswith((\"5\", \"1\", \"15\")) or \"ETF\" in name.upper():\n            etf_funds.append(item)\n        else:\n            a_stocks.append(item)\n\n    total_cost = sum(float(h.get(\"cost_price\", 0) or 0) * int(float(h.get(\"qty\", 0) or 0)) for h in holdings)\n\n    lines = []\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(\"📊 持仓日报\")\n    lines.append(f\"日期：{date} | 生成：{now.strftime('%m-%d %H:%M')}\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    if a_stocks:\n        lines.append(f\"\\n【A 股持仓】共 {len(a_stocks)} 只\")\n        lines.append(f\"成本总额：{total_cost:,.0f} 元\")\n        lines.append(\"\")\n        for h in a_stocks:\n            name = h[\"name\"] if h[\"name\"] and h[\"name\"] != h[\"code\"] else h[\"code\"]\n            lines.append(f\"  {h['code']} {name[:6]}\")\n            lines.append(f\"    {h['qty']:,} 股 | 成本 {h['cost_price']:.3f} 元\")\n\n    if hk_stocks:\n        lines.append(f\"\\n【港股持仓】共 {len(hk_stocks)} 只\")\n        for h in hk_stocks:\n            lines.append(f\"  {h['code']} {h['name']})\")\n            lines.append(f\"    {h['qty']:,} 股 | 成本 {h['cost_price']:.3f} 港币\")\n\n    if etf_funds:\n        lines.append(f\"\\n【ETF/基金】共 {len(etf_funds)} 只\")\n        for h in etf_funds:\n            lines.append(f\"  {h['code']} {h['name']})\")\n            lines.append(f\"    {h['qty']:,} 份 | 成本 {h['cost_price']:.3f} 元\")\n\n    lines.append(\"\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"【汇总】A股 {len(a_stocks)} 只 | 港股 {len(hk_stocks)} | ETF {len(etf_funds)} 只\")\n    lines.append(f\"持仓总数：{len(holdings)} 只 | 成本总额：{total_cost:,.0f} 元\")\n\n    if strategy:\n        bw = strategy.get(\"market_breadth\")\n        buy = strategy.get(\"buy_count\", 0)\n        sell = strategy.get(\"sell_count\", 0)\n        is_fresh = bool(strategy.get(\"is_fresh\"))\n        captured_at = strategy.get(\"market_breadth_captured_at\") or \"-\"\n        breadth_source = strategy.get(\"market_breadth_source\") or strategy.get(\"source\") or \"-\"\n        source_date_tag = strategy.get(\"source_date_tag\") or \"-\"\n        if bw is not None:\n            icon = \"🟢\" if bw >= 28 else \"🟡\" if bw >= 14 else \"🔴\"\n            freshness = \"\" if is_fresh else \"（非当日）\"\n            lines.append(f\"\\n【市场宽度】{bw:.2f}% {icon}{freshness}\")\n            lines.append(f\"【宽度时间】{captured_at} | 来源 {breadth_source} | 数据日期 {source_date_tag}\")\n        else:\n            lines.append(\"\\n【市场宽度】缺少有效数据\")\n        if buy or sell:\n            lines.append(f\"【策略信号】BUY {buy} 个 | SELL {sell} 个\")\n        risk_mode = strategy.get(\"risk_mode\", \"\")\n        if risk_mode:\n            lines.append(f\"【风险模式】{risk_mode}\")\n\n    if audit:\n        ar = audit.get(\"annual_return_pct\", 0)\n        mdd = audit.get(\"max_drawdown_pct\", 0)\n        sharpe = audit.get(\"sharpe\", 0)\n        if ar:\n            lines.append(f\"\\n【模拟盘审计】年化 {ar:.1f}% | 回撤 {mdd:.1f}% | 夏普 {sharpe:.2f}\")\n\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"📊 生成时间：{now.strftime('%H:%M:%S')}\")\n    return \"\\n\".join(lines)\n\n\ndef main():\n    if not is_trading_day():\n        print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] 非 A 股交易日，跳过持仓日报\")\n        return\n\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] 生成持仓日报...\")\n    try:\n        holdings, date = get_holdings()\n    except Exception as e:\n        print(f\"[{datetime.now().strftime('%H:%M:%S')}] 中止发送：{e}\")\n        return\n\n    strategy = get_strategy_summary(datetime.now().strftime(\"%Y%m%d\"))\n    audit = get_audit()\n    report = build_report(holdings, date, strategy, audit)\n\n    out_file = REPORTS / \"daily_position_report_latest.md\"\n    out_file.write_text(report, encoding=\"utf-8\")\n    print(f\"已保存: {out_file.name}\")\n\n    print(\"\\n发送飞书...\")\n    result = send_feishu(report)\n    print(f\"发送结果: {result}\")\n    print(\"\\n\" + report)\n\n\nif __name__ == \"__main__\":\n    main()"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"def send_feishu(msg):\n    import requests\n    payload = {\"msg_type\": \"text\", \"content\": {\"text\": msg}}\n    resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\n    return resp.json()\n\n\ndef build_report(holdings, date, strategy, audit):\n    now = datetime.now()\n\n    a_stocks = []\n    hk_stocks = []\n    etf_funds = []\n    for h in holdings:\n        ts = h.get(\"ts_code\", \"\")\n        cur = h.get(\"currency\", \"CNY\")\n        name = h.get(\"name\", \"\") or ts\n        qty = int(float(h.get(\"qty\", 0) or 0))\n        cost = float(h.get(\"cost_price\", 0) or 0)\n        asset_type = h.get(\"asset_type\", \"stock\")\n\n        item = {\"code\": ts, \"name\": name, \"qty\": qty, \"cost_price\": cost, \"currency\": cur}\n        if cur == \"HKD\":\n            hk_stocks.append(item)\n        elif asset_type == \"etf\" or ts.startswith((\"5\", \"1\", \"15\")) or \"ETF\" in name.upper():\n            etf_funds.append(item)\n        else:\n            a_stocks.append(item)\n\n    total_cost = sum(float(h.get(\"cost_price\", 0) or 0) * int(float(h.get(\"qty\", 0) or 0)) for h in holdings)\n\n    lines = []\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(\"📊 持仓日报\")\n    lines.append(f\"日期：{date} | 生成：{now.strftime('%m-%d %H:%M')}\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    if a_stocks:\n        lines.append(f\"\\n【A 股持仓】共 {len(a_stocks)} 只\")\n        lines.append(f\"成本总额：{total_cost:,.0f} 元\")\n        lines.append(\"\")\n        for h in a_stocks:\n            name = h[\"name\"] if h[\"name\"] and h[\"name\"] != h[\"code\"] else h[\"code\"]\n            lines.append(f\"  {h['code']} {name[:6]}\")\n            lines.append(f\"    {h['qty']:,} 股 | 成本 {h['cost_price']:.3f} 元\")\n\n    if hk_stocks:\n        lines.append(f\"\\n【港股持仓】共 {len(hk_stocks)} 只\")\n        for h in hk_stocks:\n            lines.append(f\"  {h['code']} {h['name']})\")\n            lines.append(f\"    {h['qty']:,} 股 | 成本 {h['cost_price']:.3f} 港币\")\n\n    if etf_funds:\n        lines.append(f\"\\n【ETF/基金】共 {len(etf_funds)} 只\")\n        for h in etf_funds:\n            lines.append(f\"  {h['code']} {h['name']})\")\n            lines.append(f\"    {h['qty']:,} 份 | 成本 {h['cost_price']:.3f} 元\")\n\n    lines.append(\"\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"【汇总】A股 {len(a_stocks)} 只 | 港股 {len(hk_stocks)} | ETF {len(etf_funds)} 只\")\n    lines.append(f\"持仓总数：{len(holdings)} 只 | 成本总额：{total_cost:,.0f} 元\")\n\n    if strategy:\n        bw = strategy.get(\"market_breadth\")\n        buy = strategy.get(\"buy_count\", 0)\n        sell = strategy.get(\"sell_count\", 0)\n        is_fresh = bool(strategy.get(\"is_fresh\"))\n        captured_at = strategy.get(\"market_breadth_captured_at\") or \"-\"\n        breadth_source = strategy.get(\"market_breadth_source\") or strategy.get(\"source\") or \"-\"\n        source_date_tag = strategy.get(\"source_date_tag\") or \"-\"\n        if bw is not None:\n            icon = \"🟢\" if bw >= 28 else \"🟡\" if bw >= 14 else \"🔴\"\n            freshness = \"\" if is_fresh else \"（非当日）\"\n            lines.append(f\"\\n【市场宽度】{bw:.2f}% {icon}{freshness}\")\n            lines.append(f\"【宽度时间】{captured_at} | 来源 {breadth_source} | 数据日期 {source_date_tag}\")\n        else:\n            lines.append(\"\\n【市场宽度】缺少有效数据\")\n        if buy or sell:\n            lines.append(f\"【策略信号】BUY {buy} 个 | SELL {sell} 个\")\n        risk_mode = strategy.get(\"risk_mode\", \"\")\n        if risk_mode:\n            lines.append(f\"【风险模式】{risk_mode}\")\n\n    if audit:\n        ar = audit.get(\"annual_return_pct\", 0)\n        mdd = audit.get(\"max_drawdown_pct\", 0)\n        sharpe = audit.get(\"sharpe\", 0)\n        if ar:\n            lines.append(f\"\\n【模拟盘审计】年化 {ar:.1f}% | 回撤 {mdd:.1f}% | 夏普 {sharpe:.2f}\")\n\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(f\"📊 生成时间：{now.strftime('%H:%M:%S')}\")\n    return \"\\n\".join(lines)\n\n\ndef main():\n    if not is_trading_day():\n        print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] 非 A 股交易日，跳过持仓日报\")\n        return\n\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] 生成持仓日报...\")\n    try:\n        holdings, date = get_holdings()\n    except Exception as e:\n        print(f\"[{datetime.now().strftime('%H:%M:%S')}] 中止发送：{e}\")\n        return\n\n    strategy = get_strategy_summary(datetime.now().strftime(\"%Y%m%d\"))\n    audit = get_audit()\n    report = build_report(holdings, date, strategy, audit)\n\n    out_file = REPORTS / \"daily_position_report_latest.md\"\n    out_file.write_text(report, encoding=\"utf-8\")\n    print(f\"已保存: {out_file.name}\")\n\n    print(\"\\n发送飞书...\")\n    result = send_feishu(report)\n    print(f\"发送结果: {result}\")\n    print(\"\\n\" + report)\n\n\nif __name__ == \"__main__\":\n    main()","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775483730073}}
