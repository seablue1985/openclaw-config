{"type":"message","id":"bf1f6b38","parentId":"da86ab5f","timestamp":"2026-04-06T13:26:15.641Z","message":{"role":"toolResult","toolCallId":"call_function_d7j4kb2t24n8_1","toolName":"read","content":[{"type":"text","text":"    governance_blocking = bool(gate.get(\"blocking_issues\")) or str(gate.get(\"overall_status\") or \"\").upper() not in {\"PASS\", \"GREEN\"}\n    control_status = normalize_status(control_tower.get(\"overall_status\"))\n    remediation_status = normalize_status(remediation.get(\"overall_status\")) if remediation else \"UNKNOWN\"\n\n    if missing_required or mismatched_required:\n        overall_status = \"BLOCK\"\n    elif governance_blocking:\n        overall_status = \"BLOCK\"\n    elif control_status == \"BLOCK\":\n        overall_status = \"BLOCK\"\n    elif control_status == \"YELLOW\" or remediation_status == \"YELLOW\" or unknown_required:\n        overall_status = \"YELLOW\"\n    else:\n        overall_status = \"GREEN\"\n\n    main_profiles, breadth_profiles = summarize_profiles(panel)\n    profile_holdings = build_profile_holdings(panel)\n    candidate_source_summary = build_candidate_source_summary(today_report)\n    acceptance_watchlist = build_acceptance_watchlist(remediation, role_output_archive)\n\n    payload = {\n        \"schema_version\": SCHEMA_VERSION,\n        \"report_kind\": \"daily_quant_analysis_skill\",\n        \"trade_date_tag\": trade_date_tag,\n        \"trade_date\": trade_date,\n        \"generated_at\": generated_at,\n        \"overall_status\": overall_status,\n        \"delivery_ready\": not missing_required and not mismatched_required,\n        \"data_freshness\": {\n            \"status\": \"BLOCK\" if (missing_required or mismatched_required) else (\"YELLOW\" if unknown_required else \"GREEN\"),\n            \"missing_required_inputs\": missing_required,\n            \"mismatched_required_inputs\": mismatched_required,\n            \"unknown_required_inputs\": unknown_required,\n            \"required_inputs\": required_inputs,\n            \"optional_inputs\": optional_inputs,\n        },\n        \"trading\": {\n            \"trading_status\": ((control_tower.get(\"trading_status\") or {}).get(\"status\")) or ((control_tower.get(\"strategy_layer\") or {}).get(\"trading_status\")) or today_report.get(\"precheck_status\"),\n            \"trading_reason\": ((control_tower.get(\"trading_status\") or {}).get(\"reason\")) or ((control_tower.get(\"strategy_layer\") or {}).get(\"trading_status_reason\")) or today_report.get(\"halt_reason\"),\n            \"recommendation_state\": ((today_report.get(\"recommendation_status\") or {}).get(\"state\")) or \"\",\n            \"execution_scope\": daily_audit.get(\"execution_scope\") or \"\",\n        },\n        \"governance\": {\n            \"status\": str(gate.get(\"overall_status\") or \"UNKNOWN\"),\n            \"blocking\": governance_blocking,\n            \"blocking_issues\": gate.get(\"blocking_issues\") or [],\n            \"generated_at\": gate.get(\"generated_at\") or \"\",\n        },\n        \"execution\": {\n            \"status\": ((control_tower.get(\"execution_layer\") or {}).get(\"trading_status\")) or \"\",\n            \"reason\": ((control_tower.get(\"execution_layer\") or {}).get(\"trading_status_reason\")) or \"\",\n            \"live_tomorrow_mode\": ((control_tower.get(\"execution_layer\") or {}).get(\"live_tomorrow_mode\")) or \"\",\n            \"live_orders_total\": ((control_tower.get(\"execution_layer\") or {}).get(\"live_orders_total\")),\n            \"live_pending_confirm_not_sent\": ((control_tower.get(\"execution_layer\") or {}).get(\"live_pending_confirm_not_sent\")),\n            \"live_not_sent\": ((control_tower.get(\"execution_layer\") or {}).get(\"live_not_sent\")),\n        },\n        \"profiles\": main_profiles,\n        \"breadth_profiles\": breadth_profiles,\n        \"profile_holdings\": profile_holdings,\n        \"candidate_source_summary\": candidate_source_summary,\n        \"candidate_summary\": {\n            \"buy_candidates\": today_report.get(\"buy_candidates\"),\n            \"research_buy_candidates\": today_report.get(\"research_buy_candidates\"),\n            \"sell_candidates\": today_report.get(\"sell_candidates\"),\n            \"top_buy_candidates\": (today_report.get(\"priority_candidates\") or [])[:5],\n            \"top_research_candidates\": (today_report.get(\"research_priority_candidates\") or [])[:5],\n            \"top_sell_risks\": (today_report.get(\"sell_candidates_list\") or [])[:5],\n        },\n        \"risk_and_ops\": {\n            \"audit_status\": daily_audit.get(\"overall_status\") or \"\",\n            \"intervention_status\": ((daily_audit.get(\"intervention_status\") or {}).get(\"status\")) or \"\",\n            \"manual_review_closure_status\": manual_review_closure.get(\"overall_status\") or \"\",\n            \"manual_review_closure_reason\": manual_review_closure.get(\"reason\") or \"\",\n            \"incident_status\": incident_registry.get(\"overall_status\") or \"\",\n            \"incident_count_30d\": incident_registry.get(\"incident_count_30d\"),\n            \"open_incident_count_30d\": incident_registry.get(\"open_incident_count_30d\"),\n        },\n        \"incidents\": (incident_registry.get(\"incidents\") or [])[:5],\n        \"acceptance_watchlist\": acceptance_watchlist,\n        \"source_files\": {\n\n[20 more lines in file. Use offset=545 to continue.]"}],"isError":false,"timestamp":1775481975631}}
