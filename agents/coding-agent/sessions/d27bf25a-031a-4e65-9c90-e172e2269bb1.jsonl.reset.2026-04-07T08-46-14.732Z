{"type":"message","id":"d8a06b3b","parentId":"423d741b","timestamp":"2026-04-06T13:25:24.973Z","message":{"role":"toolResult","toolCallId":"call_function_e0xbpw4zwz91_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport tempfile\nfrom pathlib import Path\nfrom typing import Any\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\n\n\ndef atomic_write_text(path: Path, content: str, *, encoding: str = \"utf-8\") -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with tempfile.NamedTemporaryFile(\"w\", encoding=encoding, dir=str(path.parent), delete=False) as handle:\n        handle.write(content)\n        tmp_path = Path(handle.name)\n    os.replace(tmp_path, path)\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef fmt_money(value: Any) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{float(value):,.0f}\"\n\n\ndef fmt_pct(value: Any) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{float(value):.2f}%\"\n\n\ndef short_sources(paths: list[str]) -> str:\n    return \", \".join(Path(item).name for item in paths if item) or \"-\"\n\n\ndef holding_compact(item: dict[str, Any]) -> str:\n    label = f\"{item.get('ts_code') or '-'} {item.get('name') or '-'}\"\n    bits: list[str] = []\n    if item.get(\"weight_pct\") not in (None, \"\"):\n        bits.append(f\"{float(item['weight_pct']):.2f}%\")\n    if item.get(\"pnl_pct\") not in (None, \"\"):\n        bits.append(fmt_pct(item.get(\"pnl_pct\")))\n    if item.get(\"buy_date\"):\n        bits.append(f\"买入{item['buy_date']}\")\n    return f\"{label}({ ' / '.join(bits) })\" if bits else label\n\n\ndef build_lines(payload: dict[str, Any]) -> list[str]:\n    lines = [\n        f\"【每日量化分析】{payload.get('trade_date')}\",\n        f\"总状态：{payload.get('overall_status')}\",\n        f\"交易状态：{((payload.get('trading') or {}).get('trading_status')) or '-'} / {((payload.get('trading') or {}).get('trading_reason')) or '-'}\",\n        f\"治理门禁：{((payload.get('governance') or {}).get('status')) or '-'}\",\n    ]\n\n    profiles = payload.get(\"profiles\") or []\n    if profiles:\n        lines.append(\"主组合：\")\n        for row in profiles[:3]:\n            lines.append(\n                f\"- {row.get('profile_name') or row.get('profile_slug')}: 净值 {fmt_money(row.get('nav'))}，总收益 {row.get('total_return_pct')}%，状态 {row.get('status')}\"\n            )\n\n    breadth_profiles = payload.get(\"breadth_profiles\") or []\n    if breadth_profiles:\n        lines.append(\"Breadth：\")\n        for row in breadth_profiles[:2]:\n            lines.append(\n                f\"- {row.get('profile_slug')}: 净值 {fmt_money(row.get('nav'))}，总收益 {row.get('total_return_pct')}%\"\n            )\n\n    profile_holdings = payload.get(\"profile_holdings\") or []\n    if profile_holdings:\n        lines.append(\"模拟盘持仓：\")\n        for entry in profile_holdings:\n            holdings = entry.get(\"holdings\") or []\n            holdings_text = \"；\".join(holding_compact(item) for item in holdings) if holdings else \"空仓\"\n            lines.append(\n                f\"- {entry.get('profile_name') or entry.get('profile_slug')}: {entry.get('source_label') or '单一模拟盘'} / {entry.get('position_count', 0)}持仓 / 来源 {short_sources(entry.get('source_files') or [])}\"\n            )\n            lines.append(f\"  {holdings_text}\")\n\n    candidate_summary = payload.get(\"candidate_summary\") or {}\n    candidate_source = payload.get(\"candidate_source_summary\") or {}\n    lines.append(\n        f\"候选：执行买入 {candidate_summary.get('buy_candidates', '-')}, 研究候选 {candidate_summary.get('research_buy_candidates', '-')}, 卖出风险 {candidate_summary.get('sell_candidates', '-')}\"\n    )\n    lines.append(\n        f\"候选来源：{candidate_source.get('source_label') or '-'} / {', '.join(candidate_source.get('source_file_names') or []) or '-'} / 策略 {', '.join(candidate_source.get('strategy_ids') or []) or '-'}\"\n    )\n\n    watchlist = payload.get(\"acceptance_watchlist\") or []\n    if watchlist:\n        lines.append(\"未闭环验收：\")\n        for item in watchlist[:3]:\n            lines.append(f\"- {item.get('summary')}\")\n\n    freshness = payload.get(\"data_freshness\") or {}\n    if freshness.get(\"missing_required_inputs\") or freshness.get(\"mismatched_required_inputs\"):\n        lines.append(\n            f\"数据新鲜度告警：missing={freshness.get('missing_required_inputs') or []} mismatch={freshness.get('mismatched_required_inputs') or []}\"\n        )\n\n    lines.append(f\"详报：research/reports/daily_quant_analysis_skill_{payload.get('trade_date_tag')}.md\")\n    return lines\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"Render Feishu summary text from structured daily quant analysis JSON\")\n    parser.add_argument(\"--input\", default=str(REPORT_DIR / \"daily_quant_analysis_skill_latest.json\"))\n    args = parser.parse_args()\n\n    payload = load_json(Path(args.input))\n    trade_date_tag = str(payload.get(\"trade_date_tag\") or \"latest\")\n    text = \"\\n\".join(build_lines(payload)).strip() + \"\\n\"\n\n    outputs = [\n        REPORT_DIR / f\"daily_quant_analysis_feishu_{trade_date_tag}.txt\",\n        REPORT_DIR / \"daily_quant_analysis_feishu_latest.txt\",\n    ]\n    for path in outputs:\n        atomic_write_text(path, text)\n    print(str(outputs[0]))\n\n[5 more lines in file. Use offset=131 to continue.]"}],"isError":false,"timestamp":1775481924964}}
{"type":"message","id":"6354c278","parentId":"d8a06b3b","timestamp":"2026-04-06T13:25:36.819Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the structure. The `render_daily_quant_analysis_feishu.py` is the Feishu summary renderer that reads from the JSON and produces a plain text Feishu message. \n\nThe JSON comes from `build_daily_quant_analysis_json.py`. Let me look at what I need to add:\n\n1. Add CB market temperature data to the report\n2. Add v4.3 strategy params to the report\n3. Add clearer signal section (BUY/SELL)\n4. Clean up non-trading day handling\n\nBut first, I need to understand where the input JSON comes from. Let me look at the build script.","thinkingSignature":"f14d21ef5ce0673de167d2c54cb064a849aac2c9301c503a474daff8a07b07fd"},{"type":"toolCall","id":"call_function_i1ldh3ou4f3g_1","name":"exec","arguments":{"command":"head -60 /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/build_daily_quant_analysis_json.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":118203,"output":187,"cacheRead":21467,"cacheWrite":0,"totalTokens":139857,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775481924978,"responseId":"0622e745387efa48188cd33e932d37da"}}
{"type":"message","id":"5ee584df","parentId":"6354c278","timestamp":"2026-04-06T13:25:36.857Z","message":{"role":"toolResult","toolCallId":"call_function_i1ldh3ou4f3g_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport csv\nimport json\nimport os\nimport re\nimport tempfile\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\nSCHEMA_VERSION = \"v0.3\"\n\nREQUIRED_INPUT_LABELS = [\n    \"control_tower\",\n    \"strategy_performance_panel\",\n    \"strategy_governance_gate\",\n    \"daily_strategy_audit\",\n]\n\nINPUT_FILES = {\n    \"control_tower\": REPORT_DIR / \"control_tower_daily_latest.json\",\n    \"strategy_performance_panel\": REPORT_DIR / \"strategy_performance_panel_latest.json\",\n    \"strategy_governance_gate\": REPORT_DIR / \"strategy_governance_gate_latest.json\",\n    \"daily_strategy_audit\": REPORT_DIR / \"daily_strategy_audit_latest.json\",\n    \"today_stock_strategy_report\": REPORT_DIR / \"today_stock_strategy_report_latest.json\",\n    \"incident_registry\": REPORT_DIR / \"incident_registry_latest.json\",\n    \"manual_review_closure_alert\": REPORT_DIR / \"manual_review_closure_alert_latest.json\",\n    \"role_output_archive\": REPORT_DIR / \"role_output_archive_latest.json\",\n    \"breadth_aggressive\": REPORT_DIR / \"breadth_aggressive_paper_latest.json\",\n    \"breadth_strict_oos\": REPORT_DIR / \"breadth_strict_oos_paper_latest.json\",\n}\n\nACCEPTANCE_LABELS = {\n    \"P0-3_manual_intervention_audit\": \"P0-3 人工干预留痕：还缺连续 5 个交易日真实样本\",\n    \"P2-1_data_snapshot_and_versioning\": \"P2-1 数据快照与复现：还缺 snapshot 回放作业与 6 个月历史回放验收\",\n    \"P2-3_role_outputs_archival\": \"P2-3 角色产出归档：还缺连续 4 周覆盖闭环\",\n}\n\n\ndef atomic_write_text(path: Path, content: str, *, encoding: str = \"utf-8\") -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with tempfile.NamedTemporaryFile(\"w\", encoding=encoding, dir=str(path.parent), delete=False) as handle:\n        handle.write(content)\n        tmp_path = Path(handle.name)\n    os.replace(tmp_path, path)\n\n\ndef atomic_write_json(path: Path, payload: Any) -> None:\n    atomic_write_text(path, json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef load_json(path: Path | None) -> dict[str, Any]:\n    if path is None or not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding=\"utf-8\"))"}],"details":{"status":"completed","exitCode":0,"durationMs":14,"aggregated":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport csv\nimport json\nimport os\nimport re\nimport tempfile\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\nSCHEMA_VERSION = \"v0.3\"\n\nREQUIRED_INPUT_LABELS = [\n    \"control_tower\",\n    \"strategy_performance_panel\",\n    \"strategy_governance_gate\",\n    \"daily_strategy_audit\",\n]\n\nINPUT_FILES = {\n    \"control_tower\": REPORT_DIR / \"control_tower_daily_latest.json\",\n    \"strategy_performance_panel\": REPORT_DIR / \"strategy_performance_panel_latest.json\",\n    \"strategy_governance_gate\": REPORT_DIR / \"strategy_governance_gate_latest.json\",\n    \"daily_strategy_audit\": REPORT_DIR / \"daily_strategy_audit_latest.json\",\n    \"today_stock_strategy_report\": REPORT_DIR / \"today_stock_strategy_report_latest.json\",\n    \"incident_registry\": REPORT_DIR / \"incident_registry_latest.json\",\n    \"manual_review_closure_alert\": REPORT_DIR / \"manual_review_closure_alert_latest.json\",\n    \"role_output_archive\": REPORT_DIR / \"role_output_archive_latest.json\",\n    \"breadth_aggressive\": REPORT_DIR / \"breadth_aggressive_paper_latest.json\",\n    \"breadth_strict_oos\": REPORT_DIR / \"breadth_strict_oos_paper_latest.json\",\n}\n\nACCEPTANCE_LABELS = {\n    \"P0-3_manual_intervention_audit\": \"P0-3 人工干预留痕：还缺连续 5 个交易日真实样本\",\n    \"P2-1_data_snapshot_and_versioning\": \"P2-1 数据快照与复现：还缺 snapshot 回放作业与 6 个月历史回放验收\",\n    \"P2-3_role_outputs_archival\": \"P2-3 角色产出归档：还缺连续 4 周覆盖闭环\",\n}\n\n\ndef atomic_write_text(path: Path, content: str, *, encoding: str = \"utf-8\") -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with tempfile.NamedTemporaryFile(\"w\", encoding=encoding, dir=str(path.parent), delete=False) as handle:\n        handle.write(content)\n        tmp_path = Path(handle.name)\n    os.replace(tmp_path, path)\n\n\ndef atomic_write_json(path: Path, payload: Any) -> None:\n    atomic_write_text(path, json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef load_json(path: Path | None) -> dict[str, Any]:\n    if path is None or not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding=\"utf-8\"))","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775481936845}}
