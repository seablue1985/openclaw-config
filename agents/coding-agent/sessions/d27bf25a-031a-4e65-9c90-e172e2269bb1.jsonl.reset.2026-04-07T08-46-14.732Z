{"type":"message","id":"4dce2005","parentId":"191e9bc6","timestamp":"2026-04-06T06:37:28.389Z","message":{"role":"toolResult","toolCallId":"call_function_fmsfz3saoh6v_1","toolName":"read","content":[{"type":"text","text":"def main() -> None:\n    ap = argparse.ArgumentParser(description=\"运行数据源健康探针\")\n    ap.add_argument(\"--scope\", required=True, help=\"范围标签，例如 morning 或 intraday\")\n    args = ap.parse_args()\n\n    policy = load_policy(POLICY_PATH)\n    inputs_cfg = json.loads(INPUTS_CONFIG.read_text(encoding=\"utf-8\"))\n    snapshot = org.build_input_snapshot(inputs_cfg)\n    summary = org.make_summary(snapshot, datetime.now())\n    probe = compute_probe(policy, summary, args.scope)\n\n    md_path = REPORT_DIR / f\"investment_research_data_source_health_{args.scope}_{datetime.now():%Y%m%d}.md\"\n    json_path = REPORT_DIR / f\"investment_research_data_source_health_{args.scope}_{datetime.now():%Y%m%d}.json\"\n    md_path.write_text(render_markdown(probe), encoding=\"utf-8\")\n    json_path.write_text(json.dumps(probe, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    print(md_path)\n    print(json_path)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1775457448385}}
{"type":"message","id":"f1cffcfd","parentId":"4dce2005","timestamp":"2026-04-06T06:37:28.395Z","message":{"role":"toolResult","toolCallId":"call_function_fmsfz3saoh6v_2","toolName":"read","content":[{"type":"text","text":"def main() -> None:\n    parser = argparse.ArgumentParser(description=\"盘中风险复检\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD，默认今天\")\n    parser.add_argument(\"--config\", default=str(LIVE_CONFIG_PATH), help=\"live trading config\")\n    args = parser.parse_args()\n\n    date_tag = parse_date_tag(args.date) if args.date else datetime.now().strftime(\"%Y%m%d\")\n    config_path = Path(args.config).expanduser().resolve()\n    config = load_json(config_path)\n\n    runtime_metrics = load_runtime_metrics_for_date(date_tag, config, report_dir=REPORT_DIR)\n    runtime = evaluate_runtime_state_for_date(\n        config=config,\n        live_payload=runtime_metrics[\"live_payload\"],\n        date_tag=date_tag,\n        index_ret_pct=float(runtime_metrics.get(\"index_ret_pct\", 0.0) or 0.0),\n        market_breadth=runtime_metrics.get(\"market_breadth\"),\n    )\n    base_runtime = runtime_to_dict(\n        runtime,\n        benchmark_code=str(runtime_metrics.get(\"benchmark_code\") or \"\"),\n        index_ret_pct=float(runtime_metrics.get(\"index_ret_pct\", 0.0) or 0.0),\n    )\n    regime_snapshots = compute_regime_snapshots(\n        config,\n        date_tag=date_tag,\n        benchmark_code=str(runtime_metrics.get(\"benchmark_code\") or \"\") or None,\n        market_breadth=float(runtime_metrics.get(\"market_breadth\", 0.0) or 0.0),\n    )\n    base_overlay = apply_regime_overlays(\n        mode=str(base_runtime.get(\"mode\") or \"normal\"),\n        risk_off=bool(base_runtime.get(\"risk_off\")),\n        hard_stop=bool(base_runtime.get(\"hard_stop\")),\n        halt_new_buy=bool(base_runtime.get(\"halt_new_buy\")),\n        gate_reasons=base_runtime.get(\"gate_reasons\") or [],\n        volatility_snapshot=regime_snapshots.get(\"volatility\"),\n        liquidity_snapshot=regime_snapshots.get(\"liquidity\"),\n    )\n    base_runtime.update(base_overlay)\n    base_runtime[\"volatility_snapshot\"] = regime_snapshots.get(\"volatility\")\n\n[213 more lines in file. Use offset=201 to continue.]"}],"isError":false,"timestamp":1775457448388}}
{"type":"message","id":"8091a3e9","parentId":"f1cffcfd","timestamp":"2026-04-06T06:37:44.123Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to add the trading day check to both scripts. For `run_investment_research_data_source_health_probe.py`, the main function is at line 147. For `run_intraday_risk_recheck.py`, the main function is at line 161.Let me add the check to both.For `run_investment_research_data_source_health_probe.py`, I'll add the check right after parsing args in `main()`.\nFor `run_intraday_risk_recheck.py`, I'll add the check right after parsing args in `main()`.","thinkingSignature":"5a33a048394bfac2ec8a61f457b39b378ef628828ab1a08678de29d5f7c6acf4"},{"type":"text","text":"两条都加交易日判断：\n"},{"type":"toolCall","id":"call_function_b5uvoukv9g41_1","name":"edit","arguments":{"file_path":"/Users/ling/.openclaw/workspace/scripts/run_investment_research_data_source_health_probe.py","old_string":"def main() -> None:\n    ap = argparse.ArgumentParser(description=\"运行数据源健康探针\")\n    ap.add_argument(\"--scope\", required=True, help=\"范围标签，例如 morning 或 intraday\")\n    args = ap.parse_args()\n\n    policy = load_policy(POLICY_PATH)","new_string":"def _is_trading_day_now() -> bool:\n    \"\"\"用腾讯行情 API 判断当前是否为 A 股交易日（非交易时段也检查是否是交易日）。\"\"\"\n    try:\n        import urllib.request\n        req = urllib.request.Request(\n            \"https://qt.gtimg.cn/q=sh000001\",\n            headers={\"User-Agent\": \"Mozilla/5.0\"},\n        )\n        with urllib.request.urlopen(req, timeout=5) as resp:\n            content = resp.read().decode(\"gbk\", errors=\"replace\")\n        for line in content.split(\";\"):\n            if \"sh000001\" in line:\n                parts = line.split(\"~\")\n                if len(parts) > 30:\n                    mkt_str = parts[30].strip()[:8]\n                    market_date = f\"{mkt_str[:4]}-{mkt_str[4:6]}-{mkt_str[6:8]}\"\n                    today = datetime.now().strftime(\"%Y-%m-%d\")\n                    return market_date == today\n                break\n        return datetime.now().weekday() < 5\n    except Exception:\n        return datetime.now().weekday() < 5\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser(description=\"运行数据源健康探针\")\n    ap.add_argument(\"--scope\", required=True, help=\"范围标签，例如 morning 或 intraday\")\n    args = ap.parse_args()\n\n    if not _is_trading_day_now():\n        now = datetime.now()\n        weekday = [\"周一\", \"周二\", \"周三\", \"周四\", \"周五\", \"周六\", \"周日\"][now.weekday()]\n        print(f\"[{now:%Y-%m-%d %H:%M}] 非 A 股交易日（{weekday}），跳过数据源健康探针。\", flush=True)\n        return\n\n    policy = load_policy(POLICY_PATH)"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":97012,"output":634,"cacheRead":21467,"cacheWrite":0,"totalTokens":119113,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775457448395,"responseId":"062287a826d286ccbc6aaf19383f654a"}}
