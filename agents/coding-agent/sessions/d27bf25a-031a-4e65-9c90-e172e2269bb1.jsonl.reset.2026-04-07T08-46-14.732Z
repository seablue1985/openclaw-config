g = \"\"\n        if action == \"卖出\":\n            sig = \" ⚠️ 卖出信号\"\n        elif action == \"观望\":\n            sig = \" 👀 观望\"\n\n        lines.append(f\"  • {code} {name[:8]} ×{qty}手 成本:{cost}{sig}\")\n        if strat_price:\n            lines.append(f\"    当前参考价:{strat_price} | 止损:{stop_loss or '?'} 目标:{take_profit or '?'}\")\n        shown += 1\n\n    if len(holdings) > 5:\n        lines.append(f\"  ... 还有 {len(holdings) - 5} 只（见完整持仓）\")\n    elif not holdings:\n        lines.append(\"  （空仓）\")"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":38004,"output":622,"cacheRead":21467,"cacheWrite":0,"totalTokens":60093,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775483799649,"responseId":"0622ee981ba879c6aa727eb6a9cbc03a"}}
