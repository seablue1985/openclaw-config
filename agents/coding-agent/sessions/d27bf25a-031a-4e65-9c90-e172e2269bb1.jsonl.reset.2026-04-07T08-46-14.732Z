{"type":"message","id":"c810e254","parentId":"55e7db46","timestamp":"2026-04-06T13:28:33.880Z","message":{"role":"toolResult","toolCallId":"call_function_kpm91tptp3ec_1","toolName":"read","content":[{"type":"text","text":"\n\ndef render_markdown(payload: dict[str, Any]) -> str:\n    lines = [\n        f\"# 每日量化分析简报 — {payload.get('trade_date')}\",\n        \"\",\n        f\"> 结构化主产物渲染 | schema_version={payload.get('schema_version')} | generated_at={payload.get('generated_at')} | overall_status={payload.get('overall_status')}\",\n        \"\",\n        \"## 1. 今日总判断\",\n        f\"- 总状态：**{payload.get('overall_status')}**\",\n        f\"- 交易状态：**{((payload.get('trading') or {}).get('trading_status')) or '-'}**\",\n        f\"- 交易原因：{((payload.get('trading') or {}).get('trading_reason')) or '-'}\",\n        f\"- 推荐状态：{((payload.get('trading') or {}).get('recommendation_state')) or '-'}\",\n        f\"- 执行口径：{((payload.get('trading') or {}).get('execution_scope')) or '-'}\",\n        f\"- 治理门禁：{((payload.get('governance') or {}).get('status')) or '-'}\",\n        f\"- 交付就绪：{'是' if payload.get('delivery_ready') else '否'}\",\n        \"\",\n        \"## 2. 数据新鲜度与输入校验\",\n        *build_freshness_lines(payload),\n        \"\",\n        \"## 3. 组合表现\",\n        *build_profile_table(payload.get(\"profiles\") or []),\n        \"\",\n        \"### Breadth 组合\",\n        *build_profile_table(payload.get(\"breadth_profiles\") or []),\n        \"\",\n        \"## 4. 模拟盘持仓明细\",\n        *build_profile_holdings_lines(payload),\n        \"\",\n        \"## 5. 候选与风险\",\n        *build_candidate_lines(payload),\n        \"\",\n        \"## 6. 治理与运行\",\n        f\"- 日审计：{((payload.get('risk_and_ops') or {}).get('audit_status')) or '-'}\",\n        f\"- 人工干预留痕：{((payload.get('risk_and_ops') or {}).get('intervention_status')) or '-'}\",\n        f\"- 人工复核闭环：{((payload.get('risk_and_ops') or {}).get('manual_review_closure_status')) or '-'}（{((payload.get('risk_and_ops') or {}).get('manual_review_closure_reason')) or '-'}）\",\n        f\"- Incident 状态：{((payload.get('risk_and_ops') or {}).get('incident_status')) or '-'}\",\n        f\"- 近30天 incident：{fmt_int((payload.get('risk_and_ops') or {}).get('incident_count_30d'))}，其中未关闭：{fmt_int((payload.get('risk_and_ops') or {}).get('open_incident_count_30d'))}\",\n        f\"- 实盘执行状态：{((payload.get('execution') or {}).get('status')) or '-'} / {((payload.get('execution') or {}).get('reason')) or '-'}\",\n        f\"- 待确认未发送：{fmt_int((payload.get('execution') or {}).get('live_pending_confirm_not_sent'))}，未发送：{fmt_int((payload.get('execution') or {}).get('live_not_sent'))}\",\n\n[37 more lines in file. Use offset=220 to continue.]"}],"isError":false,"timestamp":1775482113867}}
