{"type":"message","id":"2d5b271a","parentId":"aefbb378","timestamp":"2026-04-06T05:42:46.453Z","message":{"role":"toolResult","toolCallId":"call_function_iqu0q1mrlazo_1","toolName":"read","content":[{"type":"text","text":"    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)\n    STATE_PATH.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef is_trading_day(date_str: str) -> bool:\n    \"\"\"\n    交易日判断：\n    1) 优先使用本地指数日历（date/trade_date）\n    2) 若本地日历过旧（目标日期晚于最后一条日历），降级为工作日判断（周一~周五）\n    \"\"\"\n    # 先准备工作日降级逻辑\n    try:\n        date_obj = datetime.strptime(date_str, \"%Y-%m-%d\")\n        weekday_fallback = date_obj.weekday() < 5\n    except Exception:\n        weekday_fallback = False\n\n    if not INDEX_CSV.exists():\n        return weekday_fallback\n\n    # 兼容两种常见列名：date / trade_date（例如 Tushare 导出的指数数据）\n    df = pd.read_csv(INDEX_CSV, usecols=lambda c: c in {\"date\", \"trade_date\"})\n    date_col = \"date\" if \"date\" in df.columns else (\"trade_date\" if \"trade_date\" in df.columns else None)\n    if date_col is None:\n        return weekday_fallback\n\n    normalized: set[str] = set()\n    for x in df[date_col].dropna().tolist():\n        s = str(x).strip()\n        if len(s) == 8 and s.isdigit():\n            normalized.add(f\"{s[:4]}-{s[4:6]}-{s[6:8]}\")\n        else:\n            normalized.add(s[:10])\n\n    if date_str in normalized:\n        return True\n\n    # 日历不含目标日期，若目标日期晚于本地日历最大日期，则降级为工作日判断\n    try:\n        latest = max(normalized) if normalized else \"\"\n\n[314 more lines in file. Use offset=85 to continue.]"}],"isError":false,"timestamp":1775454166447}}
