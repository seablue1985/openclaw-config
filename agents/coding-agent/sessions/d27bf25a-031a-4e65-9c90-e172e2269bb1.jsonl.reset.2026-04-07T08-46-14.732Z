{"type":"message","id":"88cc9a1f","parentId":"eb6896a8","timestamp":"2026-04-06T13:56:56.478Z","message":{"role":"toolResult","toolCallId":"call_function_srh85p3qh9q4_1","toolName":"exec","content":[{"type":"text","text":"def build_actionable_brief(trade_card, audit, strategy, real_holdings, real_meta, sim_meta):\n    \"\"\"构建高度可执行的简报\"\"\"\n    now = datetime.now()\n    lines = []\n\n    # ===== 头部 =====\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(\"📊 A股投研可执行简报\")\n    lines.append(f\"{now.strftime('%Y-%m-%d %H:%M')} | 交易日\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    # ===== 系统状态 =====\n    if audit:\n        status = audit.get(\"overall_status\", \"?\")\n        status_map = {\"PASS\": \"✅ 正常\", \"FAIL\": \"❌ 失败\", \"WARNING\": \"⚠️ 警告\", \"OK\": \"✅ 正常\", \"ALERT\": \"ALERT\"}\n        status_text = status_map.get(str(status).upper(), str(status))\n\n        ar = audit.get(\"annual_return_pct\", 0)\n        mdd = audit.get(\"max_drawdown_pct\", 0)\n        sharpe = audit.get(\"sharpe\", 0)\n\n        lines.append(\"\")\n        lines.append(f\"【系统审计】{status_text}\")\n        if ar is not None:\n            lines.append(f\"年化 {float(ar):.1f}% | 回撤 {float(mdd):.1f}% | 夏普 {float(sharpe):.2f}\")\n\n    # ===== 持仓口径 =====\n    lines.append(\"\")\n    lines.append(\"【持仓口径】\")\n    lines.append(\n        f\"  实盘来源: {real_meta.get('selected_file')} | 持仓 {real_meta.get('selected_count', 0)} 只\"\n    )\n    if real_meta.get(\"fallback_used\"):\n        lines.append(\n            f\"  ⚠️ 最新文件 {real_meta.get('latest_file')} 仅 {real_meta.get('latest_count', 0)} 只，\"\n            f\"已按防异常规则回退\"\n        )\n\n    sim_profiles = sim_meta.get(\"profiles\", [])\n    sim_nonzero = [p for p in sim_profiles if p.get(\"count\", 0) > 0]\n    if sim_profiles:\n        if sim_nonzero:\n            detail = \"；\".join([f\"{p['profile']}={p['count']}\" for p in sim_nonzero])\n            lines.append(f\"  模拟盘合计: {sim_meta.get('total_count', 0)} 只（{detail}）\")\n        else:\n            lines.append(\"  模拟盘合计: 0 只\")\n\n    # ===== 实盘持仓 =====\n    if real_holdings:\n        lines.append(\"\")\n        lines.append(f\"【实盘持仓】{len(real_holdings)} 只\")\n        preview = 8 if len(real_holdings) > 8 else len(real_holdings)\n        for h in real_holdings[:preview]:\n            lines.append(f\"  • {h['code']} {h['name']} ×{h['qty']}手 成本价:{h['cost']}\")\n        if len(real_holdings) > preview:\n            lines.append(f\"  ... 还有 {len(real_holdings) - preview} 只\")\n    else:\n        lines.append(\"\")\n        lines.append(\"【实盘持仓】暂无\")\n\n    # ===== 风险框架 =====\n    if audit:\n        risk_off = audit.get(\"risk_off\", None)\n        if risk_off is not None:\n            lines.append(\"\")\n            if risk_off:\n                lines.append(\"【风险框架】🔴 风险收缩模式（谨慎开新仓）\")\n            else:\n                lines.append(\"【风险框架】🟢 正常模式\")\n\n    # ===== 今日行动 =====\n    lines.append(\"\")\n    lines.append(\"【今日行动】\")\n\n    if strategy:\n        # 从策略报告提取 BUY/SELL 数量\n        buy_m = re.search(r\"形成 `(\\d+)` 个去重 BUY 候选\", strategy)\n        sell_m = re.search(r\"形成 `(\\d+)` 个去重 SELL 候选\", strategy)\n        buy_count = int(buy_m.group(1)) if buy_m else 0\n        sell_count = int(sell_m.group(1)) if sell_m else 0\n\n        lines.append(f\"  策略 BUY 候选: {buy_count} 个（详见完整报告）\")\n        lines.append(f\"  策略 SELL 候选: {sell_count} 个（详见完整报告）\")\n\n    if trade_card:\n        # 提取观察池\n        obs = re.findall(r\"`(\\d{6})`\\.SZ` (.+?) \\| 动作=(观察|买入)\", clean(trade_card))\n        if obs:\n            lines.append(f\"  观察候选: {len(obs)} 个\")"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"def build_actionable_brief(trade_card, audit, strategy, real_holdings, real_meta, sim_meta):\n    \"\"\"构建高度可执行的简报\"\"\"\n    now = datetime.now()\n    lines = []\n\n    # ===== 头部 =====\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n    lines.append(\"📊 A股投研可执行简报\")\n    lines.append(f\"{now.strftime('%Y-%m-%d %H:%M')} | 交易日\")\n    lines.append(\"━━━━━━━━━━━━━━━━━━━━\")\n\n    # ===== 系统状态 =====\n    if audit:\n        status = audit.get(\"overall_status\", \"?\")\n        status_map = {\"PASS\": \"✅ 正常\", \"FAIL\": \"❌ 失败\", \"WARNING\": \"⚠️ 警告\", \"OK\": \"✅ 正常\", \"ALERT\": \"ALERT\"}\n        status_text = status_map.get(str(status).upper(), str(status))\n\n        ar = audit.get(\"annual_return_pct\", 0)\n        mdd = audit.get(\"max_drawdown_pct\", 0)\n        sharpe = audit.get(\"sharpe\", 0)\n\n        lines.append(\"\")\n        lines.append(f\"【系统审计】{status_text}\")\n        if ar is not None:\n            lines.append(f\"年化 {float(ar):.1f}% | 回撤 {float(mdd):.1f}% | 夏普 {float(sharpe):.2f}\")\n\n    # ===== 持仓口径 =====\n    lines.append(\"\")\n    lines.append(\"【持仓口径】\")\n    lines.append(\n        f\"  实盘来源: {real_meta.get('selected_file')} | 持仓 {real_meta.get('selected_count', 0)} 只\"\n    )\n    if real_meta.get(\"fallback_used\"):\n        lines.append(\n            f\"  ⚠️ 最新文件 {real_meta.get('latest_file')} 仅 {real_meta.get('latest_count', 0)} 只，\"\n            f\"已按防异常规则回退\"\n        )\n\n    sim_profiles = sim_meta.get(\"profiles\", [])\n    sim_nonzero = [p for p in sim_profiles if p.get(\"count\", 0) > 0]\n    if sim_profiles:\n        if sim_nonzero:\n            detail = \"；\".join([f\"{p['profile']}={p['count']}\" for p in sim_nonzero])\n            lines.append(f\"  模拟盘合计: {sim_meta.get('total_count', 0)} 只（{detail}）\")\n        else:\n            lines.append(\"  模拟盘合计: 0 只\")\n\n    # ===== 实盘持仓 =====\n    if real_holdings:\n        lines.append(\"\")\n        lines.append(f\"【实盘持仓】{len(real_holdings)} 只\")\n        preview = 8 if len(real_holdings) > 8 else len(real_holdings)\n        for h in real_holdings[:preview]:\n            lines.append(f\"  • {h['code']} {h['name']} ×{h['qty']}手 成本价:{h['cost']}\")\n        if len(real_holdings) > preview:\n            lines.append(f\"  ... 还有 {len(real_holdings) - preview} 只\")\n    else:\n        lines.append(\"\")\n        lines.append(\"【实盘持仓】暂无\")\n\n    # ===== 风险框架 =====\n    if audit:\n        risk_off = audit.get(\"risk_off\", None)\n        if risk_off is not None:\n            lines.append(\"\")\n            if risk_off:\n                lines.append(\"【风险框架】🔴 风险收缩模式（谨慎开新仓）\")\n            else:\n                lines.append(\"【风险框架】🟢 正常模式\")\n\n    # ===== 今日行动 =====\n    lines.append(\"\")\n    lines.append(\"【今日行动】\")\n\n    if strategy:\n        # 从策略报告提取 BUY/SELL 数量\n        buy_m = re.search(r\"形成 `(\\d+)` 个去重 BUY 候选\", strategy)\n        sell_m = re.search(r\"形成 `(\\d+)` 个去重 SELL 候选\", strategy)\n        buy_count = int(buy_m.group(1)) if buy_m else 0\n        sell_count = int(sell_m.group(1)) if sell_m else 0\n\n        lines.append(f\"  策略 BUY 候选: {buy_count} 个（详见完整报告）\")\n        lines.append(f\"  策略 SELL 候选: {sell_count} 个（详见完整报告）\")\n\n    if trade_card:\n        # 提取观察池\n        obs = re.findall(r\"`(\\d{6})`\\.SZ` (.+?) \\| 动作=(观察|买入)\", clean(trade_card))\n        if obs:\n            lines.append(f\"  观察候选: {len(obs)} 个\")","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775483816473}}
