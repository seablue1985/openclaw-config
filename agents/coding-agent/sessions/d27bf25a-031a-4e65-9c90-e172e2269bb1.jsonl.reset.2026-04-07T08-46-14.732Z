{"type":"message","id":"ba90b870","parentId":"e3b9b452","timestamp":"2026-04-06T05:39:48.073Z","message":{"role":"toolResult","toolCallId":"call_function_x7v5i8o9jsti_1","toolName":"read","content":[{"type":"text","text":"def main() -> None:\n    ap = argparse.ArgumentParser(description=\"Run always-on background cycle for investment research org\")\n    ap.add_argument(\"--cycle\", choices=[\"pre_open\", \"intraday\", \"post_close\", \"overnight\"], default=\"overnight\")\n    args = ap.parse_args()\n\n    now = datetime.now()\n    REPORT_DIR.mkdir(parents=True, exist_ok=True)\n    duty_cfg = load_json(DUTY_CONFIG)\n    role_map = {r[\"id\"]: r for r in duty_cfg.get(\"roles\", [])}\n    inputs_cfg = load_json(INPUTS_CONFIG)\n    snapshot = org.build_input_snapshot(inputs_cfg)\n    summary = org.make_summary(snapshot, now)\n\n    focused_roles = CYCLE_TO_ROLE_FOCUS[args.cycle]\n    policy = load_policy(DATA_SOURCE_POLICY)\n    source_runtime = build_runtime_status(policy, summary=summary, role_ids=focused_roles, cycle=args.cycle)\n    outputs = []\n    md_lines = [\n        f\"# 来福投研会 - 常驻值班周期（{CYCLE_LABEL.get(args.cycle, args.cycle)}）\",\n        \"\",\n        f\"- 生成时间：{now:%Y-%m-%d %H:%M:%S}\",\n        f\"- 周期目标：{duty_cfg['cycles'][args.cycle]['goal']}\",\n        f\"- 审计状态：{cn_status(summary.get('audit_status', 'unknown'))}\",\n        f\"- 风险收缩：{cn_bool(summary.get('risk_off', '-'))}\",\n        f\"- 数据源状态：{cn_status(source_runtime.get('status'))}\",\n        f\"- 本轮主源：{cn_sources(source_runtime.get('primary_sources', []))}\",\n        f\"- 本轮确认源：{cn_sources(source_runtime.get('confirmation_sources', []))}\",\n        \"\",\n    ]\n\n    for role_id in focused_roles:\n        role = role_map[role_id]\n        notes = build_role_note(role_id, snapshot, summary)\n        payload = {\n            \"generated_at\": now.strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"cycle\": args.cycle,\n            \"role_id\": role_id,\n            \"role_label\": ROLE_LABEL[role_id],\n            \"duties\": role.get(\"duties\", []),\n            \"outputs\": role.get(\"outputs\", []),\n            \"notes\": notes,\n            \"summary\": summary,\n            \"data_source_runtime\": source_runtime,\n        }\n        md_path = REPORT_DIR / f\"investment_research_background_{role_id}_{args.cycle}_{now:%Y%m%d}.md\"\n        json_path = REPORT_DIR / f\"investment_research_background_{role_id}_{args.cycle}_{now:%Y%m%d}.json\"\n        md_content = [\n            f\"# 来福投研会 - {ROLE_LABEL[role_id]} 常驻值班卡\",\n            \"\",\n            f\"- 生成时间：{now:%Y-%m-%d %H:%M:%S}\",\n            f\"- 周期：{CYCLE_LABEL.get(args.cycle, args.cycle)}\",\n            \"\",\n            \"## 当前职责\",\n        ]\n        for item in role.get(\"duties\", []):\n            md_content.append(f\"- {item}\")\n        md_content.append(\"\")\n        md_content.append(\"## 本轮输出\")\n        for item in notes:\n            md_content.append(f\"- {item}\")\n\n[52 more lines in file. Use offset=252 to continue.]"}],"isError":false,"timestamp":1775453988068}}
