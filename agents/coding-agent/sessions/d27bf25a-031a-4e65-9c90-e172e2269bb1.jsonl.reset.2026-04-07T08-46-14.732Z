n+ 76     return summary_path, windows_path\n+ 77 \n+ 78 \n  59 def load_latest_summary(path: Path) -> dict | None:\n  60     try:\n  61         return json.loads(path.read_text(encoding=\"utf-8\"))\n  62     except Exception:\n  63         return None\n  64 \n  65 \n- 66 def extract_latest_window(d: dict) -> dict | None:\n- 67     \"\"\"从 summary 中提取最晚的一个 test window。\"\"\"\n- 68     windows = d.get(\"windows\", [])\n+ 86 def extract_latest_window(summary: dict, windows_csv: Path | None) -> dict | None:\n+ 87     \"\"\"从 windows CSV 提取最晚的一个 test window（比 summary JSON 更准确）。\"\"\"\n+ 88     if windows_csv and windows_csv.exists():\n+ 89         try:\n+ 90             import pandas as pd\n+ 91             df = pd.read_csv(windows_csv)\n+ 92             if \"test_end\" in df.columns and \"test_sharpe_daily\" in df.columns:\n+ 93                 df = df.sort_values(\"test_end\")\n+ 94                 row = df.iloc[-1]\n+ 95                 return row.to_dict()\n+ 96         except Exception:\n+ 97             pass\n+ 98     # 降级：从 summary 中取\n+ 99     windows = summary.get(\"windows\", [])\n  69     if not windows:\n  70         return None\n- 71     # 按 test_end 排序，取最晚的\n- 72     latest = max(windows, key=lambda w: w.get(\"test_end\", \"\"))\n- 73     return latest\n+102     return max(windows, key=lambda w: w.get(\"test_end\", \"\"))\n  74 \n  75 \n  76 def compute_alerts(latest_window: dict, summary: dict) -> list[dict]:\n  77     \"\"\"计算告警项。\"\"\"\n     ...","firstChangedLine":44},"isError":false,"timestamp":1775473005026}}
