R / \"build_daily_quant_analysis_json.py\"\nRENDER_MD_SCRIPT = SCRIPTS_DIR / \"render_daily_quant_analysis_md.py\"\nRENDER_FEISHU_SCRIPT = SCRIPTS_DIR / \"render_daily_quant_analysis_feishu.py\"\nDELIVERY_STATUS_SCRIPT = SCRIPTS_DIR / \"manage_daily_quant_analysis_delivery.py\"\n\n# 找指数日频 CSV 用于交易日判断\nINDEX_CSV = REPORT_DIR / \"daily_zz2000_closes.csv\"\n\n\ndef _is_trading_day(date_str: str) -> bool:\n    \"\"\"判断是否为 A 股交易日。优先用指数日历，降级为工作日（周一~五）。\"\"\"\n    try:\n        date_obj = datetime.strptime(date_str, \"%Y-%m-%d\")\n        weekday_fallback = date_obj.weekday() < 5\n    except Exception:\n        weekday_fallback = False\n\n    if not INDEX_CSV.exists():\n        return weekday_fallback\n\n    try:\n        df = pd.read_csv(INDEX_CSV, usecols=lambda c: c in {\"date\", \"trade_date\"})\n        date_col = \"date\" if \"date\" in df.columns else (\"trade_date\" if \"trade_date\" in df.columns else None)\n        if date_col is None:\n            return weekday_fallback\n\n        normalized: set[str] = set()\n        for x in df[date_col].dropna().tolist():\n            s = str(x).strip()\n            if len(s) == 8 and s.isdigit():\n                normalized.add(f\"{s[:4]}-{s[4:6]}-{s[6:8]}\")\n            else:\n                normalized.add(s[:10])\n\n        return date_str in normalized\n    except Exception:\n        return weekday_fallback\n\n\ndef run_step(command: list[str]) -> None:\n    subprocess.run(command, check=True)\n\n\ndef main() -> int:\n    parser = argparse.ArgumentParser(description=\"Daily investment research brief orchestrator\")\n    parser.add_argument(\"mode\", nargs=\"?\", default=\"morning\", choices=[\"morning\", \"close\"], help=\"Report mode\")\n    parser.add_argument(\"--date-tag\", default=\"\", help=\"Optional trade date tag override\")\n    parser.add_argument(\"--json-only\", action=\"store_true\", help=\"Only build structured JSON artifact\")\n    parser.add_argument(\"--skip-feishu-render\", action=\"store_true\", help=\"Skip generating Feishu summary text artifact\")\n    parser.add_argument(\n        \"--skip-delivery-status-sync\",\n        action=\"store_true\",\n        help=\"Skip updating delivery status bookkeeping artifacts\",\n    )\n    parser.add_argument(\n        \"--force\",\n        action=\"store_true\",\n        help=\"强制在非交易日运行（用于手动调试）\",\n    )\n    args = parser.parse_args()\n\n    date_tag = args.date_tag or datetime.now().strftime(\"%Y-%m-%d\")\n    if not args.force and not _is_trading_day(date_tag):\n        now = datetime.now().strftime(\"%Y-%m-%d %H:%M\")\n        weekday_name = [\"周一\", \"周二\", \"周三\", \"周四\", \"周五\", \"周六\", \"周日\"][datetime.strptime(date_tag, \"%Y-%m-%d\").weekday()]\n        print(f\"[{now}] 非 A 股交易日（{date_tag} {weekday_name}），跳过日报生成。\", flush=True)\n        return 0"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":37535,"output":1130,"cacheRead":21467,"cacheWrite":0,"totalTokens":60132,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775453885581,"responseId":"062279befef89c73673351eb674b9116"}}
