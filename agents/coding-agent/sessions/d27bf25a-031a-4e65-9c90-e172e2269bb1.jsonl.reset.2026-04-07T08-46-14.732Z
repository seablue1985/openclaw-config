{"type":"message","id":"b9c8b20e","parentId":"72b552be","timestamp":"2026-04-06T13:35:33.212Z","message":{"role":"toolResult","toolCallId":"call_function_byxk2ju7jqs8_1","toolName":"read","content":[{"type":"text","text":"        lines.append(\n            f\"来源：{format_buy_source(signals.get('signal_file', ''), top_buy, signals.get('signal_generated_at', ''))}\"\n        )\n        for s in top_buy:\n            lines.append(f\"  {s['code']} {s['name']} 评分{s['score']:.3f}\")\n    elif signals.get(\"signal_file\"):\n        lines.append(\"\")\n        lines.append(\"**买入候选 TOP3：**\")\n        lines.append(\n            f\"来源：{format_buy_source(signals.get('signal_file', ''), [], signals.get('signal_generated_at', ''))}\"\n        )\n        lines.append(\"  当前时点无新增买入候选\")\n        if signals.get(\"buy_candidates_count\") is not None or signals.get(\"research_buy_candidates_count\") is not None:\n            lines.append(\n                f\"  可执行候选 {signals.get('buy_candidates_count', 0)} | 研究层候选 {signals.get('research_buy_candidates_count', 0)}\"\n            )\n\n    text = \"\\n\".join(lines)\n    return send_feishu(text)\n\n\n# ============ 主流程 ============\n\ndef main():\n    # ── 命令行参数 ──────────────────────────────────────────\n    parser = argparse.ArgumentParser(description=\"投研情报汇聚\", add_help=False)\n    parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"仅采集和保存，不发飞书\")\n    parser.add_argument(\"--no-send\", action=\"store_true\", help=\"同 --dry-run\")\n    parser.add_argument(\"--force-send\", action=\"store_true\", help=\"强制发送，忽略内容去重\")\n    args = parser.parse_args()\n\n[61 more lines in file. Use offset=720 to continue.]"}],"isError":false,"timestamp":1775482533198}}
