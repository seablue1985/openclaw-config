{r.get('symbol','-')} {r.get('quantity','-')}股 @ 成本{r.get('cost_price','-')}\"\n            )\n    return '\\n'.join(lines)\n\n\ndef push_message(message: str) -> tuple[bool, str]:\n    cmd = [\n        'openclaw', 'message', 'send',\n        '--channel', CHANNEL,\n        '--account', ACCOUNT,\n        '--target', TARGET,\n        '-m', message,\n    ]\n    proc = subprocess.run(cmd, capture_output=True, text=True, timeout=120)\n    info = ((proc.stdout or '').strip() or (proc.stderr or '').strip())[-2000:]\n    return proc.returncode == 0, info\n\n\ndef main() -> int:\n    parser = argparse.ArgumentParser(description='推送模拟盘成交回报到飞书')\n    parser.add_argument('--date', required=True)\n    parser.add_argument('--profile', default='aggressive')\n    args = parser.parse_args()\n\n    date_tag = str(args.date)\n    profile_slug = str(args.profile)\n    journal = REPORT_DIR / f'paper_{profile_slug}_trading_journal_{date_tag}.csv'\n    positions_latest = REPORT_DIR / f'paper_{profile_slug}_portfolio_positions_latest.csv'\n    account_latest = REPORT_DIR / f'paper_{profile_slug}_account_v1_latest.json'\n    trade_rows = read_rows(journal)\n    position_rows = read_rows(positions_latest)\n    account_payload = load_json(account_latest)\n    buys = [r for r in trade_rows if str(r.get('action', '')).upper() == 'BUY']\n    sells = [r for r in trade_rows if str(r.get('action', '')).upper() == 'SELL']\n\n    state = load_json(STATE_FILE)\n    dedupe_key = f'{date_tag}:{profile_slug}:{len(buys)}:{len(sells)}:{len(position_rows)}:{journal.stat().st_mtime if journal.exists() else 0}:{positions_latest.stat().st_mtime if positions_latest.exists() else 0}'\n    if state.get('dedupe_key') == dedupe_key:\n        print(json.dumps({'status': 'SKIPPED', 'reason': 'duplicate', 'dedupe_key': dedupe_key}, ensure_ascii=False, indent=2))\n        return 0\n\n    message = build_message(date_tag, profile_slug, trade_rows, position_rows, account_payload)\n    ok, info = push_message(message)\n    payload = {\n        'date_tag': date_tag,\n        'profile_slug': profile_slug,\n        'journal_file': str(journal),\n        'positions_latest_file': str(positions_latest),\n        'account_latest_file': str(account_latest),\n        'buy_count': len(buys),\n        'sell_count': len(sells),\n        'position_count': int(account_payload.get('position_count', len(position_rows)) or 0),\n        'dedupe_key': dedupe_key,\n        'pushed_at': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n        'push_ok': ok,\n        'push_info': info,\n        'status': 'OK' if ok else 'FAILED',\n    }\n    write_json(STATE_FILE, payload)\n    print(json.dumps(payload, ensure_ascii=False, indent=2))\n    return 0 if ok else 1\n\n\nif __name__ == '__main__':\n    raise SystemExit(main())\nit(main())","cwd":"/Users/ling/.openclaw/workspace-coding-agent"},"isError":false,"timestamp":1775483644042}}
