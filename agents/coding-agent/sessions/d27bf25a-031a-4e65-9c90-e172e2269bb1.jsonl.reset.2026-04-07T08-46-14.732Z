{"type":"message","id":"61f2b26b","parentId":"7b49178f","timestamp":"2026-04-06T05:43:01.419Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the full `is_trading_day` function. Let me replace it with the Tencent API version.","thinkingSignature":"e93b8990a4470eaa78029dca73b559eb06ee654d2523bd4a109e7e9e9fa170c9"},{"type":"toolCall","id":"call_function_v09ftdetuht1_1","name":"edit","arguments":{"file_path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/auto_run_premarket_precheck.py","old_string":"def is_trading_day(date_str: str) -> bool:\n    \"\"\"\n    交易日判断：\n    1) 优先使用本地指数日历（date/trade_date）\n    2) 若本地日历过旧（目标日期晚于最后一条日历），降级为工作日判断（周一~周五）\n    \"\"\"\n    # 先准备工作日降级逻辑\n    try:\n        date_obj = datetime.strptime(date_str, \"%Y-%m-%d\")\n        weekday_fallback = date_obj.weekday() < 5\n    except Exception:\n        weekday_fallback = False\n\n    if not INDEX_CSV.exists():\n        return weekday_fallback\n\n    # 兼容两种常见列名：date / trade_date（例如 Tushare 导出的指数数据）\n    df = pd.read_csv(INDEX_CSV, usecols=lambda c: c in {\"date\", \"trade_date\"})\n    date_col = \"date\" if \"date\" in df.columns else (\"trade_date\" if \"trade_date\" in df.columns else None)\n    if date_col is None:\n        return weekday_fallback\n\n    normalized: set[str] = set()\n    for x in df[date_col].dropna().tolist():\n        s = str(x).strip()\n        if len(s) == 8 and s.isdigit():\n            normalized.add(f\"{s[:4]}-{s[4:6]}-{s[6:8]}\")\n        else:\n            normalized.add(s[:10])\n\n    if date_str in normalized:\n        return True\n\n    # 日历不含目标日期，若目标日期晚于本地日历最大日期，则降级为工作日判断\n    try:\n        latest = max(normalized) if normalized else \"\"\n        if latest and date_str > latest:\n            return weekday_fallback\n    except Exception:\n        pass\n\n    return False","new_string":"def is_trading_day(date_str: str) -> bool:\n    \"\"\"\n    交易日判断：优先用腾讯行情 API，API 异常时降级为工作日（周一~五）判断。\n    \"\"\"\n    try:\n        date_obj = datetime.strptime(date_str, \"%Y-%m-%d\")\n        weekday_fallback = date_obj.weekday() < 5\n    except Exception:\n        weekday_fallback = False\n\n    if date_obj.weekday() >= 5:  # 周末直接返回 False\n        return False\n\n    try:\n        import urllib.request\n        req = urllib.request.Request(\n            \"https://qt.gtimg.cn/q=sh000001\",\n            headers={\"User-Agent\": \"Mozilla/5.0\"},\n        )\n        with urllib.request.urlopen(req, timeout=5) as resp:\n            content = resp.read().decode(\"gbk\", errors=\"replace\")\n        for line in content.split(\";\"):\n            if \"sh000001\" in line:\n                parts = line.split(\"~\")\n                if len(parts) > 30:\n                    mkt_str = parts[30].strip()[:8]\n                    market_date = f\"{mkt_str[:4]}-{mkt_str[4:6]}-{mkt_str[6:8]}\"\n                    return market_date == date_str\n                break\n        return weekday_fallback\n    except Exception:\n        return weekday_fallback"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":63992,"output":775,"cacheRead":21467,"cacheWrite":0,"totalTokens":86234,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775454169939,"responseId":"06227adaaf08175abbdb7eabd20da0c5"}}
