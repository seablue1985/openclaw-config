{"type":"message","id":"73e345c0","parentId":"cab3887c","timestamp":"2026-04-06T13:27:55.358Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good. Now let me update the feishu renderer to display these new sections.","thinkingSignature":"7d8a080b971f4322773a44f995be92a34a62193fa08e0b4bc0f267a2ff2db4c5"},{"type":"text","text":"**第二步：改 Feishu 渲染器，加 CB 市场 + v4.3 参数 + 清晰信号**\n"},{"type":"toolCall","id":"call_function_q7jy4ly00o7m_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport tempfile\nfrom pathlib import Path\nfrom typing import Any\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\n\n\ndef atomic_write_text(path: Path, content: str, *, encoding: str = \"utf-8\") -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with tempfile.NamedTemporaryFile(\"w\", encoding=encoding, dir=str(path.parent), delete=False) as handle:\n        handle.write(content)\n        tmp_path = Path(handle.name)\n    os.replace(tmp_path, path)\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef fmt_money(value: Any) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{float(value):,.0f}\"\n\n\ndef fmt_pct(value: Any) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{float(value):.2f}%\"\n\n\ndef temp_emoji(temp: float) -> str:\n    if temp >= 80:\n        return \"🔴\"\n    elif temp >= 60:\n        return \"🟡\"\n    elif temp >= 30:\n        return \"⚪\"\n    else:\n        return \"🟢\"\n\n\ndef cb_signal_summary(cb: dict) -> str:\n    \"\"\"把CB市场数据翻译成对小市值策略的一句话信号。\"\"\"\n    if not cb.get(\"available\"):\n        return \"无可转债数据\"\n    temp = cb.get(\"temperature\", 50)\n    dblow = cb.get(\"avg_dblow\", 200)\n    prem = cb.get(\"avg_premium_rt\", 50)\n    if temp >= 80:\n        risk = \"⚠️ 风险偏好高位，注意小市值回调\"\n    elif temp <= 30:\n        risk = \"🟢 风险偏好低位，关注超跌反弹\"\n    else:\n        risk = \"✅ 风险偏好中性\"\n    if dblow < 180:\n        cb_bias = \"双低偏低 → 可转债整体低估 → 对小市值策略友好\"\n    elif dblow > 220:\n        cb_bias = \"双低偏高 → 可转债整体高估 → 小市值仓位从严\"\n    else:\n        cb_bias = \"双低中性\"\n    return f\"{risk} | {cb_bias}\"\n\n\ndef status_emoji(status: str | None) -> str:\n    s = (status or \"\").upper()\n    if s == \"GREEN\":\n        return \"🟢\"\n    if s == \"YELLOW\":\n        return \"🟡\"\n    if s == \"BLOCK\":\n        return \"🔴\"\n    if s == \"ALERT\":\n        return \"⚠️\"\n    return \"⚪\"\n\n\ndef holding_compact(item: dict[str, Any]) -> str:\n    label = f\"{item.get('ts_code') or '-'} {item.get('name') or '-'}\"\n    bits: list[str] = []\n    if item.get(\"weight_pct\") not in (None, \"\"):\n        bits.append(f\"{float(item['weight_pct']):.2f}%\")\n    if item.get(\"pnl_pct\") not in (None, \"\"):\n        bits.append(fmt_pct(item.get(\"pnl_pct\")))\n    if item.get(\"buy_date\"):\n        bits.append(f\"买{item['buy_date']}\")\n    return f\"{label}({' / '.join(bits)})\" if bits else label\n\n\ndef v4_3_display(v4_3: dict) -> list[str]:\n    \"\"\"渲染 v4.3 策略参数块。\"\"\"\n    if not v4_3:\n        return []\n    perf = v4_3.get(\"performance\", {})\n    params = v4_3.get(\"params\", {})\n    lines = [\n        \"📊 当前实盘基准（小市值筹码v4.3进取型）\",\n        f\"  年化收益 {fmt_pct(perf.get('annual_return_pct'))} | Sharpe {perf.get('sharpe','?')} | 回撤 {fmt_pct(perf.get('max_drawdown_pct'))}\",\n        f\"  参数：topk={params.get('topk')} / risk_degree={params.get('risk_degree')} / turnover_cap={params.get('daily_turnover_cap')}\",\n        f\"  Breadth阈值：低={params.get('breadth_low_th')} / 中={params.get('breadth_mid_th')} / 高仓={params.get('breadth_high_scale')}\",\n    ]\n    return lines\n\n\ndef build_lines(payload: dict[str, Any]) -> list[str]:\n    trade_date = payload.get(\"trade_date\", \"\")\n    trade_date_tag = payload.get(\"trade_date_tag\", \"\")\n    overall = payload.get(\"overall_status\", \"UNKNOWN\")\n    trading = payload.get(\"trading\") or {}\n    governance = payload.get(\"governance\") or {}\n    candidate_summary = payload.get(\"candidate_summary\") or {}\n    candidate_source = payload.get(\"candidate_source_summary\") or {}\n    profiles = payload.get(\"profiles\") or []\n    breadth_profiles = payload.get(\"breadth_profiles\") or []\n    profile_holdings = payload.get(\"profile_holdings\") or []\n    watchlist = payload.get(\"acceptance_watchlist\") or []\n    freshness = payload.get(\"data_freshness\") or {}\n    cb = payload.get(\"cb_market\") or {}\n    v4_3 = payload.get(\"v4_3_strategy\") or {}\n\n    lines = [\n        f\"【每日量化分析】{trade_date}\",\n        f\"{status_emoji(overall)} 总状态：{overall}\",\n        \"\",\n        \"━━━ 交易信号 ━━━\",\n        f\"{status_emoji(trading.get('trading_status'))} 交易状态：{trading.get('trading_status') or '-'} / {trading.get('trading_reason') or '-'}\",\n    ]\n\n    # BUY / SELL 信号\n    buy_cnt = candidate_summary.get(\"buy_candidates\") or 0\n    research_buy = candidate_summary.get(\"research_buy_candidates\") or 0\n    sell_cnt = candidate_summary.get(\"sell_candidates\") or 0\n    top_buy = (candidate_summary.get(\"top_buy_candidates\") or [])[:5]\n    top_sell = (candidate_summary.get(\"top_sell_risks\") or [])[:3]\n\n    if buy_cnt == 0 and research_buy == 0:\n        signal = \"⚪ 无 BUY 信号，等待\"\n    else:\n        signal = f\"🟢 BUY 信号 {buy_cnt} 个（量化）/ {research_buy} 个（研究候选）\"\n    lines.append(signal)\n    if top_buy:\n        for c in top_buy:\n            code = c.get(\"code\", c.get(\"ts_code\", \"?\"))\n            name = c.get(\"name\", \"?\")\n            score = c.get(\"score\", c.get(\"reason\", \"\"))\n            lines.append(f\"  → {code} {name} {score}\")\n    if sell_cnt == 0:\n        lines.append(\"⚪ 无 SELL 信号\")\n    else:\n        lines.append(f\"🔴 SELL 信号 {sell_cnt} 个\")\n        for c in top_sell:\n            code = c.get(\"code\", c.get(\"ts_code\", \"?\"))\n            name = c.get(\"name\", \"?\")\n            reason = c.get(\"reason\", c.get(\"sell_reason\", \"\"))\n            lines.append(f\"  → {code} {name} {reason}\")\n\n    lines.append(\"\")\n    lines.append(\"━━━ 持仓预览 ━━━\")\n    if not profile_holdings:\n        lines.append(\"⚪ 模拟盘空仓\")\n    else:\n        # 只显示前两个模拟盘\n        shown = 0\n        for entry in profile_holdings:\n            slug = entry.get(\"profile_slug\", \"\")\n            # 优先显示 v4_3_aggressive\n            holdings = entry.get(\"holdings\") or []\n            if shown >= 2:\n                break\n            if not holdings:\n                lines.append(f\"- {entry.get('profile_name', slug)}：空仓\")\n            else:\n                lines.append(f\"- {entry.get('profile_name', slug)}（{len(holdings)}持仓）：\")\n                for item in holdings[:5]:\n                    lines.append(f\"  {holding_compact(item)}\")\n                if len(holdings) > 5:\n                    lines.append(f\"  ...等共{len(holdings)}只\")\n            shown += 1\n\n    # 治理门禁\n    gov_status = governance.get(\"status\", \"UNKNOWN\")\n    gov_block = governance.get(\"blocking_issues\") or []\n    lines.append(\"\")\n    lines.append(f\"━━━ 系统门禁 {status_emoji(gov_status)} ━━━\")\n    lines.append(f\"治理：{gov_status}\")\n    if gov_block:\n        for issue in gov_block[:3]:\n            lines.append(f\"  ⚠️ {issue}\")\n    else:\n        lines.append(\"  ✅ 无阻塞\")\n\n    # 数据新鲜度\n    missing = freshness.get(\"missing_required_inputs\") or []\n    mismatch = freshness.get(\"mismatched_required_inputs\") or []\n    if missing or mismatch:\n        lines.append(f\"  ⚠️ 数据缺失：{missing} / 数据不匹配：{mismatch}\")\n\n    # 可转债市场\n    if cb.get(\"available\"):\n        temp = cb.get(\"temperature\", 0)\n        dblow = cb.get(\"avg_dblow\", 0)\n        prem = cb.get(\"avg_premium_rt\", 0)\n        lines.append(\"\")\n        lines.append(f\"━━━ 可转债市场 🌡️ ━━━\")\n        lines.append(f\"  温度：{temp:.0f} {temp_emoji(temp)} | 双低：{dblow:.1f} | 溢价率：{fmt_pct(prem)}\")\n        lines.append(f\"  {cb_signal_summary(cb)}\")\n\n    # v4.3 策略参数\n    if v4_3 and v4_3.get(\"params\"):\n        lines.append(\"\")\n        for l in v4_3_display(v4_3):\n            lines.append(l)\n\n    # 未闭环验收\n    if watchlist:\n        lines.append(\"\")\n        lines.append(\"━━━ 待处理 ━━━\")\n        for item in watchlist[:3]:\n            lines.append(f\"  ⚠️ {item.get('summary', '')}\")\n\n    lines.append(\"\")\n    lines.append(f\"📁 详报：daily_quant_analysis_skill_{trade_date_tag}.md\")\n    return lines\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"Render Feishu summary text from structured daily quant analysis JSON\")\n    parser.add_argument(\"--input\", default=str(REPORT_DIR / \"daily_quant_analysis_skill_latest.json\"))\n    args = parser.parse_args()\n\n    payload = load_json(Path(args.input))\n    trade_date_tag = str(payload.get(\"trade_date_tag\") or \"latest\")\n    text = \"\\n\".join(build_lines(payload)).strip() + \"\\n\"\n\n    outputs = [\n        REPORT_DIR / f\"daily_quant_analysis_feishu_{trade_date_tag}.txt\",\n        REPORT_DIR / \"daily_quant_analysis_feishu_latest.txt\",\n    ]\n    for path in outputs:\n        atomic_write_text(path, text)\n    print(str(outputs[0]))\n\n\nif __name__ == \"__main__\":\n    main()\n","file_path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/render_daily_quant_analysis_feishu.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":115626,"output":2542,"cacheRead":21467,"cacheWrite":0,"totalTokens":139635,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775482027857,"responseId":"0622e7ac803d8e236a3e7f9e880f3b06"}}
