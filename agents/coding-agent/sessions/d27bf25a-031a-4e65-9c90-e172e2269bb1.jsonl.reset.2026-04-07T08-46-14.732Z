{"type":"message","id":"d4918289","parentId":"b7bce5fb","timestamp":"2026-04-06T13:42:11.781Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me fix the data source health probe - make it only send for BLOCK/ALERT severity, not for watch_guarded.","thinkingSignature":"8366cddece86376ea0028eac5f02ad2d1e88e8d1e7d1a14f9836e4a460824178"},{"type":"text","text":"**2. 数据源巡检**：只推送 BLOCK/ALERT，watch_guarded 静默\n"},{"type":"toolCall","id":"call_function_mav48p6mfqtm_1","name":"read","arguments":{"offset":155,"limit":40,"file_path":"/Users/ling/.openclaw/workspace/scripts/run_investment_research_data_source_health_probe.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":133909,"output":119,"cacheRead":21467,"cacheWrite":0,"totalTokens":155495,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775482925943,"responseId":"0622eb2e54886f8f8b2a47b26e418dd6"}}
{"type":"message","id":"00774144","parentId":"d4918289","timestamp":"2026-04-06T13:42:11.804Z","message":{"role":"toolResult","toolCallId":"call_function_mav48p6mfqtm_1","toolName":"read","content":[{"type":"text","text":"        with urllib.request.urlopen(req, timeout=5) as resp:\n            content = resp.read().decode(\"gbk\", errors=\"replace\")\n        for line in content.split(\";\"):\n            if \"sh000001\" in line:\n                parts = line.split(\"~\")\n                if len(parts) > 30:\n                    mkt_str = parts[30].strip()[:8]\n                    market_date = f\"{mkt_str[:4]}-{mkt_str[4:6]}-{mkt_str[6:8]}\"\n                    today = datetime.now().strftime(\"%Y-%m-%d\")\n                    return market_date == today\n                break\n        return datetime.now().weekday() < 5\n    except Exception:\n        return datetime.now().weekday() < 5\n\n\ndef main() -> None:\n    ap = argparse.ArgumentParser(description=\"运行数据源健康探针\")\n    ap.add_argument(\"--scope\", required=True, help=\"范围标签，例如 morning 或 intraday\")\n    args = ap.parse_args()\n\n    if not _is_trading_day_now():\n        now = datetime.now()\n        weekday = [\"周一\", \"周二\", \"周三\", \"周四\", \"周五\", \"周六\", \"周日\"][now.weekday()]\n        print(f\"[{now:%Y-%m-%d %H:%M}] 非 A 股交易日（{weekday}），跳过数据源健康探针。\", flush=True)\n        return\n\n    policy = load_policy(POLICY_PATH)\n    inputs_cfg = json.loads(INPUTS_CONFIG.read_text(encoding=\"utf-8\"))\n    snapshot = org.build_input_snapshot(inputs_cfg)\n    summary = org.make_summary(snapshot, datetime.now())\n    probe = compute_probe(policy, summary, args.scope)\n\n    md_path = REPORT_DIR / f\"investment_research_data_source_health_{args.scope}_{datetime.now():%Y%m%d}.md\"\n    json_path = REPORT_DIR / f\"investment_research_data_source_health_{args.scope}_{datetime.now():%Y%m%d}.json\"\n    md_path.write_text(render_markdown(probe), encoding=\"utf-8\")\n    json_path.write_text(json.dumps(probe, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    print(md_path)\n    print(json_path)\n\n\n[4 more lines in file. Use offset=195 to continue.]"}],"isError":false,"timestamp":1775482931790}}
{"type":"message","id":"1c738b6b","parentId":"00774144","timestamp":"2026-04-06T13:42:28.009Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I can see that `deliver_data_source_health_to_feishu` is called unconditionally regardless of status. Let me modify it to only send for BLOCK and ALERT severity.","thinkingSignature":"865a2404b29fbd42907f43aa128e43869ed6db7e53375310d65792bba6ee2d94"},{"type":"toolCall","id":"call_function_uwovbfffwee8_1","name":"edit","arguments":{"file_path":"/Users/ling/.openclaw/workspace/scripts/run_investment_research_data_source_health_probe.py","old_string":"def deliver_data_source_health_to_feishu(\n    data_source_health_json: Path,\n    output_path: Path,\n) -> None:\n    \"\"\"\n    Load data source health JSON, render Feishu card, write and optionally push.\n    \"\"\"\n\n    raw = json.loads(data_source_health_json.read_text(encoding=\"utf-8\"))\n    rendered = render_data_source_health(raw)\n    output_path.write_text(rendered, encoding=\"utf-8\")\n    if not rendered.strip():\n        return\n\n    feishu_push = os.environ.get(\"FEISHU_PUSH_ENABLED\", \"false\").lower() in (\"1\", \"true\")\n    if not feishu_push:\n        return\n\n    status = raw.get(\"overall_status\", \"\").upper()\n    feishu_push_override = os.environ.get(\"FEISHU_PUSH_OVERRIDE\", \"false\").lower() in (\n        \"1\",\n        \"true\",\n    )\n    if status != \"BLOCK\" and not feishu_push_override:\n        return","new_string":"def deliver_data_source_health_to_feishu(\n    data_source_health_json: Path,\n    output_path: Path,\n) -> None:\n    \"\"\"\n    Load data source health JSON, render Feishu card, write and optionally push.\n    Only pushes for BLOCK or ALERT status — watch_guarded / normal are silent.\n    \"\"\"\n\n    raw = json.loads(data_source_health_json.read_text(encoding=\"utf-8\"))\n    rendered = render_data_source_health(raw)\n    output_path.write_text(rendered, encoding=\"utf-8\")\n    if not rendered.strip():\n        return\n\n    status = raw.get(\"overall_status\", \"\").upper()\n    # Only push for serious issues: BLOCK or ALERT\n    serious = status in (\"BLOCK\", \"ALERT\")\n    feishu_push = os.environ.get(\"FEISHU_PUSH_ENABLED\", \"false\").lower() in (\"1\", \"true\")\n    feishu_push_override = os.environ.get(\"FEISHU_PUSH_OVERRIDE\", \"false\").lower() in (\n        \"1\",\n        \"true\",\n    )\n    if not serious and not feishu_push_override:\n        return"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":134053,"output":557,"cacheRead":21467,"cacheWrite":0,"totalTokens":156077,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775482931810,"responseId":"0622eb340e0e689c68251aa4b29756ec"}}
