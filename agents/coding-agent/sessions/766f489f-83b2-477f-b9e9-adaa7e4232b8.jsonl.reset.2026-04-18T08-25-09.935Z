{"type":"message","id":"53f8c1b5","parentId":"7ebd3425","timestamp":"2026-04-17T03:02:29.040Z","message":{"role":"toolResult","toolCallId":"call_00_R1lsPCgrN1HIoRwZlbvtxHaA","toolName":"read","content":[{"type":"text","text":"def latest_web_holdings_metrics() -> dict[str, Any]:\n    \"\"\"\n    网页持仓口径（优先 ths_web_holding_count_fix_*，回退 ths_web_multi_account_snapshot_*）。\n    用于主面板展示“持仓条数”与“网页总资产”，避免被本地单账本口径覆盖。\n    \"\"\"\n    fix_file = latest_file(\"ths_web_holding_count_fix_*.json\")\n    fix_payload = load_json(fix_file)\n\n    snap_file = latest_file(\"ths_web_multi_account_snapshot_*.json\")\n    snap_payload = load_json(snap_file)\n\n    holding_count = fix_payload.get(\"holding_count\")\n    total_asset_sum = fix_payload.get(\"total_asset_sum\")\n    if total_asset_sum is None:\n        total_asset_sum = (snap_payload.get(\"totals\") or {}).get(\"total_asset_sum\")\n\n    if holding_count is None:\n        holding_count = (snap_payload.get(\"totals\") or {}).get(\"holding_rows_sum\")\n\n    source_file = \"-\"\n    source = \"none\"\n    if fix_file:\n        source_file = str(fix_file)\n        source = \"ths_web_holding_count_fix\"\n    elif snap_file:\n        source_file = str(snap_file)\n        source = \"ths_web_multi_account_snapshot\"\n\n    return {\n        \"holding_count\": holding_count,\n        \"total_asset_sum\": total_asset_sum,\n        \"source\": source,\n        \"source_file\": source_file,\n    }\n\n\n@dataclass\nclass NewsItem:\n    title: str\n    source: str\n    published: str\n    link: str\n\n\ndef fetch_news(limit: int = 12) -> list[NewsItem]:\n    feeds = [\n        (\"全球市场\", \"https://news.google.com/rss/search?q=%E5%85%A8%E7%90%83%E8%82%A1%E5%B8%82&hl=zh-CN&gl=CN&ceid=CN:zh-Hans\"),\n        (\"A股\", \"https://news.google.com/rss/search?q=A%E8%82%A1+%E5%B8%82%E5%9C%BA&hl=zh-CN&gl=CN&ceid=CN:zh-Hans\"),\n    ]\n\n\n[797 more lines in file. Use offset=457 to continue.]"}],"isError":false,"timestamp":1776394949032}}
