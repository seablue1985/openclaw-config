{"type":"message","id":"d38f0e95","parentId":"fa2973f3","timestamp":"2026-04-17T03:27:01.185Z","message":{"role":"toolResult","toolCallId":"call_00_m0qRHc9JwIQyhe50kJpU2YmY","toolName":"read","content":[{"type":"text","text":"\"\"\"Real LLM adapter for candidate explainer using Ollama.\n\nCalls local Ollama server for structured JSON output.\nSupports my-qwen (fast, instruction-following) and deepseek-r1:7b (reasoning).\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport re\nimport time\nfrom datetime import datetime\nfrom typing import Any, Optional\n\nimport requests\n\n\nOLLAMA_BASE = \"http://localhost:11434\"\nDEFAULT_MODEL = \"my-qwen\"\nTIMEOUT_SECONDS = 120\n\n\n# Per-model sessions to avoid connection pool saturation\n_sessions: dict[str, requests.Session] = {}\n\n\ndef _get_session(model: str) -> requests.Session:\n    if model not in _sessions:\n        _sessions[model] = requests.Session()\n    return _sessions[model]\n\n\nSYSTEM_PROMPT = \"\"\"You are a candidate explainer for an A-share research workflow.\n\nYou MUST follow these rules strictly:\n1. You are NOT a trading executor. NEVER output buy/sell/position size/stop-loss advice.\n2. You MUST only use information provided in the inputs below. Do NOT invent any information not present in the inputs.\n3. If the inputs do not mention something, do NOT claim it exists. Say you don't know or the information is not available.\n4. If market context says \"risk_off\" or \"defensive\", do NOT say market sentiment is improving.\n5. Output ONLY valid JSON - no markdown, no commentary, no code fences, no thinking tags.\n6. action_bias must be exactly one of: keep, keep_watch, downgrade_watch, defer\n7. Every candidate MUST have at least 1 bull_case AND 1 bear_case item.\n8. source_refs must list EXACTLY which inputs you used: candidate_pool, market_context, morning_summary, news_snapshot (only those provided).\n9. If you cannot find supporting information in inputs for a claim, do NOT make the claim.\n10. confidence_note must honestly reflect how much information was actually provided.\n\nOutput schema (output ONLY this JSON, nothing else):\n{\n  \"date_tag\": \"YYYYMMDD\",\n  \"market_context\": \"...\",\n  \"candidate_count\": N,\n  \"items\": [\n    {\n      \"ticker\": \"...\",\n      \"name\": \"...\",\n      \"strategy_tag\": \"...\",\n      \"priority\": N,\n      \"bull_case\": [\"claim based ONLY on provided inputs\"],\n      \"bear_case\": [\"risk based ONLY on provided inputs\"],\n      \"key_risks\": [\"...\"],\n      \"watch_triggers\": [\"condition that would change the view\"],\n      \"action_bias\": \"keep|keep_watch|downgrade_watch|defer\",\n      \"confidence_note\": \"how much information was available\",\n      \"source_refs\": [\"list only inputs actually used\"]\n    }\n  ]\n}\"\"\".strip()\n\n\ndef call_ollama(\n    *,\n    model: str,\n    system_prompt: str,\n    user_prompt: str,\n    timeout: int = TIMEOUT_SECONDS,\n) -> dict[str, Any]:\n    \"\"\"Call Ollama /api/generate endpoint using per-model session.\"\"\"\n    session = _get_session(model)\n    start = time.time()\n    response = session.post(\n        f\"{OLLAMA_BASE}/api/generate\",\n        json={\n            \"model\": model,\n            \"prompt\": f\"## System\\n{system_prompt}\\n\\n## User\\n{user_prompt}\",\n            \"stream\": False,\n            \"options\": {\n                \"temperature\": 0.2,\n                \"num_predict\": 3072,\n            },\n        },\n        timeout=(10, timeout),\n    )\n    response.raise_for_status()\n    data = response.json()\n    raw = data.get(\"response\", \"\").strip()\n    elapsed = time.time() - start\n    if not raw:\n        raise RuntimeError(f\"Ollama returned empty response after {elapsed:.1f}s. Data: {data}\")\n    # Strip <think> tags (deepseek-r1, omnicoder, qwen-think variants)\n    raw = re.sub(r\"<think>.*?</think>\", \"\", raw, flags=re.DOTALL).strip()\n\n[199 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1776396421170}}
