s_up >= 2 and us_avg > -0.20:\n+143         summary = \"隔夜海外市场分化震荡，未形成明确 risk-on / risk-off 信号\"\n+144         tone = \"中性\"\n+145     elif us_avg <= -0.50:\n+146         summary = \"隔夜海外市场整体偏弱，风险偏好回落\"\n+147         tone = \"偏弱\"\n+148     else:\n+149         summary = \"隔夜海外市场略偏弱，但暂无单边走弱共识\"\n+150         tone = \"偏弱\"\n+151 \n+152     caveat = \"仅依据主要指数涨跌判断；若需推导风格偏好，还应结合黄金、美元、美债收益率及成长/防御板块相对强弱。\"\n+153 \n+154     return {\n+155         \"结论\": summary,\n+156         \"口径\": tone,\n+157         \"依据\": evidence,\n+158         \"提示\": caveat,\n+159     }\n+160 \n+161 \n 106 def get_新闻摘要():\n 107     \"\"\"获取今日股市新闻摘要\"\"\"\n 108     # 简化版本：返回placeholder\n 109     # 实际可以接入东方财富、同花顺等新闻API\n     ...","firstChangedLine":76},"isError":false,"timestamp":1776387849050}}
