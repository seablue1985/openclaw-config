t a clearer picture of how they're performing. I’ll take some time to analyze the data, looking into the signals that are validated by my criteria. This way, I’ll be more equipped to offer meaningful insights or recommendations based on those calculations. Let's dive into those numbers now!\"}]}"},{"type":"toolCall","id":"call_Dlsyj9NJZLeHWg2hcTdnZLEN|fc_0aa356ee13d07a430169e255cfe7d0819abd39e0ce83f3c2fc","name":"exec","arguments":{"command":"python3 - <<'PY'\nfrom pathlib import Path\nimport pandas as pd\nimport numpy as np\n\nhistory = pd.read_csv('/Users/ling/.openclaw/workspace/data/a_stock_history.csv')\ncodes = ['688082.SH','300054.SZ','300623.SZ']\nname_map = {'688082.SH':'盛美上海','300054.SZ':'鼎龙股份','300623.SZ':'捷捷微电'}\nsub = history[history['ts_code'].isin(codes)].copy()\nsub['trade_date']=pd.to_datetime(sub['trade_date'].astype(str))\nsub=sub.sort_values(['ts_code','trade_date'])\n\nrows=[]\nfor code, g in sub.groupby('ts_code'):\n    g=g.sort_values('trade_date').reset_index(drop=True)\n    close=g['close']\n    amt=g['amount']\n    latest=g.iloc[-1]\n    ma20=close.tail(20).mean() if len(g)>=20 else np.nan\n    ma60=close.tail(60).mean() if len(g)>=60 else np.nan\n    ret20=close.iloc[-1]/close.iloc[-21]-1 if len(g)>=21 else np.nan\n    ret60=close.iloc[-1]/close.iloc[-61]-1 if len(g)>=61 else np.nan\n    vol20=close.pct_change().tail(20).std()*np.sqrt(252) if len(g)>=21 else np.nan\n    avg_amt20=amt.tail(20).mean()/1e8 if len(g)>=20 else np.nan\n    # 120d max drawdown from rolling peak over last 120 bars\n    tail=close.tail(120)\n    running_max=tail.cummax()\n    mdd=((tail/running_max)-1).min() if len(tail)>1 else np.nan\n    # RSI14\n    delta=close.diff()\n    gain=delta.clip(lower=0)\n    loss=-delta.clip(upper=0)\n    rs=(gain.rolling(14).mean()/loss.rolling(14).mean()).iloc[-1]\n    rsi=100-(100/(1+rs)) if pd.notna(rs) and np.isfinite(rs) else np.nan\n    rows.append({\n        'code':code,\n        'name':name_map[code],\n        'latest_date':latest['trade_date'].date().isoformat(),\n        'close':round(float(latest['close']),2),\n        'ma20':round(float(ma20),2),\n        'ma60':round(float(ma60),2),\n        'above_ma20':bool(latest['close']>ma20) if pd.notna(ma20) else None,\n        'above_ma60':bool(latest['close']>ma60) if pd.notna(ma60) else None,\n        'ret20_pct':round(float(ret20*100),2),\n        'ret60_pct':round(float(ret60*100),2),\n        'vol20_pct':round(float(vol20*100),2),\n        'avg_amt20_yi':round(float(avg_amt20),2),\n        'mdd120_pct':round(float(mdd*100),2),\n        'rsi14':round(float(rsi),2) if pd.notna(rsi) else None,\n    })\n\n# count signals in merged approved signals files\nroot=Path('/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports')\ncounts={c:{'approved_buy':0,'buy_any':0,'files_hit':0} for c in codes}\nfor f in root.glob('*merged_approved_signals*.csv'):\n    try:\n        df=pd.read_csv(f)\n    except Exception:\n        continue\n    if 'ts_code' not in df.columns:\n        continue\n    hit=False\n    for c in codes:\n        d=df[df['ts_code']==c]\n        if len(d):\n            hit=True\n            counts[c]['files_hit'] += 1\n            if 'signal_type' in d.columns:\n                counts[c]['buy_any'] += int((d['signal_type']=='BUY').sum())\n            if 'approved' in d.columns:\n                appr=d['approved'].astype(str).str.lower().isin(['true','1','yes'])\n                if 'signal_type' in d.columns:\n                    counts[c]['approved_buy'] += int(((d['signal_type']=='BUY') & appr).sum())\n    \nfor r in rows:\n    r.update(counts[r['code']])\n\nprint(pd.DataFrame(rows).to_markdown(index=False))\nPY","workdir":"/Users/ling/.openclaw/workspace/coding-agent","timeout":60},"partialJson":"{\"command\":\"python3 - <<'PY'\\nfrom pathlib import Path\\nimport pandas as pd\\nimport numpy as np\\n\\nhistory = pd.read_csv('/Users/ling/.openclaw/workspace/data/a_stock_history.csv')\\ncodes = ['688082.SH','300054.SZ','300623.SZ']\\nname_map = {'688082.SH':'盛美上海','300054.SZ':'鼎龙股份','300623.SZ':'捷捷微电'}\\nsub = history[history['ts_code'].isin(codes)].copy()\\nsub['trade_date']=pd.to_datetime(sub['trade_date'].astype(str))\\nsub=sub.sort_values(['ts_code','trade_date'])\\n\\nrows=[]\\nfor code, g in sub.groupby('ts_code'):\\n    g=g.sort_values('trade_date').reset_index(drop=True)\\n    close=g['close']\\n    amt=g['amount']\\n    latest=g.iloc[-1]\\n    ma20=close.tail(20).mean() if len(g)>=20 else np.nan\\n    ma60=close.tail(60).mean() if len(g)>=60 else np.nan\\n    ret20=close.iloc[-1]/close.iloc[-21]-1 if len(g)>=21 else np.nan\\n    ret60=close.iloc[-1]/close.iloc[-61]-1 if len(g)>=61 else np.nan\\n    vol20=close.pct_change().tail(20).std()*np.sqrt(252) if len(g)>=21 else np.nan\\n    avg_amt20=amt.tail(20).mean()/1e8 if len(g)>=20 else np.nan\\n    # 120d max drawdown from rolling peak over last 120 bars\\n    tail=close.tail(120)\\n    running_max=tail.cummax()\\n    mdd=((tail/running_max)-1).min() if len(tail)>1 else np.nan\\n    # RSI14\\n    delta=close.diff()\\n    gain=delta.clip(lower=0)\\n    loss=-delta.clip(upper=0)\\n    rs=(gain.rolling(14).mean()/loss.rolling(14).mean()).iloc[-1]\\n    rsi=100-(100/(1+rs)) if pd.notna(rs) and np.isfinite(rs) else np.nan\\n    rows.append({\\n        'code':code,\\n        'name':name_map[code],\\n        'latest_date':latest['trade_date'].date().isoformat(),\\n        'close':round(float(latest['close']),2),\\n        'ma20':round(float(ma20),2),\\n        'ma60':round(float(ma60),2),\\n        'above_ma20':bool(latest['close']>ma20) if pd.notna(ma20) else None,\\n        'above_ma60':bool(latest['close']>ma60) if pd.notna(ma60) else None,\\n        'ret20_pct':round(float(ret20*100),2),\\n        'ret60_pct':round(float(ret60*100),2),\\n        'vol20_pct':round(float(vol20*100),2),\\n        'avg_amt20_yi':round(float(avg_amt20),2),\\n        'mdd120_pct':round(float(mdd*100),2),\\n        'rsi14':round(float(rsi),2) if pd.notna(rsi) else None,\\n    })\\n\\n# count signals in merged approved signals files\\nroot=Path('/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports')\\ncounts={c:{'approved_buy':0,'buy_any':0,'files_hit':0} for c in codes}\\nfor f in root.glob('*merged_approved_signals*.csv'):\\n    try:\\n        df=pd.read_csv(f)\\n    except Exception:\\n        continue\\n    if 'ts_code' not in df.columns:\\n        continue\\n    hit=False\\n    for c in codes:\\n        d=df[df['ts_code']==c]\\n        if len(d):\\n            hit=True\\n            counts[c]['files_hit'] += 1\\n            if 'signal_type' in d.columns:\\n                counts[c]['buy_any'] += int((d['signal_type']=='BUY').sum())\\n            if 'approved' in d.columns:\\n                appr=d['approved'].astype(str).str.lower().isin(['true','1','yes'])\\n                if 'signal_type' in d.columns:\\n                    counts[c]['approved_buy'] += int(((d['signal_type']=='BUY') & appr).sum())\\n    \\nfor r in rows:\\n    r.update(counts[r['code']])\\n\\nprint(pd.DataFrame(rows).to_markdown(index=False))\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace/coding-agent\",\"timeout\":60}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":128743,"output":1095,"cacheRead":0,"cacheWrite":0,"totalTokens":129838,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776440773302,"responseId":"resp_0aa356ee13d07a430169e255c7e32c819a80c371df34ed1597"}}
