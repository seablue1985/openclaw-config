{"type":"message","id":"cfe70b96","parentId":"b38e2e65","timestamp":"2026-04-09T14:52:28.047Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user chose option 1 - they want me to write scripts (主备切换/告警/数据校验). Let me write these scripts for them.\n\nI should create practical scripts for:\n1. 主备切换脚本 - check primary machine status, switch to backup\n2. 告警脚本 - monitoring and alerting\n3. 数据校验脚本 - data validation\n\nLet me create these scripts in the workspace.\n","thinkingSignature":"34c24135e840db60e402689517a977953519f6a41db4f24b10eea33448c42e4e"},{"type":"toolCall","id":"call_function_l67rov51j91n_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n同花顺主备切换脚本\n功能：监控主力机状态，异常时切换到备机并告警\n\"\"\"\n\nimport time\nimport subprocess\nimport requests\nimport json\nfrom datetime import datetime\n\n# ========== 配置项 ==========\nPRIMARY_HOST = \"192.168.1.100\"  # 主力机IP（改成实际的）\nPRIMARY_PORT = 8888              # 同花顺API端口（改成实际的）\nCHECK_INTERVAL = 60             # 检查间隔（秒）\n\n# 告警配置（选择一种）\nWEBHOOK_URL = \"\"                # 钉钉/飞书Webhook地址\nPUSHOVER_USER_KEY = \"\"          # Pushover用户Key\n\n# ========== 监控函数 ==========\ndef check_tonghuashun_alive():\n    \"\"\"检查同花顺进程是否存活\"\"\"\n    try:\n        # 检查进程是否存在\n        result = subprocess.run(\n            ['ps', 'aux'],\n            capture_output=True,\n            text=True\n        )\n        if 'Tonghuashun' in result.stdout or 'ths' in result.stdout:\n            return True\n        return False\n    except Exception as e:\n        print(f\"检查进程失败: {e}\")\n        return False\n\ndef check_network():\n    \"\"\"检查网络连通性\"\"\"\n    try:\n        # ping一下主力机\n        result = subprocess.run(\n            ['ping', '-c', '1', '-W', '2', PRIMARY_HOST],\n            capture_output=True\n        )\n        return result.returncode == 0\n    except:\n        return False\n\ndef send_alert(message):\n    \"\"\"发送告警\"\"\"\n    print(f\"🚨 告警: {message}\")\n    \n    if WEBHOOK_URL:\n        try:\n            headers = {\"Content-Type\": \"application/json\"}\n            payload = {\"msgtype\": \"text\", \"text\": {\"content\": f\"量化监控: {message}\"}}\n            requests.post(WEBHOOK_URL, headers=headers, data=json.dumps(payload))\n        except Exception as e:\n            print(f\"告警发送失败: {e}\")\n\ndef switch_to_backup():\n    \"\"\"切换到备机\"\"\"\n    message = f\"主力机异常，已切换到备机执行 | {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\"\n    send_alert(message)\n    # 这里可以添加切换逻辑，比如启动备机的交易脚本\n\n# ========== 主循环 ==========\ndef main():\n    print(f\"🟢 主备监控启动 | 检查间隔: {CHECK_INTERVAL}秒 | {datetime.now()}\")\n    \n    consecutive_fail = 0\n    MAX_FAIL = 3  # 连续3次失败才切换\n    \n    while True:\n        try:\n            process_ok = check_tonghuashun_alive()\n            network_ok = check_network()\n            \n            status = \"✅正常\" if (process_ok and network_ok) else \"❌异常\"\n            print(f\"[{datetime.now().strftime('%H:%M:%S')}] 进程:{process_ok} 网络:{network_ok} | {status}\")\n            \n            if not (process_ok and network_ok):\n                consecutive_fail += 1\n                if consecutive_fail >= MAX_FAIL:\n                    switch_to_backup()\n                    consecutive_fail = 0\n            else:\n                consecutive_fail = 0\n                \n        except Exception as e:\n            print(f\"监控异常: {e}\")\n        \n        time.sleep(CHECK_INTERVAL)\n\nif __name__ == \"__main__\":\n    main()","path":"/Users/ling/.openclaw/workspace/coding-agent/scripts/monitor_backup.py"}},{"type":"toolCall","id":"call_function_l67rov51j91n_2","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n交易异常监控告警脚本\n功能：监控交易成交、持仓、风控触发并告警\n\"\"\"\n\nimport time\nimport requests\nimport json\nfrom datetime import datetime\n\n# ========== 配置项 ==========\n# 钉钉/飞书Webhook\nWEBHOOK_URL = \"\"  # 填入你的Webhook地址\n\n# 交易API配置（根据你的实际情况修改）\nAPI_BASE = \"http://localhost:8888/api\"  # 同花顺API地址\nAPI_KEY = \"\"  # API密钥\n\n# 告警阈值\nMAX_SLIPPAGE = 0.5  # 最大滑点阈值(%)\nMAX_POSITION_LOSS = -5.0  # 单票最大亏损(%)\nDAILY_LOSS_THRESHOLD = -3.0  # 单日最大亏损(%)\n\n# ========== 告警函数 ==========\ndef send_alert(title, message):\n    \"\"\"发送告警到Webhook\"\"\"\n    full_msg = f\"🛡️ 量化风控告警\\n\\n⏰ {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\n📌 {title}\\n📝 {message}\"\n    print(f\"🚨 {title}: {message}\")\n    \n    if WEBHOOK_URL:\n        try:\n            payload = {\n                \"msgtype\": \"text\",\n                \"text\": {\"content\": full_msg}\n            }\n            requests.post(WEBHOOK_URL, json=payload, timeout=10)\n        except Exception as e:\n            print(f\"告警发送失败: {e}\")\n\n# ========== 监控函数 ==========\ndef check_trade_status():\n    \"\"\"检查交易状态\"\"\"\n    # 这里需要根据你的实际API来获取成交数据\n    # 伪代码示例：\n    # trades = get_recent_trades()  # 获取最近成交\n    # for trade in trades:\n    #     if trade['slippage'] > MAX_SLIPPAGE:\n    #         send_alert(\"滑点异常\", f\"股票{trade['symbol']}滑点{trade['slippage']}%\")\n    pass\n\ndef check_positions():\n    \"\"\"检查持仓风险\"\"\"\n    # 伪代码示例：\n    # positions = get_positions()\n    # for pos in positions:\n    #     if pos['loss_pct'] < MAX_POSITION_LOSS:\n    #         send_alert(\"持仓亏损超标\", f\"{pos['symbol']}亏损{pos['loss_pct']}%\")\n    pass\n\ndef check_daily_pnl():\n    \"\"\"检查当日盈亏\"\"\"\n    # 伪代码示例：\n    # pnl = get_daily_pnl()\n    # if pnl < DAILY_LOSS_THRESHOLD:\n    #     send_alert(\"当日亏损超标\", f\"当前亏损{pnl}%，触发强平线\")\n    pass\n\n# ========== 主循环 ==========\ndef main():\n    print(f\"🟢 交易监控启动 | {datetime.now()}\")\n    \n    while True:\n        try:\n            check_trade_status()\n            check_positions()\n            check_daily_pnl()\n        except Exception as e:\n            print(f\"监控异常: {e}\")\n        \n        time.sleep(60)  # 每分钟检查一次\n\nif __name__ == \"__main__\":\n    main()","path":"/Users/ling/.openclaw/workspace/coding-agent/scripts/trade_monitor.py"}},{"type":"toolCall","id":"call_function_l67rov51j91n_3","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n数据清洗校验脚本\n功能：检测行情数据异常，避免垃圾数据进入策略\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\n\n# ========== 配置项 ==========\nDATA_PATH = \"stock_data.csv\"  # 数据文件路径\n\n# 异常检测阈值\nMAX_DAILY_CHANGE = 0.20      # 单日最大涨跌幅（20%）\nMIN_VOLUME = 1000             # 最小成交量\nMAX_VOLUME_RATIO = 20         # 最大成交量倍数（超过均值的20倍为异常）\n\n# ========== 校验函数 ==========\ndef check_price_anomaly(df):\n    \"\"\"检查价格异常\"\"\"\n    issues = []\n    \n    # 检查涨跌停价是否合理\n    df['high_max'] = df['close'] * 1.1\n    df['low_min'] = df['close'] * 0.9\n    \n    high_abnormal = df[df['high'] > df['high_max']]\n    if len(high_abnormal) > 0:\n        issues.append(f\"最高价超过涨停价: {len(high_abnormal)}条\")\n    \n    low_abnormal = df[df['low'] < df['low_min']]\n    if len(low_abnormal) > 0:\n        issues.append(f\"最低价低于跌停价: {len(low_abnormal)}条\")\n    \n    # 检查涨跌幅异常\n    df['pct_change'] = df['close'].pct_change()\n    extreme = df[abs(df['pct_change']) > MAX_DAILY_CHANGE]\n    if len(extreme) > 0:\n        issues.append(f\"涨跌幅超过±{MAX_DAILY_CHANGE*100}%: {len(extreme)}条\")\n    \n    return issues\n\ndef check_volume_anomaly(df):\n    \"\"\"检查成交量异常\"\"\"\n    issues = []\n    \n    # 检查成交量为0或负数\n    zero_vol = df[df['volume'] <= 0]\n    if len(zero_vol) > 0:\n        issues.append(f\"成交量为0或负: {len(zero_vol)}条\")\n    \n    # 检查成交量异常放大\n    vol_mean = df['volume'].mean()\n    vol_abnormal = df[df['volume'] > vol_mean * MAX_VOLUME_RATIO]\n    if len(vol_abnormal) > 0:\n        issues.append(f\"成交量异常放大(>{MAX_VOLUME_RATIO}倍均值): {len(vol_abnormal)}条\")\n    \n    return issues\n\ndef check_ohlc_logic(df):\n    \"\"\"检查OHLC逻辑关系\"\"\"\n    issues = []\n    \n    # 最高价应该 >= 最低价\n    invalid_hl = df[df['high'] < df['low']]\n    if len(invalid_hl) > 0:\n        issues.append(f\"最高价<最低价: {len(invalid_hl)}条\")\n    \n    # 收盘价应该在高低之间\n    invalid_close = df[(df['close'] > df['high']) | (df['close'] < df['low'])]\n    if len(invalid_close) > 0:\n        issues.append(f\"收盘价超出高低范围: {len(invalid_close)}条\")\n    \n    return issues\n\ndef check_data_completeness(df):\n    \"\"\"检查数据完整性\"\"\"\n    issues = []\n    \n    # 检查必要列是否存在\n    required_cols = ['date', 'open', 'high', 'low', 'close', 'volume']\n    missing = [col for col in required_cols if col not in df.columns]\n    if missing:\n        issues.append(f\"缺少必要列: {missing}\")\n    \n    # 检查缺失值\n    null_counts = df[required_cols].isnull().sum()\n    if null_counts.sum() > 0:\n        issues.append(f\"存在缺失值:\\n{null_counts[null_counts > 0]}\")\n    \n    return issues\n\n# ========== 主函数 ==========\ndef validate_data(file_path):\n    \"\"\"主校验函数\"\"\"\n    print(f\"🔍 开始数据校验: {file_path} | {datetime.now()}\")\n    \n    try:\n        # 读取数据（根据实际格式调整）\n        if file_path.endswith('.csv'):\n            df = pd.read_csv(file_path)\n        elif file_path.endswith('.parquet'):\n            df = pd.read_parquet(file_path)\n        else:\n            print(\"❌ 不支持的格式\")\n            return\n        \n        print(f\"📊 数据量: {len(df)}行\")\n        \n        all_issues = []\n        \n        # 执行各项检查\n        all_issues.extend(check_price_anomaly(df))\n        all_issues.extend(check_volume_anomaly(df))\n        all_issues.extend(check_ohlc_logic(df))\n        all_issues.extend(check_data_completeness(df))\n        \n        # 输出结果\n        if all_issues:\n            print(\"\\n⚠️ 发现数据问题:\")\n            for issue in all_issues:\n                print(f\"  - {issue}\")\n        else:\n            print(\"✅ 数据校验通过\")\n        \n        return all_issues\n        \n    except Exception as e:\n        print(f\"❌ 校验失败: {e}\")\n        return [str(e)]\n\n# ========== 命令行入口 ==========\nif __name__ == \"__main__\":\n    import sys\n    if len(sys.argv) > 1:\n        validate_data(sys.argv[1])\n    else:\n        print(\"用法: python data_validator.py <数据文件路径>\")\n        # 默认测试\n        # validate_data(DATA_PATH)","path":"/Users/ling/.openclaw/workspace/coding-agent/scripts/data_validator.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":302,"output":2796,"cacheRead":35648,"cacheWrite":0,"totalTokens":38746,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775746257957,"responseId":"0626efd2c238dc92ce3837fbc7b830c5"}}
