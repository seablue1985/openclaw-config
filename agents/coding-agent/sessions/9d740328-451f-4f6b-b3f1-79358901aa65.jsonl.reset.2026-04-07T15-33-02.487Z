{"type":"message","id":"0e55ce6e","parentId":"1fde919c","timestamp":"2026-04-07T09:40:02.627Z","message":{"role":"toolResult","toolCallId":"call_function_v0tdqefq0u9o_1","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport re\nfrom pathlib import Path\nfrom typing import Any\n\n\ndef profile_slug_from_config(cfg: dict[str, Any]) -> str:\n    raw = str(cfg.get(\"profile_slug\", \"\") or cfg.get(\"profile\", \"\") or \"\").strip().lower()\n    if not raw:\n        return \"\"\n    slug = re.sub(r\"[^a-z0-9]+\", \"_\", raw)\n    return slug.strip(\"_\")\n\n\ndef profile_name_from_config(cfg: dict[str, Any]) -> str:\n    explicit = str(cfg.get(\"profile_name\", \"\") or \"\").strip()\n    if explicit:\n        return explicit\n    slug = profile_slug_from_config(cfg)\n    return slug or \"default\"\n\n\ndef _profile_prefix(profile_slug: str) -> str:\n    return f\"{profile_slug}_\" if profile_slug else \"\"\n\n\ndef report_filename(kind: str, profile_slug: str = \"\", date_tag: str = \"\") -> str:\n    prefix = _profile_prefix(profile_slug)\n    mapping = {\n\n[46 more lines in file. Use offset=31 to continue.]"}],"isError":false,"timestamp":1775554802623}}
