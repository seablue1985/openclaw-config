{"type":"message","id":"04543623","parentId":"5e1c360b","timestamp":"2026-04-07T08:49:22.365Z","message":{"role":"toolResult","toolCallId":"call_function_j1yi3q5sgkw1_2","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env bash\nset -euo pipefail\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\nWORKSPACE_ROOT=\"$(cd \"$ROOT/../..\" && pwd)\"\nPUSH_SCRIPT=\"$WORKSPACE_ROOT/scripts/push_investment_research_paper_execution.py\"\ncd \"$ROOT\"\n\n# 非交易日跳过\nMKT_OK=$(python3 -c \"\nimport urllib.request, datetime\ntry:\n    req = urllib.request.Request('https://qt.gtimg.cn/q=sh000001', headers={'User-Agent':'Mozilla/5.0'})\n    with urllib.request.urlopen(req, timeout=5) as r:\n        c = r.read().decode('gbk', errors='replace')\n    for line in c.split(';'):\n        parts = line.split('~')\n        if len(parts) > 30:\n            mkt = parts[30].strip()[:8]\n            today = datetime.datetime.now().strftime('%Y%m%d')\n            print('yes' if mkt == today else 'no')\n            break\n    else:\n        print('no')\nexcept:\n    print('yes')\n\" 2>/dev/null)\nif [[ \"$MKT_OK\" != \"yes\" ]]; then\n    echo \"[$(date '+%Y-%m-%d %H:%M')] 非 A 股交易日，跳过 paper_profiles_v1 cron\"\n    exit 0\nfi\n\nPYRUN=\"$ROOT/scripts/cron_python.sh\"\n\"$PYRUN\" --runtime-only\n\nexport LITELLM_LOCAL_MODEL_COST_MAP=true\n\nDATE_TAG=\"${1:-$(date +%Y%m%d)}\"\nstatus=0\nRUN_MODE=\"${PAPER_PROFILE_RUN_MODE:-eod}\"\nRUN_HEAVY_REPORTS=\"${PAPER_PROFILE_RUN_HEAVY_REPORTS:-}\"\n\nif [[ -z \"$RUN_HEAVY_REPORTS\" ]]; then\n  if [[ \"$RUN_MODE\" == \"morning_open\" ]]; then\n    RUN_HEAVY_REPORTS=\"0\"\n  else\n    RUN_HEAVY_REPORTS=\"1\"\n  fi\nfi\n\nif PAPER_PROFILE_RUN_HEAVY_REPORTS=\"$RUN_HEAVY_REPORTS\" bash scripts/run_paper_trading_profiles_auto_v1.sh \"$DATE_TAG\" \"\" \"$RUN_MODE\"; then\n  :\nelse\n  status=$?\n  echo \"[WARN] paper profile refresh failed date=${DATE_TAG} exit=${status}\" >&2\nfi\n\nif [[ $status -eq 0 && \"$RUN_HEAVY_REPORTS\" == \"1\" && -f \"$PUSH_SCRIPT\" ]]; then\n  if ! \"$PYRUN\" \"$PUSH_SCRIPT\" --date-tag \"$DATE_TAG\"; then\n    echo \"[WARN] paper execution push failed date=${DATE_TAG}\" >&2\n  fi\nfi\n\nif [[ \"$RUN_HEAVY_REPORTS\" == \"1\" ]]; then\n  \"$PYRUN\" scripts/generate_stock_lens_dashboard.py\n  \"$PYRUN\" scripts/generate_strategy_performance_panel.py\n  \"$PYRUN\" scripts/generate_control_tower_daily.py\n  if ! \"$PYRUN\" scripts/push_control_tower_alert_if_changed.py; then\n    echo \"[WARN] control tower alert push failed date=${DATE_TAG}\" >&2\n  fi\n  \"$PYRUN\" scripts/generate_cto_real_data_dashboard.py\n  \"$PYRUN\" scripts/generate_dashboard_portal.py\nfi\n\nexit \"$status\"\n"}],"isError":false,"timestamp":1775551762362}}
