{"type":"message","id":"b1ba4bed","parentId":"6d91c8dc","timestamp":"2026-04-07T15:29:55.733Z","message":{"role":"toolResult","toolCallId":"call_function_3755p63fl80t_1","toolName":"read","content":[{"type":"text","text":"def _push_candidate_change(date_tag: str, snapshot: dict, reasons: list[str], candidates: pd.DataFrame) -> None:\n    \"\"\"Send Feishu push if there are material candidate changes.\"\"\"\n    try:\n        sys.path.insert(0, str(PROJECT_ROOT / \"scripts\"))\n        from feishu_push import _load_feishu_config, _get_app_access_token, _send_feishu_message\n        cfg = _load_feishu_config()\n        if not cfg.get(\"app_id\"):\n            print(\"[PUSH] no feishu config, skipping\")\n            return\n        token = _get_app_access_token(cfg[\"app_id\"], cfg[\"app_secret\"])\n        top10 = candidates.head(10).copy()\n        score_col = \"guard_score\" if \"guard_score\" in top10.columns else \"score\"\n        date_display = f\"{date_tag[:4]}-{date_tag[4:6]}-{date_tag[6:8]}\"\n        lines_msg = [f\"📊 **{date_display} 实时候选变化**（有变化才推送）\"]\n        lines_msg.append(\"\")\n        for i, (_, r) in enumerate(top10.iterrows(), 1):\n            code = str(r[\"ts_code\"])\n            score = float(r.get(score_col, 0))\n            close = float(r.get(\"close\", 0))\n            vwap60 = float(r.get(\"vwap60\", 0))\n            reason = _build_reason_text(r)\n            # Suggested entry: use vwap60 if available, else close\n            ref_price = vwap60 if vwap60 > 0 else close\n            if ref_price > 0:\n                lo = ref_price * 0.98\n                hi = ref_price * 1.02\n                price_str = f\"参考价{vwap60:.2f}（区间{lo:.2f}~{hi:.2f}）\"\n            else:\n                price_str = f\"现价{close:.2f}\"\n            lines_msg.append(f\"{i}. {code}｜{price_str}\")\n            lines_msg.append(f\"   原因：{reason}｜得分{score:.4f}\")\n        lines_msg.append(\"\")\n        lines_msg.append(\"⚠️ 变化：\" + \"；\".join(reasons))\n        lines_msg.append(\"\")\n        lines_msg.append(\"🔔 风险提示：盘中价格波动较大，信号仅供参考\")\n        msg_text = \"\\n\".join(lines_msg)\n        result = _send_feishu_message(token, cfg[\"open_id\"], \"text\", {\"text\": msg_text})\n        if result.get(\"code\") == 0:\n            print(f\"[PUSH] candidate change pushed to feishu: {', '.join(reasons)}\")\n        else:\n            print(f\"[PUSH] feishu push failed: {result}\")\n    except Exception as e:\n        print(f\"[PUSH] candidate change push failed: {e}\")\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"Generate same-day live smallcap candidates\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD, default today\")\n    parser.add_argument(\"--realtime\", action=\"store_true\", default=False, help=\"Fetch real-time close prices from Tencent API\")\n    parser.add_argument(\"--force-realtime\", action=\"store_true\", default=False, help=\"Force realtime mode regardless of market hours\")\n    parser.add_argument(\"--no-realtime\", action=\"store_true\", default=False, help=\"Disable realtime mode (use CSV only)\")\n    parser.add_argument(\"--price-src\", default=str(DEFAULT_PRICE_CSV))\n    parser.add_argument(\"--basic-src\", default=str(DEFAULT_BASIC_CSV))\n    parser.add_argument(\"--config\", default=str(DEFAULT_CONFIG))\n    parser.add_argument(\"--main-output\", default=\"\")\n    parser.add_argument(\"--guard-output\", default=\"\")\n    parser.add_argument(\"--summary-output\", default=\"\")\n    parser.add_argument(\"--main-count\", type=int, default=10)\n    parser.add_argument(\"--guard-count\", type=int, default=8)\n    parser.add_argument(\"--main-target-weight\", type=float, default=0.10)\n    parser.add_argument(\"--guard-target-weight\", type=float, default=0.08)\n\n[173 more lines in file. Use offset=546 to continue.]"}],"isError":false,"timestamp":1775575795725}}
