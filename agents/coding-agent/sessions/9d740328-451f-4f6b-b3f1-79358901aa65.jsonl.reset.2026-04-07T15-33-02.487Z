 _push_candidate_change function before main()\n# Find the line \"def main()\" \nmain_idx = None\nfor i, l in enumerate(lines):\n    if l.startswith(\"def main()\"):\n        main_idx = i\n        break\n\npush_func = '''\ndef _push_candidate_change(date_tag: str, snapshot: dict, reasons: list[str], candidates: pd.DataFrame) -> None:\n    \"\"\"Send Feishu push if there are material candidate changes.\"\"\"\n    try:\n        sys.path.insert(0, str(PROJECT_ROOT / \"scripts\"))\n        from feishu_push import _load_feishu_config, _get_app_access_token, _send_feishu_message\n        cfg = _load_feishu_config()\n        if not cfg.get(\"app_id\"):\n            print(\"[PUSH] no feishu config, skipping\")\n            return\n        token = _get_app_access_token(cfg[\"app_id\"], cfg[\"app_secret\"])\n        # Build top-10 list with scores\n        top10 = candidates.head(10).copy()\n        score_col = \"guard_score\" if \"guard_score\" in top10.columns else \"score\"\n        lines_msg = [f\"📊 **{date_tag[:4]}-{date_tag[4:6]}-{date_tag[6:8]} 实时候选变化**\"]\n        lines_msg.append(\"\")\n        for i, (_, r) in enumerate(top10.iterrows(), 1):\n            code = str(r[\"ts_code\"])\n            score = float(r.get(score_col, 0))\n            comment = str(r.get(\"comment\", \"\"))[:20]\n            lines_msg.append(f\"{i}. {code}（{comment}）得分{score:.4f}\")\n        lines_msg.append(\"\")\n        lines_msg.append(\"**⚠️ 变化：** \" + \"；\".join(reasons))\n        msg_text = \"\\\\n\".join(lines_msg)\n        result = _send_feishu_message(token, cfg[\"open_id\"], \"text\", {\"text\": msg_text})\n        if result.get(\"code\") == 0:\n            print(f\"[PUSH] candidate change pushed to feishu: {', '.join(reasons)}\")\n        else:\n            print(f\"[PUSH] feishu push failed: {result}\")\n    except Exception as e:\n        print(f\"[PUSH] candidate change push failed: {e}\")\n\n'''\n\nlines.insert(main_idx, push_func)\n\n# Now insert change detection block after line 540 (which is index 539 in 0-indexed)\nblock = '''\n        # --- Material change detection & Feishu push ---\n        if use_realtime and summary.get(\"status\") == \"PASS\":\n            curr_snap = compute_candidate_snapshot(main_candidates, top_n=int(args.main_count))\n            prev_snap = load_last_snapshot(date_tag)\n            has_change, reasons = detect_material_change(curr_snap, prev_snap, top_n=int(args.main_count))\n            summary[\"material_change\"] = has_change\n            summary[\"change_reasons\"] = reasons\n            save_snapshot(date_tag, curr_snap)\n            if has_change:\n                _push_candidate_change(date_tag, curr_snap, reasons, main_candidates)\n        else:\n            summary[\"material_change\"] = False\n            summary[\"change_reasons\"] = []\n\n'''\n\n# Find the line with \"summary[\"outputs\"][\"v4_2b\"] = write_candidates\" after our insertions\n# Insert right after it\nfor i in range(insert_after, len(lines)):\n    if 'summary[\"outputs\"][\"v4_2b\"]' in lines[i]:\n        lines.insert(i + 1, block)\n        break\n\nwith open(path, \"w\") as f:\n    f.writelines(lines)\n\nprint(\"Done, file now has\", sum(1 for _ in open(path)), \"lines\")\nPYEOF"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","stopReason":"toolUse","timestamp":1775554400900,"responseId":"06240261ffa679f7648c35b14086ac07","__openclaw":{"id":"9ca62a9b","seq":678}},{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me verify the syntax is OK and test the script."},{"type":"toolCall","id":"call_function_a8rr2m8s50z8_1","name":"exec","arguments":{"command":"python3 -m py_compile ~/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_live_smallcap_candidates.py && echo \"Syntax OK\""}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","stopReason":"toolUse","timestamp":1775554424530,"responseId":"062402796c0246cd1bcc302364