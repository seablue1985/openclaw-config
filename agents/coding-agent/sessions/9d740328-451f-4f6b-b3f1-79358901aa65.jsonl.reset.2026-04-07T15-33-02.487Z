report.py --date \"$DATE_TAG\"\n  \"$PYRUN\" scripts/generate_strategy_performance_panel.py\n  \"$PYRUN\" scripts/generate_control_tower_daily.py\n  \"$PYRUN\" scripts/generate_cto_real_data_dashboard.py\nfi\n\nif [[ \"$RUN_HEAVY_REPORTS\" == \"1\" && \"$RUN_MODE\" == \"eod\" && -f \"$WORKSPACE_ROOT/scripts/run_investment_research_event_watch.py\" ]]; then\n  \"$PYRUN\" \"$WORKSPACE_ROOT/scripts/run_investment_research_event_watch.py\"\nfi\n"}],"isError":false,"timestamp":1775554791770}}
