\": 0.6,\n    \"mode_halt_target_exposure\": 0.35,\n    \"cautious_probe\": {\n      \"enabled\": true,\n      \"max_daily_add_ratio_of_available_cash\": 0.2,\n      \"single_ticket_budget_ratio_of_available_cash\": 0.08,\n      \"max_single_position_ratio\": 0.08,\n      \"max_buy_slots\": 5\n    },\n    \"style_rotation\": {\n      \"enabled\": true,\n      \"short_window\": 5,\n      \"medium_window\": 20,\n      \"riskoff_short_excess_pct\": -2.0,\n      \"riskoff_medium_excess_pct\": -4.0,\n      \"hard_stop_short_excess_pct\": -4.0,\n      \"hard_stop_medium_excess_pct\": -6.0,\n      \"hard_stop_requires_negative_smallcap\": true\n    }\n  },\n  \"cost\": {\n    \"commission_rate\": 8.5e-05,\n    \"min_commission\": 0,\n    \"stamp_duty_sell\": 0.001,\n    \"slippage_bps\": 8\n  },\n  \"qlib_breadth_long_b_v1\": {\n    \"enabled\": true,\n    \"as_of_date\": \"20260404\",\n    \"period\": {\n      \"start_date\": \"2015-01-05\",\n      \"end_date\": \"2026-03-03\"\n    },\n    \"sanity_rules\": {\n      \"signal_shift\": \"T+1\",\n      \"deal_price\": \"open\",\n      \"open_cost\": 0.000885,\n      \"close_cost\": 0.001885,\n      \"breadth_use\": \"previous_day\"\n    },\n    \"params\": {\n      \"topk\": 8,\n      \"n_drop\": 1,\n      \"hold_thresh\": 4,\n      \"risk_degree\": 0.80,\n      \"min_score_improve\": 0.0,\n      \"daily_turnover_cap\": 0.28,\n      \"breadth_low_th\": 0.45,\n      \"breadth_mid_th\": 0.55,\n      \"breadth_low_scale\": 0.40,\n      \"breadth_mid_scale\": 0.70,\n      \"breadth_high_scale\": 1.0,\n      \"breadth_emergency_th\": 0.20,\n      \"dd_soft\": 0.10,\n      \"dd_hard\": 0.20\n    }\n  },\n  \"exit_rules\": {\n    \"trailing_take_profit_arm_pct\": 12.0,\n    \"trailing_take_profit_drawdown_pct\": 6.0,\n    \"trailing_take_profit_confirm_bars\": 1\n  },\n  \"smallcap_live_candidates\": {\n    \"profile\": \"v4_3_aggressive\",\n    \"config\": \"config/live_trading_v1.json\",\n    \"main_count\": 10,\n    \"guard_coun