{"type":"message","id":"a73c06e1","parentId":"61a5c342","timestamp":"2026-04-07T09:37:25.280Z","message":{"role":"toolResult","toolCallId":"call_function_f55fh10kh2v2_1","toolName":"read","content":[{"type":"text","text":"def get_paper_real_drawdown(profile_slug: str) -> Optional[float]:\n    \"\"\"Get paper account's real max_drawdown_pct from its latest metrics.\n    Returns None if no metrics file is available (fallback to live_system data).\n    \"\"\"\n    metrics = load_paper_latest_metrics(profile_slug)\n    if metrics is None:\n        return None\n    dd = metrics.get(\"metrics\", {}).get(\"max_drawdown_pct\")\n    if dd is not None:\n        return float(dd)\n    return None\n\ndef compute_panel_risk(global_risk: dict, profile_slug: str) -> dict:\n    \"\"\"Build a per-panel runtime risk state with panel-level halt logic.\n    \n    进取方案核心修复：使用纸盘自己的真实最大回撤，\n    而不是 live_system_v1 的11年回测回撤（24.51%），\n    避免纸盘被历史回测数据错误地halt。\n    \"\"\"\n    cfg = PROFILE_RUNTIME_RISK_CONFIG.get(profile_slug, {})\n    halt_pct = cfg.get(\"strategy_max_drawdown_halt_pct\", 15.0)\n    riskoff_pct = cfg.get(\"strategy_max_drawdown_riskoff_pct\", 10.0)\n    \n    global_metrics = global_risk.get(\"runtime_metrics\", {})\n    # 进取方案：优先用纸盘自己的真实回撤；没有则降级用全局live_system数据\n\n[97 more lines in file. Use offset=60 to continue.]"}],"isError":false,"timestamp":1775554645273}}
