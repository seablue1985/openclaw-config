{"type":"message","id":"864f2e39","parentId":"d0659993","timestamp":"2026-04-08T16:08:39.235Z","message":{"role":"toolResult","toolCallId":"call_function_e9mo202pvfao_1","toolName":"read","content":[{"type":"text","text":"{\n  \"market\": \"CN_A\",\n  \"constraints\": {\n    \"exclude_st\": true,\n    \"min_listing_days\": 120,\n    \"benchmark_smallcap\": \"ZZ2000\",\n    \"benchmark_broad\": \"HS300\"\n  },\n  \"targets\": {\n    \"annual_return_min_pct\": 40.0,\n    \"max_drawdown_max_pct\": 25.0\n  },\n  \"execution\": {\n    \"lot_size\": 100,\n    \"max_daily_add_ratio\": 0.6,\n    \"single_ticket_budget_ratio_of_available_cash\": 0.2,\n    \"max_single_position_ratio\": 0.08,\n    \"cash_buffer_ratio\": 0.1,\n    \"buy_window\": \"09:45-10:30\",\n    \"risk_only_after\": \"10:30\"\n  },\n  \"execution_decision\": {\n    \"enabled\": true,\n    \"buy_signal_score_weight\": 0.8,\n    \"buy_intraday_score_weight\": 0.2,\n    \"buy_intraday_floor_pct\": -2.0,\n    \"buy_intraday_ceiling_pct\": 2.0,\n    \"buy_realtime_drop_soft_penalty_pct\": -3.0,\n    \"buy_realtime_drop_hard_block_pct\": -5.0,\n    \"buy_realtime_drop_score_scale\": 0.35,\n    \"buy_realtime_drop_position_scale\": 0.25\n  },\n  \"smallcap_live_candidates\": {\n    \"profile\": \"candidate_top50\",\n    \"config\": \"config/strategy_smallcap_chip_candidate_top50.yaml\",\n    \"main_count\": 10,\n    \"guard_count\": 8,\n    \"main_target_weight\": 0.1,\n    \"guard_target_weight\": 0.08\n  },\n  \"broker_api\": {\n    \"enabled\": false,\n    \"adapter\": \"simulated\",\n    \"note\": \"Broker adapter selection: 'simulated' (paper), 'tongdaxin' (placeholder), 'huatai' (TBD), 'juejin' (TBD)\",\n    \"simulated\": {\n      \"initial_cash\": 1000000.0,\n      \"commission_rate\": 8.5e-05,\n      \"stamp_duty_sell\": 0.001\n    },\n    \"tongdaxin\": {\n      \"note\": \"Requires Windows + iFinD API COM. See execution/broker_tongdaxin.py\",\n      \"username_env\": \"THS_USERNAME\",\n      \"password_env\": \"THS_PASSWORD\",\n      \"account\": \"\"\n    },\n    \"rest\": {\n      \"base_url\": \"https://api.example.com\",\n      \"holdings_path\": \"/v1/holdings\",\n      \"trades_path\": \"/v1/trades\",\n      \"holdings_data_key\": \"data\",\n      \"trades_data_key\": \"data\",\n      \"token_env\": \"BROKER_API_TOKEN\",\n      \"token_header\": \"X-API-Token\",\n      \"extra_headers\": {},\n      \"query\": {},\n      \"date_query_param\": \"trade_date\",\n      \"date_format\": \"%Y-%m-%d\",\n      \"timeout_sec\": 12,\n      \"verify_ssl\": true,\n      \"fail_if_empty\": true\n    },\n    \"xtquant\": {\n      \"note\": \"迅投 QMT 接口（华泰/招商/中信等券商）；pip install xtquant；account=资金账号, password=交易密码, com_server=券商通讯服务器地址\",\n      \"account_env\": \"XTQUANT_ACCOUNT\",\n      \"password_env\": \"XTQUANT_PASSWORD\",\n      \"com_server\": \"\",\n      \"mgr_port\": 5858\n    },\n    \"manual_confirm_queue\": {\n      \"note\": \"人工确认队列模式：订单写入 orders/manual_confirm/ 目录，由人工在券商客户端执行。适用于同花顺等不支持 API 的券商。\",\n      \"orders_dir\": \"orders/manual_confirm\",\n      \"holdings_file\": \"data/holdings_ths_latest.json\",\n      \"account_file\": \"data/account_ths_latest.json\",\n      \"adapter\": \"tongdaxin\"\n    }\n  },\n  \"risk\": {\n    \"single_soft_stop_pct\": -5.0,\n    \"single_hard_stop_pct\": -8.0,\n    \"portfolio_drawdown_guard_pct\": -2.5,\n    \"portfolio_drawdown_halt_pct\": -3.5,\n    \"index_halt_threshold_pct\": -1.5,\n    \"weekly_loss_trigger_pct\": -5.0,\n    \"riskoff_total_exposure\": 0.65,\n    \"allow_new_buy_when_riskoff\": true,\n    \"market_breadth_riskoff_threshold\": 0.28,\n    \"market_breadth_hard_stop_threshold\": 0.14,\n    \"strategy_max_drawdown_riskoff_pct\": 10.0,\n    \"strategy_sharpe_cautious_threshold\": 0.8,\n    \"cautious_probe\": {\n      \"enabled\": true,\n      \"max_daily_add_ratio_of_available_cash\": 0.15,\n      \"single_ticket_budget_ratio_of_available_cash\": 0.05,\n      \"max_single_position_ratio\": 0.05,\n      \"max_buy_slots\": 3\n    },\n    \"style_rotation\": {\n      \"enabled\": true,\n      \"short_window\": 5,\n      \"medium_window\": 20,\n      \"riskoff_short_excess_pct\": -1.5,\n      \"riskoff_medium_excess_pct\": -3.0,\n      \"hard_stop_short_excess_pct\": -3.0,\n      \"hard_stop_medium_excess_pct\": -5.0,\n      \"hard_stop_requires_negative_smallcap\": true\n    },\n    \"volatility_regime\": {\n      \"enabled\": true,\n      \"short_window\": 20,\n      \"long_window\": 60,\n      \"riskoff_vol20_pct\": 18.0,\n      \"hard_stop_vol20_pct\": 22.0,\n      \"riskoff_vol_ratio\": 1.2,\n      \"hard_stop_vol_ratio\": 1.35,\n      \"hard_stop_requires_negative_return\": true,\n      \"note\": \"20d/60d年化波动率 regime，基于ZZ2000；vol_ratio=短/长>1.2触发risk_off，>1.35+指数跌触发halt\"\n    },\n    \"liquidity_regime\": {\n      \"enabled\": true,\n      \"short_window\": 5,\n      \"medium_window\": 20,\n      \"long_window\": 60,\n      \"riskoff_short_medium_ratio\": 0.8,\n      \"hard_stop_short_medium_ratio\": 0.65,\n      \"riskoff_latest_percentile\": 0.25,\n      \"hard_stop_latest_percentile\": 0.15,\n      \"note\": \"ZZ2000成交额5d/20d比值+60d分位数；低于阈值触发risk_off，极低触发halt（ liquidity硬停较宽松）\"\n    }\n  },\n  \"exit_rules\": {\n    \"enabled\": true,\n    \"stop_loss_pct\": -8.0,\n    \"stop_loss_soft_pct\": -5.0,\n    \"stop_loss_soft_sell_ratio\": 0.5,\n    \"stop_loss_hard_pct\": -8.0,\n    \"trailing_take_profit_arm_pct\": 8.0,\n    \"trailing_take_profit_drawdown_pct\": 4.0,\n    \"mode_cautious_target_exposure\": 0.65,\n    \"mode_halt_target_exposure\": 0.3,\n    \"peak_price_state_path\": \"research/reports/live_exit_peak_state_v1.json\"\n  },\n  \"cost\": {\n    \"commission_rate\": 8.5e-05,\n    \"min_commission\": 0,\n    \"stamp_duty_sell\": 0.001,\n    \"slippage_bps\": 8\n  },\n  \"qlib_breadth_sanity_v1\": {\n    \"enabled\": true,\n    \"as_of_date\": \"20260306\",\n    \"period\": {\n      \"start_date\": \"2023-01-03\",\n      \"end_date\": \"2026-03-0