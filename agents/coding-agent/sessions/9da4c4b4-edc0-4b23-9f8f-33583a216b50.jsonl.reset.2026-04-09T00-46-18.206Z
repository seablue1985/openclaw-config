{"type":"message","id":"1c03f93c","parentId":"35b37b5c","timestamp":"2026-04-08T15:53:50.424Z","message":{"role":"toolResult","toolCallId":"call_function_fxg77ga1ckmd_3","toolName":"read","content":[{"type":"text","text":"strategy_name: a_share_multi_factor_weekly\nuniverse:\n  indexes:\n  - HS300\n  - ZZ500\n  min_listing_days: 250\n  exclude_st: true\n  exclude_suspended: true\n  min_turnover_20d: 30000000\nrebalance:\n  frequency: weekly\n  day: monday\n  top_n: 40\nfactors:\n  momentum_60d:\n    weight: 0.35\n    direction: high\n  quality_roe_ttm:\n    weight: 0.25\n    direction: high\n  value_pe_ttm:\n    weight: 0.2\n    direction: low\n  low_vol_20d:\n    weight: 0.2\n    direction: low\nrisk:\n  max_single_position: 0.1\n  max_industry_exposure: 0.3\n  max_portfolio_drawdown: 0.1\n  stop_new_positions_if_drawdown_exceed: 0.08\n  daily_turnover_limit: 0.25\ncost:\n  commission_bps: 3\n  slippage_bps: 8\n  stamp_duty_sell_bps: 10\nvalidation:\n  walk_forward_months_train: 24\n  walk_forward_months_test: 6\n  min_sharpe: 0.8\n  max_drawdown: 0.2\nalpha:\n  momentum_window: 20\n  volatility_window: 40\n  momentum_weight: 1.0\n  volatility_weight: 1.2\n"}],"isError":false,"timestamp":1775663630419}}
