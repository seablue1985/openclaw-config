{"type":"message","id":"9dd97f1b","parentId":"22e82bf3","timestamp":"2026-04-08T16:26:04.240Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I have the full holdings data with 36 positions. This is great - it's more complete than what we had before. Let me now get the current prices for all these stocks to calculate real-time P&L.","thinkingSignature":"5dad18e1ea0fac291acb23898a6083be4ae6b07ca907f3bcbdf178c3b92a5f09"},{"type":"text","text":"36个持仓完整抓到了！比之前23只更全。现在让我批量获取实时价格计算盈亏。\n"},{"type":"toolCall","id":"call_function_16hnjfiky8op_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/quant_projects/personal-a-share-research-system && source .venv/bin/activate 2>/dev/null; /Library/Frameworks/Python.framework/Versions/3.14/bin/python3.14 << 'EOF'\nimport akshare as ak\nimport pandas as pd\nimport json\n\n# 读取持仓\ndf = pd.read_csv('/Users/ling/.openclaw/workspace/coding-agent/ths_selected_holdings.csv')\nprint(f\"总持仓: {len(df)}个\\n\")\n\nresults = []\nfor _, row in df.iterrows():\n    code = row['symbol']\n    name = row['name']\n    qty = row['quantity']\n    cost = row['cost_price']\n    asset_type = row['asset_type']\n    \n    if asset_type == 'fund':\n        results.append({\n            'name': name, 'code': code, 'type': 'ETF',\n            'qty': qty, 'cost': cost,\n            'current': 'N/A', 'pnl_pct': 0, 'pnl_abs': 0,\n            'mv': qty * cost, 'status': 'fund'\n        })\n        continue\n    \n    # 港股\n    if code.endswith('.HK'):\n        try:\n            df_hk = ak.stock_hk_spot_em()\n            row_hk = df_hk[df_hk['代码'] == code.replace('.HK', '')]\n            if not row_hk.empty:\n                current = float(row_hk.iloc[0]['最新价'])\n                change = float(row_hk.iloc[0]['涨跌幅'])\n            else:\n                current = cost\n                change = 0\n        except:\n            current = cost\n            change = 0\n        pnl_pct = (current - cost) / cost * 100\n        pnl_abs = (current - cost) * qty\n        results.append({\n            'name': name, 'code': code, 'type': '港股',\n            'qty': qty, 'cost': cost,\n            'current': current, 'pnl_pct': pnl_pct, 'pnl_abs': pnl_abs,\n            'mv': qty * current, 'change_today': change, 'status': 'ok'\n        })\n        print(f\"{'港'}{name}({code}): 成本={cost}, 现价={current:.2f}, 今日={change:.2f}%, 盈亏={pnl_pct:.1f}%\")\n        continue\n    \n    # A股\n    try:\n        pure = code.replace('.SH', '').replace('.SZ', '')\n        df_quote = ak.stock_bid_ask_em(symbol=pure)\n        quote = {r['item']: r['value'] for _, r in df_quote.iterrows()}\n        current = float(quote.get('最新', 0))\n        change_today = float(quote.get('涨幅', 0))\n        if current == 0:\n            raise ValueError(\"价格=0\")\n    except:\n        try:\n            df_hist = ak.stock_zh_a_hist(symbol=pure, period='daily', adjust='qfq')\n            current = float(df_hist.iloc[-1]['close'])\n            prev = float(df_hist.iloc[-2]['close']) if len(df_hist) > 1 else current\n            change_today = (current - prev) / prev * 100\n        except Exception as e:\n            current = cost\n            change_today = 0\n    \n    pnl_pct = (current - cost) / cost * 100\n    pnl_abs = (current - cost) * qty\n    results.append({\n        'name': name, 'code': code, 'type': 'A股',\n        'qty': qty, 'cost': cost,\n        'current': current, 'pnl_pct': pnl_pct, 'pnl_abs': pnl_abs,\n        'mv': qty * current, 'change_today': change_today, 'status': 'ok'\n    })\n    print(f\"{name}({code}): 成本={cost:.2f}, 现价={current:.2f}, 今日={change_today:+.1f}%, 盈亏={pnl_pct:+.1f}%\")\n\nprint(\"\\n=== 汇总 ===\")\nstocks = [r for r in results if r['status'] == 'ok']\nfunds = [r for r in results if r['status'] == 'fund']\ntotal_stock_mv = sum(r['mv'] for r in stocks)\ntotal_stock_cost = sum(r['qty'] * r['cost'] for r in stocks)\ntotal_stock_pnl = total_stock_mv - total_stock_cost\ntotal_fund_mv = sum(r['mv'] for r in funds)\n\nprint(f\"A股+港股持仓市值: {total_stock_mv:,.0f}\")\nprint(f\"A股+港股成本: {total_stock_cost:,.0f}\")\nprint(f\"A股+港股盈亏: {total_stock_pnl:,.0f} ({total_stock_pnl/total_stock_cost*100:+.1f}%)\")\nprint(f\"ETF基金市值: {total_fund_mv:,.0f}\")\nprint(f\"股票+基金总计: {total_stock_mv + total_fund_mv:,.0f}\")\nprint(f\"现金(约): 880,000\")\nprint(f\"估算总资产: {total_stock_mv + total_fund_mv + 880000:,.0f}\")\n\n# 保存结果\nwith open('/tmp/holdings_analysis.json', 'w') as f:\n    json.dump(results, f, ensure_ascii=False, indent=2)\nprint(\"\\n详细数据已保存\")\nEOF\n","timeout":180}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":113856,"output":1314,"cacheRead":19969,"cacheWrite":0,"totalTokens":135139,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775665543284,"responseId":"0625b4876c15a7bcd9b61ef7d1a42cbb"}}
