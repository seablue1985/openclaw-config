{"type":"message","id":"51b5031d","parentId":"3446adfc","timestamp":"2026-04-19T00:28:41.903Z","message":{"role":"toolResult","toolCallId":"call_8kKRjjR16XsTHDeziU9fXVi5|fc_0670f03dbcdf5eed0169e421b92cd48199a603f63ba036cd1f","toolName":"read","content":[{"type":"text","text":"        if len(part) == 8 and part.isdigit():\n            return part\n    return \"\"\n\n\ndef resolve_expected_trade_date(report_date_tag: str) -> dict[str, str]:\n    normalized = str(report_date_tag or \"\").strip()\n    candidates: list[tuple[str, str]] = []\n\n    if MARKET_PRICE_HISTORY.exists():\n        try:\n            latest_trade_date = latest_trade_date_from_history(MARKET_PRICE_HISTORY)\n            if latest_trade_date is not None:\n                latest_market_trade_date = str(int(latest_trade_date))\n                if latest_market_trade_date <= normalized:\n                    candidates.append((\"market_price_history\", latest_market_trade_date))\n        except Exception:\n            pass\n\n    today_report = load_json(REPORT_DIR / \"today_stock_strategy_report_latest.json\")\n    today_report_date_tag = str(today_report.get(\"date_tag\") or \"\").strip()\n    if len(today_report_date_tag) == 8 and today_report_date_tag.isdigit() and today_report_date_tag <= normalized:\n        candidates.append((\"today_stock_strategy_report\", today_report_date_tag))\n\n    latest_live_review_tag = extract_date_tag_from_name(latest_report(\"live_close_review_v2_*.json\"))\n    if len(latest_live_review_tag) == 8 and latest_live_review_tag.isdigit() and latest_live_review_tag <= normalized:\n        candidates.append((\"live_close_review\", latest_live_review_tag))\n\n    for profile_slug in TRACKED_ACCOUNT_PROFILES:\n        account_payload = load_json(REPORT_DIR / f\"paper_{profile_slug}_account_v1_latest.json\")\n        account_date_tag = str(account_payload.get(\"date_tag\") or \"\").strip()\n        if len(account_date_tag) == 8 and account_date_tag.isdigit() and account_date_tag <= normalized:\n            candidates.append((f\"paper_account:{profile_slug}\", account_date_tag))\n\n    if not candidates:\n        return {\"date_tag\": normalized, \"source\": \"wall_clock\"}\n\n    source, date_tag = max(candidates, key=lambda item: item[1])\n    return {\"date_tag\": date_tag, \"source\": source}\n\n\ndef governance_gate_state() -> dict[str, Any]:\n    path = REPORT_DIR / \"strategy_governance_gate_latest.json\"\n    if not path.exists():\n        return {\n            \"status\": \"RED\",\n            \"path\": str(path),\n            \"mtime\": \"\",\n            \"reason\": \"missing_governance_gate_report\",\n            \"report_status\": \"MISSING\",\n            \"blocking_issues\": [\"missing_governance_gate_report\"],\n            \"registry_rows\": [],\n        }\n\n    try:\n        payload = json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {\n            \"status\": \"RED\",\n            \"path\": str(path),\n            \"mtime\": datetime.fromtimestamp(path.stat().st_mtime).strftime(\"%Y-%m-%d %H:%M:%S\"),\n            \"reason\": \"invalid_governance_gate_report\",\n            \"report_status\": \"INVALID\",\n            \"blocking_issues\": [\"invalid_governance_gate_report\"],\n            \"registry_rows\": [],\n        }\n\n    mtime = datetime.fromtimestamp(path.stat().st_mtime)\n    age_hours = (datetime.now() - mtime).total_seconds() / 3600.0\n    report_status = str(payload.get(\"overall_status\") or \"UNKNOWN\").upper()\n    blocking_issues = [str(x).strip() for x in (payload.get(\"blocking_issues\") or []) if str(x).strip()]\n    manual_review = payload.get(\"manual_review\") or {}\n    manual_review_decisions = [\n        f\"{str(item.get('strategy_id') or '').strip()}:{str(item.get('suggested_action') or '').strip()}\"\n        for item in (manual_review.get(\"decisions\") or [])\n        if str(item.get(\"strategy_id\") or \"\").strip()\n    ]\n    stale = age_hours > 72\n    if stale:\n        blocking_issues.append(\"stale_governance_gate_report\")\n\n[888 more lines in file. Use offset=340 to continue.]"}],"isError":false,"timestamp":1776558521894}}
{"type":"message","id":"764aad86","parentId":"51b5031d","timestamp":"2026-04-19T00:28:41.912Z","message":{"role":"toolResult","toolCallId":"call_zbPSsZlcXXAfA8iQlf4VGMnR|fc_0670f03dbcdf5eed0169e421b92ce881998a75866e27246479","toolName":"read","content":[{"type":"text","text":"    runtime_truth = get_runtime_truth(live_review)\n    return {\n        \"live_risk_level\": live_review.get(\"risk_level\", \"NO_DATA\"),\n        \"live_tomorrow_mode\": live_review.get(\"tomorrow_mode\", \"-\"),\n        \"live_runtime_truth_state\": str(runtime_truth.get(\"state\") or \"NO_DATA\"),\n        \"live_runtime_truth_ready\": bool(runtime_truth.get(\"trading_ready\")),\n        \"trading_status\": str(runtime_truth.get(\"trading_status\") or \"NO_DATA\"),\n        \"trading_status_reason\": str(runtime_truth.get(\"trading_status_reason\") or \"\"),\n        \"live_orders_total\": (live_review.get(\"orders\") or {}).get(\"total\", 0),\n        \"live_execution_attempted\": (live_review.get(\"orders\") or {}).get(\"execution_attempted\", 0),\n        \"live_pending_confirm_not_sent\": (live_review.get(\"orders\") or {}).get(\"pending_confirm_not_sent\", 0),\n        \"live_not_sent\": (live_review.get(\"orders\") or {}).get(\"not_sent\", 0),\n        \"live_journal_records\": (live_review.get(\"journal\") or {}).get(\"records\", 0),\n        \"source_report\": str(live_review_path),\n        \"source_report_date_tag\": review_date_tag,\n    }\n\n\ndef build_payload() -> dict[str, Any]:\n    expected_report_date_tag = datetime.now().strftime(\"%Y%m%d\")\n    expected_trade_date = resolve_expected_trade_date(expected_report_date_tag)\n    expected_trade_date_tag = expected_trade_date[\"date_tag\"]\n    incident_registry_mod.sync_registry(write=True)\n    today_report = load_json(REPORT_DIR / \"today_stock_strategy_report_latest.json\")\n    premarket_reviews = sorted(REPORT_DIR.glob(\"live_premarket_risk_v2_*.json\"))\n    premarket_review_path = premarket_reviews[-1] if premarket_reviews else None\n    premarket_review = load_json(premarket_review_path) if premarket_review_path else {}\n    guard_summary = load_json(REPORT_DIR / \"strategy_probe_guard_summary_latest.json\")\n    perf_panel = load_json(REPORT_DIR / \"strategy_performance_panel_latest.json\")\n    breadth_alert_raw = load_json(REPORT_DIR / \"breadth_strict_oos_alert_state.json\")\n    breadth_alert = normalize_breadth_alert_state(\n        breadth_alert_raw,\n        expected_trade_date_tag=expected_trade_date_tag,\n    )\n    runtime_state = load_json(REPORT_DIR / \"runtime_risk_state_latest.json\")\n    future_leak_audit = load_json(REPORT_DIR / \"future_leak_walkforward_audit_latest.json\")\n    intervention_rows = load_csv_tail(REPORT_DIR / \"risk_intervention_log.csv\", limit=5)\n    profile_update_checks = [profile_update_state(profile_slug, expected_date_tag=expected_trade_date_tag) for profile_slug in TRACKED_ACCOUNT_PROFILES]\n    exact_live_review_path = REPORT_DIR / f\"live_close_review_v2_{expected_trade_date_tag}.json\"\n    latest_live_review_path = latest_report(\"live_close_review_v2_*.json\")\n    live_review_path = exact_live_review_path if exact_live_review_path.exists() else latest_live_review_path\n    live_review = load_json(live_review_path) if live_review_path else {}\n    execution_live_review_path = exact_live_review_path if exact_live_review_path.exists() else None\n    execution_live_review = load_json(execution_live_review_path) if execution_live_review_path else {}\n    exit_suite_reports = sorted(REPORT_DIR.glob(\"paper_exit_candidate_suite_*.json\"))\n    manual_review_summary = aggregate_manual_review_state()\n    governance_summary = governance_gate_state()\n\n    system_checks = {\n        \"strategy_report\": file_state(REPORT_DIR / \"today_stock_strategy_report_latest.json\", stale_hours=72),\n        \"premarket_runtime_v2\": file_state(premarket_review_path, stale_hours=72) if premarket_review_path else {\"status\": \"YELLOW\", \"path\": \"\", \"mtime\": \"\", \"reason\": \"missing\"},\n        \"strategy_governance_gate\": {\n            \"status\": governance_summary[\"status\"],\n            \"path\": governance_summary[\"path\"],\n            \"mtime\": governance_summary[\"mtime\"],\n            \"reason\": governance_summary[\"reason\"],\n            \"manual_review_signoff_pending\": governance_summary.get(\"manual_review_signoff_pending\"),\n            \"manual_review_decisions\": governance_summary.get(\"manual_review_decisions\") or [],\n        },\n        \"guard_summary\": json_date_tag_state(\n            REPORT_DIR / \"strategy_probe_guard_summary_latest.json\",\n            expected_date_tag=expected_trade_date_tag,\n            stale_hours=72,\n        ),\n        \"latest_chain_consistency\": latest_chain_consistency_state(\n            expected_trade_date_tag=expected_trade_date_tag,\n            perf_panel=perf_panel,\n            guard_summary=guard_summary,\n        ),\n        \"performance_panel\": file_state(REPORT_DIR / \"strategy_performance_panel_latest.html\", stale_hours=72),\n        \"breadth_aggressive\": file_state(REPORT_DIR / \"breadth_aggressive_paper_latest.json\", stale_hours=72),\n        \"breadth_strict_oos\": file_state(REPORT_DIR / \"breadth_strict_oos_paper_latest.json\", stale_hours=72),\n        \"breadth_strict_oos_alert\": file_state(REPORT_DIR / \"breadth_strict_oos_alert_state.json\", stale_hours=72),\n        \"alpha55_account\": file_state(REPORT_DIR / \"paper_alpha55_account_v1_latest.json\", stale_hours=72),\n        \"exit_dual_account\": file_state(REPORT_DIR / \"paper_exit_dual_account_v1_latest.json\", stale_hours=72),\n        \"exit_tight_account\": file_state(REPORT_DIR / \"paper_exit_tight_account_v1_latest.json\", stale_hours=72),\n        \"exit_candidate_suite\": file_state(exit_suite_reports[-1], stale_hours=72) if exit_suite_reports else {\"status\": \"RED\", \"path\": \"\", \"mtime\": \"\", \"reason\": \"missing\"},\n        \"future_leak_walkforward_audit\": file_state(REPORT_DIR / \"future_leak_walkforward_audit_latest.json\", stale_hours=72),\n        \"risk_intervention_log\": intervention_log_state(runtime_state),\n        \"manual_reconciliation\": {\n\n[348 more lines in file. Use offset=880 to continue.]"}],"isError":false,"timestamp":1776558521905}}
