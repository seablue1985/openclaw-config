ace/quant_projects/personal-a-share-research-system/scripts/generate_today_stock_strategy_report.py","offset":500,"limit":90},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_today_stock_strategy_report.py\",\"offset\":500,\"limit\":90}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":9899,"output":134,"cacheRead":74752,"cacheWrite":0,"totalTokens":84785,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776558555043,"responseId":"resp_0670f03dbcdf5eed0169e421dca02081998c2878a227aa7d43"}}
{"type":"message","id":"5279c7b2","parentId":"50e75142","timestamp":"2026-04-19T00:29:22.361Z","message":{"role":"toolResult","toolCallId":"call_uBzIUFBJk3eUVHwN2n1JXoQp|fc_0670f03dbcdf5eed0169e421e1adc881998a7ab9928e2a56df","toolName":"read","content":[{"type":"text","text":"        \"mode\": parsed.get(\"mode\") or stats.get(\"mode\"),\n        \"risk_off\": parsed.get(\"risk_off\") if parsed.get(\"risk_off\") is not None else stats.get(\"risk_off\"),\n        \"hard_stop\": parsed.get(\"hard_stop\") if parsed.get(\"hard_stop\") is not None else stats.get(\"hard_stop\"),\n        \"halt_new_buy\": parsed.get(\"halt_new_buy\") if parsed.get(\"halt_new_buy\") is not None else stats.get(\"halt_new_buy\"),\n        \"market_breadth\": parsed.get(\"market_breadth\") if parsed.get(\"market_breadth\") is not None else stats.get(\"market_breadth\"),\n        \"halt_reason\": parsed.get(\"halt_reason\") or stats.get(\"halt_reason\") or precheck.get(\"halt_reason\") or precheck.get(\"status_reason\"),\n        \"gate_reasons\": gate_reasons,\n        \"decision_eligible_buy_count\": stats.get(\"decision_eligible_buy_count\"),\n        \"blocked_buy_halt\": stats.get(\"blocked_buy_halt\"),\n        \"buy_count\": stats.get(\"buy_count\"),\n        \"sell_count\": stats.get(\"sell_count\"),\n        \"authoritative\": bool(parsed or stats),\n    }\n\n\ndef dedupe_signal_rows(rows: list[dict[str, str]]) -> list[dict[str, str]]:\n    merged: dict[tuple[str, str], dict[str, str]] = {}\n    for row in rows:\n        ts_code = str(row.get(\"ts_code\") or \"\").strip()\n        action = str(row.get(\"action\") or \"\").strip().upper()\n        if not ts_code or not action:\n            continue\n        key = (ts_code, action)\n        score = to_float(row.get(\"score\"))\n        current = merged.get(key)\n        if current is None or score > to_float(current.get(\"score\")):\n            merged[key] = row\n    return sorted(\n        merged.values(),\n        key=lambda row: (\n            str(row.get(\"action\") or \"\").upper(),\n            -to_float(row.get(\"score\")),\n            str(row.get(\"ts_code\") or \"\"),\n        ),\n    )\n\n\ndef classify_candidates(rows: list[dict[str, str]]) -> tuple[list[dict[str, str]], list[dict[str, str]], list[dict[str, str]]]:\n    buy_rows = [row for row in rows if str(row.get(\"action\") or \"\").upper() == \"BUY\"]\n    sell_rows = [row for row in rows if str(row.get(\"action\") or \"\").upper() == \"SELL\"]\n    tech_rows = [\n        row\n        for row in buy_rows\n        if \"smallcap_chip_v4_2\" in str(row.get(\"strategy_id\") or \"\")\n    ]\n    guard_rows = [\n        row\n        for row in buy_rows\n        if \"smallcap_chip_v4_2b\" in str(row.get(\"strategy_id\") or \"\")\n    ]\n    tech_rows = sorted(tech_rows, key=lambda row: -to_float(row.get(\"score\")))\n    guard_rows = sorted(guard_rows, key=lambda row: -to_float(row.get(\"score\")))\n    sell_rows = sorted(sell_rows, key=lambda row: -to_float(row.get(\"score\")))\n    # Deduplicate: guard_rows (v4_2b, more conservative) takes priority over tech_rows (v4_2)\n    guard_codes = {row[\"ts_code\"] for row in guard_rows}\n    tech_rows = [row for row in tech_rows if row[\"ts_code\"] not in guard_codes]\n    return tech_rows, guard_rows, sell_rows\n\n\ndef merged_signal_rows(path: Path | None) -> list[dict[str, str]]:\n    rows = load_csv_rows(path)\n    converted: list[dict[str, str]] = []\n    for row in rows:\n        action = str(row.get(\"action\") or row.get(\"signal_type\") or \"\").strip().upper()\n        if not action:\n            continue\n        converted.append(\n            {\n                \"trade_date\": str(row.get(\"trade_date\") or \"\"),\n                \"ts_code\": str(row.get(\"ts_code\") or \"\"),\n                \"action\": action,\n                \"score\": str(row.get(\"score\") or \"\"),\n                \"strategy_id\": str(row.get(\"strategy_id\") or \"\"),\n                \"approved\": \"False\",\n                \"ai_stock_name\": str(row.get(\"ai_stock_name\") or \"\"),\n                \"ai_operation_advice\": str(row.get(\"ai_operation_advice\") or \"候选观察\"),\n                \"ai_decision\": str(row.get(\"ai_decision\") or \"observe\"),\n                \"risk_status\": str(row.get(\"risk_flag\") or row.get(\"risk_status\") or \"normal\"),\n            }\n        )\n    return converted\n\n\ndef execution_pass_rows(rows: list[dict[str, str]]) -> list[dict[str, str]]:\n    passed = [\n        row\n        for row in rows\n        if str(row.get(\"approved\") or \"\").strip().lower() == \"true\"\n        and str(row.get(\"ai_decision\") or \"\").strip().lower() != \"block\"\n    ]\n\n[587 more lines in file. Use offset=340 to continue.]"}],"isError":false,"timestamp":1776558562355}}
{"type":"message","id":"76d65cca","parentId":"5279c7b2","timestamp":"2026-04-19T00:29:22.367Z","message":{"role":"toolResult","toolCallId":"call_GHHA1plQzaI9ZxKzMrJ5gv2H|fc_0670f03dbcdf5eed0169e421e1addc8199bff6b1dea5b669cc","toolName":"read","content":[{"type":"text","text":"            rs[\"generated_at\"] = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n            atomic_write_json(rs_path, rs)\n    except Exception:\n        pass  # 非关键路径，不阻断报告生成\n\n    buy_count = len([row for row in deduped_rows if str(row.get(\"action\") or \"\").upper() == \"BUY\"])\n    sell_count = len(sell_rows)\n    blocked_buy_total = sum(int(to_float(stats.get(\"blocked_buy_halt\"))) for stats in profile_stats)\n    decision_eligible_buy_total = sum(int(to_float(stats.get(\"decision_eligible_buy_count\"))) for stats in profile_stats)\n    realtime_source_breakdown_total: dict[str, int] = {}\n    intraday_ma_source_breakdown_total: dict[str, int] = {}\n    for stats in profile_stats:\n        for key, value in parse_counter_map(stats.get(\"realtime_source_breakdown\")).items():\n            realtime_source_breakdown_total[key] = realtime_source_breakdown_total.get(key, 0) + value\n        for key, value in parse_counter_map(stats.get(\"intraday_ma_source_breakdown\")).items():\n            intraday_ma_source_breakdown_total[key] = intraday_ma_source_breakdown_total.get(key, 0) + value\n    if not realtime_source_breakdown_total:\n        live_sources = live_overlay.get(\"realtime_sources\", []) or []\n        ths_confirmed_count = int(to_float(live_overlay.get(\"ths_confirmed_count\")))\n        if len(live_sources) == 1 and ths_confirmed_count > 0:\n            realtime_source_breakdown_total[str(live_sources[0])] = ths_confirmed_count\n\n    if runtime_snapshot.get(\"authoritative\"):\n        if runtime_snapshot.get(\"buy_count\") is not None:\n            buy_count = int(to_float(runtime_snapshot.get(\"buy_count\")))\n        if runtime_snapshot.get(\"sell_count\") is not None:\n            sell_count = int(to_float(runtime_snapshot.get(\"sell_count\")))\n        if runtime_snapshot.get(\"blocked_buy_halt\") is not None:\n            blocked_buy_total = int(to_float(runtime_snapshot.get(\"blocked_buy_halt\")))\n        if runtime_snapshot.get(\"decision_eligible_buy_count\") is not None:\n            decision_eligible_buy_total = int(to_float(runtime_snapshot.get(\"decision_eligible_buy_count\")))\n\n    comparison_profiles = comparison_metrics.get(\"profiles\", []) or []\n    annual_candidates = [item.get(\"metrics\", {}).get(\"strategy_annual_return_pct\") for item in comparison_profiles]\n    mdd_candidates = [item.get(\"metrics\", {}).get(\"max_drawdown_pct\") for item in comparison_profiles]\n    sharpe_candidates = [item.get(\"metrics\", {}).get(\"sharpe\") for item in comparison_profiles]\n    comparison_trade_count = sum(int(to_float(item.get(\"metrics\", {}).get(\"trade_count\"))) for item in comparison_profiles)\n    comparison_annual = max([to_float(value, -999.0) for value in annual_candidates], default=0.0)\n    comparison_mdd = max([to_float(value, 0.0) for value in mdd_candidates], default=0.0)\n    valid_sharpes = [to_float(value) for value in sharpe_candidates if value not in (None, \"\")]\n    comparison_sharpe = max(valid_sharpes) if valid_sharpes else 0.0\n\n    research_priority_candidates = execution_pass_rows(tech_rows)[:5]\n    research_guarded_candidates = execution_pass_rows(guard_rows)[:5]\n    display_tech_rows = tech_rows[:8]\n    display_guard_rows = guard_rows[:8]\n    recommendation_status = recommendation_gate(\n        halt_new_buy=halt_new_buy,\n        governance_status=governance_status,\n    )\n    priority_candidates = [] if recommendation_status[\"blocked\"] else research_priority_candidates\n    guarded_candidates = [] if recommendation_status[\"blocked\"] else research_guarded_candidates\n    priority_codes = [str(row.get(\"ts_code\") or \"\") for row in priority_candidates if row.get(\"ts_code\")]\n    guarded_codes = [str(row.get(\"ts_code\") or \"\") for row in guarded_candidates if row.get(\"ts_code\")]\n    raw_buy_count = buy_count\n    executable_buy_count = 0 if recommendation_status[\"blocked\"] else buy_count\n\n    trade_date = f\"{date_tag[:4]}-{date_tag[4:6]}-{date_tag[6:]}\"\n    trigger_reason = \"；\".join(halt_reasons) if halt_reasons else \"无\"\n    gate_reason_text = \"；\".join(gate_reasons) if gate_reasons else \"无\"\n    benchmark_code = str(runtime_metrics.get(\"benchmark_code\") or latest_runtime.get(\"benchmark_code\") or \"-\")\n    index_ret_pct = latest_runtime.get(\"index_ret_pct\")\n    breadth_riskoff = risk_thresholds.get(\"market_breadth_riskoff_threshold\")\n    breadth_hard_stop = risk_thresholds.get(\"market_breadth_hard_stop_threshold\")\n    intraday_gate_action = str(intraday_gate.get(\"gate_action\") or \"none\")\n    intraday_gate_reason = str(intraday_gate.get(\"reason\") or \"无\")\n    intraday_index_snapshot = [\n        f\"{str(item.get('name') or code)} {fmt_pct(item.get('change_pct'))}%\"\n        for code, item in (intraday_gate.get(\"indices\") or {}).items()\n        if isinstance(item, dict)\n    ]\n    intraday_breadth_source = str(intraday_breadth.get(\"source\") or \"-\")\n    intraday_breadth_at = str(intraday_breadth.get(\"captured_at\") or runtime_state_latest.get(\"generated_at\") or \"-\")\n    runtime_risk_cfg = (runtime_config.get(\"risk\") or {}) if isinstance(runtime_config, dict) else {}\n    allow_new_buy_when_riskoff = risk_thresholds.get(\n        \"allow_new_buy_when_riskoff\",\n        runtime_risk_cfg.get(\"allow_new_buy_when_riskoff\"),\n    )\n    index_halt_threshold_pct = risk_thresholds.get(\n        \"index_halt_threshold_pct\",\n        runtime_risk_cfg.get(\"index_halt_threshold_pct\"),\n    )\n    runtime_truth_state = runtime_snapshot.get(\"runtime_truth_state\")\n    runtime_truth_ready = runtime_snapshot.get(\"runtime_truth_ready\")\n    runtime_buy_authorized = runtime_snapshot.get(\"buy_authorized\")\n    runtime_trading_status = str(runtime_truth.get(\"trading_status\") or runtime_snapshot.get(\"runtime_truth_state\") or \"\").strip()\n\n    precheck_status = str(precheck.get(\"status\") or \"\").strip()\n    precheck_passed = precheck.get(\"passed\")\n    precheck_date_tag = path_date_tag(precheck_path)\n\n[337 more lines in file. Use offset=590 to continue.]"}],"isError":false,"timestamp":1776558562361}}
