{"type":"message","id":"a378f85d","parentId":"98165793","timestamp":"2026-04-09T10:15:27.210Z","message":{"role":"toolResult","toolCallId":"call_function_09xrmiql8myz_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env bash\n# =============================================================================\n# Tesslate Studio — One-Command Installer\n# =============================================================================\n# Usage: curl -fsSL https://tesslate.com/install.sh | bash\n#\n# Installs Tesslate Studio locally using Docker Compose.\n# Idempotent — safe to re-run. Does NOT auto-install Docker.\n# =============================================================================\n\nset -euo pipefail\n\nREPO_URL=\"https://github.com/TesslateAI/Studio.git\"\nINSTALL_DIR=\"${TESSLATE_DIR:-$HOME/tesslate-studio}\"\nHEALTH_URL=\"http://studio.localhost\"\nHEALTH_TIMEOUT=60\n\n# ── Colors (respects NO_COLOR) ──\n\nif [[ -z \"${NO_COLOR:-}\" ]] && [[ -t 1 ]]; then\n  B='\\033[1m'\n  G='\\033[0;32m'\n  R='\\033[0;31m'\n  Y='\\033[1;33m'\n  C='\\033[0;36m'\n  D='\\033[0;90m'\n  NC='\\033[0m'\nelse\n  B='' G='' R='' Y='' C='' D='' NC=''\nfi\n\nok()   { echo -e \"  ${G}✓${NC} $*\"; }\nerr()  { echo -e \"  ${R}✗${NC} $*\"; }\nwarn() { echo -e \"  ${Y}!${NC} $*\"; }\ninfo() { echo -e \"  ${C}▸${NC} $*\"; }\nhdr()  { echo -e \"\\n${B}$*${NC}\\n\"; }\n\ndie() { err \"$@\"; exit 1; }\n\n# ── Banner ──\n\necho \"\"\necho -e \"${B}  ╔══════════════════════════════════════════╗${NC}\"\necho -e \"${B}  ║     Tesslate Studio — Local Installer     ║${NC}\"\necho -e \"${B}  ║   Open source · Self-hosted · Your data    ║${NC}\"\necho -e \"${B}  ╚══════════════════════════════════════════╝${NC}\"\necho \"\"\n\n# ── Step 1: Check prerequisites ──\n\nhdr \"Checking prerequisites...\"\n\n# Docker\nif command -v docker &>/dev/null; then\n  ok \"Docker found: $(docker --version | head -1)\"\nelse\n  die \"Docker not found.\n\n  Please install Docker first:\n    macOS / Windows:  https://docs.docker.com/desktop/\n    Linux:            https://docs.docker.com/engine/install/\n\n  Then re-run this script.\"\nfi\n\n# Docker daemon running\nif ! docker info &>/dev/null; then\n  die \"Docker daemon is not running.\n\n  Start Docker Desktop (macOS/Windows) or run:\n    sudo systemctl start docker  (Linux)\n\n  Then re-run this script.\"\nfi\n\n# Docker Compose\nif docker compose version &>/dev/null; then\n  ok \"Docker Compose found: $(docker compose version --short 2>/dev/null || echo 'available')\"\nelif command -v docker-compose &>/dev/null; then\n  ok \"docker-compose found (legacy)\""}],"details":{"status":"completed","exitCode":0,"durationMs":863,"aggregated":"#!/usr/bin/env bash\n# =============================================================================\n# Tesslate Studio — One-Command Installer\n# =============================================================================\n# Usage: curl -fsSL https://tesslate.com/install.sh | bash\n#\n# Installs Tesslate Studio locally using Docker Compose.\n# Idempotent — safe to re-run. Does NOT auto-install Docker.\n# =============================================================================\n\nset -euo pipefail\n\nREPO_URL=\"https://github.com/TesslateAI/Studio.git\"\nINSTALL_DIR=\"${TESSLATE_DIR:-$HOME/tesslate-studio}\"\nHEALTH_URL=\"http://studio.localhost\"\nHEALTH_TIMEOUT=60\n\n# ── Colors (respects NO_COLOR) ──\n\nif [[ -z \"${NO_COLOR:-}\" ]] && [[ -t 1 ]]; then\n  B='\\033[1m'\n  G='\\033[0;32m'\n  R='\\033[0;31m'\n  Y='\\033[1;33m'\n  C='\\033[0;36m'\n  D='\\033[0;90m'\n  NC='\\033[0m'\nelse\n  B='' G='' R='' Y='' C='' D='' NC=''\nfi\n\nok()   { echo -e \"  ${G}✓${NC} $*\"; }\nerr()  { echo -e \"  ${R}✗${NC} $*\"; }\nwarn() { echo -e \"  ${Y}!${NC} $*\"; }\ninfo() { echo -e \"  ${C}▸${NC} $*\"; }\nhdr()  { echo -e \"\\n${B}$*${NC}\\n\"; }\n\ndie() { err \"$@\"; exit 1; }\n\n# ── Banner ──\n\necho \"\"\necho -e \"${B}  ╔══════════════════════════════════════════╗${NC}\"\necho -e \"${B}  ║     Tesslate Studio — Local Installer     ║${NC}\"\necho -e \"${B}  ║   Open source · Self-hosted · Your data    ║${NC}\"\necho -e \"${B}  ╚══════════════════════════════════════════╝${NC}\"\necho \"\"\n\n# ── Step 1: Check prerequisites ──\n\nhdr \"Checking prerequisites...\"\n\n# Docker\nif command -v docker &>/dev/null; then\n  ok \"Docker found: $(docker --version | head -1)\"\nelse\n  die \"Docker not found.\n\n  Please install Docker first:\n    macOS / Windows:  https://docs.docker.com/desktop/\n    Linux:            https://docs.docker.com/engine/install/\n\n  Then re-run this script.\"\nfi\n\n# Docker daemon running\nif ! docker info &>/dev/null; then\n  die \"Docker daemon is not running.\n\n  Start Docker Desktop (macOS/Windows) or run:\n    sudo systemctl start docker  (Linux)\n\n  Then re-run this script.\"\nfi\n\n# Docker Compose\nif docker compose version &>/dev/null; then\n  ok \"Docker Compose found: $(docker compose version --short 2>/dev/null || echo 'available')\"\nelif command -v docker-compose &>/dev/null; then\n  ok \"docker-compose found (legacy)\"","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1775729727198}}
