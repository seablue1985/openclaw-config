need to use jq or maybe a Python script to modify the JSON. It's probably a good idea to do a backup first, perhaps with a simple copy (cp) command. I'll also consider using exec alongside the Python script for this. Just making sure I have a solid plan before diving in!\"}]}"},{"type":"toolCall","id":"call_FKxBzKGtlLxsMZK2P6LlhViX|fc_074e35d428ca81320169ef58c1d2c0819abdf860a19c62e507","name":"exec","arguments":{"command":"python3 - <<'PY'\nimport json\nfrom pathlib import Path\npath = Path('/Users/ling/.openclaw/openclaw.json')\ndata = json.loads(path.read_text())\nfor agent in data['agents']['list']:\n    if agent.get('id') == 'coding-agent':\n        model = agent.setdefault('model', {})\n        old_primary = model.get('primary')\n        old_fallbacks = model.get('fallbacks', [])\n        model['primary'] = 'deepseek/deepseek-v4-pro'\n        new_fallbacks = []\n        for m in [old_primary, *old_fallbacks]:\n            if m and m != model['primary'] and m not in new_fallbacks:\n                new_fallbacks.append(m)\n        model['fallbacks'] = new_fallbacks\n        break\nelse:\n    raise SystemExit('coding-agent not found')\npath.write_text(json.dumps(data, ensure_ascii=False, indent=2) + '\\n')\nprint('updated', old_primary, '->', 'deepseek/deepseek-v4-pro')\nprint('fallbacks:', new_fallbacks)\nPY","workdir":"/Users/ling/.openclaw/workspace/coding-agent","timeout":20}}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":49823,"output":336,"cacheRead":0,"cacheWrite":0,"totalTokens":50159,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777293499771,"responseId":"resp_074e35d428ca81320169ef58be1a98819abdd99f4f9e71aaf5"}}
