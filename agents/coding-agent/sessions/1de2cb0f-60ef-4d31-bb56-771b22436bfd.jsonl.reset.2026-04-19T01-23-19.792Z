m_adapter.py","limit":260},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/llm_adapter.py\",\"limit\":260}"},{"type":"toolCall","id":"call_gBwIY0MENa8RmI9umFPYU5Yy|fc_0fad9e409c19087f0169e3b2dbbc14819aa7a9e8cbfed23cdc","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/minimax_adapter.py","limit":320},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/minimax_adapter.py\",\"limit\":320}"},{"type":"toolCall","id":"call_U7PUCNmuVjqvYOsphcrYg51Y|fc_0fad9e409c19087f0169e3b2dbbc20819aa198b0dbbc767606","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/run_explainer.py","limit":140},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/run_explainer.py\",\"limit\":140}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":53726,"output":340,"cacheRead":191104,"cacheWrite":0,"totalTokens":245170,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776530126539,"responseId":"resp_0fad9e409c19087f0169e3b2d2c52c819a842eaf5becb98617"}}
{"type":"message","id":"48fa74ab","parentId":"acf8fca8","timestamp":"2026-04-18T16:35:41.619Z","message":{"role":"toolResult","toolCallId":"call_mPI6M69l0p1TPBgrJvzLJzTL|fc_0fad9e409c19087f0169e3b2dbb7f4819a9fdc32c7c63e01e5","toolName":"read","content":[{"type":"text","text":"\"\"\"Real LLM adapter for position explainer using Ollama.\n\nIncludes retry with exponential backoff for robustness against slow models.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport re\nimport time\nfrom datetime import datetime\nfrom typing import Any\n\nimport requests\n\n\nOLLAMA_BASE = \"http://localhost:11434\"\nDEFAULT_MODEL = \"deepseek-r1:7b\"\nTIMEOUT_SECONDS = 120\nMAX_RETRIES = 3\nRETRY_BACKOFF = [30, 60, 90]  # seconds to wait between retries\n\n\n_sessions: dict[str, requests.Session] = {}\n\n\ndef _get_session(model: str) -> requests.Session:\n    if model not in _sessions:\n        _sessions[model] = requests.Session()\n    return _sessions[model]\n\n\nSYSTEM_PROMPT = \"\"\"You are a position explainer for an A-share stock portfolio.\n\nYou MUST follow these rules strictly:\n1. You are NOT a trading executor. NEVER output specific buy/sell/position size/stop-loss advice.\n2. You MUST only use information provided in the inputs. Do NOT invent information.\n3. Output ONLY valid JSON - no markdown, no commentary, no thinking tags.\n4. position_advice must be exactly one of: hold, add, reduce, exit\n5. Every item needs hold_case AND risk_case (at least 1 each).\n6. exit_triggers should be specific conditions, not generic warnings.\n7. If pnl is positive and market is risk_off, be more conservative about \"add\".\n8. If pnl is negative and market is risk_off, consider \"reduce\" or \"exit\".\n9. source_refs must only list inputs actually provided.\n\nOutput schema:\n{\n  \"date_tag\": \"YYYYMMDD\",\n  \"market_context\": \"risk_off|...\",\n  \"holding_count\": N,\n  \"portfolio_summary\": \"...\",\n  \"items\": [\n    {\n      \"ts_code\": \"000001.SZ\",\n      \"name\": \"...\",\n      \"qty\": N,\n      \"cost_price\": N,\n      \"current_price\": N,\n      \"unrealized_pnl_pct\": N,\n      \"hold_case\": [\"reason1\", \"reason2\"],\n      \"risk_case\": [\"risk1\", \"risk2\"],\n      \"exit_triggers\": [\"condition1\", \"condition2\"],\n      \"position_advice\": \"hold|add|reduce|exit\",\n      \"confidence_note\": \"...\",\n      \"source_refs\": [\"source1\"]\n    }\n  ]\n}\"\"\".strip()\n\n\ndef call_ollama(\n    *,\n    model: str,\n    system_prompt: str,\n    user_prompt: str,\n    timeout: int = TIMEOUT_SECONDS,\n) -> dict[str, Any]:\n    session = _get_session(model)\n    start = time.time()\n    response = session.post(\n        f\"{OLLAMA_BASE}/api/generate\",\n        json={\n            \"model\": model,\n            \"prompt\": f\"## System\\n{system_prompt}\\n\\n## User\\n{user_prompt}\",\n            \"stream\": False,\n            \"options\": {\n                \"temperature\": 0.2,\n                \"num_predict\": 3072,\n            },\n        },\n        timeout=(10, timeout),\n    )\n    response.raise_for_status()\n    data = response.json()\n    raw = data.get(\"response\", \"\").strip()\n    elapsed = time.time() - start\n    if not raw:\n        raise RuntimeError(f\"Ollama returned empty response after {elapsed:.1f}s.\")\n    # Strip think tags\n    raw = re.sub(r\"<think>.*?</think>\", \"\", raw, flags=re.DOTALL).strip()\n    # Extract JSON\n    json_text = _extract_json(raw)\n    return json.loads(json_text)\n\n\ndef _extract_json(text: str) -> str:\n    text = text.strip()\n    try:\n        json.loads(text)\n        return text\n    except json.JSONDecodeError:\n        pass\n    # Try markdown fence\n    m = re.search(r\"```(?:json)?\\s*(\\{.*\\})\\s*```\", text, re.DOTALL)\n    if m:\n        try:\n            json.loads(m.group(1))\n            return m.group(1)\n        except json.JSONDecodeError:\n            pass\n    # Find first { to last }\n    first = text.find(\"{\")\n    last = text.rfind(\"}\")\n    if first == -1 or last == -1 or last <= first:\n        raise RuntimeError(f\"No JSON found in: {text[:200]!r}\")\n    candidate = text[first:last + 1]\n    # Remove trailing commas\n    candidate = re.sub(r\",(\\s*[}\\]])\", r\"\\1\", candidate)\n    return candidate\n\n\ndef call_llm(\n    *,\n    system_prompt: str,\n    user_prompt: str,\n    model: str = DEFAULT_MODEL,\n    timeout: int = TIMEOUT_SECONDS,\n) -> dict[str, Any]:\n    \"\"\"Call Ollama with retry + exponential backoff.\"\"\"\n    last_exc = None\n    for attempt in range(MAX_RETRIES):\n        try:\n            return call_ollama(\n                model=model,\n                system_prompt=system_prompt,\n                user_prompt=user_prompt,\n                timeout=timeout,\n            )\n        except Exception as exc:\n            last_exc = exc\n            if attempt < MAX_RETRIES - 1:\n                wait = RETRY_BACKOFF[attempt]\n                print(f\"[position_explainer] attempt {attempt+1} failed ({exc}), retrying in {wait}s...\")\n                time.sleep(wait)\n            else:\n                print(f\"[position_explainer] all {MAX_RETRIES} attempts failed\")\n    raise RuntimeError(f\"Ollama call failed after {MAX_RETRIES} attempts: {last_exc}\") from last_exc\n\n\ndef build_user_prompt(payload: dict) -> str:\n    \"\"\"Build user prompt from payload.\"\"\"\n    holdings = payload.get(\"holdings\", [])\n    mc = payload.get(\"market_context\", {})\n    summary = payload.get(\"morning_summary\", \"\")\n    date_tag = payload.get(\"date_tag\", \"N/A\")\n\n    lines = []\n    lines.append(f\"Today's date: {date_tag}\")\n    lines.append(\"\")\n    lines.append(\"## Market Context\")\n    lines.append(f\"  label: {mc.get('label', 'unknown')}\")\n    if mc.get(\"market_bias\"):\n        lines.append(f\"  bias: {mc.get('market_bias')}\")\n    if mc.get(\"breadth_note\"):\n        lines.append(f\"  breadth: {mc.get('breadth_note')}\")\n    if mc.get(\"theme_note\"):\n        lines.append(f\"  theme: {mc.get('theme_note')}\")\n    lines.append(\"\")\n    lines.append(\"## Morning Report Summary\")\n    lines.append(summary[:1000] if summary else \"(no summary)\")\n    lines.append(\"\")\n    lines.append(f\"## Portfolio Holdings ({len(holdings)})\")\n    for h in holdings:\n        ts = h.get(\"ts_code\", \"\")\n        name = h.get(\"name\", \"\")\n        qty = h.get(\"qty\", \"\")\n        cost = h.get(\"cost_price\", \"\")\n        pnl = h.get(\"unrealized_pnl_pct\", \"\")\n        currency = h.get(\"currency\", \"CNY\")\n        lines.append(f\"\\n### {ts} {name}\")\n        lines.append(f\"  qty: {qty}, cost: {cost} {currency}\")\n        if pnl:\n            try:\n                lines.append(f\"  unrealized_pnl_pct: {float(pnl):+.2f}%\")\n            except (ValueError, TypeError):\n                lines.append(f\"  unrealized_pnl_pct: {pnl}\")\n    lines.append(\"\")\n    lines.append(\"Output: return ONLY valid JSON matching the schema above.\")\n\n    return \"\\n\".join(lines)\n\n\ndef run_explainer(payload: dict, model: str = DEFAULT_MODEL) -> dict:\n    from .schemas import PositionReport\n\n    raw = call_llm(\n        system_prompt=SYSTEM_PROMPT,\n        user_prompt=build_user_prompt(payload),\n        model=model,\n    )\n    raw[\"generated_at\"] = datetime.now().isoformat()\n    return PositionReport.model_validate(raw).model_dump(mode=\"json\")\n"}],"isError":false,"timestamp":1776530141609}}
{"type":"message","id":"51d9fecc","parentId":"48fa74ab","timestamp":"2026-04-18T16:35:41.631Z","message":{"role":"toolResult","toolCallId":"call_gBwIY0MENa8RmI9umFPYU5Yy|fc_0fad9e409c19087f0169e3b2dbbc14819aa7a9e8cbfed23cdc","toolName":"read","content":[{"type":"text","text":"\"\"\"MiniMax adapter for position_explainer.\n\nReuses the verified MiniMax API call from candidate_explainer/minimax_adapter.py.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport os\nimport re\nimport urllib.request\nimport urllib.error\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom .schemas import PositionReport\n\n\n_MINIMAX_API_KEY: str | None = None\n_MINIMAX_BASE_URL = \"https://api.minimaxi.com/anthropic/v1\"\n\n\ndef _get_minimax_api_key() -> str:\n    global _MINIMAX_API_KEY\n    if _MINIMAX_API_KEY is None:\n        openclaw_path = Path.home() / \".openclaw\" / \"openclaw.json\"\n        if openclaw_path.exists():\n            try:\n                data = json.loads(openclaw_path.read_text(encoding=\"utf-8\"))\n                _MINIMAX_API_KEY = (\n                    data.get(\"models\", {})\n                    .get(\"providers\", {})\n                    .get(\"custom-proxy\", {})\n                    .get(\"apiKey\", \"\")\n                )\n            except Exception:\n                pass\n        if not _MINIMAX_API_KEY:\n            secrets_path = Path.home() / \".openclaw\" / \"secrets\" / \"model_api_keys.json\"\n            if secrets_path.exists():\n                try:\n                    data = json.loads(secrets_path.read_text(encoding=\"utf-8\"))\n                    _MINIMAX_API_KEY = (\n                        data.get(\"providers\", {})\n                        .get(\"minimax-portal\", {})\n                        .get(\"apiKey\", \"\")\n                    )\n                except Exception:\n                    pass\n        if not _MINIMAX_API_KEY:\n            _MINIMAX_API_KEY = os.getenv(\"MINIMAX_API_KEY\", \"\")\n    if not _MINIMAX_API_KEY:\n        raise RuntimeError(\n            \"MiniMax API key not found. \"\n            \"Set MINIMAX_API_KEY or populate ~/.openclaw/openclaw.json custom-proxy.apiKey\"\n        )\n    return _MINIMAX_API_KEY\n\n\nclass MiniMaxError(Exception):\n    \"\"\"Raised when MiniMax API call fails.\"\"\"\n\n\ndef call_minimax(\n    *,\n    system_prompt: str,\n    user_payload: str,\n    model: str = \"MiniMax-M2.7\",\n    timeout: int = 120,\n) -> dict[str, Any]:\n    \"\"\"Call MiniMax Anthropic-compatible API with structured JSON output.\"\"\"\n    api_key = _get_minimax_api_key()\n    url = f\"{_MINIMAX_BASE_URL}/messages\"\n    headers = {\n        \"Authorization\": f\"Bearer {api_key}\",\n        \"Content-Type\": \"application/json\",\n        \"anthropic-version\": \"2023-06-01\",\n        \"anthropic-dangerous-direct-browser-access\": \"true\",\n    }\n    body = {\n        \"model\": model,\n        \"max_tokens\": 32000,\n        \"system\": system_prompt,\n        \"messages\": [{\"role\": \"user\", \"content\": user_payload}],\n    }\n\n    req = urllib.request.Request(\n        url,\n        data=json.dumps(body).encode(\"utf-8\"),\n        headers=headers,\n        method=\"POST\",\n    )\n    try:\n        with urllib.request.urlopen(req, timeout=timeout) as resp:\n            raw = resp.read().decode(\"utf-8\")\n    except urllib.error.HTTPError as exc:\n        raise MiniMaxError(f\"HTTP {exc.code}: {exc.read().decode('utf-8')}\") from exc\n    except urllib.error.URLError as exc:\n        raise MiniMaxError(f\"URL error (timeout={timeout}s): {exc.reason}\") from exc\n\n    try:\n        result = json.loads(raw)\n    except json.JSONDecodeError as exc:\n        raise MiniMaxError(f\"Invalid JSON from MiniMax: {exc}\") from exc\n\n    # Collect all text blocks (skip thinking blocks)\n    content = result.get(\"content\", [])\n    text_parts: list[str] = []\n    if isinstance(content, list):\n        for block in content:\n            if isinstance(block, dict) and block.get(\"type\") == \"text\":\n                text_parts.append(block.get(\"text\", \"\"))\n\n    text = \"\".join(text_parts)\n    if not text.strip():\n        raise MiniMaxError(f\"Empty response from MiniMax (content blocks: {content})\")\n\n    # Parse JSON (strict=False allows control chars like \\n in strings)\n    def _try_parse(s: str):\n        try:\n            return json.loads(s, strict=False)\n        except json.JSONDecodeError:\n            return None\n\n    parsed = _try_parse(text)\n    if parsed is not None:\n        return parsed\n    # Try markdown code block\n    m = re.search(r\"```(?:json)?\\s*(\\{.*?\\})\\s*```\", text, re.DOTALL)\n    if m:\n        parsed = _try_parse(m.group(1))\n        if parsed is not None:\n            return parsed\n    # Try to find JSON object\n    if text.strip().startswith(\"{\"):\n        m2 = re.search(r\"\\{[\\s\\S]*\\}\", text)\n        if m2:\n            parsed = _try_parse(m2.group(0))\n            if parsed is not None:\n                return parsed\n    raise MiniMaxError(f\"Could not parse JSON from response: {text[:500]}\")\n\n\nSYSTEM_PROMPT = \"\"\"你是一个持仓风险观察引擎（position_explainer），专为A股交易研究副驾驶设计。\n\n## 核心约束\n1. 你只做持仓风险解释，**不是交易执行器**，禁止输出具体买卖价格或仓位指令。\n2. 你的结论必须基于输入的持仓数据、市场环境、浮亏浮盈，不得虚构。\n3. 输出格式：严格JSON，包含所有必填字段，不得输出非JSON内容。\n4. 如果数据不足无法判断，明确标注，不得虚构持仓数据。\n\n## 输出Schema（字段名必须严格遵循）\n{\n  \"date_tag\": \"YYYYMMDD\",\n  \"market_context\": \"risk_on|risk_off|neutral|halt\",\n  \"holding_count\": N,\n  \"items\": [\n    {\n      \"ts_code\": \"000000.SZ\",\n      \"name\": \"股票名称\",\n      \"direction\": \"long\",\n      \"qty\": N,\n      \"cost_price\": N,\n      \"current_price\": N,\n      \"unrealized_pnl_pct\": N,\n      \"hold_case\": [\"继续持有的利好因素，最多3条\"],\n      \"risk_case\": [\"风险因素，最多3条\"],\n      \"exit_triggers\": [\"退出触发条件，最多2条\"],\n      \"position_advice\": \"hold|add|reduce|exit\",\n      \"confidence_note\": \"置信度说明（一句话）\",\n      \"source_refs\": [\"参考来源\"]\n    }\n  ]\n}\n\n## 关键要求\n- 每只持仓必须同时输出 hold_case（至少1条）和 risk_case（至少1条），不能只写一方\n- hold_case 描述的是\"继续持有的理由\"，比如：行业龙头地位、估值优势、业绩拐点等\n- risk_case 描述的是\"风险因素\"，比如：浮亏幅度、行业景气下行、竞争恶化等\n- position_advice 必须从 hold|add|reduce|exit 中选一个\n- 不要在 hold_case 里重复 risk_case 的内容\n\"\"\"\n\n\ndef _resolve_model(model: str) -> str:\n    mapping = {\n        \"minimax-m2.7\": \"MiniMax-M2.7\",\n        \"minimax-m2.5\": \"MiniMax-M2.5\",\n        \"minimax-m2.5-highspeed\": \"MiniMax-M2.5-highspeed\",\n        \"minimax-m2.5-lightning\": \"MiniMax-M2.5-Lightning\",\n        \"minimax-m2.1\": \"MiniMax-M2.1\",\n    }\n    return mapping.get(model.lower(), \"MiniMax-M2.7\")\n\n\ndef build_user_prompt(payload: dict) -> str:\n    holdings = payload.get(\"holdings\", [])\n    mc = payload.get(\"market_context\", {})\n    summary = payload.get(\"morning_summary\", \"\")\n    date_tag = payload.get(\"date_tag\", \"N/A\")\n\n    lines = []\n    lines.append(f\"Today's date: {date_tag}\")\n    lines.append(\"\")\n    lines.append(\"## Market Context\")\n    lines.append(f\"  label: {mc.get('label', 'unknown')}\")\n    if mc.get(\"market_bias\"):\n        lines.append(f\"  bias: {mc.get('market_bias')}\")\n    if mc.get(\"breadth_note\"):\n        lines.append(f\"  breadth: {mc.get('breadth_note')}\")\n    if mc.get(\"theme_note\"):\n        lines.append(f\"  theme: {mc.get('theme_note')}\")\n    lines.append(\"\")\n    lines.append(\"## Morning Report Summary\")\n    lines.append(summary[:1000] if summary else \"(no summary)\")\n    lines.append(\"\")\n    lines.append(f\"## Portfolio Holdings ({len(holdings)})\")\n    for h in holdings:\n        ts = h.get(\"ts_code\", \"\")\n        name = h.get(\"name\", \"\")\n        qty = h.get(\"qty\", \"\")\n        cost = h.get(\"cost_price\", \"\")\n        pnl = h.get(\"unrealized_pnl_pct\", \"\")\n        lines.append(f\"\\n### {ts} {name}\")\n        lines.append(f\"  qty: {qty}, cost: {cost}\")\n        if pnl:\n            try:\n                lines.append(f\"  unrealized_pnl_pct: {float(pnl):+.2f}%\")\n            except (ValueError, TypeError):\n                lines.append(f\"  unrealized_pnl_pct: {pnl}\")\n    lines.append(\"\")\n    lines.append(\"Output requirements:\")\n    lines.append(\"- Return ONLY valid JSON, no markdown or commentary\")\n    lines.append(\"- Every item must have: hold_case (at least 1), risk_case (at least 1), exit_triggers\")\n    lines.append(\"- position_advice must be: hold | add | reduce | exit\")\n    lines.append(\"- Do not invent information not in the inputs above\")\n    lines.append(\"- hold_case = reasons to keep holding; risk_case = risk factors; exit_triggers = conditions to sell\")\n\n    return \"\\n\".join(lines)\n\n\ndef validate_output(output: dict) -> tuple[bool, str | None]:\n    \"\"\"Normalize and validate MiniMax output to match PositionReport schema.\n\n    Steps:\n      1. Normalize numeric fields (strip %, handle N/A)\n      2. Map output field names → schema field names\n      3. Validate required fields exist and have correct types\n    \"\"\"\n    if not isinstance(output, dict):\n        return False, \"output is not a dict\"\n    if not isinstance(output.get(\"items\"), list):\n        return False, \"items is not a list\"\n\n    for item in output[\"items\"]:\n        # ---- Step 1: Normalize numeric fields ----\n        numeric_fields = [\n            \"current_price\", \"unrealized_pnl_pct\", \"unrealized_pnl\",\n            \"position_value\", \"qty\", \"cost_price\",\n        ]\n        for field in numeric_fields:\n            val = item.get(field)\n            if not isinstance(val, str):\n                continue\n            stripped = val.strip()\n            if stripped.upper() in (\"N/A\", \"NA\", \"NULL\", \"\"):\n                item[field] = None\n                continue\n            if stripped.endswith(\"%\"):\n                stripped = stripped[:-1]\n            try:\n                item[field] = float(stripped)\n            except ValueError:\n                item[field] = None\n\n        # ---- Step 2: Field name mapping ----\n        # bull_case / bear_case / risk_flags → PositionAdviceItem fields\n        if \"bull_case\" in item and \"hold_case\" not in item:\n            item[\"hold_case\"] = item.pop(\"bull_case\")\n        if \"bear_case\" in item and \"risk_case\" not in item:\n            item[\"risk_case\"] = item.pop(\"bear_case\")\n        if \"watch_triggers\" in item and \"exit_triggers\" not in item:\n            item[\"exit_triggers\"] = item.pop(\"watch_triggers\")\n        if \"risk_factors\" in item:\n            item.setdefault(\"risk_case\", item.pop(\"risk_factors\"))\n        if \"action_reason\" in item:\n            item.setdefault(\"confidence_note\", item.pop(\"action_reason\"))\n        # action → position_advice\n        action_aliases = {\n            \"hold\": \"hold\", \"keep\": \"hold\", \"keep_watch\": \"hold\",\n            \"add\": \"add\",\n            \"reduce\": \"reduce\",\n            \"exit\": \"exit\", \"liquidate\": \"exit\", \"watch\": \"hold\", \"defer\": \"hold\",\n        }\n        raw_action = item.get(\"action\", item.get(\"position_advice\", \"hold\"))\n        item[\"position_advice\"] = action_aliases.get(raw_action, \"hold\")\n        item.pop(\"action\", None)\n        # Defaults\n        item.setdefault(\"direction\", \"long\")\n        item.setdefault(\"source_refs\", [])\n        for lf in (\"hold_case\", \"risk_case\", \"exit_triggers\", \"source_refs\"):\n            if not isinstance(item.get(lf), list):\n                item[lf] = []\n        if \"confidence_note\" not in item:\n            item[\"confidence_note\"] = str(item.pop(\"confidence\", \"\"))\n\n    # ---- Step 3: Validate required fields ----\n    for field in [\"date_tag\", \"market_context\", \"holding_count\", \"items\"]:\n        if field not in output:\n            return False, f\"missing field: {field}\"\n    allowed_advice = {\"hold\", \"add\", \"reduce\", \"exit\"}\n    for i, item in enumerate(output[\"items\"]):\n        for field in [\"ts_code\", \"name\", \"position_advice\"]:\n            if field not in item:\n                return False, f\"item[{i}] missing: {field}\"\n        if item.get(\"position_advice\") not in allowed_advice:\n            return False, f\"item[{i}] invalid position_advice: {item.get('position_advice')}\"\n\n    return True, None\n\n[35 more lines in file. Use offset=321 to continue.]"}],"isError":false,"timestamp":1776530141619}}
{"type":"message","id":"ac360628","parentId":"51d9fecc","timestamp":"2026-04-18T16:35:41.642Z","message":{"role":"toolResult","toolCallId":"call_U7PUCNmuVjqvYOsphcrYg51Y|fc_0fad9e409c19087f0169e3b2dbbc20819aa198b0dbbc767606","toolName":"read","content":[{"type":"text","text":"\"\"\"Fake explainer for position overlay (development/testing).\"\"\"\n\nfrom __future__ import annotations\n\nfrom datetime import datetime\nfrom typing import Any\n\nfrom .schemas import BlockedStatus, PositionAdviceItem, PositionReport\n\n\ndef run_explainer(payload: dict, model: str = \"fake\") -> dict:  # noqa: ARG001\n    \"\"\"Return a fake but structurally valid position report.\"\"\"\n    holdings = payload.get(\"holdings\", [])\n    mc = payload.get(\"market_context\", {})\n    market_label = mc.get(\"label\", \"neutral\")\n\n    items = []\n    for h in holdings:\n        ts_code = h.get(\"ts_code\", \"UNKNOWN\")\n        name = h.get(\"name\", ts_code)\n        pnl_pct = h.get(\"unrealized_pnl_pct\")\n        cost = h.get(\"cost_price\", \"N/A\")\n        qty = h.get(\"qty\", \"N/A\")\n\n        if pnl_pct is not None:\n            try:\n                pnl_f = float(pnl_pct)\n            except (ValueError, TypeError):\n                pnl_f = 0.0\n        else:\n            pnl_f = 0.0\n\n        if pnl_f > 10:\n            bias = \"hold\"\n            hold_rationale = [\n                f\"浮盈 {pnl_f:.1f}%，走势强于大盘\",\n                f\"成本 {cost}，当前市场环境（{market_label}）支持持仓\",\n            ]\n            risk = [\"个股独立风险\", \"板块轮动风险\"]\n            exit_trig = [f\"浮盈回落至 {max(0, pnl_f - 10):.1f}% 区域\", \"市场进入 risk_off 确认\"]\n        elif pnl_f > 0:\n            bias = \"hold\"\n            hold_rationale = [\n                f\"浮盈 {pnl_f:.1f}%，成本控制良好\",\n            ]\n            risk = [\"利润回吐风险\", \"个股波动风险\"]\n            exit_trig = [f\"浮盈回落至 0%\", \"出现放量破位\"]\n        else:\n            bias = \"reduce\" if pnl_f < -5 else \"hold\"\n            hold_rationale = [\n                f\"浮亏 {pnl_f:.1f}%，需关注成本支撑\",\n            ]\n            risk = [\"亏损扩大风险\", \"市场继续下行风险\"]\n            exit_trig = [\"亏损超过 -15%\", \"成本下方放量下跌确认\"]\n\n        items.append(\n            PositionAdviceItem(\n                ts_code=ts_code,\n                name=name,\n                qty=float(qty) if qty not in (None, \"N/A\", \"\") else None,\n                cost_price=float(cost) if cost not in (None, \"N/A\", \"\") else None,\n                unrealized_pnl_pct=pnl_f,\n                hold_case=hold_rationale,\n                risk_case=risk,\n                exit_triggers=exit_trig,\n                position_advice=bias,\n                confidence_note=\"fake_explainer_v1\",\n                source_refs=[\"holdings\", \"market_context\"],\n            )\n        )\n\n    report = PositionReport(\n        date_tag=payload.get(\"date_tag\", \"N/A\"),\n        generated_at=datetime.now(),\n        market_context=market_label,\n        holding_count=len(items),\n        items=items,\n        portfolio_summary=f\"持仓 {len(items)} 只，参考市场状态：{market_label}\",\n    )\n    return report.model_dump(mode=\"json\")\n"}],"isError":false,"timestamp":1776530141631}}
