)\n    except Exception as exc:\n","newText":"        result = runner(payload, model=args.model)\n\n        # Merge freshest price metadata from holdings payload back into result items,\n        # so downstream markdown/digest always shows quote provenance even if the model omits it.\n        holdings_by_code = {\n            str(h.get(\"ts_code\") or \"\").strip().upper(): h\n            for h in payload.get(\"holdings\", [])\n        }\n        for item in result.get(\"items\", []):\n            ts_code = str(item.get(\"ts_code\") or \"\").strip().upper()\n            src = holdings_by_code.get(ts_code, {})\n            for field in (\"current_price\", \"price_source\", \"price_timestamp\", \"price_is_stale\"):\n                if item.get(field) in (None, \"\") and src.get(field) not in (None, \"\"):\n                    item[field] = src.get(field)\n    except Exception as exc:\n"}]},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/main.py\",\"edits\":[{\"oldText\":\"DEFAULT_INPUT_PATTERNS = {\\n    \\\"holdings\\\": \\\"selected_real_positions_{date}.csv\\\",\\n    \\\"market_context\\\": \\\"breadth_aggressive_paper_{date}.json\\\",\\n    \\\"morning_summary\\\": \\\"daily_quant_analysis_skill_{date}.md\\\",\\n}\\n\",\"newText\":\"DEFAULT_INPUT_PATTERNS = {\\n    \\\"holdings\\\": \\\"selected_real_positions_{date}.csv\\\",\\n    \\\"holdings_enriched\\\": \\\"selected_real_positions_{date}_enriched.csv\\\",\\n    \\\"market_context\\\": \\\"breadth_aggressive_paper_{date}.json\\\",\\n    \\\"morning_summary\\\": \\\"daily_quant_analysis_skill_{date}.md\\\",\\n}\\n\"},{\"oldText\":\"def resolve_paths(date_tag: str) -> dict:\\n    return {\\n        \\\"holdings\\\": REPORTS_DIR / DEFAULT_INPUT_PATTERNS[\\\"holdings\\\"].format(date=date_tag),\\n        \\\"market_context\\\": REPORTS_DIR / DEFAULT_INPUT_PATTERNS[\\\"market_context\\\"].format(date=date_tag),\\n        \\\"m