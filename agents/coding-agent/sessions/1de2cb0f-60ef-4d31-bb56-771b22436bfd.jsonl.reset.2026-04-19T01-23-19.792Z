],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":120461,"output":234,"cacheRead":0,"cacheWrite":0,"totalTokens":120695,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776525322353,"responseId":"resp_0fad9e409c19087f0169e3a00c95a8819a9ceb51d7763100ce"}}
{"type":"message","id":"08c1e1e9","parentId":"affe5705","timestamp":"2026-04-18T15:15:34.185Z","message":{"role":"toolResult","toolCallId":"call_TVursEpdP1UcA20iWfbRaG8b|fc_0fad9e409c19087f0169e3a0145954819a8ef81af21981bb58","toolName":"read","content":[{"type":"text","text":"\ndef prepare_performance_frame(curve_df: pd.DataFrame, benchmark_df: pd.DataFrame, initial_cash: float) -> pd.DataFrame:\n    if curve_df.empty or initial_cash <= 0:\n        return pd.DataFrame()\n\n    out = curve_df.copy()\n    out[\"date\"] = pd.to_datetime(out.get(\"date\"), errors=\"coerce\")\n    out[\"nav\"] = pd.to_numeric(out.get(\"nav\"), errors=\"coerce\")\n    out[\"cash\"] = pd.to_numeric(out.get(\"cash\"), errors=\"coerce\")\n    out[\"market_value\"] = pd.to_numeric(out.get(\"market_value\"), errors=\"coerce\")\n    out = out.dropna(subset=[\"date\", \"nav\"]).sort_values(\"date\").reset_index(drop=True)\n    if out.empty:\n        return out\n\n    out[\"strategy_equity\"] = out[\"nav\"] / float(initial_cash)\n    out[\"strategy_ret\"] = out[\"nav\"].pct_change()\n    first_idx = out.index[0]\n    out.loc[first_idx, \"strategy_ret\"] = out.loc[first_idx, \"nav\"] / float(initial_cash) - 1.0\n\n    if benchmark_df.empty:\n        out[\"benchmark_close\"] = np.nan\n        out[\"benchmark_ret\"] = 0.0\n    else:\n        bench = benchmark_df.copy()\n        bench[\"date\"] = pd.to_datetime(bench[\"date\"], errors=\"coerce\")\n        bench = bench.dropna(subset=[\"date\"]).sort_values(\"date\").set_index(\"date\")\n        aligned = bench.reindex(out[\"date\"])\n        out[\"benchmark_close\"] = pd.to_numeric(aligned.get(\"close\"), errors=\"coerce\").values\n        out[\"benchmark_ret\"] = pd.to_numeric(aligned.get(\"benchmark_ret\"), errors=\"coerce\").fillna(0.0).values\n\n    out[\"benchmark_equity\"] = (1.0 + out[\"benchmark_ret\"].fillna(0.0)).cumprod()\n    out[\"excess_ret\"] = out[\"strategy_ret\"].fillna(0.0) - out[\"benchmark_ret\"].fillna(0.0)\n    out[\"excess_equity\"] = (1.0 + out[\"excess_ret\"]).cumprod()\n    out[\"strategy_drawdown_pct\"] = (out[\"strategy_equity\"] / out[\"strategy_equity\"].cummax() - 1.0) * 100.0\n    out[\"excess_drawdown_pct\"] = (out[\"excess_equity\"] / out[\"excess_equity\"].cummax() - 1.0) * 100.0\n    out[\"strategy_ret_pct\"] = out[\"strategy_ret\"] * 100.0\n    out[\"benchmark_ret_pct\"] = out[\"benchmark_ret\"] * 100.0\n    out[\"excess_ret_pct\"] = out[\"excess_ret\"] * 100.0\n    out[\"date_str\"] = out[\"date\"].dt.strftime(\"%Y-%m-%d\")\n    return out\n\n\ndef load_all_trade_rows(\n    report_dir: Path,\n    profile_slug: str = \"\",\n    end_date_tag: str = \"\",\n    *,\n    include_end_date: bool = True,\n) -> pd.DataFrame:\n    frames: list[pd.DataFrame] = []\n    cutoff_date = parse_date_tag(end_date_tag)\n    for path in sorted(report_dir.glob(journal_glob(profile_slug))):\n        df = load_csv(path)\n        if df.empty:\n            continue\n        frame = df.copy().reset_index(drop=True)\n        frame[\"source_file\"] = path.name\n        frame[\"date\"] = pd.to_datetime(frame.get(\"date\"), errors=\"coerce\").dt.strftime(\"%Y-%m-%d\")\n        frame[\"action\"] = safe_text_series(frame, \"action\").map(normalize_side)\n        frame[\"ts_code\"] = safe_text_series(frame, \"ts_code\").str.strip().str.upper()\n        frame[\"shares\"] = pd.to_numeric(frame.get(\"shares\", pd.Series(0, index=frame.index)), errors=\"coerce\").fillna(0).astype(int)\n        frame[\"price\"] = pd.to_numeric(frame.get(\"price\", pd.Series(np.nan, index=frame.index)), errors=\"coerce\")\n        frame[\"fee\"] = pd.to_numeric(frame.get(\"fee\", pd.Series(0.0, index=frame.index)), errors=\"coerce\").fillna(0.0)\n        frame[\"slippage\"] = pd.to_numeric(frame.get(\"slippage\", pd.Series(0.0, index=frame.index)), errors=\"coerce\").fillna(0.0)\n        frame[\"signal_reason\"] = safe_text_series(frame, \"signal_reason\").str.strip()\n        frame[\"risk_reason\"] = safe_text_series(frame, \"risk_reason\").str.strip()\n        frame[\"notes\"] = safe_text_series(frame, \"notes\").str.strip()\n        frame[\"exit_type\"] = safe_text_series(frame, \"exit_type\").str.strip().str.lower()\n        frame[\"exit_reason\"] = safe_text_series(frame, \"exit_reason\").str.strip()\n        derived_exit = frame.apply(\n            lambda row: pd.Series(\n                derive_exit_metadata(\n                    side=row.get(\"action\", \"\"),\n                    signal_reason=row.get(\"signal_reason\", \"\"),\n                    notes=row.get(\"notes\", \"\"),\n                    exit_type=row.get(\"exit_type\", \"\"),\n                    exit_reason=row.get(\"exit_reason\", \"\"),\n                ),\n                index=[\"exit_type\", \"exit_reason\"],\n            ),\n            axis=1,\n        )\n        frame[\"exit_type\"] = derived_exit[\"exit_type\"]\n        frame[\"exit_reason\"] = derived_exit[\"exit_reason\"]\n        frame[\"amount\"] = frame[\"price\"].fillna(0.0) * frame[\"shares\"].fillna(0)\n        frames.append(frame)\n    if not frames:\n        return pd.DataFrame(\n            columns=[\n                \"date\",\n                \"action\",\n                \"ts_code\",\n                \"price\",\n                \"shares\",\n                \"fee\",\n                \"slippage\",\n                \"amount\",\n                \"signal_reason\",\n                \"risk_reason\",\n                \"exit_type\",\n                \"exit_reason\",\n                \"notes\",\n                \"source_file\",\n            ]\n        )\n    trades = pd.concat(frames, ignore_index=True)\n    trades[\"date_tag\"] = trades[\"date\"].map(parse_date_tag)\n    if cutoff_date > 0:\n        if include_end_date:\n            trades = trades[(trades[\"date_tag\"] > 0) & (trades[\"date_tag\"] <= cutoff_date)].copy()\n        else:\n            trades = trades[(trades[\"date_tag\"] > 0) & (trades[\"date_tag\"] < cutoff_date)].copy()\n    trades[\"sort_date\"] = pd.to_datetime(trades[\"date\"], errors=\"coerce\")\n    trades[\"_row_no\"] = np.arange(len(trades))\n    trades = trades.sort_values([\"sort_date\", \"_row_no\"]).reset_index(drop=True)\n    return trades.drop(columns=[\"sort_date\", \"_row_no\", \"date_tag\"], errors=\"ignore\")\n\n\ndef compute_trade_statistics(trades: pd.DataFrame) -> dict[str, Any]:\n    if trades.empty:\n        return {\n            \"win_rate_pct\": np.nan,\n            \"profit_loss_ratio\": np.nan,\n            \"win_count\": 0,\n            \"loss_count\": 0,\n            \"closed_trade_count\": 0,\n            \"journal_trade_count\": 0,\n            \"buy_trade_count\": 0,\n            \"sell_trade_count\": 0,\n            \"realized_pnl_total\": 0.0,\n        }\n\n    holdings: dict[str, dict[str, float]] = {}\n    realized: list[float] = []\n    ordered = trades.copy()\n    ordered[\"price\"] = pd.to_numeric(ordered.get(\"price\"), errors=\"coerce\").fillna(0.0)\n    ordered[\"fee\"] = pd.to_numeric(ordered.get(\"fee\"), errors=\"coerce\").fillna(0.0)\n    ordered[\"shares\"] = pd.to_numeric(ordered.get(\"shares\"), errors=\"coerce\").fillna(0).astype(int)\n    valid_mask = (\n        ordered.get(\"ts_code\", pd.Series(\"\", index=ordered.index)).astype(str).str.strip().ne(\"\")\n        & ordered.get(\"action\", pd.Series(\"\", index=ordered.index)).astype(str).str.upper().isin([\"BUY\", \"SELL\"])\n        & (ordered[\"shares\"].abs() > 0)\n        & (ordered[\"price\"] > 0)\n    )\n    journal_trade_count = int(valid_mask.sum())\n    buy_trade_count = int((valid_mask & ordered[\"action\"].astype(str).str.upper().eq(\"BUY\")).sum())\n    sell_trade_count = int((valid_mask & ordered[\"action\"].astype(str).str.upper().eq(\"SELL\")).sum())\n\n    for _, row in ordered.iterrows():\n        symbol = str(row.get(\"ts_code\", \"\") or \"\").strip().upper()\n        side = str(row.get(\"action\", \"\") or \"\").strip().upper()\n        qty = abs(int(row.get(\"shares\", 0) or 0))\n        price = float(row.get(\"price\", 0.0) or 0.0)\n        fee = float(row.get(\"fee\", 0.0) or 0.0)\n        if not symbol or side not in {\"BUY\", \"SELL\"} or qty <= 0 or price <= 0:\n            continue\n\n        state = holdings.get(symbol, {\"qty\": 0, \"avg_cost\": 0.0})\n        if side == \"BUY\":\n            total_cost = state[\"qty\"] * state[\"avg_cost\"] + qty * price + fee\n            new_qty = state[\"qty\"] + qty\n            state[\"qty\"] = new_qty\n            state[\"avg_cost\"] = total_cost / new_qty if new_qty > 0 else 0.0\n            holdings[symbol] = state\n            continue\n\n        sell_qty = min(qty, int(state.get(\"qty\", 0)))\n        if sell_qty <= 0:\n            continue\n        avg_cost = float(state.get(\"avg_cost\", 0.0))\n        pnl = (price - avg_cost) * sell_qty - fee\n        realized.append(float(pnl))\n        state[\"qty\"] -= sell_qty\n        if state[\"qty\"] <= 0:\n            holdings.pop(symbol, None)\n        else:\n            holdings[symbol] = state\n\n    wins = [x for x in realized if x > 0]\n    losses = [x for x in realized if x < 0]\n    closed = len(realized)\n    win_rate = (len(wins) / closed * 100.0) if closed > 0 else np.nan\n    profit_loss = (float(np.mean(wins)) / abs(float(np.mean(losses)))) if wins and losses else np.nan\n    return {\n        \"win_rate_pct\": round(win_rate, 2) if np.isfinite(win_rate) else np.nan,\n        \"profit_loss_ratio\": round(profit_loss, 3) if np.isfinite(profit_loss) else np.nan,\n        \"win_count\": int(len(wins)),\n        \"loss_count\": int(len(losses)),\n        \"closed_trade_count\": int(closed),\n        \"journal_trade_count\": journal_trade_count,\n        \"buy_trade_count\": buy_trade_count,\n        \"sell_trade_count\": sell_trade_count,\n        \"realized_pnl_total\": round(float(np.sum(realized)), 2) if realized else 0.0,\n    }\n\n\ndef compute_performance_metrics(perf: pd.DataFrame, trade_stats: dict[str, Any], benchmark_name: str) -> dict[str, Any]:\n    if perf.empty:\n        return {\n            \"strategy_total_return_pct\": np.nan,\n            \"strategy_annual_return_pct\": np.nan,\n            \"benchmark_total_return_pct\": np.nan,\n            \"alpha_pct\": np.nan,\n            \"beta\": np.nan,\n            \"sharpe\": np.nan,\n            \"sortino\": np.nan,\n            \"max_drawdown_pct\": np.nan,\n            \"max_drawdown_interval\": \"-\",\n            \"daily_avg_excess_return_pct\": np.nan,\n            \"excess_max_drawdown_pct\": np.nan,\n            \"excess_sharpe\": np.nan,\n            \"daily_win_rate_pct\": np.nan,\n            \"positive_days\": 0,\n            \"negative_days\": 0,\n            \"information_ratio\": np.nan,\n            \"strategy_vol_pct\": np.nan,\n            \"benchmark_vol_pct\": np.nan,\n            \"trade_win_rate_pct\": trade_stats.get(\"win_rate_pct\"),\n            \"profit_loss_ratio\": trade_stats.get(\"profit_loss_ratio\"),\n            \"win_count\": trade_stats.get(\"win_count\", 0),\n            \"loss_count\": trade_stats.get(\"loss_count\", 0),\n            \"trade_count\": trade_stats.get(\"closed_trade_count\", 0),\n            \"closed_trade_count\": trade_stats.get(\"closed_trade_count\", 0),\n            \"journal_trade_count\": trade_stats.get(\"journal_trade_count\", 0),\n            \"buy_trade_count\": trade_stats.get(\"buy_trade_count\", 0),\n            \"sell_trade_count\": trade_stats.get(\"sell_trade_count\", 0),\n            \"benchmark_name\": benchmark_name,\n        }\n\n    strategy_ret = perf[\"strategy_ret\"].astype(float)\n    benchmark_ret = perf[\"benchmark_ret\"].astype(float)\n    excess_ret = perf[\"excess_ret\"].astype(float)\n\n    strategy_equity = perf[\"strategy_equity\"].astype(float)\n    benchmark_equity = perf[\"benchmark_equity\"].astype(float)\n    excess_equity = perf[\"excess_equity\"].astype(float)\n\n    strategy_total_return = (float(strategy_equity.iloc[-1]) - 1.0) * 100.0\n    benchmark_total_return = (float(benchmark_equity.iloc[-1]) - 1.0) * 100.0\n    strategy_annual_return = annualized_return(strategy_ret) * 100.0 if np.isfinite(annualized_return(strategy_ret)) else np.nan\n    strategy_vol = annualized_vol(strategy_ret) * 100.0 if np.isfinite(annualized_vol(strategy_ret)) else np.nan\n    benchmark_vol = annualized_vol(benchmark_ret) * 100.0 if np.isfinite(annualized_vol(benchmark_ret)) else np.nan\n    sharpe = sharpe_ratio(strategy_ret)\n    sortino = sortino_ratio(strategy_ret)\n    excess_sharpe = sharpe_ratio(excess_ret)\n    info_ratio_value = information_ratio(excess_ret)\n    alpha_ann, beta_value = alpha_beta(strategy_ret, benchmark_ret)\n\n    anchor_label = f\"{str(perf['date_str'].iloc[0])} 开盘\"\n    strategy_equity_anchored = pd.concat(\n        [\n            pd.Series([1.0]),\n            strategy_equity.reset_index(drop=True),\n        ],\n        ignore_index=True,\n    )\n    excess_equity_anchored = pd.concat(\n        [\n            pd.Series([1.0]),\n            excess_equity.reset_index(drop=True),\n\n[808 more lines in file. Use offset=620 to continue.]"}],"isError":false,"timestamp":1776525334157}}
