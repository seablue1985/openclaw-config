\n\ndef profile_payload(profile_slug: str, date_tag: str) -> dict[str, Any]:\n","newText":"def fmt_ratio_pct(value: Any, digits: int = 2) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{to_float(value) * 100.0:.{digits}f}\"\n\n\ndef format_realtime_meta(row: dict[str, Any]) -> str:\n    source = str(row.get(\"ai_realtime_source\") or \"-\").strip() or \"-\"\n    confirmed_raw = str(row.get(\"ai_realtime_confirmed\") or \"\").strip().lower()\n    freshness = \"FRESH\" if confirmed_raw in {\"1\", \"true\", \"yes\", \"y\"} else \"UNCERTAIN\"\n    return f\"{source}/{freshness}\"\n\n\ndef profile_payload(profile_slug: str, date_tag: str) -> dict[str, Any]:\n"},{"oldText":"    lines.append(\n        f\"- 实时源分布：`{realtime_source_breakdown_total if realtime_source_breakdown_total else {}}` / \"\n        f\"分时MA来源：`{intraday_ma_source_breakdown_total if intraday_ma_source_breakdown_total else {}}`\"\n    )\n","newText":"    lines.append(\n        f\"- 实时源分布：`{realtime_source_breakdown_total if realtime_source_breakdown_total else {}}` / \"\n        f\"分时MA来源：`{intraday_ma_source_breakdown_total if intraday_ma_source_breakdown_total else {}}`\"\n    )\n    lines.append(\"- 表格中的‘实时源’已附带 freshness 标记：`FRESH=已确认的实时价`，`UNCERTAIN=仅有来源但未确认/不保证是盘中新鲜价`\")\n"},{"oldText":"            str(row.get(\"ai_realtime_source\") or \"-\"),\n","newText":"            format_realtime_meta(row),\n"},{"oldText":"            str(row.get(\"ai_realtime_source\") or \"-\"),\n","newText":"            format_realtime_meta(row),\n"},{"oldText":"            [\"排名\", \"代码\", \"名称\", \"score\", \"实时源\", \"实时价\", \"AI建议\", \"执行状态\", \"来源策略\"],\n","newText":"            [\"排名\", \"代码\", \"名称\", \"score\", \"实时源/新鲜度\", \"实时价\", \"AI建议\", \"执行状态\", \"来源策略\"],\n"},{"oldText":"            [\"排名\", \"代码\", \"名称\", \"综合分\", \"实时源\", \"实时价\", \"AI建议\", \"当前状态\", \"来源策略\"],\n","newText":"            [\"排名\", \"代码\", \"名称\", \"综合分\", \"实时源/新鲜度\", \"实时价\", \"AI建议\", \"当前状态\", \"来源策略\"],\n"}]