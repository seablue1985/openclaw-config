y insights. I want to make sure I'm not missing anything important while doing this. It's all about being thorough and attentive to detail! Let's see what I can uncover!\"}]}"},{"type":"toolCall","id":"call_91V0IkzRv9jw3CmoQxEkJJa7|fc_0fad9e409c19087f0169e3b2b07264819aa1de5238bb68d1c3","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/build_payload.py","limit":220},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/build_payload.py\",\"limit\":220}"},{"type":"toolCall","id":"call_dsooD199Q6s41q3PcWZ80v5F|fc_0fad9e409c19087f0169e3b2b07284819ab76835a442942703","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/render_report.py","limit":220},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/render_report.py\",\"limit\":220}"},{"type":"toolCall","id":"call_e0u6AJE1Nh7UbZ08C4EHDM0v|fc_0fad9e409c19087f0169e3b2b0728c819aa980672e17949f85","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/multi_perspective_merger.py","limit":260},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/multi_perspective_merger.py\",\"limit\":260}"},{"type":"toolCall","id":"call_X69tE0oXyeH2PXcFTi7Z94Xk|fc_0fad9e409c19087f0169e3b2b07294819abfcc70497a6ffc53","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_single_stock_lens.py","offset":500,"limit":180},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_single_stock_lens.py\",\"offset\":500,\"limit\":180}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":235030,"output":220,"cacheRead":0,"cacheWrite":0,"totalTokens":235250,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776530084552,"responseId":"resp_0fad9e409c19087f0169e3b2a803a0819a8785909e1170bd26"}}
{"type":"message","id":"e59cb8ec","parentId":"61e841d0","timestamp":"2026-04-18T16:34:58.595Z","message":{"role":"toolResult","toolCallId":"call_91V0IkzRv9jw3CmoQxEkJJa7|fc_0fad9e409c19087f0169e3b2b07264819aa1de5238bb68d1c3","toolName":"read","content":[{"type":"text","text":"\"\"\"Build payload and validate inputs for position explainer overlay.\"\"\"\n\nfrom __future__ import annotations\n\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nfrom .load_inputs import load_holdings, load_market_context, load_morning_summary\nfrom .schemas import BlockedStatus, HoldingInput\n\n\nclass PayloadError(Exception):\n    \"\"\"Raised when payload validation fails.\"\"\"\n    pass\n\n\ndef _parse_market_context(raw_mc: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Parse market context flexibly - handle multiple formats.\"\"\"\n    # Standard format: has label + date_tag\n    if \"label\" in raw_mc and \"date_tag\" in raw_mc:\n        return {\n            \"date_tag\": str(raw_mc[\"date_tag\"]),\n            \"label\": raw_mc.get(\"label\", \"neutral\"),\n            \"market_bias\": raw_mc.get(\"market_bias\"),\n            \"breadth_note\": raw_mc.get(\"breadth_note\"),\n            \"theme_note\": raw_mc.get(\"theme_note\"),\n        }\n    # Breadth paper format: has risk_degree, signal_date, current_date\n    risk_degree = raw_mc.get(\"risk_degree\", 0.5)\n    label = \"risk_off\" if float(risk_degree) >= 0.6 else \"risk_on\" if float(risk_degree) <= 0.3 else \"neutral\"\n    return {\n        \"date_tag\": str(raw_mc.get(\"signal_date\", raw_mc.get(\"current_date\", \"\")).replace(\"-\", \"\")),\n        \"label\": label,\n        \"market_bias\": f\"risk_degree={risk_degree}, target_position={raw_mc.get('target_position_pct', 'N/A')}%\",\n        \"breadth_note\": f\"持仓 {raw_mc.get('position_count', 'N/A')} 只, 仓位目标 {raw_mc.get('target_position_pct', 'N/A')}%\",\n        \"theme_note\": raw_mc.get(\"strategy_name\", \"\"),\n    }\n\n\ndef build_payload(\n    *,\n    holdings_path: Path,\n    market_context_path: Path,\n    morning_summary_path: Path,\n    expected_date_tag: str,\n) -> dict:\n    \"\"\"Build and validate payload from holdings + market context.\"\"\"\n    if not holdings_path.exists():\n        raise PayloadError(\"holdings_missing\")\n    raw_holdings = load_holdings(holdings_path)\n    if not raw_holdings:\n        raise PayloadError(\"holdings_empty\")\n\n    if not market_context_path.exists():\n        raise PayloadError(\"market_context_missing\")\n    raw_mc = load_market_context(market_context_path)\n    mc = _parse_market_context(raw_mc)\n\n    if not morning_summary_path.exists():\n        summary_text = \"(morning summary not available)\"\n    else:\n        summary_text = load_morning_summary(morning_summary_path)\n\n    # Normalize column names (CSV may use different names than schema)\n    col_aliases = {\n        \"symbol\": \"ts_code\",\n        \"quantity\": \"qty\",\n        \"cost\": \"cost_price\",\n    }\n    # Fields that must be numeric (empty string → None)\n    numeric_fields = {\n        \"qty\", \"cost_price\", \"last_price\", \"market_value\",\n        \"unrealized_pnl\", \"unrealized_pnl_pct\", \"current_price\",\n    }\n    normalized_holdings = []\n    for h in raw_holdings:\n        h = dict(h)\n        for alias, canonical in col_aliases.items():\n            if alias in h and canonical not in h:\n                h[canonical] = h.pop(alias)\n        for field in numeric_fields:\n            val = h.get(field)\n            if val is None or str(val).strip() == \"\":\n                h[field] = None\n            elif field in (\"qty\", \"cost_price\", \"last_price\", \"market_value\",\n                           \"unrealized_pnl\", \"current_price\"):\n                try:\n                    h[field] = float(val)\n                except (ValueError, TypeError):\n                    h[field] = None\n        normalized_holdings.append(h)\n    holdings = [HoldingInput.model_validate(h) for h in normalized_holdings]\n\n    return {\n        \"date_tag\": expected_date_tag,\n        \"market_context\": mc,\n        \"morning_summary\": summary_text,\n        \"holdings\": [h.model_dump() for h in holdings],\n    }\n\n\ndef build_blocked(reason: str) -> BlockedStatus:\n    return BlockedStatus(\n        status=\"blocked\",\n        reason=reason,\n        generated_at=datetime.now(),\n    )\n"}],"isError":false,"timestamp":1776530098586}}
{"type":"message","id":"b3a862e6","parentId":"e59cb8ec","timestamp":"2026-04-18T16:34:58.606Z","message":{"role":"toolResult","toolCallId":"call_dsooD199Q6s41q3PcWZ80v5F|fc_0fad9e409c19087f0169e3b2b07284819ab76835a442942703","toolName":"read","content":[{"type":"text","text":"\"\"\"Render position explainer report as Markdown.\"\"\"\n\nfrom __future__ import annotations\n\n\nADVICE_EMOJI = {\n    \"hold\": \"🔵\",\n    \"add\": \"🟢\",\n    \"reduce\": \"🟡\",\n    \"exit\": \"🔴\",\n}\n\n\ndef render_markdown(report: dict) -> str:\n    \"\"\"Render a PositionReport as a readable Markdown string.\"\"\"\n    lines = []\n    lines.append(f\"# 持仓解释报告 {report.get('date_tag', 'N/A')}\")\n    lines.append(\"\")\n    lines.append(f\"**生成时间:** {report.get('generated_at', 'N/A')}\")\n    lines.append(f\"**市场状态:** {report.get('market_context', 'N/A')}\")\n    lines.append(f\"**持仓数量:** {report.get('holding_count', 0)} 只\")\n    lines.append(\"\")\n    smry = report.get(\"portfolio_summary\", \"\")\n    if smry:\n        lines.append(smry)\n    lines.append(\"\")\n    lines.append(\"---\")\n    lines.append(\"\")\n\n    for item in report.get(\"items\", []):\n        ts = item.get(\"ts_code\", \"N/A\")\n        name = item.get(\"name\", ts)\n        advice = item.get(\"position_advice\", \"hold\")\n        emoji = ADVICE_EMOJI.get(advice, \"⚪\")\n        pnl = item.get(\"unrealized_pnl_pct\")\n        pnl_str = f\"{pnl:+.2f}%\" if isinstance(pnl, (int, float)) else \"N/A\"\n\n        lines.append(f\"## {emoji} {ts} {name}  [{advice.upper()}]\")\n        lines.append(\"\")\n        lines.append(\"| 指标 | 值 |\")\n        lines.append(\"|---|---|\")\n        qty = item.get(\"qty\")\n        cost = item.get(\"cost_price\")\n        curr = item.get(\"current_price\")\n        if qty is not None:\n            lines.append(f\"| 持仓数量 | {qty} |\")\n        if cost is not None:\n            lines.append(f\"| 成本价 | {cost:.3f} |\")\n        if curr is not None:\n            lines.append(f\"| 当前价 | {curr:.3f} |\")\n        lines.append(f\"| 浮盈亏 | {pnl_str} |\")\n        lines.append(\"\")\n\n        hold_case = item.get(\"hold_case\", [])\n        if hold_case:\n            lines.append(\"**持有理由:**\")\n            for b in hold_case:\n                lines.append(f\"- {b}\")\n            lines.append(\"\")\n\n        risk_case = item.get(\"risk_case\", [])\n        if risk_case:\n            lines.append(\"**风险因素:**\")\n            for r in risk_case:\n                lines.append(f\"- {r}\")\n            lines.append(\"\")\n\n        exit_triggers = item.get(\"exit_triggers\", [])\n        if exit_triggers:\n            lines.append(\"**退出触发条件:**\")\n            for e in exit_triggers:\n                lines.append(f\"- {e}\")\n            lines.append(\"\")\n\n        conf = item.get(\"confidence_note\", \"\")\n        if conf:\n            lines.append(f\"_置信度: {conf}_\")\n        lines.append(\"\")\n        lines.append(\"---\")\n        lines.append(\"\")\n\n    lines.append(\"\")\n    lines.append(\"_⚠️ 本报告由 AI 生成，仅供参考，不构成投资建议_\")\n    return \"\\n\".join(lines)\n"}],"isError":false,"timestamp":1776530098596}}
{"type":"message","id":"6f314aa1","parentId":"b3a862e6","timestamp":"2026-04-18T16:34:58.616Z","message":{"role":"toolResult","toolCallId":"call_e0u6AJE1Nh7UbZ08C4EHDM0v|fc_0fad9e409c19087f0169e3b2b0728c819aa980672e17949f85","toolName":"read","content":[{"type":"text","text":"\"\"\"Multi-perspective merger: combine candidate_explainer + position_explainer into a single daily summary.\n\nGoal: answer \"what should I pay attention to today?\" by fusing:\n  - Candidate insights: which candidates are worth watching\n  - Position insights: which holdings need attention (reduce/exit/watch)\n\nOutput: ai_overlay/daily_digest_{date}.md + daily_digest_{date}.json\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nsys.path.insert(0, str(Path(__file__).parent.parent))\n\n\n# ---------- Output schema ----------\ndef _normalize_ticker(raw: str) -> str:\n    \"\"\"Normalize ticker to a comparable form (no .SH/.SZ suffix).\"\"\"\n    return raw.replace(\".SH\", \"\").replace(\".SZ\", \"\").replace(\".\", \"\").strip()\n\n\ndef build_digest(\n    candidate_path: Path,\n    position_path: Path,\n    date_tag: str,\n) -> dict[str, Any]:\n    \"\"\"Build the multi-perspective digest from both explainer outputs.\"\"\"\n\n    cand_data = json.loads(candidate_path.read_text(encoding=\"utf-8\"))\n    pos_data = json.loads(position_path.read_text(encoding=\"utf-8\"))\n\n    cand_items = cand_data.get(\"items\", [])\n    pos_items = pos_data.get(\"items\", [])\n\n    # Enrich all tickers with real company names\n    from ai_overlay._ticker_names import ensure_names\n    all_tickers = [c.get(\"ticker\", \"\") for c in cand_items] + [p.get(\"ts_code\", \"\") for p in pos_items]\n    name_cache = ensure_names(all_tickers)\n\n    for c in cand_items:\n        ticker = c.get(\"ticker\", \"\")\n        c[\"name\"] = name_cache.get(ticker, c.get(\"name\", ticker))\n    for p in pos_items:\n        ticker = p.get(\"ts_code\", \"\")\n        p[\"name\"] = name_cache.get(ticker, p.get(\"name\", ticker))\n\n    # Build position lookup by normalized ticker\n    pos_by_ticker: dict[str, dict] = {}\n    for item in pos_items:\n        ts = item.get(\"ts_code\", \"\")\n        ticker_key = _normalize_ticker(ts)\n        pos_by_ticker[ticker_key] = item\n\n    # Overlap: candidates that are also held\n    overlap: list[dict] = []\n    standalone_candidates: list[dict] = []\n    at_risk_holdings: list[dict] = []\n\n    for c in cand_items:\n        cticker = _normalize_ticker(c.get(\"ticker\", \"\"))\n        pos_item = pos_by_ticker.get(cticker)\n        entry = {\n            **c,\n            \"position_info\": None,\n        }\n        if pos_item:\n            entry[\"position_info\"] = {\n                \"ts_code\": pos_item.get(\"ts_code\"),\n                \"qty\": pos_item.get(\"qty\"),\n                \"cost_price\": pos_item.get(\"cost_price\"),\n                \"current_price\": pos_item.get(\"current_price\"),\n                \"unrealized_pnl_pct\": pos_item.get(\"unrealized_pnl_pct\"),\n                \"position_advice\": pos_item.get(\"position_advice\"),\n                \"risk_case\": pos_item.get(\"risk_case\", []),\n                \"exit_triggers\": pos_item.get(\"exit_triggers\", []),\n                \"confidence_note\": pos_item.get(\"confidence_note\"),\n            }\n            overlap.append(entry)\n        else:\n            standalone_candidates.append(entry)\n\n    # At-risk holdings: those with reduce/exit advice\n    for p in pos_items:\n        advice = p.get(\"position_advice\", \"hold\")\n        if advice in (\"reduce\", \"exit\"):\n            at_risk_holdings.append({\n                \"ts_code\": p.get(\"ts_code\"),\n                \"name\": p.get(\"name\"),\n                \"unrealized_pnl_pct\": p.get(\"unrealized_pnl_pct\"),\n                \"position_advice\": advice,\n                \"risk_case\": p.get(\"risk_case\", []),\n                \"exit_triggers\": p.get(\"exit_triggers\", []),\n                \"confidence_note\": p.get(\"confidence_note\", \"\"),\n                \"hold_case\": p.get(\"hold_case\", []),\n            })\n\n    # Market context\n    market_context = cand_data.get(\"market_context\", pos_data.get(\"market_context\", \"unknown\"))\n\n    # Portfolio summary\n    portfolio_summary = pos_data.get(\"portfolio_summary\", \"\")\n\n    # Priority candidates (top 3)\n    top_candidates = sorted(cand_items, key=lambda x: x.get(\"priority\", 999))[:3]\n\n    # Stats\n    reduce_count = sum(1 for p in pos_items if p.get(\"position_advice\") == \"reduce\")\n    exit_count = sum(1 for p in pos_items if p.get(\"position_advice\") == \"exit\")\n    hold_count = sum(1 for p in pos_items if p.get(\"position_advice\") == \"hold\")\n\n    return {\n        \"date_tag\": date_tag,\n        \"generated_at\": datetime.now().isoformat(),\n        \"market_context\": market_context,\n        \"stats\": {\n            \"total_candidates\": cand_data.get(\"candidate_count\", len(cand_items)),\n            \"overlap_count\": len(overlap),\n            \"standalone_candidates\": len(standalone_candidates),\n            \"total_holdings\": pos_data.get(\"holding_count\", len(pos_items)),\n            \"at_risk_holdings\": len(at_risk_holdings),\n            \"reduce_count\": reduce_count,\n            \"exit_count\": exit_count,\n            \"hold_count\": hold_count,\n        },\n        \"top_candidates\": top_candidates,\n        \"overlap\": overlap,\n        \"standalone_candidates\": standalone_candidates,\n        \"at_risk_holdings\": at_risk_holdings,\n        \"portfolio_summary\": portfolio_summary,\n        \"portfolio_metrics\": pos_data.get(\"portfolio_metrics\", {}),\n        \"raw_candidate_count\": cand_data.get(\"candidate_count\", len(cand_items)),\n        \"raw_position_count\": pos_data.get(\"holding_count\", len(pos_items)),\n    }\n\n\ndef render_digest_markdown(digest: dict) -> str:\n    \"\"\"Render the digest as a readable Markdown report.\"\"\"\n    lines = []\n    lines.append(f\"# 每日综合研判 {digest['date_tag']}\")\n    lines.append(\"\")\n    lines.append(f\"**生成时间:** {digest['generated_at']}\")\n    lines.append(f\"**市场状态:** {digest['market_context']}\")\n    lines.append(\"\")\n\n    stats = digest[\"stats\"]\n    lines.append(\"## 📊 今日概况\")\n    lines.append(f\"| 维度 | 数量 |\")\n    lines.append(f\"|------|------|\")\n    lines.append(f\"| 候选池总数 | {stats['total_candidates']} |\")\n    lines.append(f\"| 其中已持仓 | {stats['overlap_count']} |\")\n    lines.append(f\"| 纯候选（未持仓）| {stats['standalone_candidates']} |\")\n    lines.append(f\"| 持仓总数 | {stats['total_holdings']} |\")\n    lines.append(f\"| 其中建议减仓 | {stats['reduce_count']} |\")\n    lines.append(f\"| 其中建议清仓 | {stats['exit_count']} |\")\n    lines.append(f\"| 正常持仓 | {stats['hold_count']} |\")\n    lines.append(\"\")\n\n    # Top candidates\n    top = digest[\"top_candidates\"]\n    if top:\n        lines.append(\"## 🏆 Top 3 优先候选\")\n        for i, c in enumerate(top, 1):\n            ticker = c.get(\"ticker\", \"\")\n            name = c.get(\"name\", \"\")\n            priority = c.get(\"priority\", \"\")\n            bias = c.get(\"action_bias\", \"\")\n            bull = c.get(\"bull_case\", [])\n            bear = c.get(\"bear_case\", [])\n            triggers = c.get(\"watch_triggers\", [])\n            lines.append(f\"### {i}. {ticker} {name} (优先级{priority})\")\n            lines.append(f\"**倾向:** {bias}\")\n            if bull:\n                lines.append(f\"**利好:** {'; '.join(bull[:2])}\")\n            if bear:\n                lines.append(f\"**利空:** {'; '.join(bear[:2])}\")\n            if triggers:\n                lines.append(f\"**观察触发:** {'; '.join(triggers[:1])}\")\n            # Position info if overlap\n            pi = c.get(\"position_info\")\n            if pi:\n                pnl = pi.get(\"unrealized_pnl_pct\")\n                advice = pi.get(\"position_advice\", \"\")\n                lines.append(f\"**持仓状态:** {advice} | 浮亏 {pnl:.2f}%\" if isinstance(pnl, (int, float)) else f\"**持仓状态:** {advice}\")\n            lines.append(\"\")\n\n    # Overlap (candidates that are also holdings)\n    overlap = digest.get(\"overlap\", [])\n    if overlap:\n        lines.append(f\"## 🔄 已持仓候选（{len(overlap)}只）\")\n        lines.append(\"\")\n        lines.append(\"| 股票 | 候选倾向 | 持仓建议 | 浮盈亏 | 核心风险 |\")\n        lines.append(\"|------|----------|----------|--------|----------|\")\n        for c in overlap:\n            ticker = c.get(\"ticker\", \"\")\n            name = c.get(\"name\", \"\")\n            cand_bias = c.get(\"action_bias\", \"\")\n            pi = c.get(\"position_info\") or {}\n            pos_advice = pi.get(\"position_advice\", \"\")\n            pnl = pi.get(\"unrealized_pnl_pct\")\n            risk_case = pi.get(\"risk_case\", [])\n            risk_str = \"; \".join(risk_case[:1]) if risk_case else \"\"\n            pnl_str = f\"{pnl:+.2f}%\" if isinstance(pnl, (int, float)) else \"N/A\"\n            lines.append(f\"| {ticker} {name} | {cand_bias} | {pos_advice} | {pnl_str} | {risk_str} |\")\n        lines.append(\"\")\n\n    # At-risk holdings\n    at_risk = digest.get(\"at_risk_holdings\", [])\n    if at_risk:\n        lines.append(f\"## ⚠️ 今日需关注持仓（{len(at_risk)}只）\")\n        lines.append(\"\")\n        for h in at_risk:\n            ts = h.get(\"ts_code\", \"\")\n            name = h.get(\"name\", \"\")\n            advice = h.get(\"position_advice\", \"\")\n            pnl = h.get(\"unrealized_pnl_pct\")\n            risk_case = h.get(\"risk_case\", [])\n            exit_triggers = h.get(\"exit_triggers\", [])\n            confidence = h.get(\"confidence_note\", \"\")\n            pnl_str = f\"{pnl:+.2f}%\" if isinstance(pnl, (int, float)) else \"N/A\"\n            icon = \"🔴\" if advice == \"exit\" else \"🟡\"\n            lines.append(f\"### {icon} {ts} {name} [{advice.upper()}] 浮亏{pnl_str}\")\n            if risk_case:\n                lines.append(f\"- **风险:** {'; '.join(risk_case[:2])}\")\n            if exit_triggers:\n                lines.append(f\"- **退出触发:** {'; '.join(exit_triggers[:2])}\")\n            if confidence:\n                lines.append(f\"- 置信: {confidence[:100]}\")\n            lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(\"*本报告由 AI 自动生成，仅供参考，不构成投资建议*\")\n    return \"\\n\".join(lines)\n\n\ndef main() -> int:\n    parser = argparse.ArgumentParser(description=\"Multi-perspective daily digest merger\")\n    parser.add_argument(\"--date\", default=None, help=\"Date tag YYYYMMDD (default: today)\")\n    parser.add_argument(\"--output-dir\", default=None, help=\"Override output directory\")\n    args = parser.parse_args()\n\n    if args.date:\n        date_tag = args.date\n    else:\n        date_tag = datetime.now().strftime(\"%Y%m%d\")\n\n    base = Path(__file__).parent.parent / \"research\" / \"reports\" / \"ai_overlay\"\n    if args.output_dir:\n        base = Path(args.output_dir)\n\n    cand_path = base / f\"candidate_explainer_{date_tag}.json\"\n    pos_path = base / f\"position_explainer_{date_tag}.json\"\n    cand_latest = base / \"candidate_explainer_latest.json\"\n    pos_latest = base / \"position_explainer_latest.json\"\n\n\n[44 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776530098606}}
{"type":"message","id":"b7004387","parentId":"6f314aa1","timestamp":"2026-04-18T16:34:58.627Z","message":{"role":"toolResult","toolCallId":"call_X69tE0oXyeH2PXcFTi7Z94Xk|fc_0fad9e409c19087f0169e3b2b07294819abfcc70497a6ffc53","toolName":"read","content":[{"type":"text","text":"    lines.append(f\"- 是否命中模拟盘分析：`{s['has_paper_overlay']}`\")\n    lines.append(f\"- 是否命中今日执行单：`{s['in_live_orders']}`\")\n    lines.append(f\"- 是否命中今日策略总览：`{s['in_today_report']}`\")\n    lines.append(f\"- 是否命中真实持仓：`{s['in_real_holdings']}`\")\n    lines.append(f\"- 当前出现在持仓的模拟盘：`{'、'.join(s['in_positions']) if s['in_positions'] else '无'}`\")\n    lines.append(f\"- 当前有分析结果的模拟盘：`{'、'.join(s['profiles_with_overlay']) if s['profiles_with_overlay'] else '无'}`\")\n    lines.append(\"\")\n\n    lines.append(\"## 二、当前市场与执行环境\")\n    lines.append(f\"- 当前风险模式：`{fmt(report_meta.get('risk_mode'))}`\")\n    lines.append(f\"- hard_stop：`{fmt(report_meta.get('hard_stop'))}` / halt_new_buy：`{fmt(report_meta.get('halt_new_buy'))}`\")\n    lines.append(f\"- 当前触发原因：`{fmt(report_meta.get('trigger_reason'))}`\")\n    gate_reasons = report_meta.get('gate_reasons') or []\n    lines.append(f\"- 当前门控摘要：`{' | '.join(gate_reasons) if gate_reasons else '-'}`\")\n    lines.append(\"\")\n\n    lines.append(\"## 三、实时链路分析\")\n    if live:\n        lines.append(f\"- 操作建议：`{fmt(live.get('operation_advice'))}`\")\n        lines.append(f\"- 趋势判断：`{fmt(live.get('trend_prediction'))}`\")\n        lines.append(f\"- 情绪评分：`{fmt(live.get('sentiment_score'))}`\")\n        lines.append(f\"- AI决策：`{fmt(live.get('ai_decision'))}`\")\n        lines.append(f\"- 预算系数：`{fmt(live.get('ai_budget_scale'))}` / 分数系数：`{fmt(live.get('ai_score_scale'))}`\")\n        lines.append(f\"- 实时价格：`{fmt(live.get('realtime_price'))}` / 实时涨跌幅：`{fmt(live.get('realtime_change_pct'))}`\")\n        lines.append(f\"- 决策原因：`{fmt(live.get('ai_gate_reason'))}`\")\n        lines.append(f\"- 分析摘要：`{fmt(live.get('ai_analysis_summary'))}`\")\n        lines.append(f\"- 风险提示：`{fmt(live.get('ai_risk_warning'))}`\")\n        lines.append(f\"- 止损参考：`{fmt(live.get('ai_stop_loss'))}` / 止盈参考：`{fmt(live.get('ai_take_profit'))}`\")\n        lines.append(f\"- 空仓建议：`{fmt(live.get('ai_no_position_advice'))}`\")\n        lines.append(f\"- 来源文件：`{fmt(live.get('overlay_path'))}`\")\n    else:\n        lines.append(\"- 暂无实时链路分析结果\")\n    lines.append(\"\")\n\n    lines.append(\"## 四、即时深度分析\")\n    report = instant_analysis.get('report') or {}\n    if report:\n        meta = report.get('meta') or {}\n        summary_block = report.get('summary') or {}\n        strategy = report.get('strategy') or {}\n        details = report.get('details') or {}\n        lines.append(f\"- 当前价格：`{fmt(meta.get('current_price'))}` / 涨跌幅：`{fmt(meta.get('change_pct'))}`\")\n        lines.append(f\"- 操作建议：`{fmt(summary_block.get('operation_advice'))}`\")\n        lines.append(f\"- 趋势判断：`{fmt(summary_block.get('trend_prediction'))}`\")\n        lines.append(f\"- 情绪评分：`{fmt(summary_block.get('sentiment_score'))}` / 情绪标签：`{fmt(summary_block.get('sentiment_label'))}`\")\n        lines.append(f\"- 分析摘要：`{fmt(summary_block.get('analysis_summary'))}`\")\n        lines.append(f\"- 理想买点：`{fmt(strategy.get('ideal_buy'))}` / 二次买点：`{fmt(strategy.get('secondary_buy'))}`\")\n        lines.append(f\"- 止损：`{fmt(strategy.get('stop_loss'))}` / 止盈：`{fmt(strategy.get('take_profit'))}`\")\n        lines.append(f\"- 技术分析：`{fmt(details.get('technical_analysis'))}`\")\n        lines.append(f\"- 基本面分析：`{fmt(details.get('fundamental_analysis'))}`\")\n        lines.append(f\"- 风险提示：`{fmt(details.get('risk_warning'))}`\")\n        lines.append(f\"- 新闻摘要：`{fmt(details.get('news_summary'))}`\")\n    elif instant_analysis.get('error'):\n        lines.append(f\"- 即时分析失败：`{fmt(instant_analysis.get('error'))}`\")\n    else:\n        lines.append(\"- 暂无即时深度分析结果\")\n    lines.append(\"\")\n\n    lines.append(\"## 五、技术指标\")\n    if technical_indicators and not technical_indicators.get('error'):\n        lines.append(f\"- 收盘价：`{fmt(technical_indicators.get('close'))}`\")\n        lines.append(f\"- MA10：`{fmt(technical_indicators.get('ma10'))}` / MA20：`{fmt(technical_indicators.get('ma20'))}` / 均线状态：`{fmt(technical_indicators.get('ma_signal'))}`\")\n        lines.append(f\"- MACD：DIF=`{fmt(technical_indicators.get('macd_dif'))}` / DEA=`{fmt(technical_indicators.get('macd_dea'))}` / 柱=`{fmt(technical_indicators.get('macd_hist'))}` / 状态=`{fmt(technical_indicators.get('macd_signal'))}`\")\n        lines.append(f\"- RSI14：`{fmt(technical_indicators.get('rsi14'))}` / 状态：`{fmt(technical_indicators.get('rsi_signal'))}`\")\n        lines.append(f\"- KDJ：K=`{fmt(technical_indicators.get('kdj_k'))}` / D=`{fmt(technical_indicators.get('kdj_d'))}` / J=`{fmt(technical_indicators.get('kdj_j'))}` / 状态=`{fmt(technical_indicators.get('kdj_signal'))}`\")\n        lines.append(f\"- BIAS5：`{fmt(technical_indicators.get('bias5'))}` / 状态：`{fmt(technical_indicators.get('bias_signal'))}`\")\n    elif technical_indicators.get('error'):\n        lines.append(f\"- 技术指标计算失败：`{fmt(technical_indicators.get('error'))}`\")\n    else:\n        lines.append(\"- 暂无技术指标结果\")\n    lines.append(\"\")\n\n    lines.append(\"## 六、基本面\")\n    fund = view.get(\"fundamental_data\") or {}\n    if fund and not fund.get('error'):\n        lines.append(f\"- 市盈率PE：`{fmt(fund.get('pe'))}` / 评估：`{fmt(fund.get('valuation'))}`\")\n        lines.append(f\"- 市净率PB：`{fmt(fund.get('pb'))}` / 评估：`{fmt(fund.get('pb评估'))}`\")\n        lines.append(f\"- 市销率PS：`{fmt(fund.get('ps'))}`\")\n        lines.append(f\"- 股息率：`{fmt(fund.get('dv_ratio'))}%`\")\n        lines.append(f\"- 总市值：`{fmt(fund.get('total_mv'))}亿` / 流通值：`{fmt(fund.get('circ_mv'))}亿`\")\n        lines.append(f\"- 换手率：`{fmt(fund.get('turnover_rate'))}%`\")\n    elif fund.get('error'):\n        lines.append(f\"- 基本面数据失败：`{fmt(fund.get('error'))}`\")\n    else:\n        lines.append(\"- 暂无基本面数据\")\n    lines.append(\"\")\n\n    lines.append(\"## 七、量价结构\")\n    volume_structure = view.get(\"volume_structure\") or {}\n    if volume_structure and not volume_structure.get('error'):\n        lines.append(f\"- 收盘价：`{fmt(volume_structure.get('close'))}`\")\n        lines.append(f\"- 成交量：`{fmt(volume_structure.get('volume'))}`\")\n        lines.append(f\"- 量比（vs 5日均）：`{fmt(volume_structure.get('vol_ratio_5d'))}`\")\n        lines.append(f\"- 5日涨跌幅：`{fmt(volume_structure.get('price_change_5d'))}%`\")\n        lines.append(f\"- 5日波动率：`{fmt(volume_structure.get('volatility_5d'))}%`\")\n        lines.append(f\"- 量价状态：`{fmt(volume_structure.get('volume_status'))}`\")\n        lines.append(f\"- 趋势判断：`{fmt(volume_structure.get('trend'))}`\")\n    elif volume_structure.get('error'):\n        lines.append(f\"- 量价分析失败：`{fmt(volume_structure.get('error'))}`\")\n    else:\n        lines.append(\"- 暂无量价结构结果\")\n    lines.append(\"\")\n\n    lines.append(\"## 八、股东结构\")\n    holder = view.get(\"holder_data\") or {}\n    if holder and not holder.get('error'):\n        lines.append(f\"- 流通股东数：`{fmt(holder.get('circ_holder_count'))}`\")\n        lines.append(f\"- 流通大股东：`{fmt(holder.get('circ_top1_name'))}` / 持股比例：`{fmt(holder.get('circ_top1_pct'))}%`\")\n        lines.append(f\"- 股东总数：`{fmt(holder.get('main_holder_count'))}`\")\n        lines.append(f\"- 主要大股东：`{fmt(holder.get('main_top1_name'))}` / 持股数：`{fmt(holder.get('main_top1_share'))}`\")\n    elif holder.get('error'):\n        lines.append(f\"- 股东数据失败：`{fmt(holder.get('error'))}`\")\n    else:\n        lines.append(\"- 暂无股东数据\")\n    lines.append(\"\")\n    lines.append(\"## 九、今日执行命中\")\n    if live_order:\n        lines.append(f\"- side：`{fmt(live_order.get('side'))}`\")\n        lines.append(f\"- risk_gate：`{fmt(live_order.get('risk_gate'))}`\")\n        lines.append(f\"- gate_reason：`{fmt(live_order.get('gate_reason'))}`\")\n        lines.append(f\"- ref_price：`{fmt(live_order.get('ref_price_low'))}` ~ `{fmt(live_order.get('ref_price_high'))}`\")\n        lines.append(f\"- realtime：`{fmt(live_order.get('realtime_price'))}` / `{fmt(live_order.get('realtime_pct'))}`\")\n        lines.append(f\"- source_reason：`{fmt(live_order.get('source_reason'))}`\")\n    else:\n        lines.append(\"- 今日执行单中未命中该股票\")\n    lines.append(\"\")\n\n    lines.append(\"## 八、今日策略总览命中\")\n    if report_entry:\n        lines.append(f\"- 候选池：`{fmt(report_entry.get('bucket'))}`\")\n        lines.append(f\"- 策略：`{fmt(report_entry.get('strategy_id'))}`\")\n        lines.append(f\"- score：`{fmt(report_entry.get('score'))}`\")\n        lines.append(f\"- AI建议：`{fmt(report_entry.get('ai_operation_advice'))}` / AI决策：`{fmt(report_entry.get('ai_decision'))}`\")\n        lines.append(f\"- 预算系数：`{fmt(report_entry.get('ai_budget_scale'))}` / 分数系数：`{fmt(report_entry.get('ai_score_scale'))}`\")\n        lines.append(f\"- 决策原因：`{fmt(report_entry.get('ai_gate_reason'))}`\")\n        lines.append(f\"- 分析摘要：`{fmt(report_entry.get('ai_analysis_summary'))}`\")\n        lines.append(f\"- 风险提示：`{fmt(report_entry.get('ai_risk_warning'))}`\")\n    else:\n        lines.append(\"- 今日策略总览未命中该股票\")\n    lines.append(\"\")\n\n    lines.append(\"## 九、真实持仓\")\n    if real_position:\n        lines.append(f\"- 持仓数量：`{fmt(real_position.get('quantity'))}`\")\n        lines.append(f\"- 成本价：`{fmt(real_position.get('cost_price'))}`\")\n        lines.append(f\"- 资产类型：`{fmt(real_position.get('asset_type'))}`\")\n        lines.append(f\"- 来源：`{fmt(real_position.get('source'))}`\")\n    else:\n        lines.append(\"- 当前真实持仓中无该股票\")\n    lines.append(\"\")\n\n    lines.append(\"## 十、三盘模拟盘分析\")\n    for profile in view.get(\"profiles\", []):\n        lines.append(f\"### {profile['profile']}\")\n        overlay = profile.get(\"overlay\") or {}\n        position = profile.get(\"position\") or {}\n        if overlay:\n            lines.append(f\"- 操作建议：`{fmt(overlay.get('operation_advice'))}`\")\n            lines.append(f\"- 趋势判断：`{fmt(overlay.get('trend_prediction'))}`\")\n            lines.append(f\"- 情绪评分：`{fmt(overlay.get('sentiment_score'))}`\")\n            lines.append(f\"- AI决策：`{fmt(overlay.get('ai_decision'))}`\")\n            lines.append(f\"- 预算系数：`{fmt(overlay.get('ai_budget_scale'))}`\")\n            lines.append(f\"- 决策原因：`{fmt(overlay.get('ai_gate_reason'))}`\")\n            lines.append(f\"- 分析文件：`{fmt(profile.get('overlay_path'))}`\")\n        else:\n            lines.append(\"- 暂无该模拟盘分析结果\")\n        if position:\n            lines.append(f\"- 当前持仓：数量 `{fmt(position.get('quantity'))}` / 成本 `{fmt(position.get('cost_price'))}` / 现价 `{fmt(position.get('last_price'))}`\")\n        else:\n            lines.append(\"- 当前持仓：无\")\n        lines.append(\"\")\n\n    lines.append(\"## 十一、结论\")\n    if live_order and str(live_order.get('risk_gate')) == 'blocked' and str(report_meta.get('hard_stop')).lower() == 'true':\n        lines.append(\"- 当前不可执行的主要原因是市场级 hard stop，不是这只股票本身单独被否决。\")\n    elif live_order and str(live_order.get('risk_gate')) == 'blocked':\n        lines.append(\"- 当前不可执行，主要看今日执行单里的 gate_reason。\")\n    elif live_order and str(live_order.get('risk_gate')) == 'pass':\n        lines.append(\"- 当前执行链允许该股票通过，可进入下单/观察环节。\")\n    elif live:\n\n[486 more lines in file. Use offset=680 to continue.]"}],"isError":false,"timestamp":1776530098616}}
