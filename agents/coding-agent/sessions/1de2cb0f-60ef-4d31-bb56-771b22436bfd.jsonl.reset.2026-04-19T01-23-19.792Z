690b8819a81764be9d1ded584","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_live_smallcap_candidates.py","offset":520,"limit":220},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_live_smallcap_candidates.py\",\"offset\":520,\"limit\":220}"},{"type":"toolCall","id":"call_2tgTeicEFODJiszSjgglX1sr|fc_0fad9e409c19087f0169e3b57690ec819a996b386c90f83b3b","name":"exec","arguments":{"command":"grep -RIn \"market_trade_date\\|price_lag_days\\|price_src\\|stale_price_source\\|inject_realtime_prices\\|realtime_closes\\|summary\\[\\\"price\" /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports 2>/dev/null | head -n 240","workdir":"/Users/ling/.openclaw/workspace/coding-agent","timeout":40},"partialJson":"{\"command\":\"grep -RIn \\\"market_trade_date\\\\|price_lag_days\\\\|price_src\\\\|stale_price_source\\\\|inject_realtime_prices\\\\|realtime_closes\\\\|summary\\\\[\\\\\\\"price\\\" /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/research/reports 2>/dev/null | head -n 240\",\"workdir\":\"/Users/ling/.openclaw/workspace/coding-agent\",\"timeout\":40}"},{"type":"toolCall","id":"call_2H2kiqwSb9i2AYHae0HkeRjy|fc_0fad9e409c19087f0169e3b57690f4819ab8472585be9d577f","name":"exec","arguments":{"command":"grep -RIn \"candidate_generation_.*json\\|order_plan_v1_.*json\\|top_preview\\|price_lag_days\\|market_trade_date\" /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts 2>/dev/null | head -n 200","workdir":"/Users/ling/.openclaw/workspace/coding-agent","timeout":40},"partialJson":"{\"command\":\"grep -RIn \\\"candidate_generation_.*json\\\\|order_plan_v1_.*json\\\\|top_preview\\\\|price_lag_days\\\\|market_trade_date\\\" /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts 2>/dev/null | head -n 200\",\"workdir\":\"/Users/ling/.openclaw/workspace/coding-agent\",\"timeout\":40}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":284049,"output":560,"cacheRead":0,"cacheWrite":0,"totalTokens":284609,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776530789455,"responseId":"resp_0fad9e409c19087f0169e3b5690980819a8b8be39750efb0c4"}}
{"type":"message","id":"eceabf03","parentId":"af3150df","timestamp":"2026-04-18T16:46:48.667Z","message":{"role":"toolResult","toolCallId":"call_TUjbKXzAzI3agL5xUPYWStTF|fc_0fad9e409c19087f0169e3b57690b8819a81764be9d1ded584","toolName":"read","content":[{"type":"text","text":"                lo = ref_price * 0.98\n                hi = ref_price * 1.02\n                price_str = f\"参考价{vwap60:.2f}（区间{lo:.2f}~{hi:.2f}）\"\n            else:\n                price_str = f\"现价{close:.2f}\"\n            lines_msg.append(f\"{i}. {code}｜{price_str}\")\n            lines_msg.append(f\"   原因：{reason}｜得分{score:.4f}\")\n        lines_msg.append(\"\")\n        lines_msg.append(\"⚠️ 变化：\" + \"；\".join(reasons))\n        lines_msg.append(\"\")\n        lines_msg.append(\"🔔 风险提示：盘中价格波动较大，信号仅供参考\")\n        msg_text = \"\\n\".join(lines_msg)\n        result = _send_feishu_message(token, cfg[\"open_id\"], \"text\", {\"text\": msg_text})\n        if result.get(\"code\") == 0:\n            print(f\"[PUSH] candidate change pushed to feishu: {', '.join(reasons)}\")\n        else:\n            print(f\"[PUSH] feishu push failed: {result}\")\n    except Exception as e:\n        print(f\"[PUSH] candidate change push failed: {e}\")\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"Generate same-day live smallcap candidates\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD, default today\")\n    parser.add_argument(\"--realtime\", action=\"store_true\", default=False, help=\"Fetch real-time close prices from Tencent API\")\n    parser.add_argument(\"--force-realtime\", action=\"store_true\", default=False, help=\"Force realtime mode regardless of market hours\")\n    parser.add_argument(\"--no-realtime\", action=\"store_true\", default=False, help=\"Disable realtime mode (use CSV only)\")\n    parser.add_argument(\"--price-src\", default=str(DEFAULT_PRICE_CSV))\n    parser.add_argument(\"--basic-src\", default=str(DEFAULT_BASIC_CSV))\n    parser.add_argument(\"--config\", default=str(DEFAULT_CONFIG))\n    parser.add_argument(\"--main-output\", default=\"\")\n    parser.add_argument(\"--guard-output\", default=\"\")\n    parser.add_argument(\"--summary-output\", default=\"\")\n    parser.add_argument(\"--main-count\", type=int, default=10)\n    parser.add_argument(\"--guard-count\", type=int, default=8)\n    parser.add_argument(\"--main-target-weight\", type=float, default=0.10)\n    parser.add_argument(\"--guard-target-weight\", type=float, default=0.08)\n    parser.add_argument(\"--overwrite\", action=\"store_true\")\n    parser.add_argument(\"--max-price-lag-days\", type=int, default=3, help=\"价格源相对目标日允许的最大日历滞后\")\n    parser.add_argument(\"--max-basic-lag-days\", type=int, default=7, help=\"daily_basic 相对目标日允许的最大日历滞后\")\n    args = parser.parse_args()\n\n    date_tag = args.date.strip() or datetime.now().strftime(\"%Y%m%d\")\n    target_date = int(date_tag)\n    main_path = main_output_path(date_tag, args.main_output)\n    guard_path = guard_output_path(date_tag, args.guard_output)\n    summary_path = summary_output_path(date_tag, args.summary_output)\n\n    summary: dict[str, Any] = {\n        \"generated_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"date_tag\": date_tag,\n        \"target_trade_date\": date_tag,\n        \"price_src\": str(Path(args.price_src)),\n        \"basic_src\": str(Path(args.basic_src)),\n        \"config\": str(Path(args.config)),\n        \"market_trade_date\": \"\",\n        \"daily_basic_trade_date\": \"\",\n        \"outputs\": {},\n        \"top_preview\": {},\n        \"status\": \"PASS\",\n        \"reason\": \"\",\n    }\n\n    try:\n        cfg = load_smallcap_config(Path(args.config))\n        price_frame = load_price_history(Path(args.price_src), target_date)\n        \n        use_realtime = (args.realtime or args.force_realtime) or (\n            not args.no_realtime and is_market_open()\n        )\n        if use_realtime:\n            print(f\"[REALTIME] fetching live prices for universe...\", flush=True)\n            # First get the liquid universe from CSV to know which symbols to fetch\n            temp_universe_symbols = pick_liquid_symbols(price_frame, max_symbols=300)\n            realtime_closes = fetch_realtime_closes(temp_universe_symbols)\n            if realtime_closes:\n                price_frame = inject_realtime_prices(price_frame, realtime_closes, date_tag)\n                print(f\"[REALTIME] injected {len(realtime_closes)} real-time prices\", flush=True)\n            else:\n                print(f\"[REALTIME] no prices fetched, falling back to CSV\", flush=True)\n        \n        universe, market_trade_date = build_market_snapshot(price_frame, cfg)\n        summary[\"market_trade_date\"] = market_trade_date\n\n        basic_trade_date, daily_basic = load_latest_daily_basic(Path(args.basic_src), target_date)\n        summary[\"daily_basic_trade_date\"] = basic_trade_date\n\n        price_lag_days = _calendar_lag_days(date_tag, market_trade_date)\n        basic_lag_days = _calendar_lag_days(date_tag, basic_trade_date)\n        summary[\"price_lag_days\"] = int(price_lag_days) if price_lag_days < 10**9 else None\n        summary[\"basic_lag_days\"] = int(basic_lag_days) if basic_lag_days < 10**9 else None\n        if price_lag_days > int(args.max_price_lag_days):\n            raise ValueError(f\"stale_price_source: market_trade_date={market_trade_date} lag_days={price_lag_days} target={date_tag}\")\n        if basic_trade_date and basic_lag_days > int(args.max_basic_lag_days):\n            raise ValueError(f\"stale_daily_basic_source: daily_basic_trade_date={basic_trade_date} lag_days={basic_lag_days} target={date_tag}\")\n\n        main_candidates = select_main_candidates(\n            universe,\n            limit=max(1, int(args.main_count)),\n            target_weight=max(0.0, float(args.main_target_weight)),\n        )\n        guard_candidates = build_guard_candidates(\n            universe,\n            daily_basic,\n            limit=max(1, int(args.guard_count)),\n            target_weight=max(0.0, float(args.guard_target_weight)),\n        )\n\n        summary[\"outputs\"][\"v4_2\"] = write_candidates(main_path, main_candidates, overwrite=bool(args.overwrite))\n        summary[\"outputs\"][\"v4_2b\"] = write_candidates(guard_path, guard_candidates, overwrite=bool(args.overwrite))\n\n        # --- Material change detection & Feishu push ---\n        if use_realtime and summary.get(\"status\") == \"PASS\":\n            curr_snap = compute_candidate_snapshot(main_candidates, top_n=int(args.main_count))\n            prev_snap = load_last_snapshot(date_tag)\n            has_change, reasons = detect_material_change(curr_snap, prev_snap, top_n=int(args.main_count))\n            summary[\"material_change\"] = has_change\n            summary[\"change_reasons\"] = reasons\n            save_snapshot(date_tag, curr_snap)\n            if has_change:\n                _push_candidate_change(date_tag, curr_snap, reasons, main_candidates)\n        else:\n            summary[\"material_change\"] = False\n            summary[\"change_reasons\"] = []\n\n        summary[\"top_preview\"][\"v4_2\"] = (\n            main_candidates[[\"ts_code\", \"score\"]].head(5).to_dict(orient=\"records\")\n            if not main_candidates.empty else []\n        )\n        summary[\"top_preview\"][\"v4_2b\"] = (\n            guard_candidates[[\"ts_code\", \"score\", \"guard_mode\"]].head(5).to_dict(orient=\"records\")\n            if not guard_candidates.empty else []\n        )\n        if not basic_trade_date:\n            summary[\"reason\"] = \"daily_basic_missing_guard_used_tech_fallback\"\n    except Exception as exc:\n        summary[\"status\"] = \"FAIL\"\n        summary[\"reason\"] = str(exc)\n        summary[\"outputs\"][\"v4_2\"] = {\"path\": str(main_path), \"status\": \"not_written\", \"rows\": count_csv_rows(main_path)}\n        summary[\"outputs\"][\"v4_2b\"] = {\"path\": str(guard_path), \"status\": \"not_written\", \"rows\": count_csv_rows(guard_path)}\n\n    ensure_parent(summary_path)\n    summary_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    print(json.dumps(summary, ensure_ascii=False, indent=2))\n    if summary.get(\"status\") != \"PASS\":\n        sys.exit(1)\n\n\n\ndef compute_candidate_snapshot(frame: pd.DataFrame, top_n: int = 10) -> dict[str, Any]:\n    \"\"\"Compute a hashable snapshot of top-N candidates for change detection.\"\"\"\n    if frame.empty:\n        return {\"hash\": \"\", \"codes\": [], \"scores\": {}, \"rank_order\": []}\n    top = frame.head(top_n).copy()\n    codes = top[\"ts_code\"].astype(str).tolist()\n    scores = {str(r[\"ts_code\"]): round(float(r[\"score\"]), 6) for _, r in top.iterrows()}\n    hash_input = \"|\".join(f\"{c}:{scores[c]}\" for c in codes)\n    import hashlib\n    h = hashlib.md5(hash_input.encode()).hexdigest()[:12]\n    return {\"hash\": h, \"codes\": codes, \"scores\": scores, \"rank_order\": codes}\n\n\nSNAPSHOT_DIR = REPORT_DIR / \"candidate_snapshots\"\nSNAPSHOT_DIR.mkdir(parents=True, exist_ok=True)\n\n\ndef load_last_snapshot(date_tag: str) -> dict[str, Any]:\n    snap_file = SNAPSHOT_DIR / f\"snapshot_{date_tag}.json\"\n    if not snap_file.exists():\n        # Try yesterday\n        import datetime as _dt\n        yesterday = (datetime.strptime(date_tag, \"%Y%m%d\") - _dt.timedelta(days=1)).strftime(\"%Y%m%d\")\n        snap_file = SNAPSHOT_DIR / f\"snapshot_{yesterday}.json\"\n    if snap_file.exists():\n        return json.loads(snap_file.read_text(encoding=\"utf-8\"))\n    return {\"hash\": \"\", \"codes\": [], \"scores\": {}, \"rank_order\": []}\n\n\ndef save_snapshot(date_tag: str, snapshot: dict[str, Any]) -> None:\n    snap_file = SNAPSHOT_DIR / f\"snapshot_{date_tag}.json\"\n    snap_file.write_text(json.dumps(snapshot, ensure_ascii=False) + \"\\n\", encoding=\"utf-8\")\n\n\ndef detect_material_change(curr: dict[str, Any], prev: dict[str, Any], top_n: int = 10) -> tuple[bool, list[str]]:\n    \"\"\"Return (has_change, change_reasons).\"\"\"\n    if prev.get(\"hash\") and curr.get(\"hash\") == prev[\"hash\"]:\n        return False, []\n    reasons = []\n    old_codes = set(prev.get(\"codes\", []))\n    new_codes = set(curr.get(\"codes\", []))\n    entered = new_codes - old_codes\n    exited = old_codes - new_codes\n    if entered:\n        reasons.append(f\"新进top{top_n}：{', '.join(sorted(entered))}\")\n    if exited:\n        reasons.append(f\"跌出top{top_n}：{', '.join(sorted(exited))}\")\n    # Rank drift for overlapping stocks\n    old_rank = {c: i for i, c in enumerate(prev.get(\"rank_order\", []))}\n    for c in sorted(old_rank.keys() & new_codes):\n        drift = abs(old_rank[c] - new_codes.index(c))\n        if drift >= 3:\n            old_score = prev[\"scores\"].get(c, 0)\n            new_score = curr[\"scores\"].get(c, 0)\n            reasons.append(f\"{c}排名变动{old_rank[c]+1}→{new_codes.index(c)+1}（得分{old_score:.4f}→{new_score:.4f}）\")\n    return bool(reasons), reasons\n\nif __name__ == \"__main__\":\n    main()\n\n"}],"isError":false,"timestamp":1776530808652}}
