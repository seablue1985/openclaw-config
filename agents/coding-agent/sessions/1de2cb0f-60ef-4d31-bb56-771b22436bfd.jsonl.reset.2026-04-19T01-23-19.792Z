{"type":"message","id":"ab68fe40","parentId":"95ee1a4c","timestamp":"2026-04-18T16:42:06.490Z","message":{"role":"toolResult","toolCallId":"call_DSXrNOCQo5BYxU073Nq4Rpqf|fc_0fad9e409c19087f0169e3b45c65d8819aaa78700349db24b5","toolName":"read","content":[{"type":"text","text":"    return {\n        \"state\": \"blocked\" if issues else \"executable\",\n        \"blocked\": bool(issues),\n        \"issues\": issues,\n    }\n\n\ndef resolve_risk_mode(profile_stats: list[dict[str, Any]]) -> str:\n    modes = unique_ordered([str(stats.get(\"mode\") or \"\").strip() for stats in profile_stats])\n    if len(modes) == 1 and modes[0]:\n        return modes[0]\n    if any(str(stats.get(\"halt_new_buy\") or \"\").lower() == \"true\" or bool(stats.get(\"halt_new_buy\")) for stats in profile_stats):\n        return \"guarded\"\n    return \"mixed\"\n\n\ndef render_candidate_table(title: str, headers: list[str], rows: list[list[str]]) -> list[str]:\n    lines = [title, \"\", \"|\" + \"|\".join(headers) + \"|\", \"|\" + \"|\".join([\"---\"] * len(headers)) + \"|\"]\n    if not rows:\n        lines.append(\"| \" + \" | \".join([\"-\"] * len(headers)) + \" |\")\n    else:\n        for row in rows:\n            lines.append(\"| \" + \" | \".join(row) + \" |\")\n    return lines\n\n\ndef build_report(date_tag: str) -> tuple[dict[str, Any], str]:\n    profile_payloads = [profile_payload(profile_slug, date_tag) for profile_slug in PAPER_PROFILES]\n    profile_stats = [payload[\"stats\"] for payload in profile_payloads]\n    all_order_rows = [row for payload in profile_payloads for row in payload[\"orders\"]]\n    missing_order_plan_profiles = [payload[\"profile_slug\"] for payload in profile_payloads if not payload.get(\"order_plan\")]\n    deduped_rows = dedupe_signal_rows(all_order_rows)\n    tech_rows, guard_rows, sell_rows = classify_candidates(deduped_rows)\n\n    comparison_metrics_path = latest_or_exact(\"paper_profiles_comparison_metrics\", date_tag, \"json\")\n    comparison_metrics = load_json(comparison_metrics_path)\n    audit_path = latest_or_exact(\"daily_strategy_audit\", date_tag, \"json\")\n    audit = load_json(audit_path)\n    governance_status = governance_gate_status(date_tag)\n    precheck_path = latest_or_exact(\"auto_premarket_precheck\", date_tag, \"json\")\n    precheck = load_json(precheck_path)\n    runtime_state_latest_path = REPORT_DIR / \"runtime_risk_state_latest.json\"\n    runtime_state_latest = load_json(runtime_state_latest_path if runtime_state_latest_path.exists() else None)\n    runtime_metrics = (runtime_state_latest.get(\"runtime_metrics\") or {}) if isinstance(runtime_state_latest, dict) else {}\n    intraday_gate = (runtime_state_latest.get(\"intraday_gate\") or {}) if isinstance(runtime_state_latest, dict) else {}\n    intraday_breadth = (runtime_state_latest.get(\"intraday_breadth\") or {}) if isinstance(runtime_state_latest, dict) else {}\n    risk_thresholds = (runtime_state_latest.get(\"risk_thresholds\") or {}) if isinstance(runtime_state_latest, dict) else {}\n    runtime_config_path = Path(runtime_state_latest.get(\"config\")) if runtime_state_latest.get(\"config\") else None\n    runtime_config = load_json(runtime_config_path)\n    merged_signal_path = ROOT / \"signals\" / \"merged\" / f\"merged_signals_{date_tag}.csv\"\n    if not merged_signal_path.exists():\n        merged_signal_path = None\n    live_merged_orders_path = ROOT / \"orders\" / \"proposed\" / f\"merged_proposed_orders_{date_tag}.csv\"\n    if not live_merged_orders_path.exists():\n        live_merged_orders_path = None\n    live_overlay_path = REPORT_DIR / f\"live_stock_analysis_overlay_{date_tag}.json\"\n    live_overlay = load_json(live_overlay_path if live_overlay_path.exists() else None)\n\n    if not deduped_rows and live_merged_orders_path is not None:\n        fallback_rows = load_csv_rows(live_merged_orders_path)\n\n[509 more lines in file. Use offset=410 to continue.]"}],"isError":false,"timestamp":1776530526480}}
