{"type":"message","id":"9641ff73","parentId":"edb097db","timestamp":"2026-04-18T16:41:22.125Z","message":{"role":"toolResult","toolCallId":"call_JLw1DOemwBpaNXHT1RG1WVxV|fc_0fad9e409c19087f0169e3b42f504c819abf5c1715f2841103","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport csv\nimport json\nimport os\nimport tempfile\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\n\nROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = ROOT / \"research\" / \"reports\"\nPAPER_PROFILES = [\"defensive\", \"balanced\", \"aggressive\"]\n\n\ndef atomic_write_text(path: Path, content: str, *, encoding: str = \"utf-8\") -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    with tempfile.NamedTemporaryFile(\"w\", encoding=encoding, dir=str(path.parent), delete=False) as handle:\n        handle.write(content)\n        tmp_path = Path(handle.name)\n    os.replace(tmp_path, path)\n\n\ndef atomic_write_json(path: Path, payload: Any) -> None:\n    atomic_write_text(path, json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef load_json(path: Path | None) -> dict[str, Any]:\n    if path is None or not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef load_csv_rows(path: Path | None) -> list[dict[str, str]]:\n    if path is None or not path.exists():\n        return []\n    with path.open(\"r\", encoding=\"utf-8-sig\", newline=\"\") as handle:\n        return list(csv.DictReader(handle))\n\n\n# 全局股票名称缓存（按ts_code索引）\n_STOCK_NAME_MAP: dict[str, str] = {}\n\n\ndef _ensure_stock_name_map() -> None:\n    \"\"\"延迟加载股票名称映射表，只在首次需要时加载一次。\"\"\"\n    global _STOCK_NAME_MAP\n    if _STOCK_NAME_MAP:\n        return\n    list_path = ROOT / \"data\" / \"tushare_a_all\" / \"a_stock_list.csv\"\n    if not list_path.exists():\n        return\n    for row in load_csv_rows(list_path):\n        ts_code = str(row.get(\"ts_code\") or \"\").strip()\n        name = str(row.get(\"name\") or \"\").strip()\n        if ts_code and name:\n            _STOCK_NAME_MAP[ts_code] = name\n\n\ndef enrich_rows_with_names(rows: list[dict[str, str]]) -> list[dict[str, str]]:\n    \"\"\"为每行补充 ai_stock_name（若该字段为空，则从股票名称表查询）。\"\"\"\n    _ensure_stock_name_map()\n    for row in rows:\n        if not str(row.get(\"ai_stock_name\") or \"\").strip():\n            ts_code = str(row.get(\"ts_code\") or \"\").strip()\n            row[\"ai_stock_name\"] = _STOCK_NAME_MAP.get(ts_code, \"\")\n    return rows\n\n\ndef latest_file(pattern: str) -> Path | None:\n    files = sorted(REPORT_DIR.glob(pattern))\n    return files[-1] if files else None\n\n\ndef resolve_date_tag(explicit_date_tag: str | None) -> str:\n    if explicit_date_tag:\n        return explicit_date_tag\n\n    tags: list[str] = []\n\n    metrics_path = latest_file(\"paper_profiles_comparison_metrics_*.json\")\n    metrics = load_json(metrics_path)\n    if metrics.get(\"date_tag\"):\n        tags.append(str(metrics[\"date_tag\"]))\n\n    account_candidates = sorted(REPORT_DIR.glob(\"paper_*_account_v1_latest.json\"))\n    for path in account_candidates:\n        payload = load_json(path)\n        if payload.get(\"date_tag\"):\n            tags.append(str(payload[\"date_tag\"]))\n\n    latest_live_system = latest_file(\"live_system_v1_*.json\")\n    if latest_live_system:\n        tags.append(latest_live_system.stem.rsplit(\"_\", 1)[-1])\n\n    merged_dir = ROOT / \"signals\" / \"merged\"\n    merged_candidates = sorted(merged_dir.glob(\"merged_signals_*.csv\"))\n    if merged_candidates:\n        tags.append(merged_candidates[-1].stem.rsplit(\"_\", 1)[-1])\n\n    valid_tags = [tag for tag in tags if tag.isdigit() and len(tag) == 8]\n    if valid_tags:\n        return max(valid_tags)\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef latest_or_exact(pattern_prefix: str, date_tag: str, suffix: str) -> Path | None:\n    exact = REPORT_DIR / f\"{pattern_prefix}_{date_tag}.{suffix}\"\n    if exact.exists():\n        return exact\n    candidates = sorted(REPORT_DIR.glob(f\"{pattern_prefix}_*.{suffix}\"))\n    if not candidates:\n        return None\n    eligible = [path for path in candidates if path.stem.rsplit(\"_\", 1)[-1] <= date_tag]\n    return eligible[-1] if eligible else candidates[-1]\n\n\ndef path_date_tag(path: Path | None) -> str:\n    if path is None:\n        return \"\"\n    stem = path.stem\n    tail = stem.rsplit(\"_\", 1)[-1]\n    return tail if len(tail) == 8 and tail.isdigit() else \"\"\n\n\ndef governance_gate_status(date_tag: str) -> dict[str, Any]:\n    path = latest_or_exact(\"strategy_governance_gate\", date_tag, \"json\") or (REPORT_DIR / \"strategy_governance_gate_latest.json\")\n    payload = load_json(path if path and path.exists() else None)\n    if not payload:\n        return {\n            \"report_status\": \"MISSING\",\n            \"blocking\": True,\n            \"issues\": [\"missing_governance_gate_report\"],\n            \"path\": str(path) if path else \"\",\n            \"generated_at\": \"\",\n        }\n    report_status = str(payload.get(\"overall_status\") or \"UNKNOWN\").upper()\n    issues = [str(item).strip() for item in (payload.get(\"blocking_issues\") or []) if str(item).strip()]\n    manual_review = payload.get(\"manual_review\") or {}\n    manual_review_decisions = [\n        f\"{str(item.get('strategy_id') or '').strip()}:{str(item.get('suggested_action') or '').strip()}\"\n        for item in (manual_review.get(\"decisions\") or [])\n        if str(item.get(\"strategy_id\") or \"\").strip()\n    ]\n    return {\n        \"report_status\": report_status,\n        \"blocking\": report_status != \"PASS\" or bool(issues),\n        \"issues\": issues,\n        \"path\": str(path) if path else \"\",\n        \"generated_at\": str(payload.get(\"generated_at\") or \"\"),\n        \"manual_review_available\": bool(manual_review.get(\"available\")),\n        \"manual_review_signoff_pending\": bool(manual_review.get(\"signoff_pending\")),\n        \"manual_review_decisions\": manual_review_decisions,\n        \"manual_review_path\": str(manual_review.get(\"source_json\") or \"\"),\n    }\n\n\ndef to_float(value: Any, default: float = 0.0) -> float:\n    try:\n        return float(str(value).replace(\",\", \"\").strip())\n    except Exception:\n        return default\n\n\ndef to_bool(value: Any) -> bool:\n    if isinstance(value, bool):\n        return value\n    return str(value).strip().lower() in {\"1\", \"true\", \"yes\", \"y\"}\n\n\ndef unique_ordered(items: list[str]) -> list[str]:\n    return list(dict.fromkeys(item for item in items if item))\n\n\ndef parse_counter_map(value: Any) -> dict[str, int]:\n    if isinstance(value, dict):\n        return {\n            str(k): int(to_float(v))\n            for k, v in value.items()\n            if str(k).strip()\n        }\n    text = str(value or \"\").strip()\n    if not text:\n        return {}\n    try:\n        parsed = json.loads(text)\n    except Exception:\n        return {}\n    if not isinstance(parsed, dict):\n        return {}\n    return {\n        str(k): int(to_float(v))\n        for k, v in parsed.items()\n        if str(k).strip()\n    }\n\n\ndef fmt_pct(value: Any, digits: int = 2) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{to_float(value):.{digits}f}\"\n\n\ndef fmt_ratio_pct(value: Any, digits: int = 2) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{to_float(value) * 100.0:.{digits}f}\"\n\n\ndef profile_payload(profile_slug: str, date_tag: str) -> dict[str, Any]:\n    order_plan_candidate = REPORT_DIR / f\"paper_{profile_slug}_order_plan_v1_{date_tag}.json\"\n    merged_orders_candidate = REPORT_DIR / f\"paper_{profile_slug}_merged_proposed_orders_{date_tag}.csv\"\n    order_plan_path = order_plan_candidate if order_plan_candidate.exists() else None\n    merged_orders_path = merged_orders_candidate if merged_orders_candidate.exists() else None\n    order_plan = load_json(order_plan_path)\n    return {\n        \"profile_slug\": profile_slug,\n        \"order_plan_path\": order_plan_path,\n        \"merged_orders_path\": merged_orders_path,\n        \"order_plan\": order_plan,\n        \"stats\": order_plan.get(\"stats\", {}) or {},\n        \"orders\": load_csv_rows(merged_orders_path),\n    }\n\n\ndef extract_runtime_snapshot_from_precheck(precheck: dict[str, Any]) -> dict[str, Any]:\n    parsed = (((precheck or {}).get(\"result\") or {}).get(\"parsed\") or {})\n    stats = (parsed.get(\"stats\") or {}) if isinstance(parsed, dict) else {}\n\n    gate_reasons = parsed.get(\"gate_reasons\")\n    if isinstance(gate_reasons, str):\n        gate_reasons = [bit.strip() for bit in gate_reasons.split(\"|\") if bit.strip()]\n    elif not isinstance(gate_reasons, list):\n        gate_reasons = []\n\n    if not gate_reasons and isinstance(stats.get(\"gate_reasons\"), str):\n        gate_reasons = [bit.strip() for bit in str(stats.get(\"gate_reasons\") or \"\").split(\"|\") if bit.strip()]\n\n    return {\n        \"mode\": parsed.get(\"mode\") or stats.get(\"mode\"),\n        \"risk_off\": parsed.get(\"risk_off\") if parsed.get(\"risk_off\") is not None else stats.get(\"risk_off\"),\n        \"hard_stop\": parsed.get(\"hard_stop\") if parsed.get(\"hard_stop\") is not None else stats.get(\"hard_stop\"),\n        \"halt_new_buy\": parsed.get(\"halt_new_buy\") if parsed.get(\"halt_new_buy\") is not None else stats.get(\"halt_new_buy\"),\n        \"market_breadth\": parsed.get(\"market_breadth\") if parsed.get(\"market_breadth\") is not None else stats.get(\"market_breadth\"),\n        \"halt_reason\": parsed.get(\"halt_reason\") or stats.get(\"halt_reason\") or precheck.get(\"halt_reason\") or precheck.get(\"status_reason\"),\n        \"gate_reasons\": gate_reasons,\n        \"decision_eligible_buy_count\": stats.get(\"decision_eligible_buy_count\"),\n        \"blocked_buy_halt\": stats.get(\"blocked_buy_halt\"),\n        \"buy_count\": stats.get(\"buy_count\"),\n        \"sell_count\": stats.get(\"sell_count\"),\n        \"authoritative\": bool(parsed or stats),\n    }\n\n\ndef dedupe_signal_rows(rows: list[dict[str, str]]) -> list[dict[str, str]]:\n    merged: dict[tuple[str, str], dict[str, str]] = {}\n    for row in rows:\n\n[658 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776530482115}}
{"type":"message","id":"6bb164f1","parentId":"9641ff73","timestamp":"2026-04-18T16:41:22.136Z","message":{"role":"toolResult","toolCallId":"call_K0RiN9KHwEaZTrvTLaKj2eIM|fc_0fad9e409c19087f0169e3b42f5054819ab7bebf40f1587807","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nimport urllib.request\nfrom typing import Any\n\nimport sys\nimport numpy as np\nimport pandas as pd\nimport yaml\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nDEFAULT_PRICE_CSV = Path(\"/Users/ling/.openclaw/workspace/data/a_stock_history.csv\")\nDEFAULT_BASIC_CSV = PROJECT_ROOT / \"data\" / \"daily_basic_all_2019_2026.csv\"\nDEFAULT_CONFIG = PROJECT_ROOT / \"config\" / \"strategy_smallcap_chip_candidate_top50.yaml\"\n\n\ndef count_csv_rows(path: Path) -> int:\n    if not path.exists():\n        return 0\n    try:\n        with path.open(\"r\", encoding=\"utf-8\", newline=\"\") as handle:\n            return max(0, sum(1 for _ in handle) - 1)\n    except Exception:\n        return 0\n\n\ndef ensure_parent(path: Path) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n\n\ndef load_smallcap_config(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    payload = yaml.safe_load(path.read_text(encoding=\"utf-8\")) or {}\n    return payload.get(\"smallcap_chip\", payload)\n\n\ndef pick_liquid_symbols(frame: pd.DataFrame, max_symbols: int) -> list[str]:\n    latest_dates = sorted(frame[\"date\"].dropna().unique())\n    if not latest_dates:\n        return []\n    cutoff = latest_dates[max(0, len(latest_dates) - 60)]\n    recent = frame[frame[\"date\"] >= cutoff]\n    ranked = (\n        recent.groupby(\"ts_code\", as_index=False)[\"amount\"]\n        .mean()\n        .sort_values(\"amount\", ascending=False)\n        .head(max_symbols)\n    )\n    return sorted(ranked[\"ts_code\"].astype(str).tolist())\n\n\ndef safe_percentile(series: pd.Series, *, ascending: bool = True, fill_value: float = 0.0) -> pd.Series:\n    numeric = pd.to_numeric(series, errors=\"coerce\")\n    ranked = numeric.rank(pct=True, ascending=ascending)\n    return ranked.fillna(fill_value)\n\n\ndef load_price_history(path: Path, target_date: int) -> pd.DataFrame:\n    if not path.exists():\n        raise FileNotFoundError(path)\n\n    chunks: list[pd.DataFrame] = []\n    for chunk in pd.read_csv(\n        path,\n        usecols=[\"ts_code\", \"trade_date\", \"close\", \"vol\", \"amount\"],\n        dtype={\"ts_code\": str, \"trade_date\": int, \"close\": float, \"vol\": float, \"amount\": float},\n        chunksize=100_000,\n    ):\n        chunk = chunk[chunk[\"trade_date\"] <= target_date]\n        if not chunk.empty:\n            chunks.append(chunk)\n    if not chunks:\n        raise ValueError(f\"no_price_history_le_{target_date}\")\n    frame = pd.concat(chunks, ignore_index=True)\n\n    frame[\"date\"] = pd.to_datetime(frame[\"trade_date\"].astype(str), format=\"%Y%m%d\", errors=\"coerce\")\n    frame = frame.dropna(subset=[\"date\"]).copy()\n    if frame.empty:\n        raise ValueError(\"no_valid_price_dates\")\n\n    frame[\"ts_code\"] = frame[\"ts_code\"].astype(str).str.upper().str.strip()\n    frame[\"close\"] = pd.to_numeric(frame[\"close\"], errors=\"coerce\")\n    frame[\"amount\"] = pd.to_numeric(frame[\"amount\"], errors=\"coerce\").fillna(0.0) * 1000.0\n    frame[\"volume\"] = pd.to_numeric(frame[\"vol\"], errors=\"coerce\").fillna(0.0) * 100.0\n    frame = frame.dropna(subset=[\"ts_code\", \"close\"]).copy()\n    if frame.empty:\n        raise ValueError(\"no_valid_price_rows\")\n    return frame\n\n\ndef build_market_snapshot(frame: pd.DataFrame, cfg: dict[str, Any]) -> tuple[pd.DataFrame, str]:\n    max_symbols = int(cfg.get(\"max_symbols\", 300))\n    smallcap_pct = float(cfg.get(\"smallcap_pct\", 0.35))\n    min_turnover_20d = float(cfg.get(\"min_turnover_20d\", 30_000_000))\n    w_m20 = float(cfg.get(\"w_m20\", 0.55))\n    w_m60 = float(cfg.get(\"w_m60\", 0.45))\n    w_break = float(cfg.get(\"w_break\", 0.25))\n    w_near = float(cfg.get(\"w_near\", 0.05))\n    chip_near_threshold = float(cfg.get(\"chip_near_threshold\", 0.07))\n    volume_break_ratio = float(cfg.get(\"volume_break_ratio\", 1.3))\n\n    selected = pick_liquid_symbols(frame, max_symbols=max_symbols)\n    scoped = frame[frame[\"ts_code\"].isin(selected)].copy()\n    if scoped.empty:\n        raise ValueError(\"liquid_universe_empty\")\n\n    close = scoped.pivot(index=\"date\", columns=\"ts_code\", values=\"close\").sort_index()\n    amount = scoped.pivot(index=\"date\", columns=\"ts_code\", values=\"amount\").sort_index()\n    volume = scoped.pivot(index=\"date\", columns=\"ts_code\", values=\"volume\").sort_index()\n    if close.empty:\n        raise ValueError(\"pivot_close_empty\")\n\n    latest_date = close.index[-1]\n    latest_close = close.loc[latest_date]\n    prev_close = close.shift(1).loc[latest_date]\n    mom20 = close.pct_change(20, fill_method=None).loc[latest_date]\n    mom60 = close.pct_change(60, fill_method=None).loc[latest_date]\n    liq20 = amount.rolling(20).mean().loc[latest_date]\n\n    vwap60_full = (close * volume).rolling(60).sum() / volume.rolling(60).sum().replace(0, np.nan)\n    vwap60 = vwap60_full.loc[latest_date]\n    prev_vwap60 = vwap60_full.shift(1).loc[latest_date]\n    vol_ma20 = volume.rolling(20).mean().loc[latest_date]\n    latest_volume = volume.loc[latest_date]\n\n    chip_break = (\n        (latest_close > vwap60)\n        & (prev_close <= prev_vwap60)\n        & (latest_volume > volume_break_ratio * vol_ma20)\n    ).fillna(False)\n    chip_near = (((latest_close - vwap60).abs() / vwap60.replace(0, np.nan)) <= chip_near_threshold).fillna(False)\n\n    eligible = mom20.notna() & mom60.notna() & liq20.notna() & (liq20 >= min_turnover_20d)\n    eligible_codes = eligible[eligible].index.tolist()\n    if not eligible_codes:\n        raise ValueError(\"eligible_universe_empty\")\n\n    m20_rank = safe_percentile(mom20[eligible_codes], ascending=True)\n    m60_rank = safe_percentile(mom60[eligible_codes], ascending=True)\n    liq_rank = safe_percentile(liq20[eligible_codes], ascending=True)\n    smallcap_mask = liq_rank <= smallcap_pct\n\n    tech_score = (\n        w_m20 * m20_rank\n        + w_m60 * m60_rank\n        + w_break * chip_break[eligible_codes].astype(float)\n        + w_near * chip_near[eligible_codes].astype(float)\n    )\n    tech_score = tech_score[smallcap_mask].sort_values(ascending=False)\n    if tech_score.empty:\n        raise ValueError(\"tech_score_empty_after_smallcap_filter\")\n\n    universe = pd.DataFrame({\"ts_code\": tech_score.index, \"tech_score\": tech_score.values})\n    universe[\"close\"] = pd.to_numeric(latest_close.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"mom20\"] = pd.to_numeric(mom20.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"mom60\"] = pd.to_numeric(mom60.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"liq20\"] = pd.to_numeric(liq20.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"vwap60\"] = pd.to_numeric(vwap60.reindex(universe[\"ts_code\"]).values, errors=\"coerce\")\n    universe[\"volume_break\"] = chip_break.reindex(universe[\"ts_code\"]).fillna(False).astype(bool).values\n    universe[\"chip_near\"] = chip_near.reindex(universe[\"ts_code\"]).fillna(False).astype(bool).values\n    universe[\"tech_rank\"] = safe_percentile(universe[\"tech_score\"], ascending=True)\n    universe[\"source_trade_date\"] = latest_date.strftime(\"%Y%m%d\")\n    universe = universe.sort_values([\"tech_score\", \"ts_code\"], ascending=[False, True]).reset_index(drop=True)\n    return universe, latest_date.strftime(\"%Y%m%d\")\n\n\ndef load_latest_daily_basic(path: Path, target_date: int) -> tuple[str, pd.DataFrame]:\n    if not path.exists():\n        return \"\", pd.DataFrame()\n\n    chunks: list[pd.DataFrame] = []\n    for chunk in pd.read_csv(\n        path,\n        usecols=[\"ts_code\", \"trade_date\", \"total_mv\", \"circ_mv\", \"turnover_rate\", \"pe\", \"pb\", \"ps\"],\n        dtype={\"ts_code\": str, \"trade_date\": int, \"total_mv\": float, \"circ_mv\": float, \"turnover_rate\": float, \"pe\": float, \"pb\": float, \"ps\": float},\n        chunksize=100_000,\n    ):\n        chunk = chunk[chunk[\"trade_date\"] <= target_date]\n        if not chunk.empty:\n            chunks.append(chunk)\n    if not chunks:\n        return \"\", pd.DataFrame()\n\n    frame = pd.concat(chunks, ignore_index=True)\n    latest_trade_date = int(frame[\"trade_date\"].max())\n    frame = frame[frame[\"trade_date\"] == latest_trade_date].copy()\n    frame[\"ts_code\"] = frame[\"ts_code\"].astype(str).str.upper().str.strip()\n    for col in [\"total_mv\", \"circ_mv\", \"turnover_rate\", \"pe\", \"pb\", \"ps\"]:\n        frame[col] = pd.to_numeric(frame[col], errors=\"coerce\")\n    return str(latest_trade_date), frame\n\n\ndef select_main_candidates(\n    universe: pd.DataFrame,\n    *,\n    limit: int,\n    target_weight: float,\n) -> pd.DataFrame:\n    picked = universe.head(limit).copy()\n    picked[\"score\"] = picked[\"tech_score\"].round(6)\n    picked[\"target_weight\"] = round(float(target_weight), 4)\n    picked[\"comment\"] = \"auto_live_v4_2\"\n    return picked[\n        [\n            \"ts_code\",\n            \"score\",\n            \"target_weight\",\n            \"comment\",\n            \"source_trade_date\",\n            \"close\",\n            \"mom20\",\n            \"mom60\",\n            \"liq20\",\n            \"vwap60\",\n            \"volume_break\",\n            \"chip_near\",\n            \"tech_score\",\n        ]\n    ].copy()\n\n\ndef build_guard_candidates(\n    universe: pd.DataFrame,\n    daily_basic: pd.DataFrame,\n    *,\n    limit: int,\n    target_weight: float,\n) -> pd.DataFrame:\n    merged = universe.merge(\n        daily_basic[[\"ts_code\", \"turnover_rate\", \"pe\", \"pb\", \"ps\", \"total_mv\", \"circ_mv\"]],\n        on=\"ts_code\",\n        how=\"left\",\n    )\n    merged[\"guard_mode\"] = \"fundamental_guard\"\n\n    valid = merged[\n        (pd.to_numeric(merged[\"turnover_rate\"], errors=\"coerce\") >= 0.8)\n        & (pd.to_numeric(merged[\"pb\"], errors=\"coerce\") > 0)\n        & (pd.to_numeric(merged[\"ps\"], errors=\"coerce\") > 0)\n    ].copy()\n\n    if valid.empty:\n        fallback = universe.head(limit).copy()\n        fallback[\"score\"] = fallback[\"tech_score\"].round(6)\n        fallback[\"target_weight\"] = round(float(target_weight), 4)\n        fallback[\"comment\"] = \"auto_live_v4_2b_tech_fallback\"\n        fallback[\"guard_mode\"] = \"tech_fallback_no_basic\"\n        for col in [\"turnover_rate\", \"pe\", \"pb\", \"ps\", \"total_mv\", \"circ_mv\", \"guard_score\"]:\n            fallback[col] = np.nan\n        return fallback[\n            [\n                \"ts_code\",\n                \"score\",\n\n[468 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776530482125}}
{"type":"message","id":"ad36592a","parentId":"6bb164f1","timestamp":"2026-04-18T16:41:22.146Z","message":{"role":"toolResult","toolCallId":"call_OmYTTFjP13mgQBNSfdtitNei|fc_0fad9e409c19087f0169e3b42f505c819a8f9c1ce1c7610f3d","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nimport math\nimport os\nimport sys\nfrom contextlib import contextmanager\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\nfrom typing import Any\n\nimport pandas as pd\n\nDEFAULT_DSA_ROOT = Path(\n    os.getenv(\n        \"STOCK_ANALYSIS_PROJECT_ROOT\",\n        \"/Users/ling/.openclaw/workspace/quant_projects/daily_stock_analysis\",\n    )\n).resolve()\nDEFAULT_CACHE_MAX_AGE_HOURS = 24.0\nDEFAULT_MAX_WORKERS = 3\nPOSITIVE_ADVICES = {\"买入\", \"加仓\"}\nCAUTION_ADVICES = {\"持有\", \"观望\"}\nNEGATIVE_ADVICES = {\"减仓\", \"卖出\"}\nBEARISH_TRENDS = {\"看空\", \"强烈看空\"}\nNEUTRAL_TRENDS = {\"震荡\"}\nDEFAULT_OVERLAY_PROFILE = \"balanced_plus_v4\"\nEXECUTION_OVERLAY_PROFILE = \"execution_consistent_v5\"\nOVERLAY_RULE_PROFILES: dict[str, dict[str, float | bool | None]] = {\n    \"baseline_v1\": {\n        \"hold_caution_scale\": 0.50,\n        \"watch_caution_scale\": 0.25,\n        \"negative_sell_scale\": 0.25,\n        \"negative_reduce_scale\": 0.50,\n        \"bearish_caution_cap\": 0.25,\n        \"low_score_caution_cap\": 0.25,\n        \"neutral_low_score_cap\": 0.50,\n        \"hold_mid_non_bear_scale\": None,\n        \"watch_bearish_low_score_block\": False,\n        \"watch_bearish_oversold_scale\": None,\n        \"watch_non_bear_low40_scale\": None,\n    },\n    \"tight_hold_v2\": {\n        \"hold_caution_scale\": 0.50,\n        \"watch_caution_scale\": 0.25,\n        \"negative_sell_scale\": 0.25,\n        \"negative_reduce_scale\": 0.50,\n        \"bearish_caution_cap\": 0.25,\n        \"low_score_caution_cap\": 0.25,\n        \"neutral_low_score_cap\": 0.50,\n        \"hold_mid_non_bear_scale\": 0.25,\n        \"watch_bearish_low_score_block\": False,\n        \"watch_bearish_oversold_scale\": None,\n        \"watch_non_bear_low40_scale\": None,\n    },\n    \"balanced_v3\": {\n        \"hold_caution_scale\": 0.50,\n        \"watch_caution_scale\": 0.25,\n        \"negative_sell_scale\": 0.25,\n        \"negative_reduce_scale\": 0.50,\n        \"bearish_caution_cap\": 0.25,\n        \"low_score_caution_cap\": 0.25,\n        \"neutral_low_score_cap\": 0.50,\n        \"hold_mid_non_bear_scale\": 0.25,\n        \"watch_bearish_low_score_block\": False,\n        \"watch_bearish_oversold_scale\": 0.75,\n        \"watch_non_bear_low40_scale\": 0.50,\n    },\n    \"balanced_plus_v4\": {\n        \"hold_caution_scale\": 0.50,\n        \"watch_caution_scale\": 0.25,\n        \"negative_sell_scale\": 0.25,\n        \"negative_reduce_scale\": 0.50,\n        \"bearish_caution_cap\": 0.25,\n        \"low_score_caution_cap\": 0.25,\n        \"neutral_low_score_cap\": 0.50,\n        \"hold_mid_non_bear_scale\": 0.25,\n        \"watch_bearish_low_score_block\": False,\n        \"watch_bearish_oversold_scale\": 0.75,\n        \"watch_non_bear_low40_scale\": 0.75,\n    },\n    \"execution_consistent_v5\": {\n        \"hold_caution_scale\": 0.50,\n        \"watch_caution_scale\": 0.25,\n        \"negative_sell_scale\": 0.25,\n        \"negative_reduce_scale\": 0.50,\n        \"bearish_caution_cap\": 0.25,\n        \"low_score_caution_cap\": 0.25,\n        \"neutral_low_score_cap\": 0.50,\n        \"hold_mid_non_bear_scale\": 0.25,\n        \"watch_bearish_low_score_block\": True,\n        \"watch_bearish_oversold_scale\": None,\n        \"watch_non_bear_low40_scale\": 0.75,\n    },\n}\n\n\ndef parse_float(value: Any, default: float = 0.0) -> float:\n    try:\n        parsed = float(str(value).replace(\",\", \"\").strip())\n        return parsed if math.isfinite(parsed) else default\n    except Exception:\n        return default\n\n\ndef normalize_tushare_code(value: Any) -> str:\n    raw = str(value or \"\").strip().upper()\n    if not raw or raw == \"NAN\":\n        return \"\"\n    raw = raw.replace(\".XSHG\", \".SH\").replace(\".XSHE\", \".SZ\")\n    if raw.endswith((\".SH\", \".SZ\", \".BJ\", \".HK\")):\n        return raw\n    if raw.startswith(\"SH\") and len(raw) >= 8:\n        return f\"{raw[2:8]}.SH\"\n    if raw.startswith(\"SZ\") and len(raw) >= 8:\n        return f\"{raw[2:8]}.SZ\"\n    if raw.isdigit() and len(raw) == 6:\n        market = \"SH\" if raw.startswith((\"5\", \"6\", \"9\")) else \"SZ\"\n        return f\"{raw}.{market}\"\n    return raw\n\n\ndef safe_text(value: Any, limit: int = 180) -> str:\n    text = \" \".join(str(value or \"\").replace(\"\\r\", \" \").replace(\"\\n\", \" \").split())\n    return text[:limit].strip()\n\n\ndef safe_note_value(value: Any, limit: int = 120) -> str:\n    return safe_text(value, limit=limit).replace(\";\", \" \").replace(\"=\", \":\")\n\n\ndef extract_technical_indicator_payload(dashboard: dict[str, Any]) -> dict[str, Any]:\n    technical = dashboard.get(\"technical_indicators\") if isinstance(dashboard, dict) else {}\n    if not isinstance(technical, dict):\n        technical = {}\n    rsi14_raw = technical.get(\"rsi14\")\n    rsi14: float | None = None\n    if str(rsi14_raw).strip() not in {\"\", \"None\", \"nan\", \"NaN\"}:\n        parsed = parse_float(rsi14_raw, float(\"nan\"))\n        if math.isfinite(parsed):\n            rsi14 = round(parsed, 2)\n    return {\n        \"rsi14\": rsi14,\n        \"rsi_signal\": safe_text(technical.get(\"rsi_signal\"), 20),\n    }\n\n\ndef advice_contains(advice: str, keywords: set[str]) -> bool:\n    text = str(advice or \"\").strip()\n    return any(keyword in text for keyword in keywords)\n\n\ndef list_overlay_profiles() -> list[str]:\n    return sorted(OVERLAY_RULE_PROFILES.keys())\n\n\ndef normalize_overlay_profile_name(profile_name: str | None) -> str:\n    if not profile_name:\n        return DEFAULT_OVERLAY_PROFILE\n    slug = str(profile_name).strip().lower()\n    if slug not in OVERLAY_RULE_PROFILES:\n        raise ValueError(\n            f\"unknown overlay profile: {profile_name}; available={','.join(list_overlay_profiles())}\"\n        )\n    return slug\n\n\ndef resolve_overlay_profile(profile_name: str | None = None) -> dict[str, float | bool | None]:\n    return dict(OVERLAY_RULE_PROFILES[normalize_overlay_profile_name(profile_name)])\n\n\ndef build_report_prefix(profile_slug: str = \"\", scope: str = \"paper\") -> str:\n    slug = str(profile_slug or \"\").strip()\n    if scope == \"live\":\n        return \"live\"\n    return f\"paper_{slug}\" if slug else \"paper\"\n\n\ndef overlay_report_paths(report_dir: Path, date_tag: str, report_prefix: str) -> dict[str, Path]:\n    stem = f\"{report_prefix}_stock_analysis_overlay_{date_tag}\"\n    return {\n        \"json\": report_dir / f\"{stem}.json\",\n        \"md\": report_dir / f\"{stem}.md\",\n    }\n\n\n@contextmanager\ndef dsa_runtime_context(dsa_root: Path):\n    previous_cwd = Path.cwd()\n    previous_env = {\n        \"ENV_FILE\": os.environ.get(\"ENV_FILE\"),\n        \"DATABASE_PATH\": os.environ.get(\"DATABASE_PATH\"),\n        \"LOG_DIR\": os.environ.get(\"LOG_DIR\"),\n    }\n    os.environ[\"ENV_FILE\"] = str(dsa_root / \".env\")\n    os.environ[\"DATABASE_PATH\"] = str(dsa_root / \"data\" / \"stock_analysis.db\")\n    os.environ[\"LOG_DIR\"] = str(dsa_root / \"logs\")\n    if str(dsa_root) not in sys.path:\n        sys.path.insert(0, str(dsa_root))\n    os.chdir(dsa_root)\n    try:\n        yield\n    finally:\n        os.chdir(previous_cwd)\n        for key, value in previous_env.items():\n            if value is None:\n                os.environ.pop(key, None)\n            else:\n                os.environ[key] = value\n\n\ndef load_dsa_runtime(dsa_root: Path) -> dict[str, Any]:\n    with dsa_runtime_context(dsa_root):\n        from src.config import Config, get_config, setup_env  # type: ignore\n\n        setup_env(override=True)\n        Config.reset_instance()\n        config = get_config()\n        config.single_stock_notify = False\n\n[582 more lines in file. Use offset=221 to continue.]"}],"isError":false,"timestamp":1776530482136}}
{"type":"message","id":"0260be4b","parentId":"ad36592a","timestamp":"2026-04-18T16:41:43.206Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Evaluating stock report patches**\n\nI’m considering how to patch the `generate_today_stock_strategy_report` function to reflect freshness, since the user requested ongoing fixes. We’ve already addressed overlays, but it seems I may need to inspect how it renders `ai_realtime_price` and check for column headings to add `ai_realtime_source` and freshness indicators. I also want to look into how the decision bridge uses rows, especially ensuring that `ai_realtime_confirmed` is part of the report for clarity. I’ll keep digging into what needs to be patched.","thinkingSignature":"{\"id\":\"rs_0fad9e409c19087f0169e3b43dd458819a870d02a8bb6ba3ed\",\"type\":\"reasoning\",\"encrypted_content\":\"gAAAAABp47RDWZuol142emymTFqtWXqQWI0Z85n-6V4MBpVCwSlOTbsS0ODlLeL2h__KpVVHtPnrEMOaxv8e9rAszeQ3USGhhQjQDf0l9H9KBEBnRO_dE9tVqfMJHyEZD3VqUgbOWfPFijS0lHb6k89PBha1Q7itVstOs8d-QJUWvR9EL8EFZvz5zrTbSWgDO7yIc31aTTmWtwIR6rSEdCNUb3DLOk4O7aCdhOeqAjTzHFQZDfVr1pK-pb0LpT9JmZQJxJEAobcEG25y29byEMsVtvsMl3fgvXx-sEeJjCDkrv33slj1pqMgbxWsO2-jyfF-Rr4sRanNkIwAxBXYzbGwHncXknKDenEFwdxuG_vZcYzT9AYJZuQQu2aoITL6eNvtEYRHuehptgDDZLpTIwt0pEsy1e5b1VPFzXnalGnrF1x8MVdfYnZh5PnDKjaQy4sVaWFsd-Ae7Xj9E8HcTFlAv4tjg_zWkFEoJB1ZfTSk7A06MRCFMIMyiH78bEj8mYuAb1Q0umx8IGyIZs8VVOecWgDUUBgde01CjFlQ4q_HEYraY_jvV1AQTMei7Jzg8taLFM0OH5S1xR7Y7avRtQDcHM2HQq1TJQo5ru0E7uo_1-S9Re09IlN3KSNvBwT83HogSdK32OzlIr7ttg2QkZQVLfYE-_ra-x_Xz4FHhIIRp9A9T8WforTfQdGFtWMd87bWcMEknnRB9PRvb-N6IVXrSN5wM9ipr05lWy5kr3ZntSGkqkwTaubLXKBFomJOo3NF2Mfb8HQ7TUP0YYEpBwvxN7QutgtomTjQPFqpVQ1ftRbHncCFkW43yxGVqsoMVcJcCZMoSSDlwWyZZi-ptOHGulEzl-DpqAflg1Iak2Hj3ggeRfQskQ3byA9KIx1rrZ84wS2Uy1FBK0rszX19Yp0EB5u-SanDbVY8g0hZ5lvlmPywjF1KRALJIPZ3RWMZyvkWBIBhhIIwaxHTMmHrmf2qluXYOAIdVmctgVRLyUy92ORyvh9Qwf_C7dpSGaALTvYATLE4TDptSImijAhelqBZlUgMBuYVtp2VpBaL9burDucU3B-wlyE_FRaaj8Ooi_ZewUWIY9_oPe20PgeL8sCThKu038a5xdJgWNBT0Fq4-Py