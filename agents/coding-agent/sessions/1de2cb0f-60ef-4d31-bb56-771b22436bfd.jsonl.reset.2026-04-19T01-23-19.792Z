{"type":"message","id":"a0badf63","parentId":"ce11c9bb","timestamp":"2026-04-18T15:14:17.576Z","message":{"role":"toolResult","toolCallId":"call_6hkCwsqY1WNvrHVZEkuzJAp4|fc_0fad9e409c19087f0169e39fc79c00819ab3a72aa5cde7da3b","toolName":"read","content":[{"type":"text","text":"        {{ key: \"market_value\", label: \"market_value\" }},\n        {{ key: \"unrealized_pnl\", label: \"unrealized_pnl\" }},\n        {{ key: \"unrealized_pnl_pct\", label: \"unrealized_pnl_pct\" }}\n      ];\n      downloadCsv(`${{profileSlug}}_paper_positions_${{dateTag}}.csv`, columns, positionRows);\n    }}\n\n    function filteredTrades() {{\n      const searchText = String(document.getElementById(\"tradeSymbolSearch\")?.value || \"\").trim().toUpperCase();\n      const symbolValue = String(document.getElementById(\"tradeSymbolSelect\")?.value || \"\").trim().toUpperCase();\n      const sideValue = String(document.getElementById(\"tradeSideSelect\")?.value || \"\").trim().toUpperCase();\n      const exitTypeValue = String(document.getElementById(\"tradeExitTypeSelect\")?.value || \"\").trim().toUpperCase();\n      const dateValue = String(document.getElementById(\"tradeDateSelect\")?.value || \"\").trim();\n\n      return allTrades.filter(r => {{\n        const symbol = String(r.ts_code || \"\").toUpperCase();\n        const haystack = `${{String(r.notes || \"\").toUpperCase()}} ${{String(r.signal_reason || \"\").toUpperCase()}} ${{String(r.symbol_name || \"\").toUpperCase()}} ${{String(r.exit_type || \"\").toUpperCase()}} ${{String(r.exit_reason || \"\").toUpperCase()}}`;\n        if (symbolValue && symbol !== symbolValue) return false;\n        if (sideValue && String(r.action || \"\").toUpperCase() !== sideValue) return false;\n        if (exitTypeValue && String(r.exit_type || \"\").toUpperCase() !== exitTypeValue) return false;\n        if (dateValue && String(r.date || \"\").slice(0, 10) !== dateValue) return false;\n        if (searchText && !(symbol.includes(searchText) || haystack.includes(searchText))) return false;\n        return true;\n      }});\n    }}\n\n    function exportFilteredTrades() {{\n      const rows = filteredTrades().map(r => ({{\n        date: String(r.date || \"\").slice(0, 10),\n        side: r.action || \"\",\n        symbol: r.ts_code || \"\",\n        name: r.symbol_name || \"\",\n        price: r.price,\n        shares: r.shares,\n        amount: r.amount,\n        fee: r.fee,\n        slippage: r.slippage,\n        signal_reason: r.signal_reason || \"\",\n        exit_type: r.exit_type || \"\",\n        exit_reason: r.exit_reason || \"\",\n        notes: r.notes || \"\"\n      }}));\n      const columns = [\n        {{ key: \"date\", label: \"date\" }},\n        {{ key: \"side\", label: \"side\" }},\n        {{ key: \"symbol\", label: \"symbol\" }},\n        {{ key: \"name\", label: \"name\" }},\n        {{ key: \"price\", label: \"price\" }},\n        {{ key: \"shares\", label: \"shares\" }},\n        {{ key: \"amount\", label: \"amount\" }},\n        {{ key: \"fee\", label: \"fee\" }},\n        {{ key: \"slippage\", label: \"slippage\" }},\n        {{ key: \"signal_reason\", label: \"signal_reason\" }},\n        {{ key: \"exit_type\", label: \"exit_type\" }},\n        {{ key: \"exit_reason\", label: \"exit_reason\" }},\n        {{ key: \"notes\", label: \"notes\" }}\n      ];\n      downloadCsv(`${{profileSlug}}_paper_trades_filtered_${{dateTag}}.csv`, columns, rows);\n    }}\n\n    function populateTradeDates() {{\n      const select = document.getElementById(\"tradeDateSelect\");\n      if (!select) return;\n      const dates = [...new Set(allTrades.map(x => (x.date || \"\").slice(0, 10)).filter(Boolean))].sort();\n      select.innerHTML = \"<option value=''>全部日期</option>\" + dates.map(d => `<option value=\"${{d}}\">${{d}}</option>`).join(\"\");\n    }}\n\n    function renderTradeTable() {{\n      const tbody = document.getElementById(\"tradeTable\");\n      if (!tbody) return;\n      const rows = filteredTrades();\n\n      if (!rows.length) {{\n        tbody.innerHTML = \"<tr><td colspan='12' style='text-align:center;color:#93a4c0'>没有匹配的成交记录</td></tr>\";\n        return;\n      }}\n\n      tbody.innerHTML = rows.map(r => `\n        <tr>\n          <td>${{String(r.date || \"\").slice(0, 10)}}</td>\n          <td class=\"${{String(r.action || \"\").toUpperCase() === \"BUY\" ? \"buy\" : \"sell\"}}\">${{escapeHtml(r.action || \"\")}}</td>\n          <td>${{escapeHtml(r.ts_code || \"\")}}${{r.symbol_name ? `<div class=\"symbol-name\">${{escapeHtml(r.symbol_name)}}</div>` : \"\"}}</td>\n          <td>${{fmt(r.price, 4)}}</td>\n          <td>${{fmt(r.shares, 0)}}</td>\n          <td>${{fmt(r.amount, 2)}}</td>\n          <td>${{fmt(r.fee, 2)}}</td>\n          <td>${{fmt(r.slippage, 2)}}</td>\n          <td>${{escapeHtml(r.signal_reason || \"\")}}</td>\n          <td>${{escapeHtml(r.exit_type || \"\")}}</td>\n          <td>${{escapeHtml(r.exit_reason || \"\")}}</td>\n          <td>${{escapeHtml(r.notes || \"\")}}</td>\n        </tr>\n      `).join(\"\");\n    }}\n\n    function renderCompareCurve() {{\n      const el = document.getElementById(\"compareCurve\");\n      if (!el || !perfRows.length) return;\n      Plotly.newPlot(\"compareCurve\", [\n        {{\n          x: perfRows.map(r => r.date),\n          y: perfRows.map(r => Number(r.strategy_equity || 0)),\n          mode: \"lines+markers\",\n          name: \"Strategy\",\n          line: {{ color: \"#62c8ff\", width: 2.6 }}\n        }},\n        {{\n          x: perfRows.map(r => r.date),\n          y: perfRows.map(r => Number(r.benchmark_equity || 0)),\n          mode: \"lines+markers\",\n          name: \"{benchmark_name}\",\n          line: {{ color: \"#ffb703\", width: 2.2 }}\n        }},\n        {{\n          x: perfRows.map(r => r.date),\n          y: perfRows.map(r => Number(r.excess_equity || 0)),\n          mode: \"lines\",\n          name: \"Excess\",\n          line: {{ color: \"#39c885\", width: 1.8, dash: \"dot\" }}\n        }}\n      ], {{\n        margin: {{ l: 48, r: 18, t: 8, b: 30 }},\n        paper_bgcolor: \"rgba(0,0,0,0)\",\n        plot_bgcolor: \"rgba(0,0,0,0)\",\n        xaxis: {{ showgrid: true, gridcolor: \"rgba(125,154,197,0.12)\" }},\n        yaxis: {{ title: \"Normalized Equity\", showgrid: true, gridcolor: \"rgba(125,154,197,0.12)\" }},\n        legend: {{ orientation: \"h\", y: 1.12 }}\n      }}, {{ displayModeBar: false, responsive: true }});\n    }}\n\n    function renderDailyReturnChart() {{\n      const el = document.getElementById(\"dailyReturnChart\");\n      if (!el || !perfRows.length) return;\n      Plotly.newPlot(\"dailyReturnChart\", [\n        {{\n          x: perfRows.map(r => r.date),\n          y: perfRows.map(r => Number(r.strategy_ret_pct || 0)),\n          type: \"bar\",\n          name: \"Strategy Daily %\",\n          marker: {{ color: \"#62c8ff\" }}\n        }},\n        {{\n          x: perfRows.map(r => r.date),\n          y: perfRows.map(r => Number(r.benchmark_ret_pct || 0)),\n          type: \"bar\",\n          name: \"{benchmark_name} Daily %\",\n          marker: {{ color: \"#ffb703\" }}\n        }},\n        {{\n          x: perfRows.map(r => r.date),\n          y: perfRows.map(r => Number(r.excess_ret_pct || 0)),\n          type: \"scatter\",\n          mode: \"lines+markers\",\n          name: \"Excess Daily %\",\n          line: {{ color: \"#39c885\", width: 1.8 }}\n        }}\n      ], {{\n        barmode: \"group\",\n        margin: {{ l: 48, r: 18, t: 8, b: 30 }},\n        paper_bgcolor: \"rgba(0,0,0,0)\",\n        plot_bgcolor: \"rgba(0,0,0,0)\",\n        xaxis: {{ showgrid: true, gridcolor: \"rgba(125,154,197,0.12)\" }},\n        yaxis: {{ title: \"Daily Return %\", showgrid: true, gridcolor: \"rgba(125,154,197,0.12)\" }},\n        legend: {{ orientation: \"h\", y: 1.14 }}\n      }}, {{ displayModeBar: false, responsive: true }});\n    }}\n\n    populateTradeDates();\n    renderTradeTable();\n    renderCompareCurve();\n    renderDailyReturnChart();\n    document.getElementById(\"exportPositionsBtn\")?.addEventListener(\"click\", exportPositions);\n    document.getElementById(\"exportTradesBtn\")?.addEventListener(\"click\", exportFilteredTrades);\n    document.getElementById(\"tradeSymbolSearch\")?.addEventListener(\"input\", renderTradeTable);\n    document.getElementById(\"tradeSymbolSelect\")?.addEventListener(\"change\", renderTradeTable);\n    document.getElementById(\"tradeSideSelect\")?.addEventListener(\"change\", renderTradeTable);\n    document.getElementById(\"tradeExitTypeSelect\")?.addEventListener(\"change\", renderTradeTable);\n    document.getElementById(\"tradeDateSelect\")?.addEventListener(\"change\", renderTradeTable);\n  </script>\n</body>\n</html>\n\"\"\"\n\n    out_latest = report_path(REPORT_DIR, \"dashboard_latest\", profile_slug=profile_slug)\n    out_dated = report_path(REPORT_DIR, \"dashboard_dated\", profile_slug=profile_slug, date_tag=date_tag)\n    out_latest.write_text(html_text, encoding=\"utf-8\")\n    out_dated.write_text(html_text, encoding=\"utf-8\")\n\n    metrics_file = report_path(REPORT_DIR, \"metrics\", profile_slug=profile_slug, date_tag=date_tag)\n    metrics_payload = {\n        \"generated_at\": now_str,\n        \"profile_slug\": profile_slug,\n        \"profile_name\": profile_name,\n        \"account_file\": str(account_file),\n        \"positions_file\": str(positions_file),\n        \"curve_file\": str(curve_file),\n        \"journal_file\": str(journal_file),\n        \"benchmark_name\": benchmark_name,\n        \"benchmark_file\": str(benchmark_path) if benchmark_path else \"\",\n        \"benchmark_latest_date\": benchmark_latest_date,\n        \"metrics\": metrics,\n    }\n    metrics_file.write_text(json.dumps(sanitize_for_json(metrics_payload), ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n    print(\n        json.dumps(\n            {\n                \"generated_at\": now_str,\n                \"profile_slug\": profile_slug,\n                \"profile_name\": profile_name,\n                \"dashboard_latest\": str(out_latest),\n                \"dashboard_dated\": str(out_dated),\n                \"account_file\": str(account_file),\n                \"positions_file\": str(positions_file),\n                \"curve_file\": str(curve_file),\n                \"journal_file\": str(journal_file),\n                \"benchmark_file\": str(benchmark_path) if benchmark_path else \"\",\n                \"metrics_file\": str(metrics_file),\n            },\n            ensure_ascii=False,\n            indent=2,\n        )\n    )\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1776525257563}}
