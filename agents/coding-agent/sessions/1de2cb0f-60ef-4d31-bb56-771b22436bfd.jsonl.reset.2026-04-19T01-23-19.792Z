{"type":"message","id":"1cbddc48","parentId":"2554c26f","timestamp":"2026-04-18T16:43:14.037Z","message":{"role":"toolResult","toolCallId":"call_1UNZPFqPJxaTGtpkFA4RYnds|fc_0fad9e409c19087f0169e3b49fa018819aa6f985e71d58c159","toolName":"read","content":[{"type":"text","text":"        return {\n            str(k): int(to_float(v))\n            for k, v in value.items()\n            if str(k).strip()\n        }\n    text = str(value or \"\").strip()\n    if not text:\n        return {}\n    try:\n        parsed = json.loads(text)\n    except Exception:\n        return {}\n    if not isinstance(parsed, dict):\n        return {}\n    return {\n        str(k): int(to_float(v))\n        for k, v in parsed.items()\n        if str(k).strip()\n    }\n\n\ndef fmt_pct(value: Any, digits: int = 2) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{to_float(value):.{digits}f}\"\n\n\ndef fmt_ratio_pct(value: Any, digits: int = 2) -> str:\n    if value in (None, \"\"):\n        return \"-\"\n    return f\"{to_float(value) * 100.0:.{digits}f}\"\n\n\ndef profile_payload(profile_slug: str, date_tag: str) -> dict[str, Any]:\n    order_plan_candidate = REPORT_DIR / f\"paper_{profile_slug}_order_plan_v1_{date_tag}.json\"\n    merged_orders_candidate = REPORT_DIR / f\"paper_{profile_slug}_merged_proposed_orders_{date_tag}.csv\"\n    order_plan_path = order_plan_candidate if order_plan_candidate.exists() else None\n    merged_orders_path = merged_orders_candidate if merged_orders_candidate.exists() else None\n    order_plan = load_json(order_plan_path)\n    return {\n        \"profile_slug\": profile_slug,\n        \"order_plan_path\": order_plan_path,\n        \"merged_orders_path\": merged_orders_path,\n        \"order_plan\": order_plan,\n        \"stats\": order_plan.get(\"stats\", {}) or {},\n        \"orders\": load_csv_rows(merged_orders_path),\n    }\n\n\ndef extract_runtime_snapshot_from_precheck(precheck: dict[str, Any]) -> dict[str, Any]:\n    parsed = (((precheck or {}).get(\"result\") or {}).get(\"parsed\") or {})\n    stats = (parsed.get(\"stats\") or {}) if isinstance(parsed, dict) else {}\n\n    gate_reasons = parsed.get(\"gate_reasons\")\n    if isinstance(gate_reasons, str):\n        gate_reasons = [bit.strip() for bit in gate_reasons.split(\"|\") if bit.strip()]\n    elif not isinstance(gate_reasons, list):\n        gate_reasons = []\n\n    if not gate_reasons and isinstance(stats.get(\"gate_reasons\"), str):\n        gate_reasons = [bit.strip() for bit in str(stats.get(\"gate_reasons\") or \"\").split(\"|\") if bit.strip()]\n\n    return {\n        \"mode\": parsed.get(\"mode\") or stats.get(\"mode\"),\n        \"risk_off\": parsed.get(\"risk_off\") if parsed.get(\"risk_off\") is not None else stats.get(\"risk_off\"),\n        \"hard_stop\": parsed.get(\"hard_stop\") if parsed.get(\"hard_stop\") is not None else stats.get(\"hard_stop\"),\n        \"halt_new_buy\": parsed.get(\"halt_new_buy\") if parsed.get(\"halt_new_buy\") is not None else stats.get(\"halt_new_buy\"),\n        \"market_breadth\": parsed.get(\"market_breadth\") if parsed.get(\"market_breadth\") is not None else stats.get(\"market_breadth\"),\n        \"halt_reason\": parsed.get(\"halt_reason\") or stats.get(\"halt_reason\") or precheck.get(\"halt_reason\") or precheck.get(\"status_reason\"),\n        \"gate_reasons\": gate_reasons,\n\n[669 more lines in file. Use offset=250 to continue.]"}],"isError":false,"timestamp":1776530594027}}
{"type":"message","id":"93d76dba","parentId":"1cbddc48","timestamp":"2026-04-18T16:43:26.337Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_g10KxbALmrZigQmVmOTABYMB|fc_0fad9e409c19087f0169e3b4ac23b4819a9a15e2b8feaa3230","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_today_stock_strategy_report.py","offset":732,"limit":100},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_today_stock_strategy_report.py\",\"offset\":732,\"limit\":100}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":278177,"output":52,"cacheRead":0,"cacheWrite":0,"totalTokens":278229,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776530594039,"responseId":"resp_0fad9e409c19087f0169e3b4a52544819a8232c775baa63334"}}
{"type":"message","id":"497228dd","parentId":"93d76dba","timestamp":"2026-04-18T16:43:26.393Z","message":{"role":"toolResult","toolCallId":"call_g10KxbALmrZigQmVmOTABYMB|fc_0fad9e409c19087f0169e3b4ac23b4819a9a15e2b8feaa3230","toolName":"read","content":[{"type":"text","text":"    lines.append(\n        f\"- 盘中宽度来源：`{intraday_breadth_source}` / 捕获时间：`{intraday_breadth_at}` / \"\n        f\"risk_off 允许新开仓：`{bool(allow_new_buy_when_riskoff)}`\"\n    )\n    lines.append(f\"- 当前触发原因：`{trigger_reason}`\")\n    lines.append(f\"- 当前门控摘要：`{gate_reason_text}`\")\n    lines.append(\n        f\"- 实时源分布：`{realtime_source_breakdown_total if realtime_source_breakdown_total else {}}` / \"\n        f\"分时MA来源：`{intraday_ma_source_breakdown_total if intraday_ma_source_breakdown_total else {}}`\"\n    )\n    lines.append(\"\")\n    lines.append(\"## 二、历史健康度（仅审计，不直接决定当下开平仓）\")\n    lines.append(f\"- 每日策略审计：`{audit.get('overall_status', '-')}`\")\n    lines.append(f\"- 年化：`{fmt_pct(audit.get('annual_return_pct'))}%`\")\n    lines.append(f\"- 最大回撤：`{fmt_pct(audit.get('max_drawdown_pct'))}%`\")\n    lines.append(f\"- 夏普：`{fmt_pct(audit.get('sharpe'), 3)}`\")\n    lines.append(\"- 说明：这一层用于评估策略长期健康度，不直接替代今日实时风控。\")\n    lines.append(\"\")\n    lines.append(\"## 三、今日核心结论\")\n    if recommendation_status[\"blocked\"] and governance_status.get(\"blocking\"):\n        lines.append(\"- **结论：今天不允许把研究候选继续包装成可执行买入建议，治理闸门处于 BLOCK。**\")\n        lines.append(\"- 即使候选池有分数，治理缺口未补完之前，这些标的也只能停留在研究观察层，不能进入执行建议层。\")\n        lines.append(\n            f\"- 当前研究层仍识别出 `{raw_buy_count}` 个去重 BUY 候选、`{sell_count}` 个去重 SELL 候选，但可执行 BUY 候选被压到 `0`。\"\n        )\n        lines.append(\n            f\"- 治理阻断项：`{'；'.join(governance_status.get('issues') or ['governance_block'])}`\"\n        )\n        if governance_status.get(\"manual_review_decisions\"):\n            lines.append(\n                f\"- 当前治理建议：`{'；'.join(governance_status.get('manual_review_decisions') or [])}`\"\n            )\n    elif halt_new_buy:\n        lines.append(\"- **结论：今天不建议新开仓，三套模拟盘执行层处于统一风险阻断态。**\")\n        lines.append(\"- 原因不是候选池为空，而是 `risk_off/hard_stop` 已经联动触发，新增买单被风险闸门整体拦截。\")\n        lines.append(f\"- 当前共形成 `{raw_buy_count}` 个去重 BUY 候选、`{sell_count}` 个去重 SELL 候选，但三盘合计被阻断买单 `{blocked_buy_total}` 笔。\")\n        lines.append(\"- 今日更适合保留候选优先级与风险边界，不把候选直接翻译成执行买单。\")\n    else:\n        lines.append(\"- **结论：今天允许条件化推进，但仍需先过风控门控与用户确认。**\")\n        lines.append(\"- 当前候选池可用于排序与跟踪，但不应越级跳过盘前强检与预算约束。\")\n        lines.append(f\"- 当前共形成 `{raw_buy_count}` 个去重 BUY 候选、`{sell_count}` 个去重 SELL 候选。\")\n        lines.append(\"- 今日应以‘候选池 + 触发条件 + 风控边界’作为执行前提。\")\n    lines.append(\"\")\n    lines.append(\"## 四、组合层补充指标\")\n    if comparison_trade_count <= 0:\n        lines.append(\"- 模拟盘比较面板：三盘仍处于空仓起始态，收益/夏普指标暂不具备解释力。\")\n    else:\n        lines.append(f\"- 模拟盘比较面板：最高年化 `{fmt_pct(comparison_annual)}%` / 最大回撤 `{fmt_pct(comparison_mdd)}%` / 最高夏普 `{fmt_pct(comparison_sharpe, 3)}`\")\n    lines.append(\"- 目标约束：年化 > 40%，最大回撤 <= 25%\")\n    lines.append(\"- 当前应以执行纪律优先于纸面收益展示，避免把历史强势表现误当成今日进攻依据。\")\n    lines.append(\"\")\n\n    tech_table_rows = [\n        [\n            str(idx),\n            str(row.get(\"ts_code\") or \"-\"),\n            str(row.get(\"ai_stock_name\") or \"-\"),\n            f\"{to_float(row.get('score')):.6f}\",\n            str(row.get(\"ai_realtime_source\") or \"-\"),\n            (f\"{to_float(row.get('ai_realtime_price')):.2f}\" if to_float(row.get(\"ai_realtime_price\")) > 0 else \"-\"),\n            str(row.get(\"ai_operation_advice\") or \"-\"),\n            (\"已阻断\" if halt_new_buy else (\"是\" if str(row.get(\"approved\") or \"\").strip().lower() == \"true\" and str(row.get(\"ai_decision\") or \"\").strip().lower() != \"block\" else \"否\")),\n            str(row.get(\"strategy_id\") or \"-\"),\n        ]\n        for idx, row in enumerate(display_tech_rows, start=1)\n    ]\n    lines.extend(\n        render_candidate_table(\n            \"## 五、今日选股候选池（技术候选 v4.2）\",\n            [\"排名\", \"代码\", \"名称\", \"score\", \"实时源\", \"实时价\", \"AI建议\", \"执行状态\", \"来源策略\"],\n            tech_table_rows,\n        )\n    )\n    lines.append(\"\")\n\n    guard_table_rows = [\n        [\n            str(idx),\n            str(row.get(\"ts_code\") or \"-\"),\n            str(row.get(\"ai_stock_name\") or \"-\"),\n            f\"{to_float(row.get('score')):.6f}\",\n            str(row.get(\"ai_realtime_source\") or \"-\"),\n            (f\"{to_float(row.get('ai_realtime_price')):.2f}\" if to_float(row.get(\"ai_realtime_price\")) > 0 else \"-\"),\n            str(row.get(\"ai_operation_advice\") or \"-\"),\n            (\"已阻断\" if halt_new_buy else str(row.get(\"risk_status\") or \"-\")),\n            str(row.get(\"strategy_id\") or \"-\"),\n        ]\n        for idx, row in enumerate(display_guard_rows, start=1)\n    ]\n    lines.extend(\n        render_candidate_table(\n            \"## 六、今日优先候选池（基本面守门 v4.2b）\",\n            [\"排名\", \"代码\", \"名称\", \"综合分\", \"实时源\", \"实时价\", \"AI建议\", \"当前状态\", \"来源策略\"],\n            guard_table_rows,\n        )\n    )\n    lines.append(\"\")\n    lines.append(\"## 七、今日模板信号摘要\")\n    lines.append(f\"- 可执行 BUY 候选数：`{executable_buy_count}`\")\n    lines.append(f\"- 研究层 BUY 候选数：`{raw_buy_count}`\")\n\n[87 more lines in file. Use offset=832 to continue.]"}],"isError":false,"timestamp":1776530606381}}
