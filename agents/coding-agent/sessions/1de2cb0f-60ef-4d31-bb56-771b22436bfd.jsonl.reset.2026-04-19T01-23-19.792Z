{"type":"message","id":"112626ea","parentId":"1eeb171b","timestamp":"2026-04-18T16:49:08.730Z","message":{"role":"toolResult","toolCallId":"call_iFDNernKgNo5YD41amL0mRIA|fc_0fad9e409c19087f0169e3b6025b2c819a884b898dd04348d2","toolName":"read","content":[{"type":"text","text":"    picked[\"score\"] = picked[\"guard_score\"].round(6)\n    picked[\"target_weight\"] = round(float(target_weight), 4)\n    picked[\"comment\"] = picked[\"guard_mode\"].map(\n        lambda x: \"auto_live_v4_2b_fundamental_guard\" if x == \"fundamental_guard\" else \"auto_live_v4_2b_tech_fallback\"\n    )\n    return picked[\n        [\n            \"ts_code\",\n            \"score\",\n            \"target_weight\",\n            \"comment\",\n            \"guard_mode\",\n            \"source_trade_date\",\n            \"tech_score\",\n            \"guard_score\",\n            \"turnover_rate\",\n            \"pe\",\n            \"pb\",\n            \"ps\",\n            \"total_mv\",\n            \"circ_mv\",\n        ]\n    ].copy()\n\n\ndef write_candidates(path: Path, frame: pd.DataFrame, *, overwrite: bool) -> dict[str, Any]:\n    existing_rows = count_csv_rows(path)\n    if existing_rows > 0 and not overwrite:\n        return {\n            \"path\": str(path),\n            \"status\": \"skipped_existing_non_empty\",\n            \"rows\": existing_rows,\n        }\n\n    ensure_parent(path)\n    frame.to_csv(path, index=False, encoding=\"utf-8\")\n    return {\n        \"path\": str(path),\n        \"status\": \"written\",\n        \"rows\": int(len(frame)),\n    }\n\n\ndef summary_output_path(date_tag: str, override: str) -> Path:\n    if override:\n        return Path(override)\n    return REPORT_DIR / f\"live_smallcap_candidate_generation_{date_tag}.json\"\n\n\ndef main_output_path(date_tag: str, override: str) -> Path:\n    if override:\n        return Path(override)\n    return REPORT_DIR / f\"manual_smallcap_candidates_{date_tag}.csv\"\n\n\ndef guard_output_path(date_tag: str, override: str) -> Path:\n    if override:\n        return Path(override)\n    return REPORT_DIR / f\"manual_smallcap_candidates_v4_2b_{date_tag}.csv\"\n\n\ndef _calendar_lag_days(date_a: str, date_b: str) -> int:\n    if not date_a or not date_b:\n        return 10**9\n    da = pd.to_datetime(str(date_a), format=\"%Y%m%d\", errors=\"coerce\")\n    db = pd.to_datetime(str(date_b), format=\"%Y%m%d\", errors=\"coerce\")\n    if pd.isna(da) or pd.isna(db):\n        return 10**9\n    return abs((da - db).days)\n\n\ndef fetch_realtime_closes(symbols: list[str]) -> dict[str, float]:\n    \"\"\"Fetch current prices from Tencent real-time API for given symbols.\"\"\"\n    closes = {}\n    try:\n        def _to_tencent(s):\n            s = s.strip()\n            if s.endswith(\".SH\"):\n                return \"sh\" + s[:-3]\n            if s.endswith(\".SZ\"):\n\n[363 more lines in file. Use offset=380 to continue.]"}],"isError":false,"timestamp":1776530948720}}
