Pkmyl3m2CRGgmuKY49yJN9HypCXUaGMp9G7RnFfxkc0FN7huc-SiHVwEF7Idoye_N8FN_tj_3n2GRmgbkV89ORPD7c_xIllMejjBXMNFLbezsxnkHU261vZHZO7zygIaUVQBcROMKgw00Fce8uG6HohvZTOBTqewkLAjflATuh9GC-6XmxFXnZUD9ryViNUUBxP7m0=\",\"summary\":[]}"},{"type":"toolCall","id":"call_4xU0pNtckQVr8AC9A4Np07xI|fc_0fad9e409c19087f0169e3b3088cf8819a9d518c7b3a7e64e9","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/main.py","limit":220},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/ai_overlay/position_explainer/main.py\",\"limit\":220}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":60900,"output":476,"cacheRead":191360,"cacheWrite":0,"totalTokens":252736,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776530169340,"responseId":"resp_0fad9e409c19087f0169e3b2fc0f00819aaac04c1c977a7a1f"}}
{"type":"message","id":"3ba61174","parentId":"1077eb65","timestamp":"2026-04-18T16:36:26.417Z","message":{"role":"toolResult","toolCallId":"call_4xU0pNtckQVr8AC9A4Np07xI|fc_0fad9e409c19087f0169e3b3088cf8819a9d518c7b3a7e64e9","toolName":"read","content":[{"type":"text","text":"\"\"\"Main entry point for position explainer overlay.\n\nUsage:\n    python -m ai_overlay.position_explainer.main --date 20260403\n\nReads holdings + market context + morning summary,\nexplains each holding with hold/add/reduce/exit advice.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport sys\nimport time\nfrom datetime import datetime\nfrom pathlib import Path\n\nsys.path.insert(0, str(Path(__file__).parent.parent.parent.parent))\n\nfrom ai_overlay.position_explainer.build_payload import build_blocked, build_payload, PayloadError\nfrom ai_overlay.position_explainer.render_report import render_markdown\nfrom ai_overlay._stability import audit_run, print_stats_summary\n\nREPORTS_DIR = Path(__file__).parent.parent.parent / \"research\" / \"reports\"\nOVERLAY_DIR = REPORTS_DIR / \"ai_overlay\"\n\nDEFAULT_INPUT_PATTERNS = {\n    \"holdings\": \"selected_real_positions_{date}.csv\",\n    \"market_context\": \"breadth_aggressive_paper_{date}.json\",\n    \"morning_summary\": \"daily_quant_analysis_skill_{date}.md\",\n}\n\n\n_MINIMAX_ALIASES = frozenset({\n    \"minimax-m2.7\", \"minimax-m2.5\", \"minimax-m2.5-highspeed\",\n    \"minimax-m2.5-lightning\", \"minimax-m2.1\",\n})\n\n\ndef get_explainer_runner(model: str):\n    if model == \"fake\":\n        from ai_overlay.position_explainer.run_explainer import run_explainer as runner\n    elif model.lower() in _MINIMAX_ALIASES or model.lower().startswith(\"minimax\"):\n        from ai_overlay.position_explainer.minimax_adapter import run_explainer as runner\n    else:\n        from ai_overlay.position_explainer.llm_adapter import run_explainer as runner\n    return runner\n\n\ndef get_date_tag(date_arg: str | None) -> str:\n    if date_arg:\n        return date_arg\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef resolve_paths(date_tag: str) -> dict:\n    return {\n        \"holdings\": REPORTS_DIR / DEFAULT_INPUT_PATTERNS[\"holdings\"].format(date=date_tag),\n        \"market_context\": REPORTS_DIR / DEFAULT_INPUT_PATTERNS[\"market_context\"].format(date=date_tag),\n        \"morning_summary\": REPORTS_DIR / DEFAULT_INPUT_PATTERNS[\"morning_summary\"].format(date=date_tag),\n    }\n\n\ndef write_json(path: Path, data: dict) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef write_text(path: Path, content: str) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(content, encoding=\"utf-8\")\n\n\ndef main() -> int:\n    parser = argparse.ArgumentParser(description=\"Position Explainer Overlay\")\n    parser.add_argument(\"--date\", default=None, help=\"Date tag YYYYMMDD (default: today)\")\n    parser.add_argument(\"--holdings\", default=None, help=\"Holdings CSV override\")\n    parser.add_argument(\"--market-context\", default=None, help=\"Market context JSON override\")\n    parser.add_argument(\"--model\", default=\"fake\", help=\"Model: fake (default), minimax-m2.7, or deepseek-r1:7b\")\n    parser.add_argument(\"--stats\", action=\"store_true\", help=\"Print 7-day run statistics and exit\")\n    args = parser.parse_args()\n\n    if args.stats:\n        print_stats_summary(\"position_explainer\")\n        return 0\n\n    date_tag = get_date_tag(args.date)\n    paths = resolve_paths(date_tag)\n    if args.holdings:\n        paths[\"holdings\"] = Path(args.holdings)\n    if args.market_context:\n        paths[\"market_context\"] = Path(args.market_context)\n\n    t0 = time.time()\n    print(f\"[position_explainer] date_tag={date_tag}\")\n    print(f\"[position_explainer] holdings={paths['holdings']}\")\n    print(f\"[position_explainer] market_context={paths['market_context']}\")\n\n    payload = None\n    result = None\n\n    try:\n        payload = build_payload(\n            holdings_path=paths[\"holdings\"],\n            market_context_path=paths[\"market_context\"],\n            morning_summary_path=paths[\"morning_summary\"],\n            expected_date_tag=date_tag,\n        )\n    except PayloadError as exc:\n        reason = str(exc)\n        blocked = build_blocked(reason)\n        status_path = OVERLAY_DIR / f\"position_explainer_{date_tag}.status.json\"\n        write_json(status_path, blocked.model_dump(mode=\"json\"))\n        print(f\"[position_explainer] BLOCKED: {reason}\")\n        duration_ms = int((time.time() - t0) * 1000)\n        audit_run(\n            explainer=\"position_explainer\",\n            stage=\"position_explainer.build_payload\",\n            status=\"blocked\",\n            date_tag=date_tag,\n            reason=reason,\n            duration_ms=duration_ms,\n            model=args.model,\n            error_detail=reason,\n        )\n        return 1\n\n    try:\n        runner = get_explainer_runner(args.model)\n        result = runner(payload, model=args.model)\n    except Exception as exc:\n        duration_ms = int((time.time() - t0) * 1000)\n        audit_run(\n            explainer=\"position_explainer\",\n            stage=\"position_explainer.llm_call\",\n            status=\"error\",\n            date_tag=date_tag,\n            reason=\"llm_call_failed\",\n            duration_ms=duration_ms,\n            model=args.model,\n            error_detail=str(exc),\n            payload=payload,\n        )\n        print(f\"[position_explainer] LLM ERROR: {exc}\")\n        return 1\n\n    json_path = OVERLAY_DIR / f\"position_explainer_{date_tag}.json\"\n    md_path = OVERLAY_DIR / f\"position_explainer_{date_tag}.md\"\n    latest_json = OVERLAY_DIR / \"position_explainer_latest.json\"\n    latest_md = OVERLAY_DIR / \"position_explainer_latest.md\"\n\n    write_json(json_path, result)\n    write_text(md_path, render_markdown(result))\n    write_json(latest_json, result)\n    write_text(latest_md, render_markdown(result))\n\n    duration_ms = int((time.time() - t0) * 1000)\n    holding_count = len(payload.get(\"holdings\", []))\n    audit_run(\n        explainer=\"position_explainer\",\n        stage=\"position_explainer.run\",\n        status=\"success\",\n        date_tag=date_tag,\n        reason=\"\",\n        duration_ms=duration_ms,\n        candidate_count=holding_count,\n        model=args.model,\n        payload=payload,\n        output=result,\n    )\n\n    print(f\"[position_explainer] DONE\")\n    print(f\"[position_explainer] holdings_advised={result.get('holding_count', 0)}\")\n    print(f\"[position_explainer] duration={duration_ms}ms\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n"}],"isError":false,"timestamp":1776530186407}}
