{"type":"message","id":"ca7ac154","parentId":"c50a016c","timestamp":"2026-04-18T15:14:08.820Z","message":{"role":"toolResult","toolCallId":"call_U79EadRye2ZYfsOsbH2W0Kno|fc_0fad9e409c19087f0169e39fbe66f0819aa48b8bbbec429cb4","toolName":"read","content":[{"type":"text","text":"\n\ndef trade_exit_type_options(trades: pd.DataFrame) -> str:\n    if trades.empty:\n        return \"\"\n    exit_types = sorted({str(x).strip().lower() for x in trades.get(\"exit_type\", pd.Series(dtype=str)).fillna(\"\") if str(x).strip()})\n    return \"\\n\".join(\n        [\n            f\"<option value=\\\"{html.escape(exit_type)}\\\">{html.escape(exit_type)}</option>\"\n            for exit_type in exit_types\n        ]\n    )\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"生成模拟盘观察面板\")\n    parser.add_argument(\n        \"--config\",\n        default=str(DEFAULT_CONFIG_PATH),\n        help=\"模拟盘配置文件；默认使用 aggressive profile\",\n    )\n    args = parser.parse_args()\n\n    cfg = load_json(resolve_path(args.config))\n    profile_slug = profile_slug_from_config(cfg)\n    profile_name = profile_name_from_config(cfg)\n    account_file = resolve_path(\n        str(\n            cfg.get(\n                \"account_latest_file\",\n                report_path(REPORT_DIR, \"account_latest\", profile_slug=profile_slug).relative_to(PROJECT_ROOT),\n            )\n        )\n    )\n    positions_file = resolve_path(\n        str(\n            cfg.get(\n                \"positions_latest_file\",\n                report_path(REPORT_DIR, \"positions_latest\", profile_slug=profile_slug).relative_to(PROJECT_ROOT),\n            )\n        )\n    )\n    curve_file = resolve_path(\n        str(\n            cfg.get(\n                \"nav_curve_file\",\n                report_path(REPORT_DIR, \"nav_curve\", profile_slug=profile_slug).relative_to(PROJECT_ROOT),\n            )\n        )\n    )\n\n    if not account_file.exists():\n        raise FileNotFoundError(f\"未找到模拟盘账户快照: {account_file}\")\n\n    account = load_json(account_file)\n    initial_cash = parse_float(account.get(\"initial_cash\"), 0.0)\n    journal_file = (\n        resolve_path(str((account.get(\"files\") or {}).get(\"today_journal\", \"\")))\n        if account.get(\"files\")\n        else report_path(REPORT_DIR, \"journal\", profile_slug=profile_slug, date_tag=str(account.get(\"date_tag\", \"\")))\n    )\n    positions_df = load_csv(positions_file)\n    curve_df = load_csv(curve_file)\n    today_trades_df = load_csv(journal_file)\n    all_trades_df = load_all_trade_rows(REPORT_DIR, profile_slug=profile_slug)\n    positions_df, all_trades_df = attach_symbol_names(positions_df, all_trades_df)\n    benchmark_df, benchmark_name, benchmark_path = load_benchmark_frame(cfg)\n    benchmark_latest_date = (\n        pd.to_datetime(benchmark_df[\"date\"], errors=\"coerce\").dropna().max().strftime(\"%Y-%m-%d\")\n        if not benchmark_df.empty\n        else \"\"\n    )\n    perf_df = prepare_performance_frame(curve_df, benchmark_df, initial_cash=initial_cash)\n    trade_stats = compute_trade_statistics(all_trades_df)\n    metrics = compute_performance_metrics(perf_df, trade_stats, benchmark_name)\n\n    date_tag = str(account.get(\"date_tag\") or extract_date_tag(account_file))\n    now_str = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n    if not today_trades_df.empty:\n        today_trades_df = today_trades_df.copy()\n        today_trades_df[\"amount\"] = pd.to_numeric(today_trades_df.get(\"price\", 0), errors=\"coerce\").fillna(0.0) * pd.to_numeric(today_trades_df.get(\"shares\", 0), errors=\"coerce\").fillna(0.0)\n\n    html_text = f\"\"\"<!doctype html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>{html.escape(profile_name)} 模拟盘观察面板</title>\n  <script src=\"https://cdn.plot.ly/plotly-2.35.2.min.js\"></script>\n  <style>\n    :root {{\n      --bg: #08111f;\n      --bg2: #0f1d35;\n      --card: rgba(14, 25, 46, 0.84);\n      --line: rgba(125, 154, 197, 0.18);\n      --text: #edf5ff;\n      --muted: #94a6c7;\n      --rise: #ff6f6f;\n      --fall: #39c885;\n      --warn: #ffd166;\n      --accent: #62c8ff;\n      --accent2: #ffb703;\n    }}\n    * {{ box-sizing: border-box; }}\n    body {{\n      margin: 0;\n      font-family: \"SF Pro Display\", \"PingFang SC\", \"Noto Sans SC\", sans-serif;\n      color: var(--text);\n      background:\n        radial-gradient(circle at 12% 18%, rgba(98, 200, 255, 0.14), transparent 25%),\n        radial-gradient(circle at 85% 12%, rgba(255, 183, 3, 0.10), transparent 22%),\n        linear-gradient(180deg, var(--bg), #07101c 100%);\n    }}\n    .wrap {{ max-width: 1560px; margin: 0 auto; padding: 28px 20px 46px; }}\n    .hero {{\n      display: flex;\n      justify-content: space-between;\n      gap: 18px;\n      align-items: flex-end;\n      margin-bottom: 22px;\n    }}\n    .hero h1 {{\n      margin: 0;\n      font-size: 36px;\n      letter-spacing: 0.03em;\n    }}\n    .sub {{ color: var(--muted); font-size: 14px; margin-top: 6px; }}\n    .mono {{ color: var(--muted); font-family: ui-monospace, \"SFMono-Regular\", Menlo, monospace; font-size: 12px; line-height: 1.6; }}\n    .grid {{\n      display: grid;\n      grid-template-columns: repeat(12, 1fr);\n      gap: 16px;\n    }}\n    .card {{\n      background: var(--card);\n      border: 1px solid var(--line);\n      border-radius: 18px;\n      padding: 18px 18px 16px;\n      backdrop-filter: blur(10px);\n      box-shadow: 0 18px 60px rgba(0, 0, 0, 0.22);\n    }}\n    .kpi {{ grid-column: span 3; min-height: 116px; }}\n    .span-12 {{ grid-column: span 12; }}\n    .span-8 {{ grid-column: span 8; }}\n    .span-6 {{ grid-column: span 6; }}\n    .span-4 {{ grid-column: span 4; }}\n    .label {{ font-size: 13px; color: var(--muted); margin-bottom: 8px; }}\n    .value {{ font-size: 30px; font-weight: 700; line-height: 1.15; }}\n    .meta {{ color: var(--muted); font-size: 12px; margin-top: 8px; }}\n    .pos {{ color: var(--rise); }}\n    .neg {{ color: var(--fall); }}\n    .buy {{ color: var(--rise); }}\n    .sell {{ color: var(--fall); }}\n    .warn {{ color: var(--warn); }}\n    .symbol-name {{ color: var(--muted); font-size: 12px; margin-top: 3px; }}\n    .section-title {{ margin: 0 0 12px; font-size: 17px; }}\n    .section-head {{\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 12px;\n      margin-bottom: 12px;\n    }}\n    .section-head .section-title {{ margin-bottom: 0; }}\n    .action-btn {{\n      background: rgba(255,255,255,0.05);\n      border: 1px solid var(--line);\n      color: var(--text);\n      padding: 9px 12px;\n      border-radius: 10px;\n      cursor: pointer;\n      font-size: 13px;\n      line-height: 1;\n    }}\n    .action-btn:hover {{ background: rgba(255,255,255,0.08); }}\n    table {{ width: 100%; border-collapse: collapse; }}\n    th, td {{\n      padding: 10px 8px;\n      border-bottom: 1px solid var(--line);\n      text-align: left;\n      font-size: 13px;\n      vertical-align: top;\n    }}\n    th {{ color: var(--muted); font-weight: 600; }}\n    .metric-table th {{ width: 180px; }}\n    .toolbar {{\n      display: flex;\n      flex-wrap: wrap;\n      gap: 10px;\n      margin-bottom: 12px;\n    }}\n    .toolbar input, .toolbar select {{\n      background: rgba(255,255,255,0.04);\n      border: 1px solid var(--line);\n      color: var(--text);\n      padding: 10px 12px;\n      border-radius: 10px;\n      outline: none;\n      min-width: 140px;\n    }}\n    .hint {{\n      font-size: 12px;\n      color: var(--muted);\n      margin-bottom: 10px;\n    }}\n    @media (max-width: 1120px) {{\n      .kpi, .span-8, .span-6, .span-4, .span-12 {{ grid-column: span 12; }}\n      .hero {{ flex-direction: column; align-items: flex-start; }}\n    }}\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <section class=\"hero\">\n      <div>\n        <h1>{html.escape(profile_name)} 模拟盘观察面板</h1>\n        <div class=\"sub\">trade_date={html.escape(str(account.get(\"trade_date\", \"-\")))} ｜ strategy={html.escape(str(account.get(\"strategy_id\", \"-\")))} ｜ profile={html.escape(profile_slug or 'default')} ｜ benchmark={html.escape(benchmark_name)} ｜ updated={html.escape(now_str)}</div>\n      </div>\n      <div class=\"mono\">\n        account={html.escape(str(account_file))}<br>\n        positions={html.escape(str(positions_file))} ｜ curve={html.escape(str(curve_file))}<br>\n        benchmark={html.escape(str(benchmark_path) if benchmark_path else \"-\")} ｜ journal={html.escape(str(journal_file))}\n      </div>\n    </section>\n\n    <section class=\"grid\">\n      <article class=\"card kpi\"><div class=\"label\">当前净值</div><div class=\"value\">{fmt(account.get(\"nav\"), 2)}</div><div class=\"meta\">初始资金 {fmt(account.get(\"initial_cash\"), 2)}</div></article>\n      <article class=\"card kpi\"><div class=\"label\">策略收益</div><div class=\"value {'pos' if parse_float(metrics.get(\"strategy_total_return_pct\")) >= 0 else 'neg'}\">{fmt_pct(metrics.get(\"strategy_total_return_pct\"))}</div><div class=\"meta\">累计收益率</div></article>\n      <article class=\"card kpi\"><div class=\"label\">策略年化收益</div><div class=\"value {'pos' if parse_float(metrics.get(\"strategy_annual_return_pct\")) >= 0 else 'neg'}\">{fmt_pct(metrics.get(\"strategy_annual_return_pct\"))}</div><div class=\"meta\">按日收益年化</div></article>\n      <article class=\"card kpi\"><div class=\"label\">{html.escape(benchmark_name)}收益</div><div class=\"value {'pos' if parse_float(metrics.get(\"benchmark_total_return_pct\")) >= 0 else 'neg'}\">{fmt_pct(metrics.get(\"benchmark_total_return_pct\"))}</div><div class=\"meta\">同区间基准表现</div></article>\n\n      <article class=\"card kpi\"><div class=\"label\">阿尔法</div><div class=\"value {'pos' if parse_float(metrics.get(\"alpha_pct\")) >= 0 else 'neg'}\">{fmt_pct(metrics.get(\"alpha_pct\"))}</div><div class=\"meta\">日频回归年化 alpha</div></article>\n      <article class=\"card kpi\"><div class=\"label\">贝塔</div><div class=\"value\">{fmt_ratio(metrics.get(\"beta\"))}</div><div class=\"meta\">相对 {html.escape(benchmark_name)}</div></article>\n      <article class=\"card kpi\"><div class=\"label\">夏普比率</div><div class=\"value\">{fmt_ratio(metrics.get(\"sharpe\"))}</div><div class=\"meta\">风险调整后收益</div></article>\n      <article class=\"card kpi\"><div class=\"label\">索提诺比率</div><div class=\"value\">{fmt_ratio(metrics.get(\"sortino\"))}</div><div class=\"meta\">仅惩罚下行波动</div></article>\n\n      <article class=\"card kpi\"><div class=\"label\">信息比率</div><div class=\"value\">{fmt_ratio(metrics.get(\"information_ratio\"))}</div><div class=\"meta\">超额收益稳定性</div></article>\n      <article class=\"card kpi\"><div class=\"label\">最大回撤</div><div class=\"value neg\">{fmt_pct(metrics.get(\"max_drawdown_pct\"))}</div><div class=\"meta\">{html.escape(str(metrics.get(\"max_drawdown_interval\", \"-\")))}</div></article>\n      <article class=\"card kpi\"><div class=\"label\">超额收益最大回撤</div><div class=\"value neg\">{fmt_pct(metrics.get(\"excess_max_drawdown_pct\"))}</div><div class=\"meta\">相对基准的回撤</div></article>\n      <article class=\"card kpi\"><div class=\"label\">日均超额收益</div><div class=\"value {'pos' if parse_float(metrics.get(\"daily_avg_excess_return_pct\")) >= 0 else 'neg'}\">{fmt_pct(metrics.get(\"daily_avg_excess_return_pct\"), 4)}</div><div class=\"meta\">strategy - benchmark</div></article>\n\n      <article class=\"card span-8\">\n        <h3 class=\"section-title\">模拟盘 vs {html.escape(benchmark_name)} 对比曲线</h3>\n        <div id=\"compareCurve\" style=\"height: 380px;\"></div>\n      </article>\n\n      <article class=\"card span-4\">\n        <h3 class=\"section-title\">关键账户状态</h3>\n        <table class=\"metric-table\">\n          <tbody>\n            <tr><th>起始日期</th><td>{html.escape(str(account.get(\"start_trade_date\", \"-\")))}</td></tr>\n            <tr><th>当前现金</th><td>{fmt(account.get(\"cash\"), 2)}</td></tr>\n            <tr><th>持仓市值</th><td>{fmt(account.get(\"market_value\"), 2)}</td></tr>\n            <tr><th>持仓数量</th><td>{fmt(account.get(\"position_count\"), 0)}</td></tr>\n            <tr><th>今日成交</th><td>{fmt(account.get(\"today_trade_count\"), 0)}（BUY {fmt(account.get(\"today_buy_count\"), 0)} / SELL {fmt(account.get(\"today_sell_count\"), 0)}）</td></tr>\n            <tr><th>基准最新日</th><td>{html.escape(benchmark_latest_date or \"-\")}</td></tr>\n            <tr><th>实时估值命中</th><td>{fmt(account.get(\"realtime_mark_hits\"), 0)}</td></tr>\n            <tr><th>胜率</th><td>{fmt_pct(metrics.get(\"trade_win_rate_pct\"))} <span class=\"mono\">按已平仓交易</span></td></tr>\n            <tr><th>日胜率</th><td>{fmt_pct(metrics.get(\"daily_win_rate_pct\"))}</td></tr>\n            <tr><th>盈利次数 / 亏损次数</th><td>{fmt(metrics.get(\"win_count\"), 0)} / {fmt(metrics.get(\"loss_count\"), 0)}</td></tr>\n            <tr><th>盈亏比</th><td>{fmt_ratio(metrics.get(\"profit_loss_ratio\"))}</td></tr>\n          </tbody>\n        </table>\n      </article>\n\n      <article class=\"card span-6\">\n        <h3 class=\"section-title\">每日收益柱状图</h3>\n        <div id=\"dailyReturnChart\" style=\"height: 340px;\"></div>\n      </article>\n\n      <article class=\"card span-6\">\n        <h3 class=\"section-title\">绩效指标</h3>\n        <table class=\"metric-table\">\n          <tbody>\n            {metric_rows_html(metrics)}\n          </tbody>\n        </table>\n      </article>\n\n      <article class=\"card span-12\">\n        <div class=\"section-head\">\n          <h3 class=\"section-title\">模拟持仓</h3>\n          <button id=\"exportPositionsBtn\" class=\"action-btn\" type=\"button\">导出持仓 CSV</button>\n        </div>\n        <table>\n          <thead>\n            <tr>\n              <th>symbol / name</th>\n              <th>quantity</th>\n              <th>cost_price</th>\n              <th>last_price</th>\n              <th>market_value</th>\n              <th>unrealized_pnl</th>\n              <th>unrealized_pnl_pct</th>\n            </tr>\n          </thead>\n          <tbody>\n            {positions_rows_html(positions_df)}\n          </tbody>\n        </table>\n      </article>\n\n      <article class=\"card span-12\">\n        <div class=\"section-head\">\n          <h3 class=\"section-title\">成交明细筛选</h3>\n          <button id=\"exportTradesBtn\" class=\"action-btn\" type=\"button\">导出当前筛选 CSV</button>\n        </div>\n        <div class=\"toolbar\">\n          <input id=\"tradeSymbolSearch\" type=\"text\" placeholder=\"按代码/备注/卖出原因搜索\">\n          <select id=\"tradeSymbolSelect\">\n            <option value=\"\">全部代码</option>\n            {trade_filter_options(all_trades_df)}\n          </select>\n          <select id=\"tradeSideSelect\">\n            <option value=\"\">全部方向</option>\n            <option value=\"BUY\">BUY</option>\n            <option value=\"SELL\">SELL</option>\n          </select>\n          <select id=\"tradeExitTypeSelect\">\n            <option value=\"\">全部卖出类型</option>\n            {trade_exit_type_options(all_trades_df)}\n          </select>\n          <select id=\"tradeDateSelect\">\n            <option value=\"\">全部日期</option>\n          </select>\n        </div>\n        <div class=\"hint\">支持按日期、方向、代码、卖出类型和备注全文过滤。当前数据源仅包含本组合的成交日志。</div>\n        <table>\n          <thead>\n            <tr>\n              <th>date</th>\n              <th>side</th>\n              <th>symbol / name</th>\n              <th>price</th>\n              <th>shares</th>\n              <th>amount</th>\n              <th>fee</th>\n              <th>slippage</th>\n              <th>signal_reason</th>\n              <th>exit_type</th>\n              <th>exit_reason</th>\n              <th>notes</th>\n            </tr>\n          </thead>\n          <tbody id=\"tradeTable\"></tbody>\n        </table>\n      </article>\n    </section>\n  </div>\n\n  <script>\n    const perfRows = {json.dumps(performance_payload(perf_df), ensure_ascii=False)};\n    const positionRows = {json.dumps(positions_export_payload(positions_df), ensure_ascii=False)};\n    const allTrades = {json.dumps(as_records(all_trades_df), ensure_ascii=False)};\n    const profileSlug = {json.dumps(profile_slug or \"default\", ensure_ascii=False)};\n    const dateTag = {json.dumps(date_tag, ensure_ascii=False)};\n\n    function cls(v) {{\n      const n = Number(v);\n      if (!Number.isFinite(n)) return \"\";\n      return n >= 0 ? \"pos\" : \"neg\";\n    }}\n\n    function fmt(v, digits=2) {{\n      const n = Number(v);\n      if (!Number.isFinite(n)) return \"\";\n      return n.toLocaleString(\"zh-CN\", {{ minimumFractionDigits: 0, maximumFractionDigits: digits }});\n    }}\n\n    function escapeHtml(value) {{\n      return String(value ?? \"\").replace(/[&<>\"']/g, ch => ({{ \"&\": \"&amp;\", \"<\": \"&lt;\", \">\": \"&gt;\", '\"': \"&quot;\", \"'\": \"&#39;\" }})[ch]);\n    }}\n\n    function csvCell(value) {{\n      const text = String(value ?? \"\");\n      if (/[\",\\n]/.test(text)) {{\n        return `\"${{text.replace(/\"/g, '\"\"')}}\"`;\n      }}\n      return text;\n    }}\n\n    function triggerDownload(filename, content) {{\n      const blob = new Blob([content], {{ type: \"text/csv;charset=utf-8;\" }});\n      const url = URL.createObjectURL(blob);\n      const link = document.createElement(\"a\");\n      link.href = url;\n      link.download = filename;\n      link.rel = \"noopener\";\n      link.style.display = \"none\";\n      document.body.appendChild(link);\n      const cleanup = () => window.setTimeout(() => {{\n        URL.revokeObjectURL(url);\n        if (link.isConnected) link.remove();\n      }}, 1500);\n      try {{\n        if (typeof link.click === \"function\") {{\n          link.click();\n        }} else {{\n          link.dispatchEvent(new MouseEvent(\"click\", {{ bubbles: true, cancelable: true, view: window }}));\n        }}\n      }} finally {{\n        cleanup();\n      }}\n    }}\n\n    function downloadCsv(filename, columns, rows) {{\n      const header = columns.map(col => csvCell(col.label)).join(\",\");\n      const body = rows.map(row => columns.map(col => csvCell(row[col.key])).join(\",\")).join(\"\\n\");\n      const content = \"\\ufeff\" + [header, body].filter(Boolean).join(\"\\n\");\n      triggerDownload(filename, content);\n    }}\n\n    function exportPositions() {{\n      const columns = [\n        {{ key: \"symbol\", label: \"symbol\" }},\n        {{ key: \"symbol_name\", label: \"name\" }},\n        {{ key: \"quantity\", label: \"quantity\" }},\n        {{ key: \"cost_price\", label: \"cost_price\" }},\n        {{ key: \"last_price\", label: \"last_price\" }},\n\n[228 more lines in file. Use offset=1200 to continue.]"}],"isError":false,"timestamp":1776525248798}}
