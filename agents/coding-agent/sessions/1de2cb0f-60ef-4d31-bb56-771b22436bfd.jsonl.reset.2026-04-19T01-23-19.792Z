{"type":"message","id":"8d0e1e7f","parentId":"cb53eece","timestamp":"2026-04-18T16:48:57.291Z","message":{"role":"toolResult","toolCallId":"call_U8mBhh5YB5HMfX0jSl8jzAt6|fc_0fad9e409c19087f0169e3b5f7b9e4819abaf9898136d0db26","toolName":"read","content":[{"type":"text","text":"        path,\n        usecols=[\"ts_code\", \"trade_date\", \"total_mv\", \"circ_mv\", \"turnover_rate\", \"pe\", \"pb\", \"ps\"],\n        dtype={\"ts_code\": str, \"trade_date\": int, \"total_mv\": float, \"circ_mv\": float, \"turnover_rate\": float, \"pe\": float, \"pb\": float, \"ps\": float},\n        chunksize=100_000,\n    ):\n        chunk = chunk[chunk[\"trade_date\"] <= target_date]\n        if not chunk.empty:\n            chunks.append(chunk)\n    if not chunks:\n        return \"\", pd.DataFrame()\n\n    frame = pd.concat(chunks, ignore_index=True)\n    latest_trade_date = int(frame[\"trade_date\"].max())\n    frame = frame[frame[\"trade_date\"] == latest_trade_date].copy()\n    frame[\"ts_code\"] = frame[\"ts_code\"].astype(str).str.upper().str.strip()\n    for col in [\"total_mv\", \"circ_mv\", \"turnover_rate\", \"pe\", \"pb\", \"ps\"]:\n        frame[col] = pd.to_numeric(frame[col], errors=\"coerce\")\n    return str(latest_trade_date), frame\n\n\ndef select_main_candidates(\n    universe: pd.DataFrame,\n    *,\n    limit: int,\n    target_weight: float,\n) -> pd.DataFrame:\n    picked = universe.head(limit).copy()\n    picked[\"score\"] = picked[\"tech_score\"].round(6)\n    picked[\"target_weight\"] = round(float(target_weight), 4)\n    picked[\"comment\"] = \"auto_live_v4_2\"\n    return picked[\n        [\n            \"ts_code\",\n            \"score\",\n            \"target_weight\",\n            \"comment\",\n            \"source_trade_date\",\n            \"close\",\n            \"mom20\",\n            \"mom60\",\n            \"liq20\",\n            \"vwap60\",\n            \"volume_break\",\n            \"chip_near\",\n            \"tech_score\",\n        ]\n    ].copy()\n\n\ndef build_guard_candidates(\n    universe: pd.DataFrame,\n    daily_basic: pd.DataFrame,\n    *,\n    limit: int,\n    target_weight: float,\n) -> pd.DataFrame:\n    merged = universe.merge(\n        daily_basic[[\"ts_code\", \"turnover_rate\", \"pe\", \"pb\", \"ps\", \"total_mv\", \"circ_mv\"]],\n        on=\"ts_code\",\n        how=\"left\",\n    )\n    merged[\"guard_mode\"] = \"fundamental_guard\"\n\n    valid = merged[\n        (pd.to_numeric(merged[\"turnover_rate\"], errors=\"coerce\") >= 0.8)\n        & (pd.to_numeric(merged[\"pb\"], errors=\"coerce\") > 0)\n        & (pd.to_numeric(merged[\"ps\"], errors=\"coerce\") > 0)\n    ].copy()\n\n    if valid.empty:\n        fallback = universe.head(limit).copy()\n        fallback[\"score\"] = fallback[\"tech_score\"].round(6)\n        fallback[\"target_weight\"] = round(float(target_weight), 4)\n        fallback[\"comment\"] = \"auto_live_v4_2b_tech_fallback\"\n        fallback[\"guard_mode\"] = \"tech_fallback_no_basic\"\n        for col in [\"turnover_rate\", \"pe\", \"pb\", \"ps\", \"total_mv\", \"circ_mv\", \"guard_score\"]:\n            fallback[col] = np.nan\n        return fallback[\n            [\n                \"ts_code\",\n                \"score\",\n                \"target_weight\",\n                \"comment\",\n                \"guard_mode\",\n                \"source_trade_date\",\n                \"tech_score\",\n                \"guard_score\",\n                \"turnover_rate\",\n                \"pe\",\n                \"pb\",\n                \"ps\",\n                \"total_mv\",\n                \"circ_mv\",\n            ]\n        ].copy()\n\n    valid[\"turnover_score\"] = safe_percentile(valid[\"turnover_rate\"], ascending=True)\n    valid[\"size_score\"] = safe_percentile(valid[\"total_mv\"], ascending=False, fill_value=0.0)\n    valid[\"pb_score\"] = safe_percentile(valid[\"pb\"], ascending=False, fill_value=0.0)\n    valid[\"ps_score\"] = safe_percentile(valid[\"ps\"], ascending=False, fill_value=0.0)\n    valid[\"pe_score\"] = safe_percentile(valid[\"pe\"].where(valid[\"pe\"] > 0), ascending=False, fill_value=0.5)\n    valid[\"guard_score\"] = (\n        0.55 * valid[\"tech_rank\"]\n        + 0.15 * valid[\"turnover_score\"]\n        + 0.15 * valid[\"size_score\"]\n        + 0.075 * valid[\"pb_score\"]\n        + 0.05 * valid[\"ps_score\"]\n        + 0.025 * valid[\"pe_score\"]\n    )\n    valid = valid.sort_values([\"guard_score\", \"tech_score\", \"ts_code\"], ascending=[False, False, True]).copy()\n\n    if len(valid) < limit:\n        existing_codes = set(valid[\"ts_code\"].astype(str))\n        supplement = merged[~merged[\"ts_code\"].isin(existing_codes)].head(limit - len(valid)).copy()\n        if not supplement.empty:\n            supplement[\"guard_score\"] = supplement[\"tech_rank\"] * 0.9\n            supplement[\"guard_mode\"] = \"tech_fallback_partial\"\n            valid = pd.concat([valid, supplement], ignore_index=True)\n\n    picked = valid.head(limit).copy()\n\n[443 more lines in file. Use offset=300 to continue.]"}],"isError":false,"timestamp":1776530937267}}
