id":"call_jiQ3N2zzDUDYZKyKoXHjOEb6|fc_0fad9e409c19087f0169e3b5a2f7b4819a900918e08e3537b4","name":"exec","arguments":{"command":"grep -n \"def inject_realtime_prices\\|def fetch_realtime_closes\\|def is_market_open\\|realtime_closes\" /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_live_smallcap_candidates.py","workdir":"/Users/ling/.openclaw/workspace/coding-agent","timeout":40},"partialJson":"{\"command\":\"grep -n \\\"def inject_realtime_prices\\\\|def fetch_realtime_closes\\\\|def is_market_open\\\\|realtime_closes\\\" /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_live_smallcap_candidates.py\",\"workdir\":\"/Users/ling/.openclaw/workspace/coding-agent\",\"timeout\":40}"},{"type":"toolCall","id":"call_t67puHZCxiOvFGw2Jlmeb41Q|fc_0fad9e409c19087f0169e3b5a2f7c0819aa09a99a6766ac2f3","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_live_smallcap_candidates.py","offset":400,"limit":140},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_live_smallcap_candidates.py\",\"offset\":400,\"limit\":140}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":57056,"output":260,"cacheRead":232704,"cacheWrite":0,"totalTokens":290020,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776530839168,"responseId":"resp_0fad9e409c19087f0169e3b59a04c0819a9142738491e0815c"}}
{"type":"message","id":"c812db4e","parentId":"da6d889c","timestamp":"2026-04-18T16:47:32.670Z","message":{"role":"toolResult","toolCallId":"call_jiQ3N2zzDUDYZKyKoXHjOEb6|fc_0fad9e409c19087f0169e3b5a2f7b4819a900918e08e3537b4","toolName":"exec","content":[{"type":"text","text":"371:def fetch_realtime_closes(symbols: list[str]) -> dict[str, float]:\n416:def inject_realtime_prices(frame: pd.DataFrame, realtime_closes: dict[str, float], target_date_str: str) -> pd.DataFrame:\n418:    if not realtime_closes:\n425:    for ts_code, price in realtime_closes.items():\n445:def is_market_open() -> bool:\n593:            realtime_closes = fetch_realtime_closes(temp_universe_symbols)\n594:            if realtime_closes:\n595:                price_frame = inject_realtime_prices(price_frame, realtime_closes, date_tag)\n596:                print(f\"[REALTIME] injected {len(realtime_closes)} real-time prices\", flush=True)"}],"details":{"status":"completed","exitCode":0,"durationMs":23,"aggregated":"371:def fetch_realtime_closes(symbols: list[str]) -> dict[str, float]:\n416:def inject_realtime_prices(frame: pd.DataFrame, realtime_closes: dict[str, float], target_date_str: str) -> pd.DataFrame:\n418:    if not realtime_closes:\n425:    for ts_code, price in realtime_closes.items():\n445:def is_market_open() -> bool:\n593:            realtime_closes = fetch_realtime_closes(temp_universe_symbols)\n594:            if realtime_closes:\n595:                price_frame = inject_realtime_prices(price_frame, realtime_closes, date_tag)\n596:                print(f\"[REALTIME] injected {len(realtime_closes)} real-time prices\", flush=True)","cwd":"/Users/ling/.openclaw/workspace/coding-agent"},"isError":false,"timestamp":1776530852647}}
{"type":"message","id":"00bfdf19","parentId":"c812db4e","timestamp":"2026-04-18T16:47:32.684Z","message":{"role":"toolResult","toolCallId":"call_t67puHZCxiOvFGw2Jlmeb41Q|fc_0fad9e409c19087f0169e3b5a2f7c0819aa09a99a6766ac2f3","toolName":"read","content":[{"type":"text","text":"                ts_code = raw_code[2:] + \".SZ\"\n            elif raw_code.startswith(\"bj\"):\n                ts_code = raw_code[2:] + \".BJ\"\n            else:\n                continue\n            try:\n                price = float(parts[3])  # current price\n                if price > 0:\n                    closes[ts_code] = price\n            except (ValueError, IndexError):\n                continue\n    except Exception as e:\n        print(f\"[WARN] realtime fetch failed: {e}\", flush=True)\n    return closes\n\n\ndef inject_realtime_prices(frame: pd.DataFrame, realtime_closes: dict[str, float], target_date_str: str) -> pd.DataFrame:\n    \"\"\"Inject today's real-time close prices into the price frame as a new row.\"\"\"\n    if not realtime_closes:\n        return frame\n    import datetime\n    target_date_int = int(target_date_str)\n    target_dt = pd.to_datetime(target_date_str, format=\"%Y%m%d\")\n    # Filter to only symbols we have realtime for\n    rows = []\n    for ts_code, price in realtime_closes.items():\n        # Get last known volume/amount for this symbol from the frame\n        sym_data = frame[frame[\"ts_code\"] == ts_code].sort_values(\"trade_date\", ascending=False)\n        if sym_data.empty:\n            continue\n        last_row = sym_data.iloc[0]\n        rows.append({\n            \"ts_code\": ts_code,\n            \"trade_date\": target_date_int,\n            \"close\": price,\n            \"vol\": last_row.get(\"vol\", 0),\n            \"amount\": last_row.get(\"amount\", 0),\n            \"date\": target_dt,\n        })\n    if not rows:\n        return frame\n    inject_frame = pd.DataFrame(rows)\n    return pd.concat([frame, inject_frame], ignore_index=True)\n\n\ndef is_market_open() -> bool:\n    \"\"\"Check if current time is within A-share trading hours.\"\"\"\n    import datetime\n    now = datetime.datetime.now()\n    weekday = now.weekday()\n    if weekday >= 5:\n        return False\n    current_time = now.time()\n    morning_open = datetime.time(9, 30)\n    morning_close = datetime.time(11, 30)\n    afternoon_open = datetime.time(13, 0)\n    afternoon_close = datetime.time(15, 0)\n    in_morning = morning_open <= current_time <= morning_close\n    in_afternoon = afternoon_open <= current_time <= afternoon_close\n    return in_morning or in_afternoon\n\n\n\ndef _build_reason_text(r: dict) -> str:\n    \"\"\"Build human-readable reason for why a stock was selected.\"\"\"\n    parts = []\n    mom20 = float(r.get(\"mom20\", 0)) * 100\n    mom60 = float(r.get(\"mom60\", 0)) * 100\n    vol_break = bool(r.get(\"volume_break\", False))\n    chip_near = bool(r.get(\"chip_near\", False))\n    tech_rank = float(r.get(\"tech_rank\", 0.5)) * 100\n    liq20 = float(r.get(\"liq20\", 0))\n    # Momentum\n    if mom20 > 5:\n        parts.append(f\"20日动能+{mom20:.1f}%\")\n    elif mom20 < -5:\n        parts.append(f\"20日动能{mom20:.1f}%\")\n    if mom60 > 5:\n        parts.append(f\"60日动能+{mom60:.1f}%\")\n    elif mom60 < -5:\n        parts.append(f\"60日动能{mom60:.1f}%\")\n    # Volume break\n    if vol_break:\n        parts.append(\"放量突破\")\n    # Chip near VWAP\n    if chip_near:\n        parts.append(\"筹码贴近VWAP\")\n    # Smallcap rank (tech_rank is percentile, lower = better)\n    if tech_rank < 20:\n        parts.append(f\"小市值前{int(100-tech_rank)}位\")\n    # Liquidity\n    if liq20 > 500_000_000:\n        parts.append(f\"流动性{liq20/1e6:.0f}万\")\n    return \" / \".join(parts) if parts else \"综合技术评分入榜\"\n\n\ndef _push_candidate_change(date_tag: str, snapshot: dict, reasons: list[str], candidates: pd.DataFrame) -> None:\n    \"\"\"Send Feishu push if there are material candidate changes.\"\"\"\n    try:\n        sys.path.insert(0, str(PROJECT_ROOT / \"scripts\"))\n        from feishu_push import _load_feishu_config, _get_app_access_token, _send_feishu_message\n        cfg = _load_feishu_config()\n        if not cfg.get(\"app_id\"):\n            print(\"[PUSH] no feishu config, skipping\")\n            return\n        token = _get_app_access_token(cfg[\"app_id\"], cfg[\"app_secret\"])\n        top10 = candidates.head(10).copy()\n        score_col = \"guard_score\" if \"guard_score\" in top10.columns else \"score\"\n        date_display = f\"{date_tag[:4]}-{date_tag[4:6]}-{date_tag[6:8]}\"\n        lines_msg = [f\"📊 **{date_display} 实时候选变化**（有变化才推送）\"]\n        lines_msg.append(\"\")\n        for i, (_, r) in enumerate(top10.iterrows(), 1):\n            code = str(r[\"ts_code\"])\n            score = float(r.get(score_col, 0))\n            close = float(r.get(\"close\", 0))\n            vwap60 = float(r.get(\"vwap60\", 0))\n            reason = _build_reason_text(r)\n            # Suggested entry: use vwap60 if available, else close\n            ref_price = vwap60 if vwap60 > 0 else close\n            if ref_price > 0:\n                lo = ref_price * 0.98\n                hi = ref_price * 1.02\n                price_str = f\"参考价{vwap60:.2f}（区间{lo:.2f}~{hi:.2f}）\"\n            else:\n                price_str = f\"现价{close:.2f}\"\n            lines_msg.append(f\"{i}. {code}｜{price_str}\")\n            lines_msg.append(f\"   原因：{reason}｜得分{score:.4f}\")\n        lines_msg.append(\"\")\n        lines_msg.append(\"⚠️ 变化：\" + \"；\".join(reasons))\n        lines_msg.append(\"\")\n        lines_msg.append(\"🔔 风险提示：盘中价格波动较大，信号仅供参考\")\n        msg_text = \"\\n\".join(lines_msg)\n        result = _send_feishu_message(token, cfg[\"open_id\"], \"text\", {\"text\": msg_text})\n        if result.get(\"code\") == 0:\n            print(f\"[PUSH] candidate change pushed to feishu: {', '.join(reasons)}\")\n        else:\n            print(f\"[PUSH] feishu push failed: {result}\")\n    except Exception as e:\n        print(f\"[PUSH] candidate change push failed: {e}\")\n\n\n[189 more lines in file. Use offset=540 to continue.]"}],"isError":false,"timestamp":1776530852670}}
