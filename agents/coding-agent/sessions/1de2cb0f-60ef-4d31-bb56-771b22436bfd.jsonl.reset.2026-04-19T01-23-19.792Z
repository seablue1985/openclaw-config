rce\": \"\",\n        \"outputs\": {},\n        \"top_preview\": {},\n        \"status\": \"PASS\",\n        \"reason\": \"\",\n    }\n"},{"oldText":"        use_realtime = (args.realtime or args.force_realtime) or (\n            not args.no_realtime and is_market_open()\n        )\n        if use_realtime:\n            print(f\"[REALTIME] fetching live prices for universe...\", flush=True)\n            # First get the liquid universe from CSV to know which symbols to fetch\n            temp_universe_symbols = pick_liquid_symbols(price_frame, max_symbols=300)\n            realtime_closes = fetch_realtime_closes(temp_universe_symbols)\n            if realtime_closes:\n                price_frame = inject_realtime_prices(price_frame, realtime_closes, date_tag)\n                print(f\"[REALTIME] injected {len(realtime_closes)} real-time prices\", flush=True)\n            else:\n                print(f\"[REALTIME] no prices fetched, falling back to CSV\", flush=True)\n","newText":"        use_realtime = (args.realtime or args.force_realtime) or (\n            not args.no_realtime and is_market_open()\n        )\n        summary[\"realtime_requested\"] = bool(args.realtime or args.force_realtime)\n        summary[\"realtime_attempted\"] = bool(use_realtime)\n        if use_realtime:\n            print(f\"[REALTIME] fetching live prices for universe...\", flush=True)\n            # First get the liquid universe from CSV to know which symbols to fetch\n            temp_universe_symbols = pick_liquid_symbols(price_frame, max_symbols=300)\n            realtime_closes = fetch_realtime_closes(temp_universe_symbols)\n            if realtime_closes:\n                price_frame = inject_realtime_prices(price_frame, realtime_closes, date_tag)\n                summary[\"realtime_injected_count\"] = len(realtime_closes)\n                summary[\"realtime_source\"] = \"tencent\"\n                summary[\"price_mode\"] = \"realtime_injected\"\n                print(f\"[REALTIME] injected {len(realtime_closes)} real-time prices\", flush=True)\n            else:\n                summary[\"realtime_injected_count\"] = 0\n                summary[\"price_mode\"] = \"historical_csv_fallback\"\n                print(f\"[REALTIME] no prices fetched, falling back to CSV\", flush=True)\n"},{"oldText":"        summary[\"price_lag_days\"] = int(price_lag_days) if price_lag_days < 10**9 else None\n        summary[\"basic_lag_days\"] = int(basic_lag_days) if basic_lag_days < 10**9 else None\n","newText":"        summary[\"price_lag_days\"] = int(price_lag_days) if price_lag_days < 10**9 else None\n        summary[\"basic_lag_days\"] = int(basic_lag_days) if basic_lag_days < 10**9 else None\n        summary[\"price_freshness\"] = \"FRESH\" if str(market_trade_date) == str(date_tag) else \"STALE\"\n"},{"oldText":"        summary[\"top_preview\"][\"v4_2\"] = (\n            main_candidates[[\"ts_code\", \"score\"]].head(5).to_dict(orient=\"records\")\n            if not main_candidates.empty else []\n        )\n        summary[\"top_preview\"][\"v4_2b\"] = (\n            guard_candidates[[\"ts_code\", \"score\", \"guard_mode\"]].head(5).to_dict(orient=\"records\")\n            if not guard_candidates.empty else []\n        )\n","newText":"        summary[\"top_preview\"][\"v4_2\"] = (\n            main_candidates[[\"ts_code\", \"score\", \"close\", \"source_trade_date\"]].head(5).to_dict(orient=\"records\")\n            if not main_candidates.empty else []\n        )\n        summary[\"top_preview\"][\"v4_2b\"] = (\n            guard_candidates[[\"ts_code\", \"score\", \"guard_mode\", \"close\", \"source_trade_date\"]].head(5).to_dict(orient=\"records\")\n            if not guard_candidates.empty else []\n        )\n"}]},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/generate_live_smallcap_candidates.py\",\"edits\":[{\"oldText\":\"    summary: dict[str, Any] = {\\n        \\\"generated_at\\\