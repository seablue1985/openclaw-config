(description=\"Enrich holdings CSV with freshest available prices\")\n 128     parser.add_argument(\"--input\", \"-i\", required=True, help=\"Input holdings CSV\")\n 129     parser.add_argument(\"--output\", \"-o\", required=True, help=\"Output enriched CSV\")\n 130     args = parser.parse_args()\n 131 \n     ...\n 140         reader = csv.DictReader(f)\n 141         holdings = list(reader)\n 142 \n 143     tickers = [h[\"symbol\"] for h in holdings]\n-144     print(f\"[enrich_holdings] Fetching prices for {len(tickers)} tickers...\")\n+149     print(f\"[enrich_holdings] Fetching freshest prices for {len(tickers)} tickers...\")\n 145 \n-146     price_map = fetch_prices(tickers)\n-147     print(f\"[enrich_holdings] Got prices for {len(price_map)} tickers\")\n+151     # Batch Tencent first (fast); fall back per-symbol to multi-source fetcher.\n+152     tencent_map = fetch_prices(tickers)\n+153     fetcher = PriceFetcher()\n+154     now_iso = datetime.now().isoformat()\n 148 \n 149     # Enrich holdings\n 150     enriched: list[dict] = []\n 151     for h in holdings:\n     ...\n 156             cost = float(cost_str)\n 157         except (ValueError, TypeError):\n 158             cost = 0.0\n 159 \n-160         # Find price\n 161         current_price = None\n 162         prev_close = None\n 163         change_pct = None\n+170         price_source = \"\"\n+171         price_timestamp = \"\"\n+172         price_is_stale = \"\"\n+173         price_error = \"\"\n 164 \n+175         # 1) fast Tencent batch result\n+176         quote_found = False\n 165         for suffix, prefix in _EXCHANGE_MAP.items():\n 166             if symbol.endswith(suffix):\n 167                 qt_key = prefix + symbol.replace(suffix, \"\")\n-168                 if qt_key in price_map:\n-169                     p = price_map[qt_key]\n+180                 if qt_key in tencent_map:\n+181                     p = tencent_map[qt_key]\n 170                     current_price = p[\"current_price\"]\n 171                     prev_close = p[\"prev_close\"]\n 172                     change_pct = p[\"change_pct\"]\n+185                     if current_price is not None and float(current_price) > 0:\n+186                         price_source = \"tencent_batch\"\n+187                         price_timestamp = p.get(\"date\") or now_iso\n+188                         price_is_stale = \"0\"\n+189                         quote_found = True\n 173                 break\n 174 \n+192         # 2) multi-source fallback if batch quote failed\n+193         if not quote_found:\n+194             result = fetcher.fetch_price(symbol)\n+195             if result.success and result.price > 0:\n+196                 current_price = result.price\n+197                 price_source = result.source\n+198                 price_timestamp = result.timestamp or now_iso\n+199                 # Non-intraday sources may still be latest close rather than live quote; mark explicitly.\n+200                 price_is_stale = \"1\" if result.source in {\"tushare\", \"yahoo\"} else \"0\"\n+201                 price_error = \"\"\n+202             else:\n+203                 price_source = result.source or \"all_failed\"\n+204                 price_timestamp = result.timestamp or now_iso\n+205                 price_is_stale = \"1\"\n+206                 price_error = result.error or \"fetch_failed\"\n+207 \n 175         h[\"current_price\"] = str(current_price) if current_price is not None else \"\"\n 176         h[\"prev_close\"] = str(prev_close) if prev_close is not None else \"\"\n 177         h[\"change_pct_today\"] = str(change_pct) if change_pct is not None else \"\"\n+211         h[\"price_source\"] = price_source\n+212         h[\"price_timestamp\"] = price_timestamp\n+213         h[\"price_is_stale\"] = price_is_stale\n+214         h[\"price_error\"] = price_error\n 178 \n 179         if current_price and cost and cost > 0:\n-180             pnl_pct = (current_price - cost) / cost * 100\n+217             pnl_pct = (float(current_price) - cost) / cost * 100\n 181             h[\"unrealized_pnl_pct\"] = f\"{pnl_pct:.2f}\"\n-182             mkt_val = current_price * float(h.get(\"quantity\", 0))\n+219             mkt_val = float(current_price) * float(h.get(\"quantity\", 0))\n 183             h[\"market_value\"] = f\"{mkt_val:.2f}\"\n 184         else:\n 185             h[\"unrealized_pnl_pct\"] = \"\"\n 186             h[\"market_value\"] = \"\"\n     ...\n 205         pnl = h.get(\"unrealized_pnl_pct\", \"N/A\")\n 206         cur = h.get(\"current_price\", \"N/A\")\n 207         chg = h.get(\"change_pct_today\", \"\")\n 208         chg_str = f\"{float(chg):+.2f}%\" if chg else \"\"\n-209         print(f\"  {h['symbol']:15s} {h.get('name',''):10s}  cur={cur:>8s}  cost={h.get('cost_price',''):>8s}  pnl={pnl:>8s}%  today={chg_str}\")\n+246         stale = \"STALE\" if str(h.get(\"price_is_stale\", \"0\")) == \"1\" else \"FRESH\"\n+247         source = h.get(\"price_source\", \"\")\n+248         print(\n+249             f\"  {h['symbol']:15s} {h.get('name',''):10s}  cur={cur:>8s}  cost={h.get('cost_price',''):>8s}  \"\n+250             f\"pnl={pnl:>8s}%  today={chg_str:<8s}  source={source:<12s}  {stale}\"\n+251         )\n 210     return 0\n 211 \n 212 \n 213 if __name__ == \"__main__\":\n     ...","firstChangedLine":2},"isError":false,"timestamp":1776529823712}}
