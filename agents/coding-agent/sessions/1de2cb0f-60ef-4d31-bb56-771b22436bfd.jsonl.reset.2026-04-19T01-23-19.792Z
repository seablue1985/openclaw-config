=df.iloc[-2] if len(df)>=2 else last\n        high60=float(df['high'].tail(60).max())\n        low60=float(df['low'].tail(60).min())\n        high20=float(df['high'].tail(20).max())\n        low20=float(df['low'].tail(20).min())\n        print('TECH', {\n            'date': str(last['date'].date()),\n            'close': round(float(last['close']),2),\n            'pct': round(float(last.get('pct',0)),2),\n            'turnover': round(float(last.get('turnover',0)),2),\n            'ma5': round(float(last['ma5']),2),\n            'ma10': round(float(last['ma10']),2),\n            'ma20': round(float(last['ma20']),2),\n            'ma60': round(float(last['ma60']),2),\n            'dist_ma20_pct': round((float(last['close'])/float(last['ma20'])-1)*100,2),\n            '20d_high': round(high20,2),\n            '20d_low': round(low20,2),\n            '60d_high': round(high60,2),\n            '60d_low': round(low60,2),\n        })\n    except Exception as e:\n        print('HIST_ERR',e)\nPY","workdir":"/Users/ling/.openclaw/workspace/coding-agent","timeout":120,"yieldMs":1000},"partialJson":"{\"command\":\"python3 - <<'PY'\\nimport akshare as ak\\nimport pandas as pd\\nfrom datetime import datetime, timedelta\\nstocks = [('002119','002119.SZ 康强电子'),('300442','300442.SZ 润泽科技')]\\nstart=(datetime.now()-timedelta(days=220)).strftime('%Y%m%d')\\nend=datetime.now().strftime('%Y%m%d')\\nfor code,name in stocks:\\n    print('\\\\n###',name)\\n    try:\\n        qdf=ak.stock_bid_ask_em(symbol=code)\\n        quote={str(r['item']): r['value'] for _,r in qdf.iterrows()}\\n        print('QUOTE', {k:quote.get(k) for k in ['最新','涨幅','涨跌','总手','金额','换手','市盈率','市净率','最高','最低','今开','昨收']})\\n    except Exception as e:\\n        print('QUOTE_ERR',e)\\n    try:\\n        df=ak.stock_zh_a_hist(symbol=code, period='daily', start_date=start, end_date=end, adjust='qfq')\\n        # normalize columns\\n        cols=list(df.columns)\\n        rename={cols[0]:'date', cols[1]:'open', cols[2]:'close', cols[3]:'high', cols[4]:'low', cols[5]:'volume', cols[6]:'amount', cols[7]:'amplitude', cols[8]:'pct', cols[9]:'chg', cols[10]:'turnover'} if len(cols)>=11 else {}\\n        df=df.rename(columns=rename)\\n        for c in ['open','close','high','low','volume','amount','pct','turnover']:\\n            if c in df.columns:\\n                df[c]=pd.to_numeric(df[c],errors='coerce')\\n        df['date']=pd.to_datetime(df['date'])\\n        df=df.dropna(subset=['date','close']).sort_values('date').reset_index(drop=True)\\n        for n in [5,10,20,60]:\\n            df[f'ma{n}']=df['close'].rolling(n).mean()\\n        last=df.iloc[-1]\\n        prev=df.iloc[-2] if len(df)>=2 else last\\n        high60=float(df['high'].tail(60).max())\\n        low60=float(df['low'].tail(60).min())\\n        high20=float(df['high'].tail(20).max())\\n        low20=float(df['low'].tail(20).min())\\n        print('TECH', {\\n            'date': str(last['date'].date()),\\n            'close': round(float(last['close']),2),\\n            'pct': round(float(last.get('pct',0)),2),\\n            'turnover': round(float(last.get('turnover',0)),2),\\n            'ma5': round(float(last['ma5']),2),\\n            'ma10': round(float(last['ma10']),2),\\n            'ma20': round(float(last['ma20']),2),\\n            'ma60': round(float(last['ma60']),2),\\n            'dist_ma20_pct': round((float(last['close'])/float(last['ma20'])-1)*100,2),\\n            '20d_high': round(high20,2),\\n            '20d_low': round(low20,2),\\n            '60d_high': round(high60,2),\\n            '60d_low': round(low60,2),\\n        })\\n    except Exception as e:\\n        print('HIST_ERR',e)\\nPY\",\"workdir\":\"/Users/ling/.openclaw/workspace/coding-agent\",\"timeout\":120,\"yieldMs\":1000}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":216211,"output":1051,"cacheRead":0,"cacheWrite":0,"totalTokens":217262,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total"