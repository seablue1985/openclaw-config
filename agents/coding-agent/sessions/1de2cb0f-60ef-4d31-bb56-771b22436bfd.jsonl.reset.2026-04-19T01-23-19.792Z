)\n\n\ndef main() -> None:\n","newText":"def trade_exit_type_options(trades: pd.DataFrame) -> str:\n    if trades.empty:\n        return \"\"\n    exit_types = sorted({str(x).strip().lower() for x in trades.get(\"exit_type\", pd.Series(dtype=str)).fillna(\"\") if str(x).strip()})\n    return \"\\n\".join(\n        [\n            f\"<option value=\\\"{html.escape(exit_type)}\\\">{html.escape(exit_type)}</option>\"\n            for exit_type in exit_types\n        ]\n    )\n\n\ndef trade_rows_html(trades: pd.DataFrame) -> str:\n    if trades.empty:\n        return \"<tr><td colspan='12' style='text-align:center;color:#93a4c0'>暂无成交日志</td></tr>\"\n    rows: list[str] = []\n    for _, row in trades.iterrows():\n        side = str(row.get(\"action\", \"\") or \"\").strip().upper()\n        rows.append(\n            \"<tr>\"\n            f\"<td>{html.escape(str(row.get('date', '') or '')[:10])}</td>\"\n            f\"<td class=\\\"{'buy' if side == 'BUY' else 'sell' if side == 'SELL' else ''}\\\">{html.escape(side)}</td>\"\n            f\"<td>{symbol_cell_html(row.get('ts_code', ''), row.get('symbol_name', ''))}</td>\"\n            f\"<td>{fmt(row.get('price'), 4)}</td>\"\n            f\"<td>{fmt(row.get('shares'), 0)}</td>\"\n            f\"<td>{fmt(row.get('amount'), 2)}</td>\"\n            f\"<td>{fmt(row.get('fee'), 2)}</td>\"\n            f\"<td>{fmt(row.get('slippage'), 2)}</td>\"\n            f\"<td>{html.escape(str(row.get('signal_reason', '') or ''))}</td>\"\n            f\"<td>{html.escape(str(row.get('exit_type', '') or ''))}</td>\"\n            f\"<td>{html.escape(str(row.get('exit_reason', '') or ''))}</td>\"\n            f\"<td>{html.escape(str(row.get('notes', '') or ''))}</td>\"\n            \"</tr>\"\n        )\n    return \"\\n\".join(rows)\n\n\ndef main() -> None:\n"},{"oldText":"          <tbody id=\"tradeTable\"></tbody>\n","newText":"          <tbody id=\"tradeTable\">{trade_rows_html(all_trades_df)}</tbody>\n"},{"oldText":"    const perfRows = {json.