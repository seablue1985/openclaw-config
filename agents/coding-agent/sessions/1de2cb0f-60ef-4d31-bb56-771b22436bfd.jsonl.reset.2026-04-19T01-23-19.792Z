{"type":"message","id":"df95a708","parentId":"d8be3d34","timestamp":"2026-04-18T15:17:16.267Z","message":{"role":"toolResult","toolCallId":"call_orCRzmltvGO58I09UtxidVcg|fc_0fad9e409c19087f0169e3a079589c819aafa45cae9e12e2f4","toolName":"read","content":[{"type":"text","text":"        \"trade_count\": int(trade_stats.get(\"closed_trade_count\", 0) or 0),\n        \"closed_trade_count\": int(trade_stats.get(\"closed_trade_count\", 0) or 0),\n        \"journal_trade_count\": int(trade_stats.get(\"journal_trade_count\", 0) or 0),\n        \"buy_trade_count\": int(trade_stats.get(\"buy_trade_count\", 0) or 0),\n        \"sell_trade_count\": int(trade_stats.get(\"sell_trade_count\", 0) or 0),\n        \"realized_pnl_total\": trade_stats.get(\"realized_pnl_total\", 0.0),\n        \"benchmark_name\": benchmark_name,\n    }\n\n\ndef metric_rows_html(metrics: dict[str, Any]) -> str:\n    rows = [\n        (\"策略收益\", fmt_pct(metrics.get(\"strategy_total_return_pct\"))),\n        (\"策略年化收益\", fmt_pct(metrics.get(\"strategy_annual_return_pct\"))),\n        (f\"{metrics.get('benchmark_name', '中证2000')}收益\", fmt_pct(metrics.get(\"benchmark_total_return_pct\"))),\n        (\"阿尔法\", fmt_pct(metrics.get(\"alpha_pct\"))),\n        (\"贝塔\", fmt_ratio(metrics.get(\"beta\"))),\n        (\"夏普比率\", fmt_ratio(metrics.get(\"sharpe\"))),\n        (\"索提诺比率\", fmt_ratio(metrics.get(\"sortino\"))),\n        (\"信息比率\", fmt_ratio(metrics.get(\"information_ratio\"))),\n        (\"策略波动率\", fmt_pct(metrics.get(\"strategy_vol_pct\"))),\n        (\"基准波动率\", fmt_pct(metrics.get(\"benchmark_vol_pct\"))),\n        (\"最大回撤\", fmt_pct(metrics.get(\"max_drawdown_pct\"))),\n        (\"超额收益最大回撤\", fmt_pct(metrics.get(\"excess_max_drawdown_pct\"))),\n        (\"超额收益夏普比率\", fmt_ratio(metrics.get(\"excess_sharpe\"))),\n        (\"日均超额收益\", fmt_pct(metrics.get(\"daily_avg_excess_return_pct\"), 4)),\n        (\"胜率\", fmt_pct(metrics.get(\"trade_win_rate_pct\"))),\n        (\"日胜率\", fmt_pct(metrics.get(\"daily_win_rate_pct\"))),\n        (\"盈亏比\", fmt_ratio(metrics.get(\"profit_loss_ratio\"))),\n        (\"盈利次数\", fmt(metrics.get(\"win_count\"), 0)),\n        (\"亏损次数\", fmt(metrics.get(\"loss_count\"), 0)),\n        (\"最大回撤区间\", html.escape(str(metrics.get(\"max_drawdown_interval\", \"-\")))),\n    ]\n    html_rows = []\n    for label, value in rows:\n        html_rows.append(\n            \"<tr>\"\n            f\"<th>{html.escape(str(label))}</th>\"\n            f\"<td>{value}</td>\"\n            \"</tr>\"\n        )\n    return \"\\n\".join(html_rows)\n\n\ndef performance_payload(perf: pd.DataFrame) -> list[dict[str, Any]]:\n    if perf.empty:\n        return []\n    out = perf[\n        [\n            \"date_str\",\n            \"strategy_equity\",\n            \"benchmark_equity\",\n            \"excess_equity\",\n            \"strategy_ret_pct\",\n            \"benchmark_ret_pct\",\n            \"excess_ret_pct\",\n            \"strategy_drawdown_pct\",\n            \"excess_drawdown_pct\",\n        ]\n    ].copy()\n    out = out.rename(columns={\"date_str\": \"date\"})\n    return as_records(out)\n\n\ndef positions_export_payload(positions_df: pd.DataFrame) -> list[dict[str, Any]]:\n    if positions_df.empty:\n        return []\n    out = positions_df.copy()\n    out[\"symbol_name\"] = safe_text_series(out, \"symbol_name\")\n    columns = [\n        \"symbol\",\n        \"symbol_name\",\n        \"quantity\",\n        \"cost_price\",\n        \"last_price\",\n        \"market_value\",\n        \"unrealized_pnl\",\n        \"unrealized_pnl_pct\",\n    ]\n    for col in columns:\n        if col not in out.columns:\n            out[col] = None\n    return as_records(out[columns])\n\n\ndef positions_rows_html(positions_df: pd.DataFrame) -> str:\n    if positions_df.empty:\n        return \"<tr><td colspan='7' style='text-align:center;color:#93a4c0'>暂无模拟持仓</td></tr>\"\n    rows = []\n    for _, row in positions_df.iterrows():\n        pnl = parse_float(row.get(\"unrealized_pnl\"), np.nan)\n        pnl_pct = parse_float(row.get(\"unrealized_pnl_pct\"), np.nan)\n        rows.append(\n            \"<tr>\"\n            f\"<td>{symbol_cell_html(row.get('symbol', ''), row.get('symbol_name', row.get('name', '')))}</td>\"\n            f\"<td>{fmt(row.get('quantity'), 0)}</td>\"\n            f\"<td>{fmt(row.get('cost_price'), 4)}</td>\"\n            f\"<td>{fmt(row.get('last_price'), 4)}</td>\"\n            f\"<td>{fmt(row.get('market_value'), 2)}</td>\"\n            f\"<td class=\\\"{'pos' if np.isfinite(pnl) and pnl >= 0 else 'neg'}\\\">{fmt(pnl, 2)}</td>\"\n            f\"<td class=\\\"{'pos' if np.isfinite(pnl_pct) and pnl_pct >= 0 else 'neg'}\\\">{fmt(pnl_pct, 2)}%</td>\"\n            \"</tr>\"\n        )\n    return \"\\n\".join(rows)\n\n\ndef trade_filter_options(trades: pd.DataFrame) -> str:\n    if trades.empty:\n        return \"\"\n    symbols = sorted({str(x).strip().upper() for x in trades.get(\"ts_code\", pd.Series(dtype=str)).fillna(\"\") if str(x).strip()})\n    labels = {\n        str(row.get(\"ts_code\", \"\")).strip().upper(): clean_symbol_name(row.get(\"symbol_name\", \"\"))\n        for _, row in trades.iterrows()\n    }\n    return \"\\n\".join(\n        [\n            f\"<option value=\\\"{html.escape(symbol)}\\\">{html.escape(symbol)}{' | ' + html.escape(labels.get(symbol, '')) if labels.get(symbol, '') else ''}</option>\"\n            for symbol in symbols\n        ]\n    )\n\n[648 more lines in file. Use offset=780 to continue.]"}],"isError":false,"timestamp":1776525436240}}
