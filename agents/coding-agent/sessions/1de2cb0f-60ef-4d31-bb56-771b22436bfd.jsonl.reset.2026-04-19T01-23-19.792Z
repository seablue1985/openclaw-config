{"type":"message","id":"349537d3","parentId":"e916c4c1","timestamp":"2026-04-18T15:17:05.101Z","message":{"role":"toolResult","toolCallId":"call_6kd6cpzfyomEN7JqhET6QT6B|fc_0fad9e409c19087f0169e3a06f15ac819aa430a78440c4ca82","toolName":"read","content":[{"type":"text","text":"        return np.nan\n    return ann / downside_vol\n\n\ndef information_ratio(excess_ret: pd.Series) -> float:\n    series = excess_ret.dropna().astype(float)\n    if len(series) < 2:\n        return np.nan\n    std = float(series.std(ddof=0))\n    if std <= 0:\n        return np.nan\n    return float(series.mean() / std * np.sqrt(252.0))\n\n\ndef alpha_beta(strategy_ret: pd.Series, benchmark_ret: pd.Series) -> tuple[float, float]:\n    aligned = pd.concat(\n        [\n            strategy_ret.rename(\"strategy\"),\n            benchmark_ret.rename(\"benchmark\"),\n        ],\n        axis=1,\n        join=\"inner\",\n    ).dropna()\n    if len(aligned) < 2:\n        return np.nan, np.nan\n    bench_var = float(aligned[\"benchmark\"].var(ddof=0))\n    if bench_var <= 0:\n        return np.nan, np.nan\n    cov = float(np.cov(aligned[\"strategy\"], aligned[\"benchmark\"], ddof=0)[0, 1])\n    beta = cov / bench_var\n    alpha_daily = float(aligned[\"strategy\"].mean() - beta * aligned[\"benchmark\"].mean())\n    return alpha_daily * 252.0, beta\n\n\ndef drawdown_info(equity: pd.Series, date_index: pd.Series) -> dict[str, Any]:\n    values = pd.Series(pd.to_numeric(equity, errors=\"coerce\").astype(float).values, index=pd.Index(date_index))\n    values = values.dropna()\n    if values.empty:\n        return {\n            \"max_drawdown_pct\": np.nan,\n            \"peak_date\": \"\",\n            \"trough_date\": \"\",\n            \"recovery_date\": \"\",\n            \"interval_text\": \"-\",\n        }\n\n    peak = values.cummax()\n    drawdown = values / peak - 1.0\n    trough_date = drawdown.idxmin()\n    max_drawdown_pct = abs(float(drawdown.loc[trough_date])) * 100.0\n    peak_window = values.loc[:trough_date]\n    peak_date = peak_window.idxmax()\n    recovery_window = values.loc[trough_date:]\n    recovery_mask = recovery_window >= float(values.loc[peak_date])\n    recovery_date = \"\"\n    if recovery_mask.any():\n        recovery_date = str(recovery_mask[recovery_mask].index[0])[:10]\n\n    peak_str = str(peak_date)[:10]\n    trough_str = str(trough_date)[:10]\n    if recovery_date:\n        interval_text = f\"{peak_str} -> {trough_str} -> {recovery_date}\"\n    else:\n        interval_text = f\"{peak_str} -> {trough_str} (未修复)\"\n    return {\n        \"max_drawdown_pct\": round(max_drawdown_pct, 2),\n        \"peak_date\": peak_str,\n        \"trough_date\": trough_str,\n        \"recovery_date\": recovery_date,\n        \"interval_text\": interval_text,\n    }\n\n\ndef sanitize_for_json(value: Any) -> Any:\n    if isinstance(value, dict):\n        return {k: sanitize_for_json(v) for k, v in value.items()}\n    if isinstance(value, list):\n        return [sanitize_for_json(v) for v in value]\n    if isinstance(value, tuple):\n        return [sanitize_for_json(v) for v in value]\n    if isinstance(value, (np.floating, float)):\n        return None if not np.isfinite(float(value)) else float(value)\n    if isinstance(value, (np.integer, int)):\n        return int(value)\n    return value\n\n\ndef load_benchmark_frame(cfg: dict[str, Any]) -> tuple[pd.DataFrame, str, Path | None]:\n    benchmark_cfg = cfg.get(\"benchmark\", {}) or {}\n    benchmark_name = str(benchmark_cfg.get(\"name\", \"中证2000\")).strip() or \"中证2000\"\n    paths: list[Path] = []\n    if benchmark_cfg.get(\"file\"):\n        paths.append(resolve_path(str(benchmark_cfg.get(\"file\"))))\n    for path in BENCHMARK_CANDIDATES:\n        if path not in paths:\n            paths.append(path)\n\n    for path in paths:\n        if not path.exists():\n            continue\n        df = load_csv(path)\n        if df.empty or \"close\" not in df.columns:\n            continue\n\n        out = pd.DataFrame()\n        if \"trade_date\" in df.columns:\n            out[\"date\"] = pd.to_datetime(df[\"trade_date\"].astype(str), errors=\"coerce\")\n        elif \"date\" in df.columns:\n            out[\"date\"] = pd.to_datetime(df[\"date\"], errors=\"coerce\")\n        else:\n            continue\n        out[\"close\"] = pd.to_numeric(df[\"close\"], errors=\"coerce\")\n        if \"pct_chg\" in df.columns:\n            out[\"benchmark_ret\"] = pd.to_numeric(df[\"pct_chg\"], errors=\"coerce\") / 100.0\n        else:\n            out[\"benchmark_ret\"] = out[\"close\"].pct_change()\n        out = out.dropna(subset=[\"date\", \"close\"]).sort_values(\"date\").reset_index(drop=True)\n        return out[[\"date\", \"close\", \"benchmark_ret\"]].copy(), benchmark_name, path\n    return pd.DataFrame(columns=[\"date\", \"close\", \"benchmark_ret\"]), benchmark_name, None\n\n\ndef prepare_performance_frame(curve_df: pd.DataFrame, benchmark_df: pd.DataFrame, initial_cash: float) -> pd.DataFrame:\n    if curve_df.empty or initial_cash <= 0:\n        return pd.DataFrame()\n\n    out = curve_df.copy()\n    out[\"date\"] = pd.to_datetime(out.get(\"date\"), errors=\"coerce\")\n    out[\"nav\"] = pd.to_numeric(out.get(\"nav\"), errors=\"coerce\")\n    out[\"cash\"] = pd.to_numeric(out.get(\"cash\"), errors=\"coerce\")\n    out[\"market_value\"] = pd.to_numeric(out.get(\"market_value\"), errors=\"coerce\")\n    out = out.dropna(subset=[\"date\", \"nav\"]).sort_values(\"date\").reset_index(drop=True)\n    if out.empty:\n        return out\n\n    out[\"strategy_equity\"] = out[\"nav\"] / float(initial_cash)\n    out[\"strategy_ret\"] = out[\"nav\"].pct_change()\n    first_idx = out.index[0]\n    out.loc[first_idx, \"strategy_ret\"] = out.loc[first_idx, \"nav\"] / float(initial_cash) - 1.0\n\n    if benchmark_df.empty:\n\n[1048 more lines in file. Use offset=380 to continue.]"}],"isError":false,"timestamp":1776525425081}}
