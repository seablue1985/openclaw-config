{"type":"message","id":"9fbe5242","parentId":"e68e0725","timestamp":"2026-04-21T01:36:32.714Z","message":{"role":"toolResult","toolCallId":"call_00_0SA2zTr3JPmliCHlj1uIdrPQ","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n修复持仓数据管道 - 不再依赖不稳定的同花顺网页账本\n\"\"\"\nimport sys\nimport os\nimport json\nimport pandas as pd\nfrom datetime import datetime, timedelta\nfrom pathlib import Path\nfrom typing import Dict, List, Any\n\nPROJECT_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system\")\nREPORTS_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nCONFIG_DIR = PROJECT_ROOT / \"config\"\n\n\nclass HoldingsPipelineFixer:\n    \"\"\"持仓数据管道修复器\"\"\"\n    \n    def __init__(self):\n        self.today = datetime.now().strftime(\"%Y%m%d\")\n        self.now_str = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    \n    def analyze_current_state(self):\n        \"\"\"分析当前状态\"\"\"\n        print(\"=\" * 60)\n        print(\"持仓数据管道状态分析\")\n        print(\"=\" * 60)\n        \n        # 1. 检查同花顺网页数据\n        ths_file = REPORTS_DIR / \"ths_web_selected_holdings_latest.json\"\n        if ths_file.exists():\n            with open(ths_file, 'r', encoding='utf-8') as f:\n                ths_data = json.load(f)\n            \n            ths_time = ths_data.get(\"generated_at\", \"未知\")\n            print(f\"1. 同花顺网页账本:\")\n            print(f\"   文件: {ths_file.name}\")\n            print(f\"   生成时间: {ths_time}\")\n            \n            # 计算时间差\n            try:\n                gen_time = datetime.fromisoformat(ths_time.replace('Z', '+00:00'))\n                hours_diff = (datetime.now() - gen_time).total_seconds() / 3600\n                print(f\"   陈旧度: {hours_diff:.1f} 小时\")\n                print(f\"   状态: {'❌ 陈旧' if hours_diff > 24 else '✅ 新鲜'}\")\n            except:\n                print(f\"   状态: ⚠️ 时间格式异常\")\n        else:\n\n[353 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1776735392695}}
