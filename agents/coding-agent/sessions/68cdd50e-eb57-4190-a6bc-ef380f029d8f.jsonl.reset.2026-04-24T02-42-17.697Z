{"type":"message","id":"bd68b633","parentId":"6b71e892","timestamp":"2026-04-21T01:37:00.194Z","message":{"role":"toolResult","toolCallId":"call_00_7icuRMyNnsMnJfCbvXT5Xp8d","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nAggressive 18% 策略 - 持续实时监控\n在后台持续运行，每5分钟检测一次\n\"\"\"\nimport sys\nimport time\nimport subprocess\nimport shutil\nfrom pathlib import Path\nfrom datetime import datetime\nimport urllib.request\nimport ssl\n\nPROJECT_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system\")\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\n\n# 策略参数\nSTOP_LOSS_PCT = -5.0\nTRAILING_TAKE_PROFIT_PCT = -8.0\nCHECK_INTERVAL = 300  # 5分钟检测一次\n\n# 飞书用户ID\nFEISHU_USER_ID = \"ou_47c21eede907b0c4f9fd4d34519d84ae\"\n\ndef send_feishu(text):\n    \"\"\"发送飞书消息\"\"\"\n    try:\n        openclaw_bin = shutil.which('openclaw') or '/Users/ling/.local/share/fnm/node-versions/v22.22.0/installation/bin/openclaw'\n        cmd = [\n            openclaw_bin,\n            'message', 'send',\n            '--channel', 'feishu',\n            '--account', 'coding-agent',\n            '--target', f'user:{FEISHU_USER_ID}',\n            '--message', text,\n            '--json',\n        ]\n        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)\n        if result.returncode == 0:\n            print(\"✅ 飞书推送成功\")\n            return True\n        else:\n            err = (result.stderr or result.stdout or '').strip()\n            print(f\"⚠️ 推送失败: {err}\")\n            return False\n    except Exception as e:\n        print(f\"⚠️ 推送异常: {e}\")\n        return False\n\n\n[139 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1776735420177}}
{"type":"message","id":"163c7b76","parentId":"bd68b633","timestamp":"2026-04-21T01:37:05.677Z","message":{"role":"assistant","content":[{"type":"text","text":"让我继续查看这个文件，看看持仓数据的读取逻辑："},{"type":"toolCall","id":"call_00_AxLKKp3qVpaJoWU4MS2NQNPA","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/coding-agent/run_aggressive_livemonitor.py","offset":51,"limit":100}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":501,"output":108,"cacheRead":71104,"cacheWrite":0,"totalTokens":71713,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776735420194,"responseId":"f2dfe2a3-1caf-4fdd-973c-a50f6da4d0d6"}}
{"type":"message","id":"1746e3a1","parentId":"163c7b76","timestamp":"2026-04-21T01:37:05.799Z","message":{"role":"toolResult","toolCallId":"call_00_AxLKKp3qVpaJoWU4MS2NQNPA","toolName":"read","content":[{"type":"text","text":"def get_realtime_price(ts_code):\n    \"\"\"获取实时价格\"\"\"\n    try:\n        if ts_code.endswith('.SH'):\n            market = 'sh' + ts_code.replace('.SH', '')\n        else:\n            market = 'sz' + ts_code.replace('.SZ', '')\n        \n        url = f'http://qt.gtimg.cn/q={market}'\n        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})\n        \n        ctx = ssl.create_default_context()\n        ctx.check_hostname = False\n        ctx.verify_mode = ssl.CERT_NONE\n        \n        with urllib.request.urlopen(req, timeout=5, context=ctx) as r:\n            content = r.read().decode('gbk', errors='replace')\n        \n        parts = content.split('~')\n        if len(parts) > 3:\n            return float(parts[3]), float(parts[32]) if len(parts) > 32 else 0\n    except:\n        pass\n    return None, None\n\ndef is_trading_hours():\n    \"\"\"检查是否在交易时段\"\"\"\n    now = datetime.now()\n    weekday = now.weekday()\n    hour = now.hour\n    minute = now.minute\n    \n    if weekday >= 5:  # 周末\n        return False\n    if hour < 9 or (hour == 9 and minute < 25):\n        return False\n    if hour >= 15:\n        return False\n    return True\n\ndef analyze_and_push():\n    \"\"\"分析持仓并推送信号\"\"\"\n    positions_file = REPORT_DIR / \"paper_aggressive_portfolio_positions_latest.csv\"\n    \n    if not positions_file.exists():\n        print(f\"[{datetime.now().strftime('%H:%M:%S')}] ⚠️ 持仓文件不存在\")\n        return\n    \n    # 读取持仓\n    positions = []\n    with open(positions_file, 'r', encoding='utf-8-sig') as f:\n        lines = f.readlines()\n        for line in lines[1:]:\n            parts = line.strip().split(',')\n            if len(parts) >= 8:\n                positions.append({\n                    'symbol': parts[0],\n                    'name': parts[2],\n                    'quantity': int(parts[3]),\n                    'cost': float(parts[4]),\n                    'last_price': float(parts[5]),\n                    'peak_pnl_pct': float(parts[7])\n                })\n    \n    sell_signals = []\n    \n    for pos in positions:\n        symbol = pos['symbol']\n        name = pos['name']\n        cost = pos['cost']\n        peak_pnl = pos['peak_pnl_pct']\n        quantity = pos['quantity']\n        \n        price, change_pct = get_realtime_price(symbol)\n        if price is None:\n            price = pos['last_price']\n            change_pct = 0\n        \n        current_pnl = (price - cost) / cost * 100\n        \n        # 检查止损\n        if current_pnl <= STOP_LOSS_PCT:\n            sell_signals.append({\n                'symbol': symbol,\n                'name': name,\n                'price': price,\n                'quantity': quantity,\n                'pnl': current_pnl,\n                'reason': f'止损: {current_pnl:.2f}% <= {STOP_LOSS_PCT}%'\n            })\n        \n        # 检查移动止盈\n        elif peak_pnl > 5 and current_pnl < peak_pnl - abs(TRAILING_TAKE_PROFIT_PCT):\n            sell_signals.append({\n                'symbol': symbol,\n                'name': name,\n                'price': price,\n                'quantity': quantity,\n                'pnl': current_pnl,\n                'reason': f'移动止盈: 峰值{peak_pnl:.2f}% → 当前{current_pnl:.2f}%'\n\n[39 more lines in file. Use offset=151 to continue.]"}],"isError":false,"timestamp":1776735425774}}
