{"type":"message","id":"60990c86","parentId":"ca8a6a14","timestamp":"2026-04-21T01:36:38.981Z","message":{"role":"toolResult","toolCallId":"call_00_PeqSLanInCM1AqerbQjpmrDx","toolName":"read","content":[{"type":"text","text":"            print(f\"1. 同花顺网页账本: ❌ 文件不存在\")\n        \n        # 2. 检查模拟盘数据\n        print(f\"\\n2. 模拟盘持仓数据:\")\n        paper_files = list(REPORTS_DIR.glob(\"paper_*positions*.csv\"))\n        paper_files.sort(key=lambda x: x.stat().st_mtime, reverse=True)\n        \n        if paper_files:\n            latest_file = paper_files[0]\n            mtime = datetime.fromtimestamp(latest_file.stat().st_mtime)\n            hours_diff = (datetime.now() - mtime).total_seconds() / 3600\n            \n            print(f\"   最新文件: {latest_file.name}\")\n            print(f\"   修改时间: {mtime.strftime('%Y-%m-%d %H:%M:%S')}\")\n            print(f\"   新鲜度: {hours_diff:.1f} 小时\")\n            print(f\"   状态: {'✅ 新鲜' if hours_diff < 24 else '⚠️ 陈旧'}\")\n            \n            # 显示文件内容\n            try:\n                df = pd.read_csv(latest_file)\n                print(f\"   持仓数量: {len(df)}\")\n                print(f\"   样本: {df['symbol'].head(5).tolist()}\")\n            except Exception as e:\n                print(f\"   读取失败: {e}\")\n        else:\n            print(f\"   状态: ❌ 无模拟盘数据\")\n        \n        # 3. 检查融合数据状态\n        fusion_file = REPORTS_DIR / \"web_source_fusion_daily_latest.json\"\n        if fusion_file.exists():\n            with open(fusion_file, 'r', encoding='utf-8') as f:\n                fusion_data = json.load(f)\n            \n            print(f\"\\n3. 数据融合状态:\")\n            print(f\"   状态: {fusion_data.get('status', '未知')}\")\n            if fusion_data.get('status') == 'FAILED_CLOSED':\n                print(f\"   失败原因: {fusion_data.get('reason', '未知')}\")\n                print(f\"   检查时间: {fusion_data.get('checked_at', '未知')}\")\n        else:\n            print(f\"\\n3. 数据融合状态: ❌ 文件不存在\")\n    \n    def find_reliable_sources(self) -> List[Path]:\n        \"\"\"查找可靠的持仓数据源\"\"\"\n        reliable_sources = []\n        \n        # 1. 模拟盘持仓 (最可靠)\n        paper_patterns = [\n            \"paper_portfolio_positions_*.csv\",\n            \"paper_*_portfolio_positions_*.csv\",\n            \"paper_*_holdings_*.csv\"\n        ]\n        \n        for pattern in paper_patterns:\n            for file in REPORTS_DIR.glob(pattern):\n                # 检查文件新鲜度\n                mtime = datetime.fromtimestamp(file.stat().st_mtime)\n                if (datetime.now() - mtime).total_seconds() < 48 * 3600:  # 48小时内\n                    reliable_sources.append(file)\n        \n        # 去重并排序（最新的优先）\n        reliable_sources = list(set(reliable_sources))\n        reliable_sources.sort(key=lambda x: x.stat().st_mtime, reverse=True)\n        \n        return reliable_sources\n    \n    def create_alternative_pipeline(self):\n        \"\"\"创建替代数据管道\"\"\"\n        print(\"\\n\" + \"=\" * 60)\n        print(\"创建替代持仓数据管道\")\n        print(\"=\" * 60)\n        \n        # 1. 查找可靠数据源\n        sources = self.find_reliable_sources()\n        \n        if not sources:\n            print(\"❌ 未找到可靠的持仓数据源\")\n            return False\n        \n        print(f\"找到 {len(sources)} 个可靠数据源:\")\n        for i, source in enumerate(sources, 1):\n            mtime = datetime.fromtimestamp(source.stat().st_mtime)\n            age_hours = (datetime.now() - mtime).total_seconds() / 3600\n            print(f\"{i}. {source.name} ({age_hours:.1f}小时前)\")\n        \n        # 2. 使用最新数据源创建融合数据\n        latest_source = sources[0]\n        print(f\"\\n使用最新数据源: {latest_source.name}\")\n        \n        try:\n            # 读取数据\n            if latest_source.suffix == '.csv':\n                df = pd.read_csv(latest_source)\n                holdings = {}\n                \n                for _, row in df.iterrows():\n                    symbol = str(row.get('symbol', '')).strip()\n                    if not symbol:\n                        continue\n                    \n                    holdings[symbol] = {\n\n[253 more lines in file. Use offset=151 to continue.]"}],"isError":false,"timestamp":1776735398965}}
