new_lines.append(line)\n\nif not disabled:\n    print('NO_MATCHES')\nelse:\n    p = subprocess.run(['crontab', '-'], input='\\n'.join(new_lines) + '\\n', text=True, capture_output=True)\n    if p.returncode != 0:\n        raise SystemExit(f'FAILED_TO_INSTALL_CRONTAB\\nSTDOUT:\\n{p.stdout}\\nSTDERR:\\n{p.stderr}')\n    print('DISABLED_LINES_BEGIN')\n    for item in disabled:\n        print(item)\n    print('DISABLED_LINES_END')\nPY\nprintf '\\n--- backup ---\\n%s\\n' \"$BACKUP_FILE\"\nprintf '\\n--- current crontab ---\\n'\ncrontab -l","workdir":"/Users/ling/.openclaw/workspace/coding-agent","timeout":30,"yieldMs":1000},"partialJson":"{\"command\":\"set -e\\nBACKUP_DIR=\\\"/Users/ling/.openclaw/workspace/coding-agent/backups\\\"\\nmkdir -p \\\"$BACKUP_DIR\\\"\\nBACKUP_FILE=\\\"$BACKUP_DIR/crontab_backup_before_disable_backtest_push_$(date +%Y%m%d_%H%M%S).txt\\\"\\ncrontab -l > \\\"$BACKUP_FILE\\\"\\npython3 - <<'PY'\\nimport subprocess\\nfrom pathlib import Path\\n\\nlines = subprocess.check_output(['crontab', '-l'], text=True).splitlines()\\n\\ndef should_disable(line: str) -> bool:\\n    s = line.strip()\\n    if not s or s.startswith('#'):\\n        return False\\n    targets = [\\n        'generate_today_stock_strategy_report.py',\\n        'cron_breadth_paper_trading.sh',\\n        'cron_paper_trading_profiles_v1.sh',\\n        'run_paper_trading_profiles_auto_v1.sh',\\n        'cron_run_all_panels.sh',\\n    ]\\n    return any(t in s for t in targets)\\n\\nnew_lines = []\\ndisabled = []\\nfor line in lines:\\n    if should_disable(line):\\n        disabled.append(line)\\n        new_lines.append('# DISABLED 2026-04-19 by coding-agent (backtest/paper/report push noise)')\\n        new_lines.append('# ' + line)\\n    else:\\n        new_lines.append(line)\\n\\nif not disabled:\\n    print('NO_MATCHES')\\nelse:\\n    p = subprocess.run(['crontab', '-'], input='\\\\n'.join(new_lines) + '\\\\n', text=True, capture_output=True)\\n    if p.returncode != 0:\\n        r