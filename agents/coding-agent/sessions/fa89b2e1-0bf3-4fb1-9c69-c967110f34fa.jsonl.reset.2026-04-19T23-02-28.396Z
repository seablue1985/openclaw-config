170819aa807c8311db41f4c","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/scripts/daily_market_report.py","limit":260},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/scripts/daily_market_report.py\",\"limit\":260}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":164103,"output":252,"cacheRead":0,"cacheWrite":0,"totalTokens":164355,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776562348648,"responseId":"resp_0b3ac7b405e714490169e430aee8f4819a8bcf23affb69a93f"}}
{"type":"message","id":"6975dec6","parentId":"d09e6816","timestamp":"2026-04-19T01:32:40.584Z","message":{"role":"toolResult","toolCallId":"call_OVhwltWZJznIfsK9aokL6k1s|fc_0b3ac7b405e714490169e430b82158819a816062cf3114eeb2","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n早盘准备脚本 - 每日9:00执行\n功能：更新数据、筛选股票、生成信号\n\"\"\"\n\nimport akshare as ak\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\nimport json\nimport os\n\nDATA_DIR = os.path.expanduser(\"~/qlib_data/cn_data\")\nos.makedirs(DATA_DIR, exist_ok=True)\n\nLOG_FILE = os.path.expanduser(\"~/qlib_data/morning_log.md\")\n\ndef log(msg):\n    \"\"\"记录日志\"\"\"\n    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    with open(LOG_FILE, 'a') as f:\n        f.write(f\"[{timestamp}] {msg}\\n\")\n    print(msg)\n\ndef get_realtime_data():\n    \"\"\"获取实时行情\"\"\"\n    log(\"📊 获取实时行情...\")\n    try:\n        df = ak.stock_zh_a_spot_em()\n        df.to_csv(f\"{DATA_DIR}/realtime_spot.csv\", index=False)\n        log(f\"   获取 {len(df)} 只股票实时行情\")\n        return df\n    except Exception as e:\n        log(f\"   获取失败: {e}\")\n        return None\n\ndef get_market_index():\n    \"\"\"获取指数行情\"\"\"\n    log(\"📈 获取指数行情...\")\n    indices = {\n        \"上证指数\": \"000001\",\n        \"深证成指\": \"399001\",\n        \"创业板指\": \"399006\",\n        \"中证2000\": \"000010\",\n        \"沪深300\": \"000300\"\n    }\n    \n    index_data = {}\n    for name, code in indices.items():\n        try:\n            df = ak.stock_zh_index_daily(symbol=f\"sh{code}\")\n            if len(df) > 0:\n                latest = df.iloc[-1]\n                index_data[name] = {\n                    \"close\": latest['close'],\n                    \"change\": latest['close'] / latest['open'] - 1\n                }\n                log(f\"   {name}: {latest['close']:.2f} ({latest['close']/latest['open']-1:.2%})\")\n        except Exception as e:\n            log(f\"   {name} 获取失败: {e}\")\n    \n    return index_data\n\ndef get_fund_flow():\n    \"\"\"获取资金流向\"\"\"\n    log(\"💰 获取资金流向...\")\n    try:\n        # 使用正确的API\n        df = ak.stock_individual_fund_flow_rank(indicator=\"今日\", n=\"10\")\n        if df is not None:\n            log(f\"   主力净流入前10\")\n            for _, row in df.head(5).iterrows():\n                if '名称' in row and '主力净流入-净额' in row:\n                    log(f\"   {row['名称']}: {row['主力净流入-净额']}\")\n        return df\n    except Exception as e:\n        log(f\"   获取失败: {e}\")\n        return None\n\ndef get_hot_stocks():\n    \"\"\"获取热门股票\"\"\"\n    log(\"🔥 获取热门股票...\")\n    try:\n        df = ak.stock_hot_rank_em()\n        if df is not None:\n            log(f\"   热门股票前5:\")\n            for _, row in df.head(5).iterrows():\n                if '名称' in row:\n                    log(f\"   {row['名称']}\")\n        return df\n    except Exception as e:\n        log(f\"   获取失败: {e}\")\n        return None\n\ndef analyze_stocks(df):\n    \"\"\"分析股票池\"\"\"\n    log(\"📋 分析股票池...\")\n    \n    if df is None or len(df) == 0:\n        return pd.DataFrame()\n    \n    # 尝试获取量比和换手率字段\n    available_cols = df.columns.tolist()\n    \n    # 筛选条件\n    candidates = pd.DataFrame()\n    \n    if '涨跌幅' in available_cols:\n        # 基本筛选\n        temp = df[df['涨跌幅'] > 0].copy()\n        \n        # 量比筛选\n        if '量比' in available_cols:\n            temp = temp[temp['量比'] > 1.5]\n        \n        # 换手率筛选\n        if '换手率' in available_cols:\n            temp = temp[temp['换手率'] > 3]\n        \n        candidates = temp.sort_values('涨跌幅', ascending=False)\n    \n    log(f\"   符合条件: {len(candidates)} 只\")\n    \n    if len(candidates) > 0:\n        log(\"   Top 5:\")\n        for _, row in candidates.head(5).iterrows():\n            name = row.get('名称', row.get('代码', 'N/A'))\n            change = row.get('涨跌幅', 0)\n            log(f\"   {name} {change:.2f}%\")\n    \n    return candidates\n\ndef generate_signal(index_data, candidates):\n    \"\"\"生成交易信号\"\"\"\n    log(\"🎯 生成交易信号...\")\n    \n    signal = {\n        \"大盘强度\": \"neutral\",\n        \"小盘强度\": \"neutral\",\n        \"建议\": \"观望\"\n    }\n    \n    # 沪深300判断\n    csi300 = index_data.get(\"沪深300\", {})\n    csi2000 = index_data.get(\"中证2000\", {})\n    \n    if csi300.get(\"change\", 0) > 0.5:\n        signal[\"大盘强度\"] = \"强势\"\n        signal[\"建议\"] = \"可以做多\"\n    elif csi300.get(\"change\", 0) < -0.5:\n        signal[\"大盘强度\"] = \"弱势\"\n        signal[\"建议\"] = \"谨慎观望\"\n    \n    # 小盘股判断\n    if csi2000.get(\"change\", 0) > csi300.get(\"change\", 0):\n        signal[\"小盘强度\"] = \"相对强势\"\n    \n    log(f\"   大盘: {signal['大盘强度']}, 小盘: {signal['小盘强度']}\")\n    log(f\"   建议: {signal['建议']}\")\n    \n    return signal\n\ndef save_report(index_data, candidates, signal):\n    \"\"\"保存日报\"\"\"\n    report = f\"\"\"# 量化交易日报\n生成时间: {datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")}\n\n## 大盘行情\n| 指数 | 收盘价 | 涨跌幅 |\n|------|--------|--------|\n\"\"\"\n    for name, data in index_data.items():\n        report += f\"| {name} | {data['close']:.2f} | {data['change']:.2%} |\\n\"\n    \n    report += f\"\"\"\n## 交易信号\n- 大盘强度: {signal['大盘强度']}\n- 小盘强度: {signal['小盘强度']}\n- 建议: {signal['建议']}\n\n## 候选股票\n| 股票 | 涨跌幅 |\n|------|--------|\n\"\"\"\n    \n    for _, row in candidates.head(10).iterrows():\n        name = row.get('名称', row.get('代码', 'N/A'))\n        change = row.get('涨跌幅', 0)\n        report += f\"| {name} | {change:.2f}% |\\n\"\n    \n    with open(os.path.expanduser(\"~/qlib_data/daily_report.md\"), 'w') as f:\n        f.write(report)\n    \n    log(\"📄 日报已保存\")\n\n\ndef update_realtime_index_returns():\n    \"\"\"获取今日实时指数涨跌，写入 JSON 供盘前门控使用。\n\n    使用 akshare stock_zh_index_spot_em（实时快照）获取当前指数价格，\n    与昨日收盘价对比计算今日收益率。\n    结果写入 ~/.qlib_data/cn_data/realtime_index_returns.json，\n    由 runtime_date_utils.load_index_return_pct_for_date 的盘中 fallback 读取。\n    \"\"\"\n    log(\"📊 更新实时指数收益率...\")\n\n    # 指数代码映射（通达信格式: sh000852）\n    REALTIME_INDEX_MAP = {\n        \"ZZ2000\": \"sh000852\",   # 中证2000\n        \"HS300\":  \"sh000300\",   # 沪深300\n        \"ZZ500\":  \"sh000905\",   # 中证500\n        \"SH0001\": \"sh000001\",   # 上证指数\n        \"SZ3991\": \"sz399001\",   # 深证成指\n        \"CYBZ\":   \"sz399006\",   # 创业板指\n    }\n\n    import json\n    from datetime import date\n\n    output_path = os.path.join(DATA_DIR, \"realtime_index_returns.json\")\n    today_str = date.today().strftime(\"%Y%m%d\")\n\n    # 读取昨日收盘价（从已有 CSV）\n    import pandas as pd\n    prev_closes = {}\n    for code_key, ts_code in REALTIME_INDEX_MAP.items():\n        csv_path = os.path.join(DATA_DIR, f\"index_{ts_code.replace('sh','000').replace('sz','399')}_SH.csv\")\n        # 尝试找到对应的 CSV\n        csv_pattern = ts_code.replace(\"sh\", \"000\").replace(\"sz\", \"399\") + \"_SH.csv\"\n        csv_path2 = os.path.join(DATA_DIR, csv_pattern)\n        for p in [csv_path, csv_path2]:\n            if os.path.exists(p):\n                try:\n                    df_idx = pd.read_csv(p)\n                    if not df_idx.empty and \"close\" in df_idx.columns:\n                        prev_closes[code_key] = float(df_idx.iloc[-1][\"close\"])\n                        break\n                except Exception:\n                    pass\n\n    result = {\n        \"date\": today_str,\n        \"updated_at\": datetime.now().isoformat(),\n        \"returns\": {},\n        \"note\": \"实时涨跌（当前价 vs 昨日收盘），盘中有效；盘前（09:25 前）全为 None\",\n    }\n\n    # 尝试获取实时价格\n    try:\n        spot_df = ak.stock_zh_index_spot_em()\n        for code_key, name in [\n            (\"ZZ2000\", \"中证2000\"),\n            (\"HS300\",  \"沪深300\"),\n            (\"ZZ500\",  \"中证500\"),\n        ]:\n            row = spot_df[spot_df[\"代码\"] == REALTIME_INDEX_MAP[code_key].replace(\"sh\", \"\").replace(\"sz\", \"\")]\n            if not row.empty:\n                current = float(row.iloc[0][\"最新价\"])\n                prev = prev_closes.get(code_key)\n\n[54 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776562360581}}
{"type":"message","id":"2bcb4b9c","parentId":"6975dec6","timestamp":"2026-04-19T01:32:40.588Z","message":{"role":"toolResult","toolCallId":"call_wMbDA8ao79pO7hf8q2NMfV2d|fc_0b3ac7b405e714490169e430b82168819ab256c96b3aff2cc8","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n午后处理脚本 - 每日14:30执行\n功能：信号确认、调仓准备、风险检查\n\"\"\"\n\nimport akshare as ak\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\nimport json\nimport os\n\nDATA_DIR = os.path.expanduser(\"~/qlib_data/cn_data\")\nSIGNAL_FILE = os.path.expanduser(\"~/qlib_data/trading_signal.json\")\n\ndef log(msg):\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] {msg}\")\n\ndef get_afternoon_data():\n    \"\"\"获取午后数据\"\"\"\n    log(\"📊 获取午后数据...\")\n    \n    try:\n        # 实时涨跌幅\n        df = ak.stock_zh_a_spot_em()\n        \n        # 计算涨跌幅\n        df['当前涨跌幅'] = (df['现价'] - df['昨收']) / df['昨收'] * 100\n        \n        # 筛选强势股\n        strong = df[df['当前涨跌幅'] > 3].sort_values('当前涨跌幅', ascending=False)\n        \n        log(f\"   涨幅>3%: {len(strong)} 只\")\n        \n        return df, strong\n    except Exception as e:\n        log(f\"获取失败: {e}\")\n        return None, None\n\ndef check_positions(strong_df):\n    \"\"\"检查持仓\"\"\"\n    log(\"📋 检查持仓...\")\n    \n    # 读取候选股票\n    candidates_file = f\"{DATA_DIR}/realtime_spot.csv\"\n    \n    if not os.path.exists(candidates_file):\n        log(\"   无候选股票数据\")\n        return []\n    \n    candidates = pd.read_csv(candidates_file)\n    \n    # 检查持仓股票是否在强势列表中\n    if strong_df is not None and len(strong_df) > 0:\n        # 简化处理，返回强势股\n        top_strong = strong_df.head(5)['代码'].tolist()\n        return top_strong\n    \n    return []\n\ndef generate_trading_signal(strong_codes):\n    \"\"\"生成交易信号\"\"\"\n    log(\"🎯 生成交易信号...\")\n    \n    signal = {\n        \"timestamp\": datetime.now().isoformat(),\n        \"action\": \"hold\",  # buy, sell, hold\n        \"targets\": [],\n        \"reason\": \"\"\n    }\n    \n    if len(strong_codes) >= 3:\n        # 多个强势股，建议买入\n        signal[\"action\"] = \"buy\"\n        signal[\"targets\"] = strong_codes[:3]\n        signal[\"reason\"] = f\"发现{len(strong_codes)}只强势股\"\n    elif len(strong_codes) > 0:\n        signal[\"action\"] = \"hold\"\n        signal[\"targets\"] = strong_codes[:2]\n        signal[\"reason\"] = f\"仅有{len(strong_codes)}只强势股，观望\"\n    else:\n        signal[\"action\"] = \"hold\"\n        signal[\"reason\"] = \"无强势股，观望\"\n    \n    # 保存信号\n    with open(SIGNAL_FILE, 'w') as f:\n        json.dump(signal, f, indent=2)\n    \n    log(f\"   操作: {signal['action']}\")\n    log(f\"   目标: {signal['targets']}\")\n    log(f\"   原因: {signal['reason']}\")\n    \n    return signal\n\ndef risk_check():\n    \"\"\"风险检查\"\"\"\n    log(\"🛡️ 风险检查...\")\n    \n    checks = []\n    \n    try:\n        # 大盘风险\n        df = ak.stock_zh_index_daily(symbol=\"sh000300\")\n        if len(df) > 0:\n            latest = df.iloc[-1]\n            change = (latest['close'] - latest['open']) / latest['open'] * 100\n            \n            if change < -2:\n                checks.append(f\"⚠️ 大盘跌幅较大: {change:.2f}%\")\n            else:\n                checks.append(f\"✅ 大盘正常: {change:.2f}%\")\n    except:\n        pass\n    \n    # 检查是否有止损信号\n    if os.path.exists(SIGNAL_FILE):\n        with open(SIGNAL_FILE, 'r') as f:\n            signal = json.load(f)\n        \n        if signal.get(\"stop_loss\"):\n            checks.append(\"⚠️ 触发止损\")\n    \n    for check in checks:\n        log(f\"   {check}\")\n    \n    return checks\n\ndef main():\n    print(\"=\"*50)\n    print(\"🚀 午后处理脚本启动\")\n    print(\"=\"*50)\n    \n    # 1. 获取数据\n    df, strong = get_afternoon_data()\n    \n    # 2. 风险检查\n    risk_check()\n    \n    # 3. 检查持仓\n    strong_codes = check_positions(strong)\n    \n    # 4. 生成信号\n    signal = generate_trading_signal(strong_codes)\n    \n    log(\"✅ 午后处理完成\")\n    print(\"=\"*50)\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1776562360584}}
{"type":"message","id":"cec31209","parentId":"2bcb4b9c","timestamp":"2026-04-19T01:32:40.593Z","message":{"role":"toolResult","toolCallId":"call_SRaVR5jGkaPJiuw4ZNGdV4c3|fc_0b3ac7b405e714490169e430b82170819aa807c8311db41f4c","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n每日全球股市新闻汇总与深度分析脚本\n1. 调用 downloader (MiniMax) 搜集新闻\n2. 调用 main (GPT-5.4) 进行深度分析并推送到飞书\n\"\"\"\n\nimport subprocess\nimport time\nimport sys\nimport shutil\nfrom pathlib import Path\n\n# 配置路径\nOPENCLAW_BIN_CANDIDATES = [\n    str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"aliases\" / \"default\" / \"bin\" / \"openclaw\"),\n    shutil.which(\"openclaw\") or \"\",\n    \"openclaw\",\n]\nNEWS_FILE = \"/Users/ling/.openclaw/workspace/research/news_daily.md\"\n\n\ndef resolve_openclaw_bin():\n    for candidate in OPENCLAW_BIN_CANDIDATES:\n        if candidate and Path(candidate).exists():\n            return candidate\n    for candidate in OPENCLAW_BIN_CANDIDATES:\n        if candidate:\n            return candidate\n    return \"openclaw\"\n\ndef run_agent(agent_id, message, deliver=False):\n    \"\"\"调用 OpenClaw Agent 执行任务\"\"\"\n    cmd = [resolve_openclaw_bin(), \"agent\", \"--agent\", agent_id, \"--message\", message]\n    if deliver:\n        cmd.append(\"--deliver\")\n    \n    print(f\"[*] Calling agent '{agent_id}'...\")\n    try:\n        # 使用 check=True 确保命令执行成功\n        result = subprocess.run(cmd, capture_output=True, text=True, check=True)\n        print(f\"[+] Agent '{agent_id}' completed successfully.\")\n        return result.stdout\n    except FileNotFoundError as e:\n        print(f\"[!] Error calling agent '{agent_id}': {e}\")\n        sys.exit(1)\n    except subprocess.CalledProcessError as e:\n        print(f\"[!] Error calling agent '{agent_id}': {e.stderr}\")\n        sys.exit(1)\n\ndef main():\n    print(f\"=== Daily Market Report Task Started at {time.ctime()} ===\")\n    \n    # 第一步：由 downloader 搜集新闻\n    collect_msg = (\n        \"请搜集过去 24 小时内关于全球股市（重点关注美股 AI 板块和 A 股算力板块）的核心新闻，\"\n        f\"并汇总成一份详细的 Markdown 文档，直接覆盖保存到路径: {NEWS_FILE}。\"\n    )\n    run_agent(\"downloader\", collect_msg)\n    \n    # 等待文件写入完成（以防万一）\n    time.sleep(5)\n    \n    # 第二步：由 main 进行深度分析并推送\n    analyze_msg = (\n        f\"请阅读本地文件 {NEWS_FILE}，分析这些新闻对今天 A 股开盘可能产生的具体影响，\"\n        \"并生成一份 500 字左右的深度策略日报。请直接将最终报告通过飞书发送给我。\"\n    )\n    # 使用 --deliver 确保回复推送到飞书\n    run_agent(\"main\", analyze_msg, deliver=True)\n    \n    print(f\"=== Daily Market Report Task Completed at {time.ctime()} ===\")\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1776562360588}}
