hOnapjNzaT96Xx8E6jZTDHe_dlGJuRbFO5AjvrXtNJInvQztq1g==\",\"summary\":[{\"type\":\"summary_text\",\"text\":\"**Investigating cron tasks**\\n\\nI think I need to dig deeper into why the rg output is truncated. It might be due to a command issue or something about the binary. I'm wondering if the lack of output is related to permissions or if I need to inspect the setup for cron tasks, like crontab or scheduled system tasks. I’ll check the run_aggressive_cron.sh script and the setup_cron_tasks to get a clearer picture. Let's figure this out!\"}]}"},{"type":"toolCall","id":"call_0dc5bljJ9hwOVT8lhyU3bXZU|fc_0b3ac7b405e714490169e42eb0ba88819aaac0e27bf082c3de","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/coding-agent/run_aggressive_cron.sh"},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/coding-agent/run_aggressive_cron.sh\"}"},{"type":"toolCall","id":"call_8YUNTFaN0T8fBD715Q14GA6t|fc_0b3ac7b405e714490169e42eb0ba98819a9e1cd7301112a2ca","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/coding-agent/setup_cron_tasks.py"},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/coding-agent/setup_cron_tasks.py\"}"},{"type":"toolCall","id":"call_C4g7Qa9shhC9SpQbkipIdTgJ|fc_0b3ac7b405e714490169e42eb0baa0819aaf51a5598c6d3309","name":"read","arguments":{"path":"/Users/ling/.openclaw/workspace/coding-agent/setup_cron_tasks_fixed.py"},"partialJson":"{\"path\":\"/Users/ling/.openclaw/workspace/coding-agent/setup_cron_tasks_fixed.py\"}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":35046,"output":176,"cacheRead":0,"cacheWrite":0,"totalTokens":35222,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776561833152,"responseId":"resp_0b3ac7b405e714490169e42eaad9f4819a94638d30d2c9b4cc"}}
{"type":"message","id":"fed8cc40","parentId":"e2b98b7b","timestamp":"2026-04-19T01:24:01.528Z","message":{"role":"toolResult","toolCallId":"call_0dc5bljJ9hwOVT8lhyU3bXZU|fc_0b3ac7b405e714490169e42eb0ba88819aaac0e27bf082c3de","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n# Aggressive 18% 策略实时监控定时任务\n# 交易时段每30分钟自动检测并推送信号\n\nPYTHON_SCRIPT=\"/Users/ling/.openclaw/workspace/coding-agent/run_aggressive_realtime_signal.py\"\nLOG_FILE=\"/Users/ling/.openclaw/workspace/coding-agent/logs/aggressive_signal.log\"\n\n# 确保日志目录存在\nmkdir -p \"$(dirname \"$LOG_FILE\")\"\n\n# 检查是否在交易时段 (工作日 9:25-15:05)\nis_trading_hours() {\n    now=$(date +%H%M)\n    weekday=$(date +%u)\n    \n    # 周一到周五，且在9:25-15:05之间\n    if [ $weekday -le 5 ] && [ $now -ge 0925 ] && [ $now -le 1505 ]; then\n        return 0\n    else\n        return 1\n    fi\n}\n\n# 如果在交易时段，运行检测\nif is_trading_hours; then\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] 运行Aggressive信号检测...\" >> \"$LOG_FILE\"\n    python3 \"$PYTHON_SCRIPT\" >> \"$LOG_FILE\" 2>&1\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] 检测完成\" >> \"$LOG_FILE\"\nelse\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] 非交易时段，跳过检测\" >> \"$LOG_FILE\"\nfi"}],"isError":false,"timestamp":1776561841520}}
{"type":"message","id":"80f2f1d3","parentId":"fed8cc40","timestamp":"2026-04-19T01:24:01.537Z","message":{"role":"toolResult","toolCallId":"call_8YUNTFaN0T8fBD715Q14GA6t|fc_0b3ac7b405e714490169e42eb0ba98819a9e1cd7301112a2ca","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n定时任务设置脚本\n为量化系统设置自动化的定时任务\n\"\"\"\nimport os\nimport sys\nimport json\nfrom pathlib import Path\nfrom datetime import datetime\nimport subprocess\n\n# 项目根目录\nPROJECT_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system\")\nSCRIPTS_DIR = PROJECT_ROOT / \"scripts\"\nCRON_DIR = PROJECT_ROOT / \"cron\"\nCRON_DIR.mkdir(exist_ok=True)\n\ndef create_cron_scripts():\n    \"\"\"创建定时任务脚本\"\"\"\n    print(\"创建定时任务脚本...\")\n    print(\"=\" * 50)\n    \n    scripts = [\n        {\n            \"name\": \"update_reliable_holdings.sh\",\n            \"content\": \"\"\"#!/bin/bash\n# 更新可靠持仓数据\n# 运行时间: 每天 09:30 和 14:30\n\ncd \"$(dirname \"$0\")/..\"\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 开始更新持仓数据...\"\n\n# 运行持仓数据更新脚本\npython3 scripts/create_reliable_holdings.py\n\n# 检查结果\nif [ $? -eq 0 ]; then\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ✅ 持仓数据更新成功\"\nelse\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ❌ 持仓数据更新失败\"\n    exit 1\nfi\n\n# 验证数据\nif [ -f \"research/reports/reliable_holdings_latest.json\" ]; then\n    holdings_count=$(python3 -c \"\nimport json\ntry:\n    with open('research/reports/reliable_holdings_latest.json', 'r') as f:\n        data = json.load(f)\n    print(data.get('holdings_count', 0))\nexcept:\n    print(0)\n\")\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] 📊 持仓数量: $holdings_count\"\nfi\n\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 任务完成\"\n\"\"\",\n            \"description\": \"更新可靠持仓数据 (每天09:30和14:30)\"\n        },\n        {\n            \"name\": \"check_data_freshness.sh\",\n            \"content\": \"\"\"#!/bin/bash\n# 检查数据新鲜度\n# 运行时间: 每天 10:00, 13:00, 16:00\n\ncd \"$(dirname \"$0\")/..\"\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 开始检查数据新鲜度...\"\n\n# 检查可靠持仓数据\nif [ -f \"research/reports/reliable_holdings_latest.json\" ]; then\n    python3 -c \"\nimport json\nfrom datetime import datetime, timedelta\n\ntry:\n    with open('research/reports/reliable_holdings_latest.json', 'r') as f:\n        data = json.load(f)\n    \n    generated_at = data.get('generated_at', '')\n    status = data.get('status', 'UNKNOWN')\n    holdings_count = data.get('holdings_count', 0)\n    \n    if generated_at:\n        # 解析时间\n        gen_time = datetime.strptime(generated_at, '%Y-%m-%d %H:%M:%S')\n        now = datetime.now()\n        age_hours = (now - gen_time).total_seconds() / 3600\n        \n        print(f'数据状态: {status}')\n        print(f'持仓数量: {holdings_count}')\n        print(f'生成时间: {generated_at}')\n        print(f'数据年龄: {age_hours:.1f} 小时')\n        \n        if age_hours > 48:\n            print('⚠️  警告: 数据超过48小时未更新')\n            exit(1)\n        else:\n            print('✅ 数据新鲜度正常')\n            exit(0)\n    else:\n        print('❌ 无法获取生成时间')\n        exit(1)\n        \nexcept Exception as e:\n    print(f'❌ 检查失败: {e}')\n    exit(1)\n\"\n    \n    if [ $? -eq 0 ]; then\n        echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ✅ 数据新鲜度检查通过\"\n    else\n        echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ❌ 数据新鲜度检查失败\"\n        # 可以在这里添加告警逻辑\n    fi\nelse\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ❌ 可靠持仓数据文件不存在\"\n    exit 1\nfi\n\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 检查完成\"\n\"\"\",\n            \"description\": \"检查数据新鲜度 (每天10:00, 13:00, 16:00)\"\n        },\n        {\n            \"name\": \"run_daily_analysis.sh\",\n            \"content\": \"\"\"#!/bin/bash\n# 运行每日分析\n# 运行时间: 每天 15:30 (收盘后)\n\ncd \"$(dirname \"$0\")/..\"\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 开始运行每日分析...\"\n\n# 检查数据是否就绪\nif [ ! -f \"research/reports/reliable_holdings_latest.json\" ]; then\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ❌ 持仓数据不存在，先更新数据\"\n    python3 scripts/create_reliable_holdings.py\nfi\n\n# 运行价格获取脚本（测试SSL修复）\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 测试价格获取...\"\npython3 scripts/enrich_holdings_with_prices.py \\\\\n  --input research/reports/selected_real_positions_20260414.csv \\\\\n  --output research/reports/selected_real_positions_20260414_enriched_daily.csv\n\nif [ $? -eq 0 ]; then\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ✅ 价格获取测试成功\"\nelse\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ❌ 价格获取测试失败\"\nfi\n\n# 运行其他分析任务\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 运行其他分析任务...\"\n\n# 这里可以添加其他分析任务\n# python3 scripts/other_analysis.py\n\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 每日分析完成\"\n\"\"\",\n            \"description\": \"运行每日分析 (每天15:30收盘后)\"\n        },\n        {\n            \"name\": \"backup_data_sources.sh\",\n            \"content\": \"\"\"#!/bin/bash\n# 备份数据源\n# 运行时间: 每天 17:00\n\ncd \"$(dirname \"$0\")/..\"\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 开始备份数据源...\"\n\n# 创建备份目录\nBACKUP_DIR=\"research/backups/$(date +%Y%m%d)\"\nmkdir -p \"$BACKUP_DIR\"\n\n# 备份关键文件\nfiles_to_backup=(\n    \"research/reports/reliable_holdings_latest.json\"\n    \"research/reports/paper_portfolio_fusion_latest.json\"\n    \"research/reports/web_source_fusion_daily_latest.json\"\n    \"config/thsdata_credentials.json\"\n)\n\nbackup_count=0\nfor file in \"${files_to_backup[@]}\"; do\n    if [ -f \"$file\" ]; then\n        cp \"$file\" \"$BACKUP_DIR/\"\n        echo \"  ✅ 备份: $file\"\n        backup_count=$((backup_count + 1))\n    else\n        echo \"  ⚠️  跳过: $file (不存在)\"\n    fi\ndone\n\n# 创建备份清单\necho \"备份时间: $(date '+%Y-%m-%d %H:%M:%S')\" > \"$BACKUP_DIR/backup_info.txt\"\necho \"备份文件数: $backup_count\" >> \"$BACKUP_DIR/backup_info.txt\"\necho \"备份目录: $BACKUP_DIR\" >> \"$BACKUP_DIR/backup_info.txt\"\n\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] ✅ 备份完成: $backup_count 个文件\"\n\"\"\",\n            \"description\": \"备份数据源 (每天17:00)\"\n        }\n    ]\n    \n    created_scripts = []\n    for script_info in scripts:\n        script_path = CRON_DIR / script_info[\"name\"]\n        \n        with open(script_path, 'w', encoding='utf-8') as f:\n            f.write(script_info[\"content\"])\n        \n        # 设置执行权限\n        os.chmod(script_path, 0o755)\n        \n        created_scripts.append((script_path, script_info[\"description\"]))\n        print(f\"✅ 创建脚本: {script_path.name}\")\n        print(f\"   描述: {script_info['description']}\")\n    \n    return created_scripts\n\ndef generate_crontab_config():\n    \"\"\"生成crontab配置\"\"\"\n    print(\"\\n生成crontab配置...\")\n    print(\"=\" * 50)\n    \n    crontab_content = \"\"\"# ============================================\n# 量化系统定时任务配置\n# 生成时间: {generated_time}\n# 项目: {project_root}\n# ============================================\n\n# 更新可靠持仓数据 (交易日开盘后和盘中)\n30 9 * * * cd {project_root} && ./cron/update_reliable_holdings.sh >> ./logs/cron_update_holdings.log 2>&1\n30 14 * * * cd {project_root} && ./cron/update_reliable_holdings.sh >> ./logs/cron_update_holdings.log 2>&1\n\n# 检查数据新鲜度 (交易日三个时间点)\n0 10 * * * cd {project_root} && ./cron/check_data_freshness.sh >> ./logs/cron_check_freshness.log 2>&1\n0 13 * * * cd {project_root} && ./cron/check_data_freshness.sh >> ./logs/cron_check_freshness.log 2>&1\n0 16 * * * cd {project_root} && ./cron/check_data_freshness.sh >> ./logs/cron_check_freshness.log 2>&1\n\n# 运行每日分析 (收盘后)\n30 15 * * * cd {project_root} && ./cron/run_daily_analysis.sh >> ./logs/cron_daily_analysis.log 2>&1\n\n# 备份数据源 (每天收盘后)\n0 17 * * * cd {project_root} && ./cron/backup_data_sources.sh >> ./logs/cron_backup.log 2>&1\n\n# 周末清理日志 (每周日凌晨)\n0 2 * * 0 find {project_root}/logs -name \"cron_*.log\" -mtime +7 -delete\n0 2 * * 0 find {project_root}/research/backups -type d -mtime +30 -exec rm -rf {{}} \\\\;\n\n# ============================================\n# 说明:\n# 1. 所有任务都在项目目录下运行\n# 2. 日志输出到 logs/ 目录\n# 3. 备份保存在 research/backups/ 目录\n# 4. 自动清理7天前的日志和30天前的备份\n# ============================================\n\"\"\".format(\n        generated_time=datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n        project_root=PROJECT_ROOT\n    )\n    \n    crontab_path = CRON_DIR / \"crontab_config.txt\"\n    with open(crontab_path, 'w', encoding='utf-8') as f:\n        f.write(crontab_content)\n    \n    print(f\"✅ 生成crontab配置: {crontab_path}\")\n    \n    # 显示配置内容\n    print(\"\\n📋 crontab配置内容:\")\n    print(\"-\" * 40)\n    print(crontab_content)\n    \n    return crontab_path\n\ndef create_install_script():\n    \"\"\"创建安装脚本\"\"\"\n    print(\"\\n创建安装脚本...\")\n    print(\"=\" * 50)\n    \n    install_script = \"\"\"#!/bin/bash\n# 定时任务安装脚本\n# 运行此脚本将定时任务添加到crontab\n\nset -e\n\necho \"安装量化系统定时任务...\"\necho \"=\" * 50\n\n# 检查项目目录\nPROJECT_ROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\necho \"项目目录: $PROJECT_ROOT\"\n\nif [ ! -d \"$PROJECT_ROOT/cron\" ]; then\n    echo \"❌ cron目录不存在\"\n    exit 1\nfi\n\n# 备份当前crontab\nBACKUP_FILE=\"$HOME/crontab_backup_$(date +%Y%m%d_%H%M%S).bak\"\necho \"备份当前crontab到: $BACKUP_FILE\"\ncrontab -l > \"$BACKUP_FILE\" 2>/dev/null || true\n\n# 添加新配置\necho \"添加定时任务配置...\"\nCRON_CONFIG=\"$PROJECT_ROOT/cron/crontab_config.txt\"\n\nif [ ! -f \"$CRON_CONFIG\" ]; then\n    echo \"❌ crontab配置文件不存在: $CRON_CONFIG\"\n    exit 1\nfi\n\n# 合并配置\nTEMP_FILE=$(mktemp)\ncrontab -l 2>/dev/null > \"$TEMP_FILE\" || true\necho \"\" >> \"$TEMP_FILE\"\ncat \"$CRON_CONFIG\" >> \"$TEMP_FILE\"\n\n# 安装新配置\ncrontab \"$TEMP_FILE\"\nrm -f \"$TEMP_FILE\"\n\necho \"✅ 定时任务安装完成\"\necho \"\"\necho \"已安装的任务:\"\necho \"1. 更新持仓数据: 09:30, 14:30\"\necho \"2. 检查数据新鲜度: 10:00, 13:00, 16:00\"\necho \"3. 运行每日分析: 15:30\"\necho \"4. 备份数据源: 17:00\"\necho \"5. 周末清理: 周日02:00\"\necho \"\"\necho \"查看当前crontab: crontab -l\"\necho \"编辑crontab: crontab -e\"\necho \"删除所有任务: crontab -r\"\necho \"\"\necho \"日志目录: $PROJECT_ROOT/logs/\"\necho \"备份目录: $PROJECT_ROOT/research/backups/\"\n\"\"\"\n    \n    install_path = CRON_DIR / \"install_cron.sh\"\n    with open(install_path, 'w', encoding='utf-8') as f:\n        f.write(install_script)\n    \n    os.chmod(install_path, 0o755)\n    \n    print(f\"✅ 创建安装脚本: {install_path}\")\n    \n    return install_path\n\ndef create_test_script():\n    \"\"\"创建测试脚本\"\"\"\n    print(\"\\n创建测试脚本...\")\n    print(\"=\" * 50)\n    \n    test_script = \"\"\"#!/bin/bash\n# 定时任务测试脚本\n# 测试所有定时任务脚本\n\nset -e\n\necho \"测试定时任务脚本...\"\necho \"=\" * 50\n\nPROJECT_ROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\nCRON_DIR=\"$PROJECT_ROOT/cron\"\n\n# 测试脚本列表\nscripts=(\n    \"update_reliable_holdings.sh\"\n    \"check_data_freshness.sh\"\n    \"run_daily_analysis.sh\"\n    \"backup_data_sources.sh\"\n)\n\nall_passed=true\n\nfor script in \"${scripts[@]}\"; do\n    script_path=\"$CRON_DIR/$script\"\n    \n    if [ -f \"$script_path\" ]; then\n        echo \"测试: $script\"\n        echo \"-\" * 30\n        \n        # 检查脚本语法\n        if bash -n \"$script_path\"; then\n            echo \"✅ 语法检查通过\"\n            \n            # 试运行（不实际执行）\n            echo \"试运行输出:\"\n            bash -x \"$script_path\" --dry-run 2>&1 | head -20 || true\n            \n        else\n            echo \"❌ 语法检查失败\"\n            all_passed=false\n        fi\n        \n        echo \"\"\n    else\n        echo \"❌ 脚本不存在: $script\"\n        all_passed=false\n    fi\ndone\n\n# 测试crontab配置\necho \"测试crontab配置...\"\necho \"-\" * 30\n\nCRON_CONFIG=\"$CRON_DIR/crontab_config.txt\"\nif [ -f \"$CRON_CONFIG\" ]; then\n    # 检查配置格式\n    if grep -q \"^[0-9*]\" \"$CRON_CONFIG\"; then\n        echo \"✅ crontab配置格式正确\"\n        \n        # 统计任务数量\n        task_count=$(grep -c \"^[0-9*]\" \"$CRON_CONFIG\")\n        echo \"   任务数量: $task_count\"\n        \n        # 显示任务列表\n        echo \"   任务列表:\"\n        grep \"^[0-9*]\" \"$CRON_CONFIG\" | while read line; do\n            echo \"   - $line\"\n        done\n        \n    else\n        echo \"❌ crontab配置格式错误\"\n        all_passed=false\n    fi\nelse\n    echo \"❌ crontab配置文件不存在\"\n    all_passed=false\nfi\n\necho \"\"\necho \"=\" * 50\nif [ \"$all_passed\" = true ]; then\n    echo \"✅ 所有测试通过\"\n    echo \"\"\n    echo \"下一步:\"\n    echo \"1. 运行安装脚本: ./cron/install_cron.sh\"\n    echo \"2. 验证安装: crontab -l\"\n    echo \"3. 查看日志: tail -f logs/cron_*.log\"\nelse\n    echo \"❌ 测试失败，请检查问题\"\n    exit 1\nfi\n\"\"\"\n    \n    test_path = CRON_DIR / \"test_cron.sh\"\n    with open(test_path, 'w', encoding='utf-8') as f:\n        f.write(test_script)\n    \n    os.chmod(test_path, 0o755)\n    \n    print(f\"✅ 创建测试脚本: {"}],"isError":false,"timestamp":1776561841529}}
{"type":"message","id":"7a29fede","parentId":"80f2f1d3","timestamp":"2026-04-19T01:24:01.544Z","message":{"role":"toolResult","toolCallId":"call_C4g7Qa9shhC9SpQbkipIdTgJ|fc_0b3ac7b405e714490169e42eb0baa0819aaf51a5598c6d3309","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n定时任务设置脚本 - 修复版\n为量化系统设置自动化的定时任务\n\"\"\"\nimport os\nimport sys\nimport json\nfrom pathlib import Path\nfrom datetime import datetime\n\n# 项目根目录\nPROJECT_ROOT = Path(\"/Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system\")\nSCRIPTS_DIR = PROJECT_ROOT / \"scripts\"\nCRON_DIR = PROJECT_ROOT / \"cron\"\nCRON_DIR.mkdir(exist_ok=True)\n\ndef create_cron_scripts():\n    \"\"\"创建定时任务脚本\"\"\"\n    print(\"创建定时任务脚本...\")\n    print(\"=\" * 50)\n    \n    scripts = [\n        {\n            \"name\": \"update_reliable_holdings.sh\",\n            \"content\": \"\"\"#!/bin/bash\n# 更新可靠持仓数据\n# 运行时间: 每天 09:30 和 14:30\n\ncd \"$(dirname \"$0\")/..\"\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 开始更新持仓数据...\"\n\n# 运行持仓数据更新脚本\npython3 scripts/create_reliable_holdings.py\n\n# 检查结果\nif [ $? -eq 0 ]; then\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ✅ 持仓数据更新成功\"\nelse\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ❌ 持仓数据更新失败\"\n    exit 1\nfi\n\n# 验证数据\nif [ -f \"research/reports/reliable_holdings_latest.json\" ]; then\n    holdings_count=$(python3 -c \"\nimport json\ntry:\n    with open('research/reports/reliable_holdings_latest.json', 'r') as f:\n        data = json.load(f)\n    print(data.get('holdings_count', 0))\nexcept:\n    print(0)\n\")\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] 📊 持仓数量: $holdings_count\"\nfi\n\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 任务完成\"\n\"\"\",\n            \"description\": \"更新可靠持仓数据 (每天09:30和14:30)\"\n        },\n        {\n            \"name\": \"check_data_freshness.sh\",\n            \"content\": \"\"\"#!/bin/bash\n# 检查数据新鲜度\n# 运行时间: 每天 10:00, 13:00, 16:00\n\ncd \"$(dirname \"$0\")/..\"\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 开始检查数据新鲜度...\"\n\n# 检查可靠持仓数据\nif [ -f \"research/reports/reliable_holdings_latest.json\" ]; then\n    python3 -c \"\nimport json\nfrom datetime import datetime, timedelta\n\ntry:\n    with open('research/reports/reliable_holdings_latest.json', 'r') as f:\n        data = json.load(f)\n    \n    generated_at = data.get('generated_at', '')\n    status = data.get('status', 'UNKNOWN')\n    holdings_count = data.get('holdings_count', 0)\n    \n    if generated_at:\n        # 解析时间\n        gen_time = datetime.strptime(generated_at, '%Y-%m-%d %H:%M:%S')\n        now = datetime.now()\n        age_hours = (now - gen_time).total_seconds() / 3600\n        \n        print(f'数据状态: {status}')\n        print(f'持仓数量: {holdings_count}')\n        print(f'生成时间: {generated_at}')\n        print(f'数据年龄: {age_hours:.1f} 小时')\n        \n        if age_hours > 48:\n            print('⚠️  警告: 数据超过48小时未更新')\n            exit(1)\n        else:\n            print('✅ 数据新鲜度正常')\n            exit(0)\n    else:\n        print('❌ 无法获取生成时间')\n        exit(1)\n        \nexcept Exception as e:\n    print(f'❌ 检查失败: {e}')\n    exit(1)\n\"\n    \n    if [ $? -eq 0 ]; then\n        echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ✅ 数据新鲜度检查通过\"\n    else\n        echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ❌ 数据新鲜度检查失败\"\n    fi\nelse\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] ❌ 可靠持仓数据文件不存在\"\n    exit 1\nfi\n\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] 检查完成\"\n\"\"\",\n            \"description\": \"检查数据新鲜度 (每天10:00, 13:00, 16:00)\"\n        }\n    ]\n    \n    created_scripts = []\n    for script_info in scripts:\n        script_path = CRON_DIR / script_info[\"name\"]\n        \n        with open(script_path, 'w', encoding='utf-8') as f:\n            f.write(script_info[\"content\"])\n        \n        # 设置执行权限\n        os.chmod(script_path, 0o755)\n        \n        created_scripts.append((script_path, script_info[\"description\"]))\n        print(f\"✅ 创建脚本: {script_path.name}\")\n        print(f\"   描述: {script_info['description']}\")\n    \n    return created_scripts\n\ndef generate_crontab_config():\n    \"\"\"生成crontab配置\"\"\"\n    print(\"\\n生成crontab配置...\")\n    print(\"=\" * 50)\n    \n    crontab_content = f\"\"\"# ============================================\n# 量化系统定时任务配置\n# 生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n# 项目: {PROJECT_ROOT}\n# ============================================\n\n# 更新可靠持仓数据 (交易日开盘后和盘中)\n30 9 * * * cd {PROJECT_ROOT} && ./cron/update_reliable_holdings.sh >> ./logs/cron_update_holdings.log 2>&1\n30 14 * * * cd {PROJECT_ROOT} && ./cron/update_reliable_holdings.sh >> ./logs/cron_update_holdings.log 2>&1\n\n# 检查数据新鲜度 (交易日三个时间点)\n0 10 * * * cd {PROJECT_ROOT} && ./cron/check_data_freshness.sh >> ./logs/cron_check_freshness.log 2>&1\n0 13 * * * cd {PROJECT_ROOT} && ./cron/check_data_freshness.sh >> ./logs/cron_check_freshness.log 2>&1\n0 16 * * * cd {PROJECT_ROOT} && ./cron/check_data_freshness.sh >> ./logs/cron_check_freshness.log 2>&1\n\n# ============================================\n# 说明:\n# 1. 所有任务都在项目目录下运行\n# 2. 日志输出到 logs/ 目录\n# 3. 自动清理7天前的日志\n# ============================================\n\n# 周末清理日志 (每周日凌晨)\n0 2 * * 0 find {PROJECT_ROOT}/logs -name \"cron_*.log\" -mtime +7 -delete\n\"\"\"\n    \n    crontab_path = CRON_DIR / \"crontab_config.txt\"\n    with open(crontab_path, 'w', encoding='utf-8') as f:\n        f.write(crontab_content)\n    \n    print(f\"✅ 生成crontab配置: {crontab_path}\")\n    \n    # 显示配置内容\n    print(\"\\n📋 crontab配置内容:\")\n    print(\"-\" * 40)\n    print(crontab_content)\n    \n    return crontab_path\n\ndef create_install_guide():\n    \"\"\"创建安装指南\"\"\"\n    print(\"\\n创建安装指南...\")\n    print(\"=\" * 50)\n    \n    guide_content = f\"\"\"# 定时任务安装指南\n\n## 安装步骤\n\n### 1. 检查当前crontab\n```bash\ncrontab -l\n```\n\n### 2. 备份当前crontab\n```bash\ncrontab -l > ~/crontab_backup_$(date +%Y%m%d_%H%M%S).bak\n```\n\n### 3. 添加量化系统定时任务\n```bash\n# 方法1: 手动添加（推荐）\ncrontab -e\n\n# 在文件末尾添加以下内容:\n{generate_minimal_crontab()}\n\n# 方法2: 使用crontab命令\n(crontab -l 2>/dev/null; echo \"{generate_minimal_crontab()}\") | crontab -\n```\n\n### 4. 验证安装\n```bash\ncrontab -l | grep -A5 \"量化系统\"\n```\n\n## 定时任务说明\n\n### 任务列表\n1. **更新持仓数据** (09:30, 14:30)\n   - 更新可靠持仓数据源\n   - 确保数据新鲜度\n\n2. **检查数据新鲜度** (10:00, 13:00, 16:00)\n   - 检查数据是否超过48小时未更新\n   - 发送告警（如需）\n\n### 日志管理\n- 日志目录: `{PROJECT_ROOT}/logs/`\n- 自动清理: 每周日02:00清理7天前的日志\n\n## 测试定时任务\n\n### 1. 手动测试脚本\n```bash\ncd {PROJECT_ROOT}\n./cron/update_reliable_holdings.sh\n./cron/check_data_freshness.sh\n```\n\n### 2. 查看日志\n```bash\ntail -f logs/cron_update_holdings.log\ntail -f logs/cron_check_freshness.log\n```\n\n## 故障排除\n\n### 问题1: 脚本权限不足\n```bash\nchmod +x {PROJECT_ROOT}/cron/*.sh\n```\n\n### 问题2: Python环境问题\n```bash\n# 检查Python路径\nwhich python3\npython3 --version\n\n# 安装依赖\npip install certifi\n```\n\n### 问题3: 项目目录不存在\n```bash\n# 确认项目目录\nls -la {PROJECT_ROOT}\n```\n\n## 管理命令\n\n### 查看所有定时任务\n```bash\ncrontab -l\n```\n\n### 编辑定时任务\n```bash\ncrontab -e\n```\n\n### 删除所有定时任务\n```bash\ncrontab -r\n```\n\n### 恢复备份\n```bash\ncrontab ~/crontab_backup_*.bak\n```\n\n## 联系支持\n如有问题，请联系系统管理员。\n\n---\n**生成时间**: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n**项目目录**: {PROJECT_ROOT}\n\"\"\"\n    \n    guide_path = CRON_DIR / \"INSTALL_GUIDE.md\"\n    with open(guide_path, 'w', encoding='utf-8') as f:\n        f.write(guide_content)\n    \n    print(f\"✅ 创建安装指南: {guide_path}\")\n    \n    return guide_path\n\ndef generate_minimal_crontab():\n    \"\"\"生成最小化的crontab配置\"\"\"\n    return f\"\"\"# 量化系统定时任务\n30 9 * * * cd {PROJECT_ROOT} && ./cron/update_reliable_holdings.sh >> ./logs/cron_update_holdings.log 2>&1\n30 14 * * * cd {PROJECT_ROOT} && ./cron/update_reliable_holdings.sh >> ./logs/cron_update_holdings.log 2>&1\n0 10 * * * cd {PROJECT_ROOT} && ./cron/check_data_freshness.sh >> ./logs/cron_check_freshness.log 2>&1\n0 13 * * * cd {PROJECT_ROOT} && ./cron/check_data_freshness.sh >> ./logs/cron_check_freshness.log 2>&1\n0 16 * * * cd {PROJECT_ROOT} && ./cron/check_data_freshness.sh >> ./logs/cron_check_freshness.log 2>&1\n0 2 * * 0 find {PROJECT_ROOT}/logs -name \"cron_*.log\" -mtime +7 -delete\"\"\"\n\ndef main():\n    \"\"\"主函数\"\"\"\n    print(\"定时任务设置工具\")\n    print(\"=\" * 60)\n    print(f\"时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n    print(f\"项目: {PROJECT_ROOT}\")\n    print()\n    \n    # 1. 创建定时任务脚本\n    created_scripts = create_cron_scripts()\n    \n    # 2. 生成crontab配置\n    crontab_path = generate_crontab_config()\n    \n    # 3. 创建安装指南\n    guide_path = create_install_guide()\n    \n    # 4. 总结\n    print(\"\\n\" + \"=\" * 60)\n    print(\"定时任务设置完成\")\n    print(\"=\" * 60)\n    \n    print(\"\\n✅ 已完成:\")\n    print(f\"1. 创建 {len(created_scripts)} 个定时任务脚本\")\n    print(f\"2. 生成crontab配置: {crontab_path.name}\")\n    print(f\"3. 创建安装指南: {guide_path.name}\")\n    \n    print(\"\\n📋 定时任务详情:\")\n    for script_path, description in created_scripts:\n        print(f\"  - {script_path.name}: {description}\")\n    \n    print(\"\\n🚀 安装步骤:\")\n    print(\"1. 备份当前crontab: crontab -l > ~/crontab_backup.bak\")\n    print(\"2. 添加定时任务: crontab -e\")\n    print(\"3. 粘贴配置内容（见 crontab_config.txt）\")\n    print(\"4. 保存并退出\")\n    \n    print(f\"\\n📖 详细指南: {guide_path}\")\n    print(f\"📅 完成时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n\nif __name__ == \"__main__\":\n    main()"}],"isError":false,"timestamp":1776561841537}}
