h.write_text(json.dumps(data, ensure_ascii=False, indent=2) + '\\n', encoding='utf-8')\nprint('UPDATED')\nPY\npython3 - <<'PY'\nimport json\nfrom pathlib import Path\njob_id = '55a9fce0-aec0-4dbc-b7cc-c7066c77d995'\ndata = json.loads(Path('/Users/ling/.openclaw/cron/jobs.json').read_text(encoding='utf-8'))\nfor job in data.get('jobs', []):\n    if job.get('id') == job_id:\n        print(job['payload']['message'])\n        break\nPY","workdir":"/Users/ling/.openclaw/workspace/coding-agent","timeout":30,"yieldMs":1000},"partialJson":"{\"command\":\"set -e\\npython3 - <<'PY'\\nimport json, time\\nfrom pathlib import Path\\njobs_path = Path('/Users/ling/.openclaw/cron/jobs.json')\\ndata = json.loads(jobs_path.read_text(encoding='utf-8'))\\njob_id = '55a9fce0-aec0-4dbc-b7cc-c7066c77d995'\\nnew_message = '''执行以下自动更新检查并推送摘要：\\n\\n1. 运行：`python3 /Users/ling/.openclaw/workspace/scripts/skill_update_check.py --auto-update-safe`\\n   这个脚本现在会：\\n   - 扫描真实 skills 根目录，而不是只看单一路径\\n   - 明确区分：ClawHub 托管 / 本地技能 / 扩展技能 / OpenClaw 内置 / ACPX 内置 / 记录缺失\\n   - 对安全可处理的 ClawHub 技能直接执行 `clawhub update <slug>`\\n   - 遇到本地 hash 不匹配、suspicious、敏感代码时，不覆盖，只标记 review / 保留本地\\n   - 额外检查 OpenClaw 当前版本与 npm 最新版本（包名：`openclaw`，不是 `clawhub`）\\n\\n2. 输出摘要时必须说清楚：\\n   - 哪些技能已自动更新\\n   - 哪些因为本地变更而跳过\\n   - 哪些只是本地已安装（内置 / 扩展 / 本地），不能再误报“未安装”\\n   - 哪些是 clawhub 记录漂移 / 本地缺失\\n   - OpenClaw 是否值得升级\\n\\n3. 推送摘要要短，但结论必须明确；不要再把“本地存在但不在 clawhub 托管目录”的技能说成未安装。'''\\nchanged = False\\nfor job in data.get('jobs', []):\\n    if isinstance(job, dict) and job.get('id') == job_id:\\n        job.setdefault('payload', {})['message'] = new_message\\n        job['updatedAtMs'] = int(time.time() * 1000)\\n        changed = True\\n        break\\nif not changed:\\n    raise SystemExit('JOB_NOT_FOUND')\\njobs_path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + '\\\\n', encoding='utf-8')\\nprint('UPDATED')\\nPY\\npython3 - <<'PY'\\nimport json\\nfrom pathlib import Path\\njob_id = '55a9fce0-aec0-4dbc-b7cc-c7066c77d9