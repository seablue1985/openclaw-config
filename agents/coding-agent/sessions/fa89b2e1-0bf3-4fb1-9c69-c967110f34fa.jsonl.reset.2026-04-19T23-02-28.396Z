原因: {item['reason']}\\\\n\\\\n\\\"\\n173:            message += f\\\"{emoji} {item['symbol']} {item['name']}\\\\n\\\"\\n174:            message += f\\\"   建议买入价: {item['price']:.2f}\\\\n\\\"\\n175:            message += f\\\"   预算: {item.get('budget', 150000):.0f}\\\\n\\\"\\n176:            message += f\\\"   原因: {item['reason']}\\\\n\\\\n\\\"\\n178:    # 发送飞书消息\\n179:    print(f\\\"\\\\n📤 推送飞书: {title}\\\")\\n180:    print(message)\\n182:    # 使用openclaw message工具发送\\n184:        from openclaw_tools import message\\n185:        # 简化消息格式用于推送\\n199:        print(\\\"✅ 飞书推送完成\\\")\\n202:        print(f\\\"⚠️ 飞书推送失败: {e}\\\")\\n346:    # 如果有卖出信号，立即推送\\n349:        print(\\\"🚨 检测到卖出信号！推送飞书通知...\\\")\\n350:        push_signal_to_feishu(\\\"SELL\\\", sell_list)\\n352:    # 如果有买入信号，立即推送\\n355:        print(\\\"🛒 检测到买入信号！推送飞书通知...\\\")\\n356:        push_signal_to_feishu(\\\"BUY\\\", buy_list)\\n\\n### FILE: /Users/ling/.openclaw/workspace/scripts/lt_stock_forecast.py\\n6:- 推送：飞书 DM（张玲）\\n21:FEISHU_WEBHOOK = \\\"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\\\"\\n294:def send_feishu(text: str) -> bool:\\n297:        resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\\n300:        print(f\\\"Webhook error: {e}\\\")\\n335:    # 5. 发飞书\\n336:    ok = send_feishu(report_text)\\n338:        print(f\\\"✅ 飞书消息已发送\\\")\\n340:        print(f\\\"⚠️ 飞书发送失败（报告已本地保存）\\\")\"\n        }\n      ],\n      \"isError\": false,\n      \"timestamp\": 1776561892581,\n      \"__openclaw\": {\n        \"id\": \"c2eae870\",\n        \"seq\": 22\n      }\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": [\n        {\n          \"type\": \"thinking\",\n          \"thinking\": \"\"\n        },\n        {\n          \"type\": \"toolCall\",\n          \"id\": \"call_yD01OOO3OUdApGnjhKPzkRse|fc_0b3ac7b405e714490169e42eefbb94819a8303886e3d910bc7\",\n          \"name\": \"read\",\n          \"arguments\": {\n            \"path\": \"/Users/lin