) / \\\\\\\".openclaw\\\\\\\" / \\\\\\\"workspace\\\\\\\"\\\\nREPORT_DIR = WORKSPACE / \\\\\\\"research\\\\\\\" / \\\\\\\"reports\\\\\\\"\\\\nCONFIG_FILE = WORKSPACE / \\\\\\\"config\\\\\\\" / \\\\\\\"investment_research_delivery_v1.json\\\\\\\"\\\\nSTATE_FILE = WORKSPACE / \\\\\\\"memory\\\\\\\" / \\\\\\\"investment_research_paper_execution_push_state.json\\\\\\\"\\\\nOPENCLAW_BIN_CANDIDATES = [\\\\n    str(Path.home() / \\\\\\\".local\\\\\\\" / \\\\\\\"share\\\\\\\" / \\\\\\\"fnm\\\\\\\" / \\\\\\\"aliases\\\\\\\" / \\\\\\\"default\\\\\\\" / \\\\\\\"bin\\\\\\\" / \\\\\\\"openclaw\\\\\\\"),\\\\n    shutil.which(\\\\\\\"openclaw\\\\\\\") or \\\\\\\"\\\\\\\",\\\\n    \\\\\\\"openclaw\\\\\\\",\\\\n]\\\\n\\\\n\\\\ndef now_str() -> str:\\\\n    return datetime.now().strftime(\\\\\\\"%Y-%m-%d %H:%M:%S\\\\\\\")\\\\n\\\\n\\\\ndef default_date_tag() -> str:\\\\n    return datetime.now().strftime(\\\\\\\"%Y%m%d\\\\\\\")\\\\n\\\\n\\\\ndef load_json(path: Path) -> dict[str, Any]:\\\\n    if not path.exists():\\\\n        return {}\\\\n    try:\\\\n        return json.loads(path.read_text(encoding=\\\\\\\"utf-8\\\\\\\"))\\\\n    except Exception:\\\\n        return {}\\\\n\\\\n\\\\ndef write_json(path: Path, payload: dict[str, Any]) -> None:\\\\n    path.parent.mkdir(parents=True, exist_ok=True)\\\\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + \\\\\\\"\\\\\\\\n\\\\\\\", encoding=\\\\\\\"utf-8\\\\\\\")\\\\n\\\\n\\\\ndef read_csv_rows(path: Path) -> list[dict[str, str]]:\\\\n    if not path.exists():\\\\n        return []\\\\n    with path.open(\\\\\\\"r\\\\\\\", encoding=\\\\\\\"utf-8-sig\\\\\\\", newline=\\\\\\\"\\\\\\\") as handle:\\\\n        return list(csv.DictReader(handle))\\\\n\\\\n\\\\ndef resolve_openclaw_bin() -> str:\\\\n    for candidate in OPENCLAW_BIN_CANDIDATES:\\\\n        if candidate and Path(candidate).exists():\\\\n            return candidate\\\\n    for candidate in OPENCLAW_BIN_CANDIDATES:\\\\n        if candidate:\\\\n            return candidate\\\\n    return \\\\\\\"openclaw\\\\\\\"\\\\n\\\\n\\\\ndef run_cmd(cmd: list[str], timeout: int = 120) -> tuple[int, str, str]:\\\\n    try:\\\\n        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)\\\\n        return proc.returncode, proc.stdout or \\\\\\\"\\\\\\\", proc.stderr or \\\\\\\"\\\\\\\"\\\\n    except FileNotFoundError as exc:\\\\n        return 127, \\\\\\\"\\\\\\\", str(exc)\\\\n    except subprocess.TimeoutExpired as exc:\\\\n        return 124, exc.stdout or \\\\\\\"\\\\\\\", exc.stderr or f\\\\\\\"timeout after {timeout}s\\\\\\\"\\\\n\\\\n\\\\ndef selected_targets(config: dict[str, Any]) -> list[tuple[str, dict[str, Any]]]:\\\\n    targets = config.get(\\\\\\\"targets\\\\\\\", {})\\\\n    mode = str(config.get(\\\\\\\"deliveryMode\\\\\\\") or \\\\\\\"dm_and_group\\\\\\\")\\\\n    ordered_names = [\\\\\\\"dm\\\\\\\"] if mode == \\\\\\\"dm\\\\\\\" else [\\\\\\\"group\\\\\\\"] if mode == \\\\\\\"group\\\\\\\" else [\\\\\\\"dm\\\\\\\", \\\\\\\"group\\\\\\\"]\\\\n\\\\n    result: list[tuple[str, dict[str, Any]]] = []\\\\n    for name in ordered_names:\\\\n        payload = targets.get(name)\\\\n        if isinstance(payload, dict) and payload.get(\\\\\\\"enabled\\\\\\\", True):\\\\n            result.append((name, payload))\\\\n    if result:\\\\n        return result\\\\n\\\\n    for name, payload in targets.items():\\\\n        if isinstance(payload, dict) and payload.get(\\\\\\\"enabled\\\\\\\", True):\\\\n            result.append((str(name), payload))\\\\n    return result\\\\n\\\\n\\\\ndef normalized_code(value: str) -> str:\\\\n    return value.replace(\\\\\\\".XSHE\\\\\\\", \\\\\\\".SZ\\\\\\\").replace(\\\\\\\".XSHG\\\\\\\", \\\\\\\".SH\\\\\\\")\\\\n\\\\n\\\\n@functools.lru_cache(maxsize=200)\\\\ndef _stock_name_from_cache(code: str) -> str:\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"通过 akshare 实时查询股票名称，带 LRU 缓存。\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    try:\\\\n        import akshare as ak\\\\n        sym = code.replace(\\\\\\\".SZ\\\\\\\", \\\\\\\"\\\\\\\").replace(\\\\\\\".SH\\\\\\\", \\\\\\\"\\\\\\\")\\\\n        suffix = \\\\\\\"sz\\\\\\\" if code.endswith(\\\\\\\".SZ\\\\\\\") else \\\\\\\"sh\\\\\\\"\\\\n        df = ak.stock_individual_info_em(symbol=sym)\\\\n        for _, row in df.iterrows():\\\\n            val = str(row.get(\\\\\\\"item\\\\\\\", \\\\\\\"\\\\\\\")).strip()\\\\n            if val in (\\\\\\\"股票简称\\\\\\\", \\\\\\\"证券简称\\\\\\\", \\\\\\\"公司简称\\\\\\\"):\\\\n                name = str(row.get(\\\\\\\"value\\\\\\\", \\\\\\\"\\\\\\\")).strip()\\\\n                if name:\\\\n                    return name\\\\n        return \\\\\\\"\\\\\\\"\\\\n    except Exception:\\\\n        return \\\\\\\"\\\\\\\"\\\\n\\\\n\\\\ndef _enrich_name(code: str, name_map: dict[str, str]) -> str:\\\\n    \\\\\\\"\\\\\\\"\\\\\\\"返回 '名称[代码]'，若无名称则只返回代码。\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    if not code or code == \\\\\\\"-\\\\\\\":\\\\n        return code\\\\n    name = name_map.get(code, \\\\\\\"\\\\\\\")\\\\n    return f\\\\\\\"{name}[{code}]\\\\\\\" if name else code\\\\n\\\\n\\\\ndef build_candidate_lines(order_rows: list[dict[str, str]], name_map: dict[str, str]) -> list[str]:\\\\n   \\\\n…(truncated)…\\\"}],\\\"isError\\\":false,\\\"timestamp\\\":1776561917331,\\\"__openclaw\\\":{\\\"id\\\":\\\"8a0a9ee7\\\",\\\"seq\\\":28}},{\\\"role\\\":\\\"toolResult\\\",\\\"toolCallId\\\":\\\"call_s4dWTcNG725PD58kcjf2boI5|fc_0b3ac7b405e714490169e42efcd560819a8988301a5261fc12\\\",\\\"toolName\\\":\\\"read\\\",\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"#!/usr/bin/env python3\\\\nfrom __future__ import annotations\\\\n\\\\nimport argparse\\\\nimport json\\\\nimport shutil\\\\nimport subprocess\\\\nfrom datetime import datetime\\\\nfrom pathlib import Path\\\\nfrom typing import Any\\\\n\\\\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\\\\nREPORT_DIR = PROJECT_ROOT / \\\\\\\"research\\\\\\\" / \\\\\\\"reports\\\\\\\"\\\\nSTATE_PATH = REPORT_DIR / \\\\\\\"control_tower_alert_state.json\\\\\\\"\\\\nCONTROL_TOWER_PATH = REPORT_DIR / \\\\\\\"control_tower_daily_latest.json\\\\\\\"\\\\nPERF_PANEL_PATH = REPORT_DIR / \\\\\\\"strategy_performance_panel_latest.json\\\\\\\"\\\\n\\\\nSTATUS_RANK = {\\\\\\\"NO_DATA\\\\\\\": 0, \\\\\\\"GREEN\\\\\\\": 1, \\\\\\\"YELLOW\\\\\\\": 2, \\\\\\\"RED\\\\\\\": 3}\\\\n\\\\n\\\\ndef load_json(path: Path) -> dict[str, Any]:\\\\n    if not path.exists():\\\\n        return {}\\\\n    return json.loads(path.read_text(encoding=\\\\\\\"utf-8\\\\\\\"))\\\\n\\\\n\\\\ndef write_json(path: Path, payload: dict[str, Any]) -> None:\\\\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\\\\\\\"utf-8\\\\\\\")\\\\n\\\\n\\\\ndef worse_than(prev: str, cur: str) -> bool:\\\\n    return STATUS_RANK.get(cur, 0) > STATUS_RANK.get(prev, 0)\\\\n\\\\n\\\\ndef push_feishu(message: str) -> tuple[bool, str]:\\\\n    openclaw_bin = shutil.which(\\\\\\\"openclaw\\\\\\\")\\\\n    if not openclaw_bin:\\\\n        return False, \\\\\\\"openclaw_cli_missing\\\\\\\"\\\\n    cmd = [\\\\n        openclaw_bin,\\\\n        \\\\\\\"message\\\\\\\",\\\\n        \\\\\\\"send\\\\\\\",\\\\n        \\\\\\\"--channel\\\\\\\",\\\\n        \\\\\\\"feishu\\\\\\\",\\\\n        \\\\\\\"--account\\\\\\\",\\\\n        \\\\\\\"main\\\\\\\",\\\\n        \\\\\\\"--target\\\\\\\",\\\\n        \\\\\\\"user:ou_968a615509dc191f04220e18cda67080\\\\\\\",\\\\n        \\\\\\\"-m\\\\\\\",\\\\n        message,\\\\n    ]\\\\n    try:\\\\n        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=120)\\\\n    except Exception as exc:\\\\n        return False, f\\\\\\\"push_failed:{exc}\\\\\\\"\\\\n    detail = ((proc.stdout or \\\\\\\"\\\\\\\").strip() or (proc.stderr or \\\\\\\"\\\\\\\").strip())[-2000:]\\\\n    return proc.returncode == 0, detail\\\\n\\\\n\\\\ndef build_snapshot(control: dict[str, Any], perf: dict[str, Any]) -> dict[str, Any]:\\\\n    profiles = {}\\\\n    for row in perf.get(\\\\\\\"rows\\\\\\\", []):\\\\n        slug = str(row.get(\\\\\\\"profile_slug\\\\\\\") or \\\\\\\"\\\\\\\").strip()\\\\n        if not slug:\\\\n            continue\\\\n        profiles[slug] = {\\\\n            \\\\\\\"status\\\\\\\": str(row.get(\\\\\\\"status\\\\\\\") or \\\\\\\"NO_DATA\\\\\\\"),\\\\n            \\\\\\\"tomorrow_mode\\\\\\\": str(row.get(\\\\\\\"tomorrow_mode\\\\\\\") or \\\\\\\"-\\\\\\\"),\\\\n            \\\\\\\"issue_codes\\\\\\\": str(row.get(\\\\\\\"issue_codes\\\\\\\") or \\\\\\\"\\\\\\\"),\\\\n            \\\\\\\"nav\\\\\\\": row.get(\\\\\\\"nav\\\\\\\"),\\\\n            \\\\\\\"total_return_pct\\\\\\\": row.get(\\\\\\\"total_return_pct\\\\\\\"),\\\\n        }\\\\n    return {\\\\n        \\\\\\\"captured_at\\\\\\\": datetime.now().strftime(\\\\\\\"%Y-%m-%d %H:%M:%S\\\\\\\"),\\\\n        \\\\\\\"overall_status\\\\\\\": str(control.get(\\\\\\\"overall_status\\\\\\\") or \\\\\\\"NO_DATA\\\\\\\"),\\\\n        \\\\\\\"system_health_status\\\\\\\": str(control.get(\\\\\\\"system_health_status\\\\\\\") or control.get(\\\\\\\"overall_status\\\\\\\") or \\\\\\\"NO_DATA\\\\\\\"),\\\\n        \\\\\\\"strategy_portfolio_status\\\\\\\": str((control.get(\\\\\\\"strategy_layer\\\\\\\") or {}).get(\\\\\\\"guard_portfolio_status\\\\\\\") or \\\\\\\"NO_DATA\\\\\\\"),\\\\n        \\\\\\\"strategy_risk_mode\\\\\\\": str((control.get(\\\\\\\"strategy_layer\\\\\\\") or {}).get(\\\\\\\"risk_mode\\\\\\\") or \\\\\\\"-\\\\\\\"),\\\\n        \\\\\\\"strategy_trading_status\\\\\\\": str((control.get(\\\\\\\"strategy_layer\\\\\\\") or {}).get(\\\\\\\"trading_status\\\\\\\") or \\\\\\\"-\\\\\\\"),\\\\n        \\\\\\\"strategy_halt_count\\\\\\\": int((control.get(\\\\\\\"strategy_layer\\\\\\\") or {}).get(\\\\\\\"guard_halt_count\\\\\\\") or 0),\\\\n        \\\\\\\"execution_risk_level\\\\\\\": str((control.get(\\\\\\\"execution_layer\\\\\\\") or {}).get(\\\\\\\"live_risk_level\\\\\\\") or \\\\\\\"NO_DATA\\\\\\\"),\\\\n        \\\\\\\"execution_trading_status\\\\\\\": str((control.get(\\\\\\\"execution_layer\\\\\\\") or {}).get(\\\\\\\"trading_status\\\\\\\") or \\\\\\\"-\\\\\\\"),\\\\n        \\\\\\\"execution_orders_total\\\\\\\": int((control.get(\\\\\\\"execution_layer\\\\\\\") or {}).get(\\\\\\\"live_orders_total\\\\\\\") or 0),\\\\n        \\\\\\\"execution_journal_records\\\\\\\": int((control.get(\\\\\\\"execution_layer\\\\\\\") or {}).get(\\\\\\\"live_journal_records\\\\\\\") or 0),\\\\n        \\\\\\\"profiles\\\\\\\": profiles,\\\\n    }\\\\n\\\\n\\\\ndef main() -> None:\\\\n    parser = argparse.ArgumentParser(description=\\\\\\\"控制塔状态变化告警\\\\\\\")\\\\n    parser.add_argument(\\\\\\\"--force\\\\\\\", action=\\\\\\\"store_true\\\\\\\")\\\\n    args = parser.parse_args()\\\\n\\\\n    control = load_json(CONTROL_TOWER_PATH)\\\\n    perf = load_json(PERF_PANEL_PATH)\\\\n    if not control or not perf:\\\\n        payload = {\\\\\\\"status\\\\\\\": \\\\\\\"SKIPPED\\\\\\\", \\\\\\\"reason\\\\\\\": \\\\\\\"missing_control_tower_or_perf_panel\\\\\\\"}\\\\n        print(json.dumps(payload, ensure_ascii=False, indent=2))\\\\n        return\\\\n\\\\n    current = build_snapshot(control, perf)\\\\n    previous = load_json(STATE_PATH)\\\\n    has_previous = STATE_PATH.\\\\n…(truncated)…\\\"}],\\\"isError\\\":false,\\\"timestamp\\\":1776561917339,\\\"__openclaw\\\":{\\\"id\\\":\\\"e263f89f\\\",\\\"seq\\\":29}},{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\" 我查了，不是你“手动发起了定时回测”，而是这台机器的 crontab 里本来就挂着一串自动任务。\\\\n\\\\n跟你说的“回测/模拟盘推送”最相关的，主要有这几类：\\\\n\\\\n1. 08:25、13:30、14:30、16:05 跑三盘模拟执行/复检  \\\\n2. 08:30 跑进取宽度策略模拟盘  \\\\n3. 08:40 生成今日策略报告  \\\\n4. 09:35 跑盘前强检  \\\\n5. 另外还有 09:15 的利通电子盘前预判、以及盘中每 30 分钟一次的 aggressive 信号检测\\\\n\\\\n所以它的“用途”本质上不是你手动回测，而是自动给你发：\\\\n- 模拟盘执行回报\\\\n- 盘前/盘中风控提醒\\\\n- 候选股或信号摘要\\\\n- 某些专题股票预判\\\\n\\\\n但实话实说：如果你现在并不依赖这些模拟盘/研究链路做决策，那这些推送对你就是噪音，不是刚需。\\\\n\\\\n而且我顺手看了下，里面有几条链路最近还在报错，比如：\\\\n- 读数据文件权限被拒绝\\\\n- 某些 summary 文件缺失\\\\n- aggressive 那条飞书推送模块本身也失败过\\\\n\\\\n也就是说，它现在更像“遗留自动实验任务”，不是一套干净、稳定、只推有用信息的