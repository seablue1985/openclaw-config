sh_control_tower_alert_if_changed.py\",\"offset\":1,\"limit\":260}"}],"api":"openai-responses","provider":"beecode","model":"gpt-5.4","usage":{"input":60728,"output":444,"cacheRead":0,"cacheWrite":0,"totalTokens":61172,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776561904489,"responseId":"resp_0b3ac7b405e714490169e42ef23cbc819ab81b727ccb2ef371"}}
{"type":"message","id":"8a0a9ee7","parentId":"ba0dfb1e","timestamp":"2026-04-19T01:25:17.339Z","message":{"role":"toolResult","toolCallId":"call_9szGYg7isWMa56YZd6ubYiWL|fc_0b3ac7b405e714490169e42efcd550819aa9c66db8798c68da","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport csv\nimport functools\nimport hashlib\nimport json\nimport re\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nWORKSPACE = Path.home() / \".openclaw\" / \"workspace\"\nREPORT_DIR = WORKSPACE / \"research\" / \"reports\"\nCONFIG_FILE = WORKSPACE / \"config\" / \"investment_research_delivery_v1.json\"\nSTATE_FILE = WORKSPACE / \"memory\" / \"investment_research_paper_execution_push_state.json\"\nOPENCLAW_BIN_CANDIDATES = [\n    str(Path.home() / \".local\" / \"share\" / \"fnm\" / \"aliases\" / \"default\" / \"bin\" / \"openclaw\"),\n    shutil.which(\"openclaw\") or \"\",\n    \"openclaw\",\n]\n\n\ndef now_str() -> str:\n    return datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n\ndef default_date_tag() -> str:\n    return datetime.now().strftime(\"%Y%m%d\")\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    try:\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return {}\n\n\ndef write_json(path: Path, payload: dict[str, Any]) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n\n\ndef read_csv_rows(path: Path) -> list[dict[str, str]]:\n    if not path.exists():\n        return []\n    with path.open(\"r\", encoding=\"utf-8-sig\", newline=\"\") as handle:\n        return list(csv.DictReader(handle))\n\n\ndef resolve_openclaw_bin() -> str:\n    for candidate in OPENCLAW_BIN_CANDIDATES:\n        if candidate and Path(candidate).exists():\n            return candidate\n    for candidate in OPENCLAW_BIN_CANDIDATES:\n        if candidate:\n            return candidate\n    return \"openclaw\"\n\n\ndef run_cmd(cmd: list[str], timeout: int = 120) -> tuple[int, str, str]:\n    try:\n        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)\n        return proc.returncode, proc.stdout or \"\", proc.stderr or \"\"\n    except FileNotFoundError as exc:\n        return 127, \"\", str(exc)\n    except subprocess.TimeoutExpired as exc:\n        return 124, exc.stdout or \"\", exc.stderr or f\"timeout after {timeout}s\"\n\n\ndef selected_targets(config: dict[str, Any]) -> list[tuple[str, dict[str, Any]]]:\n    targets = config.get(\"targets\", {})\n    mode = str(config.get(\"deliveryMode\") or \"dm_and_group\")\n    ordered_names = [\"dm\"] if mode == \"dm\" else [\"group\"] if mode == \"group\" else [\"dm\", \"group\"]\n\n    result: list[tuple[str, dict[str, Any]]] = []\n    for name in ordered_names:\n        payload = targets.get(name)\n        if isinstance(payload, dict) and payload.get(\"enabled\", True):\n            result.append((name, payload))\n    if result:\n        return result\n\n    for name, payload in targets.items():\n        if isinstance(payload, dict) and payload.get(\"enabled\", True):\n            result.append((str(name), payload))\n    return result\n\n\ndef normalized_code(value: str) -> str:\n    return value.replace(\".XSHE\", \".SZ\").replace(\".XSHG\", \".SH\")\n\n\n@functools.lru_cache(maxsize=200)\ndef _stock_name_from_cache(code: str) -> str:\n    \"\"\"通过 akshare 实时查询股票名称，带 LRU 缓存。\"\"\"\n    try:\n        import akshare as ak\n        sym = code.replace(\".SZ\", \"\").replace(\".SH\", \"\")\n        suffix = \"sz\" if code.endswith(\".SZ\") else \"sh\"\n        df = ak.stock_individual_info_em(symbol=sym)\n        for _, row in df.iterrows():\n            val = str(row.get(\"item\", \"\")).strip()\n            if val in (\"股票简称\", \"证券简称\", \"公司简称\"):\n                name = str(row.get(\"value\", \"\")).strip()\n                if name:\n                    return name\n        return \"\"\n    except Exception:\n        return \"\"\n\n\ndef _enrich_name(code: str, name_map: dict[str, str]) -> str:\n    \"\"\"返回 '名称[代码]'，若无名称则只返回代码。\"\"\"\n    if not code or code == \"-\":\n        return code\n    name = name_map.get(code, \"\")\n    return f\"{name}[{code}]\" if name else code\n\n\ndef build_candidate_lines(order_rows: list[dict[str, str]], name_map: dict[str, str]) -> list[str]:\n    seen: set[tuple[str, str]] = set()\n    per_slot_count: dict[str, int] = {}\n    result: list[str] = []\n    for row in order_rows:\n        slot_label = str(row.get(\"slot_label\") or \"-\")\n        code = normalized_code(str(row.get(\"ts_code\") or \"-\"))\n        pair = (slot_label, code)\n        if pair in seen:\n            continue\n        if per_slot_count.get(slot_label, 0) >= 2:\n            continue\n        seen.add(pair)\n        per_slot_count[slot_label] = per_slot_count.get(slot_label, 0) + 1\n        result.append(f\"{slot_label} {_enrich_name(code, name_map)}\")\n        if len(result) >= 6:\n            break\n    return result\n\n\ndef build_message(summary: dict[str, Any], trades_rows: list[dict[str, str]], order_rows: list[dict[str, str]]) -> str:\n    totals = summary.get(\"totals\", {}) if isinstance(summary.get(\"totals\"), dict) else {}\n    profiles = summary.get(\"profiles\", []) if isinstance(summary.get(\"profiles\"), list) else []\n\n    # 预先构建所有涉及的股票代码 → 名称映射\n    all_codes: set[str] = set()\n    for row in list(trades_rows) + list(order_rows):\n        for field in (\"ts_code\", \"symbol\"):\n            code = normalized_code(str(row.get(field) or \"\"))\n            if code:\n                all_codes.add(code)\n    name_map: dict[str, str] = {code: _stock_name_from_cache(code) for code in all_codes}\n\n    lines = [\n        f\"📘 三盘模拟执行回报｜{summary.get('date_tag') or default_date_tag()}\",\n        f\"- 汇总净值：{totals.get('nav', '-')}\",\n        f\"- 当前持仓数：{totals.get('position_count', '-')}\",\n        f\"- 实际成交笔数：{totals.get('trade_count', '-')}\",\n        f\"- 通过门控买单：{totals.get('pass_buy_count', '-')}\",\n        f\"- 被拦截买单：{totals.get('blocked_buy_count', '-')}\",\n    ]\n\n    for profile in profiles:\n        if not isinstance(profile, dict):\n            continue\n        stats = profile.get(\"stats\", {}) if isinstance(profile.get(\"stats\"), dict) else {}\n        account = profile.get(\"account\", {}) if isinstance(profile.get(\"account\"), dict) else {}\n        slot_label = str(profile.get(\"slot_label\") or profile.get(\"profile_slug\") or \"-\")\n        profile_name = str(profile.get(\"profile_name\") or profile.get(\"profile_slug\") or \"-\")\n        lines.append(\n            f\"- {slot_label} {profile_name}：持仓 {account.get('position_count', 0)}，买入候选 {stats.get('buy_count', 0)}，\"\n            f\"卖出候选 {stats.get('sell_count', 0)}，模式 {stats.get('mode', '-')}\"\n        )\n        if stats.get(\"halt_new_buy\"):\n            lines.append(f\"  原因：暂停新开仓，{stats.get('halt_reason') or '未提供原因'}\")\n\n    if trades_rows:\n        lines.append(\"- 实际成交：\")\n        for row in trades_rows[:8]:\n            action = str(row.get(\"action\") or row.get(\"side\") or \"-\").upper()\n            slot_label = str(row.get(\"slot_label\") or row.get(\"profile_slug\") or \"-\")\n            code = normalized_code(str(row.get(\"ts_code\") or row.get(\"symbol\") or \"-\"))\n            qty = row.get(\"shares\") or row.get(\"quantity\") or row.get(\"filled_qty\") or \"-\"\n            price = row.get(\"price\") or row.get(\"filled_price\") or row.get(\"avg_price\") or \"-\"\n            lines.append(f\"  {slot_label} {action} {_enrich_name(code, name_map)} {qty}股 @{price}\")\n    elif totals.get(\"blocked_buy_count\", 0):\n        candidates = build_candidate_lines(order_rows, name_map)\n        lines.append(\"- 今日没有形成实际买卖，原因是门控拦截了新增仓位。\")\n        if candidates:\n            lines.append(f\"- 被拦截候选：{'、'.join(candidates)}\")\n    else:\n        lines.append(\"- 今日没有形成实际买卖。\")\n\n    return \"\\n\".join(lines)\n\n\ndef dedupe_key(date_tag: str, target_name: str, target_value: str, message: str) -> str:\n    raw = json.dumps(\n        {\n            \"date_tag\": date_tag,\n            \"target_name\": target_name,\n            \"target_value\": target_value,\n            \"message\": message,\n        },\n        ensure_ascii=False,\n        sort_keys=True,\n    )\n    return hashlib.sha256(raw.encode(\"utf-8\")).hexdigest()\n\n\ndef send_payload(\n    *,\n    channel: str,\n    account: str,\n    target: str,\n    message: str,\n    dry_run: bool,\n) -> tuple[bool, str]:\n    cmd = [\n        resolve_openclaw_bin(),\n        \"message\",\n        \"send\",\n        \"--channel\",\n        channel,\n        \"--account\",\n        account,\n        \"--target\",\n        target,\n        \"-m\",\n        message,\n        \"--json\",\n    ]\n    if dry_run:\n        cmd.append(\"--dry-run\")\n    rc, out, err = run_cmd(cmd, timeout=180)\n    info = (out.strip() or err.strip())[-4000:]\n    return rc == 0, info\n\n\ndef main() -> int:\n    parser = argparse.ArgumentParser(description=\"Push paper execution summary to Feishu\")\n    parser.add_argument(\"--date-tag\", default=default_date_tag())\n    parser.add_argument(\"--dry-run\", action=\"store_true\")\n    parser.add_argument(\"--force\", action=\"store_true\")\n    args = parser.parse_args()\n\n    date_tag = str(args.date_tag)\n    config = load_json(CONFIG_FILE)\n    state = load_json(STATE_FILE)\n    state_deliveries = state.get(\"deliveries\", {}) if isinstance(state.get(\"deliveries\"), dict) else {}\n\n    summary_path = REPORT_DIR / f\"investment_research_paper_execution_summary_{date_tag}.json\"\n    summary = load_json(summary_path)\n    if not summary:\n        raise SystemExit(f\"missing paper execution summary: {summary_path}\")\n\n[83 more lines in file. Use offset=261 to continue.]"}],"isError":false,"timestamp":1776561917331}}
{"type":"message","id":"e263f89f","parentId":"8a0a9ee7","timestamp":"2026-04-19T01:25:17.349Z","message":{"role":"toolResult","toolCallId":"call_s4dWTcNG725PD58kcjf2boI5|fc_0b3ac7b405e714490169e42efcd560819a8988301a5261fc12","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Any\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nREPORT_DIR = PROJECT_ROOT / \"research\" / \"reports\"\nSTATE_PATH = REPORT_DIR / \"control_tower_alert_state.json\"\nCONTROL_TOWER_PATH = REPORT_DIR / \"control_tower_daily_latest.json\"\nPERF_PANEL_PATH = REPORT_DIR / \"strategy_performance_panel_latest.json\"\n\nSTATUS_RANK = {\"NO_DATA\": 0, \"GREEN\": 1, \"YELLOW\": 2, \"RED\": 3}\n\n\ndef load_json(path: Path) -> dict[str, Any]:\n    if not path.exists():\n        return {}\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef write_json(path: Path, payload: dict[str, Any]) -> None:\n    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n\n\ndef worse_than(prev: str, cur: str) -> bool:\n    return STATUS_RANK.get(cur, 0) > STATUS_RANK.get(prev, 0)\n\n\ndef push_feishu(message: str) -> tuple[bool, str]:\n    openclaw_bin = shutil.which(\"openclaw\")\n    if not openclaw_bin:\n        return False, \"openclaw_cli_missing\"\n    cmd = [\n        openclaw_bin,\n        \"message\",\n        \"send\",\n        \"--channel\",\n        \"feishu\",\n        \"--account\",\n        \"main\",\n        \"--target\",\n        \"user:ou_968a615509dc191f04220e18cda67080\",\n        \"-m\",\n        message,\n    ]\n    try:\n        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=120)\n    except Exception as exc:\n        return False, f\"push_failed:{exc}\"\n    detail = ((proc.stdout or \"\").strip() or (proc.stderr or \"\").strip())[-2000:]\n    return proc.returncode == 0, detail\n\n\ndef build_snapshot(control: dict[str, Any], perf: dict[str, Any]) -> dict[str, Any]:\n    profiles = {}\n    for row in perf.get(\"rows\", []):\n        slug = str(row.get(\"profile_slug\") or \"\").strip()\n        if not slug:\n            continue\n        profiles[slug] = {\n            \"status\": str(row.get(\"status\") or \"NO_DATA\"),\n            \"tomorrow_mode\": str(row.get(\"tomorrow_mode\") or \"-\"),\n            \"issue_codes\": str(row.get(\"issue_codes\") or \"\"),\n            \"nav\": row.get(\"nav\"),\n            \"total_return_pct\": row.get(\"total_return_pct\"),\n        }\n    return {\n        \"captured_at\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n        \"overall_status\": str(control.get(\"overall_status\") or \"NO_DATA\"),\n        \"system_health_status\": str(control.get(\"system_health_status\") or control.get(\"overall_status\") or \"NO_DATA\"),\n        \"strategy_portfolio_status\": str((control.get(\"strategy_layer\") or {}).get(\"guard_portfolio_status\") or \"NO_DATA\"),\n        \"strategy_risk_mode\": str((control.get(\"strategy_layer\") or {}).get(\"risk_mode\") or \"-\"),\n        \"strategy_trading_status\": str((control.get(\"strategy_layer\") or {}).get(\"trading_status\") or \"-\"),\n        \"strategy_halt_count\": int((control.get(\"strategy_layer\") or {}).get(\"guard_halt_count\") or 0),\n        \"execution_risk_level\": str((control.get(\"execution_layer\") or {}).get(\"live_risk_level\") or \"NO_DATA\"),\n        \"execution_trading_status\": str((control.get(\"execution_layer\") or {}).get(\"trading_status\") or \"-\"),\n        \"execution_orders_total\": int((control.get(\"execution_layer\") or {}).get(\"live_orders_total\") or 0),\n        \"execution_journal_records\": int((control.get(\"execution_layer\") or {}).get(\"live_journal_records\") or 0),\n        \"profiles\": profiles,\n    }\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"控制塔状态变化告警\")\n    parser.add_argument(\"--force\", action=\"store_true\")\n    args = parser.parse_args()\n\n    control = load_json(CONTROL_TOWER_PATH)\n    perf = load_json(PERF_PANEL_PATH)\n    if not control or not perf:\n        payload = {\"status\": \"SKIPPED\", \"reason\": \"missing_control_tower_or_perf_panel\"}\n        print(json.dumps(payload, ensure_ascii=False, indent=2))\n        return\n\n    current = build_snapshot(control, perf)\n    previous = load_json(STATE_PATH)\n    has_previous = STATE_PATH.exists() and bool(previous) and bool(previous.get(\"captured_at\"))\n\n    changed_reasons: list[str] = []\n    if args.force or not has_previous:\n        changed_reasons.append(\"INIT\")\n    else:\n        if current[\"system_health_status\"] != previous.get(\"system_health_status\"):\n            changed_reasons.append(f\"SYSTEM_HEALTH:{previous.get('system_health_status')}->{current['system_health_status']}\")\n        if current[\"strategy_portfolio_status\"] != previous.get(\"strategy_portfolio_status\"):\n            changed_reasons.append(\n                f\"PORTFOLIO:{previous.get('strategy_portfolio_status')}->{current['strategy_portfolio_status']}\"\n            )\n        if current[\"execution_risk_level\"] != previous.get(\"execution_risk_level\"):\n            changed_reasons.append(\n                f\"EXECUTION:{previous.get('execution_risk_level')}->{current['execution_risk_level']}\"\n            )\n\n        prev_profiles = previous.get(\"profiles\", {}) or {}\n        for slug, row in current[\"profiles\"].items():\n            prev_row = prev_profiles.get(slug, {}) or {}\n            prev_status = str(prev_row.get(\"status\") or \"NO_DATA\")\n            cur_status = str(row.get(\"status\") or \"NO_DATA\")\n            if worse_than(prev_status, cur_status):\n                changed_reasons.append(f\"PROFILE:{slug}:{prev_status}->{cur_status}\")\n            prev_mode = str(prev_row.get(\"tomorrow_mode\") or \"-\")\n            cur_mode = str(row.get(\"tomorrow_mode\") or \"-\")\n            if prev_mode != cur_mode and cur_mode == \"halt\":\n                changed_reasons.append(f\"MODE:{slug}:{prev_mode}->{cur_mode}\")\n\n    pushed = {\"ok\": False, \"detail\": \"unchanged\"}\n    if changed_reasons:\n        lines = [\n            f\"控制塔状态变化告警｜{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\",\n            f\"系统健康: {current['system_health_status']}（仅代表链路/报告健康，不代表市场看多）\",\n            f\"市场/策略: {current['strategy_portfolio_status']} / risk_mode={current['strategy_risk_mode']} / strategy_trading={current['strategy_trading_status']} / halt_count={current['strategy_halt_count']}\",\n            f\"交易执行: {current['execution_trading_status']} / risk={current['execution_risk_level']} / orders={current['execution_orders_total']} / journal={current['execution_journal_records']}\",\n            f\"变化原因: {', '.join(changed_reasons)}\",\n            \"profiles:\",\n        ]\n        for slug, row in current[\"profiles\"].items():\n            lines.append(\n                f\"- {slug}: {row['status']} / {row['tomorrow_mode']} / nav={row.get('nav')} / ret={row.get('total_return_pct')}% / issues={row.get('issue_codes') or 'none'}\"\n            )\n        lines.append(f\"控制塔: {CONTROL_TOWER_PATH}\")\n        lines.append(f\"收益面板: {REPORT_DIR / 'strategy_performance_panel_latest.html'}\")\n        pushed[\"ok\"], pushed[\"detail\"] = push_feishu(\"\\n\".join(lines))\n\n    state_payload = {\n        **current,\n        \"changed_reasons\": changed_reasons,\n        \"push\": pushed,\n    }\n    write_json(STATE_PATH, state_payload)\n    print(\n        json.dumps(\n            {\n                \"status\": \"PUSHED\" if changed_reasons and pushed[\"ok\"] else (\"CHANGED_NO_PUSH\" if changed_reasons else \"UNCHANGED\"),\n                \"changed_reasons\": changed_reasons,\n                \"state_path\": str(STATE_PATH),\n                \"push\": pushed,\n            },\n            ensure_ascii=False,\n            indent=2,\n        )\n    )\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1776561917339}}
