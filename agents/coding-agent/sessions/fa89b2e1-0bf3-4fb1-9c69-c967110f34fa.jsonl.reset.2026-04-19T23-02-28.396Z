iles_v1.sh\\\\n6:PUSH_SCRIPT=\\\\\\\"$WORKSPACE_ROOT/scripts/push_investment_research_paper_execution.py\\\\\\\"\\\\n61:if [[ $status -eq 0 && \\\\\\\"$RUN_HEAVY_REPORTS\\\\\\\" == \\\\\\\"1\\\\\\\" && -f \\\\\\\"$PUSH_SCRIPT\\\\\\\" ]]; then\\\\n62:  if ! \\\\\\\"$PYRUN\\\\\\\" \\\\\\\"$PUSH_SCRIPT\\\\\\\" --date-tag \\\\\\\"$DATE_TAG\\\\\\\"; then\\\\n63:    echo \\\\\\\"[WARN] paper execution push failed date=${DATE_TAG}\\\\\\\" >&2\\\\n71:  if ! \\\\\\\"$PYRUN\\\\\\\" scripts/push_control_tower_alert_if_changed.py; then\\\\n72:    echo \\\\\\\"[WARN] control tower alert push failed date=${DATE_TAG}\\\\\\\" >&2\\\\n\\\\n### FILE: /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/run_paper_trading_profiles_auto_v1.sh\\\\n\\\\n### FILE: /Users/ling/.openclaw/workspace/quant_projects/personal-a-share-research-system/scripts/cron_run_all_panels.sh\\\\n\\\\n### FILE: /Users/ling/.openclaw/workspace/coding-agent/run_aggressive_realtime_signal.py\\\\n3:Aggressive 18% 策略 - 实时买卖信号推送\\\\n4:当检测到买卖操作时，立即推送飞书通知\\\\n23:# 飞书推送配置\\\\n24:FEISHU_BOT_URL = \\\\\\\"\\\\\\\"  # 如果有自定义机器人URL可以填在这里\\\\n26:def send_feishu_message(message):\\\\n27:    \\\\\\\"\\\\\\\"\\\\\\\"发送飞书消息\\\\\\\"\\\\\\\"\\\\\\\"\\\\n29:        # 使用飞书机器人发送消息\\\\n33:        # 通过exec运行OpenClaw命令推送\\\\n34:        cmd = f'echo \\\\\\\\'{message}\\\\\\\\' | openclawctl message send --channel feishu --message -'\\\\n38:            print(f\\\\\\\"✅ 飞书消息发送成功\\\\\\\")\\\\n41:            print(f\\\\\\\"⚠️ 飞书消息发送失败: {result.stderr}\\\\\\\")\\\\n44:        print(f\\\\\\\"⚠️ 飞书推送异常: {e}\\\\\\\")\\\\n145:def push_signal_to_feishu(signal_type, signals):\\\\n146:    \\\\\\\"\\\\\\\"\\\\\\\"推送信号到飞书\\\\\\\"\\\\\\\"\\\\\\\"\\\\n157:    message = f\\\\\\\"\\\\\\\"\\\\\\\"\\\\n166:            message += f\\\\\\\"{emoji} {item['symbol']} {item['name']}\\\\\\\\n\\\\\\\"\\\\n167:            message += f\\\\\\\"   卖出价: {item['price']:.2f}\\\\\\\\n\\\\\\\"\\\\n168:            message += f\\\\\\\"   数量: {item['quantity']}股\\\\\\\\n\\\\\\\"\\\\n169:            message += f\\\\\\\"   预估收益: {item['pnl_pct']:+.2f}%\\\\\\\\n\\\\\\\"\\\\n170:            message += f\\\\\\\"   原因: {item['reason']}\\\\\\\\n\\\\\\\\n\\\\\\\"\\\\n173:            message += f\\\\\\\"{emoji} {item['symbol']} {item['name']}\\\\\\\\n\\\\\\\"\\\\n174:            message += f\\\\\\\"   建议买入价: {item['price']:.2f}\\\\\\\\n\\\\\\\"\\\\n175:            message += f\\\\\\\"   预算: {item.get('budget', 150000):.0f}\\\\\\\\n\\\\\\\"\\\\n176:            message += f\\\\\\\"   原因: {item['reason']}\\\\\\\\n\\\\\\\\n\\\\\\\"\\\\n178:    # 发送飞书消息\\\\n179:    print(f\\\\\\\"\\\\\\\\n📤 推送飞书: {title}\\\\\\\")\\\\n180:    print(message)\\\\n182:    # 使用openclaw message工具发送\\\\n184:        from openclaw_tools import message\\\\n185:        # 简化消息格式用于推送\\\\n199:        print(\\\\\\\"✅ 飞书推送完成\\\\\\\")\\\\n202:        print(f\\\\\\\"⚠️ 飞书推送失败: {e}\\\\\\\")\\\\n346:    # 如果有卖出信号，立即推送\\\\n349:        print(\\\\\\\"🚨 检测到卖出信号！推送飞书通知...\\\\\\\")\\\\n350:        push_signal_to_feishu(\\\\\\\"SELL\\\\\\\", sell_list)\\\\n352:    # 如果有买入信号，立即推送\\\\n355:        print(\\\\\\\"🛒 检测到买入信号！推送飞书通知...\\\\\\\")\\\\n356:        push_signal_to_feishu(\\\\\\\"BUY\\\\\\\", buy_list)\\\\n\\\\n### FILE: /Users/ling/.openclaw/workspace/scripts/lt_stock_forecast.py\\\\n6:- 推送：飞书 DM（张玲）\\\\n21:FEISHU_WEBHOOK = \\\\\\\"https://open.feishu.cn/open-apis/bot/v2/hook/f54d31a7-226d-4fac-aeaf-44b84c5c85b7\\\\\\\"\\\\n294:def send_feishu(text: str) -> bool:\\\\n297:        resp = requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)\\\\n300:        print(f\\\\\\\"Webhook error: {e}\\\\\\\")\\\\n335:    # 5. 发飞书\\\\n336:    ok = send_feishu(report_text)\\\\n338:        print(f\\\\\\\"✅ 飞书消息已发送\\\\\\\")\\\\n340:        print(f\\\\\\\"⚠️ 飞书发送失败（报告已本地保存）\\\\\\\")\\\"\\n        }\\n      ],\\n      \\\"isError\\\": false,\\n      \\\"timestamp\\\": 1776561892581,\\n      \\\"__openclaw\\\": {\\n        \\\"id\\\": \\\"c2eae870\\\",\\n        \\\"seq\\\